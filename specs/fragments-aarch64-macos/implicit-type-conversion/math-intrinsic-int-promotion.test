// Test: math-intrinsic-int-promotion
function main() returns ExitCode
  var result = sqrt(16)
  return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #16
    arm64.scvtf d0, x0
    arm64.fsqrt d1, d0
    arm64.fcvtzs x1, d1
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, lt
    arm64.mov x4, #4294967295
    arm64.cmp x1, x4
    arm64.cset x5, gt
    arm64.orr x6, x3, x5
    arm64.cmp x6, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x1
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

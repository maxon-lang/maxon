// Test: expression-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
  return trunc(x)
end 'takeFloat'

function main() returns ExitCode
  var a = 20
  var b = 22
  return takeFloat(a + b)
end 'main'
---
ExitCode: 42
---
module {
  func @implicit-type-conversion.takeFloat(x: f64) -> i64 {
  entry:
    arm64.fcvtzs x0, d0
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #20
    arm64.mov x1, #22
    arm64.add x2, x0, x1
    arm64.scvtf d0, x2
    arm64.bl implicit-type-conversion.takeFloat
    arm64.mov x3, #0
    arm64.cmp x0, x3
    arm64.cset x4, lt
    arm64.mov x5, #4294967295
    arm64.cmp x0, x5
    arm64.cset x6, gt
    arm64.orr x7, x4, x6
    arm64.cmp x7, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

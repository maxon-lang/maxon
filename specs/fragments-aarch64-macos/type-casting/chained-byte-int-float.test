// Test: chained-byte-int-float

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var b = 25 as Byte
  var i = b as Integer
  var f = i as Float
  return trunc(f)
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #25
    arm64.mov x1, #255
    arm64.and x2, x0, x1
    arm64.scvtf d0, x2
    arm64.fcvtzs x3, d0
    arm64.mov x4, #0
    arm64.cmp x3, x4
    arm64.cset x5, lt
    arm64.mov x6, #4294967295
    arm64.cmp x3, x6
    arm64.cset x7, gt
    arm64.orr x8, x5, x7
    arm64.cmp x8, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x3
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

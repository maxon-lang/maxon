// Test: union-match-range.range-covers-all-associated
typealias Integer = int(i64.min to i64.max)

enum Mixed
  a(x Integer)
  b(y Integer)
  c(z Integer)
end 'Mixed'

function main() returns ExitCode
  var m = Mixed.b(42)
  match m 'check'
    a to c then return 1
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #42
    arm64.mov x0, #16
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.str x1, [x0, #0]
    arm64.mov x2, #42
    arm64.str x2, [x0, #8]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x5, [x4, #0]
    arm64.ldr x6, [x29, #-8]
    arm64.str x6, [x29, #-16]
    arm64.ldr x7, [x29, #-16]
    arm64.str x5, [x29, #-32]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x8, [x29, #-32]
    arm64.str x8, [x29, #-24]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.ldr x3, [x29, #-24]
    arm64.mov x4, #2
    arm64.cmp x3, x4
    arm64.cset x5, le
    arm64.and x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.merge
  check_0.case0:
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_28
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_28
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_30
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_30
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  check_0.merge:
  }
  func @__destruct_Mixed(ptr: i64) {
  entry:
    arm64.b __destruct_Mixed.done
  done:
    arm64.ret
  }
}

// Test: enum-exhaustive.float-backed-range
enum Threshold
    low = 0.1
    medium = 0.5
    high = 0.9
end 'Threshold'

function main() returns ExitCode
  var t = Threshold.medium
  match t 'check'
    low to high then return 1
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_0.5]
    arm64.fstr d0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.fldr d0, [x29, #-8]
    arm64.fldr d1, [__float_0.1]
    arm64.fcmp d0, d1
    arm64.cset x0, ge
    arm64.fldr d2, [x29, #-8]
    arm64.fldr d3, [__float_0.9]
    arm64.fcmp d2, d3
    arm64.cset x1, le
    arm64.and x2, x0, x1
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.merge
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

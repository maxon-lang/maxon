// Test: error.enum-not-exhaustive
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  match c 'check'
    Color.red then return 1
    Color.green then return 2
  end 'check'
end 'main'
---

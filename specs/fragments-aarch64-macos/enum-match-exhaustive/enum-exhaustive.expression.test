// Test: enum-exhaustive.expression
enum Status
    pending
    approved
    rejected
end 'Status'

function main() returns ExitCode
  var s = Status.approved
  let code = match s 'eval'
    Status.pending gives 0
    Status.approved to Status.rejected gives 1
  end 'eval'
  return code
end 'main'
---
ExitCode: 1
---

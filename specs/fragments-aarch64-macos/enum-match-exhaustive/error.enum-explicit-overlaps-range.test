// Test: error.enum-explicit-overlaps-range
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  match c 'check'
    red to blue then return 1
    green then return 2
  end 'check'
end 'main'
---

// Test: enum-exhaustive.upto-range
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.red
  match c 'check'
    red upto blue then return 1
    blue then return 2
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #2
    arm64.cmp x3, x4
    arm64.cset x5, lt
    arm64.and x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case1
    arm64.b main.check_0.merge
  check_0.case1:
    arm64.mov x0, #2
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

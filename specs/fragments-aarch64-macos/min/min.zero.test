// Test: min.zero
function main() returns ExitCode
  var x = min(0.0, 5.0)
  if x == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @min.main() -> u32 {
  entry:
    arm64.fldr d0, [__float_0]
    arm64.fldr d1, [__float_5]
    arm64.fmin d2, d0, d1
    arm64.fldr d3, [__float_0]
    arm64.fcmp d2, d3
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne min.main.check_0
    arm64.b min.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

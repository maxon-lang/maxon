// Test: float.clone
function main() returns ExitCode
  var x = 3.14
  var y = x.clone()
  if y == 3.14 'ok'
    return 1
  end 'ok'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-cloneable.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_3.14]
    arm64.bl stdlib.float.clone
    arm64.fldr d1, [__float_3.14]
    arm64.fcmp d0, d1
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne primitive-cloneable.main.ok_0
    arm64.b primitive-cloneable.main.ok_0.after
  ok_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  ok_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

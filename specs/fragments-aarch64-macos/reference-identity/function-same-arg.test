    arm64.str x1, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.mov x0, x2
    arm64.epilogue stack_size=48
    arm64.ret
  }

// Test: function-same-arg
typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer

  static function create(value Integer) returns Self
  	return Self{value: value}
  end 'create'
end 'Box'

function areSame(a Box, b Box) returns bool
  return a is b
end 'areSame'

function main() returns ExitCode
  var x = Box.create(value: 42)
  var y = Box.create(value: 42)
  var result = 0
  if areSame(x, b: x) 'same'
    result = result + 1
  end 'same'
  if areSame(x, b: y) 'diff'
    result = result + 10
  end 'diff'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @reference-identity.areSame(a: i64, b: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.str x1, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.mov x0, x2
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #42
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #42
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.mov x4, #0
    arm64.str x4, [x29, #-24]
    arm64.add x5, x29, #-8
    arm64.mov x6, x5
    arm64.add x7, x29, #-8
    arm64.mov x8, x7
    arm64.mov x0, x6
    arm64.mov x1, x8
    arm64.bl reference-identity.areSame
    arm64.cmp x0, #0
    arm64.b.ne main.same_0
    arm64.b main.same_0.merge
  same_0:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.b main.same_0.merge
  same_0.merge:
    arm64.add x0, x29, #-8
    arm64.mov x1, x0
    arm64.add x2, x29, #-16
    arm64.mov x3, x2
    arm64.mov x0, x1
    arm64.mov x1, x3
    arm64.bl reference-identity.areSame
    arm64.cmp x0, #0
    arm64.b.ne main.diff_1
    arm64.b main.diff_1.merge
  diff_1:
    arm64.mov x0, #10
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.b main.diff_1.merge
  diff_1.merge:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_2
    arm64.b main.__range_ok_2
  __range_panic_2:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_2:
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

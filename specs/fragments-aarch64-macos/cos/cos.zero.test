// Test: cos.zero
function main() returns ExitCode
  var result = Math.cos(0.0)
  if result == 1.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @cos.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_0]
    arm64.bl stdlib.Math.cos
    arm64.fldr d1, [__float_1]
    arm64.fcmp d0, d1
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne cos.main.check_0
    arm64.b cos.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: char-literal-eq-codepoint
function main() returns ExitCode
  var cp = 45
  if cp == '-' 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @char-literal-to-int.main() -> u32 {
  entry:
    arm64.mov x0, #45
    arm64.mov x1, #45
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne char-literal-to-int.main.check_0
    arm64.b char-literal-to-int.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

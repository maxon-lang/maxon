// Test: char-literal-ge-le-codepoint
function main() returns ExitCode
  var cp = 53
  if cp >= '0' 'ge'
    if cp <= '9' 'le'
      return 0
    end 'le'
  end 'ge'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #53
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #48
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.cmp x2, #0
    arm64.b.ne main.ge_0
    arm64.b main.ge_0.merge
  ge_0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #57
    arm64.cmp x0, x1
    arm64.cset x2, le
    arm64.cmp x2, #0
    arm64.b.ne main.le_1
    arm64.b main.le_1.after
  le_1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  le_1.after:
    arm64.b main.ge_0.merge
  ge_0.merge:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: atan2.positive-y-axis
function main() returns ExitCode
  // π/2 ≈ 1.5708
  var angle = Math.atan2(1.0, x: 0.0)
  print("{angle}\n")
  // Should be approximately π/2
  if angle > 1.57 'check1'
    if angle < 1.58 'check2'
      return 0
    end 'check2'
  end 'check1'
  return 1
end 'main'

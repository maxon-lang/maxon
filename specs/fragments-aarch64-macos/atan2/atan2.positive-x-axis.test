// Test: atan2.positive-x-axis
function main() returns ExitCode
  var angle = Math.atan2(0.0, x: 1.0)
  if angle == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @atan2.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_0]
    arm64.fldr d1, [__float_1]
    arm64.bl stdlib.Math.atan2
    arm64.fldr d2, [__float_0]
    arm64.fcmp d0, d2
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne atan2.main.check_0
    arm64.b atan2.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

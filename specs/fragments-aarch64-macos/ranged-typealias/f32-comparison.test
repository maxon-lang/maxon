// Test: f32-comparison
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
  var a = F{3.0}
  var b = F{5.0}
  if a < b 'less'
    return 1
  end 'less'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.fldr d0, [__float_3]
    arm64.fldr d1, [__float_5]
    arm64.fcmp d0, d1
    arm64.cset x0, lt
    arm64.cmp x0, #0
    arm64.b.ne main.less_0
    arm64.b main.less_0.after
  less_0:
    arm64.mov x0, #1
    arm64.ret
  less_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

// Test: negative-range
typealias Temp = int(-50 to 50)

function main() returns ExitCode
  var t = Temp{-10}
  return t + 60
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #-10
    arm64.mov x1, #60
    arm64.mov x2, x0
    arm64.mov x3, x1
    arm64.add x4, x2, x3
    arm64.mov x5, #0
    arm64.sxtw x6, x4
    arm64.cmp x6, x5
    arm64.cset x7, lt
    arm64.mov x8, #4294967295
    arm64.sxtw x9, x4
    arm64.cmp x9, x8
    arm64.cset x10, gt
    arm64.orr x11, x7, x10
    arm64.cmp x11, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x4
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

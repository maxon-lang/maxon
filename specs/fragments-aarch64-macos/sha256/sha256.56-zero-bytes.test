// Test: sha256.56-zero-bytes
function main() returns ExitCode
	var data = ByteArray.create()
	var i = 0
	while i < 56 'fill'
		data.push(0)
		i = i + 1
	end 'fill'
	let hash = sha256(data)
	// SHA-256(56 * 0x00) = d4817aa5...
	// first byte = 0xd4 = 212, last byte = 0xbb = 187
	let first = try hash.get(0) otherwise 0
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'

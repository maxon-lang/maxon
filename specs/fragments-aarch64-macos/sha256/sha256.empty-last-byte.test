// Test: sha256.empty-last-byte
function main() returns ExitCode
  let hash = sha256(ByteArray.empty())
  // last byte = 0x55 = 85
  let b31 = try hash.get(31) otherwise 0
  print("{b31}\n")
  return 0
end 'main'

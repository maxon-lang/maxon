// Test: float-backed
enum Threshold
  low = 0.1
  medium = 0.5
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  var t = Threshold.medium
  if t == Threshold.medium 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_0.5]
    arm64.fstr d0, [x29, #-8]
    arm64.fldr d1, [__float_0.5]
    arm64.fldr d2, [x29, #-8]
    arm64.fcmp d2, d1
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne constants.main.check_0
    arm64.b constants.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

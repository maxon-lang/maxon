// Test: return-type
enum Result
  success
  failure
end 'Result'

function getResult(succeed bool) returns Result
  if succeed 'check'
    return Result.success
  end 'check'
  return Result.failure
end 'getResult'

function main() returns ExitCode
  var r = getResult(true)
  if r == Result.success 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getResult(succeed: i1) -> i64 {
  entry:
    arm64.cmp x0, #0
    arm64.b.ne constants.getResult.check_0
    arm64.b constants.getResult.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.bl constants.getResult
    arm64.str x0, [x29, #-8]
    arm64.mov x0, #0
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, x0
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.test_0
    arm64.b main.test_0.after
  test_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  test_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

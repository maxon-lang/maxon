// Test: keyword-case-rawvalue
enum TokenType
  function
  return
  end
  if
end 'TokenType'

function main() returns ExitCode
  var t = TokenType.end
  return t.rawValue
end 'main'
---
ExitCode: 2
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #2
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.str x1, [x29, #-16]
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, lt
    arm64.mov x4, #4294967295
    arm64.cmp x1, x4
    arm64.cset x5, gt
    arm64.orr x6, x3, x5
    arm64.cmp x6, #0
    arm64.b.ne constants.main.__range_panic_0
    arm64.b constants.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_16
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

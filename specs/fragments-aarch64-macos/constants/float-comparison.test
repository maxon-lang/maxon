// Test: float-comparison
enum Threshold
  low = 0.1
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  let val = 0.5
  if val > Threshold.low and val < Threshold.high 'inRange'
    return 1
  end 'inRange'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.fldr d0, [__float_0.5]
    arm64.fldr d1, [__float_0.1]
    arm64.fcmp d0, d1
    arm64.cset x0, gt
    arm64.fldr d2, [__float_0.9]
    arm64.fcmp d0, d2
    arm64.cset x1, lt
    arm64.and x2, x0, x1
    arm64.cmp x2, #0
    arm64.b.ne constants.main.inRange_0
    arm64.b constants.main.inRange_0.after
  inRange_0:
    arm64.mov x0, #1
    arm64.ret
  inRange_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

// Test: arithmetic-as-array-index
enum Slot
  a
  b
  c
end 'Slot'

let NUM_SLOTS = 3

function main() returns ExitCode
  let idx = Slot.b * NUM_SLOTS + Slot.a
  return idx
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #1
    arm64.mov x1, #3
    arm64.mul x2, x0, x1
    arm64.mov x3, #0
    arm64.add x4, x2, x3
    arm64.mov x5, #0
    arm64.cmp x4, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x4, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x4
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: fromRawValue-float-backed
enum Weights
  light = 1.5
  medium = 2.5
  heavy = 3.5
end 'Weights'

function main() returns ExitCode
  var w = try Weights.fromRawValue(2.5) otherwise Weights.light
  if w == Weights.medium 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.fldr d0, [__float_2.5]
    arm64.mov x0, #1
    arm64.fldr d1, [__float_1.5]
    arm64.fcmp d0, d1
    arm64.cset x1, eq
    arm64.mov x2, #0
    arm64.cmp x1, #0
    arm64.csel x3, x2, x0, ne
    arm64.fldr d2, [__float_2.5]
    arm64.fcmp d0, d2
    arm64.cset x4, eq
    arm64.mov x5, #0
    arm64.cmp x4, #0
    arm64.csel x6, x5, x3, ne
    arm64.fldr d3, [__float_3.5]
    arm64.fcmp d0, d3
    arm64.cset x7, eq
    arm64.mov x8, #0
    arm64.cmp x7, #0
    arm64.csel x9, x8, x6, ne
    arm64.fldr d4, [__float_1.5]
    arm64.fstr d4, [x29, #-8]
    arm64.fstr d0, [x29, #-16]
    arm64.mov x10, #0
    arm64.cmp x9, x10
    arm64.cset x11, ne
    arm64.cmp x11, #0
    arm64.b.ne main.otherwise_default_error_2
    arm64.b main.otherwise_default_continue_3
  otherwise_default_error_2:
    arm64.fldr d0, [x29, #-8]
    arm64.fstr d0, [x29, #-16]
    arm64.b main.otherwise_default_continue_3
  otherwise_default_continue_3:
    arm64.fldr d0, [x29, #-16]
    arm64.fstr d0, [x29, #-24]
    arm64.fldr d1, [__float_2.5]
    arm64.fldr d2, [x29, #-24]
    arm64.fcmp d2, d1
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne main.check_4
    arm64.b main.check_4.after
  check_4:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  check_4.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

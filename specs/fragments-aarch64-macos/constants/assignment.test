// Test: assignment
enum Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var d = Direction.north
  d = Direction.west
  if d == Direction.west 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #3
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #3
    arm64.ldr x2, [x29, #-8]
    arm64.cmp x2, x1
    arm64.cset x3, eq
    arm64.cmp x3, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: raw-value-int-comparison
enum Priority
  low = 1
  medium = 5
  high = 10
end 'Priority'

function main() returns ExitCode
  var p = Priority.high
  if p.rawValue > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #10
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #5
    arm64.cmp x1, x2
    arm64.cset x3, gt
    arm64.cmp x3, #0
    arm64.b.ne constants.main.check_0
    arm64.b constants.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

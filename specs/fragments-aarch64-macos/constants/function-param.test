// Test: function-param
enum Status
  on
  off
end 'Status'

function isOn(s Status) returns bool
  if s == Status.on 'check'
    return true
  end 'check'
  return false
end 'isOn'

function main() returns ExitCode
  var status = Status.on
  if isOn(status) 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.isOn(s: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.mov x0, #0
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, x0
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne constants.isOn.check_0
    arm64.b constants.isOn.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl constants.isOn
    arm64.cmp x0, #0
    arm64.b.ne main.test_0
    arm64.b main.test_0.after
  test_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  test_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: fromRawValue-int-backed
enum HttpStatus
  ok = 200
  notFound = 404
  serverError = 500
end 'HttpStatus'

function main() returns ExitCode
  var status = try HttpStatus.fromRawValue(404) otherwise HttpStatus.ok
  if status == HttpStatus.notFound 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #404
    arm64.mov x1, #1
    arm64.mov x2, #0
    arm64.mov x3, #200
    arm64.cmp x0, x3
    arm64.cset x4, eq
    arm64.mov x5, #0
    arm64.cmp x4, #0
    arm64.csel x6, x5, x1, ne
    arm64.mov x7, #200
    arm64.cmp x4, #0
    arm64.csel x8, x7, x2, ne
    arm64.mov x9, #404
    arm64.cmp x0, x9
    arm64.cset x10, eq
    arm64.mov x11, #0
    arm64.cmp x10, #0
    arm64.csel x12, x11, x6, ne
    arm64.mov x13, #404
    arm64.cmp x10, #0
    arm64.csel x14, x13, x8, ne
    arm64.mov x15, #500
    arm64.cmp x0, x15
    arm64.cset x1, eq
    arm64.mov x0, #0
    arm64.cmp x1, #0
    arm64.csel x2, x0, x12, ne
    arm64.mov x0, #500
    arm64.cmp x1, #0
    arm64.csel x3, x0, x14, ne
    arm64.mov x0, #200
    arm64.str x0, [x29, #-8]
    arm64.str x3, [x29, #-16]
    arm64.mov x0, #0
    arm64.cmp x2, x0
    arm64.cset x1, ne
    arm64.cmp x1, #0
    arm64.b.ne constants.main.otherwise_default_error_2
    arm64.b constants.main.otherwise_default_continue_3
  otherwise_default_error_2:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-16]
    arm64.b constants.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    arm64.ldr x0, [x29, #-16]
    arm64.str x0, [x29, #-24]
    arm64.mov x1, #404
    arm64.ldr x2, [x29, #-24]
    arm64.cmp x2, x1
    arm64.cset x3, eq
    arm64.cmp x3, #0
    arm64.b.ne constants.main.check_4
    arm64.b constants.main.check_4.after
  check_4:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  check_4.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  }
}

  earth = "Earth"
  mars = "Mars"
end 'Planet'

function main() returns ExitCode
  var p = Planet.earth
  p = Planet.mars
  var name = p.rawValue
  if name == "Mars" 'check'
    return 1
  end 'check'
  return 0
end 'main'

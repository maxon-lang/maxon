// Test: raw-value-int
enum HttpStatus
  ok = 200
  notFound = 404
  serverError = 500
end 'HttpStatus'

function main() returns ExitCode
  var status = HttpStatus.ok
  if status.rawValue == 200 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #200
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #200
    arm64.cmp x1, x2
    arm64.cset x3, eq
    arm64.cmp x3, #0
    arm64.b.ne constants.main.check_0
    arm64.b constants.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

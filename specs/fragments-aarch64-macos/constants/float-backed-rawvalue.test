// Test: float-backed-rawvalue
enum Weights
  light = 1.5
  medium = 2.5
  heavy = 3.5
end 'Weights'

function main() returns ExitCode
  var w = Weights.medium
  var rawVal = w.rawValue
  if rawVal > 2.0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_2.5]
    arm64.fstr d0, [x29, #-8]
    arm64.fldr d1, [x29, #-8]
    arm64.fldr d2, [__float_2]
    arm64.fcmp d1, d2
    arm64.cset x0, gt
    arm64.cmp x0, #0
    arm64.b.ne constants.main.check_0
    arm64.b constants.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: comparison-with-int
enum State
  idle
  running
  done
end 'State'

function main() returns ExitCode
  var s = State.running
  if s >= State.idle and s <= State.done 'inRange'
    return 1
  end 'inRange'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.ldr x2, [x29, #-8]
    arm64.cmp x2, x1
    arm64.cset x3, ge
    arm64.mov x4, #2
    arm64.ldr x5, [x29, #-8]
    arm64.cmp x5, x4
    arm64.cset x6, le
    arm64.and x7, x3, x6
    arm64.cmp x7, #0
    arm64.b.ne constants.main.inRange_0
    arm64.b constants.main.inRange_0.after
  inRange_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  inRange_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: complex-expression
function main() returns ExitCode
  var result = trunc((10 + (2 * 3)) / (4 - 2))
  return result
end 'main'
---
ExitCode: 8
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x2, #3
    arm64.mul x3, x1, x2
    arm64.add x4, x0, x3
    arm64.mov x5, #4
    arm64.mov x6, #2
    arm64.sub x7, x5, x6
    arm64.sdiv x8, x4, x7
    arm64.mov x9, #0
    arm64.cmp x8, x9
    arm64.cset x10, lt
    arm64.mov x11, #4294967295
    arm64.cmp x8, x11
    arm64.cset x12, gt
    arm64.orr x13, x10, x12
    arm64.cmp x13, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x8
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

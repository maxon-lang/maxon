// Test: first-class-function.reassign

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
  return x * 2
end 'double'

function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  var f = double
  var a = f(10)
  f = triple
  var b = f(10)
  return a + b
end 'main'
---
ExitCode: 50
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    arm64.mov x1, #2
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @first-class-functions.triple(x: i64) -> i64 {
  entry:
    arm64.mov x1, #3
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @first-class-functions.main() -> u32 {
  entry:
    arm64.prologue stack_size=64
    arm64.adrp_add_func x0, first-class-functions.double
    arm64.mov x1, #10
    arm64.mov x2, #0
    arm64.str x0, [x29, #-16]
    arm64.mov x9, x0
    arm64.mov x0, x1
    arm64.mov x1, x2
    arm64.blr x9
    arm64.adrp_add_func x3, first-class-functions.triple
    arm64.mov x4, #10
    arm64.mov x5, #0
    arm64.str x0, [x29, #-24]
    arm64.str x3, [x29, #-32]
    arm64.mov x9, x3
    arm64.mov x0, x4
    arm64.mov x1, x5
    arm64.blr x9
    arm64.ldr x6, [x29, #-24]
    arm64.add x7, x6, x0
    arm64.str x7, [x29, #-8]
    arm64.mov x8, #0
    arm64.cmp x7, x8
    arm64.cset x9, lt
    arm64.mov x10, #4294967295
    arm64.cmp x7, x10
    arm64.cset x11, gt
    arm64.orr x12, x9, x11
    arm64.cmp x12, #0
    arm64.b.ne first-class-functions.main.__range_panic_0
    arm64.b first-class-functions.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_18
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=64
    arm64.ret
  }
}
---

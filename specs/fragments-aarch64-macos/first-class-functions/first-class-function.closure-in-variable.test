// Test: first-class-function.closure-in-variable

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
  var f = (x Integer) gives x * 5
  return f(8)
end 'main'
---
ExitCode: 40
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=32
    arm64.adrp_add_func x0, __closure_0
    arm64.mov x1, #8
    arm64.mov x2, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x9, x0
    arm64.mov x0, x1
    arm64.mov x1, x2
    arm64.blr x9
    arm64.mov x3, #0
    arm64.cmp x0, x3
    arm64.cset x4, lt
    arm64.mov x5, #4294967295
    arm64.cmp x0, x5
    arm64.cset x6, gt
    arm64.orr x7, x4, x6
    arm64.cmp x7, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=32
    arm64.ret
  }
  func @__closure_0(x: i64) -> i64 {
  entry:
    arm64.mov x1, #5
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
}
---

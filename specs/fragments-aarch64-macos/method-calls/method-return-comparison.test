// Test: method-return-comparison

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function isPositive() returns Integer
    if n > 0 'positive'
      return 1
    end 'positive'
    return 0
  end 'isPositive'
end 'Value'

function main() returns ExitCode
  var v = Value{n: 42}
  return v.isPositive()
end 'main'
---
ExitCode: 1
---
module {
  func @Value.isPositive(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, gt
    arm64.cmp x3, #0
    arm64.b.ne Value.isPositive.positive_0
    arm64.b Value.isPositive.positive_0.after
  positive_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  positive_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #42
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #42
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Value.isPositive
    arm64.str x0, [x29, #-16]
    arm64.mov x5, #0
    arm64.cmp x0, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x0, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne method-calls.main.__range_panic_0
    arm64.b method-calls.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_24
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq method-calls.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label method-calls.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @__destruct_Value(ptr: i64) {
  entry:
    arm64.b __destruct_Value.done
  done:
    arm64.ret
  }
}

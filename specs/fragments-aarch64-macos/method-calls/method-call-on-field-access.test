// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
  var value Integer

  function get() returns Integer
    return value
  end 'get'
end 'Inner'

type Outer
  var inner Inner

  function getInnerValue() returns Integer
    return inner.get()
  end 'getInnerValue'
end 'Outer'

function main() returns ExitCode
  var o = Outer{inner: Inner{value: 42}}
  return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x2, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl Inner.get
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=64
    arm64.mov x0, #42
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #42
    arm64.str x2, [x1, #0]
    arm64.adrp_add_func x3, __destruct_Outer
    arm64.mov x4, x3
    arm64.mov x1, x4
    arm64.mov x0, #8
    arm64.mov x2, #2
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-16]
    arm64.ldr x5, [x29, #-8]
    arm64.ldr x6, [x29, #-16]
    arm64.str x5, [x6, #0]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x7, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x8, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl Outer.getInnerValue
    arm64.mov x9, #0
    arm64.cmp x0, x9
    arm64.cset x10, lt
    arm64.mov x11, #4294967295
    arm64.cmp x0, x11
    arm64.cset x12, gt
    arm64.orr x13, x10, x12
    arm64.cmp x13, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x1, [x29, #-16]
    arm64.str x0, [x29, #-24]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_32
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_32
    arm64.ldr x0, [x29, #-24]
    arm64.epilogue stack_size=64
    arm64.ret
  }
  func @__destruct_Inner(ptr: i64) {
  entry:
    arm64.b __destruct_Inner.done
  done:
    arm64.ret
  }
  func @__destruct_Outer(ptr: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.cmp x1, #0
    arm64.b.eq __destruct_Outer.__skip_guarded_4
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label __destruct_Outer.__skip_guarded_4
    arm64.b __destruct_Outer.done
  done:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #10
    arm64.bl Adder.add
    arm64.ldr x5, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #20
    arm64.bl Adder.add
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #12
    arm64.bl Adder.add
    arm64.ldr x7, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Adder.get
    arm64.str x0, [x29, #-16]
    arm64.mov x8, #0

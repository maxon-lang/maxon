// Test: method-call-with-args

typealias Integer = int(i64.min to i64.max)

type Adder
  var total Integer

  function add(n Integer)
    total = total + n
  end 'add'

  function get() returns Integer
    return total
  end 'get'
end 'Adder'

function main() returns ExitCode
  var a = Adder{total: 0}
  a.add(10)
  a.add(20)
  a.add(12)
  return a.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, n: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.add x0, x2, x1
    arm64.ldr x1, [x29, #-8]
    arm64.str x0, [x1, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Adder.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.mov x1, #10
    arm64.bl Adder.add
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.mov x1, #20
    arm64.bl Adder.add
    arm64.add x6, x29, #-8
    arm64.mov x7, x6
    arm64.mov x0, x7
    arm64.mov x1, #12
    arm64.bl Adder.add
    arm64.add x8, x29, #-8
    arm64.mov x9, x8
    arm64.mov x0, x9
    arm64.bl Adder.get
    arm64.mov x10, #0
    arm64.cmp x0, x10
    arm64.cset x11, lt
    arm64.mov x12, #4294967295
    arm64.cmp x0, x12
    arm64.cset x13, gt
    arm64.orr x14, x11, x13
    arm64.cmp x14, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: method-call-with-args

typealias Integer = int(i64.min to i64.max)

type Adder
  var total Integer

  function add(n Integer)
    total = total + n
  end 'add'

  function get() returns Integer
    return total
  end 'get'
end 'Adder'

function main() returns ExitCode
  var a = Adder{total: 0}
  a.add(10)
  a.add(20)
  a.add(12)
  return a.get()
end 'main'
---
ExitCode: 42
---
module {

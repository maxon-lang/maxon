    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.add x0, x2, x1
    arm64.ldr x1, [x29, #-8]
    arm64.str x0, [x1, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }

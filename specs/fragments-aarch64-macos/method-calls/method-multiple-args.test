// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
  var result Integer

  function addTwo(a Integer, b Integer)
    result = result + a + b
  end 'addTwo'

  function get() returns Integer
    return result
  end 'get'
end 'Calculator'

function main() returns ExitCode
  var calc = Calculator{result: 0}
  calc.addTwo(20, b: 22)
  return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.addTwo(__self_ptr: i64, a: i64, b: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x3, [x0, #0]
    arm64.add x0, x3, x1
    arm64.add x1, x0, x2
    arm64.ldr x2, [x29, #-8]
    arm64.str x1, [x2, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Calculator.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.mov x1, #20
    arm64.mov x2, #22
    arm64.bl Calculator.addTwo
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.bl Calculator.get
    arm64.mov x6, #0
    arm64.cmp x0, x6
    arm64.cset x7, lt
    arm64.mov x8, #4294967295
    arm64.cmp x0, x8
    arm64.cset x9, gt
    arm64.orr x10, x7, x9
    arm64.cmp x10, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

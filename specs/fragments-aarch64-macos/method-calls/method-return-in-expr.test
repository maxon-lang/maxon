    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #40
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Box.getValue
    arm64.mov x5, #2
    arm64.add x6, x0, x5
    arm64.str x6, [x29, #-16]
    arm64.mov x7, #0
    arm64.cmp x6, x7
    arm64.cset x8, lt
    arm64.mov x9, #4294967295
    arm64.cmp x6, x9
    arm64.cset x10, gt
    arm64.orr x11, x8, x10
    arm64.cmp x11, #0
    arm64.b.ne method-calls.main.__range_panic_0
    arm64.b method-calls.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_22
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq method-calls.main.__skip_guarded_26
    arm64.ldr x0, [x29, #-8]

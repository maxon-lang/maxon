// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
  static function create(x Integer, y Integer) returns Integer
    return x * 10 + y
  end 'create'
end 'Factory'

function main() returns ExitCode
  return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
module {
  func @Factory.create(x: i64, y: i64) -> i64 {
  entry:
    arm64.mov x2, #10
    arm64.mul x3, x0, x2
    arm64.add x0, x3, x1
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #4
    arm64.mov x1, #2
    arm64.bl Factory.create
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x1, x2, x3
    arm64.cmp x1, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

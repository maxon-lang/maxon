// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function isPositive(x Score) returns bool
  if x > 0 'check'
    return true
  end 'check'
  return false
end 'isPositive'

function main() returns ExitCode
  if isPositive(5) 'test'
    return 1
  end 'test'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @bool-type.isPositive(x: i64) -> i1 {
  entry:
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne bool-type.isPositive.check_0
    arm64.b bool-type.isPositive.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
  func @bool-type.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #5
    arm64.bl bool-type.isPositive
    arm64.cmp x0, #0
    arm64.b.ne bool-type.main.test_0
    arm64.b bool-type.main.test_0.after
  test_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  test_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: basic-bool
function main() returns ExitCode
  var x = true

  if x 'check'
    return 1
  end 'check' else 'else_check'
    return 0
  end 'else_check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #1
    arm64.cmp x0, #0
    arm64.b.ne main.check_0
    arm64.b main.else_check_1
  check_0:
    arm64.mov x0, #1
    arm64.ret
  else_check_1:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

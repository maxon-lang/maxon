// Test: bool-from-comparison
function main() returns ExitCode
  var result = 5 > 3
  if result 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #5
    arm64.mov x1, #3
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #42
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

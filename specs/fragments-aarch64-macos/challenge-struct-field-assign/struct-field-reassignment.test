    arm64.cmp x12, #0
    arm64.b.ne challenge-struct-field-assign.main.__range_panic_0
    arm64.b challenge-struct-field-assign.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_20

// Test: accumulate-sum
typealias Int = int(i64.min to i64.max)
typealias Vec5 = Vector with 5 Int

function main() returns ExitCode
	var v = Vec5.create()
	v.set(0, value: 10)
	v.set(1, value: 20)
	v.set(2, value: 30)
	v.set(3, value: 40)
	v.set(4, value: 50)
	var sum = 0
	var i = 0
	while i < v.count() 'loop'
		sum = sum + (try v.get(i) otherwise 0)
		i = i + 1
	end 'loop'
	return sum
end 'main'

// Test: float-vector
typealias Float = float(f64.min to f64.max)
typealias Vec2F = Vector with 2 Float

function main() returns ExitCode
	var v = Vec2F.create()
	v.set(0, value: 2.5)
	v.set(1, value: 3.5)
	var a = try v.get(0) otherwise 0.0
	var b = try v.get(1) otherwise 0.0
	return trunc(a + b)
end 'main'

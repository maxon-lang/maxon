// Test: named-args-multiply

typealias Integer = int(i64.min to i64.max)

function multiply(x Integer, y Integer) returns Integer
  return x * y
end 'multiply'

function main() returns ExitCode
  return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
module {
  func @parameter-labels.multiply(x: i64, y: i64) -> i64 {
  entry:
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @parameter-labels.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #6
    arm64.mov x1, #7
    arm64.bl parameter-labels.multiply
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne parameter-labels.main.__range_panic_0
    arm64.b parameter-labels.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_11
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

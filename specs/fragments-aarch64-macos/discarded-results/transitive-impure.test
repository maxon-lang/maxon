// Test: transitive-impure

typealias Integer = int(i64.min to i64.max)

function printValue(x Integer)
  print("{x}")
end 'printValue'

function computeAndPrint(x Integer) returns Integer
  printValue(x)
  return x * 2
end 'computeAndPrint'

function main() returns ExitCode
  computeAndPrint(5)
  return 0
end 'main'

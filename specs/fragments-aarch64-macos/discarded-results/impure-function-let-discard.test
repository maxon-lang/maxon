// Test: impure-function-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

function incrementAndGet() returns Integer
  counter = counter + 1
  return counter
end 'incrementAndGet'

function main() returns ExitCode
  let _ = incrementAndGet()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.incrementAndGet() -> i64 {
  entry:
    arm64.global_load x0, [counter]
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.global_store [counter], x2
    arm64.global_load x3, [counter]
    arm64.mov x0, x3
    arm64.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    arm64.prologue stack_size=32
    arm64.bl discarded-results.incrementAndGet
    arm64.mov x1, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x0, x1
    arm64.epilogue stack_size=32
    arm64.ret
  }
}
---

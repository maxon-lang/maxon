// Test: impure-mutating-param

typealias Integer = int(i64.min to i64.max)

function doubleInPlace(x Integer) returns Integer
  x = x * 2
  return x
end 'doubleInPlace'

function main() returns ExitCode
  var n = 5 as Integer
  let _ = doubleInPlace(n)
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.doubleInPlace(x: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #2
    arm64.mul x3, x1, x2
    arm64.str x3, [x29, #-16]
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x5, [x29, #-16]
    arm64.str x5, [x4, #0]
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #5
    arm64.str x0, [x29, #-8]
    arm64.add x1, x29, #-8
    arm64.mov x2, x1
    arm64.mov x0, x2
    arm64.bl discarded-results.doubleInPlace
    arm64.mov x3, #0
    arm64.str x0, [x29, #-16]
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: chainable-method-discarded

typealias Count = int(i64.min to i64.max)

type Counter
  export var value Count

  function increment() returns Counter
    value = value + 1
    return self
  end 'increment'

  static function create(value Count) returns Self
  	return Self{value: value}
  end 'create'
end 'Counter'

function main() returns ExitCode
  var c = Counter.create(value: 0)
  c.increment()
  return c.value
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #1
    arm64.add x3, x1, x2
    arm64.ldr x4, [x29, #-8]
    arm64.str x3, [x4, #0]
    arm64.ldr x5, [x29, #-8]
    arm64.mov x0, x5
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl Counter.increment
    arm64.ldr x4, [x29, #-8]
    arm64.mov x5, #0
    arm64.cmp x4, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x4, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.str x0, [x29, #-16]
    arm64.mov x0, x4
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

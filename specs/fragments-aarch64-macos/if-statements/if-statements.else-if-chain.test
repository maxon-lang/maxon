// Test: if-statements.else-if-chain
function main() returns ExitCode
  var x = 2
  if x == 1 'case1'
    return 1
  end 'case1' else if x == 2 'case2'
    return 2
  end 'case2' else 'default'
    return 0
  end 'default'
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #2
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.case1_0
    arm64.b main.case1_0.elseif
  case1_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  case1_0.elseif:
    arm64.mov x0, #2
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, x0
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.case2_1
    arm64.b main.default_2
  case2_1:
    arm64.mov x0, #2
    arm64.epilogue stack_size=48
    arm64.ret
  default_2:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

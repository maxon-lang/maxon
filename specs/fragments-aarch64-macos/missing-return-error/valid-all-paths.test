// Test: valid-all-paths

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
  if x > 0 'check'
    return 1
  end 'check'
  return 0
end 'test'

function main() returns ExitCode
  return test(5)
end 'main'
---
ExitCode: 1
---
module {
  func @missing-return-error.test(x: i64) -> i64 {
  entry:
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne missing-return-error.test.check_0
    arm64.b missing-return-error.test.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
  func @missing-return-error.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #5
    arm64.bl missing-return-error.test
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne missing-return-error.main.__range_panic_0
    arm64.b missing-return-error.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_12
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

// Test: string-keys-remove
function main() returns ExitCode
  var m = ["alpha": 1, "beta": 2, "gamma": 3]
  let _ = m.remove("beta")
  if m.contains("beta") 'check'
    return 1
  end 'check'
  return m.count()
end 'main'

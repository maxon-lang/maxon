// Test: lazy-static.struct-literal
type Point
  export var x Count
  export var y Count
end 'Point'

type Defaults
  static var origin = Point{x: 0, y: 0}

  export static function getOrigin() returns Point
    return Defaults.origin
  end 'getOrigin'
end 'Defaults'

function main() returns ExitCode
  var p = Defaults.getOrigin()
  print("{p.x} {p.y}")
  return 0
end 'main'

// Test: jump-table.four-cases-expression
enum Direction
    north
    south
    east
    west
end 'Direction'

function main() returns ExitCode
    var d = Direction.east
    let code = match d 'dir'
        north gives 10
        south gives 20
        east gives 30
        west gives 40
    end 'dir'
    return code
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #2
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #0
    arm64.str x2, [x29, #-16]
    arm64.str x1, [x29, #-24]
    arm64.ldr x3, [x29, #-24]
    arm64.jump_table x3, 4 cases, default=main.dir_0.merge
  dir_0.case0:
    arm64.mov x0, #10
    arm64.str x0, [x29, #-16]
    arm64.b main.dir_0.merge
  dir_0.case1:
    arm64.mov x0, #20
    arm64.str x0, [x29, #-16]
    arm64.b main.dir_0.merge
  dir_0.case2:
    arm64.mov x0, #30
    arm64.str x0, [x29, #-16]
    arm64.b main.dir_0.merge
  dir_0.case3:
    arm64.mov x0, #40
    arm64.str x0, [x29, #-16]
    arm64.b main.dir_0.merge
  dir_0.merge:
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_1
    arm64.b main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

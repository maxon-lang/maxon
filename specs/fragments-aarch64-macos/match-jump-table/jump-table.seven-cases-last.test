// Test: jump-table.seven-cases-last
enum Weekday
    mon
    tue
    wed
    thu
    fri
    sat
    sun
end 'Weekday'

function main() returns ExitCode
    var w = Weekday.sun
    let name = match w 'w'
        mon gives "Monday"
        tue gives "Tuesday"
        wed gives "Wednesday"
        thu gives "Thursday"
        fri gives "Friday"
        sat gives "Saturday"
        sun gives "Sunday"
    end 'w'
    print(name)
    return 0
end 'main'
---

// Test: associated-value-construction

typealias Integer = int(i64.min to i64.max)

enum Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.value(42)
  match c 'check'
    value(_) then return 1
    empty then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---

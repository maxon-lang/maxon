    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_34
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_34
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_36

// Test: where-clauses.multiple-interfaces

typealias Integer = int(i64.min to i64.max)

interface HasName
    function name() returns Integer
end 'HasName'

interface HasAge
    function age() returns Integer
end 'HasAge'

type Person implements HasName, HasAge
    var _age Integer

    function name() returns Integer
        return 1
    end 'name'

    function age() returns Integer
        return self._age
    end 'age'

    static function create(_age Integer) returns Self
    	return Self{_age: _age}
    end 'create'
end 'Person'

type Registry uses T where T is HasName and HasAge
    export var item T
end 'Registry'

typealias PersonRegistry = Registry with Person

function main() returns ExitCode
    var p = Person.create(_age: 30)
    var r = PersonRegistry.create(item: p)
    return r.item.age()
end 'main'

// Test: union-equals-direct
union Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var a = Color.green
  var b = Color.green
  var c = Color.red
  if a.equals(b) 'eq'
    if a.equals(c) 'neq'
      return 0
    end 'neq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @Color.equals(self: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=16
    arm64.bl stdlib.int.equals
    arm64.epilogue stack_size=16
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #1
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.str x1, [x29, #-16]
    arm64.mov x2, #0
    arm64.str x2, [x29, #-24]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x4, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.bl Color.equals
    arm64.cmp x0, #0
    arm64.b.ne main.eq_0
    arm64.b main.eq_0.after
  eq_0:
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-24]
    arm64.bl Color.equals
    arm64.cmp x0, #0
    arm64.b.ne main.neq_1
    arm64.b main.neq_1.after
  neq_1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  neq_1.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  eq_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

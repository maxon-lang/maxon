// Test: multiple-methods

typealias Integer = int(i64.min to i64.max)

interface Describable
  function describe() returns Integer
  function value() returns Integer
end 'Describable'

type Counter implements Describable
  var count Integer

  function describe() returns Integer
    return 100 + count
  end 'describe'

  function value() returns Integer
    return count
  end 'value'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 42}
  return c.describe() + c.value()
end 'main'
---
ExitCode: 184
---
module {
  func @Counter.describe(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #100
    arm64.add x3, x2, x1
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Counter.value(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #42
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl Counter.describe
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.str x0, [x29, #-16]
    arm64.mov x0, x5
    arm64.bl Counter.value
    arm64.ldr x6, [x29, #-16]
    arm64.add x7, x6, x0
    arm64.mov x8, #0
    arm64.cmp x7, x8
    arm64.cset x9, lt
    arm64.mov x10, #4294967295
    arm64.cmp x7, x10
    arm64.cset x11, gt
    arm64.orr x12, x9, x11
    arm64.cmp x12, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x7
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

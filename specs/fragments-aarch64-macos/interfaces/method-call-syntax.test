// Test: method-call-syntax

typealias Integer = int(i64.min to i64.max)

interface Incrementable
  function inc() returns Integer
end 'Incrementable'

type Value implements Incrementable
  var n Integer

  function inc() returns Integer
    return n + 1
  end 'inc'
end 'Value'

function main() returns ExitCode
  var v = Value{n: 41}
  return v.inc()
end 'main'

// Test: multiple-functions

typealias Integer = int(i64.min to i64.max)

export function double(x Integer) returns Integer
  return x * 2
end 'double'

export function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  return double(5) + triple(4)
end 'main'
---
ExitCode: 22
---
module {
  func @namespaces.double(x: i64) -> i64 {
  entry:
    arm64.mov x1, #2
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @namespaces.triple(x: i64) -> i64 {
  entry:
    arm64.mov x1, #3
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @namespaces.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #5
    arm64.bl namespaces.double
    arm64.str x0, [x29, #-16]
    arm64.mov x0, #4
    arm64.bl namespaces.triple
    arm64.ldr x1, [x29, #-16]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.mov x0, #0
    arm64.cmp x2, x0
    arm64.cset x1, lt
    arm64.mov x0, #4294967295
    arm64.cmp x2, x0
    arm64.cset x3, gt
    arm64.orr x2, x1, x3
    arm64.cmp x2, #0
    arm64.b.ne namespaces.main.__range_panic_0
    arm64.b namespaces.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_16
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: unary-negate-expression
function main() returns ExitCode
  var x = 10
  var y = 5
  var z = -(x + y)
  return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #5
    arm64.add x2, x0, x1
    arm64.mov x3, #0
    arm64.sub x4, x3, x2
    arm64.mov x5, #57
    arm64.add x6, x5, x4
    arm64.mov x7, #0
    arm64.cmp x6, x7
    arm64.cset x8, lt
    arm64.mov x9, #4294967295
    arm64.cmp x6, x9
    arm64.cset x10, gt
    arm64.orr x11, x8, x10
    arm64.cmp x11, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x6
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

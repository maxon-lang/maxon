// Test: int-literal-vs-byte-valid

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var b = 42 as Byte
  if b == 42 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #42
    arm64.mov x1, #255
    arm64.and x2, x0, x1
    arm64.mov x3, #42
    arm64.cmp x2, x3
    arm64.cset x4, eq
    arm64.cmp x4, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

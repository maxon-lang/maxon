// Test: docs-example-3
typealias Decimal = float(f64.min to f64.max)

function main() returns ExitCode
  var x = 5
  var y = 5.0
  if (x as Decimal) == y 'check'
    return 1
  end 'check'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #5
    arm64.fldr d0, [__float_5]
    arm64.scvtf d1, x0
    arm64.fcmp d1, d0
    arm64.cset x1, eq
    arm64.cmp x1, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

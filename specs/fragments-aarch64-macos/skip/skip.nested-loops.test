// Test: skip.nested-loops
function main() returns ExitCode
    var sum = 0
    for _ in 1 to 2 'outer'
        var inner = [10, 20, 30, 40, 50]
        for i in inner 'inner'
            if i == 20 'check'
                skip 1
            end 'check'
            sum = sum + i
        end 'inner'
    end 'outer'
    return sum
end 'main'

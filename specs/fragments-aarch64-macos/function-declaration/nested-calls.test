// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
  return x * 2
end 'double'

function quadruple(x Integer) returns Integer
  return double(double(x))
end 'quadruple'

function main() returns ExitCode
  return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @function-declaration.double(x: i64) -> i64 {
  entry:
    arm64.mov x1, #2
    arm64.mul x2, x0, x1
    arm64.mov x0, x2
    arm64.ret
  }
  func @function-declaration.quadruple(x: i64) -> i64 {
  entry:
    arm64.prologue stack_size=16
    arm64.bl function-declaration.double
    arm64.bl function-declaration.double
    arm64.epilogue stack_size=16
    arm64.ret
  }
  func @function-declaration.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #3
    arm64.bl function-declaration.quadruple
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne function-declaration.main.__range_panic_0
    arm64.b function-declaration.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_13
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: void-return-type
function doNothing()
end 'doNothing'

function main() returns ExitCode
  doNothing()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @function-declaration.doNothing() {
  entry:
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.bl function-declaration.doNothing
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}

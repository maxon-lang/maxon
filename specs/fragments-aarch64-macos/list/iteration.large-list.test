// Test: iteration.large-list
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
  var list = IntList{}
  for i in 1 to 100 'build'
    list.append(i)
  end 'build'
  var sum = 0
  for item in list 'loop'
    sum = sum + item
  end 'loop'
  return sum - 5050
end 'main'

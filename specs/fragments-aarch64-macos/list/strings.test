// Test: strings
typealias StringList = List with String

function main() returns ExitCode
	var list = StringList.create()
	list.append("hello")
	list.append("world")
	var f = try list.first() otherwise "none"
	var l = try list.last() otherwise "none"
	print("{f}\n")
	print("{l}\n")
	return 0
end 'main'

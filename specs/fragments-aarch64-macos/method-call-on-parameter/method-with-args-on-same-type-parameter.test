// Test: method-with-args-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Adder
  var value Integer
  
  function addTo(n Integer) returns Integer
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n Integer) returns Integer
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns ExitCode
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.add x0, x2, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x1, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.str x0, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, x2
    arm64.bl Adder.addTo
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #100
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #50
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.add x6, x29, #-16
    arm64.mov x7, x6
    arm64.mov x0, x5
    arm64.mov x1, x7
    arm64.mov x2, #7
    arm64.bl Adder.delegateAdd
    arm64.mov x8, #0
    arm64.cmp x0, x8
    arm64.cset x9, lt
    arm64.mov x10, #4294967295
    arm64.cmp x0, x10
    arm64.cset x11, gt
    arm64.orr x12, x9, x11
    arm64.cmp x12, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

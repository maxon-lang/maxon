// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer
  
  function get() returns Integer
    return n
  end 'get'
  
  function add(other Value) returns Integer
    return n + other.get()
  end 'add'
  
  function multiply(other Value) returns Integer
    return n * other.get()
  end 'multiply'

  static function create(n Integer) returns Self
  	return Self{n: n}
  end 'create'
end 'Value'

function main() returns ExitCode
  var a = Value.create(n: 5)
  var b = Value.create(n: 3)
  var c = Value.create(n: 2)
  // a.add(b) = 5 + 3 = 8
  // a.multiply(c) = 5 * 2 = 10
  // total = 8 + 10 = 18
  return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
module {
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Value.add(__self_ptr: i64, other: i64) -> i64 {
  entry:
    arm64.prologue stack_size=64
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.str x2, [x29, #-24]
    arm64.ldr x0, [x29, #-16]
    arm64.bl Value.get
    arm64.ldr x2, [x29, #-24]
    arm64.add x3, x2, x0
    arm64.mov x0, x3
    arm64.epilogue stack_size=64
    arm64.ret
  }
  func @Value.multiply(__self_ptr: i64, other: i64) -> i64 {
  entry:
    arm64.prologue stack_size=64
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.str x2, [x29, #-24]
    arm64.ldr x0, [x29, #-16]
    arm64.bl Value.get
    arm64.ldr x2, [x29, #-24]
    arm64.mul x3, x2, x0
    arm64.mov x0, x3
    arm64.epilogue stack_size=64
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #5
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #3
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.mov x4, #2
    arm64.mov x5, #0
    arm64.str x5, [x29, #-24]
    arm64.str x4, [x29, #-24]
    arm64.add x6, x29, #-8
    arm64.mov x7, x6
    arm64.add x8, x29, #-16
    arm64.mov x9, x8
    arm64.mov x0, x7
    arm64.mov x1, x9
    arm64.bl Value.add
    arm64.add x10, x29, #-8
    arm64.mov x11, x10
    arm64.add x12, x29, #-24
    arm64.mov x13, x12
    arm64.str x0, [x29, #-32]
    arm64.mov x0, x11
    arm64.mov x1, x13
    arm64.bl Value.multiply
    arm64.ldr x14, [x29, #-32]
    arm64.add x15, x14, x0
    arm64.mov x0, #0
    arm64.cmp x15, x0
    arm64.cset x1, lt
    arm64.mov x0, #4294967295
    arm64.cmp x15, x0
    arm64.cset x2, gt
    arm64.orr x0, x1, x2
    arm64.cmp x0, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x15
    arm64.epilogue stack_size=80
    arm64.ret
  }
}

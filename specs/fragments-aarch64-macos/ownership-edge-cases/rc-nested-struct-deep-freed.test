// Test: rc-nested-struct-deep-freed
typealias Integer = int(i64.min to i64.max)

type A
  export var n Integer
end 'A'

type B
  export var a A
end 'B'

type C
  export var b B
end 'C'

function main() returns ExitCode
  var c = C{b: B{a: A{n: 7}}}
  return c.b.a.n
end 'main'

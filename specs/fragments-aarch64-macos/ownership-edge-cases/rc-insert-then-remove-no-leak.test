// Test: rc-insert-then-remove-no-leak
typealias Integer = int(i64.min to i64.max)

type Entry
	export var key Integer

	static function create(key Integer) returns Self
		return Self{key: key}
	end 'create'
end 'Entry'

typealias EntryArray = Array with Entry

function main() returns ExitCode
	var arr = EntryArray.create()
	var i = 0
	while i < 5 'push'
		arr.push(Entry.create(key: i))
		i = i + 1
	end 'push'
	var total = 0
	while arr.count() > 0 'pop'
		var e = try arr.remove(0) otherwise 'err'
			return 99
		end 'err'
		total = total + e.key
	end 'pop'
	return total
end 'main'

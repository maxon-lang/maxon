// Test: rc-multiple-aliases-freed-once
typealias Integer = int(i64.min to i64.max)

type Data
  export var n Integer
end 'Data'

function main() returns ExitCode
  @heap var a = Data{n: 7}
  var b = a
  var c = a
  return a.n + b.n + c.n
end 'main'

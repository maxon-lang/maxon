// Test: rc-inner-block-freed
typealias Integer = int(i64.min to i64.max)

type Widget
  export var id Integer
end 'Widget'

function main() returns ExitCode
  var result = 0
  if true 'inner'
    var w = Widget{id: 7}
    result = w.id
  end 'inner'
  return result
end 'main'

// Test: rc-reassign-decrefs-old
typealias Integer = int(i64.min to i64.max)

type Tag
  export var id Integer

  static function create(id Integer) returns Self
  	return Self{id: id}
  end 'create'
end 'Tag'

function main() returns ExitCode
  var t = Tag.create(id: 1)
  t = Tag.create(id: 2)
  t = Tag.create(id: 3)
  return t.id
end 'main'

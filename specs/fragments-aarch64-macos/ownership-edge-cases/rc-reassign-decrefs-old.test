// Test: rc-reassign-decrefs-old
typealias Integer = int(i64.min to i64.max)

type Tag
  export var id Integer
end 'Tag'

function main() returns ExitCode
  var t = Tag{id: 1}
  t = Tag{id: 2}
  t = Tag{id: 3}
  return t.id
end 'main'

// Test: rc-alias-survives-reassign
typealias Integer = int(i64.min to i64.max)

type Num
  export var v Integer
end 'Num'

function main() returns ExitCode
  var a = Num{v: 10}
  let b = a
  a = Num{v: 20}
  return b.v + a.v
end 'main'
---
MmTrace: true
ExitCode: 30
Stderr: ```

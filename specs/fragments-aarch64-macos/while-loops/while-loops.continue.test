    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne while-loops.main.loop_0
    arm64.b while-loops.main.loop_0.exit
  loop_0:
    arm64.mov x0, #1

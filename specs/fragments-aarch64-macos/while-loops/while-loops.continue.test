    arm64.cset x4, eq
    arm64.cmp x4, #0
    arm64.b.ne while-loops.main.skip_1
    arm64.b while-loops.main.skip_1.after
  skip_1:
    arm64.b while-loops.main.loop_0.header
  skip_1.after:
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.add x2, x0, x1
    arm64.str x2, [x29, #-8]
    arm64.b while-loops.main.loop_0.header
  loop_0.exit:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0

    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.str x1, [x0, #0]
    arm64.mov x1, #0
    arm64.str x1, [x0, #8]
    arm64.ldr x1, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.ldr x2, [x29, #-8]
    arm64.str x2, [x29, #-16]
    arm64.ldr x3, [x29, #-16]
    arm64.str x1, [x29, #-32]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-32]
    arm64.str x4, [x29, #-24]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.ldr x3, [x29, #-24]
    arm64.mov x4, #2
    arm64.cmp x3, x4
    arm64.cset x5, le
    arm64.and x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.case1
  check_0.case0:
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_28
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_28
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_30
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_30
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  check_0.case1:
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_33
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_33
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_35
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_35
    arm64.adrp_add_symdata x2, __panic_msg_0
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl maxon_panic
  check_0.merge:

// Test: default-panic.union-range-statement
typealias Integer = int(i64.min to i64.max)

union Op
  add
  sub
  mul
  exec(code Integer)
end 'Op'

function main() returns ExitCode
  var op = Op.sub
  match op 'check'
    add to mul then return 1
    default panic("unexpected op")
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #16

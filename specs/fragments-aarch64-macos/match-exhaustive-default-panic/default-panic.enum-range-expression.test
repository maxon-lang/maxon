// Test: default-panic.union-range-expression
typealias Integer = int(i64.min to i64.max)

enum Op
  add
  sub
  mul
  exec(code Integer)
end 'Op'

function main() returns ExitCode
  var op = Op.mul
  let result = match op 'eval'
    add to sub gives 1
    mul gives 2
    default panic("unexpected op")
  end 'eval'
  return result
end 'main'
---
ExitCode: 2
---

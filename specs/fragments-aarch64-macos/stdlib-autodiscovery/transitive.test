// Test: transitive
// pow -> log, exp
function main() returns ExitCode
  var result = Math.pow(2.0, exponent: 3.0)
  if result > 7.5 'check'
    return 8
  end 'check'
  return 0
end 'main'
---
ExitCode: 8
---
module {
  func @stdlib-autodiscovery.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_2]
    arm64.fldr d1, [__float_3]
    arm64.bl stdlib.Math.pow
    arm64.fldr d2, [__float_7.5]
    arm64.fcmp d0, d2
    arm64.cset x0, gt
    arm64.cmp x0, #0
    arm64.b.ne stdlib-autodiscovery.main.check_0
    arm64.b stdlib-autodiscovery.main.check_0.after
  check_0:
    arm64.mov x0, #8
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: var-declaration
function main() returns ExitCode
  var x = 10
  return x
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.str x0, [x29, #16]
    arm64.ldr x1, [x29, #16]
    arm64.mov x0, x1
    arm64.epilogue
    arm64.ret
  }
}

---

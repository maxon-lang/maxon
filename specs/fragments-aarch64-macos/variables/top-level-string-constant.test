// Test: top-level-string-constant
let GREETING = "hello"

function main() returns ExitCode
  if GREETING == "hello" 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #1
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.b.ne else
    arm64.b then
  then:
    arm64.mov x0, #1
    arm64.epilogue
    arm64.ret
  else:
    arm64.b merge
  merge:
    arm64.mov x0, #0
    arm64.epilogue
    arm64.ret
  }
}

---

// Test: multiple-variables
function main() returns ExitCode
  let a = 10
  let b = 20
  return a + b
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.str x0, [x29, #16]
    arm64.mov x1, #20
    arm64.str x1, [x29, #24]
    arm64.ldr x2, [x29, #24]
    arm64.ldr x3, [x29, #16]
    arm64.add x3, x3, x2
    arm64.mov x0, x3
    arm64.epilogue
    arm64.ret
  }
}

---

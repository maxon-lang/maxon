// Test: self-explicit-access

typealias Integer = int(i64.min to i64.max)

type Counter
  var count Integer

  function increment()
    self.count = self.count + 1
  end 'increment'

  function get() returns Integer
    return self.count
  end 'get'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 0}
  c.increment()
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 2

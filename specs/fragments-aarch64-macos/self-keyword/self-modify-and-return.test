// Test: self-modify-and-return

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function double()
    self.n = self.n * 2
  end 'double'

  function get() returns Integer
    return self.n
  end 'get'

  static function create(n Integer) returns Self
  	return Self{n: n}
  end 'create'
end 'Value'

function main() returns ExitCode
  var v = Value.create(n: 21)
  v.double()
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.double(__self_ptr: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #2
    arm64.mul x3, x1, x2
    arm64.ldr x4, [x29, #-8]
    arm64.str x3, [x4, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #21
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl Value.double
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.bl Value.get
    arm64.mov x6, #0
    arm64.cmp x0, x6
    arm64.cset x7, lt
    arm64.mov x8, #4294967295
    arm64.cmp x0, x8
    arm64.cset x9, gt
    arm64.orr x10, x7, x9
    arm64.cmp x10, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

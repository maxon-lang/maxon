// Test: basic-extension-on-array

typealias Integer = int(i64.min to i64.max)

interface Countable
  function value() returns Integer
end 'Countable'

extension Countable
  function count() returns Integer
    return 42
  end 'count'
end 'Countable'

type IntList implements Countable
  var data Integer

  function value() returns Integer
    return data
  end 'value'
end 'IntList'

function main() returns ExitCode
  var list = IntList{data: 5}
  return list.count()
end 'main'
---
ExitCode: 42
---
module {
  func @IntList.count(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=32
    arm64.mov x1, #42
    arm64.str x0, [x29, #-8]
    arm64.mov x0, x1
    arm64.epilogue stack_size=32
    arm64.ret
  }
  func @interface-extensions.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #5
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #5
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl IntList.count
    arm64.str x0, [x29, #-16]
    arm64.mov x5, #0
    arm64.cmp x0, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x0, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne interface-extensions.main.__range_panic_0
    arm64.b interface-extensions.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_23
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq interface-extensions.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label interface-extensions.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @__destruct_IntList(ptr: i64) {
  entry:
    arm64.b __destruct_IntList.done
  done:
    arm64.ret
  }
}
---

// Test: extension-multiple-types

typealias Integer = int(i64.min to i64.max)

interface Valued
  function val() returns Integer
end 'Valued'

extension Valued
  function valPlusTen() returns Integer
    return self.val() + 10
  end 'valPlusTen'
end 'Valued'

type TypeA implements Valued
  var a Integer
  function val() returns Integer
    return a
  end 'val'
end 'TypeA'

type TypeB implements Valued
  var b Integer
  function val() returns Integer
    return b * 2
  end 'val'
end 'TypeB'

function main() returns ExitCode
  var ta = TypeA{a: 5}
  var tb = TypeB{b: 10}
  return ta.valPlusTen() + tb.valPlusTen()
end 'main'
---
ExitCode: 45
---
module {
  func @TypeA.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl TypeA.val
    arm64.mov x1, #10
    arm64.add x2, x0, x1
    arm64.mov x0, x2
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @TypeB.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl TypeB.val
    arm64.mov x1, #10
    arm64.add x2, x0, x1
    arm64.mov x0, x2
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @TypeA.val(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @TypeB.val(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #2
    arm64.mul x3, x1, x2
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=64
    arm64.mov x0, #5
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #10
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.bl TypeA.valPlusTen
    arm64.add x6, x29, #-16
    arm64.mov x7, x6
    arm64.str x0, [x29, #-24]
    arm64.mov x0, x7
    arm64.bl TypeB.valPlusTen
    arm64.ldr x8, [x29, #-24]
    arm64.add x9, x8, x0
    arm64.mov x10, #0
    arm64.cmp x9, x10
    arm64.cset x11, lt
    arm64.mov x12, #4294967295
    arm64.cmp x9, x12
    arm64.cset x13, gt
    arm64.orr x14, x11, x13
    arm64.cmp x14, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x9
    arm64.epilogue stack_size=64
    arm64.ret
  }
}

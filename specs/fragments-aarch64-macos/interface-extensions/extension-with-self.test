    arm64.mov x2, #21
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Number.doubled
    arm64.str x0, [x29, #-16]
    arm64.mov x5, #0
    arm64.cmp x0, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x0, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne interface-extensions.main.__range_panic_0
    arm64.b interface-extensions.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_26
    arm64.mov x1, x0
    arm64.mov x0, x1

// Test: union-match-range.statement-form
typealias Integer = int(i64.min to i64.max)

union Op
  add
  sub
  mul
  exec(code Integer)
end 'Op'

function main() returns ExitCode
  var op = Op.sub
  match op 'check'
    add to mul then return 1
    exec(code) then return code
  end 'check'
end 'main'
---
ExitCode: 1

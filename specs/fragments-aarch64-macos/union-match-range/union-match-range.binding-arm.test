// Test: union-match-range.binding-arm
typealias Integer = int(i64.min to i64.max)

union Action
  noop
  skip
  run(code Integer)
end 'Action'

function main() returns ExitCode
  var a = Action.run(42)
  match a 'dispatch'
    noop to skip then return 0
    run(code) then return code
  end 'dispatch'
end 'main'

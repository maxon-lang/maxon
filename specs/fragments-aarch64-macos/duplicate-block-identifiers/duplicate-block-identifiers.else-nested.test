// Test: duplicate-block-identifiers.else-nested
function main() returns ExitCode
  var x = 0
  if false 'check'
    x = 1
  end 'check' else 'else_check'
    if true 'nested'
      x = 2
    end 'nested'
  end 'else_check'
  return x
end 'main'
---
ExitCode: 2
---
module {
  func @duplicate-block-identifiers.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x1, #0
    arm64.b.ne duplicate-block-identifiers.main.check_0
    arm64.b duplicate-block-identifiers.main.else_check_1
  check_0:
    arm64.mov x0, #1
    arm64.str x0, [x29, #-8]
    arm64.b duplicate-block-identifiers.main.check_0.merge
  else_check_1:
    arm64.mov x0, #1
    arm64.cmp x0, #0
    arm64.b.ne duplicate-block-identifiers.main.nested_2
    arm64.b duplicate-block-identifiers.main.nested_2.merge
  nested_2:
    arm64.mov x0, #2
    arm64.str x0, [x29, #-8]
    arm64.b duplicate-block-identifiers.main.nested_2.merge
  nested_2.merge:
    arm64.b duplicate-block-identifiers.main.check_0.merge
  check_0.merge:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-16]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne duplicate-block-identifiers.main.__range_panic_3
    arm64.b duplicate-block-identifiers.main.__range_ok_3
  __range_panic_3:
    arm64.adrp_add_symdata x0, __panic_msg_11
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_3:
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

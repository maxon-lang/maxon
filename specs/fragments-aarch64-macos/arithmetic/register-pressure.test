// Test: register-pressure

typealias Integer = int(i64.min to i64.max)

function manyVars(a Integer, b Integer, c Integer, d Integer, e Integer, f Integer) returns Integer
  var v1 = a + 1
  var v2 = b + 2
  var v3 = c + 3
  var v4 = d + 4
  var v5 = e + 5
  var v6 = f + 6
  var v7 = v1 + v2
  var v8 = v3 + v4
  var v9 = v5 + v6
  var v10 = v7 + v8
  var v11 = v9 + v10
  var v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
  return v12
end 'manyVars'

function main() returns ExitCode
  return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
module {
  func @arithmetic.manyVars(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 {
  entry:
    arm64.mov x6, #1
    arm64.add x7, x0, x6
    arm64.mov x0, #2
    arm64.add x6, x1, x0
    arm64.mov x1, #3
    arm64.add x0, x2, x1
    arm64.mov x2, #4
    arm64.add x1, x3, x2
    arm64.mov x3, #5
    arm64.add x2, x4, x3
    arm64.mov x4, #6
    arm64.add x3, x5, x4
    arm64.add x5, x7, x6
    arm64.add x4, x0, x1
    arm64.add x8, x2, x3
    arm64.add x9, x5, x4
    arm64.add x4, x8, x9
    arm64.add x5, x4, x7
    arm64.add x4, x5, x6
    arm64.add x6, x4, x0
    arm64.add x7, x6, x1
    arm64.add x8, x7, x2
    arm64.add x9, x8, x3
    arm64.mov x0, x9
    arm64.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.mov x1, #2
    arm64.mov x2, #3
    arm64.mov x3, #4
    arm64.mov x4, #5
    arm64.mov x5, #6
    arm64.bl arithmetic.manyVars
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne arithmetic.main.__range_panic_0
    arm64.b arithmetic.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_41
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

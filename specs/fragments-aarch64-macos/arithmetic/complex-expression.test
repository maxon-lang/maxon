// Test: complex-expression
function main() returns ExitCode
  return 10 + 5 * 2
end 'main'
---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #10
    arm64.mov x1, #5
    arm64.mov x2, #2
    arm64.mul x1, x1, x2
    arm64.add x0, x0, x1
    arm64.epilogue
    arm64.ret
  }
}

---

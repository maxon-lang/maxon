// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
  var preserved = x + 1
  var result = a / b
  return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
  return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @arithmetic.divLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    arm64.mov x3, #1
    arm64.add x4, x2, x3
    arm64.sdiv x2, x0, x1
    arm64.add x0, x2, x4
    arm64.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x2, #5
    arm64.bl arithmetic.divLive
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne arithmetic.main.__range_panic_0
    arm64.b arithmetic.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_17
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

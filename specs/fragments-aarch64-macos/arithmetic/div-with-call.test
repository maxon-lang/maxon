// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
  return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
  var temp = trunc(a / b)
  var result = helper(temp)
  return result + temp
end 'divCall'

function main() returns ExitCode
  return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @arithmetic.helper(ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=16
    arm64.str x0, [x29, #16]
    arm64.mov x0, #2
    arm64.ldr x1, [x29, #16]
    arm64.mul x1, x1, x0
    arm64.mov x0, x1
    arm64.epilogue
    arm64.ret
  }
  func @arithmetic.divCall(ptr: i64, ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=32
    arm64.str x0, [x29, #16]
    arm64.str x1, [x29, #24]
    arm64.ldr x0, [x29, #24]
    arm64.ldr x1, [x29, #16]
    arm64.sdiv x1, x1, x0
    arm64.str x1, [x29, #32]
    arm64.ldr x0, [x29, #32]
    arm64.bl arithmetic.helper
    arm64.str x0, [x29, #40]
    arm64.ldr x1, [x29, #32]
    arm64.ldr x2, [x29, #40]
    arm64.add x2, x2, x1
    arm64.mov x0, x2
    arm64.epilogue
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.bl arithmetic.divCall
    arm64.epilogue
    arm64.ret
  }
}

---

// Test: div-loop

typealias Integer = int(i64.min to i64.max)

function divLoop(n Integer) returns Integer
  var sum = 0
  var i = 1
  while i <= n 'loop'
    sum = sum + trunc(100 / i)
    i = i + 1
  end 'loop'
  return sum
end 'divLoop'

function main() returns ExitCode
  return divLoop(5)
end 'main'
---
ExitCode: 228
---
module {
  func @arithmetic.divLoop(ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #16]
    arm64.mov x0, #0
    arm64.str x0, [x29, #24]
    arm64.mov x1, #1
    arm64.str x1, [x29, #32]
    arm64.b cond
  cond:
    arm64.ldr x0, [x29, #16]
    arm64.ldr x1, [x29, #32]
    arm64.cmp x1, x0
    arm64.b.gt exit
    arm64.b body
  body:
    arm64.mov x0, #100
    arm64.ldr x1, [x29, #32]
    arm64.sdiv x0, x0, x1
    arm64.ldr x2, [x29, #24]
    arm64.add x2, x2, x0
    arm64.str x2, [x29, #24]
    arm64.mov x3, #1
    arm64.ldr x4, [x29, #32]
    arm64.add x4, x4, x3
    arm64.str x4, [x29, #32]
    arm64.b cond
  exit:
    arm64.str x0, [x29, #40]
    arm64.ldr x0, [x29, #24]
    arm64.epilogue
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #5
    arm64.mov x0, #5
    arm64.bl arithmetic.divLoop
    arm64.epilogue
    arm64.ret
  }
}

---

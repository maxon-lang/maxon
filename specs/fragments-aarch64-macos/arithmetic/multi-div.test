// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @arithmetic.multiDiv(a: i64, b: i64, c: i64, d: i64) -> i64 {
  entry:
    arm64.sdiv x4, x0, x1
    arm64.sdiv x0, x2, x3
    arm64.add x1, x4, x0
    arm64.mov x0, x1
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x2, #20
    arm64.mov x3, #4
    arm64.bl arithmetic.multiDiv
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x1, x2, x3
    arm64.cmp x1, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

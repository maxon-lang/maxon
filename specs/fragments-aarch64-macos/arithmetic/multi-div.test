// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @arithmetic.multiDiv(ptr: i64, ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #16]
    arm64.str x1, [x29, #24]
    arm64.str x2, [x29, #32]
    arm64.str x3, [x29, #40]
    arm64.ldr x0, [x29, #24]
    arm64.ldr x1, [x29, #16]
    arm64.sdiv x1, x1, x0
    arm64.str x1, [x29, #48]
    arm64.ldr x2, [x29, #40]
    arm64.ldr x3, [x29, #32]
    arm64.sdiv x3, x3, x2
    arm64.str x3, [x29, #56]
    arm64.ldr x4, [x29, #56]
    arm64.ldr x5, [x29, #48]
    arm64.add x5, x5, x4
    arm64.mov x0, x5
    arm64.epilogue
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x2, #20
    arm64.mov x3, #4
    arm64.mov x0, #10
    arm64.mov x1, #2
    arm64.mov x2, #20
    arm64.mov x3, #4
    arm64.bl arithmetic.multiDiv
    arm64.epilogue
    arm64.ret
  }
}

---

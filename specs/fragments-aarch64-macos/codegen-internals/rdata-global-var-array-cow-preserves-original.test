typealias IntArray = Array with Integer

var globalArr = [10, 20, 30]

function readFirst() returns Integer
  return try globalArr.get(0) otherwise 0
end 'readFirst'

function main() returns ExitCode
  globalArr.set(0, value: 99)
  return readFirst()
end 'main'

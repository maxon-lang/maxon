// Test: i32-unsigned-cmp
typealias SmallInt = int(0 to 1000)

function main() returns ExitCode
  var a = SmallInt{10}
  var b = SmallInt{3}
  if a > b 'check'
    return 1
  end 'check'
  return 0
end 'main'

    arm64.ldr x15, [x29, #-8]
    arm64.ldr x0, [x15, #24]
    arm64.adrp_add_symdata x1, __mm_panic_element_size_zero
    arm64.mov x2, x1
    arm64.mov x1, x0
    arm64.mov x0, #0
    arm64.bl maxon_bounds_check
    arm64.adrp_add_func x0, __destruct_IntArray
    arm64.mov x1, x0
    arm64.mov x0, #16
    arm64.mov x2, #2
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #0
    arm64.str x1, [x0, #0]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.str x0, [x1, #8]
    arm64.bl mm_incref
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.mov x0, #0
    arm64.str x0, [x29, #-24]
    arm64.b main.loop_0.header
  loop_0.header:
    arm64.mov x0, #10
    arm64.ldr x1, [x29, #-24]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.loop_0
    arm64.b main.loop_0.exit
  loop_0:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-24]
    arm64.bl IntArray.push
    arm64.mov x2, #1
    arm64.ldr x3, [x29, #-24]
    arm64.add x4, x3, x2

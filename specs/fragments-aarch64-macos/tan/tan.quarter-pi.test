// Test: tan.quarter-pi
function main() returns ExitCode
  var quarterPi = 0.785398163
  var result = Math.tan(quarterPi)
  // Should be approximately 1.0
  var diff = abs(result - 1.0)
  if diff < 0.01 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @tan.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_0.785398163]
    arm64.bl stdlib.Math.tan
    arm64.fldr d1, [__float_1]
    arm64.fsub d2, d0, d1
    arm64.fabs d3, d2
    arm64.fldr d4, [__float_0.01]
    arm64.fcmp d3, d4
    arm64.cset x0, lt
    arm64.cmp x0, #0
    arm64.b.ne tan.main.check_0
    arm64.b tan.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

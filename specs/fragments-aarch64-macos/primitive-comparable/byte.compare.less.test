// Test: byte.compare.less

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var a = 10 as Byte
  var b = 20 as Byte
  var result = a.compare(b)
  match result 'check'
    lessThan then return 0
    equalTo then return 1
    greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #10
    arm64.mov x1, #255
    arm64.and x2, x0, x1
    arm64.mov x3, #20
    arm64.mov x4, #255
    arm64.and x5, x3, x4
    arm64.mov x0, x2
    arm64.mov x1, x5
    arm64.bl stdlib.byte.compare
    arm64.str x0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case1
    arm64.b main.check_0.cmp2
  check_0.case1:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp2:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case2
    arm64.b main.check_0.merge
  check_0.case2:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

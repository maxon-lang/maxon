// Test: float.compare.nan-less-than-normal
function main() returns ExitCode
  var nan = 0.0 / 0.0
  var x = 42.0
  var result = nan.compare(x)
  match result 'check'
    lessThan then return 0
    equalTo then return 1
    greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_0]
    arm64.fldr d1, [__float_0]
    arm64.fdiv d2, d0, d1
    arm64.fldr d3, [__float_42]
    arm64.fmov d0, d2
    arm64.fmov d1, d3
    arm64.bl stdlib.float.compare
    arm64.str x0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case1
    arm64.b main.check_0.cmp2
  check_0.case1:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp2:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case2
    arm64.b main.check_0.merge
  check_0.case2:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

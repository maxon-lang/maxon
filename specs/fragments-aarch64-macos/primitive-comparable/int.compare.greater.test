// Test: int.compare.greater
function main() returns ExitCode
  var a = 20
  var b = 10
  var result = a.compare(b)
  match result 'check'
    Ordering.lessThan then return 1
    Ordering.equalTo then return 1
    Ordering.greaterThan then return 0
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #20
    arm64.mov x1, #10
    arm64.bl stdlib.int.compare
    arm64.str x0, [x29, #-8]
    arm64.b primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case0
    arm64.b primitive-comparable.main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case1
    arm64.b primitive-comparable.main.check_0.cmp2
  check_0.case1:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp2:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case2
    arm64.b primitive-comparable.main.check_0.merge
  check_0.case2:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

// Test: float.compare.positive-negative-zero
function main() returns ExitCode
  var pos = 0.0
  var neg = 0.0 - 0.0
  var result = pos.compare(neg)
  match result 'check'
    Ordering.lessThan then return 1
    Ordering.equalTo then return 0
    Ordering.greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_0]
    arm64.fldr d1, [__float_0]
    arm64.fldr d2, [__float_0]
    arm64.fsub d3, d1, d2
    arm64.fmov d1, d3
    arm64.bl stdlib.float.compare
    arm64.str x0, [x29, #-8]
    arm64.b primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case0
    arm64.b primitive-comparable.main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case1
    arm64.b primitive-comparable.main.check_0.cmp2
  check_0.case1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp2:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-comparable.main.check_0.case2
    arm64.b primitive-comparable.main.check_0.merge
  check_0.case2:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

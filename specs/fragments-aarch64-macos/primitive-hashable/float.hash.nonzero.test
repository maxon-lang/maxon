// Test: float.hash.nonzero
function main() returns ExitCode
  var f = 3.14
  var h = f.hash()
  if h != 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_3.14]
    arm64.bl stdlib.float.hash
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, ne
    arm64.cmp x2, #0
    arm64.b.ne primitive-hashable.main.check_0
    arm64.b primitive-hashable.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

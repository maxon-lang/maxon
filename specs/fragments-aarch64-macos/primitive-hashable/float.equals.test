// Test: float.equals
function main() returns ExitCode
  var a = 3.14
  var b = 3.14
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_3.14]
    arm64.fldr d1, [__float_3.14]
    arm64.bl stdlib.float.equals
    arm64.cmp x0, #0
    arm64.b.ne main.eq_0
    arm64.b main.eq_0.after
  eq_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  eq_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

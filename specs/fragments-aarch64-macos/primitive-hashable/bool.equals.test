// Test: bool.equals
function main() returns ExitCode
  var a = true
  var b = true
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #1
    arm64.mov x1, #1
    arm64.bl stdlib.bool.equals
    arm64.cmp x0, #0
    arm64.b.ne primitive-hashable.main.eq_0
    arm64.b primitive-hashable.main.eq_0.after
  eq_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  eq_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

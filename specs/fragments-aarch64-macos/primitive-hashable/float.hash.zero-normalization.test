// Test: float.hash.zero-normalization
function main() returns ExitCode
  var pos = 0.0
  var neg = -0.0
  var h1 = pos.hash()
  var h2 = neg.hash()
  if h1 == h2 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    arm64.prologue stack_size=32
    arm64.fldr d0, [__float_0]
    arm64.fldr d1, [__float_0]
    arm64.fstr d1, [x29, #-8]
    arm64.bl stdlib.float.hash
    arm64.str x0, [x29, #-16]
    arm64.fldr d1, [x29, #-8]
    arm64.fmov d0, d1
    arm64.bl stdlib.float.hash
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x1, x0
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne primitive-hashable.main.eq_0
    arm64.b primitive-hashable.main.eq_0.after
  eq_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=32
    arm64.ret
  eq_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=32
    arm64.ret
  }
}
---

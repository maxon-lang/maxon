// Test: enumerated.use-index
function main() returns ExitCode
  var arr = [100, 200, 300, 400]
  var total = 0
  for (i, v) in arr.enumerated() 'loop'
    total = total + i * v
  end 'loop'
  print("{total}\n")
  return 0
end 'main'

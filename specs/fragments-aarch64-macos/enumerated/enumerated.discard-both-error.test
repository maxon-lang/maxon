// Test: enumerated.discard-both-error
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
  var arr = IntArray.empty()
  for (_, _) in arr.enumerated() 'loop'
    print("x\n")
  end 'loop'
  return 0
end 'main'

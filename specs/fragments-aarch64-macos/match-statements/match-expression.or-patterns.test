// Test: match-expression.or-patterns
function main() returns ExitCode
  var x = 4
  let result = match x 'eval'
    1 or 2 gives 10
    3 or 4 gives 20
    default gives 0
  end 'eval'
  return result
end 'main'
---
ExitCode: 20
---

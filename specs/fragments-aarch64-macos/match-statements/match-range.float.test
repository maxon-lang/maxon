// Test: match-range.float
function main() returns ExitCode
  var x = 2.5
  match x 'check'
    0.0 to 5.0 then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_2.5]
    arm64.fstr d0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.fldr d0, [x29, #-8]
    arm64.fldr d1, [__float_0]
    arm64.fcmp d0, d1
    arm64.cset x0, ge
    arm64.fldr d2, [x29, #-8]
    arm64.fldr d3, [__float_5]
    arm64.fcmp d2, d3
    arm64.cset x1, le
    arm64.and x2, x0, x1
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.case1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.case1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

// Test: match-break.exits-match-not-loop
function main() returns ExitCode
  var result = 0
  var i = 0
  while i < 3 'loop'
    match i 'check'
      1 then break
      default then result = result + 10
    end 'check'
    result = result + 1
    i = i + 1
  end 'loop'
  return result
end 'main'
---
ExitCode: 23

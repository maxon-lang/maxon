// Test: match-range.with-or
function main() returns ExitCode
  var x = 95
  match x 'check'
    1 to 10 or 90 to 100 then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #95
    arm64.str x0, [x29, #-8]
    arm64.b match-statements.main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #10
    arm64.cmp x3, x4
    arm64.cset x5, le
    arm64.and x6, x2, x5
    arm64.ldr x7, [x29, #-8]
    arm64.mov x8, #90
    arm64.cmp x7, x8
    arm64.cset x9, ge
    arm64.ldr x10, [x29, #-8]
    arm64.mov x11, #100
    arm64.cmp x10, x11
    arm64.cset x12, le
    arm64.and x13, x9, x12
    arm64.orr x14, x6, x13
    arm64.cmp x14, #0
    arm64.b.ne match-statements.main.check_0.case0
    arm64.b match-statements.main.check_0.case1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.case1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

// Test: match-range.open-upper
function main() returns ExitCode
  var x = 100
  match x 'check'
    10 to max then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #100
    arm64.str x0, [x29, #-8]
    arm64.b main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #10
    arm64.cmp x0, x1
    arm64.cset x2, ge
    arm64.cmp x2, #0
    arm64.b.ne main.check_0.case0
    arm64.b main.check_0.case1
  check_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.case1:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

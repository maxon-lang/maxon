// Test: static-var-bool
var initialized = false

function init()
  initialized = true
end 'init'

function main() returns ExitCode
  if initialized 'check1'
    return 1
  end 'check1'
  init()
  if initialized 'check2'
    return 42
  end 'check2'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.init() {
  entry:
    arm64.mov x0, #1
    arm64.global_store [initialized], x0
    arm64.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.global_load x0, [initialized]
    arm64.cmp x0, #0
    arm64.b.ne static-variables.main.check1_0
    arm64.b static-variables.main.check1_0.after
  check1_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  check1_0.after:
    arm64.bl static-variables.init
    arm64.global_load x0, [initialized]
    arm64.cmp x0, #0
    arm64.b.ne static-variables.main.check2_1
    arm64.b static-variables.main.check2_1.after
  check2_1:
    arm64.mov x0, #42
    arm64.epilogue stack_size=16
    arm64.ret
  check2_1.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

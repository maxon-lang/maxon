// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
  static var created = 0
  export var id Integer

  static function make(n Integer) returns Thing
    Thing.created = Thing.created + 1
    return Thing{id: n}
  end 'make'
end 'Thing'

function main() returns ExitCode
  var a = Thing.make(10)
  var b = Thing.make(20)
  return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
module {
  func @Thing.make(n: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.global_load x1, [Thing.created]
    arm64.mov x2, #1
    arm64.add x3, x1, x2
    arm64.global_store [Thing.created], x3
    arm64.str x0, [x29, #-16]
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.str x1, [x0, #0]
    arm64.ldr x2, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x3, [x29, #-8]
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #10
    arm64.bl Thing.make
    arm64.str x0, [x29, #-8]
    arm64.mov x0, #20
    arm64.bl Thing.make
    arm64.str x0, [x29, #-16]
    arm64.global_load x0, [Thing.created]
    arm64.ldr x1, [x29, #-8]
    arm64.ldr x2, [x1, #0]
    arm64.add x3, x0, x2
    arm64.ldr x4, [x29, #-16]
    arm64.ldr x5, [x4, #0]
    arm64.add x6, x3, x5
    arm64.str x6, [x29, #-24]
    arm64.mov x7, #0
    arm64.cmp x6, x7
    arm64.cset x8, lt
    arm64.mov x9, #4294967295
    arm64.cmp x6, x9
    arm64.cset x10, gt
    arm64.orr x11, x8, x10
    arm64.cmp x11, #0
    arm64.b.ne static-variables.main.__range_panic_0
    arm64.b static-variables.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_30
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x1, #0
    arm64.b.eq static-variables.main.__skip_guarded_25
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label static-variables.main.__skip_guarded_25
    arm64.ldr x2, [x29, #-8]
    arm64.cmp x2, #0
    arm64.b.eq static-variables.main.__skip_guarded_27
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label static-variables.main.__skip_guarded_27
    arm64.ldr x0, [x29, #-24]
    arm64.epilogue stack_size=80
    arm64.ret
  }
  func @__destruct_Thing(ptr: i64) {
  entry:
    arm64.b __destruct_Thing.done
  done:
    arm64.ret
  }
}
---

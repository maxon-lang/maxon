// Test: data-section-mixed-types
var flag = true
var count = 10
var ratio = 2.5

function main() returns ExitCode
  if flag and (count == 10) and (ratio > 2.0) 'read'
    return 0
  end 'read'
  return 1
end 'main'
---
ExitCode: 0
RequiredData: ```
i64 10
f64 2.5
i8 1
```
---
module {
  func @main() -> u32 {
  entry:
    arm64.global_load x0, [flag]
    arm64.global_load x1, [count]
    arm64.mov x2, #10
    arm64.cmp x1, x2
    arm64.cset x3, eq
    arm64.and x4, x0, x3
    arm64.global_fload d0, [ratio]
    arm64.fldr d1, [__float_2]
    arm64.fcmp d0, d1
    arm64.cset x5, gt
    arm64.and x6, x4, x5
    arm64.cmp x6, #0
    arm64.b.ne main.read_0
    arm64.b main.read_0.after
  read_0:
    arm64.mov x0, #0
    arm64.ret
  read_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

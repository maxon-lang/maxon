// Test: static-var-increment
type Counter
  static var count = 0

  static function increment()
    Counter.count = Counter.count + 1
  end 'increment'
end 'Counter'

function main() returns ExitCode
  Counter.increment()
  Counter.increment()
  Counter.increment()
  return Counter.count
end 'main'
---
ExitCode: 3
---
module {
  func @Counter.increment() {
  entry:
    arm64.global_load x0, [Counter.count]
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.global_store [Counter.count], x2
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.bl Counter.increment
    arm64.bl Counter.increment
    arm64.bl Counter.increment
    arm64.global_load x0, [Counter.count]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: data-section-bool-then-i64-sorted
var flag = false
var counter = 42

function main() returns ExitCode
  if flag 'read'
    return 1
  end 'read'
  return counter - 42
end 'main'
---
ExitCode: 0
RequiredData: ```
i64 42
i8 0
```
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.global_load x0, [flag]
    arm64.cmp x0, #0
    arm64.b.ne main.read_0
    arm64.b main.read_0.after
  read_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=16
    arm64.ret
  read_0.after:
    arm64.global_load x0, [counter]
    arm64.mov x1, #42
    arm64.sub x2, x0, x1
    arm64.mov x3, #0
    arm64.cmp x2, x3
    arm64.cset x4, lt
    arm64.mov x5, #4294967295
    arm64.cmp x2, x5
    arm64.cset x6, gt
    arm64.orr x7, x4, x6
    arm64.cmp x7, #0
    arm64.b.ne main.__range_panic_1
    arm64.b main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:
    arm64.mov x0, x2
    arm64.epilogue stack_size=16
    arm64.ret
  }
}

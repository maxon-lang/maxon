// Test: static-var-basic
type Counter
  static var count = 0
end 'Counter'

function main() returns ExitCode
  Counter.count = 42
  return Counter.count
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #42
    arm64.global_store [Counter.count], x0
    arm64.global_load x1, [Counter.count]
    arm64.str x1, [x29, #-8]
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, lt
    arm64.mov x4, #4294967295
    arm64.cmp x1, x4
    arm64.cset x5, gt
    arm64.orr x6, x3, x5
    arm64.cmp x6, #0
    arm64.b.ne static-variables.main.__range_panic_0
    arm64.b static-variables.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_13
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: export-var-basic

typealias Integer = int(i64.min to i64.max)

type Value
  export var n Integer
  var private Integer

  static function create() returns Self
    return Value{n: 42, private: 100}
  end 'create'
end 'Value'

function main() returns ExitCode
  var v = Value.create()
  return v.n
end 'main'

typealias Integer = int(i64.min to i64.max)

type Simple
  var x Integer
  var y Integer

  static function make(a Integer, b Integer) returns Self
    return Simple{x: a, y: b}
  end 'make'

  function sum() returns Integer
    return x + y
  end 'sum'
end 'Simple'

function main() returns ExitCode
  var s = Simple.make(20, b: 22)
  return s.sum()
end 'main'

// Test: union-method
enum Direction
  north
  south

  function isNorth() returns bool
    var result = match self 'check'
      north gives true
      south gives false
    end 'check'
    return result
  end 'isNorth'
end 'Direction'

function main() returns ExitCode
  let d = Direction.north
  if d.isNorth() 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @Direction.isNorth(self: i64) -> i1 {
  entry:
    arm64.prologue stack_size=80
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.str x1, [x29, #-16]
    arm64.str x0, [x29, #-24]
    arm64.b Direction.isNorth.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne Direction.isNorth.check_0.case0
    arm64.b Direction.isNorth.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #1
    arm64.str x0, [x29, #-16]
    arm64.b Direction.isNorth.check_0.merge
  check_0.cmp1:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne Direction.isNorth.check_0.case1
    arm64.b Direction.isNorth.check_0.merge
  check_0.case1:
    arm64.mov x0, #0
    arm64.str x0, [x29, #-16]
    arm64.b Direction.isNorth.check_0.merge
  check_0.merge:
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=80
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Direction.isNorth
    arm64.cmp x0, #0
    arm64.b.ne main.test_0
    arm64.b main.test_0.after
  test_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  test_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

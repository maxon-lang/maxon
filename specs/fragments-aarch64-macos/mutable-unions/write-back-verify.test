// Test: write-back-verify
typealias Integer = int(i64.min to i64.max)

union Wrapper
  none
  some(n Integer)
end 'Wrapper'

function readValue(w Wrapper) returns Integer
  match w 'r'
    some(n) then return n
    none then return 0
  end 'r'
end 'readValue'

function main() returns ExitCode
  var w = Wrapper.some(5)
  match w 'mutate'
    some(n) then n = 99
    none then return 0
  end 'mutate'
  return readValue(w)
end 'main'

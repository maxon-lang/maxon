// Test: ranges.expression-bounds

typealias Integer = int(i64.min to i64.max)

function getStart() returns Integer
    return 1
end 'getStart'

function getEnd() returns Integer
    return 4
end 'getEnd'

function main() returns ExitCode
    var sum = 0
    for i in getStart() to getEnd() 'loop'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 10
---
module {
  func @ranges.getStart() -> i64 {
  entry:
    arm64.mov x0, #1
    arm64.ret
  }
  func @ranges.getEnd() -> i64 {
  entry:
    arm64.mov x0, #4
    arm64.ret
  }
  func @ranges.main() -> u32 {
  entry:
    arm64.prologue stack_size=96
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.bl ranges.getStart
    arm64.str x0, [x29, #-40]
    arm64.bl ranges.getEnd
    arm64.str x0, [x29, #-16]
    arm64.ldr x1, [x29, #-40]
    arm64.str x1, [x29, #-24]
    arm64.b ranges.main.loop_0.header
  loop_0.header:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, le
    arm64.cmp x2, #0
    arm64.b.ne ranges.main.loop_0
    arm64.b ranges.main.loop_0.exit
  loop_0:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-8]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.b ranges.main.loop_0.incr
  loop_0.incr:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.b ranges.main.loop_0.header
  loop_0.exit:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-32]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne ranges.main.__range_panic_1
    arm64.b ranges.main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_20
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:
    arm64.ldr x0, [x29, #-32]
    arm64.epilogue stack_size=96
    arm64.ret
  }
}
---

// Test: ranges.nested-ranges
function main() returns ExitCode
    var sum = 0
    for i in 1 to 3 'outer'
        for j in 1 to 3 'inner'
            sum = sum + i * j
        end 'inner'
    end 'outer'
    return sum
end 'main'
---
ExitCode: 36
---
module {
  func @ranges.main() -> u32 {
  entry:
    arm64.prologue stack_size=144
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.mov x2, #3
    arm64.str x2, [x29, #-16]
    arm64.str x1, [x29, #-24]
    arm64.b ranges.main.outer_0.header
  outer_0.header:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, le
    arm64.cmp x2, #0
    arm64.b.ne ranges.main.outer_0
    arm64.b ranges.main.outer_0.exit
  outer_0:
    arm64.ldr x0, [x29, #-24]
    arm64.str x0, [x29, #-32]
    arm64.mov x1, #1
    arm64.mov x2, #3
    arm64.str x2, [x29, #-40]
    arm64.str x1, [x29, #-48]
    arm64.b ranges.main.inner_1.header
  inner_1.header:
    arm64.ldr x0, [x29, #-48]
    arm64.ldr x1, [x29, #-40]
    arm64.cmp x0, x1
    arm64.cset x2, le
    arm64.cmp x2, #0
    arm64.b.ne ranges.main.inner_1
    arm64.b ranges.main.inner_1.exit
  inner_1:
    arm64.ldr x0, [x29, #-48]
    arm64.ldr x1, [x29, #-32]
    arm64.mul x2, x1, x0
    arm64.ldr x3, [x29, #-8]
    arm64.add x4, x3, x2
    arm64.str x4, [x29, #-8]
    arm64.b ranges.main.inner_1.incr
  inner_1.incr:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-48]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-48]
    arm64.b ranges.main.inner_1.header
  inner_1.exit:
    arm64.b ranges.main.outer_0.incr
  outer_0.incr:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.b ranges.main.outer_0.header
  outer_0.exit:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-56]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne ranges.main.__range_panic_2
    arm64.b ranges.main.__range_ok_2
  __range_panic_2:
    arm64.adrp_add_symdata x0, __panic_msg_29
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_2:
    arm64.ldr x0, [x29, #-56]
    arm64.epilogue stack_size=144
    arm64.ret
  }
}
---

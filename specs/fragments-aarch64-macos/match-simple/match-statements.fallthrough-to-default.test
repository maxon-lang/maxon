    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne match-simple.main.check_0.case0
    arm64.b match-simple.main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #10
    arm64.str x0, [x29, #-8]
    arm64.b match-simple.main.check_0.merge
  check_0.cmp1:
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #2

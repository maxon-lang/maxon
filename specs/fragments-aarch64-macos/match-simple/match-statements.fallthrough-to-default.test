    arm64.b.ne match-simple.main.check_0.case1
    arm64.b match-simple.main.check_0.cmp2
  check_0.case1:
    arm64.mov x0, #20
    arm64.str x0, [x29, #-8]
    arm64.b match-simple.main.check_0.merge
  check_0.cmp2:
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #3
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne match-simple.main.check_0.case2
    arm64.b match-simple.main.check_0.case3
  check_0.case2:
    arm64.mov x0, #30
    arm64.ldr x1, [x29, #-8]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.b match-simple.main.check_0.case3
  check_0.case3:
    arm64.mov x0, #100
    arm64.ldr x1, [x29, #-8]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.b match-simple.main.check_0.merge
  check_0.merge:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne match-simple.main.__range_panic_1
    arm64.b match-simple.main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_25
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic

// Test: docs-example-2
function main() returns ExitCode
  var input = 3
  match input 'eval'
    1 or 2 then return 10
    3 or 4 or 5 then return 20
    default then return 0
  end 'eval'
end 'main'

---
ExitCode: 20
---

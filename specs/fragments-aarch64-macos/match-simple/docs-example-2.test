    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #2
    arm64.cmp x3, x4
    arm64.cset x5, eq
    arm64.orr x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne match-simple.main.eval_0.case0
    arm64.b match-simple.main.eval_0.cmp1
  eval_0.case0:
    arm64.mov x0, #10
    arm64.epilogue stack_size=48
    arm64.ret
  eval_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #3
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #4
    arm64.cmp x3, x4
    arm64.cset x5, eq
    arm64.orr x6, x2, x5
    arm64.ldr x7, [x29, #-8]
    arm64.mov x8, #5
    arm64.cmp x7, x8
    arm64.cset x9, eq
    arm64.orr x10, x6, x9
    arm64.cmp x10, #0
    arm64.b.ne match-simple.main.eval_0.case1
    arm64.b match-simple.main.eval_0.case2
  eval_0.case1:
    arm64.mov x0, #20
    arm64.epilogue stack_size=48
    arm64.ret
  eval_0.case2:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  eval_0.merge:

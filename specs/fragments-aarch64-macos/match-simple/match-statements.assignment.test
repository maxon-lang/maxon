// Test: match-statements.assignment
function main() returns ExitCode
  var x = 2
  var result = 0
  match x 'process'
    1 then result = 100
    2 then result = 200
    default then result = 0
  end 'process'
  return result
end 'main'
---
ExitCode: 200
---
module {
  func @match-simple.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #2
    arm64.str x0, [x29, #-8]
    arm64.b match-simple.main.process_0.cmp0
  process_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne match-simple.main.process_0.case0
    arm64.b match-simple.main.process_0.cmp1
  process_0.case0:
    arm64.mov x0, #100
    arm64.str x0, [x29, #-16]
    arm64.b match-simple.main.process_0.merge
  process_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne match-simple.main.process_0.case1
    arm64.b match-simple.main.process_0.case2
  process_0.case1:
    arm64.mov x0, #200
    arm64.str x0, [x29, #-16]
    arm64.b match-simple.main.process_0.merge
  process_0.case2:
    arm64.mov x0, #0
    arm64.str x0, [x29, #-16]
    arm64.b match-simple.main.process_0.merge
  process_0.merge:
    arm64.ldr x0, [x29, #-16]
    arm64.str x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne match-simple.main.__range_panic_1
    arm64.b match-simple.main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_17
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:
    arm64.ldr x0, [x29, #-24]
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

// Test: docs-example-3
function main() returns ExitCode
  var x = 2
  let result = match x 'convert'
    1 gives 10
    2 gives 20
    3 gives 30
    default gives 0
  end 'convert'
  return result
end 'main'

---
ExitCode: 20

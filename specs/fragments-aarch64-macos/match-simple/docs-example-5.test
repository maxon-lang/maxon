// Test: docs-example-5
union Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = Direction.north
  match dir 'navigate'
    north then return 1
    south then return 2
    east then return 3
    west then return 4
  end 'navigate'
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.jump_table x1, 4 cases, default=main.navigate_0.merge
  navigate_0.case0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  navigate_0.case1:
    arm64.mov x0, #2
    arm64.epilogue stack_size=48
    arm64.ret
  navigate_0.case2:
    arm64.mov x0, #3
    arm64.epilogue stack_size=48
    arm64.ret
  navigate_0.case3:
    arm64.mov x0, #4
    arm64.epilogue stack_size=48
    arm64.ret
  navigate_0.merge:
  }
}
---

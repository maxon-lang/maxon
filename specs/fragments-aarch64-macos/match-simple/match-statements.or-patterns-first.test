// Test: match-statements.or-patterns-first
function main() returns ExitCode
  var x = 1
  match x 'check'
    1 or 2 then return 10
    3 or 4 then return 20
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 10
---
module {
  func @match-simple.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.str x0, [x29, #-8]
    arm64.b match-simple.main.check_0.cmp0
  check_0.cmp0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #2
    arm64.cmp x3, x4
    arm64.cset x5, eq
    arm64.orr x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne match-simple.main.check_0.case0
    arm64.b match-simple.main.check_0.cmp1
  check_0.case0:
    arm64.mov x0, #10
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.cmp1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #3
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #4
    arm64.cmp x3, x4
    arm64.cset x5, eq
    arm64.orr x6, x2, x5
    arm64.cmp x6, #0
    arm64.b.ne match-simple.main.check_0.case1
    arm64.b match-simple.main.check_0.case2
  check_0.case1:
    arm64.mov x0, #20
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.case2:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.merge:
  }
}
---

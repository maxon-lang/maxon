// Test: struct-union-field-array-push
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

export enum Op
	add(value Integer)
	sub(value Integer)
end 'Op'

export type Block
	export var id Integer
	export var ops IntArray
	export var terminator Op

	static function create(id Integer, ops IntArray, terminator Op) returns Self
		return Self{id: id, ops: ops, terminator: terminator}
	end 'create'
end 'Block'

function main() returns ExitCode
	let b = Block.create(id: 0, ops: IntArray.create(), terminator: Op.add(42))
	b.ops.push(1)
	b.ops.push(2)
	b.ops.push(3)
	return b.ops.count()
end 'main'

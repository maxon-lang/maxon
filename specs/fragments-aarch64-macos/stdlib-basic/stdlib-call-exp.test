// Test: stdlib-call-exp
function main() returns ExitCode
  var result = Math.exp(0.0)
  if result == 1.0 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.fldr d0, [__float_0]
    arm64.bl stdlib.Math.exp
    arm64.fldr d1, [__float_1]
    arm64.fcmp d0, d1
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #42
    arm64.epilogue stack_size=16
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

// Test: enum-ordinal.float-backed
enum Threshold
  low = 0.1
  medium = 0.5
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  var t = Threshold.high
  if t.ordinal == 2 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-ordinal.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_0.9]
    arm64.fstr d0, [x29, #-8]
    arm64.fldr d1, [x29, #-8]
    arm64.mov x0, #0
    arm64.fldr d2, [__float_0.1]
    arm64.fcmp d1, d2
    arm64.cset x1, eq
    arm64.mov x2, #0
    arm64.cmp x1, #0
    arm64.csel x3, x2, x0, ne
    arm64.fldr d3, [__float_0.5]
    arm64.fcmp d1, d3
    arm64.cset x4, eq
    arm64.mov x5, #1
    arm64.cmp x4, #0
    arm64.csel x6, x5, x3, ne
    arm64.fldr d4, [__float_0.9]
    arm64.fcmp d1, d4
    arm64.cset x7, eq
    arm64.mov x8, #2
    arm64.cmp x7, #0
    arm64.csel x9, x8, x6, ne
    arm64.mov x10, #2
    arm64.cmp x9, x10
    arm64.cset x11, eq
    arm64.cmp x11, #0
    arm64.b.ne enum-ordinal.main.check_0
    arm64.b enum-ordinal.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

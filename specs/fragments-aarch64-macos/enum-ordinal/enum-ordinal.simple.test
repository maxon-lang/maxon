// Test: enum-ordinal.simple
enum Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  if c.ordinal == 1 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-ordinal.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #0
    arm64.mov x3, #0
    arm64.cmp x1, x3
    arm64.cset x4, eq
    arm64.mov x5, #0
    arm64.cmp x4, #0
    arm64.csel x6, x5, x2, ne
    arm64.mov x7, #1
    arm64.cmp x1, x7
    arm64.cset x8, eq
    arm64.mov x9, #1
    arm64.cmp x8, #0
    arm64.csel x10, x9, x6, ne
    arm64.mov x11, #2
    arm64.cmp x1, x11
    arm64.cset x12, eq
    arm64.mov x13, #2
    arm64.cmp x12, #0
    arm64.csel x14, x13, x10, ne
    arm64.mov x15, #1
    arm64.cmp x14, x15
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne enum-ordinal.main.check_0
    arm64.b enum-ordinal.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

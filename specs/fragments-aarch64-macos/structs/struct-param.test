    arm64.ldr x2, [x29, #-16]
    arm64.ldr x3, [x2, #0]
    arm64.mul x4, x1, x3
    arm64.ldr x5, [x29, #-8]
    arm64.ldr x6, [x5, #8]
    arm64.ldr x7, [x29, #-16]
    arm64.ldr x8, [x7, #8]
    arm64.mul x9, x6, x8
    arm64.add x10, x4, x9
    arm64.mov x0, x10
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #3
    arm64.mov x1, #4
    arm64.mov x2, #0
    arm64.str x2, [x29, #-8]
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x0, [x29, #-16]
    arm64.str x1, [x29, #-8]
    arm64.mov x4, #2
    arm64.mov x5, #1
    arm64.mov x6, #0
    arm64.str x6, [x29, #-24]
    arm64.mov x7, #0
    arm64.str x7, [x29, #-32]
    arm64.str x4, [x29, #-32]
    arm64.str x5, [x29, #-24]
    arm64.add x8, x29, #-16
    arm64.mov x9, x8
    arm64.add x10, x29, #-32
    arm64.mov x11, x10
    arm64.mov x0, x9
    arm64.mov x1, x11
    arm64.bl structs.dot
    arm64.mov x12, #0
    arm64.cmp x0, x12
    arm64.cset x13, lt
    arm64.mov x14, #4294967295
    arm64.cmp x0, x14
    arm64.cset x15, gt

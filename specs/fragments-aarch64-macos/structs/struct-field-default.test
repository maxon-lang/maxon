// Test: struct-field-default
type Counter
  export var value = 0
  export var step = 1

  static function create(value = 0, step = 1) returns Self
  	return Self{value: value, step: step}
  end 'create'
end 'Counter'

function main() returns ExitCode
  var c1 = Counter.create()
  var c2 = Counter.create(value: 40)
  var c3 = Counter.create(value: 10, step: 2)
  return c1.value + c2.value + c3.step
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #40
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.mov x4, #2
    arm64.mov x5, #0
    arm64.str x5, [x29, #-24]
    arm64.str x4, [x29, #-24]
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x7, [x29, #-16]
    arm64.add x8, x6, x7
    arm64.ldr x9, [x29, #-24]
    arm64.add x10, x8, x9
    arm64.mov x11, #0
    arm64.cmp x10, x11
    arm64.cset x12, lt
    arm64.mov x13, #4294967295
    arm64.cmp x10, x13
    arm64.cset x14, gt
    arm64.orr x15, x12, x14
    arm64.cmp x15, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x10
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

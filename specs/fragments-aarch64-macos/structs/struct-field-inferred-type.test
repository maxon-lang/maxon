// Test: struct-field-inferred-type
type Settings
  export let maxRetries = 5
  export var timeout = 50.0

  static function create(maxRetries = 5, timeout = 50.0) returns Self
  	return Self{maxRetries: maxRetries, timeout: timeout}
  end 'create'
end 'Settings'

function main() returns ExitCode
  var s = Settings.create()
  return s.maxRetries + trunc(s.timeout)
end 'main'

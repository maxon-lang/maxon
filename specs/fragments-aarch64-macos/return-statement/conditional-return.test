// Test: conditional-return
function main() returns ExitCode
  var x = 5
  if x > 3 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @return-statement.main() -> u32 {
  entry:
    arm64.mov x0, #5
    arm64.mov x1, #3
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne return-statement.main.check_0
    arm64.b return-statement.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

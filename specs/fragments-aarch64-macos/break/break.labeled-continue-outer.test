// Test: break.labeled-continue-outer
function main() returns ExitCode
  var x = 0
  var count = 0
  while x < 3 'outer'
    x = x + 1
    var y = 0
    while y < 5 'inner'
      y = y + 1
      count = count + 1
      if y == 2 'check'
        continue 'outer'
      end 'check'
    end 'inner'
  end 'outer'
  return count
end 'main'
---
ExitCode: 6
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.str x1, [x29, #-16]
    arm64.b main.outer_0.header
  outer_0.header:
    arm64.mov x0, #3
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.outer_0
    arm64.b main.outer_0.exit
  outer_0:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-8]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.mov x3, #0
    arm64.str x3, [x29, #-24]
    arm64.b main.inner_1.header
  inner_1.header:
    arm64.mov x0, #5
    arm64.ldr x1, [x29, #-24]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.inner_1
    arm64.b main.inner_1.exit
  inner_1:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.mov x3, #1
    arm64.ldr x4, [x29, #-16]
    arm64.add x5, x4, x3
    arm64.str x5, [x29, #-16]
    arm64.mov x6, #2
    arm64.cmp x2, x6
    arm64.cset x7, eq
    arm64.cmp x7, #0
    arm64.b.ne main.check_2
    arm64.b main.check_2.after
  check_2:
    arm64.b main.outer_0.header
  check_2.after:
    arm64.b main.inner_1.header
  inner_1.exit:
    arm64.b main.outer_0.header
  outer_0.exit:
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_3
    arm64.b main.__range_ok_3
  __range_panic_3:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_3:
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

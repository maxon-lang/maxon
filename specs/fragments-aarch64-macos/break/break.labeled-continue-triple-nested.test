// Test: break.labeled-continue-triple-nested
function main() returns ExitCode
  var count = 0
  var a = 0
  while a < 2 'outer'
    a = a + 1
    var b = 0
    while b < 3 'middle'
      b = b + 1
      var c = 0
      while c < 4 'inner'
        c = c + 1
        count = count + 1
        if c == 2 'check'
          continue 'middle'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return count
end 'main'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.str x1, [x29, #-16]
    arm64.b main.outer_0.header
  outer_0.header:
    arm64.mov x0, #2
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.outer_0
    arm64.b main.outer_0.exit
  outer_0:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-16]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-16]
    arm64.mov x3, #0
    arm64.str x3, [x29, #-24]
    arm64.b main.middle_1.header
  middle_1.header:
    arm64.mov x0, #3
    arm64.ldr x1, [x29, #-24]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.middle_1
    arm64.b main.middle_1.exit
  middle_1:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-24]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-24]
    arm64.mov x3, #0
    arm64.str x3, [x29, #-32]
    arm64.b main.inner_2.header
  inner_2.header:
    arm64.mov x0, #4
    arm64.ldr x1, [x29, #-32]
    arm64.cmp x1, x0
    arm64.cset x2, lt
    arm64.cmp x2, #0
    arm64.b.ne main.inner_2
    arm64.b main.inner_2.exit
  inner_2:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-32]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-32]
    arm64.mov x3, #1
    arm64.ldr x4, [x29, #-8]
    arm64.add x5, x4, x3
    arm64.str x5, [x29, #-8]
    arm64.mov x6, #2
    arm64.cmp x2, x6
    arm64.cset x7, eq
    arm64.cmp x7, #0
    arm64.b.ne main.check_3
    arm64.b main.check_3.after
  check_3:
    arm64.b main.middle_1.header
  check_3.after:
    arm64.b main.inner_2.header
  inner_2.exit:
    arm64.b main.middle_1.header
  middle_1.exit:
    arm64.b main.outer_0.header
  outer_0.exit:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_4

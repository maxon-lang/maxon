// Test: break.labeled-break-triple-nested
function main() returns ExitCode
  var result = 0
  while true 'outer'
    while true 'middle'
      while true 'inner'
        result = result + 1
        if result == 5 'check'
          break 'outer'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return result
end 'main'
---
ExitCode: 5
---
module {
  func @break.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.b break.main.outer_0.header
  outer_0.header:
    arm64.mov x0, #1
    arm64.cmp x0, #0
    arm64.b.ne break.main.outer_0
    arm64.b break.main.outer_0.exit
  outer_0:
    arm64.b break.main.middle_1.header
  middle_1.header:
    arm64.mov x0, #1
    arm64.cmp x0, #0
    arm64.b.ne break.main.middle_1
    arm64.b break.main.middle_1.exit
  middle_1:
    arm64.b break.main.inner_2.header
  inner_2.header:
    arm64.mov x0, #1
    arm64.cmp x0, #0
    arm64.b.ne break.main.inner_2
    arm64.b break.main.inner_2.exit
  inner_2:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-8]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-8]
    arm64.mov x3, #5
    arm64.cmp x2, x3
    arm64.cset x4, eq
    arm64.cmp x4, #0
    arm64.b.ne break.main.check_3
    arm64.b break.main.check_3.after
  check_3:
    arm64.b break.main.outer_0.exit
  check_3.after:
    arm64.b break.main.inner_2.header
  inner_2.exit:
    arm64.b break.main.middle_1.header
  middle_1.exit:
    arm64.b break.main.outer_0.header
  outer_0.exit:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-16]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne break.main.__range_panic_4
    arm64.b break.main.__range_ok_4
  __range_panic_4:
    arm64.adrp_add_symdata x0, __panic_msg_15
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_4:
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

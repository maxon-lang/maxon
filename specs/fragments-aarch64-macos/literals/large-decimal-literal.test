// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
  var x = 5368709120
  if x == 0x140000000 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #5368709120
    arm64.mov x1, #5368709120
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

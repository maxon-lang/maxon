// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
  var x = 0x0000_0001_4000_0000
  if x == 5368709120 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @literals.main() -> u32 {
  entry:
    arm64.mov x0, #5368709120
    arm64.mov x1, #5368709120
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne literals.main.check_0
    arm64.b literals.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

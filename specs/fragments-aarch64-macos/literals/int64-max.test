// Test: int64-max
// Test INT64_MAX (9223372036854775807)
function main() returns ExitCode
  var x = 9223372036854775807
  if x > 0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @literals.main() -> u32 {
  entry:
    arm64.mov x0, #9223372036854775807
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne literals.main.check_0
    arm64.b literals.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

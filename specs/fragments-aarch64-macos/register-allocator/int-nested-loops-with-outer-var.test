// Test: int-nested-loops-with-outer-var
function main() returns ExitCode
  var total = 0
  var i = 1
  while i <= 5 'outer'
    var j = 1
    while j <= i 'inner'
      total = total + 1
      j = j + 1
    end 'inner'
    i = i + 1
  end 'outer'
  return total
end 'main'

// Test: int-division-high-pressure
function main() returns ExitCode
  var a = 10
  var b = 20
  var c = 30
  var d = 40
  var e = 50
  var f = 60
  var g = 70
  var h = 2
  return (a + b + c + d + e + f + g) / h
end 'main'
---
ExitCode: 140
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #20
    arm64.mov x2, #30
    arm64.mov x3, #40
    arm64.mov x4, #50
    arm64.mov x5, #60
    arm64.mov x6, #70
    arm64.mov x7, #2
    arm64.add x8, x0, x1
    arm64.add x9, x8, x2
    arm64.add x10, x9, x3
    arm64.add x11, x10, x4
    arm64.add x12, x11, x5
    arm64.add x13, x12, x6
    arm64.sdiv x14, x13, x7
    arm64.mov x15, #0
    arm64.cmp x14, x15
    arm64.cset x0, lt
    arm64.mov x1, #4294967295
    arm64.cmp x14, x1
    arm64.cset x2, gt
    arm64.orr x1, x0, x2
    arm64.cmp x1, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x14
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

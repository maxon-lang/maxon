// Test: int-division-preserves-other-values
function main() returns ExitCode
  var x = 10
  var a = 84
  var b = 2
  var quotient = a / b
  return quotient - x
end 'main'
---
ExitCode: 32
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #10
    arm64.mov x1, #84
    arm64.mov x2, #2
    arm64.sdiv x3, x1, x2
    arm64.sub x4, x3, x0
    arm64.mov x5, #0
    arm64.cmp x4, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x4, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x4
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

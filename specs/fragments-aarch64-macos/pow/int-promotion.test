// Test: int-promotion
function main() returns ExitCode
  var result = Math.pow(3, exponent: 2)  // Ints promoted to float
  return trunc(result)
end 'main'
---
ExitCode: 9
---
module {
  func @pow.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #3
    arm64.mov x1, #2
    arm64.scvtf d0, x0
    arm64.scvtf d1, x1
    arm64.bl stdlib.Math.pow
    arm64.fcvtzs x2, d0
    arm64.str x2, [x29, #-8]
    arm64.mov x3, #0
    arm64.cmp x2, x3
    arm64.cset x4, lt
    arm64.mov x5, #4294967295
    arm64.cmp x2, x5
    arm64.cset x6, gt
    arm64.orr x7, x4, x6
    arm64.cmp x7, #0
    arm64.b.ne pow.main.__range_panic_0
    arm64.b pow.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_11
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

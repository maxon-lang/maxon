// Test: multiple-constants
let A = 1
let B = 2
let C = 3

function main() returns ExitCode
  return A + B + C
end 'main'
---
ExitCode: 6
---
module {
  func @top-level-let.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.mov x1, #2
    arm64.add x2, x0, x1
    arm64.mov x3, #3
    arm64.add x4, x2, x3
    arm64.str x4, [x29, #-8]
    arm64.mov x5, #0
    arm64.cmp x4, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x4, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne top-level-let.main.__range_panic_0
    arm64.b top-level-let.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_10
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

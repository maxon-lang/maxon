// Test: decref-drops-last-ref
typealias Integer = int(i64.min to i64.max)
type Tag
    export var id Integer

    static function create(id Integer) returns Self
    	return Self{id: id}
    end 'create'
end 'Tag'
function main() returns ExitCode
    var a = Tag.create(id: 1)
    a = Tag.create(id: 2)
    a = Tag.create(id: 3)
    return a.id
end 'main'

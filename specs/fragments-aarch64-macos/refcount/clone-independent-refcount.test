// Test: clone-independent-refcount
typealias Integer = int(i64.min to i64.max)
type Pair
    export var a Integer
    export var b Integer
end 'Pair'
function main() returns ExitCode
    var x = Pair{a: 3, b: 4}
    var y = x.clone()
    x = Pair{a: 0, b: 0}
    return y.a + y.b
end 'main'

    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.cmp x4, #0
    arm64.b.eq refcount.main.__skip_guarded_23
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label refcount.main.__skip_guarded_23
    arm64.ldr x5, [x29, #-16]
    arm64.str x5, [x29, #-8]
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x7, [x29, #-16]
    arm64.cmp x7, #0
    arm64.b.eq refcount.main.__skip_guarded_28
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label refcount.main.__skip_guarded_28
    arm64.b refcount.main.a_0.merge
  a_0.merge:
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.str x1, [x29, #-24]
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, lt
    arm64.mov x4, #4294967295
    arm64.cmp x1, x4
    arm64.cset x5, gt
    arm64.orr x6, x3, x5
    arm64.cmp x6, #0
    arm64.b.ne refcount.main.__range_panic_1
    arm64.b refcount.main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_22
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:

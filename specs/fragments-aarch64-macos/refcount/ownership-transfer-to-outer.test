    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.mov x4, #1
    arm64.cmp x4, #0
    arm64.b.ne refcount.main.a_0
    arm64.b refcount.main.a_0.merge
  a_0:
    arm64.mov x0, #50

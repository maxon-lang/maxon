// Test: decref-reclaims-same-scope
typealias Integer = int(i64.min to i64.max)
type Val
    export var n Integer
end 'Val'
function main() returns ExitCode
    var a = Val{n: 10}
    var b = a
    a = Val{n: 20}
    return a.n + b.n
end 'main'

// Test: alias-survives-inner-scope
typealias Integer = int(i64.min to i64.max)
type Box
    export var value Integer
end 'Box'
function main() returns ExitCode
    var result = Box{value: 0}
    if true 'blk'
        var inner = Box{value: 42}
        result = inner
    end 'blk'
    return result.value
end 'main'

    arm64.cmp x5, x4
    arm64.cset x6, eq
    arm64.cmp x6, #0
    arm64.b.ne refcount.main.brk_1
    arm64.b refcount.main.brk_1.after
  brk_1:
    arm64.ldr x0, [x29, #-24]

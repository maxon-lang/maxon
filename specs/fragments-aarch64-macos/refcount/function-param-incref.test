// Test: function-param-incref
typealias Integer = int(i64.min to i64.max)
type Config
    export var level Integer

    static function create(level Integer) returns Self
    	return Self{level: level}
    end 'create'
end 'Config'
function readLevel(c Config) returns Integer
    return c.level
end 'readLevel'
function main() returns ExitCode
    var cfg = Config.create(level: 77)
    let l = readLevel(cfg)
    return l + cfg.level - 77
end 'main'
---
ExitCode: 77
---
module {
  func @refcount.readLevel(c: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #77
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl refcount.readLevel
    arm64.ldr x4, [x29, #-8]
    arm64.add x5, x0, x4
    arm64.mov x6, #77
    arm64.sub x7, x5, x6
    arm64.mov x8, #0
    arm64.cmp x7, x8
    arm64.cset x9, lt
    arm64.mov x10, #4294967295
    arm64.cmp x7, x10
    arm64.cset x11, gt
    arm64.orr x12, x9, x11
    arm64.cmp x12, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x7
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

// Test: multiple-aliases
typealias Integer = int(i64.min to i64.max)
type Data
    export var n Integer

    static function create(n Integer) returns Self
    	return Self{n: n}
    end 'create'
end 'Data'
function main() returns ExitCode
    var a = Data.create(n: 7)
    var b = a
    var c = a
    return a.n + b.n + c.n
end 'main'
---
ExitCode: 21
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #7
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.ldr x2, [x29, #-8]
    arm64.ldr x3, [x29, #-8]
    arm64.add x4, x2, x3
    arm64.ldr x5, [x29, #-8]
    arm64.add x6, x4, x5
    arm64.mov x7, #0
    arm64.cmp x6, x7
    arm64.cset x8, lt
    arm64.mov x9, #4294967295
    arm64.cmp x6, x9
    arm64.cset x10, gt
    arm64.orr x11, x8, x10
    arm64.cmp x11, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x6
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

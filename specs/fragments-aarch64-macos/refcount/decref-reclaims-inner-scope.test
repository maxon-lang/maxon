// Test: decref-reclaims-inner-scope
typealias Integer = int(i64.min to i64.max)
type Cell
    export var value Integer

    static function create(value Integer) returns Self
    	return Self{value: value}
    end 'create'
end 'Cell'
function main() returns ExitCode
    var a = Cell.create(value: 10)
    var result = 0
    if true 'inner'
        var b = a
        a = Cell.create(value: 20)
        result = b.value
    end 'inner'
    return result + a.value
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=96
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #10
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-16]
    arm64.ldr x2, [x29, #-16]
    arm64.mov x3, #10
    arm64.str x3, [x2, #0]
    arm64.ldr x4, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.mov x5, #0
    arm64.str x5, [x29, #-24]
    arm64.mov x6, #1
    arm64.cmp x6, #0
    arm64.b.ne main.inner_0
    arm64.b main.inner_0.merge
  inner_0:
    arm64.ldr x0, [x29, #-16]
    arm64.str x0, [x29, #-32]
    arm64.ldr x1, [x29, #-32]
    arm64.ldr x0, [x29, #-32]
    arm64.bl mm_incref
    arm64.mov x2, #20
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x3, [x29, #-8]
    arm64.mov x4, #20
    arm64.str x4, [x3, #0]
    arm64.bl mm_incref
    arm64.ldr x5, [x29, #-16]
    arm64.cmp x5, #0
    arm64.b.eq main.__skip_guarded_30
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_30
    arm64.ldr x6, [x29, #-8]
    arm64.str x6, [x29, #-16]
    arm64.ldr x7, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x8, [x29, #-32]
    arm64.ldr x9, [x8, #0]
    arm64.str x9, [x29, #-24]
    arm64.ldr x10, [x29, #-32]
    arm64.cmp x10, #0
    arm64.b.eq main.__skip_guarded_38
    arm64.ldr x0, [x29, #-32]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_38
    arm64.ldr x11, [x29, #-8]
    arm64.cmp x11, #0
    arm64.b.eq main.__skip_guarded_40
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_40
    arm64.mov x12, #0
    arm64.str x12, [x29, #-8]
    arm64.b main.inner_0.merge
  inner_0.merge:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x0, #0]
    arm64.ldr x2, [x29, #-24]
    arm64.add x3, x2, x1
    arm64.mov x4, #0
    arm64.cmp x3, x4
    arm64.cset x5, lt
    arm64.mov x6, #4294967295
    arm64.cmp x3, x6
    arm64.cset x7, gt
    arm64.orr x8, x5, x7
    arm64.cmp x8, #0
    arm64.b.ne main.__range_panic_1
    arm64.b main.__range_ok_1
  __range_panic_1:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_1:
    arm64.ldr x0, [x29, #-16]
    arm64.str x3, [x29, #-40]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_58
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_58
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_60
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref

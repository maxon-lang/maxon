    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.mov x4, #20
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-16]
    arm64.ldr x5, [x29, #-16]
    arm64.mov x6, #20
    arm64.str x6, [x5, #0]
    arm64.bl mm_incref
    arm64.ldr x7, [x29, #-8]
    arm64.cmp x7, #0
    arm64.b.eq refcount.main.__skip_guarded_20
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label refcount.main.__skip_guarded_20
    arm64.ldr x8, [x29, #-16]
    arm64.str x8, [x29, #-8]
    arm64.ldr x9, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x10, [x29, #-8]
    arm64.ldr x11, [x10, #0]
    arm64.str x11, [x29, #-24]
    arm64.mov x12, #0
    arm64.cmp x11, x12
    arm64.cset x13, lt
    arm64.mov x14, #4294967295
    arm64.cmp x11, x14
    arm64.cset x15, gt
    arm64.orr x0, x13, x15
    arm64.cmp x0, #0
    arm64.b.ne refcount.main.__range_panic_0
    arm64.b refcount.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_20
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq refcount.main.__skip_guarded_38
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label refcount.main.__skip_guarded_38
    arm64.ldr x2, [x29, #-16]
    arm64.cmp x2, #0
    arm64.b.eq refcount.main.__skip_guarded_40
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label refcount.main.__skip_guarded_40
    arm64.ldr x0, [x29, #-24]
    arm64.epilogue stack_size=80

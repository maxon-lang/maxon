// Test: reassignment-decrefs-old
typealias Integer = int(i64.min to i64.max)
type Item
    export var val Integer
end 'Item'
function main() returns ExitCode
    var a = Item{val: 10}
    a = Item{val: 20}
    return a.val
end 'main'
---
ExitCode: 20
---
module {
  func @refcount.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #10

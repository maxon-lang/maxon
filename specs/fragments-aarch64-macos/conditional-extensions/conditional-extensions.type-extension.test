// Test: conditional-extensions.type-extension
type Box uses Item
  export var item Item
end 'Box'

extension Box where Item is Equatable
  function matches(other Item) returns bool
    return item == other
  end 'matches'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
  var b = IntBox.create(item: 42)
  if b.matches(42) 'yes'
    return 1
  end 'yes'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #42
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.mov x1, #42
    arm64.bl IntBox.matches
    arm64.cmp x0, #0
    arm64.b.ne main.yes_0
    arm64.b main.yes_0.after
  yes_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  yes_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @IntBox.matches(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x2, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.mov x0, x2
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: basic-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 2}
  if a.equals(b) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x3, [x0, #8]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x1, #0]
    arm64.cmp x2, x0
    arm64.cset x1, eq
    arm64.ldr x2, [x29, #-16]
    arm64.ldr x0, [x2, #8]
    arm64.cmp x3, x0
    arm64.cset x2, eq
    arm64.and x3, x1, x2
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #1
    arm64.mov x1, #2
    arm64.mov x2, #0
    arm64.str x2, [x29, #-8]
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x0, [x29, #-16]
    arm64.str x1, [x29, #-8]
    arm64.mov x4, #1
    arm64.mov x5, #2
    arm64.mov x6, #0
    arm64.str x6, [x29, #-24]
    arm64.mov x7, #0
    arm64.str x7, [x29, #-32]
    arm64.str x4, [x29, #-32]
    arm64.str x5, [x29, #-24]
    arm64.add x8, x29, #-16
    arm64.mov x9, x8
    arm64.add x10, x29, #-32
    arm64.mov x11, x10
    arm64.mov x0, x9
    arm64.mov x1, x11
    arm64.bl Point.equals
    arm64.cmp x0, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

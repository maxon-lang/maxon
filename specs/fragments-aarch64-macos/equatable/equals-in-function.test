// Test: equals-in-function

typealias Integer = int(i64.min to i64.max)

type Id implements Equatable
  export var n Integer

  function equals(other Id) returns bool
    return n == other.n
  end 'equals'
end 'Id'

function areEqual(a Id, b Id) returns bool
  return a.equals(b)
end 'areEqual'

function main() returns ExitCode
  var x = Id{n: 5}
  var y = Id{n: 5}
  var z = Id{n: 6}
  if areEqual(x, b: y) 'eq'
    if areEqual(x, b: z) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Id.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x1, #0]
    arm64.cmp x2, x0
    arm64.cset x1, eq
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @equatable.areEqual(a: i64, b: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.str x1, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.bl Id.equals
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #5
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #5
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.mov x4, #6
    arm64.mov x5, #0
    arm64.str x5, [x29, #-24]
    arm64.str x4, [x29, #-24]
    arm64.add x6, x29, #-8
    arm64.mov x7, x6
    arm64.add x8, x29, #-16
    arm64.mov x9, x8
    arm64.mov x0, x7
    arm64.mov x1, x9
    arm64.bl equatable.areEqual
    arm64.cmp x0, #0
    arm64.b.ne main.eq_0
    arm64.b main.eq_0.after
  eq_0:
    arm64.add x0, x29, #-8
    arm64.mov x1, x0
    arm64.add x2, x29, #-24
    arm64.mov x3, x2
    arm64.mov x0, x1
    arm64.mov x1, x3
    arm64.bl equatable.areEqual
    arm64.cmp x0, #0
    arm64.b.ne main.neq_1
    arm64.b main.neq_1.after
  neq_1:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  neq_1.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  eq_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

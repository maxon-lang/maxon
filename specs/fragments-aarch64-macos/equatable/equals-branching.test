// Test: equals-branching

typealias Integer = int(i64.min to i64.max)

type Token implements Equatable
  export var id Integer

  function equals(other Token) returns bool
    return id == other.id
  end 'equals'
end 'Token'

function main() returns ExitCode
  var a = Token{id: 10}
  var b = Token{id: 10}
  var c = Token{id: 20}
  var result = 0
  if a.equals(b) 'first'
    result = result + 1
  end 'first'
  if a.equals(c) 'second'
    result = result + 10
  end 'second'
  if b.equals(c) 'third'
    result = result + 100
  end 'third'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @Token.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x1, #0]
    arm64.cmp x2, x0
    arm64.cset x1, eq
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #10
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.mov x2, #10
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.mov x4, #20
    arm64.mov x5, #0
    arm64.str x5, [x29, #-24]
    arm64.str x4, [x29, #-24]
    arm64.mov x6, #0
    arm64.str x6, [x29, #-32]
    arm64.add x7, x29, #-8
    arm64.mov x8, x7
    arm64.add x9, x29, #-16
    arm64.mov x10, x9
    arm64.mov x0, x8
    arm64.mov x1, x10
    arm64.bl Token.equals
    arm64.cmp x0, #0
    arm64.b.ne main.first_0
    arm64.b main.first_0.merge
  first_0:
    arm64.mov x0, #1
    arm64.ldr x1, [x29, #-32]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-32]
    arm64.b main.first_0.merge
  first_0.merge:
    arm64.add x0, x29, #-8
    arm64.mov x1, x0
    arm64.add x2, x29, #-24
    arm64.mov x3, x2
    arm64.mov x0, x1
    arm64.mov x1, x3
    arm64.bl Token.equals
    arm64.cmp x0, #0
    arm64.b.ne main.second_1
    arm64.b main.second_1.merge
  second_1:
    arm64.mov x0, #10
    arm64.ldr x1, [x29, #-32]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-32]
    arm64.b main.second_1.merge
  second_1.merge:
    arm64.add x0, x29, #-16
    arm64.mov x1, x0
    arm64.add x2, x29, #-24
    arm64.mov x3, x2
    arm64.mov x0, x1
    arm64.mov x1, x3
    arm64.bl Token.equals
    arm64.cmp x0, #0
    arm64.b.ne main.third_2
    arm64.b main.third_2.merge
  third_2:
    arm64.mov x0, #100
    arm64.ldr x1, [x29, #-32]
    arm64.add x2, x1, x0
    arm64.str x2, [x29, #-32]
    arm64.b main.third_2.merge
  third_2.merge:
    arm64.ldr x0, [x29, #-32]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_3
    arm64.b main.__range_ok_3
  __range_panic_3:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_3:
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

// Test: self-equality

typealias Integer = int(i64.min to i64.max)

type Box implements Equatable
  export var value Integer

  function equals(other Box) returns bool
    return value == other.value
  end 'equals'

  static function create(value Integer) returns Self
  	return Self{value: value}
  end 'create'
end 'Box'

function main() returns ExitCode
  var a = Box.create(value: 7)
  if a.equals(a) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Box.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x1, #0]
    arm64.cmp x2, x0
    arm64.cset x1, eq
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #7
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x3
    arm64.mov x1, x5
    arm64.bl Box.equals
    arm64.cmp x0, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: self-equality

typealias Integer = int(i64.min to i64.max)

type Box implements Equatable
  export var value Integer

  function equals(other Box) returns bool
    return value == other.value
  end 'equals'
end 'Box'

function main() returns ExitCode
  var a = Box{value: 7}
  if a.equals(a) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Box.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.str x1, [x29, #-16]
    arm64.ldr x1, [x29, #-16]
    arm64.ldr x0, [x1, #0]
    arm64.cmp x2, x0
    arm64.cset x1, eq
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @equatable.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #7
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #7
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x5, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.bl Box.equals
    arm64.cmp x0, #0
    arm64.b.ne equatable.main.check_0
    arm64.b equatable.main.check_0.after
  check_0:
    arm64.ldr x0, [x29, #-8]
    arm64.cmp x0, #0
    arm64.b.eq equatable.main.__skip_guarded_16
    arm64.bl mm_decref
    arm64.label equatable.main.__skip_guarded_16
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  check_0.after:
    arm64.ldr x0, [x29, #-8]
    arm64.cmp x0, #0
    arm64.b.eq equatable.main.__skip_guarded_20
    arm64.bl mm_decref
    arm64.label equatable.main.__skip_guarded_20
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @__destruct_Box(ptr: i64) {
  entry:
    arm64.b __destruct_Box.done
  done:
    arm64.ret
  }
}
---

// Test: multiple-associated-types

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

interface Pair uses First, Second
  function getFirst() returns First
  function getSecond() returns Second
end 'Pair'

type IntFloat implements Pair with Integer, Float
  var a Integer
  var b Float

  function getFirst() returns Integer
    return a
  end 'getFirst'

  function getSecond() returns Float
    return b
  end 'getSecond'

  static function create(a Integer, b Float) returns Self
  	return Self{a: a, b: b}
  end 'create'
end 'IntFloat'

function main() returns ExitCode
  var p = IntFloat.create(a: 40, b: 2.5)
  var x = p.getFirst()
  var y = trunc(p.getSecond())
  return x + y
end 'main'
---
ExitCode: 42
---
module {
  func @IntFloat.getFirst(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @IntFloat.getSecond(__self_ptr: i64) -> f64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.fldr d0, [x0, #8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=64
    arm64.mov x0, #40
    arm64.fldr d0, [__float_2.5]
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.mov x2, #0
    arm64.str x2, [x29, #-16]
    arm64.str x0, [x29, #-16]
    arm64.fstr d0, [x29, #-8]
    arm64.add x3, x29, #-16
    arm64.mov x4, x3
    arm64.mov x0, x4
    arm64.bl IntFloat.getFirst
    arm64.add x5, x29, #-16
    arm64.mov x6, x5
    arm64.str x0, [x29, #-24]
    arm64.mov x0, x6
    arm64.bl IntFloat.getSecond
    arm64.fcvtzs x7, d0
    arm64.ldr x8, [x29, #-24]
    arm64.add x9, x8, x7
    arm64.mov x10, #0
    arm64.cmp x9, x10
    arm64.cset x11, lt
    arm64.mov x12, #4294967295
    arm64.cmp x9, x12
    arm64.cset x13, gt
    arm64.orr x14, x11, x13
    arm64.cmp x14, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x9
    arm64.epilogue stack_size=64
    arm64.ret
  }
}

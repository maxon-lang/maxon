    arm64.ldr x0, [x29, #-8]
    arm64.bl SingleByte.getByte
    arm64.str x0, [x29, #-16]
    arm64.mov x7, #0
    arm64.cmp x0, x7
    arm64.cset x8, lt
    arm64.mov x9, #4294967295
    arm64.cmp x0, x9
    arm64.cset x10, gt
    arm64.orr x11, x8, x10
    arm64.cmp x11, #0
    arm64.b.ne associated-types.main.__range_panic_0
    arm64.b associated-types.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_22
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:

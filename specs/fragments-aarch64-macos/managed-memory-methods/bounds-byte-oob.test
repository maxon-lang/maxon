// Test: bounds-byte-oob
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(1)
  arr.push(2)
  var b = arr.managed.byteAt(100)
  return b
end 'main'

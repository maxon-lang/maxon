    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #32
    arm64.bl Adder.add
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Adder.getTotal
    arm64.str x0, [x29, #-16]
    arm64.mov x7, #0
    arm64.cmp x0, x7

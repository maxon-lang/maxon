// Test: type-method-returning-value

typealias Integer = int(i64.min to i64.max)

type Calculator
  var value Integer

  function double() returns Integer
    return value * 2
  end 'double'
end 'Calculator'

function main() returns ExitCode
  var c = Calculator{value: 21}
  return c.double()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #2
    arm64.mul x3, x1, x2
    arm64.mov x0, x3
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @type-methods.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #21
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #21
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Calculator.double
    arm64.str x0, [x29, #-16]
    arm64.mov x5, #0
    arm64.cmp x0, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x0, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne type-methods.main.__range_panic_0
    arm64.b type-methods.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_22
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq type-methods.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label type-methods.main.__skip_guarded_24
    arm64.ldr x0, [x29, #-16]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @__destruct_Calculator(ptr: i64) {
  entry:
    arm64.b __destruct_Calculator.done
  done:
    arm64.ret
  }
}
---

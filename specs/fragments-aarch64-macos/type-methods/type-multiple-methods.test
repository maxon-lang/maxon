// Test: type-multiple-methods

typealias Integer = int(i64.min to i64.max)

type Counter
  var count Integer

  function increment()
    count = count + 1
  end 'increment'

  function decrement()
    count = count - 1
  end 'decrement'

  function reset()
    count = 0
  end 'reset'

  function get() returns Integer
    return count
  end 'get'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 10}
  c.increment()
  c.increment()
  c.decrement()
  return c.get()
end 'main'
---
ExitCode: 11
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #1
    arm64.add x3, x1, x2
    arm64.ldr x4, [x29, #-8]
    arm64.str x3, [x4, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Counter.decrement(__self_ptr: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x2, #1
    arm64.sub x3, x1, x2
    arm64.ldr x4, [x29, #-8]
    arm64.str x3, [x4, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Counter.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #10
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl Counter.increment
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.bl Counter.increment
    arm64.add x6, x29, #-8
    arm64.mov x7, x6
    arm64.mov x0, x7
    arm64.bl Counter.decrement
    arm64.add x8, x29, #-8
    arm64.mov x9, x8
    arm64.mov x0, x9
    arm64.bl Counter.get
    arm64.mov x10, #0
    arm64.cmp x0, x10
    arm64.cset x11, lt
    arm64.mov x12, #4294967295
    arm64.cmp x0, x12
    arm64.cset x13, gt
    arm64.orr x14, x11, x13
    arm64.cmp x14, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic

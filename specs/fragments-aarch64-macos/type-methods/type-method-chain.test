// Test: type-method-chain

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function add(x Integer)
    n = n + x
  end 'add'

  function get() returns Integer
    return n
  end 'get'

  static function create(n Integer) returns Self
  	return Self{n: n}
  end 'create'
end 'Value'

function main() returns ExitCode
  var v = Value.create(n: 0)
  v.add(10)
  v.add(20)
  v.add(12)
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.add(__self_ptr: i64, x: i64) {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x2, [x0, #0]
    arm64.add x0, x2, x1
    arm64.ldr x1, [x29, #-8]
    arm64.str x0, [x1, #0]
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.mov x1, #10
    arm64.bl Value.add
    arm64.add x4, x29, #-8
    arm64.mov x5, x4
    arm64.mov x0, x5
    arm64.mov x1, #20
    arm64.bl Value.add
    arm64.add x6, x29, #-8
    arm64.mov x7, x6
    arm64.mov x0, x7
    arm64.mov x1, #12
    arm64.bl Value.add
    arm64.add x8, x29, #-8
    arm64.mov x9, x8
    arm64.mov x0, x9
    arm64.bl Value.get
    arm64.mov x10, #0
    arm64.cmp x0, x10
    arm64.cset x11, lt
    arm64.mov x12, #4294967295
    arm64.cmp x0, x12
    arm64.cset x13, gt
    arm64.orr x14, x11, x13
    arm64.cmp x14, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}

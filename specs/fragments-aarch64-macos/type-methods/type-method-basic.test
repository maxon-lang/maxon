// Test: type-method-basic

typealias Integer = int(i64.min to i64.max)

type Counter
  var count Integer

  function increment()
    count = count + 1
  end 'increment'

  function get() returns Integer
    return count
  end 'get'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 0}
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 1
---

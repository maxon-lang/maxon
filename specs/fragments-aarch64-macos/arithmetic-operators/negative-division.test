// Test: negative-division
function main() returns ExitCode
  var neg = -7
  let a = neg / 2           // -7/2 = -3 (truncating toward zero)
  if a == -3 'pass'
      return 0
  end 'pass'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #-7
    arm64.mov x1, #2
    arm64.sdiv x2, x0, x1
    arm64.mov x3, #-3
    arm64.cmp x2, x3
    arm64.cset x4, eq
    arm64.cmp x4, #0
    arm64.b.ne main.pass_0
    arm64.b main.pass_0.after
  pass_0:
    arm64.mov x0, #0
    arm64.ret
  pass_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

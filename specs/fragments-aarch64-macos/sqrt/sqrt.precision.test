// Test: sqrt.precision
function main() returns ExitCode
  var x = sqrt(2.0)
  // sqrt(2) * sqrt(2) should be approximately 2
  var check = x * x
  // Trunc to get integer 2
  return trunc(check)
end 'main'
---
ExitCode: 2
---
module {
  func @sqrt.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.fldr d0, [__float_2]
    arm64.fsqrt d1, d0
    arm64.fmul d2, d1, d1
    arm64.fcvtzs x0, d2
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne sqrt.main.__range_panic_0
    arm64.b sqrt.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_9
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

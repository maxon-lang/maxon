// Test: sqrt.zero
function main() returns ExitCode
  var result = sqrt(0.0)
  if result == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @sqrt.main() -> u32 {
  entry:
    arm64.fldr d0, [__float_0]
    arm64.fsqrt d1, d0
    arm64.fldr d2, [__float_0]
    arm64.fcmp d1, d2
    arm64.cset x0, eq
    arm64.cmp x0, #0
    arm64.b.ne sqrt.main.check_0
    arm64.b sqrt.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

// Test: negate-int
function main() returns ExitCode
  var x = -42
  var y = -x
  if y == 42 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @unary-operators.main() -> u32 {
  entry:
    arm64.mov x0, #-42
    arm64.mov x1, #0
    arm64.sub x2, x1, x0
    arm64.mov x3, #42
    arm64.cmp x2, x3
    arm64.cset x4, eq
    arm64.cmp x4, #0
    arm64.b.ne unary-operators.main.check_0
    arm64.b unary-operators.main.check_0.after
  check_0:
    arm64.mov x0, #0
    arm64.ret
  check_0.after:
    arm64.mov x0, #1
    arm64.ret
  }
}
---

// Test: union-array-push-get
typealias Integer = int(i64.min to i64.max)

export enum Op
    add(value Integer)
    sub(value Integer)
    nop
end 'Op'

typealias OpArray = Array with Op

function main() returns ExitCode
    var ops = OpArray{}
    ops.push(Op.add(10))
    ops.push(Op.sub(20))
    ops.push(Op.add(30))

    let first = try ops.get(0) otherwise Op.nop
    match first 'check'
        add(v) then return v
        sub(_) then return 99
        nop then return 98
    end 'check'
end 'main'

// Test: bool-type-disambiguation
typealias Integer = int(i64.min to i64.max)

function check(value Integer) returns Integer
  return value
end 'check'

function check(value bool) returns Integer
  if value 'branch'
    return 1
  end 'branch' else 'other'
    return 0
  end 'other'
end 'check'

function main() returns ExitCode
  return check(true)
end 'main'
---
ExitCode: 1
---
module {
  func @function-overloads.check$value_i1(value: i1) -> i64 {
  entry:
    arm64.cmp x0, #0
    arm64.b.ne function-overloads.check$value_i1.branch_0
    arm64.b function-overloads.check$value_i1.other_1
  branch_0:
    arm64.mov x0, #1
    arm64.ret
  other_1:
    arm64.mov x0, #0
    arm64.ret
  }
  func @function-overloads.main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.bl function-overloads.check$value_i1
    arm64.str x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x1, #4294967295
    arm64.cmp x0, x1
    arm64.cset x3, gt
    arm64.orr x0, x2, x3
    arm64.cmp x0, #0
    arm64.b.ne function-overloads.main.__range_panic_0
    arm64.b function-overloads.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_11
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-8]
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

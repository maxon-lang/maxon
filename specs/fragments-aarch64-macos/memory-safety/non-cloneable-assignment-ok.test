// Test: non-cloneable-assignment-ok
typealias Integer = int(i64.min to i64.max)

enum Color
  red
  green
  blue
end 'Color'

type Item
  export var color Color
  export var value Integer
end 'Item'

function main() returns ExitCode
  var a = Item{color: Color.red, value: 42}
  var b = a
  b.value = 99
  return a.value
end 'main'
---
ExitCode: 99
---
module {
  func @memory-safety.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #0
    arm64.mov x1, #42
    arm64.mov x0, #16
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x2, [x29, #-8]
    arm64.mov x3, #0
    arm64.str x3, [x2, #0]
    arm64.ldr x4, [x29, #-8]
    arm64.mov x5, #42
    arm64.str x5, [x4, #8]
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x7, [x29, #-8]
    arm64.str x7, [x29, #-16]
    arm64.ldr x8, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.mov x9, #99
    arm64.ldr x10, [x29, #-16]
    arm64.str x9, [x10, #8]
    arm64.ldr x11, [x29, #-8]
    arm64.ldr x12, [x11, #8]
    arm64.str x12, [x29, #-24]
    arm64.mov x13, #0
    arm64.cmp x12, x13
    arm64.cset x14, lt
    arm64.mov x15, #4294967295
    arm64.cmp x12, x15
    arm64.cset x0, gt
    arm64.orr x1, x14, x0
    arm64.cmp x1, #0
    arm64.b.ne memory-safety.main.__range_panic_0
    arm64.b memory-safety.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_35
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-24]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x1, #0
    arm64.b.eq memory-safety.main.__skip_guarded_33
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_decref
    arm64.label memory-safety.main.__skip_guarded_33
    arm64.ldr x2, [x29, #-8]
    arm64.cmp x2, #0
    arm64.b.eq memory-safety.main.__skip_guarded_35
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label memory-safety.main.__skip_guarded_35
    arm64.ldr x0, [x29, #-24]
    arm64.epilogue stack_size=80
    arm64.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    arm64.b __destruct_Item.done
  done:
    arm64.ret
  }
}
---

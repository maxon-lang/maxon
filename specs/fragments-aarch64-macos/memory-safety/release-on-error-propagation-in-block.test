// Test: release-on-error-propagation-in-block
typealias Integer = int(i64.min to i64.max)

type Wrapper
  export var val Integer
end 'Wrapper'

enum LookupError
  case missing
end 'LookupError'

function failingLookup() returns Integer throws LookupError
  throw LookupError.missing
end 'failingLookup'

function compute(flag Integer) returns Integer throws LookupError
  var w = Wrapper{val: flag}
  if w.val > 0 'positive'
    var inner = Wrapper{val: w.val * 2}
    var result = try failingLookup()
    return result + inner.val
  end 'positive'
  return 0
end 'compute'

function main() returns ExitCode
  var result = try compute(flag: 5) otherwise 'err'
    return 77
  end 'err'
  return result
end 'main'
---
ExitCode: 77
---
module {
  func @memory-safety.failingLookup() -> i64 {
  entry:
    arm64.mov x0, #1
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.mov x1, x2
    arm64.mov x0, #0
    arm64.ret
  }
  func @memory-safety.compute(flag: i64) -> i64 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, gt
    arm64.cmp x2, #0
    arm64.b.ne memory-safety.compute.positive_0
    arm64.b memory-safety.compute.positive_0.after
  positive_0:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #2
    arm64.mul x2, x0, x1
    arm64.mov x3, #0
    arm64.str x3, [x29, #-16]
    arm64.str x2, [x29, #-16]
    arm64.bl memory-safety.failingLookup
    arm64.str x1, [x29, #-24]
    arm64.str x0, [x29, #-32]
    arm64.mov x4, #0
    arm64.cmp x1, x4
    arm64.cset x5, ne
    arm64.cmp x5, #0
    arm64.b.ne memory-safety.compute.propagate_error_1
    arm64.b memory-safety.compute.try_continue_2
  propagate_error_1:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, x0
    arm64.mov x0, #0
    arm64.epilogue stack_size=80
    arm64.ret
  try_continue_2:
    arm64.ldr x0, [x29, #-32]
    arm64.ldr x1, [x29, #-16]
    arm64.add x2, x0, x1
    arm64.mov x0, x2
    arm64.mov x1, #0
    arm64.epilogue stack_size=80
    arm64.ret
  positive_0.after:
    arm64.mov x0, #0
    arm64.mov x1, #0
    arm64.epilogue stack_size=80
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #5
    arm64.bl memory-safety.compute
    arm64.str x0, [x29, #-8]
    arm64.mov x0, #0
    arm64.cmp x1, x0
    arm64.cset x2, ne
    arm64.cmp x2, #0
    arm64.b.ne main.otherwise_error_0
    arm64.b main.otherwise_continue_1
  otherwise_error_0:
    arm64.mov x0, #77
    arm64.epilogue stack_size=48
    arm64.ret
  otherwise_continue_1:
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne main.__range_panic_4
    arm64.b main.__range_ok_4
  __range_panic_4:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_4:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

// Test: is-compares-refs
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = a
  if a is b 'same'
    return 1
  end 'same'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #1
    arm64.mov x1, #2
    arm64.mov x0, #16
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x2, [x29, #-8]
    arm64.mov x3, #1
    arm64.str x3, [x2, #0]
    arm64.ldr x4, [x29, #-8]
    arm64.mov x5, #2
    arm64.str x5, [x4, #8]
    arm64.ldr x6, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x7, [x29, #-8]
    arm64.str x7, [x29, #-16]
    arm64.ldr x8, [x29, #-16]
    arm64.ldr x0, [x29, #-16]
    arm64.bl mm_incref
    arm64.ldr x9, [x29, #-8]
    arm64.ldr x10, [x29, #-16]
    arm64.cmp x9, x10
    arm64.cset x11, eq
    arm64.cmp x11, #0
    arm64.b.ne main.same_0
    arm64.b main.same_0.after
  same_0:
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_22
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_22
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_24
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_24
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  same_0.after:
    arm64.ldr x0, [x29, #-16]
    arm64.cmp x0, #0
    arm64.b.eq main.__skip_guarded_28
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_28
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq main.__skip_guarded_30
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label main.__skip_guarded_30
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @__destruct_Point(ptr: i64) {
  entry:
    arm64.b __destruct_Point.done
  done:
    arm64.ret
  }
}
---

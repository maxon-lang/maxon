    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-24]
    arm64.ldr x7, [x29, #-24]
    arm64.mov x8, #10
    arm64.str x8, [x7, #0]
    arm64.ldr x9, [x29, #-24]

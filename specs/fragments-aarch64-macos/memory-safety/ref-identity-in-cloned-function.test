  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.str x1, [x29, #-16]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x29, #-16]
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne memory-safety.isSame.same_0
    arm64.b memory-safety.isSame.same_0.after
  same_0:
    arm64.mov x0, #1
    arm64.epilogue stack_size=48
    arm64.ret
  same_0.after:
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }

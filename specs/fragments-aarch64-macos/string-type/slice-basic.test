// Test: slice-basic
function main() returns ExitCode
  var s = "hello world"
  var start = s.startIndex()
  var spaceIdx = try s.findFirst(" ") otherwise s.endIndex()
  var sub = s.slice(start, endIndex: spaceIdx)
  print(sub)
  return 0
end 'main'

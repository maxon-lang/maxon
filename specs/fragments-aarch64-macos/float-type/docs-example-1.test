// Test: docs-example-1

typealias Radius = float(f64.min to f64.max)

function circleArea(radius Radius) returns Radius
  return 3.14159 * radius * radius
end 'circleArea'

function main() returns ExitCode
  var area = circleArea(5.0)
  return trunc(area)  // Returns 78
end 'main'


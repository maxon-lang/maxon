// Test: float-comparison
function main() returns ExitCode
  var x = 3.5
  var y = 2.1
  if x > y 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @float-type.main() -> u32 {
  entry:
    arm64.fldr d0, [__float_3.5]
    arm64.fldr d1, [__float_2.1]
    arm64.fcmp d0, d1
    arm64.cset x0, gt
    arm64.cmp x0, #0
    arm64.b.ne float-type.main.check_0
    arm64.b float-type.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

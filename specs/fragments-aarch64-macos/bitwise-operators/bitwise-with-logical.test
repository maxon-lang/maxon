// Test: bitwise-with-logical
function main() returns ExitCode
  var a = 5 and 3        // 1
  if a > 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    arm64.mov x0, #5
    arm64.mov x1, #3
    arm64.and x2, x0, x1
    arm64.mov x3, #0
    arm64.cmp x2, x3
    arm64.cset x4, gt
    arm64.cmp x4, #0
    arm64.b.ne bitwise-operators.main.check_0
    arm64.b bitwise-operators.main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

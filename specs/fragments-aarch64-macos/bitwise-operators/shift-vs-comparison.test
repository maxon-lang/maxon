// Test: shift-vs-comparison
function main() returns ExitCode
  // Shift has higher precedence than comparison
  // 1 shl 3 = 8, then 8 > 5 = true
  if 1 shl 3 > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #1
    arm64.mov x1, #3
    arm64.lslv x2, x0, x1
    arm64.mov x3, #5
    arm64.cmp x2, x3
    arm64.cset x4, gt
    arm64.cmp x4, #0
    arm64.b.ne main.check_0
    arm64.b main.check_0.after
  check_0:
    arm64.mov x0, #1
    arm64.ret
  check_0.after:
    arm64.mov x0, #0
    arm64.ret
  }
}
---

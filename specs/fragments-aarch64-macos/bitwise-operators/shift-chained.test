// Test: shift-chained
function main() returns ExitCode
  var a = 1
  return a shl 4 shr 2
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=16
    arm64.mov x0, #1
    arm64.mov x1, #4
    arm64.lslv x2, x0, x1
    arm64.mov x3, #2
    arm64.lsrv x4, x2, x3
    arm64.mov x5, #0
    arm64.cmp x4, x5
    arm64.cset x6, lt
    arm64.mov x7, #4294967295
    arm64.cmp x4, x7
    arm64.cset x8, gt
    arm64.orr x9, x6, x8
    arm64.cmp x9, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.mov x0, x4
    arm64.epilogue stack_size=16
    arm64.ret
  }
}
---

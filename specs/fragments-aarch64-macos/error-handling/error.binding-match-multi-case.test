// Test: error.binding-match-multi-case

typealias Integer = int(i64.min to i64.max)

// Test matching on error binding with multiple cases
union MyError implements Error
  failed
  timeout
  notFound
end 'MyError'

var counter = 0 as Integer

function mayFail(code Integer) returns Integer throws MyError
  counter = counter + 1
  if code == 1 'c1'
    throw MyError.failed
  end 'c1'
  if code == 2 'c2'
    throw MyError.timeout
  end 'c2'
  throw MyError.notFound
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail(2) otherwise (e) 'handler'
    match e 'check'
      MyError.failed then result = 10
      MyError.timeout then result = 20
      MyError.notFound then result = 30
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @error-handling.mayFail(code: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.global_load x1, [counter]
    arm64.mov x2, #1
    arm64.add x3, x1, x2
    arm64.global_store [counter], x3
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne error-handling.mayFail.c1_0
    arm64.b error-handling.mayFail.c1_0.after
  c1_0:
    arm64.mov x0, #0
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.mov x1, x2
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  c1_0.after:
    arm64.mov x0, #2
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, x0
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne error-handling.mayFail.c2_1
    arm64.b error-handling.mayFail.c2_1.after
  c2_1:
    arm64.mov x0, #1
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.mov x1, x2
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  c2_1.after:
    arm64.mov x0, #2
    arm64.mov x1, #1
    arm64.add x2, x0, x1
    arm64.mov x1, x2
    arm64.mov x0, #0
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    arm64.prologue stack_size=80
    arm64.mov x0, #0
    arm64.str x0, [x29, #-8]
    arm64.mov x0, #2
    arm64.bl error-handling.mayFail
    arm64.str x1, [x29, #-16]
    arm64.mov x2, #0
    arm64.cmp x1, x2
    arm64.cset x3, ne
    arm64.cmp x3, #0
    arm64.b.ne error-handling.main.otherwise_error_0
    arm64.b error-handling.main.otherwise_continue_1
  otherwise_error_0:
    arm64.ldr x0, [x29, #-16]
    arm64.mov x1, #1
    arm64.sub x2, x0, x1
    arm64.str x2, [x29, #-24]
    arm64.b error-handling.main.check_4.cmp0
  check_4.cmp0:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne error-handling.main.check_4.case0
    arm64.b error-handling.main.check_4.cmp1
  check_4.case0:
    arm64.mov x0, #10
    arm64.str x0, [x29, #-8]
    arm64.b error-handling.main.check_4.merge
  check_4.cmp1:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #1
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne error-handling.main.check_4.case1
    arm64.b error-handling.main.check_4.cmp2
  check_4.case1:
    arm64.mov x0, #20
    arm64.str x0, [x29, #-8]
    arm64.b error-handling.main.check_4.merge
  check_4.cmp2:
    arm64.ldr x0, [x29, #-24]
    arm64.mov x1, #2
    arm64.cmp x0, x1
    arm64.cset x2, eq
    arm64.cmp x2, #0
    arm64.b.ne error-handling.main.check_4.case2
    arm64.b error-handling.main.check_4.merge
  check_4.case2:
    arm64.mov x0, #30
    arm64.str x0, [x29, #-8]
    arm64.b error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    arm64.ldr x0, [x29, #-8]
    arm64.str x0, [x29, #-32]
    arm64.mov x1, #0
    arm64.cmp x0, x1
    arm64.cset x2, lt
    arm64.mov x3, #4294967295
    arm64.cmp x0, x3
    arm64.cset x4, gt
    arm64.orr x5, x2, x4
    arm64.cmp x5, #0
    arm64.b.ne error-handling.main.__range_panic_5
    arm64.b error-handling.main.__range_ok_5
  __range_panic_5:
    arm64.adrp_add_symdata x0, __panic_msg_50
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_5:
    arm64.ldr x0, [x29, #-32]
    arm64.epilogue stack_size=80
    arm64.ret
  }
}
---

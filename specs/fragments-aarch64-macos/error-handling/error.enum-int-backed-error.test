// Test: error.enum-int-backed-error
// Int-backed union error type (type inferred from values)
union MyError implements Error
  invalidInput = 1
  notFound = 404
end 'MyError'

function main() returns ExitCode
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    arm64.mov x0, #42
    arm64.ret
  }
}
---

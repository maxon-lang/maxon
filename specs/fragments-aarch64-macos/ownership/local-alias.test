// Test: local-alias
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function testAlias()
  var p = Point{x: 3, y: 4}
  let q = p
  print("{q.x}\n")
  print("{p.y}\n")
end 'testAlias'

function main() returns ExitCode
  testAlias()
  return 0
end 'main'

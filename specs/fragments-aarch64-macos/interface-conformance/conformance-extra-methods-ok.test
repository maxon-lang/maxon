// Test: conformance-extra-methods-ok

typealias Integer = int(i64.min to i64.max)

interface Simple
  function getValue() returns Integer
end 'Simple'

type Extended implements Simple
  var value Integer

  function getValue() returns Integer
    return value
  end 'getValue'

  function extraMethod() returns Integer
    return 100
  end 'extraMethod'
end 'Extended'

function main() returns ExitCode
  var e = Extended{value: 42}
  return e.getValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Extended.getValue(__self_ptr: i64) -> i64 {
  entry:
    arm64.prologue stack_size=48
    arm64.str x0, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.ldr x1, [x0, #0]
    arm64.mov x0, x1
    arm64.epilogue stack_size=48
    arm64.ret
  }
  func @main() -> u32 {
  entry:
    arm64.prologue stack_size=48
    arm64.mov x0, #42
    arm64.mov x1, #0
    arm64.str x1, [x29, #-8]
    arm64.str x0, [x29, #-8]
    arm64.add x2, x29, #-8
    arm64.mov x3, x2
    arm64.mov x0, x3
    arm64.bl Extended.getValue
    arm64.mov x4, #0
    arm64.cmp x0, x4
    arm64.cset x5, lt
    arm64.mov x6, #4294967295
    arm64.cmp x0, x6
    arm64.cset x7, gt
    arm64.orr x8, x5, x7
    arm64.cmp x8, #0
    arm64.b.ne main.__range_panic_0
    arm64.b main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_0
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.epilogue stack_size=48
    arm64.ret
  }
}
---

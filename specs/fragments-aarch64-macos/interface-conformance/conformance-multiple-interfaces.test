    arm64.prologue stack_size=48
    arm64.mov x0, #0
    arm64.mov x0, #8
    arm64.mov x1, #0
    arm64.mov x2, #1
    arm64.bl mm_alloc
    arm64.str x0, [x29, #-8]
    arm64.ldr x1, [x29, #-8]
    arm64.mov x2, #0
    arm64.str x2, [x1, #0]
    arm64.ldr x3, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_incref
    arm64.ldr x4, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.mov x1, #42
    arm64.bl Buffer.write
    arm64.ldr x5, [x29, #-8]
    arm64.ldr x0, [x29, #-8]
    arm64.bl Buffer.read
    arm64.str x0, [x29, #-16]
    arm64.mov x6, #0
    arm64.cmp x0, x6
    arm64.cset x7, lt
    arm64.mov x8, #4294967295
    arm64.cmp x0, x8
    arm64.cset x9, gt
    arm64.orr x10, x7, x9
    arm64.cmp x10, #0
    arm64.b.ne interface-conformance.main.__range_panic_0
    arm64.b interface-conformance.main.__range_ok_0
  __range_panic_0:
    arm64.adrp_add_symdata x0, __panic_msg_24
    arm64.mov x1, x0
    arm64.mov x0, x1
    arm64.bl maxon_panic
  __range_ok_0:
    arm64.ldr x0, [x29, #-16]
    arm64.ldr x1, [x29, #-8]
    arm64.cmp x1, #0
    arm64.b.eq interface-conformance.main.__skip_guarded_27
    arm64.ldr x0, [x29, #-8]
    arm64.bl mm_decref
    arm64.label interface-conformance.main.__skip_guarded_27
    arm64.ldr x0, [x29, #-16]

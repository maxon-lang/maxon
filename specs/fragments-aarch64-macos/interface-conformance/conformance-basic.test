// Test: conformance-basic

typealias Integer = int(i64.min to i64.max)

interface Counter
  function get() returns Integer
  function increment()
end 'Counter'

type SimpleCounter implements Counter
  var value Integer

  function get() returns Integer
    return value
  end 'get'

  function increment()
    value = value + 1
  end 'increment'
end 'SimpleCounter'

function main() returns ExitCode
  var c = SimpleCounter{value: 40}
  c.increment()
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 42
---

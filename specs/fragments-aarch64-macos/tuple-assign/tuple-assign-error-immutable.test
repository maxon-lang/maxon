// Test: tuple-assign-error-immutable
typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
  return (a, b)
end 'makePair'

function main() returns ExitCode
  let x = 0
  var y = 0
  (x, y) = makePair(10, b: 32)
  return x + y
end 'main'

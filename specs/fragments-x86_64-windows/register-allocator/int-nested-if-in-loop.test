// Test: int-nested-if-in-loop
function main() returns ExitCode
	var result = 0
	var i = 1
	while i <= 10 'loop'
		if i <= 5 'first'
			result = result + i
		end 'first' else 'second'
			result = result + i * 2
		end 'second'
		i = i + 1
	end 'loop'
	return result mod 256
end 'main'

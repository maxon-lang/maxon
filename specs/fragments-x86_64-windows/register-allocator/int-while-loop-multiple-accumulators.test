// Test: int-while-loop-multiple-accumulators
function main() returns ExitCode
	var even_sum = 0
	var odd_sum = 0
	var count = 0
	var i = 0
	while i < 20 'loop'
		if i mod 2 == 0 'even'
			even_sum = even_sum + i
			count = count + 1
		end 'even' else 'odd'
			odd_sum = odd_sum + i
		end 'odd'
		i = i + 1
	end 'loop'
	return (even_sum + odd_sum + count) mod 256
end 'main'

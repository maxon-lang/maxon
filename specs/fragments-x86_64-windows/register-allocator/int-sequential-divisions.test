// Test: int-sequential-divisions
function main() returns ExitCode
	var a = 100
	var b = 5
	var c = 84
	var d = 4
	return a / b + c / d
end 'main'
---
ExitCode: 41
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 100
    x86.mov rcx, 5
    x86.mov rdx, 84
    x86.mov rbx, 4
    x86.cqo
    x86.idiv rcx
    x86.mov rsi, 84
    x86.mov [rbp-8], rax
    x86.mov rax, rsi
    x86.cqo
    x86.idiv rbx
    x86.mov rdi, [rbp-8]
    x86.add rdi, rax
    x86.xor r8, r8
    x86.mov r9, 4294967295
    x86.cmp rdi, r9
    x86.jg main.__range_panic_0
    x86.cmp rdi, r8
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdi
    x86.epilogue
    x86.ret
  }
}
---

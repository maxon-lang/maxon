// Test: int-sequential-divisions
function main() returns ExitCode
  var a = 100
  var b = 5
  var c = 84
  var d = 4
  return a / b + c / d
end 'main'
---
ExitCode: 41
---
module {
  func @register-allocator.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 100
    x86.mov rcx, 5
    x86.mov rdx, 84
    x86.mov rbx, 4
    x86.cqo
    x86.idiv rcx
    x86.mov rsi, 84
    x86.mov [rbp-16], rax
    x86.mov rax, rsi
    x86.cqo
    x86.idiv rbx
    x86.mov rdi, [rbp-16]
    x86.add rdi, rax
    x86.mov [rbp-8], rdi
    x86.xor r8, r8
    x86.cmp rdi, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rdi, rax
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r9, rax
    x86.test r9, r9
    x86.je register-allocator.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_12]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

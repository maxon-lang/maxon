// Test: int-division-preserves-other-values
function main() returns ExitCode
	var x = 10
	var a = 84
	var b = 2
	var quotient = a / b
	return quotient - x
end 'main'
---
ExitCode: 32
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 84
    x86.mov rdx, 2
    x86.mov rbx, rdx
    x86.mov rax, rcx
    x86.cqo
    x86.idiv rbx
    x86.mov rbx, 10
    x86.sub rax, rbx
    x86.xor rsi, rsi
    x86.cmp rax, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or rdi, r9
    x86.test rdi, rdi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

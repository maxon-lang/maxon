// Test: int-call-result-used-later

typealias Integer = int(i64.min to i64.max)

function compute() returns Integer
  return 100
end 'compute'

function main() returns ExitCode
  var a = compute()
  var b = compute()
  return (a + b) mod 256
end 'main'

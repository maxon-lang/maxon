// Test: int-division-high-pressure
function main() returns ExitCode
	var a = 10
	var b = 20
	var c = 30
	var d = 40
	var e = 50
	var f = 60
	var g = 70
	var h = 2
	return (a + b + c + d + e + f + g) / h
end 'main'
---
ExitCode: 140
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.mov rdx, 30
    x86.mov rbx, 40
    x86.mov rsi, 50
    x86.mov rdi, 60
    x86.mov r8, 70
    x86.mov r9, 2
    x86.add rax, rcx
    x86.add rax, rdx
    x86.add rax, rbx
    x86.add rax, rsi
    x86.add rax, rdi
    x86.add rax, r8
    x86.mov [rbp-8], rax
    x86.cqo
    x86.idiv r9
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: range-check-panic.nested-call
typealias Score = int(0 to 100)

function validate(s Score) returns Score
  return s
end 'validate'

function process(x Score) returns Score
  return validate(x)
end 'process'

function main() returns ExitCode
  let result = process(200)
  return result
end 'main'

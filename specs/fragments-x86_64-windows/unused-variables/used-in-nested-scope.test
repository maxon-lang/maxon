// Test: used-in-nested-scope

function main() returns ExitCode
  var x = 42
  if x > 0 'check'
    return x
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @unused-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jle unused-variables.main.check_0.after
  check_0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je unused-variables.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

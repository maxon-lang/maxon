    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, 30
    x86.mov [rax+8], rcx
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-24], rcx
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rdx, [rax+0]
    x86.mov [rbp-32], rdx
    x86.mov rax, [rbp-32]
    x86.mov rdx, [rax+8]
    x86.add rcx, rdx
    x86.mov rax, [rbp-16]
    x86.mov rdx, [rax+8]
    x86.add rcx, rdx
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx

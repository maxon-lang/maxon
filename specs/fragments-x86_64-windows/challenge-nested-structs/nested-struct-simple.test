    x86.mov rdx, 30
    x86.call Outer.create
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rcx+0]
    x86.mov [rbp-24], rdx
    x86.mov rbx, [rbp-24]
    x86.mov rsi, [rbx+0]

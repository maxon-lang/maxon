// Test: slab-class-routing-8-byte-user-data
typealias Integer = int(i64.min to i64.max)

type Tiny
	export var x Integer
end 'Tiny'

function main() returns ExitCode
	@heap var t = Tiny{x: 7}
	return t.x
end 'main'

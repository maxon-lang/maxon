// Test: slab-span-threshold-return
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function alloc_large() returns IntArray
  var arr = IntArray{}
  arr.reserve(4000)
  return arr
end 'alloc_large'

function main() returns ExitCode
  var a = alloc_large()
  var b = alloc_large()
  return a.count() + b.count()
end 'main'

// Test: empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.empty()
	if arr.count() != 0 'check'
		return 1
	end 'check'
	if arr.isEmpty() == false 'empty'
		return 2
	end 'empty'
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call IntArray.empty
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call IntArray.count
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.je main.check_0.after
  check_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call IntArray.isEmpty
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.empty_1.after
  empty_1:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  empty_1.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory_Int(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Int.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.call mm_raw_free
    x86.jmp __destruct___ManagedMemory_Int.skip_buf_0
  skip_buf_0:
    x86.jmp __destruct___ManagedMemory_Int.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.jmp __destruct_IntArray.done

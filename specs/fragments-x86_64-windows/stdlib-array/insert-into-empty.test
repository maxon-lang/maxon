    x86.xor rdx, rdx
    x86.call IntArray.get
    x86.mov rcx, -1
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.jmp main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 42
    x86.cmp rax, rcx
    x86.je main.c0_5.after
  c0_5:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 2
    x86.epilogue
    x86.ret

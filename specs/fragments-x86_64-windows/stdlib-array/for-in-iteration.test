// Test: for-in-iteration
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.empty()
	arr.push(10)
	arr.push(20)
	arr.push(30)

	var sum = 0
	for item in arr 'loop'
		sum = sum + item
	end 'loop'

	if sum != 60 'check'
		return 1
	end 'check'

	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call IntArray.empty
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.call IntArray.push
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 20
    x86.call IntArray.push
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 30
    x86.call IntArray.push
    x86.xor rbx, rbx
    x86.mov [rbp-16], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call IntArray.__createIter
    x86.mov [rbp-24], rax
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call __IntArray_Iter.next
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.jne main.loop_0.exit
  loop_0:
    x86.mov rax, [rbp-32]
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov rax, 60
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.je main.check_3.after
  check_3:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_3.after:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory_Int(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Int.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]

    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbp-16]
    x86.mov [rsi+8], rbx
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rdi, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }

// Test: qualified-field-assign
typealias Integer = int(i64.min to i64.max)

type Right
	export var left Integer
end 'Right'

type Pair
	export var left Integer
	export var right Right
end 'Pair'

function main() returns ExitCode
	var p = Pair{left: 5, right: Right{left: 10}}
	p.right = Right{left: 20}
	if p.right.left == 20 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rbx, 10
    x86.mov [rdx+0], rbx
    x86.lea_func rsi, [__destruct_Pair]
    x86.mov rdi, rsi
    x86.mov rdx, rdi
    x86.mov rcx, 16
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov r8, [rbp-16]
    x86.mov r9, 5
    x86.mov [r8+0], r9
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+8], rax
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, 20
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-24], rax
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 20
    x86.mov [rcx+0], rdx
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rcx+8]
    x86.mov [rbp-40], rdx
    x86.test rdx, rdx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-40]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-24]
    x86.mov [rax+8], rcx
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-32], rcx
    x86.mov rax, [rbp-32]
    x86.mov rcx, [rax+0]
    x86.mov rax, 20
    x86.cmp rcx, rax
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rcx, [rbp-24]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_3
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.mov rcx, [rbp-24]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_4
    x86.call mm_decref
    x86.label __nonnull_skip_4
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
  func @__destruct_Right(ptr: i64) {
  entry:
    x86.jmp __destruct_Right.done
  done:
    x86.ret
  }
  func @__destruct_Pair(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_5
    x86.call mm_decref
    x86.label __nonnull_skip_5
    x86.jmp __destruct_Pair.done

// Test: scalar-field-assign-ok
type Counter
	var count Count

	export function increment()
		count = count + 1
	end 'increment'

	export function value() returns Count
		return count
	end 'value'

	static function create(count Count) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(count: 0)
	c.increment()
	c.increment()
	return c.value()
end 'main'
---
ExitCode: 2
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.add rdx, rax
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rdx
    x86.epilogue
    x86.ret
  }
  func @Counter.value(__self_ptr: i64) -> u64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Counter.create(count: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call Counter.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Counter.increment
    x86.mov rcx, [rbp-8]
    x86.call Counter.increment
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Counter.value
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Counter(ptr: i64) {
  entry:
    x86.jmp __destruct_Counter.done
  done:

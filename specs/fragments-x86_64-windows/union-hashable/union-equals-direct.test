// Test: union-equals-direct
union Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	var a = Color.green
	var b = Color.green
	var c = Color.red
	if a.equals(b) 'eq'
		if a.equals(c) 'neq'
			return 0
		end 'neq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @Color.equals(self: i64, other: i64) -> i1 {
  entry:
    x86.jmp stdlib.int.equals
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov [rbp-16], rcx
    x86.xor rdx, rdx
    x86.mov [rbp-24], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Color.equals
    x86.test rax, rax
    x86.je main.eq_0.after
  eq_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call Color.equals
    x86.test rax, rax
    x86.je main.neq_1.after
  neq_1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

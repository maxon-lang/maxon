// Test: byte-vector

typealias Integer = int(i64.min to i64.max)

typealias Byte = byte(0 to u8.max)
typealias ByteVec4 = Vector with 4 Byte

function main() returns ExitCode
	var v = ByteVec4.create()
	v.set(0, value: 10)
	v.set(1, value: 20)
	v.set(2, value: 30)
	v.set(3, value: 40)
	var a = try v.get(0) otherwise 0
	var b = try v.get(3) otherwise 0
	return (a as Integer) + (b as Integer)
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.call ByteVec4.create
    x86.mov [rbp-8], rax
    x86.mov rax, 10
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov r8, rax
    x86.xor rdx, rdx
    x86.call ByteVec4.set
    x86.mov rbx, 20
    x86.mov rsi, 255
    x86.and rbx, rsi
    x86.mov rdi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov r8, rbx
    x86.mov rdx, 1
    x86.call ByteVec4.set
    x86.mov r8, 30
    x86.mov r9, 255
    x86.and r8, r9
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 2
    x86.call ByteVec4.set
    x86.mov rax, 40
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rcx, [rbp-8]
    x86.mov r8, rax
    x86.mov rdx, 3
    x86.call ByteVec4.set
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.call ByteVec4.get
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 3
    x86.call ByteVec4.get
    x86.xor rcx, rcx
    x86.mov [rbp-40], rcx
    x86.mov [rbp-48], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_7
  otherwise_default_error_6:
    x86.mov rax, [rbp-40]
    x86.mov [rbp-48], rax
    x86.jmp main.otherwise_default_continue_7
  otherwise_default_continue_7:
    x86.mov rax, [rbp-48]
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_8
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_8
    x86.jmp main.__range_ok_8
  __range_panic_8:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_8:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-56], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-56]
    x86.epilogue
    x86.ret
  }
  func @__destruct_ByteMemory(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct_ByteMemory.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.call mm_raw_free
    x86.jmp __destruct_ByteMemory.skip_buf_0
  skip_buf_0:

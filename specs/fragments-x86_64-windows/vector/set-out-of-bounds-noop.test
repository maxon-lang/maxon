    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.call Vec2.get
    x86.xor rbx, rbx
    x86.mov [rbp-16], rbx
    x86.mov [rbp-24], rax
    x86.xor rsi, rsi
    x86.cmp rdx, rsi
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:

    x86.xor rdx, rdx
    x86.call Vec2.set
    x86.mov rcx, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov rdx, 1
    x86.call Vec2.set
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret

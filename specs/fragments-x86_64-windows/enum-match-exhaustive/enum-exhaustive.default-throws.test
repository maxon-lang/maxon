// Test: enum-exhaustive.default-throws
enum Color
    red
    green
    blue
end 'Color'

enum AppError
    unmatched
end 'AppError'

typealias ColorCode = int(0 to 10)

function checkColor(c Color) returns ColorCode throws AppError
  match c 'check'
    red then return ColorCode{1}
    default throws AppError.unmatched
  end 'check'
end 'checkColor'

function main() returns ExitCode
  let result = try checkColor(Color.red) otherwise 99
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @enum-match-exhaustive.checkColor(c: i64) -> u8 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.jmp enum-match-exhaustive.checkColor.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne enum-match-exhaustive.checkColor.check_0.case1
  check_0.case0:
    x86.mov rax, 1
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call enum-match-exhaustive.checkColor
    x86.mov rcx, 99
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}

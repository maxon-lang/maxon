// Test: enum-exhaustive.default-throws
enum Color
		red
		green
		blue
end 'Color'

enum AppError
		unmatched
end 'AppError'

typealias ColorCode = int(0 to 10)

function checkColor(c Color) returns ColorCode throws AppError
	match c 'check'
		red then return ColorCode{1}
		default throws AppError.unmatched
	end 'check'
end 'checkColor'

function main() returns ExitCode
	let result = try checkColor(Color.red) otherwise 'err'
		return 99
	end 'err'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @enum-match-exhaustive.checkColor(c: i64) -> u8 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.jmp enum-match-exhaustive.checkColor.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne enum-match-exhaustive.checkColor.check_0.case1
  check_0.case0:
    x86.mov rax, 1
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call enum-match-exhaustive.checkColor
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 99
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_4
    x86.cmp rax, rcx
    x86.jl main.__range_panic_4
    x86.jmp main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}

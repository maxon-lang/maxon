// Test: enum-exhaustive.mix-explicit-and-range
enum Priority
    low
    medium
    high
    critical
end 'Priority'

function main() returns ExitCode
  var p = Priority.low
  match p 'check'
    low then return 1
    medium to critical then return 2
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 3
    x86.cmp rbx, rsi
    x86.setle rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.check_0.merge
  check_0.case1:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

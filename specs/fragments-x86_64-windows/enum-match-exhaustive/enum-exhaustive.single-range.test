// Test: enum-exhaustive.single-range
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  match c 'check'
    red to blue then return 1
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @enum-match-exhaustive.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.jmp enum-match-exhaustive.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 2
    x86.cmp rbx, rsi
    x86.setle rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je enum-match-exhaustive.main.check_0.merge
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

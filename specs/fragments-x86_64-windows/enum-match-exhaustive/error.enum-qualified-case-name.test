// Test: error.enum-qualified-case-name
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  match c 'check'
    Color.red then return 1
    Color.green then return 2
    Color.blue then return 3
  end 'check'
end 'main'
---

// Test: struct-param

typealias Integer = int(i64.min to i64.max)

type Vec2
  export var x Integer
  export var y Integer
end 'Vec2'

function dot(a Vec2, b Vec2) returns Integer
  return a.x * b.x + a.y * b.y
end 'dot'

function main() returns ExitCode
  var v1 = Vec2 { x: 3, y: 4 }
  var v2 = Vec2 { x: 2, y: 1 }
  return dot(v1, b: v2)
end 'main'
---
ExitCode: 10
---

    x86.lea rsi, [rbp-16]
    x86.mov rdi, rsi
    x86.lea r8, [rbp-32]
    x86.mov r9, r8
    x86.mov rcx, rdi
    x86.mov rdx, r9
    x86.call structs.dot
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx

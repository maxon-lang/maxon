    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.mov rdx, 7
    x86.call structs.makePair
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rdx+8]
    x86.add rcx, rbx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rcx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rcx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue

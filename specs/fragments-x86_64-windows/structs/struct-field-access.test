// Test: struct-field-access

typealias Integer = int(i64.min to i64.max)

type Rect
	export var width Integer
	export var height Integer

	static function create(width Integer, height Integer) returns Self
		return Self{width: width, height: height}
	end 'create'
end 'Rect'

function main() returns ExitCode
	var r = Rect.create(5, height: 10)
	return r.width * r.height
end 'main'
---
ExitCode: 50
---
module {
  func @Rect.create(width: i64, height: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rdx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rbp-24]
    x86.mov [rdx+8], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.mov rdx, 10
    x86.call Rect.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rdx+8]
    x86.imul rcx, rbx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rcx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rcx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Rect(ptr: i64) {
  entry:
    x86.jmp __destruct_Rect.done
  done:
    x86.ret
  }
}
---

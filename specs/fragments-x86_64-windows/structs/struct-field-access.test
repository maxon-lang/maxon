// Test: struct-field-access

typealias Integer = int(i64.min to i64.max)

type Rect
  export var width Integer
  export var height Integer
end 'Rect'

function main() returns ExitCode
  var r = Rect { width: 5, height: 10 }
  return r.width * r.height
end 'main'
---
ExitCode: 50
---
module {
  func @structs.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rbx, 5
    x86.mov [rdx+0], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rdi, 10
    x86.mov [rsi+8], rdi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-8]
    x86.mov rax, [r9+0]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rcx+8]
    x86.imul rax, rdx
    x86.mov [rbp-16], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax
    x86.test rcx, rcx
    x86.je structs.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_27]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Rect(ptr: i64) {
  entry:
    x86.jmp __destruct_Rect.done
  done:
    x86.ret
  }
}
---

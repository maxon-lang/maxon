// Test: struct-field-access

typealias Integer = int(i64.min to i64.max)

type Rect
	export var width Integer
	export var height Integer
end 'Rect'

function main() returns ExitCode
	var r = Rect { width: 5, height: 10 }
	return r.width * r.height
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, [rbp-16]
    x86.mov rbx, [rbp-8]
    x86.imul rdx, rbx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

// Test: struct-field-inferred-type
type Settings
	export let maxRetries = 5
	export var timeout = 50.0
end 'Settings'

function main() returns ExitCode
	var s = Settings{}
	return s.maxRetries + trunc(s.timeout)
end 'main'

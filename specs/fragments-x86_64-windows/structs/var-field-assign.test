// Test: var-field-assign

typealias Integer = int(i64.min to i64.max)

type Config
	export let version Integer
	export var count Integer

	static function create(version Integer, count Integer) returns Self
		return Self{version: version, count: count}
	end 'create'
end 'Config'

function main() returns ExitCode
	var c = Config.create(version: 1, count: 0)
	c.count = 5
	return c.count
end 'main'
---
ExitCode: 5
---
module {
  func @Config.create(version: i64, count: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rdx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rbp-24]
    x86.mov [rdx+8], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.xor rdx, rdx
    x86.call Config.create
    x86.mov [rbp-8], rax
    x86.mov rax, 5
    x86.mov rcx, [rbp-8]
    x86.mov [rcx+8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rdx+8]
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rbx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rbx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rbx
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Config(ptr: i64) {
  entry:
    x86.jmp __destruct_Config.done
  done:
    x86.ret
  }
}

// Test: stack-when-passed-to-readonly-function
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer
end 'Point'

function readX(p Point) returns Integer
	return p.x
end 'readX'

function main() returns ExitCode
	var p = Point{x: 42, y: 0}
	return readX(p)
end 'main'
---
MmTrace: true
ExitCode: 42
Stderr: ```
sl_init
  os_alloc size=67108864
mm_raw_alloc #R1 size=40
  sl_alloc size=40 class=4
mm_raw_free #R1
  sl_free size=48 class=4
```
---
module {
  func @stack-promotion.readX(p: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.xor rcx, rcx
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call stack-promotion.readX
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.jg main.__range_panic_0
    x86.cmp rax, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

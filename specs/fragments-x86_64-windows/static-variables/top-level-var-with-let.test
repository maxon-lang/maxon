// Test: top-level-var-with-let
let BASE = 40
var offset = 0

function main() returns ExitCode
	offset = 2
	return BASE + offset
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov qword [rip+offset], rax
    x86.mov rcx, 40
    x86.mov rdx, qword [rip+offset]
    x86.add rcx, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rcx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: static-var-bool
var initialized = false

function init()
  initialized = true
end 'init'

function main() returns ExitCode
  if initialized 'check1'
    return 1
  end 'check1'
  init()
  if initialized 'check2'
    return 42
  end 'check2'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.init() {
  entry:
    x86.mov rax, 1
    x86.mov byte [rip+initialized], rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movzx rax, byte [rip+initialized]
    x86.test rax, rax
    x86.je main.check1_0.after
  check1_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check1_0.after:
    x86.call static-variables.init
    x86.movzx rax, byte [rip+initialized]
    x86.test rax, rax
    x86.je main.check2_1.after
  check2_1:
    x86.mov rax, 42
    x86.epilogue
    x86.ret
  check2_1.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

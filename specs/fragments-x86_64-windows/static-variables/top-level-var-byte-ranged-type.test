// Test: top-level-var-byte-ranged-type
typealias SmallInt = int(0 to u8.max)

var counter = SmallInt{42}

function main() returns ExitCode
    return counter
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movzx rax, byte [rip+counter]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

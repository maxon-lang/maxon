// Test: top-level-var-enum-initializer
enum Color
		Red
		Green
		Blue
end 'Color'

var current = Color.Green

function main() returns ExitCode
	var isGreen = match current 'check'
		Green gives true
		Red gives false
		Blue gives false
	end 'check'
	if isGreen 'check'
		current = Color.Blue
		var isBlue = match current 'check2'
			Blue gives true
			Red gives false
			Green gives false
		end 'check2'
		if isBlue 'check2'
			return 42
		end 'check2'
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, qword [rip+current]
    x86.xor rcx, rcx
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp2
  check_0.case1:
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.cmp2:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.check_0.merge
  check_0.case2:
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.je main.check_1.merge
  check_1:
    x86.mov rax, 2
    x86.mov qword [rip+current], rax
    x86.mov rcx, qword [rip+current]
    x86.xor rdx, rdx
    x86.mov [rbp-24], rdx
    x86.mov [rbp-32], rcx
    x86.jmp main.check2_2.cmp0
  check2_2.cmp0:
    x86.mov rax, [rbp-32]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.check2_2.cmp1
  check2_2.case0:
    x86.mov rax, 1
    x86.mov [rbp-24], rax
    x86.jmp main.check2_2.merge
  check2_2.cmp1:
    x86.mov rax, [rbp-32]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check2_2.cmp2
  check2_2.case1:
    x86.xor rax, rax
    x86.mov [rbp-24], rax
    x86.jmp main.check2_2.merge
  check2_2.cmp2:
    x86.mov rax, [rbp-32]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check2_2.merge
  check2_2.case2:
    x86.xor rax, rax
    x86.mov [rbp-24], rax
    x86.jmp main.check2_2.merge
  check2_2.merge:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.je main.check2_3.after
  check2_3:
    x86.mov rax, 42
    x86.epilogue
    x86.ret
  check2_3.after:
    x86.jmp main.check_1.merge
  check_1.merge:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

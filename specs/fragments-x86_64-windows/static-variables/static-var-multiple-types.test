// Test: static-var-multiple-types
type TypeA
	static var value = 10
end 'TypeA'

type TypeB
	static var value = 20
end 'TypeB'

function main() returns ExitCode
	TypeA.value = TypeA.value + 2
	TypeB.value = TypeB.value + 10
	return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, qword [rip+TypeA.value]
    x86.mov rcx, 2
    x86.add rax, rcx
    x86.mov qword [rip+TypeA.value], rax
    x86.mov rdx, qword [rip+TypeB.value]
    x86.mov rbx, 10
    x86.add rdx, rbx
    x86.mov qword [rip+TypeB.value], rdx
    x86.mov rsi, qword [rip+TypeA.value]
    x86.mov rdi, qword [rip+TypeB.value]
    x86.add rsi, rdi
    x86.xor r8, r8
    x86.mov r9, 4294967295
    x86.cmp rsi, r9
    x86.jg main.__range_panic_0
    x86.cmp rsi, r8
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rsi
    x86.epilogue
    x86.ret
  }
}
---

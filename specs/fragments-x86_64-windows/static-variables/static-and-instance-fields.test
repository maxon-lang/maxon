// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
  static var created = 0
  export var id Integer

  static function make(n Integer) returns Thing
    Thing.created = Thing.created + 1
    return Thing{id: n}
  end 'make'
end 'Thing'

function main() returns ExitCode
  var a = Thing.make(10)
  var b = Thing.make(20)
  return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
module {
  func @Thing.make(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, qword [rip+Thing.created]
    x86.mov rdx, 1
    x86.add rax, rdx
    x86.mov qword [rip+Thing.created], rax
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Thing.make
    x86.mov [rbp-8], rax
    x86.mov rcx, 20
    x86.call Thing.make
    x86.mov [rbp-16], rax
    x86.mov rax, qword [rip+Thing.created]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rcx+0]
    x86.add rax, rdx
    x86.mov rbx, [rbp-16]
    x86.mov rsi, [rbx+0]
    x86.add rax, rsi
    x86.xor rdi, rdi
    x86.cmp rax, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or r8, rcx
    x86.test r8, r8
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rcx, [rbp-16]
    x86.mov [rbp-24], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Thing(ptr: i64) {
  entry:
    x86.jmp __destruct_Thing.done
  done:
    x86.ret
  }
}
---

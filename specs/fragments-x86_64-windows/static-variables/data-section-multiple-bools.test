// Test: data-section-multiple-bools
var a = true
var b = false
var c = true

function main() returns ExitCode
  if a and c and (b == false) 'read'
    return 0
  end 'read'
  return 1
end 'main'
---
ExitCode: 0
RequiredData: ```
i8 1
i8 0
i8 1
```
---
module {
  func @main() -> u32 {
  entry:
    x86.movzx rax, byte [rip+a]
    x86.movzx rcx, byte [rip+c]
    x86.and rax, rcx
    x86.movzx rdx, byte [rip+b]
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.sete rsi
    x86.movzx rsi, rsib
    x86.and rax, rsi
    x86.test rax, rax
    x86.je main.read_0.after
  read_0:
    x86.xor rax, rax
    x86.ret
  read_0.after:
    x86.mov rax, 1
    x86.ret
  }
}

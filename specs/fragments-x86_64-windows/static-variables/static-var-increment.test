// Test: static-var-increment
type Counter
  static var count = 0

  static function increment()
    Counter.count = Counter.count + 1
  end 'increment'
end 'Counter'

function main() returns ExitCode
  Counter.increment()
  Counter.increment()
  Counter.increment()
  return Counter.count
end 'main'
---
ExitCode: 3
---
module {
  func @Counter.increment() {
  entry:
    x86.mov rax, qword [rip+Counter.count]
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov qword [rip+Counter.count], rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call Counter.increment
    x86.call Counter.increment
    x86.call Counter.increment
    x86.mov rax, qword [rip+Counter.count]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

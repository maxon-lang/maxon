// Test: top-level-var-increment

typealias Integer = int(i64.min to i64.max)

var total = 10

function add(n Integer)
	total = total + n
end 'add'

function main() returns ExitCode
	add(5)
	add(27)
	return total
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.add(n: i64) {
  entry:
    x86.mov rax, qword [rip+total]
    x86.add rax, rcx
    x86.mov qword [rip+total], rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call static-variables.add
    x86.mov rcx, 27
    x86.call static-variables.add
    x86.mov rax, qword [rip+total]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

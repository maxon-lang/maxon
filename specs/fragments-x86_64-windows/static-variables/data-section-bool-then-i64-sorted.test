// Test: data-section-bool-then-i64-sorted
var flag = false
var counter = 42

function main() returns ExitCode
  if flag 'read'
    return 1
  end 'read'
  return counter - 42
end 'main'
---
ExitCode: 0
RequiredData: ```
i64 42
i8 0
```
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movzx rax, byte [rip+flag]
    x86.test rax, rax
    x86.je static-variables.main.read_0.after
  read_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  read_0.after:
    x86.mov rax, qword [rip+counter]
    x86.mov rcx, 42
    x86.sub rax, rcx
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je static-variables.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

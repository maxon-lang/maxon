// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov [rbp-16], rcx
  loop_1.header:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, 5
    x86.jg loop_1.exit
  loop_1:
    x86.mov rax, [rbp+-16]
    x86.mov rcx, rax
    x86.add rcx, 1
    x86.mov rdx, [rbp+-8]
    x86.mov rbx, rdx
    x86.add rbx, rax
    x86.mov [rbp-8], rbx
    x86.mov [rbp-16], rcx
    x86.jmp loop_1.header
  loop_1.exit:
    x86.mov rax, [rbp+-8]
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rbx
    x86.or rcx, rbx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

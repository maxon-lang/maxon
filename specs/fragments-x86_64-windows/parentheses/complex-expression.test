// Test: complex-expression
function main() returns ExitCode
	var result = trunc((10 + (2 * 3)) / (4 - 2))
	return result
end 'main'
---
ExitCode: 8
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 2
    x86.mov rdx, 3
    x86.imul rcx, rdx
    x86.add rax, rcx
    x86.mov rbx, 4
    x86.mov rsi, 2
    x86.sub rbx, rsi
    x86.mov [rbp-8], rax
    x86.cqo
    x86.idiv rbx
    x86.xor rdi, rdi
    x86.cmp rax, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or r8, rcx
    x86.test r8, r8
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

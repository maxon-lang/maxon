// Test: complex-expression
function main() returns ExitCode
	var result = trunc((10 + (2 * 3)) / (4 - 2))
	return result
end 'main'
---
ExitCode: 8
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 2
    x86.mov rdx, 3
    x86.imul rcx, rdx
    x86.add rax, rcx
    x86.mov rbx, 4
    x86.mov rsi, 2
    x86.sub rbx, rsi
    x86.mov [rbp-8], rax
    x86.cqo
    x86.idiv rbx
    x86.xor rdi, rdi
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.jg main.__range_panic_0
    x86.cmp rax, rdi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: docs-example-1
function main() returns ExitCode
	var a = 2 + 3 * 4      // 14 (multiply first)
	var b = (2 + 3) * 4    // 20 (add first)
	return a+b
end 'main'

---
ExitCode: 34
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov rcx, 3
    x86.mov rdx, 4
    x86.imul rcx, rdx
    x86.add rax, rcx
    x86.mov rbx, 2
    x86.mov rsi, 3
    x86.add rbx, rsi
    x86.mov rdi, 4
    x86.imul rbx, rdi
    x86.add rax, rbx
    x86.xor r8, r8
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.jg main.__range_panic_0
    x86.cmp rax, r8
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

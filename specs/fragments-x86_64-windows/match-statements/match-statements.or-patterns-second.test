// Test: match-statements.or-patterns-second
function main() returns ExitCode
  var x = 2
  match x 'check'
    1 or 2 then return 10
    3 or 4 then return 20
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 10
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 2
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.test rdx, rdx
    x86.je match-statements.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 10
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 4
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.test rdx, rdx
    x86.je match-statements.main.check_0.case2
  check_0.case1:
    x86.mov rax, 20
    x86.epilogue
    x86.ret
  check_0.case2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

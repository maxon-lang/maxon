// Test: match-statements.nested-in-function

typealias Integer = int(i64.min to i64.max)

function categorize(n Integer) returns Integer
  match n 'cat'
    1 or 2 or 3 then return 1
    4 or 5 or 6 then return 2
    default then return 0
  end 'cat'
end 'categorize'

function main() returns ExitCode
  return categorize(5)
end 'main'
---
ExitCode: 2
---
module {
  func @match-statements.categorize(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.jmp match-statements.categorize.cat_0.cmp0
  cat_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 2
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.mov r8, [rbp-8]
    x86.mov r9, 3
    x86.cmp r8, r9
    x86.sete rax
    x86.movzx rax, raxb
    x86.or rdx, rax
    x86.test rdx, rdx
    x86.je match-statements.categorize.cat_0.cmp1
  cat_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  cat_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 4
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 5
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.mov r8, [rbp-8]
    x86.mov r9, 6
    x86.cmp r8, r9
    x86.sete rax
    x86.movzx rax, raxb
    x86.or rdx, rax
    x86.test rdx, rdx
    x86.je match-statements.categorize.cat_0.case2
  cat_0.case1:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  cat_0.case2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  cat_0.merge:
  }
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call match-statements.categorize
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je match-statements.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

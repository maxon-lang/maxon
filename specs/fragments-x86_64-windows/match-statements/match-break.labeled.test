// Test: match-break.labeled
function main() returns ExitCode
  var result = 0
  match 3 'outer'
    1 then result = 10
    2 then result = 20
    3 then break 'outer'
    default then result = 99
  end 'outer'
  return result
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.mov [rbp-16], rcx
    x86.jmp main.outer_0.cmp0
  outer_0.cmp0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.outer_0.cmp1
  outer_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.merge
  outer_0.cmp1:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.outer_0.cmp2
  outer_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.merge
  outer_0.cmp2:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jne main.outer_0.case3
  outer_0.case2:
    x86.jmp main.outer_0.merge
  outer_0.case3:
    x86.mov rax, 99
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.merge
  outer_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

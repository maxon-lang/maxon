// Test: match-range.multiple-ranges
function main() returns ExitCode
	var score = 85
	match score 'grade'
		90 to 100 then return 65
		80 upto 90 then return 66
		70 upto 80 then return 67
		default then return 70
	end 'grade'
end 'main'
---
ExitCode: 66
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 85
    x86.mov [rbp-8], rax
    x86.jmp main.grade_0.cmp0
  grade_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 90
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 100
    x86.cmp rbx, rsi
    x86.setle rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.grade_0.cmp1
  grade_0.case0:
    x86.mov rax, 65
    x86.epilogue
    x86.ret
  grade_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 80
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 90
    x86.cmp rbx, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.grade_0.cmp2
  grade_0.case1:
    x86.mov rax, 66
    x86.epilogue
    x86.ret
  grade_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 70
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 80
    x86.cmp rbx, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.grade_0.case3
  grade_0.case2:
    x86.mov rax, 67
    x86.epilogue
    x86.ret
  grade_0.case3:
    x86.mov rax, 70
    x86.epilogue
    x86.ret
  grade_0.merge:
  }
}
---

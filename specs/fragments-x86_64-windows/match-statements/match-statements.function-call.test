// Test: match-statements.function-call

typealias Integer = int(i64.min to i64.max)

function double(n Integer) returns Integer
	return n * 2
end 'double'

function main() returns ExitCode
	var x = 2
	var result = 0
	match x 'process'
		1 then result = double(10)
		2 then result = double(20)
		default then result = 0
	end 'process'
	return result
end 'main'
---
ExitCode: 40
---
module {
  func @match-statements.double(n: i64) -> i64 {
  entry:
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.process_0.cmp0
  process_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.process_0.cmp1
  process_0.case0:
    x86.mov rcx, 10
    x86.call match-statements.double
    x86.mov [rbp-16], rax
    x86.jmp main.process_0.merge
  process_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.process_0.case2
  process_0.case1:
    x86.mov rcx, 20
    x86.call match-statements.double
    x86.mov [rbp-16], rax
    x86.jmp main.process_0.merge
  process_0.case2:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.process_0.merge
  process_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

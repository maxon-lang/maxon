  check_0.case1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.jmp match-statements.process.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-24]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }

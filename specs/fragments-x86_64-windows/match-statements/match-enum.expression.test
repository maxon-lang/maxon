// Test: match-enum.expression
enum Status
	pending
	approved
	rejected
end 'Status'

function main() returns ExitCode
	var s = Status.approved
	let code = match s 'eval'
		pending gives 0
		approved gives 1
		rejected gives 2
	end 'eval'
	return code
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rcx
    x86.jmp main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.eval_0.cmp1
  eval_0.case0:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.eval_0.merge
  eval_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.eval_0.cmp2
  eval_0.case1:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp main.eval_0.merge
  eval_0.cmp2:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.eval_0.merge
  eval_0.case2:
    x86.mov rax, 2
    x86.mov [rbp-16], rax
    x86.jmp main.eval_0.merge
  eval_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

// Test: match-range.open-lower-inclusive
function main() returns ExitCode
	var x = 5
	match x 'check'
		min to 5 then return 1
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 5
    x86.cmp rax, rcx
    x86.jg main.check_0.case1
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

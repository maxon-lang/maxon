// Test: match-range.expression
function main() returns ExitCode
	var temp = 22
	let category = match temp 'weather'
		min upto 0 gives 1
		0 upto 15 gives 2
		15 upto 25 gives 3
		25 to max gives 4
		default gives 0
	end 'weather'
	return category
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 22
    x86.mov [rbp-8], rax
    x86.jmp main.weather_0.cmp0
  weather_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jge main.weather_0.cmp1
  weather_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp main.weather_0.merge
  weather_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 15
    x86.cmp rbx, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.weather_0.cmp2
  weather_0.case1:
    x86.mov rax, 2
    x86.mov [rbp-16], rax
    x86.jmp main.weather_0.merge
  weather_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 15
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 25
    x86.cmp rbx, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.weather_0.cmp3
  weather_0.case2:
    x86.mov rax, 3
    x86.mov [rbp-16], rax
    x86.jmp main.weather_0.merge
  weather_0.cmp3:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 25
    x86.cmp rax, rcx
    x86.jl main.weather_0.case4
  weather_0.case3:
    x86.mov rax, 4
    x86.mov [rbp-16], rax
    x86.jmp main.weather_0.merge
  weather_0.case4:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.weather_0.merge
  weather_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

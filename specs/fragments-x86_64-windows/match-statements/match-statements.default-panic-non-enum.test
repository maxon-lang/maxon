// Test: match-statements.default-panic-non-enum
typealias Integer = int(0 to 100)

function classify(x Integer) returns Integer
  return match x 'check'
    1 gives 10
    2 gives 20
    default panic("unexpected value")
  end 'check'
end 'classify'

function main() returns ExitCode
  let result = classify(2)
  if result == 20 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.classify(x: i64) -> u8 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov [rbp-16], rcx
    x86.jmp match-statements.classify.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne match-statements.classify.check_0.cmp1
  check_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.jmp match-statements.classify.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne match-statements.classify.check_0.case2
  check_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-8], rax
    x86.jmp match-statements.classify.check_0.merge
  check_0.case2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 100
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je match-statements.classify.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_1]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 2
    x86.call match-statements.classify
    x86.mov rcx, 20
    x86.cmp rax, rcx
    x86.jne match-statements.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

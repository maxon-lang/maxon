// Test: match-break.basic
function main() returns ExitCode
	var result = 0
	match 2 'check'
		1 then result = 10
		2 then break
		default then result = 99
	end 'check'
	return result
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 2
    x86.mov [rbp-16], rcx
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.check_0.case2
  check_0.case1:
    x86.jmp main.check_0.merge
  check_0.case2:
    x86.mov rax, 99
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

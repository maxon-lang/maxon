// Test: docs-example-1
function main() returns ExitCode
  var x = 42
  var y = -x      // y is -42
  var z = -y      // z is 42
  return z
end 'main'

---
ExitCode: 42
---
module {
  func @unary-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.xor rcx, rcx
    x86.sub rcx, rax
    x86.xor rdx, rdx
    x86.sub rdx, rcx
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je unary-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  __lazy_init_2:
    x86.call Config.value.__lazy_init
    x86.jmp Config.getValue.__lazy_merge_2
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call Config.getValue
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @Config.value.__lazy_init() {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov byte [rip+Config.value.__initialized], rax
    x86.call Config.makeValue
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, qword [rip+Config.value]

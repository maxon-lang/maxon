// Test: transitive-interface-complete

typealias Integer = int(i64.min to i64.max)

interface BaseInterface
	function baseMethod() returns Integer
end 'BaseInterface'

interface DerivedInterface extends BaseInterface
	function derivedMethod() returns Integer
end 'DerivedInterface'

// CompleteType implements all methods from both interfaces
type CompleteType implements DerivedInterface
	var value Integer

	function baseMethod() returns Integer
		return value
	end 'baseMethod'

	function derivedMethod() returns Integer
		return value * 2
	end 'derivedMethod'
end 'CompleteType'

function main() returns ExitCode
	var t = CompleteType{value: 21}
	return t.baseMethod() + t.derivedMethod()
end 'main'
---
ExitCode: 63
---
module {
  func @CompleteType.baseMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @CompleteType.derivedMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 2
    x86.imul rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 21
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call CompleteType.baseMethod
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov [rbp-16], rax
    x86.mov rcx, rsi
    x86.call CompleteType.derivedMethod
    x86.mov rdi, [rbp-16]
    x86.add rdi, rax
    x86.xor r8, r8
    x86.mov r9, 4294967295
    x86.cmp rdi, r9
    x86.jg main.__range_panic_0
    x86.cmp rdi, r8
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdi
    x86.epilogue
    x86.ret
  }
}
---

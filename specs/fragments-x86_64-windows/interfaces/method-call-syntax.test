// Test: method-call-syntax

typealias Integer = int(i64.min to i64.max)

interface Incrementable
	function inc() returns Integer
end 'Incrementable'

type Value implements Incrementable
	var n Integer

	function inc() returns Integer
		return n + 1
	end 'inc'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	var v = Value.create(n: 41)
	return v.inc()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.inc(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.lea rax, [rdx + rax]
    x86.epilogue
    x86.ret
  }
  func @Value.create(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 41
    x86.call Value.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Value.inc
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Value(ptr: i64) {
  entry:
    x86.jmp __destruct_Value.done
  done:
    x86.ret
  }
}
---

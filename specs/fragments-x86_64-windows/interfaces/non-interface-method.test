// Test: non-interface-method

typealias Integer = int(i64.min to i64.max)

type Calculator
	var value Integer

	function double() returns Integer
		return value * 2
	end 'double'

	function triple() returns Integer
		return value * 3
	end 'triple'
end 'Calculator'

function main() returns ExitCode
	var c = Calculator{value: 7}
	return c.double() + c.triple()
end 'main'
---
ExitCode: 35
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 2
    x86.imul rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Calculator.triple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 3
    x86.imul rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 7
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Calculator.double
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov [rbp-16], rax
    x86.mov rcx, rsi
    x86.call Calculator.triple
    x86.mov rdi, [rbp-16]
    x86.add rdi, rax
    x86.xor r8, r8
    x86.cmp rdi, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rdi, rax
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r9, rax
    x86.test r9, r9
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdi
    x86.epilogue
    x86.ret
  }
}

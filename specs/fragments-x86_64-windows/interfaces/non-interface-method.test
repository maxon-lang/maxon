    x86.call Calculator.double
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.call Calculator.triple
    x86.mov rdx, [rbp-16]
    x86.add rdx, rax
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]

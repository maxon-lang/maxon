// Test: type-method-with-params

typealias Integer = int(i64.min to i64.max)

type Adder
	var total Integer

	function add(value Integer)
		total = total + value
	end 'add'

	function getTotal() returns Integer
		return total
	end 'getTotal'
end 'Adder'

function main() returns ExitCode
	var a = Adder{total: 0}
	a.add(10)
	a.add(32)
	return a.getTotal()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, value: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.add rbx, rdx
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rbx
    x86.epilogue
    x86.ret
  }
  func @Adder.getTotal(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.mov rdx, 10
    x86.call Adder.add
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov rcx, rsi
    x86.mov rdx, 32
    x86.call Adder.add
    x86.lea rdi, [rbp-8]
    x86.mov r8, rdi
    x86.mov rcx, r8
    x86.call Adder.getTotal
    x86.xor r9, r9
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.jg main.__range_panic_0
    x86.cmp rax, r9
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

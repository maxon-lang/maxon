// Test: type-method-with-params

typealias Integer = int(i64.min to i64.max)

type Adder
	var total Integer

	function add(value Integer)
		total = total + value
	end 'add'

	function getTotal() returns Integer
		return total
	end 'getTotal'

	static function create(total Integer) returns Self
		return Self{total: total}
	end 'create'
end 'Adder'

function main() returns ExitCode
	var a = Adder.create(total: 0)
	a.add(10)
	a.add(32)
	return a.getTotal()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, value: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.add rbx, rdx
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rbx
    x86.epilogue
    x86.ret
  }
  func @Adder.getTotal(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Adder.create(total: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call Adder.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.call Adder.add
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 32
    x86.call Adder.add
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Adder.getTotal
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Adder(ptr: i64) {
  entry:
    x86.jmp __destruct_Adder.done
  done:
    x86.ret
  }
}

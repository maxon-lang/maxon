// Test: type-method-returning-value

typealias Integer = int(i64.min to i64.max)

type Calculator
  var value Integer

  function double() returns Integer
    return value * 2
  end 'double'
end 'Calculator'

function main() returns ExitCode
  var c = Calculator{value: 21}
  return c.double()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 2
    x86.imul rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 21
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Calculator.double
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je type-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

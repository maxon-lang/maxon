// Test: type-method-chain

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer

	function add(x Integer)
		n = n + x
	end 'add'

	function get() returns Integer
		return n
	end 'get'
end 'Value'

function main() returns ExitCode
	var v = Value{n: 0}
	v.add(10)
	v.add(20)
	v.add(12)
	return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.add(__self_ptr: i64, x: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.add rbx, rdx
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rbx
    x86.epilogue
    x86.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.mov rdx, 10
    x86.call Value.add
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov rcx, rsi
    x86.mov rdx, 20
    x86.call Value.add
    x86.lea rdi, [rbp-8]
    x86.mov r8, rdi
    x86.mov rcx, r8
    x86.mov rdx, 12
    x86.call Value.add
    x86.lea r9, [rbp-8]
    x86.mov rax, r9
    x86.mov rcx, rax
    x86.call Value.get
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

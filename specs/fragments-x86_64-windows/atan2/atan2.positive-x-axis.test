// Test: atan2.positive-x-axis
function main() returns ExitCode
	var angle = Math.atan2(0.0, x: 1.0)
	if angle == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_1]
    x86.call stdlib.Math.atan2
    x86.movsd xmm2, [rip+__float_0]
    x86.ucomisd xmm0, xmm2
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
}
---

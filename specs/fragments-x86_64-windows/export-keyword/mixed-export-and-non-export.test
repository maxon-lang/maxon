// Test: mixed-export-and-non-export

typealias Integer = int(i64.min to i64.max)

export function publicFunc() returns Integer
  return privateFunc() + 20
end 'publicFunc'

function privateFunc() returns Integer
  return 22
end 'privateFunc'

function main() returns ExitCode
  return publicFunc()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.publicFunc() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.privateFunc
    x86.mov rcx, 20
    x86.add rax, rcx
    x86.epilogue
    x86.ret
  }
  func @export-keyword.privateFunc() -> i64 {
  entry:
    x86.mov rax, 22
    x86.ret
  }
  func @export-keyword.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.publicFunc
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je export-keyword.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

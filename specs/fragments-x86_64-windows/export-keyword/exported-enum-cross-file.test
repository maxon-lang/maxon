// Test: exported-enum-cross-file
// --- file: color.maxon
export union Color
  red
  green
  blue
end 'Color'

// --- file: main.maxon
function main() returns ExitCode
  var c = Color.blue
  match c 'check'
    blue then return 42
    red then return 0
    green then return 0
  end 'check'
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 42
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp2
  check_0.case1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_0.merge
  check_0.case2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}

// Test: export-typealias-basic

typealias Integer = int(i64.min to i64.max)

export typealias IntArray = Array with Integer

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(42)
  return try arr.get(0) otherwise 0
end 'main'

// Test: export-function-basic

typealias Integer = int(i64.min to i64.max)

export function helper() returns Integer
	return 21
end 'helper'

function main() returns ExitCode
	return helper() + helper()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.helper() -> i64 {
  entry:
    x86.mov rax, 21
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.helper
    x86.mov [rbp-8], rax
    x86.call export-keyword.helper
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.xor rax, rax
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rax
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

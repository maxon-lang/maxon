// Test: equals-branching

typealias Integer = int(i64.min to i64.max)

type Token implements Equatable
	export var id Integer

	function equals(other Token) returns bool
		return id == other.id
	end 'equals'

	static function create(id Integer) returns Self
		return Self{id: id}
	end 'create'
end 'Token'

function main() returns ExitCode
	var a = Token.create(id: 10)
	var b = Token.create(id: 10)
	var c = Token.create(id: 20)
	var result = 0
	if a.equals(b) 'first'
		result = result + 1
	end 'first'
	if a.equals(c) 'second'
		result = result + 10
	end 'second'
	if b.equals(c) 'third'
		result = result + 100
	end 'third'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @Token.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rsi, [rax+0]
    x86.cmp rbx, rsi
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @Token.create(id: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Token.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 10
    x86.call Token.create
    x86.mov [rbp-16], rax
    x86.mov rcx, 20
    x86.call Token.create
    x86.mov [rbp-24], rax
    x86.xor rax, rax
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Token.equals
    x86.test rax, rax
    x86.je main.first_0.merge
  first_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.mov [rbp-32], rcx
    x86.jmp main.first_0.merge
  first_0.merge:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call Token.equals
    x86.test rax, rax
    x86.je main.second_1.merge
  second_1:
    x86.mov rax, 10
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.mov [rbp-32], rcx
    x86.jmp main.second_1.merge
  second_1.merge:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.call Token.equals
    x86.test rax, rax
    x86.je main.third_2.merge
  third_2:
    x86.mov rax, 100
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.mov [rbp-32], rcx
    x86.jmp main.third_2.merge
  third_2.merge:
    x86.mov rax, [rbp-32]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_3
    x86.cmp rax, rcx
    x86.jl main.__range_panic_3
    x86.jmp main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.mov rbx, [rbp-24]
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Token(ptr: i64) {
  entry:
    x86.jmp __destruct_Token.done
  done:
    x86.ret
  }
}

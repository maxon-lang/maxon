// Test: basic-not-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
	export var x Integer
	export var y Integer

	function equals(other Point) returns bool
		return x == other.x and y == other.y
	end 'equals'

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function main() returns ExitCode
	var a = Point.create(x: 1, y: 2)
	var b = Point.create(x: 3, y: 4)
	if a.equals(b) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-8]
    x86.mov rsi, [rax+8]
    x86.mov rax, [rbp-16]
    x86.mov rdi, [rax+0]
    x86.cmp rbx, rdi
    x86.sete rax
    x86.movzx rax, raxb
    x86.mov rbx, [rbp-16]
    x86.mov rdi, [rbx+8]
    x86.cmp rsi, rdi
    x86.sete rbx
    x86.movzx rbx, rbxb
    x86.and rax, rbx
    x86.epilogue
    x86.ret
  }
  func @Point.create(x: i64, y: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rdx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rbp-24]
    x86.mov [rdx+8], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.mov rdx, 2
    x86.call Point.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.mov rdx, 4
    x86.call Point.create
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Point.equals
    x86.test rax, rax
    x86.je main.check_0.after
  check_0:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct_Point(ptr: i64) {
  entry:
    x86.jmp __destruct_Point.done
  done:
    x86.ret
  }
}

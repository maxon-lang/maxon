// Test: self-equality

typealias Integer = int(i64.min to i64.max)

type Box implements Equatable
  export var value Integer

  function equals(other Box) returns bool
    return value == other.value
  end 'equals'
end 'Box'

function main() returns ExitCode
  var a = Box{value: 7}
  if a.equals(a) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Box.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rsi, [rax+0]
    x86.cmp rbx, rsi
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 7
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov rcx, rdx
    x86.mov rdx, rsi
    x86.call Box.equals
    x86.test rax, rax
    x86.je main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
}
---

// Test: basic-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 2}
  if a.equals(b) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-8]
    x86.mov rsi, [rax+8]
    x86.mov rax, [rbp-16]
    x86.mov rdi, [rax+0]
    x86.cmp rbx, rdi
    x86.sete rax
    x86.movzx rax, raxb
    x86.mov rbx, [rbp-16]
    x86.mov rdi, [rbx+8]
    x86.cmp rsi, rdi
    x86.sete rbx
    x86.movzx rbx, rbxb
    x86.and rax, rbx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 1
    x86.mov rbx, 2
    x86.mov [rbp-32], rdx
    x86.mov [rbp-24], rbx
    x86.lea rsi, [rbp-16]
    x86.mov rdi, rsi
    x86.lea r8, [rbp-32]
    x86.mov r9, r8
    x86.mov rcx, rdi
    x86.mov rdx, r9
    x86.call Point.equals
    x86.test rax, rax
    x86.je main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
}
---

// Test: single-field

typealias Integer = int(i64.min to i64.max)

type Wrapper implements Equatable
  export var value Integer

  function equals(other Wrapper) returns bool
    return value == other.value
  end 'equals'
end 'Wrapper'

function main() returns ExitCode
  var a = Wrapper{value: 42}
  var b = Wrapper{value: 42}
  var c = Wrapper{value: 99}
  if a.equals(b) 'eq'
    if a.equals(c) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Wrapper.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rsi, [rax+0]
    x86.cmp rbx, rsi
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.mov rcx, 42
    x86.mov [rbp-16], rcx
    x86.mov rdx, 99
    x86.mov [rbp-24], rdx
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.lea rdi, [rbp-16]
    x86.mov r8, rdi
    x86.mov rcx, rsi
    x86.mov rdx, r8
    x86.call Wrapper.equals
    x86.test rax, rax
    x86.je main.eq_0.after
  eq_0:
    x86.lea rax, [rbp-8]
    x86.mov rcx, rax
    x86.lea rdx, [rbp-24]
    x86.mov rbx, rdx
    x86.mov rdx, rbx
    x86.call Wrapper.equals
    x86.test rax, rax
    x86.je main.neq_1.after
  neq_1:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
}
---

// Test: single-field

typealias Integer = int(i64.min to i64.max)

type Wrapper implements Equatable
	export var value Integer

	function equals(other Wrapper) returns bool
		return value == other.value
	end 'equals'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Wrapper'

function main() returns ExitCode
	var a = Wrapper.create(value: 42)
	var b = Wrapper.create(value: 42)
	var c = Wrapper.create(value: 99)
	if a.equals(b) 'eq'
		if a.equals(c) 'neq'
			return 1
		end 'neq'
		return 0
	end 'eq'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Wrapper.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rsi, [rax+0]
    x86.cmp rbx, rsi
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @Wrapper.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 42
    x86.call Wrapper.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 42
    x86.call Wrapper.create
    x86.mov [rbp-16], rax
    x86.mov rcx, 99
    x86.call Wrapper.create
    x86.mov [rbp-24], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Wrapper.equals
    x86.test rax, rax
    x86.je main.eq_0.after
  eq_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call Wrapper.equals
    x86.test rax, rax
    x86.je main.neq_1.after
  neq_1:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-8]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_3
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_4
    x86.call mm_decref
    x86.label __nonnull_skip_4
    x86.mov rdx, [rbp-8]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_5
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_5
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_6
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_6
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_7
    x86.call mm_decref
    x86.label __nonnull_skip_7
    x86.mov rdx, [rbp-8]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_8
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_8
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
  func @__destruct_Wrapper(ptr: i64) {
  entry:
    x86.jmp __destruct_Wrapper.done
  done:
    x86.ret
  }
}
---

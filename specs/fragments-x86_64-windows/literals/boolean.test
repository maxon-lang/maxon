// Test: boolean
function main() returns ExitCode
  var flag = true
  if flag 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @literals.main() -> u32 {
  entry:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je literals.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

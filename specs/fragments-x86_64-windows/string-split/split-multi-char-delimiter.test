// Test: split-multi-char-delimiter
function main() returns ExitCode
	var s = "one::two::three"
	var parts = s.split("::")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'

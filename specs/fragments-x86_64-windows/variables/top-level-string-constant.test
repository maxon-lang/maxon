// Test: top-level-string-constant
let GREETING = "hello"

function main() returns ExitCode
	if GREETING == "hello" 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 1
    x86.cmp rax, 1
    x86.jne else
  then:
    x86.mov rax, 1
    x86.ret
  else:
  merge:
    x86.mov rax, 0
    x86.ret
  }
}
---

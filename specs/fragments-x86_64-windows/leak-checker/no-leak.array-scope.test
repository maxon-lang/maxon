// Test: no-leak.array-scope
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function use_array()
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)
end 'use_array'

function main() returns ExitCode
	use_array()
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @leak-checker.use_array() {
  entry:
    x86.prologue stack_size=16
    x86.call IntArray.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.call IntArray.push
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 20
    x86.call IntArray.push
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 30
    x86.call IntArray.push
    x86.mov rbx, [rbp-8]
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call leak-checker.use_array
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Integer.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.call mm_raw_free
    x86.jmp __destruct___ManagedMemory_Integer.skip_buf_0
  skip_buf_0:
    x86.jmp __destruct___ManagedMemory_Integer.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp __destruct_IntArray.done
  done:
    x86.epilogue
    x86.ret
  }
}
---

// Test: simple-panic
typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function dangerous(value Integer) returns Byte
	return Byte{value}
end

function main() returns ExitCode
	return dangerous(Integer{300})
end

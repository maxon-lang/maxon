// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function double(x Score) returns Score
	return x * 2
end 'double'

function main() returns ExitCode
	var f = double      // f is a function reference
	return f(21)        // calls double(21), returns 42
end 'main'

---
ExitCode: 42
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func rax, [first-class-functions.double]
    x86.mov rcx, 21
    x86.xor rdx, rdx
    x86.mov [rbp-8], rax
    x86.mov r10, rax
    x86.call r10
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: first-class-function.reassign

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
  return x * 2
end 'double'

function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  var f = double
  var a = f(10)
  f = triple
  var b = f(10)
  return a + b
end 'main'
---
ExitCode: 50
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @first-class-functions.triple(x: i64) -> i64 {
  entry:
    x86.mov rax, 3
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @first-class-functions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_func rax, [first-class-functions.double]
    x86.mov rcx, 10
    x86.xor rdx, rdx
    x86.mov [rbp-8], rax
    x86.mov r10, rax
    x86.call r10
    x86.lea_func rbx, [first-class-functions.triple]
    x86.mov rsi, 10
    x86.xor rdi, rdi
    x86.mov [rbp-16], rax
    x86.mov [rbp-24], rbx
    x86.mov r10, rbx
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call r10
    x86.mov r8, [rbp-16]
    x86.add r8, rax
    x86.xor r9, r9
    x86.cmp r8, r9
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rcx, 4294967295
    x86.cmp r8, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or rax, rcx
    x86.test rax, rax
    x86.je first-class-functions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, r8
    x86.epilogue
    x86.ret
  }
}
---

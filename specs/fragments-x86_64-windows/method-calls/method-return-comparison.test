// Test: method-return-comparison

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function isPositive() returns Integer
    if n > 0 'positive'
      return 1
    end 'positive'
    return 0
  end 'isPositive'
end 'Value'

function main() returns ExitCode
  var v = Value{n: 42}
  return v.isPositive()
end 'main'
---
ExitCode: 1
---
module {
  func @Value.isPositive(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.jle Value.isPositive.positive_0.after
  positive_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  positive_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Value.isPositive
    x86.mov [rbp-16], rax
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_24]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

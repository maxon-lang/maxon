// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
	var result Integer

	function addTwo(a Integer, b Integer)
		result = result + a + b
	end 'addTwo'

	function get() returns Integer
		return result
	end 'get'
end 'Calculator'

function main() returns ExitCode
	var calc = Calculator{result: 0}
	calc.addTwo(20, b: 22)
	return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.addTwo(__self_ptr: i64, a: i64, b: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.add rbx, rdx
    x86.add rbx, r8
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rbx
    x86.epilogue
    x86.ret
  }
  func @Calculator.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.mov rdx, 20
    x86.mov r8, 22
    x86.call Calculator.addTwo
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov rcx, rsi
    x86.call Calculator.get
    x86.xor rdi, rdi
    x86.cmp rax, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or r8, rcx
    x86.test r8, r8
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

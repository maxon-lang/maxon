    x86.mov rsi, [rax+8]
    x86.add rbx, rdx
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rbx
    x86.add rsi, r8
    x86.mov rax, [rbp-8]
    x86.mov [rax+8], rsi
    x86.epilogue
    x86.ret
  }

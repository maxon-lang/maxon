// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
	var value Integer

	function getValue() returns Integer
		return value
	end 'getValue'
end 'Box'

function main() returns ExitCode
	var b = Box{value: 40}
	return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
module {
  func @Box.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 40
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Box.getValue
    x86.mov rbx, 2
    x86.add rax, rbx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.jg main.__range_panic_0
    x86.cmp rax, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
  var value Integer

  function getValue() returns Integer
    return value
  end 'getValue'
end 'Box'

function main() returns ExitCode
  var b = Box{value: 40}
  return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
module {
  func @Box.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 40
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Box.getValue
    x86.mov rbx, 2
    x86.add rax, rbx
    x86.mov [rbp-16], rax
    x86.xor rsi, rsi
    x86.cmp rax, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or rdi, r9
    x86.test rdi, rdi
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

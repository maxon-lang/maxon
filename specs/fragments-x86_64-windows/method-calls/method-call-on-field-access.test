// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
  var value Integer

  function get() returns Integer
    return value
  end 'get'
end 'Inner'

type Outer
  var inner Inner

  function getInnerValue() returns Integer
    return inner.get()
  end 'getInnerValue'
end 'Outer'

function main() returns ExitCode
  var o = Outer{inner: Inner{value: 42}}
  return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov [rbp-16], rdx
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp Inner.get
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 42
    x86.mov [rcx+0], rdx
    x86.lea_func rbx, [__destruct_Outer]
    x86.mov rsi, rbx
    x86.mov rdx, rsi
    x86.mov rcx, 8
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rdi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], rdi
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call Outer.getInnerValue
    x86.mov [rbp-24], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax
    x86.test rcx, rcx
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_35]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Inner(ptr: i64) {
  entry:
    x86.jmp __destruct_Inner.done
  done:
    x86.ret
  }
  func @__destruct_Outer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp __destruct_Outer.done
  done:
    x86.epilogue
    x86.ret
  }
}

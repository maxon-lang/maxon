// Test: conditional-extensions.type-extension
type Box uses Item
  export var item Item
end 'Box'

extension Box where Item is Equatable
  function matches(other Item) returns bool
    return item == other
  end 'matches'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
  var b = IntBox{item: 42}
  if b.matches(42) 'yes'
    return 1
  end 'yes'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @conditional-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.mov rdx, 42
    x86.call IntBox.matches
    x86.test rax, rax
    x86.je conditional-extensions.main.yes_0.after
  yes_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  yes_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @IntBox.matches(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov [rbp-16], rbx
    x86.mov rax, [rbp-16]
    x86.cmp rax, rdx
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
}
---

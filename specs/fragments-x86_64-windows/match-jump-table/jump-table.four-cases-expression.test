// Test: jump-table.four-cases-expression
enum Direction
    north
    south
    east
    west
end 'Direction'

function main() returns ExitCode
    var d = Direction.east
    let code = match d 'dir'
        north gives 10
        south gives 20
        east gives 30
        west gives 40
    end 'dir'
    return code
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rcx
    x86.mov rbx, [rbp-24]
    x86.jump_table rbx, 4 cases, default=main.dir_0.merge
  dir_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-16], rax
    x86.jmp main.dir_0.merge
  dir_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-16], rax
    x86.jmp main.dir_0.merge
  dir_0.case2:
    x86.mov rax, 30
    x86.mov [rbp-16], rax
    x86.jmp main.dir_0.merge
  dir_0.case3:
    x86.mov rax, 40
    x86.mov [rbp-16], rax
    x86.jmp main.dir_0.merge
  dir_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

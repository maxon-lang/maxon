// Test: jump-table.four-cases-statement
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		var d = Direction.west
		match d 'dir'
				north then print("N")
				south then print("S")
				east then print("E")
				west then print("W")
		end 'dir'
		return 0
end 'main'
---

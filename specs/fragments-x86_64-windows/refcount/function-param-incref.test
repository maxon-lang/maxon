// Test: function-param-incref
typealias Integer = int(i64.min to i64.max)
type Config
		export var level Integer
end 'Config'
function readLevel(c Config) returns Integer
		return c.level
end 'readLevel'
function main() returns ExitCode
		var cfg = Config{level: 77}
		let l = readLevel(cfg)
		return l + cfg.level - 77
end 'main'
---
ExitCode: 77
---
module {
  func @refcount.readLevel(c: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 77
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call refcount.readLevel
    x86.mov rbx, [rbp-8]
    x86.add rax, rbx
    x86.mov rsi, 77
    x86.sub rax, rsi
    x86.xor rdi, rdi
    x86.cmp rax, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or r8, rcx
    x86.test r8, r8
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

// Test: decref-reclaims-same-scope
typealias Integer = int(i64.min to i64.max)
type Val
		export var n Integer

		static function create(n Integer) returns Self
			return Self{n: n}
		end 'create'
end 'Val'
function main() returns ExitCode
		var a = Val.create(n: 10)
		var b = a
		a = Val.create(n: 20)
		return a.n + b.n
end 'main'
---
ExitCode: 30
---
module {
  func @Val.create(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Val.create
    x86.mov [rbp-8], rax
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rcx, 20
    x86.call Val.create
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-24], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rdx, [rbp-24]
    x86.mov [rbp-8], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbx+0]
    x86.mov rdi, [rbp-16]
    x86.mov r8, [rdi+0]
    x86.add rsi, r8
    x86.xor r9, r9
    x86.mov rax, 4294967295
    x86.cmp rsi, rax
    x86.jg main.__range_panic_0
    x86.cmp rsi, r9
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-32], rsi
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Val(ptr: i64) {
  entry:
    x86.jmp __destruct_Val.done
  done:
    x86.ret
  }
}

// Test: break-cleans-refs
typealias Integer = int(i64.min to i64.max)
type Counter
    export var val Integer
end 'Counter'
function main() returns ExitCode
    var total = 0
    var i = 0
    while i < 5 'loop'
        var c = Counter{val: i}
        if i == 3 'brk'
            total = total + c.val
            break
        end 'brk'
        total = total + c.val
        i = i + 1
    end 'loop'
    return total
end 'main'
---
ExitCode: 6
---
module {
  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp refcount.main.loop_0.header
  loop_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge refcount.main.loop_0.exit
  loop_0:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.mov rcx, 3
    x86.mov rdx, [rbp-16]
    x86.cmp rdx, rcx
    x86.jne refcount.main.brk_1.after
  brk_1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp refcount.main.loop_0.exit
  brk_1.after:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 1
    x86.mov rbx, [rbp-16]
    x86.add rbx, rdx
    x86.mov [rbp-16], rbx
    x86.jmp refcount.main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je refcount.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_36]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

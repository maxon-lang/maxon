  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp refcount.main.loop_0.header
  loop_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge refcount.main.loop_0.exit
  loop_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-24], rax
    x86.mov rcx, [rbp-24]
    x86.mov rdx, [rbp-16]
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov rsi, 3
    x86.mov rdi, [rbp-16]
    x86.cmp rdi, rsi
    x86.jne refcount.main.brk_1.after
  brk_1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.add rdx, rcx
    x86.mov [rbp-8], rdx
    x86.mov rbx, [rbp-24]
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.jmp refcount.main.loop_0.exit
  brk_1.after:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.add rdx, rcx
    x86.mov [rbp-8], rdx
    x86.mov rbx, 1
    x86.mov rsi, [rbp-16]
    x86.add rsi, rbx
    x86.mov [rbp-16], rsi
    x86.mov rdi, [rbp-24]
    x86.test rdi, rdi
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp refcount.main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je refcount.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_36]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }

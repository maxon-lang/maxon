// Test: alias-survives-inner-scope
typealias Integer = int(i64.min to i64.max)
type Box
		export var value Integer

		static function create(value Integer) returns Self
			return Self{value: value}
		end 'create'
end 'Box'
function main() returns ExitCode
		var result = Box.create(value: 0)
		if true 'blk'
				var inner = Box.create(value: 42)
				result = inner
		end 'blk'
		return result.value
end 'main'
---
ExitCode: 42
---
module {
  func @Box.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call Box.create
    x86.mov [rbp-8], rax
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.blk_0.merge
  blk_0:
    x86.mov rcx, 42
    x86.call Box.create
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rdx, [rbp-16]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp main.blk_0.merge
  blk_0.merge:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_1
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Box(ptr: i64) {
  entry:
    x86.jmp __destruct_Box.done
  done:
    x86.ret
  }
}
---

// Test: reassignment-decrefs-old
typealias Integer = int(i64.min to i64.max)
type Item
		export var val Integer
end 'Item'
function main() returns ExitCode
		var a = Item{val: 10}
		a = Item{val: 20}
		return a.val
end 'main'
---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, 20
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rdi, [rbp-16]
    x86.mov r8, 20
    x86.mov [rdi+0], r8
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov r9, [rbp-8]
    x86.test r9, r9
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rax, rdx
    x86.test rax, rax
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    x86.jmp __destruct_Item.done
  done:
    x86.ret
  }
}

// Test: reassignment-decrefs-old
typealias Integer = int(i64.min to i64.max)
type Item
		export var val Integer

		static function create(val Integer) returns Self
			return Self{val: val}
		end 'create'
end 'Item'
function main() returns ExitCode
		var a = Item.create(val: 10)
		a = Item.create(val: 20)
		return a.val
end 'main'
---
ExitCode: 20
---
module {
  func @Item.create(val: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Item.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 20
    x86.call Item.create
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rcx+0]
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rdx
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    x86.jmp __destruct_Item.done
  done:
    x86.ret
  }
}
---

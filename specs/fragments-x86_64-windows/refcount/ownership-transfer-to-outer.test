// Test: ownership-transfer-to-outer
typealias Integer = int(i64.min to i64.max)
type Token
    export var kind Integer
end 'Token'
function main() returns ExitCode
    var t = Token{kind: 0}
    if true 'a'
        var inner = Token{kind: 50}
        t = inner
    end 'a'
    return t.kind
end 'main'
---
ExitCode: 50
---
module {
  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, 1
    x86.test rsi, rsi
    x86.je refcount.main.a_0.merge
  a_0:
    x86.mov rax, 50
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.jmp refcount.main.a_0.merge
  a_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je refcount.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @__destruct_Token(ptr: i64) {
  entry:
    x86.jmp __destruct_Token.done
  done:
    x86.ret
  }
}
---

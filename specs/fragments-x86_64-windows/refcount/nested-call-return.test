    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }

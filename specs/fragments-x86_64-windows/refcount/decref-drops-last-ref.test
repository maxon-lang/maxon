// Test: decref-drops-last-ref
typealias Integer = int(i64.min to i64.max)
type Tag
    export var id Integer
end 'Tag'
function main() returns ExitCode
    var a = Tag{id: 1}
    a = Tag{id: 2}
    a = Tag{id: 3}
    return a.id
end 'main'

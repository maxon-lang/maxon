// Test: decref-drops-last-ref
typealias Integer = int(i64.min to i64.max)
type Tag
		export var id Integer

		static function create(id Integer) returns Self
			return Self{id: id}
		end 'create'
end 'Tag'
function main() returns ExitCode
		var a = Tag.create(id: 1)
		a = Tag.create(id: 2)
		a = Tag.create(id: 3)
		return a.id
end 'main'
---
ExitCode: 3
---
module {
  func @Tag.create(id: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 1
    x86.call Tag.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 2
    x86.call Tag.create
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.call Tag.create
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-24], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-24]
    x86.mov [rbp-8], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbx+0]
    x86.xor rdi, rdi
    x86.mov r8, 4294967295
    x86.cmp rsi, r8
    x86.jg main.__range_panic_0
    x86.cmp rsi, rdi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rsi
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Tag(ptr: i64) {
  entry:
    x86.jmp __destruct_Tag.done
  done:
    x86.ret
  }
}
---

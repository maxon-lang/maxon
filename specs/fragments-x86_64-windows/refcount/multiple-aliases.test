// Test: multiple-aliases
typealias Integer = int(i64.min to i64.max)
type Data
		export var n Integer
end 'Data'
function main() returns ExitCode
		var a = Data{n: 7}
		var b = a
		var c = a
		return a.n + b.n + c.n
end 'main'
---
ExitCode: 21
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 7
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-8]
    x86.add rcx, rdx
    x86.mov rbx, [rbp-8]
    x86.add rcx, rbx
    x86.xor rsi, rsi
    x86.cmp rcx, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.mov r8, 4294967295
    x86.cmp rcx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or rdi, r9
    x86.test rdi, rdi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

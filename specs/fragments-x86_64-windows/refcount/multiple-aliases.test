// Test: multiple-aliases
typealias Integer = int(i64.min to i64.max)
type Data
		export var n Integer

		static function create(n Integer) returns Self
			return Self{n: n}
		end 'create'
end 'Data'
function main() returns ExitCode
		var a = Data.create(n: 7)
		var b = a
		var c = a
		return a.n + b.n + c.n
end 'main'

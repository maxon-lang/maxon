// Test: decref-reclaims-inner-scope
typealias Integer = int(i64.min to i64.max)
type Cell
		export var value Integer

		static function create(value Integer) returns Self
			return Self{value: value}
		end 'create'
end 'Cell'
function main() returns ExitCode
		var a = Cell.create(value: 10)
		var result = 0
		if true 'inner'
				var b = a
				a = Cell.create(value: 20)
				result = b.value
		end 'inner'
		return result + a.value
end 'main'
---
ExitCode: 30
---
module {
  func @Cell.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Cell.create
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.mov rcx, 1
    x86.test rcx, rcx
    x86.je main.inner_0.merge
  inner_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rax
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov rcx, 20
    x86.call Cell.create
    x86.mov rdx, [rbp-8]
    x86.mov [rbp-32], rax
    x86.test rdx, rdx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rbx, [rbp-32]
    x86.mov [rbp-8], rbx
    x86.mov rsi, [rbp-24]
    x86.mov rdi, [rsi+0]
    x86.mov [rbp-16], rdi
    x86.mov r8, [rbp-24]
    x86.test r8, r8
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp main.inner_0.merge
  inner_0.merge:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-16]
    x86.add rdx, rcx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_1
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rdx
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Cell(ptr: i64) {
  entry:
    x86.jmp __destruct_Cell.done
  done:
    x86.ret
  }
}
---

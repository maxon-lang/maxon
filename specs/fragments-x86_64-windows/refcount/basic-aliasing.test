// Test: basic-aliasing
typealias Integer = int(i64.min to i64.max)
type Point
		export var x Integer
		export var y Integer
end 'Point'
function main() returns ExitCode
		var a = Point{x: 10, y: 20}
		var b = a
		return a.x + b.y
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, [rbp-16]
    x86.mov rbx, [rbp-8]
    x86.add rdx, rbx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.mov rax, [rbp-40]
    x86.mov [rbp-56], rcx
    x86.test rax, rax
    x86.jz __nonnull_skip_0

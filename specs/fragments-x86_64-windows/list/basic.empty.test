// Test: basic.empty
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
	var list = IntList.empty()
	if list.isEmpty() 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call IntList.empty
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call IntList.isEmpty
    x86.test rax, rax
    x86.je main.check_0.after
  check_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedList_Integer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call maxon_managed_list_clear
    x86.jmp __destruct___ManagedList_Integer.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_IntList(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.jmp __destruct_IntList.done
  done:
    x86.epilogue
    x86.ret
  }
}
---

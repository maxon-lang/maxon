// Test: if-try-else-with-error-binding

typealias Integer = int(i64.min to i64.max)

union MyError implements Error
  first
  second
end 'MyError'

function mayFail(which Integer) returns Integer throws MyError
  if which == 1 'check1'
    throw MyError.first
  end 'check1'
  if which == 2 'check2'
    throw MyError.second
  end 'check2'
  return 42
end 'mayFail'

function main() returns ExitCode
  var result = 0
  if try mayFail(1) 'check'
    result = 100
  end 'check' else (e) 'err'
    result = 50
  end 'err'
  return result
end 'main'
---
ExitCode: 50
---
module {
  func @if-try.mayFail(which: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, 1
    x86.cmp rcx, rax
    x86.jne if-try.mayFail.check1_0.after
  check1_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check1_0.after:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne if-try.mayFail.check2_1.after
  check2_1:
    x86.mov rax, 1
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check2_1.after:
    x86.mov rax, 42
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.call if-try.mayFail
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.jne if-try.main.err_3
  check_2:
    x86.mov rax, 100
    x86.mov [rbp-8], rax
    x86.jmp if-try.main.check_2.merge
  err_3:
    x86.mov rax, 50
    x86.mov [rbp-8], rax
    x86.jmp if-try.main.check_2.merge
  check_2.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je if-try.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

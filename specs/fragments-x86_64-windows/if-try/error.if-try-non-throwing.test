// Test: error.if-try-non-throwing

typealias Integer = int(i64.min to i64.max)

function noThrow() returns Integer
	return 42
end 'noThrow'

function main() returns ExitCode
	if try noThrow() 'check'
		return 1
	end 'check'
	return 0
end 'main'

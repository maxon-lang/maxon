// Test: if-try-binding-success

typealias Integer = int(i64.min to i64.max)

union MyError implements Error
  failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
  if not succeed 'check'
    throw MyError.failed
  end 'check'
  return 42
end 'mayFail'

function main() returns ExitCode
  if let value = try mayFail(true) 'check'
    return value
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x86.mov rax, 1
    x86.xor rcx, rax
    x86.test rcx, rcx
    x86.je if-try.mayFail.check_0.after
  check_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 42
    x86.xor rdx, rdx
    x86.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.call if-try.mayFail
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.jne if-try.main.check_2.after
  check_2:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je if-try.main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  check_2.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

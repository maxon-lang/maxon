// Test: if-try-else-block

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
	if not succeed 'check'
		throw MyError.failed
	end 'check'
	return 42
end 'mayFail'

function main() returns ExitCode
	var result = 0
	if try mayFail(false) 'check'
		result = 1
	end 'check' else 'err'
		result = 2
	end 'err'
	return result
end 'main'
---
ExitCode: 2
---
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x86.mov rax, 1
    x86.xor rcx, rax
    x86.test rcx, rcx
    x86.je if-try.mayFail.check_0.after
  check_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 42
    x86.xor rdx, rdx
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call if-try.mayFail
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.jne main.err_3
  check_2:
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.jmp main.check_2.merge
  err_3:
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.check_2.merge
  check_2.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_4
    x86.cmp rax, rcx
    x86.jl main.__range_panic_4
    x86.jmp main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

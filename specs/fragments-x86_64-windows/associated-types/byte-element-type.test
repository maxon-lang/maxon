// Test: byte-element-type

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

interface ByteSource uses Element
  function getByte() returns Element
end 'ByteSource'

type SingleByte implements ByteSource with Byte
  var b Byte

  function getByte() returns Byte
    return b
  end 'getByte'
end 'SingleByte'

function main() returns ExitCode
  var s = SingleByte{b: 42 as Byte}
  var b = s.getByte()
  return b as Integer
end 'main'
---
ExitCode: 42
---
module {
  func @SingleByte.getByte(__self_ptr: i64) -> u8 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.movzx rdx, byte ptr [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov [rbp-8], rax
    x86.lea rdx, [rbp-8]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call SingleByte.getByte
    x86.mov [rbp-16], rax
    x86.xor rsi, rsi
    x86.cmp rax, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or rdi, r9
    x86.test rdi, rdi
    x86.je associated-types.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

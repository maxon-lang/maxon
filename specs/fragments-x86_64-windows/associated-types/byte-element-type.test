// Test: byte-element-type

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

interface ByteSource uses Element
	function getByte() returns Element
end 'ByteSource'

type SingleByte implements ByteSource with Byte
	var b Byte

	function getByte() returns Byte
		return b
	end 'getByte'

	static function create(b Byte) returns Self
		return Self{b: b}
	end 'create'
end 'SingleByte'

function main() returns ExitCode
	var s = SingleByte.create(b: 42 as Byte)
	var b = s.getByte()
	return b as Integer
end 'main'
---
ExitCode: 42
---
module {
  func @SingleByte.getByte(__self_ptr: i64) -> u8 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.movzx rdx, byte ptr [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @SingleByte.create(b: i8) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov byte ptr [rax+0], rcxb
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rcx, rax
    x86.call SingleByte.create
    x86.mov [rbp-8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call SingleByte.getByte
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_SingleByte(ptr: i64) {
  entry:
    x86.jmp __destruct_SingleByte.done
  done:
    x86.ret
  }
}
---

// Test: basic-associated-type

typealias Integer = int(i64.min to i64.max)

interface Wrapper uses Inner
	function unwrap() returns Inner
end 'Wrapper'

type IntBox implements Wrapper with Integer
	var value Integer

	function unwrap() returns Integer
		return value
	end 'unwrap'
end 'IntBox'

function main() returns ExitCode
	var box = IntBox{value: 42}
	return box.unwrap()
end 'main'
---
ExitCode: 42
---
module {
  func @IntBox.unwrap(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call IntBox.unwrap
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

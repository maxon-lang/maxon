// Test: multiple-associated-types

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

interface Pair uses First, Second
	function getFirst() returns First
	function getSecond() returns Second
end 'Pair'

type IntFloat implements Pair with Integer, Float
	var a Integer
	var b Float

	function getFirst() returns Integer
		return a
	end 'getFirst'

	function getSecond() returns Float
		return b
	end 'getSecond'
end 'IntFloat'

function main() returns ExitCode
	var p = IntFloat{a: 40, b: 2.5}
	var x = p.getFirst()
	var y = trunc(p.getSecond())
	return x + y
end 'main'
---
ExitCode: 42
---
module {
  func @IntFloat.getFirst(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @IntFloat.getSecond(__self_ptr: i64) -> f64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.movsd xmm0, [rax+8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 40
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov [rbp-16], rax
    x86.movsd [rbp-8], xmm0
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call IntFloat.getFirst
    x86.lea rbx, [rbp-16]
    x86.mov rsi, rbx
    x86.mov [rbp-24], rax
    x86.mov rcx, rsi
    x86.call IntFloat.getSecond
    x86.cvttsd2si rdi, xmm0
    x86.mov r8, [rbp-24]
    x86.add r8, rdi
    x86.xor r9, r9
    x86.mov rax, 4294967295
    x86.cmp r8, rax
    x86.jg main.__range_panic_0
    x86.cmp r8, r9
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, r8
    x86.epilogue
    x86.ret
  }
}

    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.movsd xmm1, [rbp-24]
    x86.movsd [rdx+8], xmm1
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd xmm1, xmm0
    x86.mov rcx, 40
    x86.call IntFloat.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call IntFloat.getFirst
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.call IntFloat.getSecond
    x86.cvttsd2si rdx, xmm0
    x86.mov rbx, [rbp-16]
    x86.add rbx, rdx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rbx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rbx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]

// Test: method-call-syntax

typealias Integer = int(i64.min to i64.max)

interface Addable
	function addOne() returns Integer
end 'Addable'

type Number implements Addable
	var value Integer

	function addOne() returns Integer
		return value + 1
	end 'addOne'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Number'

function main() returns ExitCode
	var n = Number.create(value: 41)
	return n.addOne()
end 'main'
---
ExitCode: 42
---
module {
  func @Number.addOne(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.lea rax, [rdx + rax]
    x86.epilogue
    x86.ret
  }
  func @Number.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 41
    x86.call Number.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Number.addOne
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Number(ptr: i64) {
  entry:
    x86.jmp __destruct_Number.done
  done:
    x86.ret
  }
}

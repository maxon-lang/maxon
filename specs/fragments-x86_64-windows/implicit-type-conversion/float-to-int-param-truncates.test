// Test: float-to-int-param-truncates

typealias Integer = int(i64.min to i64.max)

function takeInt(x Integer) returns Integer
	return x
end 'takeInt'

function main() returns ExitCode
	var f = 3.7
	return takeInt(f)
end 'main'
---
ExitCode: 3
---
module {
  func @implicit-type-conversion.takeInt(x: i64) -> i64 {
  entry:
    x86.mov rax, rcx
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.7]
    x86.cvttsd2si rax, xmm0
    x86.mov rcx, rax
    x86.call implicit-type-conversion.takeInt
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

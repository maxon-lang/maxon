// Test: expression-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
  return trunc(x)
end 'takeFloat'

function main() returns ExitCode
  var a = 20
  var b = 22
  return takeFloat(a + b)
end 'main'
---
ExitCode: 42
---
module {
  func @implicit-type-conversion.takeFloat(x: f64) -> i64 {
  entry:
    x86.cvttsd2si rax, xmm0
    x86.ret
  }
  func @implicit-type-conversion.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 20
    x86.mov rcx, 22
    x86.add rax, rcx
    x86.cvtsi2sd xmm0, rax
    x86.call implicit-type-conversion.takeFloat
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je implicit-type-conversion.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

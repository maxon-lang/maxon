// Test: no-int-to-bool

typealias Integer = int(i64.min to i64.max)

function takeBool(x bool) returns Integer
  if x 'check'
    return 1
  end 'check'
  return 0
end 'takeBool'

function main() returns ExitCode
  var i = 1
  return takeBool(i)
end 'main'

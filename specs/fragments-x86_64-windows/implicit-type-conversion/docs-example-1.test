// Test: docs-example-1
typealias Score = int(i64.min to i64.max)
typealias Weight = float(f64.min to f64.max)

function takeFloat(x Weight) returns Score
  return trunc(x)
end 'takeFloat'

function main() returns ExitCode
  return takeFloat(42)
end 'main'

---
ExitCode: 42
---
module {
  func @implicit-type-conversion.takeFloat(x: f64) -> i64 {
  entry:
    x86.cvttsd2si rax, xmm0
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.cvtsi2sd xmm0, rax
    x86.call implicit-type-conversion.takeFloat
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

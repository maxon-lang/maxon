// Test: byte.compare.less

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var a = 10 as Byte
  var b = 20 as Byte
  var result = a.compare(b)
  match result 'check'
    Ordering.lessThan then return 0
    Ordering.equalTo then return 1
    Ordering.greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rdx, 20
    x86.mov rbx, 255
    x86.and rdx, rbx
    x86.mov rcx, rax
    x86.call stdlib.byte.compare
    x86.mov [rbp-8], rax
    x86.jmp primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp1
  check_0.case0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp2
  check_0.case1:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.merge
  check_0.case2:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

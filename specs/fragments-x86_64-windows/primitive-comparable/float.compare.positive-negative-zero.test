// Test: float.compare.positive-negative-zero
function main() returns ExitCode
  var pos = 0.0
  var neg = -0.0
  var result = pos.compare(neg)
  match result 'check'
    lessThan then return 1
    equalTo then return 0
    greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.call stdlib.float.compare
    x86.mov [rbp-8], rax
    x86.jmp primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp2
  check_0.case1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.merge
  check_0.case2:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

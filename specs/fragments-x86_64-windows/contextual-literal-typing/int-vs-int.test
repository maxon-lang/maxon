// Test: int-vs-int
function main() returns ExitCode
  var a = 1000
  var b = 1000
  if a == b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 1000
    x86.mov rcx, 1000
    x86.cmp rax, rcx
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

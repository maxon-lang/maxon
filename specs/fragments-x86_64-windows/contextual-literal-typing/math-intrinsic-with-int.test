// Test: math-intrinsic-with-int
function main() returns ExitCode
	var x = 16
	var result = sqrt(x)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 16
    x86.cvtsi2sd xmm0, rax
    x86.sqrtsd xmm1, xmm0
    x86.cvttsd2si rcx, xmm1
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: float-vs-float
function main() returns ExitCode
  var a = 3.14
  var b = 3.14
  if a == b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movsd xmm1, [rip+__float_3.14]
    x86.ucomisd xmm0, xmm1
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

// Test: docs-example-2
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
  var b = 200 as Pixel
  if b == 200 'check'
    return 1
  end 'check'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 200
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rdx, 200
    x86.cmp rax, rdx
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

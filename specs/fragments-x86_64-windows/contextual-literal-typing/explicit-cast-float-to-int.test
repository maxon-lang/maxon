// Test: explicit-cast-float-to-int
function main() returns ExitCode
	var x = 5
	var y = 5.0
	if x == trunc(y) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.movsd xmm0, [rip+__float_5]
    x86.cvttsd2si rcx, xmm0
    x86.cmp rax, rcx
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

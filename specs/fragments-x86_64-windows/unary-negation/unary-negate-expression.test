// Test: unary-negate-expression
function main() returns ExitCode
	var x = 10
	var y = 5
	var z = -(x + y)
	return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 5
    x86.add rax, rcx
    x86.xor rdx, rdx
    x86.sub rdx, rax
    x86.mov rbx, 57
    x86.add rbx, rdx
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rbx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rbx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rbx
    x86.epilogue
    x86.ret
  }
}
---

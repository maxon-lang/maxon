// Test: abs.float
function main() returns ExitCode
	var neg = -5.5
	var x = abs(neg)
	var y = trunc(x)
	return y
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_-5.5]
    x86.movsd xmm1, xmm0
    x86.andpd xmm1, [rip+__abs_mask]
    x86.cvttsd2si rax, xmm1
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

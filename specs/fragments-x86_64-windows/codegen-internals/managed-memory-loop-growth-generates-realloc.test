// Test: managed-memory-loop-growth-generates-realloc
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = IntArray{}
	var i = 0
	while i < 10 'loop'
		arr.push(i)
		i = i + 1
	end 'loop'
	return arr.count()
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.xor rcx, rcx
    x86.xor rdx, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 8
    x86.lea_func rdi, [__destruct___ManagedMemory_Integer]
    x86.mov r8, rdi
    x86.mov rdx, r8
    x86.mov rcx, 32
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov r9, [rbp-8]
    x86.xor rax, rax
    x86.mov [r9+0], rax
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov [rax+8], rcx
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov [rax+16], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, 8
    x86.mov [rax+24], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+24]
    x86.lea_symdata rax, [__mm_panic_element_size_zero]
    x86.mov rdx, rax
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.xor rcx, rcx
    x86.call maxon_bounds_check
    x86.lea_func rax, [__destruct_IntArray]
    x86.mov rcx, rax
    x86.mov rdx, rcx
    x86.mov rcx, 16
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov [rax+0], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+8], rax
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.xor rax, rax
    x86.mov [rbp-24], rax
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov rax, 10
    x86.mov rcx, [rbp-24]
    x86.cmp rcx, rax
    x86.jge main.loop_0.exit
  loop_0:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.call IntArray.push
    x86.mov rdx, 1
    x86.mov rbx, [rbp-24]
    x86.add rbx, rdx
    x86.mov [rbp-24], rbx
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call IntArray.count
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rcx, [rbp-16]
    x86.mov [rbp-32], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Integer.skip_buf_0
  free_buf_0:

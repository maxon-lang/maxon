// Test: rdata-cow-mutation-copies-to-heap
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = [42]
	arr.set(0, value: 77)
	return try arr.get(0) otherwise 0
end 'main'

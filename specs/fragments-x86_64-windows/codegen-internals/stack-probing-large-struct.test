    x86.cmp rax, rbx
    x86.jg codegen-internals.recurse.__range_panic_1
    x86.cmp rax, rdx
    x86.jl codegen-internals.recurse.__range_panic_1
    x86.jmp codegen-internals.recurse.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic

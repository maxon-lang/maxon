// Test: managed-memory-scope-cleanup-generates-free
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	if true 'outer'
		var outer_arr = IntArray{}
		outer_arr.push(100)
		if true 'inner'
			var inner_arr = IntArray{}
			inner_arr.push(200)
		end 'inner'
	end 'outer'
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.outer_0.merge
  outer_0:
    x86.xor rax, rax
    x86.xor rcx, rcx
    x86.xor rdx, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 8
    x86.lea_func rdi, [__destruct___ManagedMemory_Integer]
    x86.mov r8, rdi
    x86.mov rdx, r8
    x86.mov rcx, 32
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov r9, [rbp-8]
    x86.xor rax, rax
    x86.mov [r9+0], rax
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov [rax+8], rcx
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov [rax+16], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, 8
    x86.mov [rax+24], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+24]
    x86.lea_symdata rax, [__mm_panic_element_size_zero]
    x86.mov rdx, rax
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.xor rcx, rcx
    x86.call maxon_bounds_check
    x86.lea_func rax, [__destruct_IntArray]
    x86.mov rcx, rax
    x86.mov rdx, rcx
    x86.mov rcx, 16
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov [rax+0], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+8], rax
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, 100
    x86.call IntArray.push
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.inner_1.merge
  inner_1:
    x86.xor rax, rax
    x86.xor rcx, rcx
    x86.xor rdx, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 8
    x86.lea_func rdi, [__destruct___ManagedMemory_Integer]
    x86.mov r8, rdi
    x86.mov rdx, r8
    x86.mov rcx, 32
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-24], rax
    x86.mov r9, [rbp-24]
    x86.xor rax, rax
    x86.mov [r9+0], rax
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.mov [rax+8], rcx
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.mov [rax+16], rcx
    x86.mov rax, [rbp-24]
    x86.mov rcx, 8
    x86.mov [rax+24], rcx
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+24]
    x86.lea_symdata rax, [__mm_panic_element_size_zero]
    x86.mov rdx, rax
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.xor rcx, rcx
    x86.call maxon_bounds_check
    x86.lea_func rax, [__destruct_IntArray]
    x86.mov rcx, rax
    x86.mov rdx, rcx
    x86.mov rcx, 16
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-32], rax
    x86.mov rax, [rbp-32]
    x86.xor rcx, rcx
    x86.mov [rax+0], rcx
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-32]

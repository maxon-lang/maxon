// Test: managed-memory-scope-cleanup-generates-free
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	if true 'outer'
		var outer_arr = IntArray.empty()
		outer_arr.push(100)
		if true 'inner'
			var inner_arr = IntArray.empty()
			inner_arr.push(200)
		end 'inner'
	end 'outer'
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.outer_0.merge
  outer_0:
    x86.call IntArray.empty
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 100
    x86.call IntArray.push
    x86.mov rcx, 1
    x86.test rcx, rcx
    x86.je main.inner_1.merge
  inner_1:
    x86.call IntArray.empty
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, 200
    x86.call IntArray.push
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.jmp main.inner_1.merge
  inner_1.merge:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp main.outer_0.merge
  outer_0.merge:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Integer.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.call mm_raw_free
    x86.jmp __destruct___ManagedMemory_Integer.skip_buf_0
  skip_buf_0:
    x86.jmp __destruct___ManagedMemory_Integer.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.jmp __destruct_IntArray.done
  done:
    x86.epilogue
    x86.ret
  }
}
---

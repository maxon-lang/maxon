// Test: enum-ordinal.char-backed
enum Grade
  a = 'A'
  b = 'B'
  c = 'C'
end 'Grade'

function main() returns ExitCode
  var g = Grade.c
  if g.ordinal == 2 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-ordinal.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 2
    x86.cmp rcx, rdx
    x86.jne enum-ordinal.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

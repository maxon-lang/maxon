// Test: enum-ordinal.float-backed
enum Threshold
  low = 0.1
  medium = 0.5
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  var t = Threshold.high
  if t.ordinal == 2 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0.9]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rbp-8]
    x86.xor rax, rax
    x86.movsd xmm2, [rip+__float_0.1]
    x86.ucomisd xmm1, xmm2
    x86.sete rcx
    x86.movzx rcx, rcxb
    x86.setnp rdx
    x86.movzx rdx, rdxb
    x86.and rcx, rdx
    x86.xor rbx, rbx
    x86.test rcx, rcx
    x86.mov rsi, rax
    x86.cmovne rsi, rbx
    x86.movsd xmm3, [rip+__float_0.5]
    x86.ucomisd xmm1, xmm3
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.setnp r8
    x86.movzx r8, r8b
    x86.and rdi, r8
    x86.mov r9, 1
    x86.test rdi, rdi
    x86.mov rax, rsi
    x86.cmovne rax, r9
    x86.movsd xmm4, [rip+__float_0.9]
    x86.ucomisd xmm1, xmm4
    x86.sete rcx
    x86.movzx rcx, rcxb
    x86.setnp rdx
    x86.movzx rdx, rdxb
    x86.and rcx, rdx
    x86.mov rdx, 2
    x86.test rcx, rcx
    x86.mov rbx, rax
    x86.cmovne rbx, rdx
    x86.mov rax, 2
    x86.cmp rbx, rax
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

// Test: var-redeclare-after-scope
function main() returns ExitCode
	if true 'check'
		var x = 10
	end 'check'
	var x = 42
	return x
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.check_0.merge
  check_0:
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, 42
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

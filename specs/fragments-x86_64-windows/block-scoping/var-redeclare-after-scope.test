// Test: var-redeclare-after-scope
function main() returns ExitCode
	if true 'check'
		var x = 10
	end 'check'
	var x = 42
	return x
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.check_0.merge
  check_0:
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, 42
    x86.ret
  }
}
---

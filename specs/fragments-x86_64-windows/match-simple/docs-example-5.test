// Test: docs-example-5
union Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = Direction.north
  match dir 'navigate'
    north then return 1
    south then return 2
    east then return 3
    west then return 4
  end 'navigate'
end 'main'

---
ExitCode: 1
---
module {
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.jump_table rcx, 4 cases, default=match-simple.main.navigate_0.merge
  navigate_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  navigate_0.case1:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  navigate_0.case2:
    x86.mov rax, 3
    x86.epilogue
    x86.ret
  navigate_0.case3:
    x86.mov rax, 4
    x86.epilogue
    x86.ret
  navigate_0.merge:
  }
}
---

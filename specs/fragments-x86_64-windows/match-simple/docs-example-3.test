// Test: docs-example-3
function main() returns ExitCode
	var x = 2
	let result = match x 'convert'
		1 gives 10
		2 gives 20
		3 gives 30
		default gives 0
	end 'convert'
	return result
end 'main'

---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.convert_0.cmp0
  convert_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.convert_0.cmp1
  convert_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-16], rax
    x86.jmp main.convert_0.merge
  convert_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.convert_0.cmp2
  convert_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-16], rax
    x86.jmp main.convert_0.merge
  convert_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jne main.convert_0.case3
  convert_0.case2:
    x86.mov rax, 30
    x86.mov [rbp-16], rax
    x86.jmp main.convert_0.merge
  convert_0.case3:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.convert_0.merge
  convert_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

// Test: docs-example-4
function main() returns ExitCode
  var role = 1
  var permissions = 0
  match role 'auth'
    1 then permissions = permissions + 100 and fallthrough
    2 then permissions = permissions + 10 and fallthrough
    3 then permissions = permissions + 1
    default then permissions = 0
  end 'auth'
  return permissions
end 'main'


// Test: docs-example-2
function main() returns ExitCode
  var input = 3
  match input 'eval'
    1 or 2 then return 10
    3 or 4 or 5 then return 20
    default then return 0
  end 'eval'
end 'main'

---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 3
    x86.mov [rbp-8], rax
    x86.jmp main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 2
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.test rdx, rdx
    x86.je main.eval_0.cmp1
  eval_0.case0:
    x86.mov rax, 10
    x86.epilogue
    x86.ret
  eval_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, 4
    x86.cmp rbx, rsi
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.or rdx, rdi
    x86.mov r8, [rbp-8]
    x86.mov r9, 5
    x86.cmp r8, r9
    x86.sete rax
    x86.movzx rax, raxb
    x86.or rdx, rax
    x86.test rdx, rdx
    x86.je main.eval_0.case2
  eval_0.case1:
    x86.mov rax, 20
    x86.epilogue
    x86.ret
  eval_0.case2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  eval_0.merge:
  }
}
---

    x86.mov rdx, [rbp-16]
    x86.call IntArray.push
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call IntArray.push
    x86.mov rdx, [rbp-24]
    x86.mov rbx, [rbp-16]
    x86.add rbx, rdx
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rbx
    x86.call IntArray.push
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {

// Test: byte-array-count

typealias Byte = byte(0 to u8.max)

typealias ByteArray = Array with Byte

function main() returns ExitCode
	var arr = ByteArray.empty()
	arr.push(1 as Byte)
	arr.push(2 as Byte)
	arr.push(3 as Byte)
	arr.push(4 as Byte)
	arr.push(5 as Byte)

	return arr.count()
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call ByteArray.empty
    x86.mov [rbp-8], rax
    x86.mov rax, 1
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov rbx, 2
    x86.mov rsi, 255
    x86.and rbx, rsi
    x86.mov rdi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rbx
    x86.call ByteArray.push
    x86.mov r8, 3
    x86.mov r9, 255
    x86.and r8, r9
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, r8
    x86.call ByteArray.push
    x86.mov rax, 4
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov rax, 5
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call ByteArray.count
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_ByteMemory(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct_ByteMemory.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.call mm_raw_free
    x86.jmp __destruct_ByteMemory.skip_buf_0
  skip_buf_0:
    x86.jmp __destruct_ByteMemory.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_ByteArray(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1

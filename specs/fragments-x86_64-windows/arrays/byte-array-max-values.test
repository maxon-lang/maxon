    x86.mov rdx, r8
    x86.call ByteArray.push
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.call ByteArray.get
    x86.xor rcx, rcx
    x86.mov rbx, 255
    x86.and rcx, rbx
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 1
    x86.call ByteArray.get
    x86.mov rcx, 99
    x86.mov rbx, 255
    x86.and rcx, rbx
    x86.mov [rbp-40], rcx
    x86.mov [rbp-48], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_7
  otherwise_default_error_6:
    x86.mov rax, [rbp-40]
    x86.mov [rbp-48], rax
    x86.jmp main.otherwise_default_continue_7
  otherwise_default_continue_7:
    x86.mov rax, [rbp-48]
    x86.mov [rbp-56], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 2
    x86.call ByteArray.get
    x86.xor rcx, rcx
    x86.mov rbx, 255
    x86.and rcx, rbx
    x86.mov [rbp-64], rcx
    x86.mov [rbp-72], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_11
  otherwise_default_error_10:
    x86.mov rax, [rbp-64]
    x86.mov [rbp-72], rax
    x86.jmp main.otherwise_default_continue_11
  otherwise_default_continue_11:
    x86.mov rax, [rbp-72]
    x86.mov [rbp-80], rax
    x86.mov rcx, [rbp-32]
    x86.mov rdx, 255
    x86.cmp rcx, rdx
    x86.je main.c0_12.after
  c0_12:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  c0_12.after:
    x86.mov rax, [rbp-56]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.je main.c1_13.after
  c1_13:
    x86.mov rax, [rbp-8]
    x86.test rax, rax

// Test: self-implicit-multiple-fields

typealias Integer = int(i64.min to i64.max)

type Rectangle
	var width Integer
	var height Integer

	function area() returns Integer
		return width * height
	end 'area'
end 'Rectangle'

function main() returns ExitCode
	var r = Rectangle{width: 6, height: 7}
	return r.area()
end 'main'
---
ExitCode: 42
---
module {
  func @Rectangle.area(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+8]
    x86.imul rdx, rbx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 6
    x86.mov rcx, 7
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call Rectangle.area
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.jg main.__range_panic_0
    x86.cmp rax, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

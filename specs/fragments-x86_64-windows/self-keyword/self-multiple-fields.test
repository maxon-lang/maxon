// Test: self-multiple-fields

typealias Integer = int(i64.min to i64.max)

type Point
  var x Integer
  var y Integer

  function sum() returns Integer
    return self.x + self.y
  end 'sum'

  function setX(newX Integer)
    self.x = newX
  end 'setX'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 10, y: 32}
  return p.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Point.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+8]
    x86.lea rax, [rdx + rbx]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 32
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call Point.sum
    x86.xor rsi, rsi
    x86.cmp rax, rsi
    x86.setl rdi
    x86.movzx rdi, rdib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or rdi, r9
    x86.test rdi, rdi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

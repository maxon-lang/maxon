// Test: f32-arithmetic
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	var a = F{10.0}
	var b = F{3.0}
	var sum = a + b
	var diff = a - b
	var prod = a * b
	var quot = a / b
	return trunc(sum + diff + prod + quot)
end 'main'
---
ExitCode: 53
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_10]
    x86.movsd xmm1, [rip+__float_3]
    x86.movsd xmm2, xmm0
    x86.addsd xmm2, xmm1
    x86.movsd xmm3, xmm0
    x86.subsd xmm3, xmm1
    x86.movsd xmm4, xmm0
    x86.mulsd xmm4, xmm1
    x86.movsd xmm5, xmm0
    x86.divsd xmm5, xmm1
    x86.movsd xmm6, xmm2
    x86.addsd xmm6, xmm3
    x86.movsd xmm7, xmm6
    x86.addsd xmm7, xmm4
    x86.movsd xmm8, xmm7
    x86.addsd xmm8, xmm5
    x86.cvttsd2si rax, xmm8
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: float-range
typealias Pct = float(0.0 to 100.0)

function main() returns ExitCode
	var p = Pct{75.5}
	return trunc(p)
end 'main'
---
ExitCode: 75
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_75.5]
    x86.cvttsd2si rax, xmm0
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

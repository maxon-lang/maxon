// Test: range-id-comparison
function main() returns ExitCode
	var x = i32.max
	if x == 2147483647 'isMax'
		return 1
	end 'isMax'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 2147483647
    x86.mov rcx, 2147483647
    x86.cmp rax, rcx
    x86.jne main.isMax_0.after
  isMax_0:
    x86.mov rax, 1
    x86.ret
  isMax_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

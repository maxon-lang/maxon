// Test: runtime-check-pass
typealias Integer = int(i64.min to i64.max)
typealias Age = int(0 to 150)

function makeAge(n Integer) returns Integer
	var a = Age{n}
	return a
end 'makeAge'

function main() returns ExitCode
	return makeAge(50)
end 'main'
---
ExitCode: 50
---
module {
  func @ranged-typealias.makeAge(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov rdx, 150
    x86.cmp rcx, rdx
    x86.jg ranged-typealias.makeAge.__range_panic_0
    x86.cmp rcx, rax
    x86.jl ranged-typealias.makeAge.__range_panic_0
    x86.jmp ranged-typealias.makeAge.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 50
    x86.call ranged-typealias.makeAge
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

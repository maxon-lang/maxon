// Test: f32-comparison
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	var a = F{3.0}
	var b = F{5.0}
	if a < b 'less'
		return 1
	end 'less'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_3]
    x86.movsd xmm1, [rip+__float_5]
    x86.ucomisd xmm0, xmm1
    x86.jp main.less_0.after
    x86.jae main.less_0.after
  less_0:
    x86.mov rax, 1
    x86.ret
  less_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

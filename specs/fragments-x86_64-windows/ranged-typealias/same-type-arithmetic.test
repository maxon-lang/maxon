// Test: same-type-arithmetic
typealias Score = int(0 to 100)

function main() returns ExitCode
	var a = Score{30}
	var b = Score{12}
	return a + b
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 30
    x86.mov rcx, 12
    x86.mov edx, eax
    x86.mov ebx, ecx
    x86.add rdx, rbx
    x86.xor rsi, rsi
    x86.mov edi, rdx
    x86.mov r8, 4294967295
    x86.mov r9, rdx
    x86.cmp r9, r8
    x86.jg main.__range_panic_0
    x86.cmp rdi, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

// Test: range-id-arithmetic
function main() returns ExitCode
	var x = u8.max + 1
	return x - 206
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 255
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, 206
    x86.sub rax, rdx
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: bitwise-xor-precedence
function main() returns ExitCode
	// and has higher precedence than xor
	// 12 and 10 = 8, then 8 xor 3 = 11
	return 12 and 10 xor 3
end 'main'
---
ExitCode: 11
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 12
    x86.mov rcx, 10
    x86.and rax, rcx
    x86.mov rdx, 3
    x86.xor rax, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

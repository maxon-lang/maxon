// Test: bitwise-not-masking
function main() returns ExitCode
	var value = 255    // 0xFF
	// Clear lower 4 bits: 255 and not 15 = 240
	return value and not 15
end 'main'
---
ExitCode: 240
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 255
    x86.mov rcx, 15
    x86.mov rdx, -1
    x86.xor rcx, rdx
    x86.and rax, rcx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

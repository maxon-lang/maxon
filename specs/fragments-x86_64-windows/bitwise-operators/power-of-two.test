// Test: power-of-two
function main() returns ExitCode
	// Calculate 2^n using shift
	var n = 5
	return 1 shl n        // 32
end 'main'
---
ExitCode: 32
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov rcx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.shl rdx, cl
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

// Test: multiply-by-power-of-two
function main() returns ExitCode
  // Multiply by 8 using shift
  var value = 25
  return value shl 3    // 200
end 'main'
---
ExitCode: 200
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 25
    x86.mov rcx, 3
    x86.mov rdx, rax
    x86.shl rdx, cl
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

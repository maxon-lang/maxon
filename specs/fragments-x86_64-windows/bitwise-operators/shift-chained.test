// Test: shift-chained
function main() returns ExitCode
  var a = 1
  return a shl 4 shr 2
end 'main'
---
ExitCode: 4
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov rcx, 4
    x86.mov rdx, rax
    x86.shl rdx, cl
    x86.mov rbx, 2
    x86.mov rcx, rbx
    x86.mov rsi, rdx
    x86.shr rsi, cl
    x86.xor rdi, rdi
    x86.cmp rsi, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rsi, r9
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r8, rax
    x86.test r8, r8
    x86.je bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rsi
    x86.epilogue
    x86.ret
  }
}
---

// Test: divide-by-power-of-two
function main() returns ExitCode
	// Divide by 4 using shift
	var value = 100
	return value shr 2    // 25
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 100
    x86.mov rcx, 2
    x86.mov rdx, rax
    x86.shr rdx, cl
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

// Test: bitwise-with-logical
function main() returns ExitCode
  var a = 5 and 3        // 1
  if a > 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.mov rcx, 3
    x86.and rax, rcx
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.jle main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

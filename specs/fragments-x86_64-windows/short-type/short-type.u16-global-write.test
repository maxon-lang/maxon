// Test: short-type.u16-global-write
typealias U16 = int(0 to 65535)

var counter = U16{0}

function main() returns ExitCode
  counter = U16{99}
  return counter
end 'main'
---
ExitCode: 99
---
module {
  func @short-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 99
    x86.mov word [rip+counter], rax
    x86.movzx rcx, word [rip+counter]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je short-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

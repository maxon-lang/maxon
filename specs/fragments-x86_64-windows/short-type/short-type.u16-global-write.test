// Test: short-type.u16-global-write
typealias U16 = int(0 to 65535)

var counter = U16{0}

function main() returns ExitCode
	counter = U16{99}
	return counter
end 'main'
---
ExitCode: 99
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 99
    x86.mov word [rip+counter], rax
    x86.movzx rcx, word [rip+counter]
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: short-type.u16-global
typealias U16 = int(0 to 65535)

var counter = U16{42}

function main() returns ExitCode
  return counter
end 'main'
---
ExitCode: 42
RequiredData: ```
u16 42
```
---
module {
  func @short-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16

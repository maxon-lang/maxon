// Test: short-type.u16-global
typealias U16 = int(0 to 65535)

var counter = U16{42}

function main() returns ExitCode
	return counter
end 'main'
---
ExitCode: 42
RequiredData: ```
u16 42
```
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movzx rax, word [rip+counter]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

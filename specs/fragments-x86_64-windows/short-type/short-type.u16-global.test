    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je short-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_6]

// Test: module-struct-nested-field-assign
typealias SmallInt = int(0 to u8.max)

type Inner
		export var x SmallInt
end 'Inner'

type Outer
		export var inner Inner
end 'Outer'

var state = Outer{inner: Inner{x: 0}}

function main() returns ExitCode
		state.inner.x = 99
		return state.inner.x
end 'main'

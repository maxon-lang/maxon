// Test: int-promotion
function main() returns ExitCode
	var result = Math.pow(3, exponent: 2)  // Ints promoted to float
	return trunc(result)
end 'main'
---
ExitCode: 9
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 3
    x86.mov rcx, 2
    x86.cvtsi2sd xmm0, rax
    x86.cvtsi2sd xmm1, rcx
    x86.call stdlib.Math.pow
    x86.cvttsd2si rdx, xmm0
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

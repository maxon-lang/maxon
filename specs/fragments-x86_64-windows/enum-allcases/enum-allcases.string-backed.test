// Test: enum-allcases.string-backed
enum ContentType
  json = "application/json"
  html = "text/html"
  plain = "text/plain"
end 'ContentType'

function main() returns ExitCode
  for ct in ContentType.allCases 'loop'
    print("{ct.rawValue}\n")
  end 'loop'
  return 0
end 'main'

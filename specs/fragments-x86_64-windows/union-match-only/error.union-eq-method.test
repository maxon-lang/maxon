// Test: error.union-eq-method
union Toggle
	on
	off

	function isOn() returns bool
		if self == Toggle.on 'check'
			return true
		end 'check'
		return false
	end 'isOn'
end 'Toggle'

function main() returns ExitCode
	let t = Toggle.on
	if t.isOn() 'test'
		return 1
	end 'test'
	return 0
end 'main'
---

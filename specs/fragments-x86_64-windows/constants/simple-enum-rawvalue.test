// Test: simple-enum-rawvalue
enum Direction
	north
	south
	east
end 'Direction'

function main() returns ExitCode
	var d = Direction.south
	return d.rawValue
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

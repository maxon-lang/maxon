// Test: float-rawvalue-in-function

typealias Float = float(f64.min to f64.max)

enum Weights
	light = 1.5
	medium = 2.5
end 'Weights'

function getRaw(w Weights) returns Float
	return w.rawValue
end 'getRaw'

function main() returns ExitCode
	var w = Weights.medium
	var raw = getRaw(w)
	if raw > 2.0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getRaw(w: f64) -> f64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rbp-8]
    x86.movsd xmm0, xmm1
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rbp-8]
    x86.movsd xmm0, xmm1
    x86.call constants.getRaw
    x86.movsd xmm2, [rip+__float_2]
    x86.ucomisd xmm0, xmm2
    x86.jbe main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

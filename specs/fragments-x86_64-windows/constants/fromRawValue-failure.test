// Test: fromRawValue-failure

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode() returns Integer
  return 999
end 'getCode'

function main() returns ExitCode
  var code = getCode()
  var status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
  if status == HttpStatus.ok 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getCode() -> i64 {
  entry:
    x86.mov rax, 999
    x86.ret
  }
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call constants.getCode
    x86.mov rcx, 1
    x86.xor rdx, rdx
    x86.mov rbx, 200
    x86.cmp rax, rbx
    x86.sete rbx
    x86.movzx rbx, rbxb
    x86.xor rsi, rsi
    x86.test rbx, rbx
    x86.mov rdi, rcx
    x86.cmovne rdi, rsi
    x86.mov rcx, 200
    x86.test rbx, rbx
    x86.mov rsi, rdx
    x86.cmovne rsi, rcx
    x86.mov rcx, 404
    x86.cmp rax, rcx
    x86.sete rax
    x86.movzx rax, raxb
    x86.xor rcx, rcx
    x86.test rax, rax
    x86.mov rdx, rdi
    x86.cmovne rdx, rcx
    x86.mov rbx, 404
    x86.test rax, rax
    x86.mov rcx, rsi
    x86.cmovne rcx, rbx
    x86.mov rsi, 200
    x86.mov [rbp-8], rsi
    x86.mov [rbp-16], rcx
    x86.xor rdi, rdi
    x86.cmp rdx, rdi
    x86.je constants.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.jmp constants.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.mov rcx, 200
    x86.mov rdx, [rbp-24]
    x86.cmp rdx, rcx
    x86.jne constants.main.check_4.after
  check_4:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

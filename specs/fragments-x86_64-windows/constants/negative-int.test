// Test: negative-int
enum Temperature
	freezing = 0
	cold = -10
	warm = 25
end 'Temperature'

function main() returns ExitCode
	var result = match Temperature.warm 'check'
		freezing gives 0
		cold gives -10
		warm gives 25
	end 'check'
	return result
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 25
    x86.xor rcx, rcx
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-16]
    x86.mov rcx, -10
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp2
  check_0.case1:
    x86.mov rax, -10
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.cmp2:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 25
    x86.cmp rax, rcx
    x86.jne main.check_0.merge
  check_0.case2:
    x86.mov rax, 25
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_1
    x86.cmp rax, rcx
    x86.jl main.__range_panic_1
    x86.jmp main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

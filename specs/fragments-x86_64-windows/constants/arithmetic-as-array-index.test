// Test: arithmetic-as-array-index
enum Slot
	a
	b
	c
end 'Slot'

let NUM_SLOTS = 3

function main() returns ExitCode
	let idx = Slot.b * NUM_SLOTS + Slot.a
	return idx
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov rcx, 3
    x86.imul rax, rcx
    x86.xor rdx, rdx
    x86.add rax, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

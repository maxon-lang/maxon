// Test: int-rawvalue-in-function

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns Integer
  return s.rawValue
end 'getCode'

function main() returns ExitCode
  var status = HttpStatus.notFound
  var code = getCode(status)
  if code == 404 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getCode(s: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 404
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call constants.getCode
    x86.mov rdx, 404
    x86.cmp rax, rdx
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

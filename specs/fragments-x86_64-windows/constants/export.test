// Test: export
// --- file: defs.maxon
export enum Permission
  none = 0
  read = 1
  write = 2
end 'Permission'

// --- file: main.maxon
function main() returns ExitCode
  var p = Permission.read
  if p == Permission.read 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov rdx, [rbp-8]
    x86.cmp rdx, rcx
    x86.jne main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

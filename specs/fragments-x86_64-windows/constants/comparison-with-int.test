// Test: comparison-with-int
enum State
	idle
	running
	done
end 'State'

function main() returns ExitCode
	var s = State.running
	if s >= State.idle and s <= State.done 'inRange'
		return 1
	end 'inRange'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov rdx, [rbp-8]
    x86.cmp rdx, rcx
    x86.setge rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 2
    x86.mov rdi, [rbp-8]
    x86.cmp rdi, rsi
    x86.setle r8
    x86.movzx r8, r8b
    x86.and rbx, r8
    x86.test rbx, rbx
    x86.je main.inRange_0.after
  inRange_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  inRange_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

// Test: auto-increment
enum Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = Color.blue
  var result = match c 'check'
    Color.red gives 10
    Color.green gives 20
    Color.blue gives 30
  end 'check'
  return result
end 'main'
---
ExitCode: 30
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rcx
    x86.jmp constants.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.cmp2
  check_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.cmp2:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.merge
  check_0.case2:
    x86.mov rax, 30
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je constants.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

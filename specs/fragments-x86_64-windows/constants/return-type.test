// Test: return-type
enum Result
  success
  failure
end 'Result'

function getResult(succeed bool) returns Result
  if succeed 'check'
    return Result.success
  end 'check'
  return Result.failure
end 'getResult'

function main() returns ExitCode
  var r = getResult(true)
  if r == Result.success 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getResult(succeed: i1) -> i64 {
  entry:
    x86.test rcx, rcx
    x86.je constants.getResult.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.call constants.getResult
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne main.test_0.after
  test_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

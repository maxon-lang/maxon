// Test: fromRawValue-simple
enum Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = try Color.fromRawValue(1) otherwise Color.red
  if c == Color.green 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov rcx, 1
    x86.xor rdx, rdx
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.sete rsi
    x86.movzx rsi, rsib
    x86.xor rdi, rdi
    x86.test rsi, rsi
    x86.mov r8, rcx
    x86.cmovne r8, rdi
    x86.xor r9, r9
    x86.test rsi, rsi
    x86.mov rcx, rdx
    x86.cmovne rcx, r9
    x86.mov rdx, 1
    x86.cmp rax, rdx
    x86.sete rdx
    x86.movzx rdx, rdxb
    x86.xor rbx, rbx
    x86.test rdx, rdx
    x86.mov rsi, r8
    x86.cmovne rsi, rbx
    x86.mov rbx, 1
    x86.test rdx, rdx
    x86.mov rdi, rcx
    x86.cmovne rdi, rbx
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.sete rax
    x86.movzx rax, raxb
    x86.xor rcx, rcx
    x86.test rax, rax
    x86.mov rdx, rsi
    x86.cmovne rdx, rcx
    x86.mov rcx, 2
    x86.test rax, rax
    x86.mov rbx, rdi
    x86.cmovne rbx, rcx
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov [rbp-16], rbx
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.mov rcx, 1
    x86.mov rdx, [rbp-24]
    x86.cmp rdx, rcx
    x86.jne main.check_4.after
  check_4:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

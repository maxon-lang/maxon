// Test: fromRawValue-float-backed
enum Weights
  light = 1.5
  medium = 2.5
  heavy = 3.5
end 'Weights'

function main() returns ExitCode
  var w = try Weights.fromRawValue(2.5) otherwise Weights.light
  if w == Weights.medium 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov rax, 1
    x86.movsd xmm1, [rip+__float_1.5]
    x86.ucomisd xmm0, xmm1
    x86.sete rcx
    x86.movzx rcx, rcxb
    x86.setnp rdx
    x86.movzx rdx, rdxb
    x86.and rcx, rdx
    x86.xor rbx, rbx
    x86.test rcx, rcx
    x86.mov rsi, rax
    x86.cmovne rsi, rbx
    x86.movsd xmm2, [rip+__float_2.5]
    x86.ucomisd xmm0, xmm2
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.setnp r8
    x86.movzx r8, r8b
    x86.and rdi, r8
    x86.xor r9, r9
    x86.test rdi, rdi
    x86.mov rax, rsi
    x86.cmovne rax, r9
    x86.movsd xmm3, [rip+__float_3.5]
    x86.ucomisd xmm0, xmm3
    x86.sete rcx
    x86.movzx rcx, rcxb
    x86.setnp rdx
    x86.movzx rdx, rdxb
    x86.and rcx, rdx
    x86.xor rdx, rdx
    x86.test rcx, rcx
    x86.mov rbx, rax
    x86.cmovne rbx, rdx
    x86.movsd xmm4, [rip+__float_1.5]
    x86.movsd [rbp-8], xmm4
    x86.movsd [rbp-16], xmm0
    x86.xor rax, rax
    x86.cmp rbx, rax
    x86.je constants.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.movsd xmm0, [rbp-8]
    x86.movsd [rbp-16], xmm0
    x86.jmp constants.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.movsd xmm0, [rbp-16]
    x86.movsd [rbp-24], xmm0
    x86.movsd xmm1, [rip+__float_2.5]
    x86.movsd xmm2, [rbp-24]
    x86.ucomisd xmm2, xmm1
    x86.jne constants.main.check_4.after
    x86.jp constants.main.check_4.after
  check_4:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

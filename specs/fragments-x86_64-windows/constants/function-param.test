// Test: function-param
enum Status
  on
  off
end 'Status'

function isOn(s Status) returns bool
  if s == Status.on 'check'
    return true
  end 'check'
  return false
end 'isOn'

function main() returns ExitCode
  var status = Status.on
  if isOn(status) 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.isOn(s: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.xor rax, rax
    x86.mov rdx, [rbp-8]
    x86.cmp rdx, rax
    x86.jne constants.isOn.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call constants.isOn
    x86.test rax, rax
    x86.je constants.main.test_0.after
  test_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

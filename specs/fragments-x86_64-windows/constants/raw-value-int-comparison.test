// Test: raw-value-int-comparison
enum Priority
	low = 1
	medium = 5
	high = 10
end 'Priority'

function main() returns ExitCode
	var p = Priority.high
	if p.rawValue > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 5
    x86.cmp rcx, rdx
    x86.jle main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

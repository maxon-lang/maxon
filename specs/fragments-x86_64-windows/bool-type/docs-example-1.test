// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function isPositive(x Score) returns bool
	if x > 0 'check'
		return true
	end 'check'
	return false
end 'isPositive'

function main() returns ExitCode
	if isPositive(5) 'test'
		return 1
	end 'test'
	return 0
end 'main'

---
ExitCode: 1
---
module {
  func @bool-type.isPositive(x: i64) -> i1 {
  entry:
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.jle bool-type.isPositive.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call bool-type.isPositive
    x86.test rax, rax
    x86.je main.test_0.after
  test_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

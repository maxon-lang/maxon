// Test: bool-from-comparison
function main() returns ExitCode
  var result = 5 > 3
  if result 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @bool-type.main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jle bool-type.main.check_0.after
  check_0:
    x86.mov rax, 42
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

// Test: keyword-as-case-name
union TokenType
	function
	return
	end
	if
	else
	let
	var
	identifier
end 'TokenType'

function main() returns ExitCode
	var t = TokenType.function
	var result = match t 'check'
		function gives 1
		return gives 0
		end gives 0
		if gives 0
		else gives 0
		let gives 0
		var gives 0
		identifier gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rcx
    x86.mov rbx, [rbp-24]
    x86.jump_table rbx, 8 cases, default=main.check_0.merge
  check_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case1:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case2:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case3:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case4:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case5:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case6:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.case7:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

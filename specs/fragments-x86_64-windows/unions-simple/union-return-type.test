// Test: union-return-type
union Result
  success
  failure
end 'Result'

function getResult(succeed bool) returns Result
  if succeed 'check'
    return Result.success
  end 'check'
  return Result.failure
end 'getResult'

function main() returns ExitCode
  var r = getResult(true)
  var result = match r 'handle'
    Result.success gives 1
    Result.failure gives 0
  end 'handle'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @unions-simple.getResult(succeed: i1) -> i64 {
  entry:
    x86.test rcx, rcx
    x86.je unions-simple.getResult.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
  func @unions-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 1
    x86.call unions-simple.getResult
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.mov [rbp-24], rax
    x86.jmp unions-simple.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne unions-simple.main.handle_0.cmp1
  handle_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp unions-simple.main.handle_0.merge
  handle_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne unions-simple.main.handle_0.merge
  handle_0.case1:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp unions-simple.main.handle_0.merge
  handle_0.merge:
    x86.mov rax, [rbp-16]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je unions-simple.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

// Test: associated-value-construction

typealias Integer = int(i64.min to i64.max)

union Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	var c = Container.value(42)
	match c 'check'
		value(_) then return 1
		empty then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov [rax+0], rcx
    x86.mov rdx, 42
    x86.mov [rax+8], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, [rbp-8]
    x86.mov rdi, [rsi+0]
    x86.mov r8, [rbp-8]
    x86.mov [rbp-16], r8
    x86.mov r9, [rbp-16]
    x86.mov [rbp-32], rdi
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-32]
    x86.mov [rbp-24], rax
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_0.cmp1
  check_0.case0:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_0.merge
  check_0.case1:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
  func @__destruct_Container(ptr: i64) {
  entry:
    x86.jmp __destruct_Container.done
  done:
    x86.ret
  }
}
---

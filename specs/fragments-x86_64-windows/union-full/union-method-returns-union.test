    x86.mov [rbp-24], rax
    x86.jmp Toggle.flip.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne Toggle.flip.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp Toggle.flip.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne Toggle.flip.check_0.merge
  check_0.case1:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp Toggle.flip.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-32], rax
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @union-full.main() -> u32 {

// Test: match-expr-union-binding

typealias Integer = int(i64.min to i64.max)

union Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.value(10)
  var result = match c 'get'
    empty gives 0
    value(n) gives n * 2
  end 'get'
  return result
end 'main'
---
ExitCode: 20
---

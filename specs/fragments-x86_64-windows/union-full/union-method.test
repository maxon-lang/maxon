// Test: union-method
union Direction
  north
  south

  function isNorth() returns bool
    var result = match self 'check'
      north gives true
      south gives false
    end 'check'
    return result
  end 'isNorth'
end 'Direction'

function main() returns ExitCode
  let d = Direction.north
  if d.isNorth() 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @Direction.isNorth(self: i64) -> i1 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.xor rdx, rdx
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rax
    x86.jmp Direction.isNorth.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne Direction.isNorth.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp Direction.isNorth.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne Direction.isNorth.check_0.merge
  check_0.case1:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp Direction.isNorth.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @union-full.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call Direction.isNorth
    x86.test rax, rax
    x86.je union-full.main.test_0.after
  test_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

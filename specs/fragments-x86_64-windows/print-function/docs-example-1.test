// Test: docs-example-1
function main() returns ExitCode
	var x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=112
    x86.lea rax, [rip+__str_2]
    x86.lea rcx, [rip+__str_1]
    x86.lea rdx, [rip+__str_0]
    x86.mov [rbp+-32], rcx
    x86.mov rcx, 42
    x86.mov [rbp+-40], rax
    x86.mov [rbp+-48], rdx
    x86.call mrt_printInt
    x86.mov rbx, [rbp+-48]
    x86.mov rcx, rbx
    x86.mov rdx, 1
    x86.mov [rbp+-56], rax
    x86.call mrt_write_stdout
    x86.mov rcx, 15
    x86.mov [rbp+-64], rax
    x86.call mrt_printInt
    x86.mov rsi, [rbp+-32]
    x86.mov rcx, rsi
    x86.mov rdx, 1
    x86.mov [rbp+-72], rax
    x86.call mrt_write_stdout
    x86.mov rcx, 100
    x86.mov [rbp+-80], rax
    x86.call mrt_printInt
    x86.mov rdi, [rbp+-40]
    x86.mov rcx, rdi
    x86.mov rdx, 1
    x86.mov [rbp+-88], rax
    x86.call mrt_write_stdout
    x86.mov [rbp+-96], rax
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  }
}

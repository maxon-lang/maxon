// Test: try-otherwise-error-binding
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.empty()
	arr.resize(2)
	try arr.get(0) otherwise (e) 'handler'
		match e 'check'
			emptySlot then return 42
			indexOutOfBounds then return 99
		end 'check'
	end 'handler'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @Slot.clone(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov [rbp-24], rdx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call SlotArray.empty
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 2
    x86.call SlotArray.resize
    x86.mov rcx, [rbp-8]
    x86.xor rdx, rdx
    x86.call SlotArray.get
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.sub rax, rcx
    x86.mov [rbp-32], rax
    x86.jmp main.check_4.cmp0
  check_4.cmp0:
    x86.mov rax, [rbp-32]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_4.cmp1
  check_4.case0:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 42
    x86.epilogue
    x86.ret
  check_4.cmp1:
    x86.mov rax, [rbp-32]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_4.merge
  check_4.case1:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.mov rax, 99
    x86.epilogue
    x86.ret
  check_4.merge:
  otherwise_continue_1:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_4
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_4
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_5
    x86.call mm_decref
    x86.label __nonnull_skip_5
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct_Slot(ptr: i64) {
  entry:
    x86.jmp __destruct_Slot.done
  done:
    x86.ret
  }
  func @__destruct___ManagedMemory_Slot(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory_Slot.skip_buf_0
  free_buf_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_managed_elements
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rcx+0]
    x86.mov rcx, rdx
    x86.call mm_raw_free
    x86.jmp __destruct___ManagedMemory_Slot.skip_buf_0
  skip_buf_0:
    x86.jmp __destruct___ManagedMemory_Slot.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct_SlotArray(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_6
    x86.call mm_decref
    x86.label __nonnull_skip_6
    x86.jmp __destruct_SlotArray.done
  done:
    x86.epilogue
    x86.ret
  }
}

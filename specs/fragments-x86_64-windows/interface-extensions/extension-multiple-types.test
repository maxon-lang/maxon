// Test: extension-multiple-types

typealias Integer = int(i64.min to i64.max)

interface Valued
  function val() returns Integer
end 'Valued'

extension Valued
  function valPlusTen() returns Integer
    return self.val() + 10
  end 'valPlusTen'
end 'Valued'

type TypeA implements Valued
  var a Integer
  function val() returns Integer
    return a
  end 'val'
end 'TypeA'

type TypeB implements Valued
  var b Integer
  function val() returns Integer
    return b * 2
  end 'val'
end 'TypeB'

function main() returns ExitCode
  var ta = TypeA{a: 5}
  var tb = TypeB{b: 10}
  return ta.valPlusTen() + tb.valPlusTen()
end 'main'
---
ExitCode: 45
---
module {
  func @TypeA.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call TypeA.val
    x86.mov rcx, 10
    x86.add rax, rcx
    x86.epilogue
    x86.ret
  }
  func @TypeB.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call TypeB.val
    x86.mov rcx, 10
    x86.add rax, rcx
    x86.epilogue
    x86.ret
  }
  func @TypeA.val(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @TypeB.val(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 2
    x86.imul rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.mov rcx, 10
    x86.mov [rbp-16], rcx
    x86.lea rdx, [rbp-8]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call TypeA.valPlusTen
    x86.lea rsi, [rbp-16]
    x86.mov rdi, rsi
    x86.mov [rbp-24], rax
    x86.mov rcx, rdi
    x86.call TypeB.valPlusTen
    x86.mov r8, [rbp-24]
    x86.add r8, rax
    x86.xor r9, r9
    x86.cmp r8, r9
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rcx, 4294967295
    x86.cmp r8, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or rax, rcx
    x86.test rax, rax
    x86.je interface-extensions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_50]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:

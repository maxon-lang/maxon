  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov rcx, 32
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call Coord.asSimple
    x86.mov [rbp-24], rax

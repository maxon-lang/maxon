    x86.mov rcx, [rbp-8]
    x86.call Coord.getX
    x86.mov rcx, [rbp-8]
    x86.mov [rbp-24], rax
    x86.call Coord.getY
    x86.mov [rbp-32], rax
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rdx, [rbp-16]
    x86.mov rbx, [rbp-24]
    x86.mov [rdx+0], rbx
    x86.mov rsi, [rbp-16]
    x86.mov rdi, [rbp-32]
    x86.mov [rsi+8], rdi
    x86.mov r8, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @Coord.getX(__self_ptr: i64) -> i64 {

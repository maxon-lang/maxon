// Test: extension-with-params

typealias Integer = int(i64.min to i64.max)

interface Scalable
  function base() returns Integer
end 'Scalable'

extension Scalable
  function scale(factor Integer) returns Integer
    return self.base() * factor
  end 'scale'
end 'Scalable'

type Amount implements Scalable
  var amount Integer

  function base() returns Integer
    return amount
  end 'base'
end 'Amount'

function main() returns ExitCode
  var a = Amount{amount: 7}
  return a.scale(6)
end 'main'
---
ExitCode: 42
---
module {
  func @Amount.scale(__self_ptr: i64, factor: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rdx
    x86.mov rcx, [rbp-8]
    x86.call Amount.base
    x86.mov rcx, [rbp-16]
    x86.imul rax, rcx
    x86.epilogue
    x86.ret
  }
  func @Amount.base(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 7
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.mov rdx, 6
    x86.call Amount.scale
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je interface-extensions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: extension-with-self

typealias Integer = int(i64.min to i64.max)

interface Summable
  function value() returns Integer
end 'Summable'

extension Summable
  function doubled() returns Integer
    return self.value() * 2
  end 'doubled'
end 'Summable'

type Number implements Summable
  var n Integer

  function value() returns Integer
    return n
  end 'value'
end 'Number'

function main() returns ExitCode
  var num = Number{n: 21}
  return num.doubled()
end 'main'
---
ExitCode: 42
---
module {
  func @Number.doubled(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Number.value
    x86.mov rcx, 2
    x86.imul rax, rcx
    x86.epilogue
    x86.ret
  }
  func @Number.value(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 21
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 21
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Number.doubled
    x86.mov [rbp-16], rax
    x86.xor rdi, rdi
    x86.cmp rax, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r8, rax
    x86.test r8, r8
    x86.je interface-extensions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Number(ptr: i64) {
  entry:
    x86.jmp __destruct_Number.done
  done:
    x86.ret
  }
}

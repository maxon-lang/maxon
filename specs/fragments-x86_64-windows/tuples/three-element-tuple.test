// Test: three-element-tuple
function main() returns ExitCode
	var t = (1, 2, 39)
	return t.0 + t.1 + t.2
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.mov rdx, 39
    x86.mov [rbp-24], rax
    x86.mov [rbp-16], rcx
    x86.mov [rbp-8], rdx
    x86.mov rbx, [rbp-24]
    x86.mov rsi, [rbp-16]
    x86.add rbx, rsi
    x86.mov rdi, [rbp-8]
    x86.add rbx, rdi
    x86.xor r8, r8
    x86.cmp rbx, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rbx, rax
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r9, rax
    x86.test r9, r9
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rbx
    x86.epilogue
    x86.ret
  }
}

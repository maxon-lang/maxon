// Test: mixed-type-tuple
function main() returns ExitCode
  var t = (40, 2.5)
  return t.0 + trunc(t.1)
end 'main'
---
ExitCode: 42
---
module {
  func @tuples.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 40
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov [rbp-16], rax
    x86.movsd [rbp-8], xmm0
    x86.mov rcx, [rbp-16]
    x86.movsd xmm1, [rbp-8]
    x86.cvttsd2si rdx, xmm1
    x86.add rcx, rdx
    x86.xor rbx, rbx
    x86.cmp rcx, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rcx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je tuples.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_14]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}

// Test: sqrt.precision
function main() returns ExitCode
	var x = sqrt(2.0)
	// sqrt(2) * sqrt(2) should be approximately 2
	var check = x * x
	// Trunc to get integer 2
	return trunc(check)
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_2]
    x86.sqrtsd xmm1, xmm0
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm1
    x86.cvttsd2si rax, xmm2
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

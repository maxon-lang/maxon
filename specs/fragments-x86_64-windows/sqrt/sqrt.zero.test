// Test: sqrt.zero
function main() returns ExitCode
  var result = sqrt(0.0)
  if result == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.sqrtsd xmm1, xmm0
    x86.movsd xmm2, [rip+__float_0]
    x86.ucomisd xmm1, xmm2
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

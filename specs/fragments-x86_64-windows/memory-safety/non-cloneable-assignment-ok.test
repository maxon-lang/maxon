// Test: non-cloneable-assignment-ok
typealias Integer = int(i64.min to i64.max)

enum Color
	red
	green
	blue
end 'Color'

type Item
	export var color Color
	export var value Integer

	static function create(color Color, value Integer) returns Self
		return Self{color: color, value: value}
	end 'create'
end 'Item'

function main() returns ExitCode
	var a = Item.create(color: Color.red, value: 42)
	var b = a
	b.value = 99
	return a.value
end 'main'
---
ExitCode: 99
---
module {
  func @Item.create(color: i64, value: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rdx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-8]
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-16]
    x86.mov rsi, [rbp-24]
    x86.mov [rbx+8], rsi
    x86.mov rdi, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.mov rdx, 42
    x86.call Item.create
    x86.mov [rbp-8], rax
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rcx, 99
    x86.mov rdx, [rbp-16]
    x86.mov [rdx+8], rcx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbx+8]
    x86.xor rdi, rdi
    x86.mov r8, 4294967295
    x86.cmp rsi, r8
    x86.jg main.__range_panic_0
    x86.cmp rsi, rdi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-24], rsi
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    x86.jmp __destruct_Item.done
  done:
    x86.ret
  }
}
---

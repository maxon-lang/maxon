// Test: auto-equatable
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer
end 'Point'

function main() returns ExitCode
	var a = Point{x: 1, y: 2}
	var b = Point{x: 1, y: 2}
	var c = Point{x: 3, y: 4}
	var result = 0
	if a == b 'eq1'
		result = result + 1
	end 'eq1'
	if a == c 'eq2'
		result = result + 10
	end 'eq2'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov rsi, [rax+0]
    x86.cmp rbx, rsi
    x86.sete rax
    x86.movzx rax, raxb
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbx+8]
    x86.mov rbx, [rbp-16]
    x86.mov rdi, [rbx+8]
    x86.cmp rsi, rdi
    x86.sete rbx
    x86.movzx rbx, rbxb
    x86.and rax, rbx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.mov [rbp-16], rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 1
    x86.mov rbx, 2
    x86.mov [rbp-32], rdx
    x86.mov [rbp-24], rbx
    x86.mov rsi, 3
    x86.mov rdi, 4
    x86.mov [rbp-48], rsi
    x86.mov [rbp-40], rdi
    x86.xor r8, r8
    x86.mov [rbp-56], r8
    x86.lea r9, [rbp-16]
    x86.mov rax, r9
    x86.lea rcx, [rbp-32]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Point.equals
    x86.test rax, rax
    x86.je main.eq1_0.merge
  eq1_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-56]
    x86.add rcx, rax
    x86.mov [rbp-56], rcx
    x86.jmp main.eq1_0.merge
  eq1_0.merge:
    x86.lea rax, [rbp-16]
    x86.mov rcx, rax
    x86.lea rdx, [rbp-48]
    x86.mov rbx, rdx
    x86.mov rdx, rbx
    x86.call Point.equals
    x86.test rax, rax
    x86.je main.eq2_1.merge
  eq2_1:
    x86.mov rax, 10
    x86.mov rcx, [rbp-56]
    x86.add rcx, rax
    x86.mov [rbp-56], rcx
    x86.jmp main.eq2_1.merge
  eq2_1.merge:
    x86.mov rax, [rbp-56]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

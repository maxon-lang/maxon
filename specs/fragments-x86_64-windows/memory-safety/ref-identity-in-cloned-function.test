// Test: ref-identity-in-cloned-function
typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer
end 'Box'

function isSame(a Box, b Box) returns Integer
  if a is b 'same'
    return 1
  end 'same'
  return 0
end 'isSame'

function main() returns ExitCode
  var x = Box{value: 10}
  var y = x
  var z = Box{value: 10}
  var same = isSame(a: x, b: y)
  var diff = isSame(a: x, b: z)
  return same + diff
end 'main'
---
ExitCode: 1
---
module {
  func @memory-safety.isSame(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rbp-16]
    x86.cmp rax, rbx
    x86.jne memory-safety.isSame.same_0.after
  same_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  same_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.mov rcx, 10
    x86.mov [rbp-16], rcx
    x86.lea rdx, [rbp-8]
    x86.mov rbx, rdx
    x86.lea rsi, [rbp-8]
    x86.mov rdi, rsi
    x86.mov rcx, rbx
    x86.mov rdx, rdi
    x86.call memory-safety.isSame
    x86.lea r8, [rbp-8]
    x86.mov r9, r8
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov [rbp-24], rax
    x86.mov rcx, r9
    x86.call memory-safety.isSame
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rax, rdx
    x86.test rax, rax
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: ref-identity-in-cloned-function
typealias Integer = int(i64.min to i64.max)

type Box
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function isSame(a Box, b Box) returns Integer
	if a is b 'same'
		return 1
	end 'same'
	return 0
end 'isSame'

function main() returns ExitCode
	var x = Box.create(value: 10)
	var y = x
	var z = Box.create(value: 10)
	var same = isSame(a: x, b: y)
	var diff = isSame(a: x, b: z)
	return same + diff
end 'main'
---
ExitCode: 1
---
module {
  func @Box.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @memory-safety.isSame(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rbp-16]
    x86.cmp rax, rbx
    x86.jne memory-safety.isSame.same_0.after
  same_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  same_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov rcx, 10
    x86.call Box.create
    x86.mov [rbp-8], rax
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rcx, 10
    x86.call Box.create
    x86.mov [rbp-24], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call memory-safety.isSame
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call memory-safety.isSame
    x86.mov rdi, [rbp-32]
    x86.add rdi, rax
    x86.xor r8, r8
    x86.mov r9, 4294967295
    x86.cmp rdi, r9
    x86.jg main.__range_panic_0
    x86.cmp rdi, r8
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-40], rdi
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-16]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-40]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Box(ptr: i64) {
  entry:
    x86.jmp __destruct_Box.done
  done:
    x86.ret
  }
}
---

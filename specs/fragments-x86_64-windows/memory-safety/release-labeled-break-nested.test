// Test: release-labeled-break-nested
typealias Integer = int(i64.min to i64.max)

type Pair
  export var a Integer
  export var b Integer
end 'Pair'

function main() returns ExitCode
  var result = 0
  var i = 0
  while i < 3 'outer'
    var p = Pair{a: i, b: i * 10}
    var j = 0
    while j < 3 'inner'
      var q = Pair{a: j, b: j * 10}
      if p.a == 1 'check'
        if q.a == 2 'found'
          result = p.b + q.b
          break 'outer'
        end 'found'
      end 'check'
      j = j + 1
    end 'inner'
    i = i + 1
  end 'outer'
  return result
end 'main'
---
ExitCode: 30
---
module {
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp memory-safety.main.outer_0.header
  outer_0.header:
    x86.mov rax, 3
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge memory-safety.main.outer_0.exit
  outer_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 10
    x86.mov rdx, [rbp-16]
    x86.imul rdx, rcx
    x86.mov [rbp-32], rax
    x86.mov [rbp-24], rdx
    x86.xor rbx, rbx
    x86.mov [rbp-40], rbx
    x86.jmp memory-safety.main.inner_1.header
  inner_1.header:
    x86.mov rax, 3
    x86.mov rcx, [rbp-40]
    x86.cmp rcx, rax
    x86.jge memory-safety.main.inner_1.exit
  inner_1:
    x86.mov rax, [rbp-40]
    x86.mov rcx, 10
    x86.mov rdx, [rbp-40]
    x86.imul rdx, rcx
    x86.mov [rbp-56], rax
    x86.mov [rbp-48], rdx
    x86.mov rbx, [rbp-32]
    x86.mov rsi, 1
    x86.cmp rbx, rsi
    x86.jne memory-safety.main.check_2.merge
  check_2:
    x86.mov rax, [rbp-56]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne memory-safety.main.found_3.after
  found_3:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-48]
    x86.add rax, rcx
    x86.mov [rbp-8], rax
    x86.jmp memory-safety.main.outer_0.exit
  found_3.after:
    x86.jmp memory-safety.main.check_2.merge
  check_2.merge:
    x86.mov rax, 1
    x86.mov rcx, [rbp-40]
    x86.add rcx, rax
    x86.mov [rbp-40], rcx
    x86.jmp memory-safety.main.inner_1.header
  inner_1.exit:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.jmp memory-safety.main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je memory-safety.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_58]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}

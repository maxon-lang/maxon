// Test: release-on-error-propagation-in-block
typealias Integer = int(i64.min to i64.max)

type Wrapper
  export var val Integer
end 'Wrapper'

enum LookupError
  case missing
end 'LookupError'

function failingLookup() returns Integer throws LookupError
  throw LookupError.missing
end 'failingLookup'

function compute(flag Integer) returns Integer throws LookupError
  var w = Wrapper{val: flag}
  if w.val > 0 'positive'
    var inner = Wrapper{val: w.val * 2}
    var result = try failingLookup()
    return result + inner.val
  end 'positive'
  return 0
end 'compute'

function main() returns ExitCode
  var result = try compute(flag: 5) otherwise 'err'
    return 77
  end 'err'
  return result
end 'main'
---
ExitCode: 77
---
module {
  func @memory-safety.failingLookup() -> i64 {
  entry:
    x86.mov rax, 1
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  }
  func @memory-safety.compute(flag: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jle memory-safety.compute.positive_0.after
  positive_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.imul rax, rcx
    x86.mov [rbp-16], rax
    x86.call memory-safety.failingLookup
    x86.mov [rbp-24], rdx
    x86.mov [rbp-32], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je memory-safety.compute.try_continue_2
  propagate_error_1:
    x86.mov rdx, [rbp-24]
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  try_continue_2:
    x86.mov rax, [rbp-32]
    x86.mov rcx, [rbp-16]
    x86.add rax, rcx
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  positive_0.after:
    x86.xor rax, rax
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  }
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call memory-safety.compute
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je memory-safety.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 77
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je memory-safety.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_53]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: release-on-error-propagation
typealias Integer = int(i64.min to i64.max)

type Resource
  export var id Integer
end 'Resource'

enum ResourceError
  case notFound
end 'ResourceError'

function loadResource() returns Resource throws ResourceError
  throw ResourceError.notFound
end 'loadResource'

function process() returns Integer throws ResourceError
  @heap var marker = Resource{id: 42}
  var res = try loadResource()
  return res.id + marker.id
end 'process'

function main() returns ExitCode
  var result = try process() otherwise 'err'
    return 99
  end 'err'
  return result
end 'main'
---
ExitCode: 99
---
module {
  func @memory-safety.loadResource() -> i64 {
  entry:
    x86.mov rax, 1
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  }
  func @memory-safety.process() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov rax, 42
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 42
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.call memory-safety.loadResource
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rax
    x86.xor rsi, rsi
    x86.cmp rdx, rsi
    x86.je memory-safety.process.try_continue_1
  propagate_error_0:
    x86.mov rdx, [rbp-16]
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-16]
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  try_continue_1:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-32]
    x86.call mm_incref
    x86.mov rdx, [rbp-32]
    x86.mov rbx, [rdx+0]
    x86.mov rsi, [rbp-8]
    x86.mov rdi, [rsi+0]
    x86.add rbx, rdi
    x86.mov r8, [rbp-24]
    x86.mov [rbp-40], rbx
    x86.test r8, r8
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov r9, [rbp-32]
    x86.test r9, r9
    x86.jz __nonnull_skip_3
    x86.mov rcx, [rbp-32]
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_4
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_4
    x86.mov rax, [rbp-40]
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call memory-safety.process
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 99
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue

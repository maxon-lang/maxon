// Test: break.labeled-break-outer
function main() returns ExitCode
	var x = 0
	while x < 10 'outer'
		x = x + 1
		while true 'inner'
			if x == 3 'check'
				break 'outer'
			end 'check'
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov rax, 10
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jge main.outer_0.exit
  outer_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp main.inner_1.header
  inner_1.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.inner_1.exit
  inner_1:
    x86.mov rax, 3
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne main.check_2.after
  check_2:
    x86.jmp main.outer_0.exit
  check_2.after:
    x86.jmp main.inner_1.exit
  inner_1.exit:
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-break-triple-nested
function main() returns ExitCode
  var result = 0
  while true 'outer'
    while true 'middle'
      while true 'inner'
        result = result + 1
        if result == 5 'check'
          break 'outer'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return result
end 'main'
---
ExitCode: 5
---
module {
  func @break.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je break.main.outer_0.exit
  outer_0:
    x86.jmp break.main.middle_1.header
  middle_1.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je break.main.middle_1.exit
  middle_1:
    x86.jmp break.main.inner_2.header
  inner_2.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je break.main.inner_2.exit
  inner_2:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 5
    x86.cmp rcx, rdx
    x86.jne break.main.check_3.after
  check_3:
    x86.jmp break.main.outer_0.exit
  check_3.after:
    x86.jmp break.main.inner_2.header
  inner_2.exit:
    x86.jmp break.main.middle_1.header
  middle_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je break.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-break-triple-nested
function main() returns ExitCode
	var result = 0
	while true 'outer'
		while true 'middle'
			while true 'inner'
				result = result + 1
				if result == 5 'check'
					break 'outer'
				end 'check'
			end 'inner'
		end 'middle'
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.outer_0.exit
  outer_0:
    x86.jmp main.middle_1.header
  middle_1.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.middle_1.exit
  middle_1:
    x86.jmp main.inner_2.header
  inner_2.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.inner_2.exit
  inner_2:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 5
    x86.cmp rcx, rdx
    x86.jne main.check_3.after
  check_3:
    x86.jmp main.outer_0.exit
  check_3.after:
    x86.jmp main.inner_2.header
  inner_2.exit:
    x86.jmp main.middle_1.header
  middle_1.exit:
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_4
    x86.cmp rax, rcx
    x86.jl main.__range_panic_4
    x86.jmp main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-continue-triple-nested
function main() returns ExitCode
  var count = 0
  var a = 0
  while a < 2 'outer'
    a = a + 1
    var b = 0
    while b < 3 'middle'
      b = b + 1
      var c = 0
      while c < 4 'inner'
        c = c + 1
        count = count + 1
        if c == 2 'check'
          continue 'middle'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return count
end 'main'
---
ExitCode: 12
---
module {
  func @break.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov rax, 2
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.xor rdx, rdx
    x86.mov [rbp-24], rdx
    x86.jmp break.main.middle_1.header
  middle_1.header:
    x86.mov rax, 3
    x86.mov rcx, [rbp-24]
    x86.cmp rcx, rax
    x86.jge break.main.middle_1.exit
  middle_1:
    x86.mov rax, 1
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.xor rdx, rdx
    x86.mov [rbp-32], rdx
    x86.jmp break.main.inner_2.header
  inner_2.header:
    x86.mov rax, 4
    x86.mov rcx, [rbp-32]
    x86.cmp rcx, rax
    x86.jge break.main.inner_2.exit
  inner_2:
    x86.mov rax, 1
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.mov [rbp-32], rcx
    x86.mov rdx, 1
    x86.mov rbx, [rbp-8]
    x86.add rbx, rdx
    x86.mov [rbp-8], rbx
    x86.mov rsi, 2
    x86.cmp rcx, rsi
    x86.jne break.main.check_3.after
  check_3:
    x86.jmp break.main.middle_1.header
  check_3.after:
    x86.jmp break.main.inner_2.header
  inner_2.exit:
    x86.jmp break.main.middle_1.header
  middle_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je break.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_33]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}

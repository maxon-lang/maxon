// Test: break.labeled-break-inner
function main() returns ExitCode
	var x = 0
	var y = 0
	while x < 5 'outer'
		x = x + 1
		while y < 10 'inner'
			y = y + 1
			if y == 3 'check'
				break
			end 'check'
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jge main.outer_0.exit
  outer_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp main.inner_1.header
  inner_1.header:
    x86.mov rax, 10
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge main.inner_1.exit
  inner_1:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.mov rdx, 3
    x86.cmp rcx, rdx
    x86.jne main.check_2.after
  check_2:
    x86.jmp main.inner_1.exit
  check_2.after:
    x86.jmp main.inner_1.header
  inner_1.exit:
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_3
    x86.cmp rax, rcx
    x86.jl main.__range_panic_3
    x86.jmp main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  }
}
---

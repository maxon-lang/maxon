// Test: sizeof.type-parameter
typealias Integer = int(i64.min to i64.max)

type Sizer uses T
	export var dummy T

	export static function create(dummy T) returns Self
		return Self{dummy: dummy}
	end 'create'

	export function typeSize() returns Integer
		return sizeof(T)
	end 'typeSize'
end 'Sizer'

typealias BoolSizer = Sizer with bool

function main() returns ExitCode
	var s = BoolSizer.create(dummy: false)
	return s.typeSize()
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call BoolSizer.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call BoolSizer.typeSize
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-8]
    x86.mov [rbp-16], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @BoolSizer.create(dummy: i1) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov byte ptr [rax+0], rcxb
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @BoolSizer.typeSize(__self_ptr: i64) -> i64 {
  entry:
    x86.mov rax, 1
    x86.ret
  }
  func @__destruct_BoolSizer(ptr: i64) {
  entry:
    x86.jmp __destruct_BoolSizer.done
  done:
    x86.ret
  }
}
---

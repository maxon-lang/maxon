  }
  func @__destruct_Pair(ptr: i64) {
  entry:
    x86.jmp __destruct_Pair.done
  done:
    x86.ret
  }
  func @__destruct_PairSizer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1

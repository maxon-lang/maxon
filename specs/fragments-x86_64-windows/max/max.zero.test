// Test: max.zero
function main() returns ExitCode
	var x = max(0.0, -5.0)
	if x == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_-5]
    x86.movsd xmm2, xmm0
    x86.maxsd xmm2, xmm1
    x86.movsd xmm3, [rip+__float_0]
    x86.ucomisd xmm2, xmm3
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

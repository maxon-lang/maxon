// Test: return-function-call

typealias Integer = int(i64.min to i64.max)

function getValue() returns Integer
	return 42
end 'getValue'

function main() returns ExitCode
	return getValue()
end 'main'
---
ExitCode: 42
---
module {
  func @return-function-call.getValue() -> i64 {
  entry:
    x86.mov rax, 42
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call return-function-call.getValue
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

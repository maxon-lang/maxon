    x86.test rdx, rdx
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.xor rbx, rbx
    x86.mov [rbp-8], rbx
    x86.lea_symdata rsi, [__panic_msg_0]
    x86.mov rdi, rsi
    x86.mov rcx, rdi
    x86.call maxon_panic
  eval_0.merge:

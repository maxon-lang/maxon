    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.mov [rbp-16], rdx
    x86.mov rbx, [rbp-16]
    x86.mov [rbp-40], rcx

    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-32]
    x86.mov rsi, 1
    x86.cmp rbx, rsi
    x86.setle rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.eval_0.cmp1
  eval_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-24], rax
    x86.jmp main.eval_0.merge
  eval_0.cmp1:
    x86.mov rax, [rbp-32]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne main.eval_0.case2
  eval_0.case1:
    x86.mov rax, 2
    x86.mov [rbp-24], rax
    x86.jmp main.eval_0.merge
  eval_0.case2:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx

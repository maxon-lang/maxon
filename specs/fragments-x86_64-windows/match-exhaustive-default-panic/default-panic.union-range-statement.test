// Test: default-panic.union-range-statement
typealias Integer = int(i64.min to i64.max)

union Op
	add
	sub
	mul
	exec(code Integer)
end 'Op'

function main() returns ExitCode
	var op = Op.sub
	match op 'check'
		add to mul then return 1
		default panic("unexpected op")
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov [rax+0], rcx
    x86.xor rcx, rcx
    x86.mov [rax+8], rcx
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.mov [rbp-16], rdx
    x86.mov rbx, [rbp-16]
    x86.mov [rbp-32], rcx
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rsi, [rbp-32]
    x86.mov [rbp-24], rsi
    x86.jmp main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setge rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, [rbp-24]
    x86.mov rsi, 2
    x86.cmp rbx, rsi
    x86.setle rdi
    x86.movzx rdi, rdib
    x86.and rdx, rdi
    x86.test rdx, rdx
    x86.je main.check_0.case1
  check_0.case0:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.lea_symdata rdx, [__panic_msg_0]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call mrt_panic
  check_0.merge:
  }
  func @__destruct_Op(ptr: i64) {
  entry:
    x86.jmp __destruct_Op.done
  done:
    x86.ret
  }
}
---

// Test: ranges.nested-ranges
function main() returns ExitCode
		var sum = 0
		for i in 1 to 3 'outer'
				for j in 1 to 3 'inner'
						sum = sum + i * j
				end 'inner'
		end 'outer'
		return sum
end 'main'
---
ExitCode: 36
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.mov rdx, 3
    x86.mov [rbp-16], rdx
    x86.mov [rbp-24], rcx
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.cmp rax, rcx
    x86.jg main.outer_0.exit
  outer_0:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, 1
    x86.mov rdx, 3
    x86.mov [rbp-40], rdx
    x86.mov [rbp-48], rcx
    x86.jmp main.inner_1.header
  inner_1.header:
    x86.mov rax, [rbp-48]
    x86.mov rcx, [rbp-40]
    x86.cmp rax, rcx
    x86.jg main.inner_1.exit
  inner_1:
    x86.mov rax, [rbp-48]
    x86.mov rcx, [rbp-32]
    x86.imul rcx, rax
    x86.mov rdx, [rbp-8]
    x86.add rdx, rcx
    x86.mov [rbp-8], rdx
    x86.jmp main.inner_1.incr
  inner_1.incr:
    x86.mov rax, 1
    x86.mov rcx, [rbp-48]
    x86.add rcx, rax
    x86.mov [rbp-48], rcx
    x86.jmp main.inner_1.header
  inner_1.exit:
    x86.jmp main.outer_0.incr
  outer_0.incr:
    x86.mov rax, 1
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_2
    x86.cmp rax, rcx
    x86.jl main.__range_panic_2
    x86.jmp main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}

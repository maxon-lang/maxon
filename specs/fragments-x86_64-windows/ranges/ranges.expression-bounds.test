// Test: ranges.expression-bounds

typealias Integer = int(i64.min to i64.max)

function getStart() returns Integer
		return 1
end 'getStart'

function getEnd() returns Integer
		return 4
end 'getEnd'

function main() returns ExitCode
		var sum = 0
		for i in getStart() to getEnd() 'loop'
				sum = sum + i
		end 'loop'
		return sum
end 'main'
---
ExitCode: 10
---
module {
  func @ranges.getStart() -> i64 {
  entry:
    x86.mov rax, 1
    x86.ret
  }
  func @ranges.getEnd() -> i64 {
  entry:
    x86.mov rax, 4
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.call ranges.getStart
    x86.mov [rbp-32], rax
    x86.call ranges.getEnd
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-32]
    x86.mov [rbp-24], rcx
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.cmp rax, rcx
    x86.jg main.loop_0.exit
  loop_0:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp main.loop_0.incr
  loop_0.incr:
    x86.mov rax, 1
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

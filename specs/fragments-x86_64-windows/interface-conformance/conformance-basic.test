    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call SimpleCounter.increment
    x86.mov rdi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call SimpleCounter.increment
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call SimpleCounter.get
    x86.mov [rbp-16], rax
    x86.xor r9, r9
    x86.cmp rax, r9
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax

// Test: conformance-basic

typealias Integer = int(i64.min to i64.max)

interface Counter
	function get() returns Integer
	function increment()
end 'Counter'

type SimpleCounter implements Counter
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	function increment()
		value = value + 1
	end 'increment'
end 'SimpleCounter'

function main() returns ExitCode
	var c = SimpleCounter{value: 40}
	c.increment()
	c.increment()
	return c.get()
end 'main'
---
ExitCode: 42
---
module {
  func @SimpleCounter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @SimpleCounter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.add rdx, rax
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rdx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 40
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call SimpleCounter.increment
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.mov rcx, rsi
    x86.call SimpleCounter.increment
    x86.lea rdi, [rbp-8]
    x86.mov r8, rdi
    x86.mov rcx, r8
    x86.call SimpleCounter.get
    x86.xor r9, r9
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.jg main.__range_panic_0
    x86.cmp rax, r9
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}

// Test: error.binding-match-multi-case

typealias Integer = int(i64.min to i64.max)

// Test matching on error binding with multiple cases
union MyError implements Error
  failed
  timeout
  notFound
end 'MyError'

var counter = 0 as Integer

function mayFail(code Integer) returns Integer throws MyError
  counter = counter + 1
  if code == 1 'c1'
    throw MyError.failed
  end 'c1'
  if code == 2 'c2'
    throw MyError.timeout
  end 'c2'
  throw MyError.notFound
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail(2) otherwise (e) 'handler'
    match e 'check'
      MyError.failed then result = 10
      MyError.timeout then result = 20
      MyError.notFound then result = 30
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @error-handling.mayFail(code: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, qword [rip+counter]
    x86.mov rdx, 1
    x86.add rax, rdx
    x86.mov qword [rip+counter], rax
    x86.mov rax, 1
    x86.cmp rcx, rax
    x86.jne error-handling.mayFail.c1_0.after
  c1_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  c1_0.after:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne error-handling.mayFail.c2_1.after
  c2_1:
    x86.mov rax, 1
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  c2_1.after:
    x86.mov rax, 2
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 2
    x86.call error-handling.mayFail
    x86.mov [rbp-16], rdx
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.sub rax, rcx
    x86.mov [rbp-24], rax
    x86.jmp error-handling.main.check_4.cmp0
  check_4.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne error-handling.main.check_4.cmp1
  check_4.case0:
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp1:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne error-handling.main.check_4.cmp2
  check_4.case1:
    x86.mov rax, 20
    x86.mov [rbp-8], rax
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp2:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne error-handling.main.check_4.merge
  check_4.case2:
    x86.mov rax, 30
    x86.mov [rbp-8], rax
    x86.jmp error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je error-handling.main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_50]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

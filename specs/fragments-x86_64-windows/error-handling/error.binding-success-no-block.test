// Test: error.binding-success-no-block

typealias Integer = int(i64.min to i64.max)

// Test that error binding block is skipped on success
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail(shouldFail bool) returns Integer throws MyError
  counter = counter + 1
  if shouldFail 'check'
    throw MyError.failed
  end 'check'
  return 100
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail(false) otherwise (e) 'handler'
    result = 99
  end 'handler'
  return result
end 'main'
---
ExitCode: 0
---
module {
  func @error-handling.mayFail(shouldFail: i1) -> i64 {
  entry:
    x86.mov rax, qword [rip+counter]
    x86.mov rdx, 1
    x86.add rax, rdx
    x86.mov qword [rip+counter], rax
    x86.test rcx, rcx
    x86.je error-handling.mayFail.check_0.after
  check_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 100
    x86.xor rdx, rdx
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.call error-handling.mayFail
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 99
    x86.mov [rbp-8], rax
    x86.jmp error-handling.main.otherwise_continue_1
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

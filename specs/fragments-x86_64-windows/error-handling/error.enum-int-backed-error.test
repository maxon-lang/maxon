// Test: error.enum-int-backed-error
// Int-backed enum error type (type inferred from values)
enum MyError implements Error
	invalidInput = 1
	notFound = 404
end 'MyError'

function main() returns ExitCode
	return 42
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 42
    x86.ret
  }
}
---

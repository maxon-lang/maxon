// Test: error.otherwise-block

typealias Integer = int(i64.min to i64.max)

// Test try otherwise block handler
union MyError implements Error
	failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
	counter = counter + 1
	throw MyError.failed
end 'mayFail'

function main() returns ExitCode
	var result = 0
	try mayFail() otherwise 'err'
		result = 42
	end 'err'
	return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.mov rax, qword [rip+counter]
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov qword [rip+counter], rax
    x86.xor rdx, rdx
    x86.mov rbx, 1
    x86.add rdx, rbx
    x86.xor rax, rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.call error-handling.mayFail
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.jmp main.otherwise_continue_1
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}
---

// Test: error.assoc-value-throw-catch

typealias Integer = int(i64.min to i64.max)

// Test error union with associated value - throw and catch
union MyError implements Error
  notFound(code Integer)
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.notFound(404)
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail() otherwise (e) 'handler'
    match e 'check'
      notFound(code) then result = code
      failed then result = 1
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 404
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, qword [rip+counter]
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov qword [rip+counter], rax
    x86.mov rdx, 404
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.xor rbx, rbx
    x86.mov [rax+0], rbx
    x86.mov rsi, 404
    x86.mov [rax+8], rsi
    x86.mov rdx, [rbp-8]
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.xor rdx, rdx
    x86.mov [rbp-24], rdx
    x86.call error-handling.mayFail
    x86.mov [rbp-32], rdx
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, [rbp-32]
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rdx+0]
    x86.mov rsi, [rbp-8]
    x86.mov [rbp-16], rsi
    x86.mov rdi, [rbp-16]
    x86.mov [rbp-48], rbx
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov r8, [rbp-48]
    x86.mov [rbp-40], r8
    x86.jmp main.check_4.cmp0
  check_4.cmp0:
    x86.mov rax, [rbp-40]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_4.cmp1
  check_4.case0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rax+8]
    x86.mov [rbp-24], rcx
    x86.jmp main.check_4.merge
  check_4.cmp1:
    x86.mov rax, [rbp-40]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.check_4.merge
  check_4.case1:
    x86.mov rax, 1
    x86.mov [rbp-24], rax
    x86.jmp main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_MyError(ptr: i64) {
  entry:
    x86.jmp __destruct_MyError.done
  done:
    x86.ret
  }
}
---

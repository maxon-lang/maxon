// Test: error.otherwise-default-value

typealias Integer = int(i64.min to i64.max)

// Test try otherwise with default value
union MyError implements Error
  failed
end 'MyError'

function mayFail() returns Integer throws MyError
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  let val = try mayFail() otherwise 42
  return val
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call error-handling.mayFail
    x86.mov rcx, 42
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je error-handling.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.jmp error-handling.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

// Test: error.otherwise-ignore

typealias Integer = int(i64.min to i64.max)

// Test try otherwise ignore
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  try mayFail() otherwise ignore
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.mov rax, qword [rip+counter]
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov qword [rip+counter], rax
    x86.xor rdx, rdx
    x86.mov rbx, 1
    x86.add rdx, rbx
    x86.xor rax, rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call error-handling.mayFail
    x86.mov rcx, 42
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: error.binding-match-single-case

typealias Integer = int(i64.min to i64.max)

// Test matching on typed error binding
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail() otherwise (e) 'handler'
    match e 'check'
      failed then result = 42
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.mov rax, qword [rip+counter]
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov qword [rip+counter], rax
    x86.xor rdx, rdx
    x86.mov rbx, 1
    x86.add rdx, rbx
    x86.xor rax, rax
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.call error-handling.mayFail
    x86.mov [rbp-16], rdx
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.je main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.sub rax, rcx
    x86.mov [rbp-24], rax
    x86.jmp main.check_4.cmp0
  check_4.cmp0:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne main.check_4.merge
  check_4.case0:
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.jmp main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.epilogue
    x86.ret
  }
}
---

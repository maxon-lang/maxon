    x86.call challenge-struct-lifetime.increment
    x86.mov [rbp-16], rax
    x86.mov rbx, [rbp-16]
    x86.mov rsi, [rbx+0]
    x86.xor rdi, rdi
    x86.cmp rsi, rdi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rsi, r9
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r8, rax
    x86.test r8, r8
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]

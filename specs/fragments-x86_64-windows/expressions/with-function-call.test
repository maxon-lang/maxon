// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	var x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 3
    x86.mov rdx, 4
    x86.call with-function-call.add
    x86.mov rcx, 5
    x86.add rcx, rax
    x86.test rcx, rcx
    x86.setl rax
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.or rax, rdx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @with-function-call.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.add rcx, rdx
    x86.mov rax, -9223372036854775807
    x86.cmp rcx, rax
    x86.jge __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	var x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov rcx, 3
    x86.mov rdx, 4
    x86.call expressions.add
    x86.mov rcx, 5
    x86.add rcx, rax
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rcx, rbx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @expressions.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea rax, [rcx + rdx]
    x86.ret
  }
}
---

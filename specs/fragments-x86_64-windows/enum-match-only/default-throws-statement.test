// Test: default-throws-statement
enum Color
	red
	green
	blue
end 'Color'

enum MatchError
	unmatched
end 'MatchError'

function checkColor(c Color) returns ExitCode throws MatchError
	match c 'check'
		green then return 1
		default throws MatchError.unmatched
	end 'check'
end 'checkColor'

function main() returns ExitCode
	var c = Color.green
	var result = try checkColor(c) otherwise 0
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @enum-match-only.checkColor(c: i64) -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.jmp enum-match-only.checkColor.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne enum-match-only.checkColor.check_0.case1
  check_0.case0:
    x86.mov rax, 1
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call enum-match-only.checkColor
    x86.mov ecx, rax
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.mov [rbp-24], rcx
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_4
    x86.cmp rax, rcx
    x86.jl main.__range_panic_4
    x86.jmp main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_4:
    x86.epilogue
    x86.ret
  }
}

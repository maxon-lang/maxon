// Test: int.equals.same
function main() returns ExitCode
	var a = 42
	var b = 42
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 42
    x86.mov rdx, 42
    x86.call stdlib.int.equals
    x86.test rax, rax
    x86.je main.eq_0.after
  eq_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

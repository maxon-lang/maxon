// Test: float.equals
function main() returns ExitCode
  var a = 3.14
  var b = 3.14
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movsd xmm1, [rip+__float_3.14]
    x86.call stdlib.float.equals
    x86.test rax, rax
    x86.je primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

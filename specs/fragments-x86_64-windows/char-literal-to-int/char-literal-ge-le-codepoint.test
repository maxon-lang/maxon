// Test: char-literal-ge-le-codepoint
function main() returns ExitCode
  var cp = 53
  if cp >= '0' 'ge'
    if cp <= '9' 'le'
      return 0
    end 'le'
  end 'ge'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 53
    x86.mov [rbp-8], rax
    x86.mov rcx, 48
    x86.cmp rax, rcx
    x86.jl main.ge_0.merge
  ge_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 57
    x86.cmp rax, rcx
    x86.jg main.le_1.after
  le_1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  le_1.after:
    x86.jmp main.ge_0.merge
  ge_0.merge:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  }
}
---

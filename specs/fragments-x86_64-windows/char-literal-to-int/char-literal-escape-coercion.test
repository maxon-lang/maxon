// Test: char-literal-escape-coercion
function main() returns ExitCode
	var cp = 10
	if cp == '\n' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 10
    x86.mov rcx, 10
    x86.cmp rax, rcx
    x86.jne main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

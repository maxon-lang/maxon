// Test: docs-example-1
function main() returns ExitCode
	var x = 10
	var y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.cmp rax, rcx
    x86.jge main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

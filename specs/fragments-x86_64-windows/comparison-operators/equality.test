// Test: equality
function main() returns ExitCode
	var x = 42
	if x == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 42
    x86.cmp rax, 42
    x86.jne check_1.after
  check_1:
    x86.mov rax, 1
    x86.ret
  check_1.after:
    x86.mov rax, 0
    x86.ret
  }
}
---

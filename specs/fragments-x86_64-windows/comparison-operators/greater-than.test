// Test: greater-than
function main() returns ExitCode
	if 5 > 3 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.cmp rax, 3
    x86.jle check_1.after
  check_1:
    x86.mov rax, 42
    x86.ret
  check_1.after:
    x86.mov rax, 0
    x86.ret
  }
}
---

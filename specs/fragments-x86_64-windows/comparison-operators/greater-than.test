// Test: greater-than
function main() returns ExitCode
	if 5 > 3 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jle main.check_0.after
  check_0:
    x86.mov rax, 42
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

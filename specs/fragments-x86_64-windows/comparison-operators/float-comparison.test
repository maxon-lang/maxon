// Test: float-comparison
function main() returns ExitCode
	var x = 3.5
	var y = 2.1
	if x > y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 4615063718147915776
    x86.mov [rbp+-8], rax
    x86.movsd xmm0, [rbp+-8]
    x86.mov rcx, 4611911198408756428
    x86.mov [rbp+-16], rcx
    x86.movsd xmm1, [rbp+-16]
    x86.ucomisd xmm0, xmm1
    x86.jbe check_1.after
  check_1:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_1.after:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  }
}
---

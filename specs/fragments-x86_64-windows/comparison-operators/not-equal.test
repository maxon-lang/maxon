// Test: not-equal
function main() returns ExitCode
  var x = 10
  if x != 20 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.cmp rax, rcx
    x86.je main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

// Test: not-equal
function main() returns ExitCode
	var x = 10
	if x != 20 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 10
    x86.cmp rax, 20
    x86.je else
  then:
    x86.mov rax, 1
    x86.ret
  else:
  merge:
    x86.mov rax, 0
    x86.ret
  }
}
---

// Test: less-than-or-equal
function main() returns ExitCode
	var a = 5
	var b = 10
	if a <= b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.cmp rax, 10
    x86.jg else
  then:
    x86.mov rax, 1
    x86.ret
  else:
  merge:
    x86.mov rax, 0
    x86.ret
  }
}
---

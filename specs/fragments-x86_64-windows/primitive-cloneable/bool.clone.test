// Test: bool.clone
function main() returns ExitCode
	var x = true
	if x.clone() 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.call stdlib.bool.clone
    x86.test rax, rax
    x86.je main.ok_0.after
  ok_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

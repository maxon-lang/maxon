// Test: is-not-self
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  if a is not a 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rbx, 1
    x86.mov [rdx+0], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rdi, 2
    x86.mov [rsi+8], rdi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-8]
    x86.mov rax, [rbp-8]
    x86.cmp r9, rax
    x86.je main.check_0.after
  check_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct_Point(ptr: i64) {
  entry:
    x86.jmp __destruct_Point.done
  done:
    x86.ret
  }
}
---

// Test: function-same-arg
typealias Integer = int(i64.min to i64.max)

type Box
	export var value Integer
end 'Box'

function areSame(a Box, b Box) returns bool
	return a is b
end 'areSame'

function main() returns ExitCode
	var x = Box{value: 42}
	var y = Box{value: 42}
	var result = 0
	if areSame(x, b: x) 'same'
		result = result + 1
	end 'same'
	if areSame(x, b: y) 'diff'
		result = result + 10
	end 'diff'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @reference-identity.areSame(a: i64, b: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rbp-16]
    x86.cmp rax, rbx
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.mov [rbp-8], rax
    x86.mov rcx, 42
    x86.mov [rbp-16], rcx
    x86.xor rdx, rdx
    x86.mov [rbp-24], rdx
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.lea rdi, [rbp-8]
    x86.mov r8, rdi
    x86.mov rcx, rsi
    x86.mov rdx, r8
    x86.call reference-identity.areSame
    x86.test rax, rax
    x86.je main.same_0.merge
  same_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.jmp main.same_0.merge
  same_0.merge:
    x86.lea rax, [rbp-8]
    x86.mov rcx, rax
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rdx, rbx
    x86.call reference-identity.areSame
    x86.test rax, rax
    x86.je main.diff_1.merge
  diff_1:
    x86.mov rax, 10
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.jmp main.diff_1.merge
  diff_1.merge:
    x86.mov rax, [rbp-24]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

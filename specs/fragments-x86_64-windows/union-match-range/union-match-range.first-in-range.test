// Test: union-match-range.first-in-range
typealias Integer = int(i64.min to i64.max)

union Action
  noop
  skip
  run(code Integer)
end 'Action'

function main() returns ExitCode
  var a = Action.noop
  var result = match a 'check'
    noop to skip gives 1
    run(code) gives code
  end 'check'
  return result
end 'main'
---
ExitCode: 1

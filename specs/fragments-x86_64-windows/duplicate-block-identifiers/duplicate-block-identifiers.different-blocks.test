// Test: duplicate-block-identifiers.different-blocks
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
	end 'outer'
	
	if true 'inner'
		x = 2
	end 'inner'
	
	return x
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.test rcx, rcx
    x86.je main.outer_0.merge
  outer_0:
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.jmp main.outer_0.merge
  outer_0.merge:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.inner_1.merge
  inner_1:
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.inner_1.merge
  inner_1.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_2
    x86.cmp rax, rcx
    x86.jl main.__range_panic_2
    x86.jmp main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

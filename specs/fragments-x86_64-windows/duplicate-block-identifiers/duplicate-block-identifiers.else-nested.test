// Test: duplicate-block-identifiers.else-nested
function main() returns ExitCode
	var x = 0
	if false 'check'
		x = 1
	end 'check' else 'else_check'
		if true 'nested'
			x = 2
		end 'nested'
	end 'else_check'
	return x
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.test rcx, rcx
    x86.je main.else_check_1
  check_0:
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.jmp main.check_0.merge
  else_check_1:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.nested_2.merge
  nested_2:
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.nested_2.merge
  nested_2.merge:
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_3
    x86.cmp rax, rcx
    x86.jl main.__range_panic_3
    x86.jmp main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  }
}
---

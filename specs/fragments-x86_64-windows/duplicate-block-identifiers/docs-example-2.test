// Test: docs-example-2
function main() returns ExitCode
	var x = 0
	if true 'check'
		x = 1
		if true 'check'
			x = 2
		end 'check'
	end 'check'
	return x
end 'main'

---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.test rcx, rcx
    x86.je main.check_0.merge
  check_0:
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.test rcx, rcx
    x86.je main.check_1.merge
  check_1:
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp main.check_1.merge
  check_1.merge:
    x86.jmp main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

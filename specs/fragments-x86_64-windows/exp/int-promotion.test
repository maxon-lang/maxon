// Test: int-promotion
function main() returns ExitCode
  var result = Math.exp(3)  // Int promoted to float
  return trunc(result)
end 'main'
---
ExitCode: 20
---
module {
  func @exp.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 3
    x86.cvtsi2sd xmm0, rax
    x86.call stdlib.Math.exp
    x86.cvttsd2si rcx, xmm0
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je exp.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

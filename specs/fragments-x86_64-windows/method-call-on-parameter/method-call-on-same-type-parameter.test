// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
	var x Integer
	
	function bar() returns Integer
		return x
	end 'bar'
	
	function callBarOn(other Foo) returns Integer
		return other.bar()
	end 'callBarOn'
end 'Foo'

function main() returns ExitCode
	var f1 = Foo{x: 10}
	var f2 = Foo{x: 42}
	return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rdx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Foo.bar
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.mov rcx, 42
    x86.mov [rbp-16], rcx
    x86.lea rdx, [rbp-8]
    x86.mov rbx, rdx
    x86.lea rsi, [rbp-16]
    x86.mov rdi, rsi
    x86.mov rcx, rbx
    x86.mov rdx, rdi
    x86.call Foo.callBarOn
    x86.xor r8, r8
    x86.cmp rax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or r9, rcx
    x86.test r9, r9
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

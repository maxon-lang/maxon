// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
  var x Integer
  
  function bar() returns Integer
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns Integer
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns ExitCode
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rdx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Foo.bar
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, 42
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rdi, [rbp-16]
    x86.mov r8, 42
    x86.mov [rdi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Foo.callBarOn
    x86.mov [rbp-24], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax
    x86.test rcx, rcx
    x86.je method-call-on-parameter.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_28]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Foo(ptr: i64) {
  entry:
    x86.jmp __destruct_Foo.done
  done:
    x86.ret
  }
}
---

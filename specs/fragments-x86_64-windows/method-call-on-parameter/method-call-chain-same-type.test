// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer
	
	function get() returns Integer
		return n
	end 'get'
	
	function add(other Value) returns Integer
		return n + other.get()
	end 'add'
	
	function multiply(other Value) returns Integer
		return n * other.get()
	end 'multiply'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	var a = Value.create(n: 5)
	var b = Value.create(n: 3)
	var c = Value.create(n: 2)
	// a.add(b) = 5 + 3 = 8
	// a.multiply(c) = 5 * 2 = 10
	// total = 8 + 10 = 18
	return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
module {
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Value.add(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rbx
    x86.mov rcx, [rbp-16]
    x86.call Value.get
    x86.mov rcx, [rbp-24]
    x86.lea rax, [rcx + rax]
    x86.epilogue
    x86.ret
  }
  func @Value.multiply(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rbx
    x86.mov rcx, [rbp-16]
    x86.call Value.get
    x86.mov rcx, [rbp-24]
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @Value.create(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov rcx, 5
    x86.call Value.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.call Value.create
    x86.mov [rbp-16], rax
    x86.mov rcx, 2
    x86.call Value.create
    x86.mov [rbp-24], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Value.add
    x86.mov rdx, [rbp-8]
    x86.mov rbx, [rbp-24]
    x86.mov [rbp-32], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-24]
    x86.call Value.multiply
    x86.mov rsi, [rbp-32]
    x86.add rsi, rax
    x86.xor rdi, rdi
    x86.mov r8, 4294967295
    x86.cmp rsi, r8
    x86.jg main.__range_panic_0
    x86.cmp rsi, rdi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, [rbp-24]
    x86.mov [rbp-40], rsi
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-8]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, [rbp-40]
    x86.epilogue
    x86.ret

// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer
  
  function get() returns Integer
    return n
  end 'get'
  
  function add(other Value) returns Integer
    return n + other.get()
  end 'add'
  
  function multiply(other Value) returns Integer
    return n * other.get()
  end 'multiply'
end 'Value'

function main() returns ExitCode
  var a = Value{n: 5}
  var b = Value{n: 3}
  var c = Value{n: 2}
  // a.add(b) = 5 + 3 = 8
  // a.multiply(c) = 5 * 2 = 10
  // total = 8 + 10 = 18
  return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
module {
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @Value.add(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rbx
    x86.mov rcx, [rbp-16]
    x86.call Value.get
    x86.mov rcx, [rbp-24]
    x86.lea rax, [rcx + rax]
    x86.epilogue
    x86.ret
  }
  func @Value.multiply(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rbx
    x86.mov rcx, [rbp-16]
    x86.call Value.get
    x86.mov rcx, [rbp-24]
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.mov [rbp-16], rcx
    x86.mov rdx, 2
    x86.mov [rbp-24], rdx
    x86.lea rbx, [rbp-8]
    x86.mov rsi, rbx
    x86.lea rdi, [rbp-16]
    x86.mov r8, rdi
    x86.mov rcx, rsi
    x86.mov rdx, r8
    x86.call Value.add
    x86.lea r9, [rbp-8]
    x86.mov rcx, r9
    x86.lea rdx, [rbp-24]
    x86.mov rbx, rdx
    x86.mov [rbp-32], rax
    x86.mov rdx, rbx
    x86.call Value.multiply
    x86.mov rcx, [rbp-32]
    x86.add rcx, rax
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rax, rdx
    x86.test rax, rax
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

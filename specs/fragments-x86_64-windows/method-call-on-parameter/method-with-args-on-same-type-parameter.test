// Test: method-with-args-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Adder
  var value Integer
  
  function addTo(n Integer) returns Integer
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n Integer) returns Integer
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns ExitCode
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.lea rax, [rbx + rdx]
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rdx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, r8
    x86.epilogue
    x86.jmp Adder.addTo
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 100
    x86.mov [rbp-8], rax
    x86.mov rcx, 50
    x86.mov [rbp-16], rcx
    x86.lea rdx, [rbp-8]
    x86.mov rbx, rdx
    x86.lea rsi, [rbp-16]
    x86.mov rdi, rsi
    x86.mov rcx, rbx
    x86.mov rdx, rdi
    x86.mov r8, 7
    x86.call Adder.delegateAdd
    x86.mov [rbp-24], rax
    x86.xor r8, r8
    x86.cmp rax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r9, rax
    x86.test r9, r9
    x86.je method-call-on-parameter.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_32]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

// Test: method-with-args-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Adder
	var value Integer
	
	function addTo(n Integer) returns Integer
		return value + n
	end 'addTo'
	
	function delegateAdd(other Adder, n Integer) returns Integer
		return other.addTo(n)
	end 'delegateAdd'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Adder'

function main() returns ExitCode
	var a = Adder.create(value: 100)
	var b = Adder.create(value: 50)
	return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.lea rax, [rbx + rdx]
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rdx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, r8
    x86.epilogue
    x86.jmp Adder.addTo
  }
  func @Adder.create(value: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov [rax+0], rcx
    x86.mov rdx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 100
    x86.call Adder.create
    x86.mov [rbp-8], rax
    x86.mov rcx, 50
    x86.call Adder.create
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.mov r8, 7
    x86.call Adder.delegateAdd
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.jg main.__range_panic_0
    x86.cmp rax, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rcx, [rbp-16]
    x86.mov [rbp-24], rax
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Adder(ptr: i64) {
  entry:
    x86.jmp __destruct_Adder.done
  done:
    x86.ret
  }
}

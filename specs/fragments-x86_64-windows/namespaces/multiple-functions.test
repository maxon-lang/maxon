// Test: multiple-functions

typealias Integer = int(i64.min to i64.max)

export function double(x Integer) returns Integer
  return x * 2
end 'double'

export function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  return double(5) + triple(4)
end 'main'
---
ExitCode: 22
---
module {
  func @namespaces.double(x: i64) -> i64 {
  entry:
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @namespaces.triple(x: i64) -> i64 {
  entry:
    x86.mov rax, 3
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @namespaces.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call namespaces.double
    x86.mov [rbp-8], rax
    x86.mov rcx, 4
    x86.call namespaces.triple
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rax, rdx
    x86.test rax, rax
    x86.je namespaces.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

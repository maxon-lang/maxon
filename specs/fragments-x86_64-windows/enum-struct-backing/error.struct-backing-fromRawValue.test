// Test: error.struct-backing-fromRawValue
typealias Value = int(0 to 100)

type Meta
	export let value Value
end 'Meta'

enum TestOp
	add = Meta{value: 1}
end 'TestOp'

function main() returns ExitCode
	let op = try TestOp.fromRawValue(1) otherwise TestOp.add
	return 0
end 'main'

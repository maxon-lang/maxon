// Test: struct-backing-basic
typealias Latency = int(0 to 50)

type Meta
	export let value Latency
end 'Meta'

enum TestOp
	add = Meta{value: 1}
	mul = Meta{value: 3}
end 'TestOp'

function main() returns ExitCode
	let op = TestOp.mul
	return op.rawValue.value
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.xor rdx, rdx
    x86.xor rbx, rbx
    x86.mov rsi, [rbp-8]
    x86.cmp rsi, rbx
    x86.sete rdi
    x86.movzx rdi, rdib
    x86.mov r8, 1
    x86.test rdi, rdi
    x86.mov r9, rdx
    x86.cmovne r9, r8
    x86.mov rcx, 1
    x86.cmp rsi, rcx
    x86.sete rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 3
    x86.test rcx, rcx
    x86.mov rbx, r9
    x86.cmovne rbx, rdx
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+0], rbx
    x86.mov [rbp-24], rax
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+0]
    x86.xor rax, rax
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.jg main.__range_panic_0
    x86.cmp rcx, rax
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-24]
    x86.mov [rbp-32], rcx
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Meta(ptr: i64) {
  entry:
    x86.jmp __destruct_Meta.done
  done:
    x86.ret
  }
}
---

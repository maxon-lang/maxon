// Test: error.struct-backing-mixed
typealias Value = int(0 to 100)

type Meta
	export let value Value
end 'Meta'

enum Mixed
	a = Meta{value: 1}
	b = 42
end 'Mixed'

function main() returns ExitCode
	return 0
end 'main'

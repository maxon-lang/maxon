// Test: panic.after-condition
typealias Integer = int(i64.min to i64.max)

function check(n Integer) returns Integer
    if n < 0 'negative'
        panic("negative value")
    end 'negative'
    return n
end 'check'

function main() returns ExitCode
    return check(Integer{0 - 1})
end 'main'

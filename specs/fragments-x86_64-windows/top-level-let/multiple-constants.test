// Test: multiple-constants
let A = 1
let B = 2
let C = 3

function main() returns ExitCode
	return A + B + C
end 'main'
---
ExitCode: 6
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.add rax, rcx
    x86.mov rdx, 3
    x86.add rax, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: float-promotion
function main() returns ExitCode
  var x = 5
  var y = 2.0
  var result = x + y
  return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.movsd xmm0, [rip+__float_2]
    x86.cvtsi2sd xmm1, rax
    x86.movsd xmm2, xmm1
    x86.addsd xmm2, xmm0
    x86.cvttsd2si rcx, xmm2
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

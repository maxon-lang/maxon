    x86.movsd xmm1, xmm0
    x86.mov [rbp+-16], rcx
    x86.movsd xmm2, [rbp+-16]
    x86.mulsd xmm1, xmm2
    x86.movsd xmm3, xmm1
    x86.mulsd xmm3, xmm2
    x86.movsd xmm0, xmm3
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 4617315517961601024
    x86.call docs-example-1.circleArea
    x86.cvttsd2si rax, xmm0
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rbx
    x86.or rcx, rbx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}

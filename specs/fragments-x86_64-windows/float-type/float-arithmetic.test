// Test: float-arithmetic
function main() returns ExitCode
	var a = 10.0
	var b = 3.0
	var result = a / b
	return trunc(result)
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 4621819117588971520
    x86.mov [rbp+-8], rax
    x86.movsd xmm0, [rbp+-8]
    x86.movsd xmm1, xmm0
    x86.mov rcx, 4613937818241073152
    x86.mov [rbp+-16], rcx
    x86.movsd xmm2, [rbp+-16]
    x86.divsd xmm1, xmm2
    x86.cvttsd2si rdx, xmm1
    x86.test rdx, rdx
    x86.setl rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.setg rdi
    x86.or rbx, rdi
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

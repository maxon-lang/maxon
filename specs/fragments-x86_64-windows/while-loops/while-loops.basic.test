// Test: while-loops.basic
function main() returns ExitCode
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
module {
  func @while-loops.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.mov rcx, 3
    x86.mov [rbp-16], rcx
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.xor rax, rax
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jle while-loops.main.loop_0.exit
  loop_0:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 1
    x86.mov rbx, [rbp-16]
    x86.sub rbx, rdx
    x86.mov [rbp-16], rbx
    x86.xor rsi, rsi
    x86.cmp rbx, rsi
    x86.jne while-loops.main.check_1.after
  check_1:
    x86.jmp while-loops.main.loop_0.exit
  check_1.after:
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je while-loops.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}

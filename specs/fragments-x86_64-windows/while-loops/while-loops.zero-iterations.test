// Test: while-loops.zero-iterations
function main() returns ExitCode
  var x = 10
  while x < 5 'loop'
    x = x + 1
  end 'loop'
  return x
end 'main'
---
ExitCode: 10
---
module {
  func @while-loops.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov [rbp-8], rax
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jge while-loops.main.loop_0.exit
  loop_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je while-loops.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

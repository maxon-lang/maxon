// Test: while-loops.break
function main() returns ExitCode
	var x = 5
	while true 'loop'
		x = x + 2
		if x == 11 'check'
			break
		end 'check'
	end 'loop'
	return x
end 'main'
---
ExitCode: 11
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je main.loop_0.exit
  loop_0:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.mov rdx, 11
    x86.cmp rcx, rdx
    x86.jne main.check_1.after
  check_1:
    x86.jmp main.loop_0.exit
  check_1.after:
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_2
    x86.cmp rax, rcx
    x86.jl main.__range_panic_2
    x86.jmp main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

// Test: while-loops.continue
function main() returns ExitCode
	var sum = 0
	var i = 0
	while i < 5 'loop'
		i = i + 1
		if i == 3 'skip'
			continue
		end 'skip'
		sum = sum + i
	end 'loop'
	return sum
end 'main'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge main.loop_0.exit
  loop_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.mov rdx, 3
    x86.cmp rcx, rdx
    x86.jne main.skip_1.after
  skip_1:
    x86.jmp main.loop_0.header
  skip_1.after:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.add rax, rcx
    x86.mov [rbp-8], rax
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_2
    x86.cmp rax, rcx
    x86.jl main.__range_panic_2
    x86.jmp main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

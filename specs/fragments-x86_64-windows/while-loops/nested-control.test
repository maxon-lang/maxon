// Test: nested-control
function main() returns ExitCode
	var result = 0
	var i = 0
	while i < 3 'outer'
		var j = 0
		while j < 3 'inner'
			if (i + j) mod 2 == 0 'even'
				result = result + 1
			end 'even'
			j = j + 1
		end 'inner'
		i = i + 1
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov rax, 3
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge main.outer_0.exit
  outer_0:
    x86.xor rax, rax
    x86.mov [rbp-24], rax
    x86.jmp main.inner_1.header
  inner_1.header:
    x86.mov rax, 3
    x86.mov rcx, [rbp-24]
    x86.cmp rcx, rax
    x86.jge main.inner_1.exit
  inner_1:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-24]
    x86.add rax, rcx
    x86.mov rdx, 2
    x86.mov rcx, rdx
    x86.mov [rbp-32], rax
    x86.cqo
    x86.idiv rcx
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.jne main.even_2.merge
  even_2:
    x86.mov rax, 1
    x86.mov rcx, [rbp-8]
    x86.add rcx, rax
    x86.mov [rbp-8], rcx
    x86.jmp main.even_2.merge
  even_2.merge:
    x86.mov rax, 1
    x86.mov rcx, [rbp-24]
    x86.add rcx, rax
    x86.mov [rbp-24], rcx
    x86.jmp main.inner_1.header
  inner_1.exit:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_3
    x86.cmp rax, rcx
    x86.jl main.__range_panic_3
    x86.jmp main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  }
}
---

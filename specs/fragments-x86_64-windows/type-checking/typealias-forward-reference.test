// Test: typealias-forward-reference

typealias Integer = int(i64.min to i64.max)

typealias FooArray = Array with Foo

type Foo
  let value Integer
end 'Foo'

function main() returns ExitCode
  var arr = FooArray{}
  arr.push(Foo{value: 42})
  return arr.count() - 1
end 'main'

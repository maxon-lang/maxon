    x86.prologue stack_size=32
    x86.lea_rdata rax, [__str_0]
    x86.mov rcx, rax
    x86.mov rdx, 3
    x86.lea_func rbx, [__destruct_String]
    x86.mov rsi, rbx
    x86.mov [rbp-24], rcx
    x86.mov rdx, rsi
    x86.mov rcx, 16
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.lea_func rdi, [__destruct___ManagedMemory]
    x86.mov r8, rdi
    x86.mov rdx, r8
    x86.mov rcx, 32
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov r9, [rbp-16]
    x86.mov rax, [rbp-24]
    x86.mov [r9+0], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, 3
    x86.mov [rax+8], rcx
    x86.xor rax, rax
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+16], rax
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.mov [rcx+24], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov [rcx+0], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.xor rax, rax
    x86.mov rcx, [rbp-8]
    x86.mov [rcx+8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call discarded-results.parseNum
    x86.xor rcx, rcx
    x86.xor rcx, rcx
    x86.cmp rdx, rcx
    x86.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @__destruct_String(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp __destruct_String.done
  done:
    x86.epilogue
    x86.ret
  }
  func @__destruct___ManagedMemory(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+16]
    x86.xor rdx, rdx
    x86.cmp rcx, rdx
    x86.je __destruct___ManagedMemory.skip_buf_0
  free_buf_0:

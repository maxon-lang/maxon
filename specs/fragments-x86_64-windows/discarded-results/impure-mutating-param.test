// Test: impure-mutating-param

typealias Integer = int(i64.min to i64.max)

function doubleInPlace(x Integer) returns Integer
  x = x * 2
  return x
end 'doubleInPlace'

function main() returns ExitCode
  var n = 5 as Integer
  let _ = doubleInPlace(n)
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.doubleInPlace(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, 2
    x86.imul rcx, rdx
    x86.mov [rbp-16], rcx
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbp-16]
    x86.mov [rbx+0], rsi
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call discarded-results.doubleInPlace
    x86.xor rbx, rbx
    x86.mov rax, rbx
    x86.epilogue
    x86.ret
  }
}
---

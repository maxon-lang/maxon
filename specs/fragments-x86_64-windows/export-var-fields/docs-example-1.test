// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

type Counter
	var count Score              // private
	export var name Score     // public

	function increment()
		count = count + 1      // OK - accessing within method
	end 'increment'

	export function getCount() returns Score
		return count           // OK - accessing within method
	end 'getCount'

	static function create(count Score, name Score) returns Self
		return Self{count: count, name: name}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(count: 0, name: 5)
	c.increment()
	return c.getCount()
	// c.count would be an error - not exported
end 'main'

---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.add rdx, rax
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rdx
    x86.epilogue
    x86.ret
  }
  func @Counter.getCount(__self_ptr: i64) -> i64 {

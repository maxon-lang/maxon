// Test: ceil.negative
function main() returns ExitCode
	var neg = -3.9
	var y = trunc(ceil(neg))
	return y + 10
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_-3.9]
    x86.roundsd xmm1, xmm0, 2
    x86.cvttsd2si rax, xmm1
    x86.mov rcx, 10
    x86.add rax, rcx
    x86.xor rdx, rdx
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.jg main.__range_panic_0
    x86.cmp rax, rdx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

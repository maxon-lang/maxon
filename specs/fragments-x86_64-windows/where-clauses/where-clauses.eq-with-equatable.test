// Test: where-clauses.eq-with-equatable
type Box uses T where T is Equatable
    var item T

    export function eq(other T) returns bool
        return item == other
    end 'eq'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
    var b = IntBox{item: 42}
    if b.eq(other: 42) 'yes'
        return 1
    end 'yes'
    return 0
end 'main'
---
ExitCode: 1
---
module {
  func @where-clauses.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 42
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 42
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 42
    x86.call IntBox.eq
    x86.test rax, rax
    x86.je where-clauses.main.yes_0.after
  yes_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  yes_0.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
  func @IntBox.eq(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rbx, [rax+0]
    x86.mov [rbp-16], rbx
    x86.mov rax, [rbp-16]
    x86.cmp rax, rdx
    x86.sete rax
    x86.movzx rax, raxb
    x86.epilogue
    x86.ret
  }
  func @__destruct_IntBox(ptr: i64) {
  entry:
    x86.jmp __destruct_IntBox.done
  done:
    x86.ret
  }
}
---

// Test: if-statements.else-false
function main() returns ExitCode
	var x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 3
    x86.mov rcx, 5
    x86.cmp rax, rcx
    x86.jle main.not_gt5_1
  gt5_0:
    x86.mov rax, 1
    x86.ret
  not_gt5_1:
    x86.xor rax, rax
    x86.ret
  }
}
---

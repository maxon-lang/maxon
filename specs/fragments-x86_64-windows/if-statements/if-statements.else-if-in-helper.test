// Test: if-statements.else-if-in-helper

typealias Integer = int(i64.min to i64.max)

function classify(x Integer) returns Integer
	if x == 0 'zero'
		return 0
	end 'zero' else if x < 10 'small'
		return 1
	end 'small' else if x < 100 'medium'
		return 2
	end 'medium' else 'large'
		return 3
	end 'large'
end 'classify'

function main() returns ExitCode
	var a = classify(0)
	var b = classify(5)
	var c = classify(50)
	var d = classify(200)
	return a + b * 10 + c * 100 + d * 1000
end 'main'
---
ExitCode: 3210
---
module {
  func @if-statements.classify(ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.test rcx, rcx
    x86.mov [rbp+-8], rcx
    x86.jne zero_1.else
  zero_1:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  zero_1.else:
    x86.mov rax, [rbp+-8]
    x86.cmp rax, 10
    x86.jge small_3.else
  small_3:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  small_3.else:
    x86.mov rax, [rbp+-8]
    x86.cmp rax, 100
    x86.jge large_6
  medium_5:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  large_6:
    x86.mov rax, 3
    x86.epilogue
    x86.ret
  small_3.merge:
  zero_1.merge:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 0
    x86.call if-statements.classify
    x86.mov rcx, 5
    x86.mov [rbp+-8], rax
    x86.call if-statements.classify
    x86.mov rcx, 10
    x86.imul rax, rcx
    x86.mov rcx, [rbp+-8]
    x86.add rcx, rax
    x86.mov [rbp+-16], rcx
    x86.mov rcx, 50
    x86.call if-statements.classify
    x86.mov rcx, 100
    x86.imul rax, rcx
    x86.mov rcx, [rbp+-16]
    x86.add rcx, rax
    x86.mov [rbp+-24], rcx
    x86.mov rcx, 200
    x86.call if-statements.classify
    x86.mov rcx, 1000
    x86.imul rax, rcx
    x86.mov rcx, [rbp+-24]
    x86.add rcx, rax
    x86.test rcx, rcx
    x86.setl rax
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.or rax, rdx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}
---

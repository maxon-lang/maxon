// Test: if-statements.else-if-in-helper

typealias Integer = int(i64.min to i64.max)

function classify(x Integer) returns Integer
  if x == 0 'zero'
    return 0
  end 'zero' else if x < 10 'small'
    return 1
  end 'small' else if x < 100 'medium'
    return 2
  end 'medium' else 'large'
    return 3
  end 'large'
end 'classify'

function main() returns ExitCode
  var a = classify(0)
  var b = classify(5)
  var c = classify(50)
  var d = classify(200)
  return a + b * 10 + c * 100 + d * 1000
end 'main'
---
ExitCode: 3210
---
module {
  func @if-statements.classify(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.jne if-statements.classify.zero_0.elseif
  zero_0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  zero_0.elseif:
    x86.mov rax, 10
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jge if-statements.classify.small_1.elseif
  small_1:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  small_1.elseif:
    x86.mov rax, 100
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jge if-statements.classify.large_3
  medium_2:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  large_3:
    x86.mov rax, 3
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call if-statements.classify
    x86.mov [rbp-8], rax
    x86.mov rcx, 5
    x86.call if-statements.classify
    x86.mov [rbp-16], rax
    x86.mov rcx, 50
    x86.call if-statements.classify
    x86.mov [rbp-24], rax
    x86.mov rcx, 200
    x86.call if-statements.classify
    x86.mov rcx, 10
    x86.mov rdx, [rbp-16]
    x86.imul rdx, rcx
    x86.mov rcx, [rbp-8]
    x86.add rcx, rdx
    x86.mov rdx, 100
    x86.mov rbx, [rbp-24]
    x86.imul rbx, rdx
    x86.add rcx, rbx
    x86.mov rdx, 1000
    x86.imul rax, rdx
    x86.add rcx, rax
    x86.xor rax, rax
    x86.cmp rcx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rax, rdx
    x86.test rax, rax
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
}

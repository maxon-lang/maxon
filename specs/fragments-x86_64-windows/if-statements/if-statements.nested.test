// Test: if-statements.nested
function main() returns ExitCode
  var x = 3
  if x == 1 'outer'
    return 1
  end 'outer' else 'else_outer'
    if x == 2 'inner'
      return 2
    end 'inner' else 'else_inner'
      return 3
    end 'else_inner'
  end 'else_outer'
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 3
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.else_outer_1
  outer_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  else_outer_1:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne main.else_inner_3
  inner_2:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  else_inner_3:
    x86.mov rax, 3
    x86.epilogue
    x86.ret
  }
}
---

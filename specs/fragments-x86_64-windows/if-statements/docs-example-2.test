// Test: docs-example-2
function main() returns ExitCode
	var x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 3
    x86.cmp rax, 5
    x86.jle not_gt5_2
  gt5_1:
    x86.mov rax, 1
    x86.ret
  not_gt5_2:
    x86.mov rax, 0
    x86.ret
  }
}
---

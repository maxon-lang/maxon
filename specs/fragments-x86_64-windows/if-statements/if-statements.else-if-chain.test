// Test: if-statements.else-if-chain
function main() returns ExitCode
	var x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 2
    x86.cmp rax, 1
    x86.jne case1_1.else
  case1_1:
    x86.mov rax, 1
    x86.ret
  case1_1.else:
    x86.mov rax, 2
    x86.cmp rax, 2
    x86.jne default_4
  case2_3:
    x86.mov rax, 2
    x86.ret
  default_4:
    x86.mov rax, 0
    x86.ret
  case1_1.merge:
    x86.mov rax, 0
    x86.ret
  }
}
---

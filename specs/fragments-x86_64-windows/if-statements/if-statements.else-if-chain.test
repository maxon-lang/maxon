// Test: if-statements.else-if-chain
function main() returns ExitCode
	var x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne main.case1_0.elseif
  case1_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  case1_0.elseif:
    x86.mov rax, 2
    x86.mov rcx, [rbp-8]
    x86.cmp rcx, rax
    x86.jne main.default_2
  case2_1:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  default_2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

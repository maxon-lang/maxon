// Test: if-statements.else
function main() returns ExitCode
  var x = 5
  if x == 5 'is5'
    return 1
  end 'is5' else 'not5'
    return 0
  end 'not5'
end 'main'
---
ExitCode: 1
---
module {
  func @if-statements.main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.mov rcx, 5
    x86.cmp rax, rcx
    x86.jne if-statements.main.not5_1
  is5_0:
    x86.mov rax, 1
    x86.ret
  not5_1:
    x86.xor rax, rax
    x86.ret
  }
}
---

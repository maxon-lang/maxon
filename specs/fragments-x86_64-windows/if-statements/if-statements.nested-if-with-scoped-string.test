// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(ptr: i64) -> i64 {
  entry:
    x86.test rcx, rcx
    x86.jne outer_1.after
  outer_1:
    x86.mov rax, 1
    x86.cmp rax, 1
    x86.jne checkInner_2.after
  checkInner_2:
    x86.mov rax, 1
    x86.ret
  checkInner_2.after:
  outer_1.after:
    x86.mov rax, 42
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call if-statements.test
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

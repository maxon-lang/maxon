// Test: docs-example-1
function main() returns ExitCode
	var x = 10
	if x > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, 10
    x86.cmp rax, 5
    x86.jle check_1.after
  check_1:
    x86.mov rax, 1
    x86.ret
  check_1.after:
    x86.mov rax, 0
    x86.ret
  }
}
---

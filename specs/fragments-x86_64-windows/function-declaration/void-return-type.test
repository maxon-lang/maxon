// Test: void-return-type
function doNothing()
end 'doNothing'

function main() returns ExitCode
	doNothing()
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @void-return-type.doNothing() {
  entry:
    x86.mov rax, 0
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call void-return-type.doNothing
    x86.mov [rbp+-8], rax
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  }
}
---

// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
  return x * 2
end 'double'

function quadruple(x Integer) returns Integer
  return double(double(x))
end 'quadruple'

function main() returns ExitCode
  return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @function-declaration.double(x: i64) -> i64 {
  entry:
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
  func @function-declaration.quadruple(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call function-declaration.double
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp function-declaration.double
  }
  func @function-declaration.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 3
    x86.call function-declaration.quadruple
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je function-declaration.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
  return 3 + 4
end 'add'

function main() returns ExitCode
  return add()
end 'main'
---
ExitCode: 7
---
module {
  func @function-declaration.add() -> i64 {
  entry:
    x86.mov rax, 3
    x86.mov rcx, 4
    x86.add rax, rcx
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call function-declaration.add
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: rc-field-overwrite-managed-list
typealias Integer = int(i64.min to i64.max)

type Val
  export var n Integer
end 'Val'

type Holder
  export var v Val

  export function set(newV Val)
    v = newV
  end 'set'
end 'Holder'

function main() returns ExitCode
  var h = Holder{v: Val{n: 0}}
  h.set(Val{n: 10})
  h.set(Val{n: 20})
  h.set(Val{n: 30})
  return h.v.n
end 'main'

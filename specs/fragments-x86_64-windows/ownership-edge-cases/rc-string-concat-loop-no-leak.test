// Test: rc-string-concat-loop-no-leak
function main() returns ExitCode
  var s = ""
  var a = "x"
  var i = 0
  while i < 5 'loop'
    s = s.concat(a)
    i = i + 1
  end 'loop'
  return s.byteLength()
end 'main'

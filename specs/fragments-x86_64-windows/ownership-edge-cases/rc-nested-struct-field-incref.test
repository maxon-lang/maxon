// Test: rc-nested-struct-field-incref
typealias Integer = int(i64.min to i64.max)

type Inner
  export var val Integer
end 'Inner'

type Outer
  export var child Inner
end 'Outer'

function main() returns ExitCode
  var inner = Inner{val: 55}
  var outer = Outer{child: inner}
  return outer.child.val
end 'main'
---
MmTrace: true
ExitCode: 55
Stderr: ```
sl_init
    os_alloc size=67108864
mm_alloc Inner #1 size=8 [ownership-edge-cases.main]
  sl_alloc Inner #1 size=40 class=5
mm_incref Inner #1 rc=1 [ownership-edge-cases.main]
mm_alloc Outer #2 size=8 [ownership-edge-cases.main]
  sl_alloc Outer #2 size=40 class=5
mm_incref Inner #1 rc=2 [ownership-edge-cases.main]
mm_incref Outer #2 rc=1 [ownership-edge-cases.main]
mm_decref Outer #2 rc=0 [ownership-edge-cases.main]
  mm_decref Inner #1 rc=1 [~Outer]
  mm_free Outer #2
    sl_free Outer #2 size=48 class=5
mm_decref Inner #1 rc=0 [ownership-edge-cases.main]
  mm_free Inner #1
    sl_free Inner #1 size=48 class=5
mm_raw_alloc #R1 size=40
  sl_alloc size=40 class=5
mm_raw_free #R1
  sl_free size=48 class=5
```

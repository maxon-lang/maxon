// Test: rc-return-transfers-ownership
typealias Integer = int(i64.min to i64.max)

type Token
	export var kind Integer
end 'Token'

function makeToken(k Integer) returns Token
	var t = Token{kind: k}
	return t
end 'makeToken'

function main() returns ExitCode
	var tok = makeToken(99)
	return tok.kind
end 'main'

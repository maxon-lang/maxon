// Test: rc-discarded-self-return
typealias Count = int(i64.min to i64.max)

type Counter
	export var value Count

	function increment() returns Counter
		value = value + 1
		return self
	end 'increment'
end 'Counter'

function main() returns ExitCode
	var c = Counter{value: 0}
	c.increment()
	return c.value
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, 1
    x86.add rdx, rax
    x86.mov rax, [rbp-8]
    x86.mov [rax+0], rdx
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call Counter.increment
    x86.mov rbx, [rbp-8]
    x86.xor rsi, rsi
    x86.mov rdi, 4294967295
    x86.cmp rbx, rdi
    x86.jg main.__range_panic_0
    x86.cmp rbx, rsi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rbx
    x86.epilogue
    x86.ret
  }
}
---

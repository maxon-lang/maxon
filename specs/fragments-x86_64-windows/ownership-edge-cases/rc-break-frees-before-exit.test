// Test: rc-break-frees-before-exit
typealias Integer = int(i64.min to i64.max)

type Step
	export var val Integer

	static function create(val Integer) returns Self
		return Self{val: val}
	end 'create'
end 'Step'

function main() returns ExitCode
	var i = 0
	while i < 10 'loop'
		@heap var s = Step.create(val: i)
		if s.val == 3 'stop'
			break
		end 'stop'
		i = i + 1
	end 'loop'
	return i
end 'main'

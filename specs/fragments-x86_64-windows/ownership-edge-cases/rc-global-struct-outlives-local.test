// Test: rc-global-struct-outlives-local
typealias Integer = int(i64.min to i64.max)

type Cfg
  export var level Integer
end 'Cfg'

var globalCfg = Cfg{level: 0}

function setup()
  globalCfg = Cfg{level: 42}
end 'setup'

function main() returns ExitCode
  setup()
  return globalCfg.level
end 'main'

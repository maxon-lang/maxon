// Test: rc-union-no-struct-payload-freed
typealias Integer = int(i64.min to i64.max)

union Color
  red
  green
  blue
end 'Color'

function colorCode(c Color) returns Integer
  let result = match c 'pick'
    Color.red   gives 1
    Color.green gives 2
    Color.blue  gives 3
  end 'pick'
  return result
end 'colorCode'

function main() returns ExitCode
  var c = Color.green
  return colorCode(c)
end 'main'
---
MmTrace: true
ExitCode: 2
Stderr: ```
sl_init
    os_alloc size=67108864
mm_raw_alloc #R1 size=40
  sl_alloc size=40 class=5
mm_raw_free #R1
  sl_free size=48 class=5
```

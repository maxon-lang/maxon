// Test: rc-enum-no-struct-payload-freed
typealias Integer = int(i64.min to i64.max)

enum Color
	red
	green
	blue
end 'Color'

function colorCode(c Color) returns Integer
	let result = match c 'pick'
		red   gives 1
		green gives 2
		blue  gives 3
	end 'pick'
	return result
end 'colorCode'

function main() returns ExitCode
	var c = Color.green
	return colorCode(c)
end 'main'
---
MmTrace: true
ExitCode: 2

// Test: pass-by-reference.struct-ref-field-mutation

typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer
end 'Point'

function setX(p Point)
	p.x = 99
end 'setX'

function main() returns ExitCode
	var p = Point{x: 1, y: 2}
	setX(p: p)
	print("{p.x}")
	return 0
end 'main'
---

// Test: pass-by-reference.nested-calls

typealias Integer = int(i64.min to i64.max)

function inner(x Integer)
	x = 77
end 'inner'

function outer(x Integer)
	inner(x: x)
end 'outer'

function main() returns ExitCode
	var n = 0
	outer(x: n)
	print("{n}")
	return 0
end 'main'
---
ExitCode: 0

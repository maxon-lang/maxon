// Test: modulo
function main() returns ExitCode
  return 17 mod 5
end 'main'
---
ExitCode: 2
---
module {
  func @arithmetic-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 17
    x86.mov rcx, 5
    x86.cqo
    x86.idiv rcx
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rcx, 4294967295
    x86.cmp rdx, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or rax, rcx
    x86.test rax, rax
    x86.je arithmetic-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

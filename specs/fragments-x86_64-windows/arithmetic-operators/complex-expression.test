// Test: complex-expression
function main() returns ExitCode
	var a = 10
	var b = 3
	var result = (a + b) * 2 - a / b
	return result
end 'main'
---
ExitCode: 23
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 3
    x86.lea rdx, [rax + rcx]
    x86.mov rbx, 2
    x86.imul rdx, rbx
    x86.mov [rbp-8], rdx
    x86.cqo
    x86.idiv rcx
    x86.mov rsi, [rbp-8]
    x86.sub rsi, rax
    x86.xor rdi, rdi
    x86.mov r8, 4294967295
    x86.cmp rsi, r8
    x86.jg main.__range_panic_0
    x86.cmp rsi, rdi
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rsi
    x86.epilogue
    x86.ret
  }
}
---

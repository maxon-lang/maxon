// Test: variable-division-optimizes
function main() returns ExitCode
	var a = 7
	var b = 2
	return a / b              // int/int = truncating int, returns 3
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 7
    x86.mov rcx, 2
    x86.cqo
    x86.idiv rcx
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

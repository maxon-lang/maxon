// Test: negative-division
function main() returns ExitCode
	var neg = -7
	let a = neg / 2           // -7/2 = -3 (truncating toward zero)
	if a == -3 'pass'
			return 0
	end 'pass'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x86.mov rax, -7
    x86.mov rcx, 2
    x86.cqo
    x86.idiv rcx
    x86.mov rdx, -3
    x86.cmp rax, rdx
    x86.jne main.pass_0.after
  pass_0:
    x86.xor rax, rax
    x86.ret
  pass_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

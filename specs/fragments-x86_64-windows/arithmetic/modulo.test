// Test: modulo
function main() returns ExitCode
	return 17 mod 5
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 17
    x86.cqo
    x86.mov rcx, 5
    x86.idiv rcx
    x86.test rdx, rdx
    x86.setl rax
    x86.mov rcx, 4294967295
    x86.cmp rdx, rcx
    x86.setg rcx
    x86.or rax, rcx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

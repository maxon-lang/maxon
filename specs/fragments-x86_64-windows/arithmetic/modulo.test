// Test: modulo
function main() returns ExitCode
	return 17 mod 5
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 17
    x86.mov rcx, 5
    x86.cqo
    x86.idiv rcx
    x86.xor rax, rax
    x86.mov rcx, 4294967295
    x86.cmp rdx, rcx
    x86.jg main.__range_panic_0
    x86.cmp rdx, rax
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	var preserved = x + 1
	var result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
module {
  func @arithmetic.modLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.add r8, rax
    x86.mov rbx, rdx
    x86.mov [rbp-8], rdx
    x86.mov rax, rcx
    x86.cqo
    x86.idiv rbx
    x86.lea rax, [rdx + r8]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 3
    x86.mov r8, 5
    x86.call arithmetic.modLive
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

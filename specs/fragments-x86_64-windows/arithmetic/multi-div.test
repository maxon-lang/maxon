// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
	var r1 = a / b
	var r2 = c / d
	return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
	return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @multi-div.multiDiv(ptr: i64, ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, r8
    x86.mov rbx, rdx
    x86.cqo
    x86.idiv r9
    x86.mov [rbp+-8], rax
    x86.mov rax, rcx
    x86.cqo
    x86.idiv rbx
    x86.mov rcx, [rbp+-8]
    x86.add rax, rcx
    x86.mov rcx, -9223372036854775807
    x86.cmp rax, rcx
    x86.jge __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 2
    x86.mov r8, 20
    x86.mov r9, 4
    x86.call multi-div.multiDiv
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

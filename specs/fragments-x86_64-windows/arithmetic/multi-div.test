// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @arithmetic.multiDiv(a: i64, b: i64, c: i64, d: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rbx, rdx
    x86.mov [rbp-8], rdx
    x86.mov rax, rcx
    x86.cqo
    x86.idiv rbx
    x86.mov [rbp-16], rax
    x86.mov rax, r8
    x86.cqo
    x86.idiv r9
    x86.mov rcx, [rbp-16]
    x86.lea rax, [rcx + rax]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 2
    x86.mov r8, 20
    x86.mov r9, 4
    x86.call arithmetic.multiDiv
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.movzx rdx, rdxb
    x86.or rcx, rdx
    x86.test rcx, rcx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: div-loop

typealias Integer = int(i64.min to i64.max)

function divLoop(n Integer) returns Integer
	var sum = 0
	var i = 1
	while i <= n 'loop'
		sum = sum + trunc(100 / i)
		i = i + 1
	end 'loop'
	return sum
end 'divLoop'

function main() returns ExitCode
	return divLoop(5)
end 'main'
---
ExitCode: 228
---
module {
  func @div-loop.divLoop(ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.mov [rbp+-24], rcx
    x86.mov rax, 1
    x86.mov [rbp-16], rax
  cond:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp+-24]
    x86.cmp rcx, rdx
    x86.jg exit
  body:
    x86.mov rax, [rbp+-16]
    x86.mov rcx, rax
    x86.add rcx, 1
    x86.mov rax, 100
    x86.cqo
    x86.mov rbx, [rbp+-16]
    x86.idiv rbx
    x86.mov rdx, [rbp+-8]
    x86.mov rbx, rdx
    x86.add rbx, rax
    x86.mov [rbp-8], rbx
    x86.mov [rbp-16], rcx
    x86.jmp cond
  exit:
    x86.mov rax, [rbp+-8]
    x86.mov rcx, -9223372036854775807
    x86.cmp rax, rcx
    x86.jge __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call div-loop.divLoop
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}

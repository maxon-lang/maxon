// Test: register-pressure

typealias Integer = int(i64.min to i64.max)

function manyVars(a Integer, b Integer, c Integer, d Integer, e Integer, f Integer) returns Integer
	var v1 = a + 1
	var v2 = b + 2
	var v3 = c + 3
	var v4 = d + 4
	var v5 = e + 5
	var v6 = f + 6
	var v7 = v1 + v2
	var v8 = v3 + v4
	var v9 = v5 + v6
	var v10 = v7 + v8
	var v11 = v9 + v10
	var v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
	return v12
end 'manyVars'

function main() returns ExitCode
	return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
module {
  func @register-pressure.manyVars(ptr: i64, ptr: i64, ptr: i64, ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.add r9, 4
    x86.add r8, 3
    x86.mov rax, r8
    x86.add rax, r9
    x86.add rdx, 2
    x86.add rcx, 1
    x86.mov rbx, rcx
    x86.add rbx, rdx
    x86.add rbx, rax
    x86.add rdi, 6
    x86.add rsi, 5
    x86.mov rax, rsi
    x86.add rax, rdi
    x86.add rax, rbx
    x86.add rax, rcx
    x86.add rax, rdx
    x86.add rax, r8
    x86.add rax, r9
    x86.add rax, rsi
    x86.add rax, rdi
    x86.mov rcx, -9223372036854775807
    x86.cmp rax, rcx
    x86.jge __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.mov rdx, 2
    x86.mov r8, 3
    x86.mov r9, 4
    x86.mov rsi, 5
    x86.mov rdi, 6
    x86.call register-pressure.manyVars
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}

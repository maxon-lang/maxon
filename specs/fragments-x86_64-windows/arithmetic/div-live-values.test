// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
	var preserved = x + 1
	var result = a / b
	return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
	return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @div-live-values.divLive(ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.add r8, 1
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.cqo
    x86.idiv rcx
    x86.add rax, r8
    x86.mov rcx, -9223372036854775807
    x86.cmp rax, rcx
    x86.jge __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 2
    x86.mov r8, 5
    x86.call div-live-values.divLive
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
}
---

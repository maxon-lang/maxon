// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
  var preserved = x + 1
  var result = a / b
  return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
  return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @arithmetic.divLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.add r8, rax
    x86.mov rbx, rdx
    x86.mov [rbp-8], rdx
    x86.mov rax, rcx
    x86.cqo
    x86.idiv rbx
    x86.add rax, r8
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 2
    x86.mov r8, 5
    x86.call arithmetic.divLive
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax
    x86.test rcx, rcx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_17]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

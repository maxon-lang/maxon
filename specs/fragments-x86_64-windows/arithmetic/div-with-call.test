// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	var temp = trunc(a / b)
	var result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @div-with-call.helper(ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.imul rcx, rax
    x86.mov rax, -9223372036854775807
    x86.cmp rcx, rax
    x86.jge __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  }
  func @div-with-call.divCall(ptr: i64, ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.cqo
    x86.idiv rcx
    x86.mov rcx, rax
    x86.mov [rbp+-8], rcx
    x86.call div-with-call.helper
    x86.mov rcx, [rbp+-8]
    x86.add rax, rcx
    x86.mov rcx, -9223372036854775807
    x86.cmp rax, rcx
    x86.jge __range_ok_2
  __range_panic_2:
    x86.lea rax, [rip+__panic_msg_2]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_2:
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 2
    x86.call div-with-call.divCall
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_3
  __range_panic_3:
    x86.lea rax, [rip+__panic_msg_3]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_3:
    x86.epilogue
    x86.ret
  }
}
---

// Test: division
function main() returns ExitCode
  return trunc(100 / 4)
end 'main'
---
ExitCode: 25
---
module {
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 100
    x86.mov rcx, 4
    x86.cqo
    x86.idiv rcx
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: division
function main() returns ExitCode
	return trunc(100 / 4)
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 100
    x86.cqo
    x86.mov rcx, 4
    x86.idiv rcx
    x86.test rax, rax
    x86.setl rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rdx
    x86.or rcx, rdx
    x86.je __range_ok_1
  __range_panic_1:
    x86.lea rax, [rip+__panic_msg_1]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_1:
    x86.epilogue
    x86.ret
  }
}
---

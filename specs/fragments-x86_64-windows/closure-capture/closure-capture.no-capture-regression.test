    x86.prologue stack_size=16
    x86.lea_func rax, [__closure_0]
    x86.mov rcx, rax
    x86.xor rdx, rdx
    x86.mov r8, 10
    x86.call closure-capture.apply
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
  func @__closure_0(n: i64) -> i64 {
  entry:
    x86.mov rax, 3
    x86.imul rcx, rax
    x86.mov rax, rcx
    x86.ret
  }
}

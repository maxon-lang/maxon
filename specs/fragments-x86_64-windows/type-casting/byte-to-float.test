// Test: byte-to-float

typealias Float = float(f64.min to f64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	var b = 50 as Byte
	var f = b as Float
	return trunc(f)
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 50
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.cvtsi2sd xmm0, rax
    x86.cvttsd2si rdx, xmm0
    x86.xor rbx, rbx
    x86.cmp rdx, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

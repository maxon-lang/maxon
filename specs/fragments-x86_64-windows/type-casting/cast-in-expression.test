// Test: cast-in-expression

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	var b = 10 as Byte
	var result = b as Integer + 32
	return result
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov rdx, 32
    x86.add rax, rdx
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.jg main.__range_panic_0
    x86.cmp rax, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.epilogue
    x86.ret
  }
}
---

// Test: chained-byte-int-float

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	var b = 25 as Byte
	var i = b as Integer
	var f = i as Float
	return trunc(f)
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 25
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.cvtsi2sd xmm0, rax
    x86.cvttsd2si rdx, xmm0
    x86.xor rbx, rbx
    x86.mov rsi, 4294967295
    x86.cmp rdx, rsi
    x86.jg main.__range_panic_0
    x86.cmp rdx, rbx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
}
---

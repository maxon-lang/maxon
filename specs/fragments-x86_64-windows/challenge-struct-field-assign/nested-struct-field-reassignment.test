    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.lea_func rax, [__destruct_Outer]
    x86.mov rdx, rax
    x86.mov rcx, 8
    x86.mov r8, 2
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.mov [rdx+0], rcx
    x86.call mm_incref
    x86.mov rbx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov rcx, 10
    x86.call Inner.create
    x86.mov [rbp-8], rax
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Outer.create
    x86.mov [rbp-16], rax
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rcx+0]
    x86.mov [rbp-24], rdx
    x86.mov rbx, 42
    x86.mov rsi, [rbp-24]
    x86.mov [rsi+0], rbx
    x86.mov rdi, [rbp-16]
    x86.mov r8, [rdi+0]
    x86.mov [rbp-32], r8
    x86.mov r9, [rbp-32]
    x86.mov rax, [r9+0]
    x86.xor rcx, rcx
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.jg main.__range_panic_0
    x86.cmp rax, rcx
    x86.jl main.__range_panic_0
    x86.jmp main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_0]
    x86.mov rcx, rax
    x86.call mrt_panic
  __range_ok_0:
    x86.mov rbx, [rbp-16]
    x86.mov [rbp-40], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rax, [rbp-40]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Inner(ptr: i64) {
  entry:
    x86.jmp __destruct_Inner.done
  done:
    x86.ret
  }
  func @__destruct_Outer(ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_2

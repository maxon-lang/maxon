// Test: byte-from-hex

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var b = 0xff as Byte
  return b as Integer
end 'main'
---
ExitCode: 255
---
module {
  func @byte-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 255
    x86.mov rcx, 255
    x86.and rax, rcx
    x86.mov [rbp-8], rax
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je byte-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

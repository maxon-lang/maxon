    x86.mov rcx, [rax+8]
    x86.mov [rbp-16], rcx
    x86.test rcx, rcx
    x86.jz __nonnull_skip_22
    x86.call mm_decref
    x86.label __nonnull_skip_22
    x86.jmp __destruct_DepArray.done
  done:
    x86.epilogue
    x86.ret
  }
}

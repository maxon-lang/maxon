// Test: nested-parentheses
function main() returns int
  return ((5 + 3) * 2) - 6
end 'main'
---
ExitCode: 10
---
module {
  func @parentheses.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.add eax, ecx
    x86.mov edx, 2
    x86.imul eax, edx
    x86.mov ebx, 6
    x86.sub eax, ebx
    x86.ret
  }
}
---

// Test: docs-example-1
function main() returns int
  var a = 2 + 3 * 4      // 14 (multiply first)
  var b = (2 + 3) * 4    // 20 (add first)
  return a+b
end 'main'

---
ExitCode: 34
---
module {
  func @parentheses.main() -> i64 {
  entry:
    x86.mov eax, 2
    x86.mov ecx, 3
    x86.mov edx, 4
    x86.imul ecx, edx
    x86.add eax, ecx
    x86.mov ebx, 2
    x86.mov esi, 3
    x86.add ebx, esi
    x86.mov edi, 4
    x86.imul ebx, edi
    x86.add eax, ebx
    x86.ret
  }
}

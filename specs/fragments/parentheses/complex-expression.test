// Test: complex-expression
function main() returns int
  var result = trunc((10 + (2 * 3)) / (4 - 2))
  return result
end 'main'
---
ExitCode: 8
---
module {
  func @parentheses.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 3
    x86.imul ecx, edx
    x86.add eax, ecx
    x86.mov ebx, 4
    x86.mov esi, 2
    x86.sub ebx, esi
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ebx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si edi, xmm2
    x86.mov eax, edi
    x86.ret
  }
}
---

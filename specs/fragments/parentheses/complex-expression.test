// Test: complex-expression
function main() returns Integer
  var result = trunc((10 + (2 * 3)) / (4 - 2))
  return result
end 'main'
---
ExitCode: 8
---
module {
  func @parentheses.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 3
    x86.imul ecx, edx
    x86.add eax, ecx
    x86.mov ebx, 4
    x86.mov esi, 2
    x86.sub ebx, esi
    x86.mov [rbp-8], eax
    x86.cqo
    x86.idiv ebx
    x86.epilogue
    x86.ret
  }
}
---

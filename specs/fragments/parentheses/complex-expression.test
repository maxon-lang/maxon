// Test: complex-expression
function main() returns ExitCode
  var result = trunc((10 + (2 * 3)) / (4 - 2))
  return result
end 'main'
---
ExitCode: 8
---
module {
  func @parentheses.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 10
    x86.mov edx, 2
    x86.mov ebx, 3
    x86.imul edx, ebx
    x86.add ecx, edx
    x86.mov esi, 4
    x86.mov edi, 2
    x86.sub esi, edi
    x86.mov eax, ecx
    x86.cqo
    x86.idiv esi
    x86.mov [rbp-16], eax
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je parentheses.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-24], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

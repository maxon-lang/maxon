// Test: docs-example-1
function main() returns ExitCode
  var s = "Hi"
  for ch in s 'chars'
    // ch has type 'character' (inferred from string's Element type - grapheme cluster)
    print("{ch}\n")
  end 'chars'
  return 0
end 'main'


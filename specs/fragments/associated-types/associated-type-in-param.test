    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, 8
    x86.mov [rbp-24], ebx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-16]
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @IntSum.total(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.mov rdx, rsi
    x86.call IntSum.add
    x86.mov [rbp-8], eax
    x86.mov r8, 32
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call IntSum.add
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]

    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov ecx, 10
    x86.xor edx, edx
    x86.mov [rbp-8], edx
    x86.lea rbx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.lea rsi, [rbp-16]
    x86.mov rdx, rsi

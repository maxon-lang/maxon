    x86.mov eax, [rbp-24]
    x86.add eax, r8
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [eax+0], edx
    x86.mov eax, [rbp-8]
    x86.mov edx, [rbp-32]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }

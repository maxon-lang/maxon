// Test: method-call-syntax

typealias Integer = int(i64.min to i64.max)

interface Addable
  function addOne() returns Integer
end 'Addable'

type Number implements Addable
  var value Integer

  function addOne() returns Integer
    return value + 1
  end 'addOne'
end 'Number'

function main() returns ExitCode
  var n = Number{value: 41}
  return n.addOne()
end 'main'

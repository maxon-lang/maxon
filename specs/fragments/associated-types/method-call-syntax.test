// Test: method-call-syntax
interface Addable
  function addOne() returns int
end 'Addable'

type Number is Addable
  var value int

  function addOne() returns int
    return value + 1
  end 'addOne'
end 'Number'

function main() returns int
  var n = Number{value: 41}
  return n.addOne()
end 'main'
---
ExitCode: 42
---
module {
  func @Number.addOne(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.lea eax, [edx + eax]
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 41
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.epilogue
    x86.jmp Number.addOne
  }
}
---

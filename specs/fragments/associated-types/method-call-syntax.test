// Test: method-call-syntax
interface Addable
  function addOne() returns int
end 'Addable'

type Number is Addable
  var value int

  function addOne() returns int
    return value + 1
  end 'addOne'
end 'Number'

function main() returns int
  var n = Number{value: 41}
  return n.addOne()
end 'main'
---
ExitCode: 42
---
module {
  func @Number.addOne(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 41
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call Number.addOne
    x86.epilogue
    x86.ret
  }
}
---

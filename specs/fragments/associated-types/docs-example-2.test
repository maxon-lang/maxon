// Test: docs-example-2
interface Summable uses Element
  function sum() returns Element
end 'Summable'

type IntPair is Summable with int
  var a int
  var b int

  function sum() returns int
    return a + b
  end 'sum'
end 'IntPair'

function main() returns int
  var p = IntPair{a: 10, b: 32}
  return p.sum()
end 'main'

---
ExitCode: 42
---
module {
  func @IntPair.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.add ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov [ebx+8], edi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.lea rdx, [rbp-16]
    x86.mov rcx, rdx
    x86.call IntPair.sum
    x86.epilogue
    x86.ret
  }
}

// Test: docs-example-2
interface Summable uses Element
  function sum() returns Element
end 'Summable'

type IntPair implements Summable with int
  var a int
  var b int

  function sum() returns int
    return a + b
  end 'sum'
end 'IntPair'

function main() returns int
  var p = IntPair{a: 10, b: 32}
  return p.sum()
end 'main'

---
ExitCode: 42
---
module {
  func @IntPair.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 32
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp IntPair.sum
  }
}

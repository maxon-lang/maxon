    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rdi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call SingleByte.getByte
    x86.mov [rbp-16], rax
    x86.xor r8, r8
    x86.cmp rax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or r9, rax
    x86.test r9, r9
    x86.je associated-types.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]

    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.movzx rdx, byte ptr [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }

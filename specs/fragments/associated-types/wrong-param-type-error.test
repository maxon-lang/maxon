// Test: wrong-param-type-error
interface Acceptor uses Input
  function accept(val Input) returns int
end 'Acceptor'

type WrongParam implements Acceptor with float
  var value int

  function accept(val int) returns int
    return value + val
  end 'accept'
end 'WrongParam'

function main() returns int
  return 0
end 'main'

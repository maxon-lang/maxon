// Test: multiple-associated-types
interface Pair uses First, Second
  function getFirst() returns First
  function getSecond() returns Second
end 'Pair'

type IntFloat implements Pair with int, float
  var a int
  var b float

  function getFirst() returns int
    return a
  end 'getFirst'

  function getSecond() returns float
    return b
  end 'getSecond'
end 'IntFloat'

function main() returns int
  var p = IntFloat{a: 40, b: 2.5}
  var x = p.getFirst()
  var y = trunc(p.getSecond())
  return x + y
end 'main'
---
ExitCode: 42
---
module {
  func @IntFloat.getFirst(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @IntFloat.getSecond(__self_ptr: i64) -> f64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.movsd xmm0, [eax+8]
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 40
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov ecx, 16
    x86.movsd [rbp-16], xmm0
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 40
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.movsd xmm0, [rbp-16]
    x86.movsd [esi+8], xmm0
    x86.mov rcx, [rbp-8]
    x86.call IntFloat.getFirst
    x86.mov r8, [rbp-8]
    x86.mov [rbp-24], eax
    x86.mov rcx, r8
    x86.call IntFloat.getSecond
    x86.cvttsd2si r9, xmm0
    x86.mov eax, [rbp-24]
    x86.add eax, r9
    x86.epilogue
    x86.ret
  }

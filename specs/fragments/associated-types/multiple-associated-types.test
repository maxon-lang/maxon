    x86.movsd xmm1, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-24]
    x86.mov [ecx+0], edx
    x86.movsd xmm2, [rbp-16]
    x86.movsd [ecx+8], xmm2
    x86.movsd xmm0, xmm1
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 40
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd [rbp-8], xmm0
    x86.mov [rbp-16], eax
    x86.lea rcx, [rbp-16]
    x86.call IntFloat.getFirst
    x86.movsd xmm1, [rbp-8]
    x86.mov edx, [rbp-16]

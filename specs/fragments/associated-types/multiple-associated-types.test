    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-24]
    x86.mov [edx+0], ebx
    x86.movsd xmm1, [rbp-16]
    x86.movsd [edx+8], xmm1
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }

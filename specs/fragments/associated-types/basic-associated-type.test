// Test: basic-associated-type

typealias Integer = int(i64.min to i64.max)

interface Wrapper uses Inner
  function unwrap() returns Inner
end 'Wrapper'

type IntBox implements Wrapper with Integer
  var value Integer

  function unwrap() returns Integer
    return value
  end 'unwrap'
end 'IntBox'

function main() returns ExitCode
  var box = IntBox{value: 42}
  return box.unwrap()
end 'main'
---
ExitCode: 42
---
module {
  func @IntBox.unwrap(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov rax, [rbp-8]
    x86.mov rdx, [rax+0]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  }
  func @associated-types.main() -> u32 {

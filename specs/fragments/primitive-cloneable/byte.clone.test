// Test: byte.clone
function main() returns int
  var x = 65 as byte
  var y = x.clone() as int
  return y
end 'main'
---
ExitCode: 65
---
module {
  func @primitive-cloneable.main() -> i64 {
  entry:
    x86.mov eax, 65
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.jmp stdlib.byte.clone
  }
}
---

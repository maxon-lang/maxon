// Test: unary-negate-literal
function main() returns int
  var x = -5
  return 47 + x
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, -5
    x86.mov [rbp-8], eax
    x86.mov ecx, 47
    x86.add ecx, eax
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

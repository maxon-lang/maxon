// Test: unary-negate-literal
function main() returns ExitCode
  var x = -5
  return 47 + x
end 'main'
---
ExitCode: 42
---
module {
  func @unary-negation.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, -5
    x86.mov ecx, 47
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je unary-negation.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: unary-negate-float
function main() returns int
  var f = 3.5
  var g = -f
  return trunc(g + 45.5)
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.5]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd xmm2, xmm1
    x86.subsd xmm2, xmm0
    x86.movsd xmm3, [rip+__float_45.5]
    x86.movsd xmm4, xmm2
    x86.addsd xmm4, xmm3
    x86.cvttsd2si eax, xmm4
    x86.ret
  }
}
---

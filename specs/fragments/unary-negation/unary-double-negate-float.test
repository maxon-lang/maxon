// Test: unary-double-negate-float
function main() returns Integer
  var f = 42.0
  var g = --f
  return trunc(g)
end 'main'
---
ExitCode: 42
---
module {
  func @unary-negation.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_42]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd xmm2, xmm1
    x86.subsd xmm2, xmm0
    x86.movsd xmm3, [rip+__float_0]
    x86.movsd xmm4, xmm3
    x86.subsd xmm4, xmm2
    x86.cvttsd2si eax, xmm4
    x86.ret
  }
}

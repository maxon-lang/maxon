// Test: unary-negate-expression
function main() returns int
  var x = 10
  var y = 5
  var z = -(x + y)
  return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @unary-negation.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.mov ecx, 5
    x86.mov [rbp-16], ecx
    x86.add eax, ecx
    x86.xor edx, edx
    x86.sub edx, eax
    x86.mov [rbp-24], edx
    x86.mov ebx, 57
    x86.add ebx, edx
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
}
---

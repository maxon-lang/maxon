// Test: unary-negate-expression
function main() returns int
  var x = 10
  var y = 5
  var z = -(x + y)
  return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.add eax, ecx
    x86.xor edx, edx
    x86.sub edx, eax
    x86.mov ebx, 57
    x86.lea eax, [ebx + edx]
    x86.ret
  }
}
---

// Test: unary-negate-expression
function main() returns ExitCode
  var x = 10
  var y = 5
  var z = -(x + y)
  return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @unary-negation.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.add eax, ecx
    x86.xor edx, edx
    x86.sub edx, eax
    x86.mov ebx, 57
    x86.add ebx, edx
    x86.mov [rbp-8], ebx
    x86.xor esi, esi
    x86.cmp ebx, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rbx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je unary-negation.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

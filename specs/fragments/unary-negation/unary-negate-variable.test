// Test: unary-negate-variable
function main() returns int
  var x = 47
  var y = -x
  return 42 + y
end 'main'
---
ExitCode: -5
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 47
    x86.xor ecx, ecx
    x86.sub ecx, eax
    x86.mov edx, 42
    x86.add edx, ecx
    x86.mov eax, edx
    x86.ret
  }
}
---

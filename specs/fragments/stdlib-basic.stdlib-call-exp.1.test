// Test: stdlib-basic.stdlib-call-exp.1
function main() returns int
    var result = Math.exp(0.0)
    if result == 1.0 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 0
    %tmp_call = call f64 @Math$exp(%tmp_fconst)
    %tmp_fconst.1 = const.f64 f64 1
    %tmp_fcmp = fcmp.eq i64 %tmp_call %tmp_fconst.1
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 42
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

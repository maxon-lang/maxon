// Test: arithmetic-operators.negative-division.1
function main() returns int
    var neg = -7
    let a = trunc(neg / 2)    // -7/2 = -3.5, trunc = -3 (toward zero)
    if a == -3 'pass'
      return 0
    end 'pass'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 -7
    %tmp_const.1 = const.i64 i64 2
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_sitofp.1 = sitofp f64 %tmp_const.1
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %tmp_const.2 = const.i64 i64 -3
    %tmp_icmp = icmp.eq i64 %tmp_fptosi %tmp_const.2
    br.cond %tmp_icmp @then$pass_1 @end$pass_2
then$pass_1:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
end$pass_2:
    %tmp_const.4 = const.i64 i64 1
    ret %tmp_const.4
}

---

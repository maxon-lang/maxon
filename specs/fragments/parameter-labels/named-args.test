// Test: named-args
function add(a int, b int) returns int
  return a + b
end 'add'

function main() returns int
  return add(a: 3, b: 4)
end 'main'
---
ExitCode: 7
---
module {
  func @add(a: i64, b: i64) -> i64 {
  entry:
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp add
  }
}

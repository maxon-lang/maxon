// Test: default-param-named

typealias Integer = int(i64.min to i64.max)

function repeat(value Integer, times Integer = 1) returns Integer
  return value * times
end 'repeat'

function main() returns ExitCode
  return repeat(value: 7, times: 6)
end 'main'

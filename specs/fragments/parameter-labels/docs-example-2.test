// Test: docs-example-2
function subtract(a int, b int) returns int
  return a - b
end 'subtract'

function main() returns int
  return subtract(b: 3, a: 10)
end 'main'

---
ExitCode: 7
---
module {
  func @parameter-labels.subtract(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.sub ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @parameter-labels.main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 10
    x86.mov rdx, rax
    x86.call parameter-labels.subtract
    x86.ret
  }
}

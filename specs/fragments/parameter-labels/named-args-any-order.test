    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov ecx, 10
    x86.mov rdx, rax
    x86.call parameter-labels.subtract
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je parameter-labels.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

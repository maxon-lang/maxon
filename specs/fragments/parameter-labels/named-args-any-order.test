// Test: named-args-any-order
function subtract(a int, b int) returns int
    return a - b
end 'subtract'

function main() returns int
    return subtract(b: 3, a: 10)
end 'main'
---
ExitCode: 7
---
func.func @subtract(%a: i64, %b: i64) -> i64 {
  ^entry(%a: i64, %b: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.mov rdx, rax
    x86.sub rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov rcx, 3
    x86.mov r10, rax
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call subtract
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

// Test: named-args-any-order
function subtract(a Integer, b Integer) returns Integer
  return a - b
end 'subtract'

function main() returns Integer
  return subtract(b: 3, a: 10)
end 'main'
---
ExitCode: 7
---
module {
  func @parameter-labels.subtract(a: i64, b: i64) -> i64 {
  entry:
    x86.sub ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @parameter-labels.main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 10
    x86.mov rdx, rax
    x86.jmp parameter-labels.subtract
  }
}

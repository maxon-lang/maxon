// Test: named-args-multiply
function multiply(x int, y int) returns int
  return x * y
end 'multiply'

function main() returns int
  return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
module {
  func @multiply(x: i64, y: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 6
    x86.mov ecx, 7
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call multiply
    x86.ret
  }
}
---

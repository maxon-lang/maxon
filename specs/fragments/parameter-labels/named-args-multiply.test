// Test: named-args-multiply
function multiply(x int, y int) returns int
    return x * y
end 'multiply'

function main() returns int
    return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.epilogue
    x86.ret
}
---

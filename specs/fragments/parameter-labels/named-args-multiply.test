// Test: named-args-multiply
function multiply(x Integer, y Integer) returns Integer
  return x * y
end 'multiply'

function main() returns Integer
  return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
module {
  func @parameter-labels.multiply(x: i64, y: i64) -> i64 {
  entry:
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @parameter-labels.main() -> i64 {
  entry:
    x86.mov eax, 6
    x86.mov ecx, 7
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp parameter-labels.multiply
  }
}
---

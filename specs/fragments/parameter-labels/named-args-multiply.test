// Test: named-args-multiply
function multiply(x int, y int) returns int
    return x * y
end 'multiply'

function main() returns int
    return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
func.func @multiply(%x: i64, %y: i64) -> i64 {
  ^entry(%x: i64, %y: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.imul rdx, rax, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 6
    x86.mov rcx, 7
    x86.mov r10, rax
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call multiply
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

// Test: default-param-omitted
function repeat(value int, times int = 2) returns int
  return value * times
end 'repeat'

function main() returns int
  return repeat(value: 21)
end 'main'
---
ExitCode: 42
---
module {
  func @parameter-labels.repeat(value: i64, times: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @parameter-labels.main() -> i64 {
  entry:
    x86.mov eax, 21
    x86.mov ecx, 2
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call parameter-labels.repeat
    x86.ret
  }
}
---

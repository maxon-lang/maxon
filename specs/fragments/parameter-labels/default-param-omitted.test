// Test: default-param-omitted
function repeat(value int, times int = 2) returns int
    return value * times
end 'repeat'

function main() returns int
    return repeat(value: 21)
end 'main'
---
ExitCode: 42
---
func.func @repeat(%value: i64, %times: i64) -> i64 {
  ^entry(%value: i64, %times: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.imul rdx, rax, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 21
    x86.mov rcx, 2
    x86.mov r10, rax
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call repeat
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

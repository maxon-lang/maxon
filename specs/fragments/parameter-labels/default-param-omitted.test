// Test: default-param-omitted
function repeat(value Integer, times Integer = 2) returns Integer
  return value * times
end 'repeat'

function main() returns Integer
  return repeat(value: 21)
end 'main'
---
ExitCode: 42
---
module {
  func @parameter-labels.repeat(value: i64, times: i64) -> i64 {
  entry:
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @parameter-labels.main() -> i64 {
  entry:
    x86.mov eax, 21
    x86.mov ecx, 2
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp parameter-labels.repeat
  }
}

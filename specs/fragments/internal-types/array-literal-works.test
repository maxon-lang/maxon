// Test: array-literal-works
function main() returns int
  var arr = [1, 2, 3, 4, 5]
  return arr.count()
end 'main'
---
ExitCode: 5
---
module {
  func @internal-types.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 5
    x86.xor ecx, ecx
    x86.mov edx, 8
    x86.xor ebx, ebx
    x86.lea_rdata rsi, [__const_array_internal-types.main_arr]
    x86.mov rdi, rsi
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], ebx
    x86.lea r8, [rbp-40]
    x86.mov rcx, r8
    x86.call IntArray.count
    x86.epilogue
    x86.ret
  }
}
---

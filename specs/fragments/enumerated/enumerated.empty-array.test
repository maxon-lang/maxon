// Test: enumerated.empty-array
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
  var arr = IntArray{}
  var count = 0
  for (index, value) in arr.enumerated() 'loop'
    count = count + 1
  end 'loop'
  print("{count}\n")
  return 0
end 'main'

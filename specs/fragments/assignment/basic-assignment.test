// Test: basic-assignment
function main() returns int
  var x = 3
  x = x + 2
  return x
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.add eax, ecx
    x86.mov [rbp-8], eax
    x86.epilogue
    x86.ret
  }
}
---

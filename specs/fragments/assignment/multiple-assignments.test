// Test: multiple-assignments
function main() returns int
  var x = 10
  var y = 20
  x = y
  y = 30
  return x + y
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 30
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
}
---

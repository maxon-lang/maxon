// Test: multiple-assignments
function main() returns int
  var x = 10
  var y = 20
  x = y
  y = 30
  return x + y
end 'main'
---
ExitCode: 50
---
module {
  func @assignment.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.mov ecx, 20
    x86.mov [rbp-16], ecx
    x86.mov [rbp-8], ecx
    x86.mov edx, 30
    x86.mov [rbp-16], edx
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

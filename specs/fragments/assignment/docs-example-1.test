// Test: docs-example-1
function main() returns Integer
  var x = 10
  x = 20          // Update x
  x = x + 5       // x is now 25
  return x
end 'main'

---
ExitCode: 25
---
module {
  func @assignment.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 5
    x86.add eax, ecx
    x86.ret
  }
}
---

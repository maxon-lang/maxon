// Test: docs-example-1
function main() returns int
    var x = 10
    x = 20          // Update x
    x = x + 5       // x is now 25
    return x
end 'main'

---
ExitCode: 25
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 25
    x86.epilogue
    x86.ret
}
---

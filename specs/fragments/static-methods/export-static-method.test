    x86.mov edx, [rbp-16]
    x86.mov ebx, [edx+0]
    x86.add ecx, ebx
    x86.mov [rbp-24], ecx
    x86.xor esi, esi
    x86.cmp ecx, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rcx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je static-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]

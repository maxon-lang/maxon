    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor rcx, rcx
    x86.call Factory.create
    x86.mov [rbp-16], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, [rbp-8]
    x86.mov esi, [ebx+8]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, rsi
    x86.xor r8, r8
    x86.call mm_move
    x86.mov edi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @static-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_symdata rax, [__tag_static-methods_main]
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov rcx, 100
    x86.call Factory.create
    x86.mov [rbp-16], eax
    x86.call Factory.zero
    x86.mov [rbp-24], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, [edx+0]
    x86.mov esi, [rbp-24]
    x86.mov edi, [esi+0]
    x86.add ebx, edi
    x86.mov [rbp-32], ebx
    x86.xor r8, r8
    x86.cmp ebx, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rbx, rax
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je static-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_32]

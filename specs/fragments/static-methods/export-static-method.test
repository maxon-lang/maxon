// Test: export-static-method
type Factory
  export var id int

  export static function create(val int) returns Factory
    return {id: val}
  end 'create'

  export static function zero() returns Factory
    return Factory.create(0)
  end 'zero'
end 'Factory'

function main() returns int
  var f1 = Factory.create(100)
  var f2 = Factory.zero()
  return f1.id + f2.id
end 'main'
---
ExitCode: 100
---
module {
  func @Factory.create(val: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 8
    x86.mov [rbp-16], ecx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @Factory.zero() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call Factory.create
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @static-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov rcx, rax
    x86.call Factory.create
    x86.mov [rbp-8], eax
    x86.call Factory.zero
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+0]
    x86.mov ebx, [rbp-16]
    x86.mov esi, [ebx+0]
    x86.lea eax, [edx + esi]
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @Factory.zero() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call Factory.create
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }

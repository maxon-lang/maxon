    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov r8, [rbp-8]
    x86.mov r9, [r8+8]
    x86.xor eax, eax
    x86.mov rcx, rdi
    x86.mov rdx, r9
    x86.mov r8, rax
    x86.call mm_move
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }

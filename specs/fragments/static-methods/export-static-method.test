    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @Factory.zero() -> i64 {

// Test: static-method-no-self
type Math
  var unused int

  static function add(a int, b int) returns int
    return a + b
  end 'add'
end 'Math'

function main() returns int
  return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
module {
  func @Math.add(a: i64, b: i64) -> i64 {
  entry:
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp Math.add
  }
}
---

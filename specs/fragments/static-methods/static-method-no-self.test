// Test: static-method-no-self

typealias Integer = int(i64.min to i64.max)

type Math
  var unused Integer

  static function add(a Integer, b Integer) returns Integer
    return a + b
  end 'add'
end 'Math'

function main() returns ExitCode
  return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
module {
  func @Math.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @static-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 20
    x86.mov rdx, 22
    x86.call Math.add
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je static-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

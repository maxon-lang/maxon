// Test: static-method-no-self
type Math
  var unused Integer

  static function add(a Integer, b Integer) returns Integer
    return a + b
  end 'add'
end 'Math'

function main() returns Integer
  return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
module {
  func @Math.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @static-methods.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp Math.add
  }
}
---

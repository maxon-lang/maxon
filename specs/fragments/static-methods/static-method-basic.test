// Test: static-method-basic

typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer

  static function make(v Integer) returns Box
    return Box{value: v}
  end 'make'
end 'Box'

function main() returns ExitCode
  var b = Box.make(42)
  return b.value
end 'main'
---
ExitCode: 42
---
module {
  func @Box.make(v: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], ecx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov rcx, 42
    x86.call Box.make
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-24], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je static-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

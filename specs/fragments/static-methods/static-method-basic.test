// Test: static-method-basic

typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer

  static function make(v Integer) returns Box
    return {value: v}
  end 'make'
end 'Box'

function main() returns ExitCode
  var b = Box.make(42)
  return b.value
end 'main'
---
ExitCode: 42
---
module {
  func @Box.make(v: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 8
    x86.mov [rbp-16], ecx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov rcx, rax
    x86.call Box.make
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+0]
    x86.mov [rbp-16], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je static-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

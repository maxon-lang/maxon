// Test: static-method-basic
type Box
  export var value Integer

  static function make(v Integer) returns Box
    return {value: v}
  end 'make'
end 'Box'

function main() returns Integer
  var b = Box.make(42)
  return b.value
end 'main'
---
ExitCode: 42
---
module {
  func @Box.make(v: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 8
    x86.mov [rbp-16], ecx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov rcx, rax
    x86.call Box.make
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, [ecx+0]
    x86.epilogue
    x86.ret
  }
}
---

// Test: static-method-basic
type Box
    export var value int

    static function make(v int) returns Box
        return {value: v}
    end 'make'
end 'Box'

function main() returns int
    var b = Box.make(42)
    return b.value
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 42
    x86.lea rbx, qword ptr [rbp-40]
    x86.mov r10, rbx
    x86.mov r11, rax
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Box.make
    x86.lea rax, qword ptr [rbp-48]
    x86.mov rcx, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rax
    x86.mov rsi, rbx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Box.make(%__sret: ptr<!maxon.struct<Box>>, %v: i64) {
  ^entry(%__sret: ptr<!maxon.struct<Box>>, %v: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov qword ptr [rdx], rcx
    x86.epilogue
    x86.ret
}
---

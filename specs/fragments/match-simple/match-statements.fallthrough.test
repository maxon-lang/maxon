// Test: match-statements.fallthrough
function main() returns ExitCode
  var x = 1
  var result = 0
  match x 'check'
    1 then result = result + 10 and fallthrough
    2 then result = result + 20
    default then result = result + 100
  end 'check'
  return result
end 'main'
---
ExitCode: 30
---
module {
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.xor edx, edx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.jmp match-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp1
  check_0.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 10
    x86.mov edx, [rbp-16]
    x86.add edx, ecx
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-32]
    x86.call mm_scope_exit
    x86.jmp match-simple.main.check_0.case1
  check_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.case2
  check_0.case1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov ecx, 20
    x86.mov edx, [rbp-16]
    x86.add edx, ecx
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-40]
    x86.call mm_scope_exit
    x86.jmp match-simple.main.check_0.merge
  check_0.case2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-48], eax
    x86.mov ecx, 100
    x86.mov edx, [rbp-16]
    x86.add edx, ecx
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-48]
    x86.call mm_scope_exit
    x86.jmp match-simple.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-56], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-simple.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_27]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-56]

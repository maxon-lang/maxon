// Test: match-statements.function-call

typealias Integer = int(i64.min to i64.max)

function double(n Integer) returns Integer
  return n * 2
end 'double'

function main() returns ExitCode
  var x = 2
  var result = 0
  match x 'process'
    1 then result = double(10)
    2 then result = double(20)
    default then result = 0
  end 'process'
  return result
end 'main'
---
ExitCode: 40
---
module {
  func @match-simple.double(n: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.process_0.cmp0
  process_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.process_0.cmp1
  process_0.case0:
    x86.mov rcx, 10
    x86.call match-simple.double
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.process_0.merge
  process_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.process_0.case2
  process_0.case1:
    x86.mov rcx, 20
    x86.call match-simple.double
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.process_0.merge
  process_0.case2:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.process_0.merge
  process_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-simple.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

// Test: docs-example-5
enum Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = Direction.north
  match dir 'navigate'
    Direction.north then return 1
    Direction.south then return 2
    Direction.east then return 3
    Direction.west then return 4
  end 'navigate'
end 'main'

---
ExitCode: 1
---
module {
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.navigate_0.cmp0
  navigate_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne match-simple.main.navigate_0.cmp1
  navigate_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  navigate_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.navigate_0.cmp2
  navigate_0.case1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  navigate_0.cmp2:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.navigate_0.cmp3
  navigate_0.case2:
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  navigate_0.cmp3:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-simple.main.navigate_0.merge
  navigate_0.case3:
    x86.mov eax, 4
    x86.epilogue
    x86.ret
  navigate_0.merge:
  }
}
---

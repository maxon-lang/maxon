// Test: docs-example-3
function main() returns int
  var x = 2
  let result = match x 'convert'
    1 gives 10
    2 gives 20
    3 gives 30
    default gives 0
  end 'convert'
  return result
end 'main'

---
ExitCode: 20
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.convert_0.cmp0
  convert_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.convert_0.cmp1
  convert_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.convert_0.merge
  convert_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.convert_0.cmp2
  convert_0.case1:
    x86.mov eax, 20
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.convert_0.merge
  convert_0.cmp2:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-simple.main.convert_0.case3
  convert_0.case2:
    x86.mov eax, 30
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.convert_0.merge
  convert_0.case3:
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.convert_0.merge
  convert_0.merge:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: match-expression.or-patterns
function main() returns int
  var x = 4
  let result = match x 'eval'
    1 or 2 gives 10
    3 or 4 gives 20
    default gives 0
  end 'eval'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 4
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, 2
    x86.cmp eax, ebx
    x86.sete esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-simple.main.eval_0.cmp1
  eval_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, 4
    x86.cmp eax, ebx
    x86.sete esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-simple.main.eval_0.case2
  eval_0.case1:
    x86.mov eax, 20
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.case2:
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.merge:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

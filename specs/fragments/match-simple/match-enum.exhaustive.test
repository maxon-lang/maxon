// Test: match-enum.exhaustive
union Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = Color.green
  match c 'check'
    Color.red then return 1
    Color.green then return 2
    Color.blue then return 3
  end 'check'
end 'main'
---
ExitCode: 2
---
module {
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov [rbp-16], ecx
    x86.jmp match-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp1
  check_0.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp2
  check_0.case1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov eax, 2
    x86.mov ecx, [rbp-32]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.merge
  check_0.case2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov eax, 3
    x86.mov ecx, [rbp-40]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

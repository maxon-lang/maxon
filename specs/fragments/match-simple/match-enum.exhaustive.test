// Test: match-enum.exhaustive
enum Color
  red
  green
  blue
end 'Color'

function main() returns int
  var c = Color.green
  match c 'check'
    Color.red then return 1
    Color.green then return 2
    Color.blue then return 3
  end 'check'
end 'main'
---
ExitCode: 2
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp2
  check_0.case1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.merge
  check_0.case2:
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

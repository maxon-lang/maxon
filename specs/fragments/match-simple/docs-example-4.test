// Test: docs-example-4
function main() returns Integer
  var role = 1
  var permissions = 0
  match role 'auth'
    1 then permissions = permissions + 100 and fallthrough
    2 then permissions = permissions + 10 and fallthrough
    3 then permissions = permissions + 1
    default then permissions = 0
  end 'auth'
  return permissions
end 'main'

---
ExitCode: 111
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.auth_0.cmp0
  auth_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.auth_0.cmp1
  auth_0.case0:
    x86.mov eax, 100
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-simple.main.auth_0.case1
  auth_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.auth_0.cmp2
  auth_0.case1:
    x86.mov eax, 10
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-simple.main.auth_0.case2
  auth_0.cmp2:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-simple.main.auth_0.case3
  auth_0.case2:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-simple.main.auth_0.merge
  auth_0.case3:
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.auth_0.merge
  auth_0.merge:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

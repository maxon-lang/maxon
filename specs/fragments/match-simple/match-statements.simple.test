// Test: match-statements.simple
function main() returns ExitCode
  var x = 2
  match x 'check'
    1 then return 10
    2 then return 20
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 20
---
module {
  func @match-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.jmp match-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 10
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.case2
  check_0.case1:
    x86.mov eax, 20
    x86.epilogue
    x86.ret
  check_0.case2:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

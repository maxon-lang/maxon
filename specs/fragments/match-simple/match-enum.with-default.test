// Test: match-enum.with-default
enum Color
  red
  green
  blue
end 'Color'

function main() returns int
  var c = Color.blue
  match c 'check'
    Color.red then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.jmp match-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne match-simple.main.check_0.case1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

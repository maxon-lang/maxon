// Test: match-expression.basic
function main() returns int
  var x = 2
  let result = match x 'eval'
    1 gives 10
    2 gives 20
    default gives 0
  end 'eval'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @match-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.jmp match-simple.main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-simple.main.eval_0.cmp1
  eval_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-simple.main.eval_0.case2
  eval_0.case1:
    x86.mov eax, 20
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.case2:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp match-simple.main.eval_0.merge
  eval_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.epilogue
    x86.ret
  }
}
---

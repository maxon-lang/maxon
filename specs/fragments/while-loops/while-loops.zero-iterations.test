// Test: while-loops.zero-iterations
function main() returns int
    var x = 10
    while x < 5 'loop'
        x = x + 1
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.jmp while.cond
  ^while.cond(%10: i64):
    x86.mov rax, 5
    x86.cmp rcx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body
    x86.jmp while.exit.args
    while.exit.args:
    x86.mov rax, rcx
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 1
    x86.mov r8, rcx
    x86.add r8, rdx
    x86.mov rcx, r8
    x86.jmp while.cond
  ^while.exit(%11: i64):
    x86.epilogue
    x86.ret
}
---

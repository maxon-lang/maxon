// Test: while-loops.zero-iterations
function main() returns int
    var x = 10
    while x < 5 'loop'
        x = x + 1
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 5
    x86.mov r8, 1
    x86.mov r9, 10
    x86.jmp while.cond
  ^while.cond(%9: i64):
    x86.cmp r9, rcx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, r9
    x86.add rdx, r8
    x86.mov r9, rdx
    x86.jmp while.cond
  ^while.exit:
    x86.mov rax, r9
    x86.epilogue
    x86.ret
}
---

// Test: while-loops.zero-iterations
function main() returns int
    var x = 10
    while x < 5 'loop'
        x = x + 1
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 10
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.jmp while.cond
  ^while.cond:
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 5
    x86.cmp rax, rdx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, qword ptr [rcx]
    x86.mov rax, 1
    x86.mov r8, rdx
    x86.add r8, rax
    x86.mov qword ptr [rcx], r8
    x86.jmp while.cond
  ^while.exit:
    x86.mov r8, qword ptr [rcx]
    x86.mov rax, r8
    x86.epilogue
    x86.ret
}
---

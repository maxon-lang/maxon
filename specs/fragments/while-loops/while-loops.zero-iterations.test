// Test: while-loops.zero-iterations
function main() returns Integer
  var x = 10
  while x < 5 'loop'
    x = x + 1
  end 'loop'
  return x
end 'main'
---
ExitCode: 10
---
module {
  func @while-loops.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge while-loops.main.loop_0.exit
  loop_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

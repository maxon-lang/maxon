// Test: while-loops.break
function main() returns int
    var x = 5
    while true 'loop'
        x = x + 2
        if x == 11 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 2
    x86.mov r8, 11
    x86.mov r9, 5
    x86.jmp while.cond
  ^while.cond(%10: i64):
    x86.mov rdx, r9
    x86.add rdx, rcx
    x86.cmp rdx, r8
    x86.sete rax
    x86.movzx rax, rax
    x86.test rax, rax
    x86.jne while.exit
    x86.jmp while.cond.args.from.while.body
    while.cond.args.from.while.body:
    x86.mov r9, rdx
    x86.jmp while.cond
  ^while.exit:
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

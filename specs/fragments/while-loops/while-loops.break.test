// Test: while-loops.break
function main() returns int
    var x = 5
    while true 'loop'
        x = x + 2
        if x == 11 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 5
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.jmp while.cond
  ^while.cond:
    x86.mov rax, 1
    x86.test rax, rax
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 2
    x86.mov r8, rax
    x86.add r8, rdx
    x86.mov qword ptr [rcx], r8
    x86.mov r8, qword ptr [rcx]
    x86.mov rdx, 11
    x86.cmp r8, rdx
    x86.sete r8
    x86.test r8, r8
    x86.jne then
    x86.jmp merge
  ^while.exit:
    x86.mov r8, qword ptr [rcx]
    x86.mov rax, r8
    x86.epilogue
    x86.ret
  ^then:
    x86.jmp while.exit
  ^merge:
    x86.jmp while.cond
}
---

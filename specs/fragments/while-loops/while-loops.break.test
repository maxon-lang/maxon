// Test: while-loops.break
function main() returns Integer
  var x = 5
  while true 'loop'
    x = x + 2
    if x == 11 'check'
      break
    end 'check'
  end 'loop'
  return x
end 'main'
---
ExitCode: 11
---
module {
  func @while-loops.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je while-loops.main.loop_0.exit
  loop_0:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.mov edx, 11
    x86.cmp ecx, edx
    x86.jne while-loops.main.check_1.after
  check_1:
    x86.jmp while-loops.main.loop_0.exit
  check_1.after:
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

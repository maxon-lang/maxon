// Test: while-loops.continue
function main() returns int
  var sum = 0
  var i = 0
  while i < 5 'loop'
    i = i + 1
    if i == 3 'skip'
      continue
    end 'skip'
    sum = sum + i
  end 'loop'
  return sum
end 'main'
---
ExitCode: 12
---
module {
  func @while-loops.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge while-loops.main.loop_0.exit
  loop_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.mov edx, 3
    x86.cmp ecx, edx
    x86.jne while-loops.main.skip_1.after
  skip_1:
    x86.jmp while-loops.main.loop_0.header
  skip_1.after:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.add eax, ecx
    x86.mov [rbp-8], eax
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

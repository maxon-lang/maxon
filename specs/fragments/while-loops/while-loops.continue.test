// Test: while-loops.continue
function main() returns int
    var sum = 0
    var i = 0
    while i < 5 'loop'
        i = i + 1
        if i == 3 'skip'
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 12
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov r8, 0
    x86.mov r9, 0
    x86.jmp while.cond
  ^while.cond(%18: i64, %21: i64):
    x86.mov rdx, 5
    x86.cmp r9, rdx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args
    while.exit.args:
    x86.mov rdx, r8
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, 1
    x86.mov rcx, r9
    x86.add rcx, rax
    x86.mov rax, 3
    x86.cmp rcx, rax
    x86.sete rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^while.exit(%19: i64):
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  ^then:
    x86.mov r9, rcx
    x86.jmp while.cond
  ^merge:
    x86.mov rdx, r8
    x86.add rdx, rcx
    x86.mov r8, rdx
    x86.mov r9, rcx
    x86.jmp while.cond
}

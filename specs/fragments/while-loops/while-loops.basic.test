// Test: while-loops.basic
function main() returns Integer
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
module {
  func @while-loops.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, 3
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.loop_0.header
  loop_0.header:
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jle while-loops.main.loop_0.exit
  loop_0:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.mov edx, 1
    x86.mov ebx, [rbp-16]
    x86.sub ebx, edx
    x86.mov [rbp-16], ebx
    x86.xor esi, esi
    x86.cmp ebx, esi
    x86.jne while-loops.main.check_1.after
  check_1:
    x86.jmp while-loops.main.loop_0.exit
  check_1.after:
    x86.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

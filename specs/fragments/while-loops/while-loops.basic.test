// Test: while-loops.basic
function main() returns int
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32 saved_gprs=[RBX,R12]
    x86.mov r8, 0
    x86.mov r9, 2
    x86.mov r10, 1
    x86.mov r11, 5
    x86.mov rbx, 3
    x86.jmp while.cond
  ^while.cond(%17: i64, %19: i64):
    x86.cmp rbx, r8
    x86.setg rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args.from.while.cond
    while.exit.args.from.while.cond:
    x86.mov rdx, r11
    x86.jmp while.exit
  ^while.body:
    x86.mov rcx, r11
    x86.add rcx, r9
    x86.mov rax, rbx
    x86.sub rax, r10
    x86.cmp rax, r8
    x86.sete r12
    x86.test r12, r12
    x86.jne while.exit.args.from.while.body
    x86.jmp while.cond.args.from.while.body
    while.cond.args.from.while.body:
    x86.mov r11, rcx
    x86.mov rbx, rax
    x86.jmp while.cond
    while.exit.args.from.while.body:
    x86.mov rdx, rcx
    x86.jmp while.exit
  ^while.exit(%18: i64):
    x86.mov rax, rdx
    x86.epilogue saved_gprs=[RBX,R12]
    x86.ret
}

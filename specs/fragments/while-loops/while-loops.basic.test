// Test: while-loops.basic
function main() returns int
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov r8, 5
    x86.mov r9, 3
    x86.jmp while.cond
  ^while.cond(%18: i64, %21: i64):
    x86.mov rdx, 0
    x86.cmp r9, rdx
    x86.setg rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args
    while.exit.args:
    x86.mov rcx, r8
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 2
    x86.mov r10, r8
    x86.add r10, rdx
    x86.mov rax, 1
    x86.mov rdx, r9
    x86.sub rdx, rax
    x86.mov rax, 0
    x86.cmp rdx, rax
    x86.sete rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^while.exit(%19: i64):
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
  ^then:
    x86.mov rcx, r10
    x86.jmp while.exit
  ^merge:
    x86.mov r8, r10
    x86.mov r9, rdx
    x86.jmp while.cond
}
---

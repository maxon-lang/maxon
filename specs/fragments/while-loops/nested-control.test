// Test: nested-control
function main() returns Integer
  var result = 0
  var i = 0
  while i < 3 'outer'
    var j = 0
    while j < 3 'inner'
      if (i + j) mod 2 == 0 'even'
        result = result + 1
      end 'even'
      j = j + 1
    end 'inner'
    i = i + 1
  end 'outer'
  return result
end 'main'
---
ExitCode: 5
---
module {
  func @while-loops.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.outer_0.header
  outer_0.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge while-loops.main.outer_0.exit
  outer_0:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp while-loops.main.inner_1.header
  inner_1.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge while-loops.main.inner_1.exit
  inner_1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.add eax, ecx
    x86.mov edx, 2
    x86.mov ecx, edx
    x86.mov [rbp-32], eax
    x86.cqo
    x86.idiv ecx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.jne while-loops.main.even_2.merge
  even_2:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp while-loops.main.even_2.merge
  even_2.merge:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.jmp while-loops.main.inner_1.header
  inner_1.exit:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

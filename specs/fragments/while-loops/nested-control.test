// Test: nested-control
function main() returns int
    var result = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            if (i + j) mod 2 == 0 'even'
                result = result + 1
            end 'even'
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return result
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov rax, 0
    x86.lea r8, qword ptr [rbp-48]
    x86.mov qword ptr [r8], rax
    x86.jmp while.cond
  ^while.cond:
    x86.mov rdx, qword ptr [r8]
    x86.mov rax, 3
    x86.cmp rdx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, 0
    x86.lea r9, qword ptr [rbp-56]
    x86.mov qword ptr [r9], rax
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rdx, qword ptr [rcx]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  ^while.cond_1:
    x86.mov rdx, qword ptr [r9]
    x86.mov rax, 3
    x86.cmp rdx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body_1
    x86.jmp while.exit_1
  ^while.body_1:
    x86.mov rax, qword ptr [r8]
    x86.mov rdx, qword ptr [r9]
    x86.mov r10, rax
    x86.add r10, rdx
    x86.mov rdx, 2
    x86.mov r11, rdx
    x86.mov rax, r10
    x86.cdq
    x86.idiv r11
    x86.mov r10, rdx
    x86.mov rdx, 0
    x86.cmp r10, rdx
    x86.sete r10
    x86.test r10, r10
    x86.jne then
    x86.jmp merge
  ^while.exit_1:
    x86.mov r10, qword ptr [r8]
    x86.mov rdx, 1
    x86.mov rax, r10
    x86.add rax, rdx
    x86.mov qword ptr [r8], rax
    x86.jmp while.cond
  ^then:
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 1
    x86.mov r10, rax
    x86.add r10, rdx
    x86.mov qword ptr [rcx], r10
    x86.jmp merge
  ^merge:
    x86.mov r10, qword ptr [r9]
    x86.mov rdx, 1
    x86.mov rax, r10
    x86.add rax, rdx
    x86.mov qword ptr [r9], rax
    x86.jmp while.cond_1
}

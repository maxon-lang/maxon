  func @while-loops.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.outer_0.header
  outer_0.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge while-loops.main.outer_0.exit
  outer_0:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp while-loops.main.inner_1.header
  inner_1.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge while-loops.main.inner_1.exit
  inner_1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.add eax, ecx
    x86.mov edx, 2
    x86.mov ecx, edx
    x86.mov [rbp-40], eax
    x86.cqo
    x86.idiv ecx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.jne while-loops.main.even_2.merge
  even_2:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp while-loops.main.even_2.merge
  even_2.merge:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.jmp while-loops.main.inner_1.header
  inner_1.exit:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.jmp while-loops.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je while-loops.main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }

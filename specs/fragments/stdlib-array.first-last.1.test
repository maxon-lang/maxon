typealias IntArray is Array with int

function main() returns int
    var arr = IntArray{}
    arr.push(10)
    arr.push(20)
    arr.push(30)

    var f = try arr.first() otherwise -1
    if f != 10 'fc'
        return 1
    end 'fc'

    var l = try arr.last() otherwise -1
    if l != 30 'lc'

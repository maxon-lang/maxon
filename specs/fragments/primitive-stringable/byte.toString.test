    x86.mov eax, 1
    x86.mov ecx, [rbp-32]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.call stdlib.String.equals
    x86.test eax, eax
    x86.je primitive-stringable.main.ok_0.after

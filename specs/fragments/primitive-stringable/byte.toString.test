    x86.call maxon_i64_to_string
    x86.mov ebx, 1
    x86.xor esi, esi
    x86.lea_rdata rdi, [__str_3]
    x86.mov r8, rdi
    x86.mov r9, 2
    x86.xor ecx, ecx
    x86.mov edx, 1
    x86.xor edi, edi
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-96]
    x86.mov [rbp-40], eax

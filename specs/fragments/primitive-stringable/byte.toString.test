// Test: byte.toString

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var x = 65 as Byte
  var s = x.toString()
  if s == "65" 'ok'
    return 1
  end 'ok'
  return 0
end 'main'
---
ExitCode: 1
---

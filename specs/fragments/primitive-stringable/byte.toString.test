// Test: byte.toString
function main() returns ExitCode
  var x = 65 as Byte
  var s = x.toString()
  if s == "65" 'ok'
    return 1
  end 'ok'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-stringable.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 65
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.call stdlib.byte.toString
    x86.mov [rbp-8], eax
    x86.lea_rdata rdx, [__str_3]
    x86.mov rbx, rdx
    x86.mov esi, 2
    x86.mov edi, 32
    x86.mov [rbp-32], ebx
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, [rbp-32]
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call stdlib.String.equals
    x86.test eax, eax
    x86.je primitive-stringable.main.ok_0.after
  ok_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

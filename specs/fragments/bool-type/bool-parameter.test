// Test: bool-parameter
function test_bool_param(flag bool) returns int
  if flag 'check'
    return 1
  end 'check' else 'else_check'
    return 0
  end 'else_check'
end 'test_bool_param'

function main() returns int
  return test_bool_param(true)
end 'main'
---
ExitCode: 1
---
module {
  func @bool-type.test_bool_param(flag: i1) -> i64 {
  entry:
    x86.test ecx, ecx
    x86.je bool-type.test_bool_param.else_check_1
  check_0:
    x86.mov eax, 1
    x86.ret
  else_check_1:
    x86.xor eax, eax
    x86.ret
  }
  func @bool-type.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov rcx, rax
    x86.jmp bool-type.test_bool_param
  }
}
---

// Test: bool-parameter

typealias Integer = int(i64.min to i64.max)

function test_bool_param(flag bool) returns Integer
  if flag 'check'
    return 1
  end 'check' else 'else_check'
    return 0
  end 'else_check'
end 'test_bool_param'

function main() returns ExitCode
  return test_bool_param(true)
end 'main'
---
ExitCode: 1
---
module {
  func @bool-type.test_bool_param(flag: i1) -> i64 {
  entry:
    x86.test ecx, ecx
    x86.je bool-type.test_bool_param.else_check_1
  check_0:
    x86.mov eax, 1
    x86.ret
  else_check_1:
    x86.xor eax, eax
    x86.ret
  }
  func @bool-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov rcx, rax
    x86.call bool-type.test_bool_param
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je bool-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_14]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

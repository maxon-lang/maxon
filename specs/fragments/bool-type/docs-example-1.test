// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function isPositive(x Score) returns bool
  if x > 0 'check'
    return true
  end 'check'
  return false
end 'isPositive'

function main() returns ExitCode
  if isPositive(5) 'test'
    return 1
  end 'test'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @bool-type.isPositive(x: i64) -> i1 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov edx, [rbp-24]
    x86.cmp edx, ecx
    x86.jle bool-type.isPositive.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @bool-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 5
    x86.call bool-type.isPositive
    x86.test eax, eax
    x86.je bool-type.main.test_0.after
  test_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: bool-from-comparison
function main() returns int
    var result = 5 > 3
    if result 'check'
        return 42
    end 'check'
    return 0
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.epilogue
    x86.ret
}
---

// Test: bool-from-comparison
function main() returns int
  var result = 5 > 3
  if result 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.setg edx
    x86.movzx edx, edxb
    x86.mov [rbp-1], edx
    x86.test edx, edx
    x86.je main.check_0.after
  check_0:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: basic-bool
function main() returns ExitCode
  var x = true

  if x 'check'
    return 1
  end 'check' else 'else_check'
    return 0
  end 'else_check'
end 'main'
---
ExitCode: 1
---
module {
  func @bool-type.main() -> u32 {
  entry:
    x86.mov rax, 1
    x86.test rax, rax
    x86.je bool-type.main.else_check_1
  check_0:
    x86.mov rax, 1
    x86.ret
  else_check_1:
    x86.xor rax, rax
    x86.ret
  }
}
---

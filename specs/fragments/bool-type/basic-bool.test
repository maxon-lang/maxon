// Test: basic-bool
function main() returns int
    var x = true

    if x 'check'
        return 1
    end 'check' else 'else_check'
        return 0
    end 'else_check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-1], eax
    x86.test eax, eax
    x86.je main.else_check_1
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  else_check_1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

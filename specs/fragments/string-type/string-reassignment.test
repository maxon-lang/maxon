// Test: string-reassignment
function main() returns ExitCode
  var s = "hello"
  print("{s.count()}\n")

  var u = "abc"
  u = "testing"
  print("{u.count()}\n")

  var v = ""
  v = "world"
  print("{v.count()}\n")

  return 0
end 'main'
---

// Test: grapheme-iteration-zwj
function main() returns int
  var s = "👨‍👩‍👧"  // Family emoji (1 grapheme)
  var count = 0
  for c in s 'loop'
    print("{c}")  // Use c to avoid unused warning
    count = count + 1
  end 'loop'
  print("\n{count}\n")
  return 0
end 'main'
---

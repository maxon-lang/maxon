// Test: isEmpty-method
function main() returns int
  var empty = ""
  var nonempty = "hello"
  if empty.isEmpty() 'check1'
    print("1\n")
  end 'check1'
  if nonempty.isEmpty() 'check2'
    print("0\n")
  end 'check2' else 'not_empty'
    print("2\n")
  end 'not_empty'
  return 0
end 'main'

// Test: utf16-is-surrogate
function main() returns ExitCode
  if utf16IsSurrogate(55357) 'c7'
    print("1\n")
  end 'c7'
  if utf16IsSurrogate(56832) 'c8'
    print("2\n")
  end 'c8'
  if utf16IsSurrogate(65) 'c9'
    print("0\n")
  end 'c9'
  return 0
end 'main'

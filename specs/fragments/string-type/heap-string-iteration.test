// Test: heap-string-iteration
function main() returns int
  var s = "ABCDEFGHIJKLMNOP"  // 16 bytes, triggers heap
  var sum = 0
  // Iterate over bytes directly to test heap string iteration
  for b in s.bytes() 'loop'
    sum = sum + (b as int)
  end 'loop'
  print("{sum}\n")  // 65+66+...+80 = 1160
  return 0
end 'main'
---

// Test: slice-iteration
function main() returns int
  var s = "abcdef"
  var start = s.startIndex()
  var idx = try s.find("d") otherwise s.endIndex()
  var sub = s.slice(start, endIndex: idx)
  for c in sub 'loop'
    print("{c}\n")
  end 'loop'
  return 0
end 'main'

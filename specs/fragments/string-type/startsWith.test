// Test: startsWith
function main() returns int
  var s = "hello world"
  if s.startsWith("hello") 'c1'
    print("1\n")
  end 'c1'
  if s.startsWith("world") 'c2'
    print("0\n")
  end 'c2'
  return 0
end 'main'

// Test: utf16-width
function main() returns ExitCode
  print("{utf16Width(65)}\n")      // ASCII 'A' = 1 code unit
  print("{utf16Width(945)}\n")     // Greek α = 1 code unit (BMP)
  print("{utf16Width(128512)}\n")  // 😀 U+1F600 = 2 code units
  return 0
end 'main'

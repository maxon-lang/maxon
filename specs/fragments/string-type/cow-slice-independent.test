// Test: cow-slice-independent
function main() returns int
  var s = "hello world"
  var start = s.startIndex()
  var spaceIdx = try s.find(" ") otherwise s.endIndex()
  var sub = s.slice(start, endIndex: spaceIdx)
  print("{sub}\n")
  return 0
end 'main'

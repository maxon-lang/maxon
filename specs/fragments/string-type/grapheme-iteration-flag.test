// Test: grapheme-iteration-flag
function main() returns int
  var s = "🇺🇸🇬🇧"  // Two flag emojis
  var count = 0
  for c in s 'loop'
    print("{c}")  // Use c to avoid unused warning
    count = count + 1
  end 'loop'
  print("\n{count}\n")
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
🇺🇸🇬🇧
2
```

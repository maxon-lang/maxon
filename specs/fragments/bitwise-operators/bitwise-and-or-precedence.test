// Test: bitwise-and-or-precedence
function main() returns int
    // & has higher precedence than |
    // 12 & 10 = 8, then 8 | 1 = 9
    return 12 & 10 | 1
end 'main'
---
ExitCode: 9
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 9
    x86.epilogue
    x86.ret
}
---

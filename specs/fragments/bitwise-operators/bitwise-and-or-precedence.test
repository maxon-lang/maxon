// Test: bitwise-and-or-precedence
function main() returns int
  // & has higher precedence than |
  // 12 & 10 = 8, then 8 | 1 = 9
  return 12 & 10 | 1
end 'main'
---
ExitCode: 9
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.mov eax, 12
    x86.mov ecx, 10
    x86.and eax, ecx
    x86.mov edx, 1
    x86.or eax, edx
    x86.ret
  }
}
---

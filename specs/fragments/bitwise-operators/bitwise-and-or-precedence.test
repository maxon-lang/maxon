// Test: bitwise-and-or-precedence
function main() returns ExitCode
  // and has higher precedence than or
  // 12 and 10 = 8, then 8 or 1 = 9
  return 12 and 10 or 1
end 'main'
---
ExitCode: 9
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 12
    x86.mov rcx, 10
    x86.and rax, rcx
    x86.mov rdx, 1
    x86.or rax, rdx
    x86.mov [rbp-8], rax
    x86.xor rbx, rbx
    x86.cmp rax, rbx
    x86.setl rsi
    x86.movzx rsi, rsib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or rsi, r8
    x86.test rsi, rsi
    x86.je bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

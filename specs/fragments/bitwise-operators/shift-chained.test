// Test: shift-chained
function main() returns ExitCode
  var a = 1
  return a shl 4 shr 2
end 'main'
---
ExitCode: 4
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov ecx, 4
    x86.mov edx, eax
    x86.shl edx, cl
    x86.mov ebx, 2
    x86.mov ecx, ebx
    x86.mov esi, edx
    x86.sar esi, cl
    x86.mov [rbp-8], esi
    x86.xor edi, edi
    x86.cmp esi, edi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rsi, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: shift-chained
function main() returns Integer
  var a = 1
  return a shl 4 shr 2
end 'main'
---
ExitCode: 4
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 4
    x86.mov edx, eax
    x86.shl edx, cl
    x86.mov ebx, 2
    x86.mov ecx, ebx
    x86.mov eax, edx
    x86.sar eax, cl
    x86.ret
  }
}
---

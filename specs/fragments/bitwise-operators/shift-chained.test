// Test: shift-chained
function main() returns int
    var a = 1
    return a << 4 >> 2
end 'main'
---
ExitCode: 4
---
// Generated X86 IR:
module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rcx, 4
      x86.mov rdx, 1
      x86.shl rdx, rcx
      x86.mov r8, 2
      x86.mov r9, rdx
      x86.sar r9, r8
      x86.mov rax, r9
      x86.epilogue
      x86.ret
  }
}


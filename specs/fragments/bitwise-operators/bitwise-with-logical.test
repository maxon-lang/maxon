// Test: bitwise-with-logical
function main() returns ExitCode
  var a = 5 and 3        // 1
  if a > 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.and eax, ecx
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.jle bitwise-operators.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: bitwise-with-logical
function main() returns int
    // Logical operators have lower precedence than bitwise
    var a = 5 & 3        // 1
    if a > 0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 3
    x86.mov rdx, 5
    x86.and rdx, rcx
    x86.mov rcx, 0
    x86.cmp rdx, rcx
    x86.setg rdx
    x86.test rdx, rdx
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

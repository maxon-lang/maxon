// Test: bit-masking
function main() returns int
  var flags = 5    // binary 101 (bit 0 and bit 2 set)
  return flags & 4 // returns 4 (bit 2 is set)
end 'main'
---
ExitCode: 4
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, 4
    x86.and eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

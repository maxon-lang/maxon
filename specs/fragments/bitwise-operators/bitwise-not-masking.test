// Test: bitwise-not-masking
function main() returns int
  var value = 255    // 0xFF
  // Clear lower 4 bits: 255 & ~15 = 240
  return value & ~15
end 'main'
---
ExitCode: 240
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.mov eax, 255
    x86.mov ecx, 15
    x86.mov edx, -1
    x86.xor ecx, edx
    x86.and eax, ecx
    x86.ret
  }
}
---

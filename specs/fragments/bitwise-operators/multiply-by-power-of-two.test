// Test: multiply-by-power-of-two
function main() returns int
    // Multiply by 8 using shift
    var value = 25
    return value << 3    // 200
end 'main'
---
ExitCode: 200
---
// Generated X86 IR:
module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rcx, 3
      x86.mov rdx, 25
      x86.shl rdx, rcx
      x86.mov rax, rdx
      x86.epilogue
      x86.ret
  }
}


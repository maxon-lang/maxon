// Test: multiply-by-power-of-two
function main() returns int
  // Multiply by 8 using shift
  var value = 25
  return value << 3    // 200
end 'main'
---
ExitCode: 200
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 25
    x86.mov [rbp-8], eax
    x86.mov ecx, 3
    x86.mov edx, eax
    x86.shl edx, cl
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

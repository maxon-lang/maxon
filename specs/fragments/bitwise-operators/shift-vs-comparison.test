// Test: shift-vs-comparison
function main() returns int
  // Shift has higher precedence than comparison
  // 1 shl 3 = 8, then 8 > 5 = true
  if 1 shl 3 > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 3
    x86.mov edx, eax
    x86.shl edx, cl
    x86.mov ebx, 5
    x86.cmp edx, ebx
    x86.jle bitwise-operators.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

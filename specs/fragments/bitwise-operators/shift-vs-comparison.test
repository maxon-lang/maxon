// Test: shift-vs-comparison
function main() returns ExitCode
  // Shift has higher precedence than comparison
  // 1 shl 3 = 8, then 8 > 5 = true
  if 1 shl 3 > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x86.mov rax, 1
    x86.mov rcx, 3
    x86.mov rdx, rax
    x86.shl rdx, cl
    x86.mov rbx, 5
    x86.cmp rdx, rbx
    x86.jle bitwise-operators.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

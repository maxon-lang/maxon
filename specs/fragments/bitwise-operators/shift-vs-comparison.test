// Test: shift-vs-comparison
function main() returns int
    // Shift has higher precedence than comparison
    // 1 << 3 = 8, then 8 > 5 = true
    if 1 << 3 > 5 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov rcx, 3
    x86.mov rdx, rax
    x86.shl rdx, rcx
    x86.mov rcx, 5
    x86.cmp rdx, rcx
    x86.setg rdx
    x86.test rdx, rdx
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

// Test: divide-by-power-of-two
function main() returns int
    // Divide by 4 using shift
    var value = 100
    return value >> 2    // 25
end 'main'
---
ExitCode: 25
---
// Generated X86 IR:
module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rcx, 2
      x86.mov rdx, 100
      x86.sar rdx, rcx
      x86.mov rax, rdx
      x86.epilogue
      x86.ret
  }
}


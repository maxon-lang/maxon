// Test: divide-by-power-of-two
function main() returns int
  // Divide by 4 using shift
  var value = 100
  return value >> 2    // 25
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.mov edx, eax
    x86.sar edx, cl
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

// Test: bitwise-and
function main() returns int
    var a = 12
    var b = 10
    return a & b
end 'main'
---
ExitCode: 8
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.mov rdx, 12
    x86.and rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

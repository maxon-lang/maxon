// Test: right-shift
function main() returns int
  var a = 16
  return a >> 2
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 16
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.mov edx, eax
    x86.sar edx, cl
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

// Test: power-of-two
function main() returns int
  // Calculate 2^n using shift
  var n = 5
  return 1 << n        // 32
end 'main'
---
ExitCode: 32
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, ecx
    x86.mov ecx, eax
    x86.shl edx, cl
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

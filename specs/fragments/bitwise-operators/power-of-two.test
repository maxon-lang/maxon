// Test: power-of-two
function main() returns int
    // Calculate 2^n using shift
    var n = 5
    return 1 << n        // 32
end 'main'
---
ExitCode: 32
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.mov rdx, 1
    x86.shl rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

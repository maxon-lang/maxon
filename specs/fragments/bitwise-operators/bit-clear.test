// Test: bit-clear
function main() returns int
    var flags = 7        // binary 111
    // Clear bit 1 using XOR
    flags = flags ^ 2
    return flags         // 5 (binary 101)
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.epilogue
    x86.ret
}
---

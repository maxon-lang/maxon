// Test: bit-clear
function main() returns int
  var flags = 7        // binary 111
  // Clear bit 1 using XOR
  flags = flags ^ 2
  return flags         // 5 (binary 101)
end 'main'
---
ExitCode: 5
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 7
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.xor eax, ecx
    x86.mov [rbp-8], eax
    x86.epilogue
    x86.ret
  }
}
---

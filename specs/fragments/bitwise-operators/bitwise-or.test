// Test: bitwise-or
function main() returns int
  var a = 12
  var b = 10
  return a | b
end 'main'
---
ExitCode: 14
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 12
    x86.mov [rbp-8], eax
    x86.mov ecx, 10
    x86.mov [rbp-16], ecx
    x86.or eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

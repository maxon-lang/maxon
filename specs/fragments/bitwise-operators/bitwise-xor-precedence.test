// Test: bitwise-xor-precedence
function main() returns int
    // & has higher precedence than ^
    // 12 & 10 = 8, then 8 ^ 3 = 11
    return 12 & 10 ^ 3
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 11
    x86.epilogue
    x86.ret
}
---

// Test: bitwise-xor-precedence
function main() returns int
  // & has higher precedence than ^
  // 12 & 10 = 8, then 8 ^ 3 = 11
  return 12 & 10 ^ 3
end 'main'
---
ExitCode: 11
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 12
    x86.mov ecx, 10
    x86.and eax, ecx
    x86.mov edx, 3
    x86.xor eax, edx
    x86.ret
  }
}
---

// Test: bitwise-xor-precedence
function main() returns int
  // and has higher precedence than xor
  // 12 and 10 = 8, then 8 xor 3 = 11
  return 12 and 10 xor 3
end 'main'
---
ExitCode: 11
---
module {
  func @bitwise-operators.main() -> i64 {
  entry:
    x86.mov eax, 12
    x86.mov ecx, 10
    x86.and eax, ecx
    x86.mov edx, 3
    x86.xor eax, edx
    x86.ret
  }
}
---

// Test: bitwise-xor-precedence
function main() returns int
    // & has higher precedence than ^
    // 12 & 10 = 8, then 8 ^ 3 = 11
    return 12 & 10 ^ 3
end 'main'
---
ExitCode: 11
---
// Generated X86 IR:
module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rcx, 10
      x86.mov rdx, 12
      x86.and rdx, rcx
      x86.mov r8, 3
      x86.mov r9, rdx
      x86.xor r9, r8
      x86.mov rax, r9
      x86.epilogue
      x86.ret
  }
}


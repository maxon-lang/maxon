// Test: structs.struct-return.1
type Pair
    export var first int
    export var second int
end 'Pair'

function makePair(a int, b int) returns Pair
    return { first: a, second: b }
end 'makePair'

function main() returns int
    var p = makePair(5, b: 7)
    return p.first + p.second
end 'main'
---
ExitCode: 12
---
function makePair() -> ptr {
entry_0:
    %tmp_param = param ptr 0
    %a = param i64 1
    %b = param i64 2
    memset %tmp_param 0 16
    %tmp_fieldptr = getfieldptr ptr %tmp_param 0
    store %tmp_fieldptr %a
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr.1 %b
    ret %tmp_param
}

function main() -> i64 {
entry_0:
    %p = alloca.sized ptr 16
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 7
    %tmp_call = call ptr @makePair(%p, %tmp_const, %tmp_const.1)
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_load.1 = load i64 %tmp_fieldptr.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    ret %tmp_add
}


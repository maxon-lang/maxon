// Test: short-type.u16-global-write
typealias U16 = int(0 to 65535)

var counter = U16{0}

function main() returns ExitCode
  counter = U16{99}
  return counter
end 'main'
---
ExitCode: 99
---
module {
  func @short-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 99
    x86.mov word [rip+counter], eax
    x86.movzx ecx, word [rip+counter]
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je short-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

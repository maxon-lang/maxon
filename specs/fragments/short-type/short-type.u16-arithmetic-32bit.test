// Test: short-type.u16-arithmetic-32bit
typealias U16 = int(0 to 65535)

function main() returns ExitCode
  var a = U16{1000}
  var b = U16{500}
  return a - b
end 'main'
---
ExitCode: 500
---
module {
  func @short-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1000
    x86.mov rcx, 500
    x86.sub rax, rcx
    x86.mov [rbp-8], rax
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je short-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

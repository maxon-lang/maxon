// Test: conditional-return
function main() returns ExitCode
  var x = 5
  if x > 3 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @return-statement.main() -> u32 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jle return-statement.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

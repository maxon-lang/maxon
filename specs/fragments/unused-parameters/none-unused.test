// Test: none-unused
function multiply(a int, b int) returns int
  return a * b
end 'multiply'

function main() returns int
  return multiply(7, b: 6)
end 'main'
---
ExitCode: 42
---
module {
  func @unused-parameters.multiply(a: i64, b: i64) -> i64 {
  entry:
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.ret
  }
  func @unused-parameters.main() -> i64 {
  entry:
    x86.mov eax, 7
    x86.mov ecx, 6
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp unused-parameters.multiply
  }

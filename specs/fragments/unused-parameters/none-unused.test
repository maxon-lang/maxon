// Test: none-unused
function multiply(a int, b int) returns int
  return a * b
end 'multiply'

function main() returns int
  return multiply(7, b: 6)
end 'main'
---
ExitCode: 42
---
module {
  func @multiply(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 7
    x86.mov ecx, 6
    x86.mov edx, ecx
    x86.mov ecx, eax
    x86.call multiply
    x86.ret
  }
}
---

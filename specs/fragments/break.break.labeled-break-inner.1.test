// Test: break.break.labeled-break-inner.1
function main() returns int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %y = alloca ptr
    store %y %tmp_const.1
    br @whilecond_1
whilecond_1:
    %tmp_load = load i64 %x
    %tmp_const.2 = const.i64 i64 5
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    br.cond %tmp_icmp @whilebody_2 @whilecont_8
whilebody_2:
    %tmp_load.1 = load i64 %x
    %tmp_const.3 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.3
    store %x %tmp_add
    br @whilecond_3
whilecond_3:
    %tmp_load.2 = load i64 %y
    %tmp_const.4 = const.i64 i64 10
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.2 %tmp_const.4
    br.cond %tmp_icmp.1 @whilebody_4 @whilecont_7
whilebody_4:
    %tmp_load.3 = load i64 %y
    %tmp_const.5 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.3 %tmp_const.5
    store %y %tmp_add.1
    %tmp_load.4 = load i64 %y
    %tmp_const.6 = const.i64 i64 3
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.4 %tmp_const.6
    br.cond %tmp_icmp.2 @then$check_5 @end$check_6
then$check_5:
    br @whilecont_7
    br @end$check_6
end$check_6:
    br @whilecond_3
whilecont_7:
    br @whilecond_1
whilecont_8:
    %tmp_load.5 = load i64 %x
    ret %tmp_load.5
}


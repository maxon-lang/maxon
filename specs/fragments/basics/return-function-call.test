// Test: return-function-call
function getValue() returns int
    return 42
end 'getValue'

function main() returns int
    return getValue()
end 'main'
---
ExitCode: 42
---
module {
  func @getValue() -> i64 {
  entry:
    x86.push rbp
    x86.mov rbp, rsp
    x86.mov eax, 42
    x86.pop rbp
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.push rbp
    x86.mov rbp, rsp
    x86.call getValue
    x86.pop rbp
    x86.ret
  }
}
---

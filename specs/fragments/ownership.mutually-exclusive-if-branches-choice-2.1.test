// Test: ownership.mutually-exclusive-if-branches-choice-2.1
type Position
    export var x int
    export var y int
end 'Position'

function testMutuallyExclusiveMoves(choice int) returns int
    var pos = Position{x: 10, y: 20}

    if choice == 1 'first'
        var temp = pos
        return temp.x
    end 'first'

    if choice == 2 'second'
        var temp = pos
        return temp.y
    end 'second'

    return pos.x + pos.y
end 'testMutuallyExclusiveMoves'

function main() returns int
    return testMutuallyExclusiveMoves(2)
end 'main'
---
ExitCode: 20
---
function testMutuallyExclusiveMoves() -> i64 {
entry_0:
    %choice = param i64 0
    %choice.1 = alloca ptr
    store %choice.1 %choice
    %pos = alloca.sized ptr 16
    memset %pos 0 16
    %tmp_fieldptr = getfieldptr ptr %pos 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %pos 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_const.2 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %choice %tmp_const.2
    br.cond %tmp_icmp @then$first_1 @end$first_2
then$first_1:
    %temp = alloca.sized ptr 16
    track.copy tag="Position"
    memcpy %temp %pos 16
    %tmp_fieldptr.2 = getfieldptr ptr %temp 0
    %tmp_load.1 = load i64 %tmp_fieldptr.2
    ret %tmp_load.1
end$first_2:
    %tmp_load.3 = load i64 %choice.1
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.3 %tmp_const.3
    br.cond %tmp_icmp.1 @then$second_3 @end$second_4
then$second_3:
    %temp.1 = alloca.sized ptr 16
    track.copy tag="Position"
    memcpy %temp.1 %pos 16
    %tmp_fieldptr.3 = getfieldptr ptr %temp.1 8
    %tmp_load.4 = load i64 %tmp_fieldptr.3
    ret %tmp_load.4
end$second_4:
    %tmp_fieldptr.4 = getfieldptr ptr %pos 0
    %tmp_load.6 = load i64 %tmp_fieldptr.4
    %tmp_fieldptr.5 = getfieldptr ptr %pos 8
    %tmp_load.7 = load i64 %tmp_fieldptr.5
    %tmp_add = add i64 %tmp_load.6 %tmp_load.7
    ret %tmp_add
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    %tmp_call = call i64 @testMutuallyExclusiveMoves(%tmp_const)
    ret %tmp_call
}

---

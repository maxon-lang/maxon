// Test: struct-field-reassignment
type Counter
  export var value int
end 'Counter'

function main() returns int
  var c = Counter{value: 10}
  c.value = 42
  return c.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov edi, [rbp-8]
    x86.mov [edi+0], esi
    x86.mov r8, [rbp-8]
    x86.mov r9, [r8+0]
    x86.mov eax, r9
    x86.epilogue
    x86.ret
  }
}
---

    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, 10
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov esi, 42
    x86.mov edi, [rbp-8]
    x86.mov [edi+0], esi
    x86.mov r8, [rbp-8]
    x86.mov r9, [r8+0]
    x86.mov [rbp-16], r9
    x86.xor eax, eax
    x86.cmp r9, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rcx, 4294967295
    x86.cmp r9, rcx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je challenge-struct-field-assign.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Counter(ptr: i64) {
  entry:
    x86.jmp __destruct_Counter.done
  done:

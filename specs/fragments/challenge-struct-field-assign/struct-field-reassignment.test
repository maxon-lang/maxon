// Test: struct-field-reassignment
type Counter
  export var value int
end 'Counter'

function main() returns int
  var c = Counter{value: 10}
  c.value = 42
  return c.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

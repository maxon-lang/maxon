// Test: struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Counter
  export var value Integer
end 'Counter'

function main() returns ExitCode
  var c = Counter{value: 10}
  c.value = 42
  return c.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.lea rdi, [rbp-8]
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.rep_stosq
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-16]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, 42
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, [rbp-16]
    x86.mov eax, [r9+0]
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je challenge-struct-field-assign.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

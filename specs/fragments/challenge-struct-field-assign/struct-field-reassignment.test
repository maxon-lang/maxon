// Test: struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Counter
  export var value Integer
end 'Counter'

function main() returns ExitCode
  var c = Counter{value: 10}
  c.value = 42
  return c.value
end 'main'
---
ExitCode: 42
---

// Test: struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Counter
  export var value Integer
end 'Counter'

function main() returns ExitCode
  var c = Counter{value: 10}
  c.value = 42
  return c.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 10
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 10
    x86.mov [rcx+0], rdx
    x86.mov rbx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rsi, 42
    x86.mov rdi, [rbp-8]
    x86.mov [rdi+0], rsi
    x86.mov r8, [rbp-8]
    x86.mov r9, [r8+0]
    x86.mov [rbp-16], r9
    x86.xor rax, rax
    x86.cmp r9, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rcx, 4294967295
    x86.cmp r9, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or rax, rcx
    x86.test rax, rax
    x86.je challenge-struct-field-assign.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Counter(ptr: i64) {
  entry:
    x86.jmp __destruct_Counter.done
  done:
    x86.ret
  }
}

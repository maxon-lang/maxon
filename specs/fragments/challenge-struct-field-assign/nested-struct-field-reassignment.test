// Test: nested-struct-field-reassignment
type Inner
  export var x int
end 'Inner'

type Outer
  export var inner Inner
end 'Outer'

function main() returns int
  var i = Inner{x: 10}
  var o = Outer{inner: i}
  o.inner.x = 42
  return o.inner.x
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

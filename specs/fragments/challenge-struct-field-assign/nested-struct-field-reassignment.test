// Test: nested-struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Inner
  export var x Integer
end 'Inner'

type Outer
  export var inner Inner
end 'Outer'

function main() returns ExitCode
  var i = Inner{x: 10}
  var o = Outer{inner: i}
  o.inner.x = 42
  return o.inner.x
end 'main'
---
ExitCode: 42
---

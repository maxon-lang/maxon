// Test: nested-struct-field-reassignment
type Inner
  export var x int
end 'Inner'

type Outer
  export var inner Inner
end 'Outer'

function main() returns int
  var i = Inner{x: 10}
  var o = Outer{inner: i}
  o.inner.x = 42
  return o.inner.x
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-struct-field-assign.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, [rbp-16]
    x86.mov eax, [r9+0]
    x86.mov [rbp-24], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-32], ecx
    x86.mov eax, [rbp-32]
    x86.mov ecx, [eax+0]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

// Test: array-passed-to-function
typealias IntArray = Array with int

function sum_first(arr IntArray) returns int
  return try arr.get(0) otherwise 0
end 'sum_first'

function main() returns int
  let size = 5
  var arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 99)
  return sum_first(arr)
end 'main'

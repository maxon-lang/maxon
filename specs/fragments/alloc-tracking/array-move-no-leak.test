// Test: array-move-no-leak
typealias IntArray = Array with int

function mutateFirst(arr IntArray) returns int
  arr.set(0, value: 100)
  return try arr.get(0) otherwise 0
end 'mutateFirst'

function main() returns int
  let size = 5
  var arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 42)
  return mutateFirst(arr)
end 'main'
---
TrackMemory: true
ExitCode: 100

// Test: heap-array-reassign
typealias IntArray = Array with int

function main() returns int
  let size = 5
  var arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 10)
  arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 20)
  return try arr.get(0) otherwise 0
end 'main'
---

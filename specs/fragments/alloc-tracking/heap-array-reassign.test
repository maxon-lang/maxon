// Test: heap-array-reassign
typealias IntArray = Array with int

function main() returns ExitCode
  let size = 5
  var arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 10)
  arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 20)
  return try arr.get(0) otherwise 0
end 'main'
---
TrackMemory: true
ExitCode: 20
Stdout: ```
ALLOC #1: 40 bytes (array grow)
INCREF: array grow -> rc=1
CLEANUP: arr
DECREF: arr -> rc=0
FREE #1: 40 bytes (array cleanup)
ALLOC #2: 40 bytes (array grow)
INCREF: array grow -> rc=1
CLEANUP: arr
DECREF: arr -> rc=0
FREE #2: 40 bytes (array cleanup)

=== MEMORY STATS ===
Allocated: 80 bytes
Freed:     80 bytes
Leaked:    0 bytes
Moves:     0
Increfs:   2
Decrefs:   2
Copies:    0
Cleanups:  2
```

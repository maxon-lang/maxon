// Test: array-computed-size
typealias IntArray = Array with int

function main() returns int
  let a = 2
  let b = 5
  var arr = IntArray{}
  arr.resize(a * b)
  arr.set(0, value: 77)
  return try arr.get(0) otherwise 0
end 'main'

// Test: array-in-loop
typealias IntArray = Array with int

function main() returns int
  var i = 0
  var sum = 0
  while i < 3 'loop'
    let size = 5
    var arr = IntArray{}
    arr.resize(size)
    arr.set(0, value: i)
    var val = try arr.get(0) otherwise 0
    sum = sum + val
    i = i + 1
  end 'loop'
  return sum
end 'main'
---

// Test: array-early-return-true
typealias IntArray = Array with int

function main() returns int
  let size = 5
  var arr = IntArray{}
  arr.resize(size)
  arr.set(0, value: 42)
  if true 'check'
    return try arr.get(0) otherwise 0
  end 'check'
  return 0
end 'main'

// Test: string-array-cleanup-void-main
typealias StringArray = Array with String

function main() returns ExitCode
  var arr = StringArray{}
  arr.push("hi")
  var s = try arr.get(0) otherwise "oops"
  print(s)
  return 0
end 'main'

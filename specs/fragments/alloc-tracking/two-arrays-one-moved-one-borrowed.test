// Test: two-arrays-one-moved-one-borrowed

typealias Integer = int(i64.min to i64.max)

typealias IntArray = Array with int

function readIt(arr IntArray) returns Integer
  return try arr.get(0) otherwise 0
end 'readIt'

function writeIt(arr IntArray) returns Integer
  arr.set(0, value: 99)
  return try arr.get(0) otherwise 0
end 'writeIt'

function main() returns ExitCode
  let size = 5
  var arr1 = IntArray{}
  arr1.resize(size)
  var arr2 = IntArray{}
  arr2.resize(size)
  arr1.set(0, value: 10)
  arr2.set(0, value: 20)
  let borrowed = readIt(arr1)
  let moved = writeIt(arr2)
  return borrowed + moved
end 'main'
---

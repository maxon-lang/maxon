// Test: sqrt.rt-zero
function main() returns ExitCode
  let args = CommandLine.args()
  var x = try float.fromString(try args.get(0) otherwise "") otherwise 0.0
  var result = sqrt(x)
  if result == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'

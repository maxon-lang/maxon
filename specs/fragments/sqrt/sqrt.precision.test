// Test: sqrt.precision
function main() returns int
    var x = sqrt(2.0)
    // sqrt(2) * sqrt(2) should be approximately 2
    var check = x * x
    // Trunc to get integer 2
    return trunc(check)
end 'main'
---
ExitCode: 2
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.epilogue
    x86.ret
}
---

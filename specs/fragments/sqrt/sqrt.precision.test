// Test: sqrt.precision
function main() returns int
  var x = sqrt(2.0)
  // sqrt(2) * sqrt(2) should be approximately 2
  var check = x * x
  // Trunc to get integer 2
  return trunc(check)
end 'main'
---
ExitCode: 2
---
module {
  func @sqrt.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_2]
    x86.sqrtsd xmm1, xmm0
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.ret
  }
}
---

// Test: break.labeled-break-inner
function main() returns ExitCode
  var x = 0
  var y = 0
  while x < 5 'outer'
    x = x + 1
    while y < 10 'inner'
      y = y + 1
      if y == 3 'check'
        break 'inner'
      end 'check'
    end 'inner'
  end 'outer'
  return x
end 'main'
---
ExitCode: 5
---
module {
  func @break.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 1
    x86.mov edx, [rbp-16]
    x86.add edx, ecx
    x86.mov [rbp-16], edx
    x86.jmp break.main.inner_1.header
  inner_1.header:
    x86.mov eax, 10
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge break.main.inner_1.exit
  inner_1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov ecx, 1
    x86.mov edx, [rbp-24]
    x86.add edx, ecx
    x86.mov [rbp-24], edx
    x86.mov ebx, 3
    x86.cmp edx, ebx
    x86.jne break.main.check_2.after
  check_2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-48], eax
    x86.mov ecx, [rbp-48]
    x86.call mm_scope_exit
    x86.jmp break.main.inner_1.exit
  check_2.after:
    x86.mov rcx, [rbp-40]
    x86.call mm_scope_exit
    x86.jmp break.main.inner_1.header
  inner_1.exit:
    x86.mov rcx, [rbp-32]
    x86.call mm_scope_exit
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-56], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je break.main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.mov eax, [rbp-56]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-64], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-64]
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-break-inner
function main() returns int
  var x = 0
  var y = 0
  while x < 5 'outer'
    x = x + 1
    while y < 10 'inner'
      y = y + 1
      if y == 3 'check'
        break 'inner'
      end 'check'
    end 'inner'
  end 'outer'
  return x
end 'main'
---
ExitCode: 5
---
module {
  func @break.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp break.main.inner_1.header
  inner_1.header:
    x86.mov eax, 10
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge break.main.inner_1.exit
  inner_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.mov edx, 3
    x86.cmp ecx, edx
    x86.jne break.main.check_2.after
  check_2:
    x86.jmp break.main.inner_1.exit
  check_2.after:
    x86.jmp break.main.inner_1.header
  inner_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

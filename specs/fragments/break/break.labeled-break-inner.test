// Test: break.labeled-break-inner
function main() returns int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.push rbx
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov r8, 5
    x86.mov r9, 1
    x86.mov r10, 3
    x86.mov r11, rax
    x86.jmp while.cond
  ^while.cond(%20: i64):
    x86.cmp r11, r8
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 1
    x86.mov rbx, r11
    x86.add rbx, rdx
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rax, r11
    x86.pop rbx
    x86.epilogue
    x86.ret
  ^while.cond_1:
    x86.mov rdx, qword ptr [rcx]
    x86.mov rax, 10
    x86.cmp rdx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body_1
    x86.jmp while.cond.args.from.while.cond_1
    while.cond.args.from.while.cond_1:
    x86.mov r11, rbx
    x86.jmp while.cond
  ^while.body_1:
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, rax
    x86.add rdx, r9
    x86.mov qword ptr [rcx], rdx
    x86.mov rdx, qword ptr [rcx]
    x86.cmp rdx, r10
    x86.sete rdx
    x86.test rdx, rdx
    x86.jne while.cond.args.from.while.body_1
    x86.jmp while.cond_1
    while.cond.args.from.while.body_1:
    x86.mov r11, rbx
    x86.jmp while.cond
}
---

// Test: break.labeled-break-inner
function main() returns int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rcx, 0
    x86.lea r8, qword ptr [rbp-40]
    x86.mov qword ptr [r8], rcx
    x86.mov rcx, 0
    x86.jmp while.cond
  ^while.cond(%21: i64):
    x86.mov rdx, 5
    x86.cmp rcx, rdx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args
    while.exit.args:
    x86.mov rdx, rcx
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, 1
    x86.mov r9, rcx
    x86.add r9, rax
    x86.jmp while.cond_1
  ^while.exit(%22: i64):
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  ^while.cond_1:
    x86.mov rdx, qword ptr [r8]
    x86.mov rax, 10
    x86.cmp rdx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body_1
    x86.jmp while.exit_1
  ^while.body_1:
    x86.mov rax, qword ptr [r8]
    x86.mov rdx, 1
    x86.mov r10, rax
    x86.add r10, rdx
    x86.mov qword ptr [r8], r10
    x86.mov r10, qword ptr [r8]
    x86.mov rdx, 3
    x86.cmp r10, rdx
    x86.sete r10
    x86.test r10, r10
    x86.jne then
    x86.jmp merge
  ^while.exit_1:
    x86.mov rcx, r9
    x86.jmp while.cond
  ^then:
    x86.jmp while.exit_1
  ^merge:
    x86.jmp while.cond_1
}
---

// Test: break.labeled-break-triple-nested
function main() returns int
    var result = 0
    while true 'outer'
        while true 'middle'
            while true 'inner'
                result = result + 1
                if result == 5 'check'
                    break 'outer'
                end 'check'
            end 'inner'
        end 'middle'
    end 'outer'
    return result
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.jmp while.body_2
  ^while.exit:
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
  ^while.body_2:
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 1
    x86.mov r8, rax
    x86.add r8, rdx
    x86.mov qword ptr [rcx], r8
    x86.mov r8, qword ptr [rcx]
    x86.mov rdx, 5
    x86.cmp r8, rdx
    x86.sete r8
    x86.test r8, r8
    x86.jne while.exit
    x86.jmp while.body_2
}
---

// Test: break.labeled-break-triple-nested
function main() returns int
  var result = 0
  while true 'outer'
    while true 'middle'
      while true 'inner'
        result = result + 1
        if result == 5 'check'
          break 'outer'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return result
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je main.outer_0.exit
  outer_0:
    x86.jmp main.middle_1.header
  middle_1.header:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je main.middle_1.exit
  middle_1:
    x86.jmp main.inner_2.header
  inner_2.header:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je main.inner_2.exit
  inner_2:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.mov edx, 5
    x86.cmp ecx, edx
    x86.jne main.check_3.after
  check_3:
    x86.jmp main.outer_0.exit
  check_3.after:
    x86.jmp main.inner_2.header
  inner_2.exit:
    x86.jmp main.middle_1.header
  middle_1.exit:
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-continue-inner
function main() returns int
  var sum = 0
  var x = 0
  while x < 3 'outer'
    x = x + 1
    var y = 0
    while y < 5 'inner'
      y = y + 1
      if y == 3 'check'
        continue 'inner'
      end 'check'
      sum = sum + 1
    end 'inner'
  end 'outer'
  return sum
end 'main'
---
ExitCode: 12
---
module {
  func @break.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.jmp break.main.inner_1.header
  inner_1.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge break.main.inner_1.exit
  inner_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.mov edx, 3
    x86.cmp ecx, edx
    x86.jne break.main.check_2.after
  check_2:
    x86.jmp break.main.inner_1.header
  check_2.after:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp break.main.inner_1.header
  inner_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-continue-inner
function main() returns int
    var sum = 0
    var x = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            if y == 3 'check'
                continue 'inner'
            end 'check'
            sum = sum + 1
        end 'inner'
    end 'outer'
    return sum
end 'main'
---
ExitCode: 12
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.push rbx
    x86.push r12
    x86.push r13
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov r8, 3
    x86.mov r9, 5
    x86.mov r10, 1
    x86.mov r11, rax
    x86.jmp while.cond
  ^while.cond(%25: i64):
    x86.cmp r11, r8
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 1
    x86.mov rbx, r11
    x86.add rbx, rdx
    x86.mov rdx, 0
    x86.mov r12, rdx
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rdx, qword ptr [rcx]
    x86.mov rax, rdx
    x86.pop r13
    x86.pop r12
    x86.pop rbx
    x86.epilogue
    x86.ret
  ^while.cond_1(%26: i64):
    x86.cmp r12, r9
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body_1
    x86.jmp while.cond.args.from.while.cond_1
    while.cond.args.from.while.cond_1:
    x86.mov r11, rbx
    x86.jmp while.cond
  ^while.body_1:
    x86.mov rdx, 1
    x86.mov rax, r12
    x86.add rax, rdx
    x86.mov rdx, 3
    x86.cmp rax, rdx
    x86.sete rdx
    x86.test rdx, rdx
    x86.jne while.cond_1.args.from.while.body_1
    x86.jmp merge
    while.cond_1.args.from.while.body_1:
    x86.mov r12, rax
    x86.jmp while.cond_1
  ^merge:
    x86.mov rdx, qword ptr [rcx]
    x86.mov r13, rdx
    x86.add r13, r10
    x86.mov qword ptr [rcx], r13
    x86.mov r12, rax
    x86.jmp while.cond_1
}

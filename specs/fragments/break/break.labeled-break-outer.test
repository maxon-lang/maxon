// Test: break.labeled-break-outer
function main() returns int
    var x = 0
    while x < 10 'outer'
        x = x + 1
        while true 'inner'
            if x == 3 'check'
                break 'outer'
            end 'check'
            break 'inner'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 3
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=40 saved_gprs=[RBX]
    x86.mov rcx, 10
    x86.mov r8, 3
    x86.mov r9, 1
    x86.mov r10, 0
    x86.jmp while.cond
  ^while.cond(%13: i64):
    x86.cmp r10, rcx
    x86.setl rdx
    x86.movzx rdx, rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args.from.while.cond
    while.exit.args.from.while.cond:
    x86.mov r11, r10
    x86.jmp while.exit
  ^while.body:
    x86.mov rbx, r10
    x86.add rbx, r9
    x86.cmp rbx, r8
    x86.sete rdx
    x86.movzx rdx, rdx
    x86.test rdx, rdx
    x86.jne while.exit.args.from.while.body_1
    x86.jmp while.cond.args.from.while.body_1
    while.cond.args.from.while.body_1:
    x86.mov r10, rbx
    x86.jmp while.cond
    while.exit.args.from.while.body_1:
    x86.mov r11, rbx
    x86.jmp while.exit
  ^while.exit(%14: i64):
    x86.mov rax, r11
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}
---

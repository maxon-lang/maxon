// Test: break.labeled-break-outer
function main() returns ExitCode
  var x = 0
  while x < 10 'outer'
    x = x + 1
    while true 'inner'
      if x == 3 'check'
        break 'outer'
      end 'check'
      break 'inner'
    end 'inner'
  end 'outer'
  return x
end 'main'
---
ExitCode: 3
---
module {
  func @break.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov eax, 10
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp break.main.inner_1.header
  inner_1.header:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je break.main.inner_1.exit
  inner_1:
    x86.mov eax, 3
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne break.main.check_2.after
  check_2:
    x86.jmp break.main.outer_0.exit
  check_2.after:
    x86.jmp break.main.inner_1.exit
  inner_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je break.main.__range_ok_3
  __range_panic_3:
    x86.lea_rdata rax, [__panic_msg_17]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.with-if
function main() returns int
    var x = 0
    while true 'loop'
        x = x + 1
        if x == 10 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 0
    x86.jmp while.cond
  ^while.cond(%11: i64):
    x86.mov rax, 1
    x86.mov r8, rcx
    x86.add r8, rax
    x86.mov rdx, 10
    x86.cmp r8, rdx
    x86.sete rdx
    x86.test rdx, rdx
    x86.jne then
    x86.jmp merge
  ^while.exit(%12: i64):
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  ^then:
    x86.mov rdx, r8
    x86.jmp while.exit
  ^merge:
    x86.mov rcx, r8
    x86.jmp while.cond
}
---

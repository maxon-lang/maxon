// Test: break.labeled-continue-triple-nested
function main() returns Integer
  var count = 0
  var a = 0
  while a < 2 'outer'
    a = a + 1
    var b = 0
    while b < 3 'middle'
      b = b + 1
      var c = 0
      while c < 4 'inner'
        c = c + 1
        count = count + 1
        if c == 2 'check'
          continue 'middle'
        end 'check'
      end 'inner'
    end 'middle'
  end 'outer'
  return count
end 'main'
---
ExitCode: 12
---
module {
  func @break.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp break.main.outer_0.header
  outer_0.header:
    x86.mov eax, 2
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge break.main.outer_0.exit
  outer_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.jmp break.main.middle_1.header
  middle_1.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge break.main.middle_1.exit
  middle_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.xor edx, edx
    x86.mov [rbp-32], edx
    x86.jmp break.main.inner_2.header
  inner_2.header:
    x86.mov eax, 4
    x86.mov ecx, [rbp-32]
    x86.cmp ecx, eax
    x86.jge break.main.inner_2.exit
  inner_2:
    x86.mov eax, 1
    x86.mov ecx, [rbp-32]
    x86.add ecx, eax
    x86.mov [rbp-32], ecx
    x86.mov edx, 1
    x86.mov ebx, [rbp-8]
    x86.add ebx, edx
    x86.mov [rbp-8], ebx
    x86.mov esi, 2
    x86.cmp ecx, esi
    x86.jne break.main.check_3.after
  check_3:
    x86.jmp break.main.middle_1.header
  check_3.after:
    x86.jmp break.main.inner_2.header
  inner_2.exit:
    x86.jmp break.main.middle_1.header
  middle_1.exit:
    x86.jmp break.main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

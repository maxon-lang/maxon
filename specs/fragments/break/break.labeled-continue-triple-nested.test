// Test: break.labeled-continue-triple-nested
function main() returns int
    var count = 0
    var a = 0
    while a < 2 'outer'
        a = a + 1
        var b = 0
        while b < 3 'middle'
            b = b + 1
            var c = 0
            while c < 4 'inner'
                c = c + 1
                count = count + 1
                if c == 2 'check'
                    continue 'middle'
                end 'check'
            end 'inner'
        end 'middle'
    end 'outer'
    return count
end 'main'
---
ExitCode: 12
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov rax, 0
    x86.lea r8, qword ptr [rbp-48]
    x86.mov qword ptr [r8], rax
    x86.jmp while.cond
  ^while.cond:
    x86.mov rdx, qword ptr [r8]
    x86.mov rax, 2
    x86.cmp rdx, rax
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, qword ptr [r8]
    x86.mov rdx, 1
    x86.mov r9, rax
    x86.add r9, rdx
    x86.mov qword ptr [r8], r9
    x86.mov r9, 0
    x86.lea r10, qword ptr [rbp-56]
    x86.mov qword ptr [r10], r9
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rdx, qword ptr [rcx]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
  ^while.cond_1:
    x86.mov rdx, qword ptr [r10]
    x86.mov rax, 3
    x86.cmp rdx, rax
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body_1
    x86.jmp while.exit_1
  ^while.body_1:
    x86.mov rdx, qword ptr [r10]
    x86.mov rax, 1
    x86.mov r9, rdx
    x86.add r9, rax
    x86.mov qword ptr [r10], r9
    x86.mov r9, 0
    x86.lea r11, qword ptr [rbp-64]
    x86.mov qword ptr [r11], r9
    x86.jmp while.cond_2
  ^while.exit_1:
    x86.jmp while.cond
  ^while.cond_2:
    x86.mov rax, qword ptr [r11]
    x86.mov rdx, 4
    x86.cmp rax, rdx
    x86.setl rax
    x86.test rax, rax
    x86.jne while.body_2
    x86.jmp while.exit_2
  ^while.body_2:
    x86.mov rax, qword ptr [r11]
    x86.mov rdx, 1
    x86.mov r9, rax
    x86.add r9, rdx
    x86.mov qword ptr [r11], r9
    x86.mov r9, qword ptr [rcx]
    x86.mov rdx, 1
    x86.mov rax, r9
    x86.add rax, rdx
    x86.mov qword ptr [rcx], rax
    x86.mov rax, qword ptr [r11]
    x86.mov rdx, 2
    x86.cmp rax, rdx
    x86.sete rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^while.exit_2:
    x86.jmp while.cond_1
  ^then:
    x86.jmp while.cond_1
  ^merge:
    x86.jmp while.cond_2
}

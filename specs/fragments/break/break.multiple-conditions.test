// Test: break.multiple-conditions
function main() returns int
    var x = 5
    var count = 0
    while x < 100 'loop'
        x = x + 1
        count = count + 1
        if count == 3 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
ExitCode: 8
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.push rbx
    x86.push r12
    x86.mov r8, 100
    x86.mov r9, 1
    x86.mov r10, 3
    x86.mov r11, 5
    x86.mov rbx, 0
    x86.jmp while.cond
  ^while.cond(%17: i64, %19: i64):
    x86.cmp r11, r8
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args.from.while.cond
    while.exit.args.from.while.cond:
    x86.mov rdx, r11
    x86.jmp while.exit
  ^while.body:
    x86.mov rcx, r11
    x86.add rcx, r9
    x86.mov rax, rbx
    x86.add rax, r9
    x86.cmp rax, r10
    x86.sete r12
    x86.test r12, r12
    x86.jne while.exit.args.from.while.body
    x86.jmp while.cond.args.from.while.body
    while.cond.args.from.while.body:
    x86.mov r11, rcx
    x86.mov rbx, rax
    x86.jmp while.cond
    while.exit.args.from.while.body:
    x86.mov rdx, rcx
    x86.jmp while.exit
  ^while.exit(%18: i64):
    x86.mov rax, rdx
    x86.pop r12
    x86.pop rbx
    x86.epilogue
    x86.ret
}
---

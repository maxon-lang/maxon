// Test: break.multiple-conditions
function main() returns int
    var x = 5
    var count = 0
    while x < 100 'loop'
        x = x + 1
        count = count + 1
        if count == 3 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'

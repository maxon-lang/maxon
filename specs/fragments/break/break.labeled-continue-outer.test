// Test: break.labeled-continue-outer
function main() returns int
    var x = 0
    var count = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            count = count + 1
            if y == 2 'check'
                continue 'outer'
            end 'check'
        end 'inner'
    end 'outer'
    return count
end 'main'
---
ExitCode: 6
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.push rbx
    x86.mov rcx, 0
    x86.lea r8, qword ptr [rbp-40]
    x86.mov qword ptr [r8], rcx
    x86.mov rcx, 0
    x86.jmp while.cond
  ^while.cond(%26: i64):
    x86.mov rdx, 3
    x86.cmp rcx, rdx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 1
    x86.mov r9, rcx
    x86.add r9, rdx
    x86.mov r10, 0
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rdx, qword ptr [r8]
    x86.mov rax, rdx
    x86.pop rbx
    x86.epilogue
    x86.ret
  ^while.cond_1(%28: i64):
    x86.mov rdx, 5
    x86.cmp r10, rdx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body_1
    x86.jmp while.exit_1
  ^while.body_1:
    x86.mov rdx, 1
    x86.mov rax, r10
    x86.add rax, rdx
    x86.mov rdx, qword ptr [r8]
    x86.mov r11, 1
    x86.mov rbx, rdx
    x86.add rbx, r11
    x86.mov qword ptr [r8], rbx
    x86.mov r11, 2
    x86.cmp rax, r11
    x86.sete r11
    x86.test r11, r11
    x86.jne then
    x86.jmp merge
  ^while.exit_1:
    x86.mov rcx, r9
    x86.jmp while.cond
  ^then:
    x86.mov rcx, r9
    x86.jmp while.cond
  ^merge:
    x86.mov r10, rax
    x86.jmp while.cond_1
}
---

// Test: break.labeled-continue-outer
function main() returns int
  var x = 0
  var count = 0
  while x < 3 'outer'
    x = x + 1
    var y = 0
    while y < 5 'inner'
      y = y + 1
      count = count + 1
      if y == 2 'check'
        continue 'outer'
      end 'check'
    end 'inner'
  end 'outer'
  return count
end 'main'
---
ExitCode: 6
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp main.outer_0.header
  outer_0.header:
    x86.mov eax, 3
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge main.outer_0.exit
  outer_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.jmp main.inner_1.header
  inner_1.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge main.inner_1.exit
  inner_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.mov edx, 1
    x86.mov ebx, [rbp-16]
    x86.add ebx, edx
    x86.mov [rbp-16], ebx
    x86.mov esi, 2
    x86.cmp ecx, esi
    x86.jne main.check_2.after
  check_2:
    x86.jmp main.outer_0.header
  check_2.after:
    x86.jmp main.inner_1.header
  inner_1.exit:
    x86.jmp main.outer_0.header
  outer_0.exit:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: break.labeled-continue-outer
function main() returns int
    var x = 0
    var count = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            count = count + 1
            if y == 2 'check'
                continue 'outer'
            end 'check'
        end 'inner'
    end 'outer'
    return count
end 'main'
---
ExitCode: 6
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48 saved_gprs=[RBX,R12]
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov r8, 3
    x86.mov r9, 1
    x86.mov r10, rax
    x86.jmp while.cond
  ^while.cond(%25: i64):
    x86.cmp r10, r8
    x86.setl rdx
    x86.movzx rdx, rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, 1
    x86.mov r11, r10
    x86.add r11, rdx
    x86.mov rbx, 0
    x86.jmp while.cond_1
  ^while.exit:
    x86.mov rax, qword ptr [rcx]
    x86.epilogue saved_gprs=[RBX,R12]
    x86.ret
  ^while.cond_1(%26: i64):
    x86.mov rax, 5
    x86.cmp rbx, rax
    x86.setl rax
    x86.movzx rax, rax
    x86.test rax, rax
    x86.jne while.body_1
    x86.jmp while.cond.args.from.while.cond_1
    while.cond.args.from.while.cond_1:
    x86.mov r10, r11
    x86.jmp while.cond
  ^while.body_1:
    x86.mov rax, rbx
    x86.add rax, r9
    x86.mov rdx, qword ptr [rcx]
    x86.mov r12, rdx
    x86.add r12, r9
    x86.mov qword ptr [rcx], r12
    x86.mov rdx, 2
    x86.cmp rax, rdx
    x86.sete rdx
    x86.movzx rdx, rdx
    x86.test rdx, rdx
    x86.jne while.cond.args.from.while.body_1
    x86.jmp while.cond_1.args.from.while.body_1
    while.cond_1.args.from.while.body_1:
    x86.mov rbx, rax
    x86.jmp while.cond_1
    while.cond.args.from.while.body_1:
    x86.mov r10, r11
    x86.jmp while.cond
}

// Test: conditional-extensions.type-extension
type Box uses Item
  export var item Item
end 'Box'

extension Box where Item is Equatable
  function matches(other Item) returns bool
    return item == other
  end 'matches'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
  var b = IntBox{item: 42}
  if b.matches(42) 'yes'
    return 1
  end 'yes'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @conditional-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.lea rdi, [rbp-16]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-24], edx
    x86.mov esi, [rbp-24]
    x86.mov edi, 42
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov r9, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 42
    x86.call IntBox.matches
    x86.test eax, eax
    x86.je conditional-extensions.main.yes_0.after
  yes_0:
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  yes_0.after:
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @IntBox.matches(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov [rbp-16], ebx
    x86.mov eax, [rbp-16]
    x86.cmp eax, edx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
}
---

// Test: enum-function-param
union Status
  on
  off
end 'Status'

function isOn(s Status) returns bool
  var result = match s 'check'
    Status.on gives true
    Status.off gives false
  end 'check'
  return result
end 'isOn'

function main() returns ExitCode
  var status = Status.on
  if isOn(status) 'test'
    return 1
  end 'test'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @unions-simple.isOn(s: i64) -> i1 {
  entry:
    x86.prologue stack_size=48
    x86.mov [rbp-16], ecx
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-16]
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.jmp unions-simple.isOn.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne unions-simple.isOn.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.mov [rbp-24], eax
    x86.jmp unions-simple.isOn.check_0.merge
  check_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne unions-simple.isOn.check_0.merge
  check_0.case1:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp unions-simple.isOn.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-40], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
  func @unions-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov rcx, rdx
    x86.call unions-simple.isOn
    x86.test eax, eax
    x86.je unions-simple.main.test_0.after
  test_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  test_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

// Test: float-backed
union FloatBacked
  North = 1.1
  South = 2.2
  East = 3.3
end 'FloatBacked'

function main() returns ExitCode
  var f = FloatBacked.North
  var result = match f 'check'
    FloatBacked.North gives 1
    FloatBacked.South gives 0
    FloatBacked.East gives 0
  end 'check'
  return result
end 'main'
---
ExitCode: 1

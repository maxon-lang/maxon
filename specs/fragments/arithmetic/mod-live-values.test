// Test: mod-live-values
function modLive(a int, b int, x int) returns int
  var preserved = x + 1
  var result = a mod b
  return result + preserved
end 'modLive'

function main() returns int
  return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
module {
  func @modLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.add r8, eax
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.lea eax, [edx + r8]
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 3
    x86.mov edx, 5
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp modLive
  }
}
---

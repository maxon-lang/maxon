// Test: mod-live-values

typealias Integer = i64

function modLive(a Integer, b Integer, x Integer) returns Integer
  var preserved = x + 1
  var result = a mod b
  return result + preserved
end 'modLive'

function main() returns ExitCode
  return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
module {
  func @arithmetic.modLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.add r8, eax
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.lea eax, [edx + r8]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 3
    x86.mov edx, 5
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call arithmetic.modLive
    x86.mov [rbp-8], eax
    x86.xor ebx, ebx
    x86.cmp eax, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: mod-live-values
function modLive(a int, b int, x int) returns int
    var preserved = x + 1
    var result = a mod b
    return result + preserved
end 'modLive'

function main() returns int
    return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 7
    x86.epilogue
    x86.ret
}
---

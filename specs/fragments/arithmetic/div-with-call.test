// Test: div-with-call
function helper(x int) returns int
    return x * 2
end 'helper'

function divCall(a int, b int) returns int
    var temp = a / b
    var result = helper(temp)
    return result + temp
end 'divCall'

function main() returns int
    return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 15
    x86.epilogue
    x86.ret
}
---

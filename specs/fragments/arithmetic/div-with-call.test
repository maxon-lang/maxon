// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
  return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
  var temp = trunc(a / b)
  var result = helper(temp)
  return result + temp
end 'divCall'

function main() returns ExitCode
  return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @arithmetic.helper(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @arithmetic.divCall(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov [rbp-16], eax
    x86.mov rcx, rax
    x86.call arithmetic.helper
    x86.mov ecx, [rbp-16]
    x86.add eax, ecx
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call arithmetic.divCall
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: div-with-call
function helper(x int) returns int
  return x * 2
end 'helper'

function divCall(a int, b int) returns int
  var temp = trunc(a / b)
  var result = helper(temp)
  return result + temp
end 'divCall'

function main() returns int
  return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @arithmetic.helper(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @arithmetic.divCall(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.cvtsi2sd xmm0, ecx
    x86.cvtsi2sd xmm1, edx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.mov [rbp-8], eax
    x86.mov rcx, rax
    x86.call arithmetic.helper
    x86.mov ecx, [rbp-8]
    x86.add eax, ecx
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp arithmetic.divCall
  }
}
---

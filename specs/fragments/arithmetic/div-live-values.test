// Test: div-live-values
function divLive(a int, b int, x int) returns int
    var preserved = x + 1
    var result = a / b
    return result + preserved
end 'divLive'

function main() returns int
    return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 11
    x86.epilogue
    x86.ret
}
---

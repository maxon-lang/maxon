// Test: div-live-values
function divLive(a Integer, b Integer, x Integer) returns Integer
  var preserved = x + 1
  var result = a / b
  return trunc(result + preserved)
end 'divLive'

function main() returns Integer
  return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @arithmetic.divLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.add r8, eax
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.add eax, r8
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 5
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp arithmetic.divLive
  }
}
---

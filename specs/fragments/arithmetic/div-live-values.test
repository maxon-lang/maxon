// Test: div-live-values
function divLive(a int, b int, x int) returns int
  var preserved = x + 1
  var result = a / b
  return trunc(result + preserved)
end 'divLive'

function main() returns int
  return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @arithmetic.divLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x86.mov eax, 1
    x86.add r8, eax
    x86.cvtsi2sd xmm0, ecx
    x86.cvtsi2sd xmm1, edx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvtsi2sd xmm3, r8
    x86.movsd xmm4, xmm2
    x86.addsd xmm4, xmm3
    x86.cvttsd2si ecx, xmm4
    x86.mov eax, ecx
    x86.ret
  }
  func @arithmetic.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 5
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp arithmetic.divLive
  }
}
---

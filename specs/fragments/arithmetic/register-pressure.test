// Test: register-pressure

typealias Integer = int(i64.min to i64.max)

function manyVars(a Integer, b Integer, c Integer, d Integer, e Integer, f Integer) returns Integer
  var v1 = a + 1
  var v2 = b + 2
  var v3 = c + 3
  var v4 = d + 4
  var v5 = e + 5
  var v6 = f + 6
  var v7 = v1 + v2
  var v8 = v3 + v4
  var v9 = v5 + v6
  var v10 = v7 + v8
  var v11 = v9 + v10
  var v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
  return v12
end 'manyVars'

function main() returns ExitCode
  return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
module {
  func @arithmetic.manyVars(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.add rcx, rax
    x86.mov rax, 2
    x86.add rdx, rax
    x86.mov rax, 3
    x86.add r8, rax
    x86.mov rax, 4
    x86.add r9, rax
    x86.mov rax, 5
    x86.add rsi, rax
    x86.mov rax, 6
    x86.add rdi, rax
    x86.lea rax, [rcx + rdx]
    x86.lea rbx, [r8 + r9]
    x86.mov [rbp-8], rcx
    x86.lea rcx, [rsi + rdi]
    x86.add rax, rbx
    x86.add rcx, rax
    x86.mov rax, [rbp-8]
    x86.add rcx, rax
    x86.add rcx, rdx
    x86.add rcx, r8
    x86.add rcx, r9
    x86.add rcx, rsi
    x86.lea rax, [rcx + rdi]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.mov rdx, 2
    x86.mov r8, 3
    x86.mov r9, 4
    x86.mov rsi, 5
    x86.mov rdi, 6
    x86.call arithmetic.manyVars
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rcx
    x86.movzx rcx, rcxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg rax
    x86.movzx rax, raxb
    x86.or rcx, rax
    x86.test rcx, rcx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_41]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

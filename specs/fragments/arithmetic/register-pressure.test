// Test: register-pressure
function manyVars(a int, b int, c int, d int, e int, f int) returns int
    var v1 = a + 1
    var v2 = b + 2
    var v3 = c + 3
    var v4 = d + 4
    var v5 = e + 5
    var v6 = f + 6
    var v7 = v1 + v2
    var v8 = v3 + v4
    var v9 = v5 + v6
    var v10 = v7 + v8
    var v11 = v9 + v10
    var v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
    return v12
end 'manyVars'

function main() returns int
    return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
func.func @manyVars(%a: i64, %b: i64, %c: i64, %d: i64, %e: i64, %f: i64) -> i64 {
  ^entry(%a: i64, %b: i64, %c: i64, %d: i64, %e: i64, %f: i64):
    x86.prologue stack_size=32
    x86.push rbx
    x86.push r12
    x86.push r13
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.mov rdx, r8
    x86.mov r8, r9
    x86.mov r9, qword ptr [rbp+16]
    x86.mov r10, qword ptr [rbp+24]
    x86.mov r11, 1
    x86.mov rbx, rax
    x86.add rbx, r11
    x86.mov r11, 2
    x86.mov rax, rcx
    x86.add rax, r11
    x86.mov r11, 3
    x86.mov rcx, rdx
    x86.add rcx, r11
    x86.mov r11, 4
    x86.mov rdx, r8
    x86.add rdx, r11
    x86.mov r11, 5
    x86.mov r8, r9
    x86.add r8, r11
    x86.mov r11, 6
    x86.mov r9, r10
    x86.add r9, r11
    x86.mov r11, rbx
    x86.add r11, rax
    x86.mov r10, rcx
    x86.add r10, rdx
    x86.mov r12, r8
    x86.add r12, r9
    x86.mov r13, r11
    x86.add r13, r10
    x86.mov r10, r12
    x86.add r10, r13
    x86.mov r11, r10
    x86.add r11, rbx
    x86.mov r10, r11
    x86.add r10, rax
    x86.mov rax, r10
    x86.add rax, rcx
    x86.mov rcx, rax
    x86.add rcx, rdx
    x86.mov rdx, rcx
    x86.add rdx, r8
    x86.mov r8, rdx
    x86.add r8, r9
    x86.mov rax, r8
    x86.pop r13
    x86.pop r12
    x86.pop rbx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.mov rdx, 3
    x86.mov r8, 4
    x86.mov r9, 5
    x86.mov r10, 6
    x86.push r10
    x86.push r9
    x86.mov r10, rax
    x86.mov r11, 2
    x86.push rdx
    x86.push r8
    x86.pop r9
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call manyVars
    x86.add rsp, 16
    x86.mov r8, rax
    x86.mov rax, r8
    x86.epilogue
    x86.ret
}

    x86.add r8, eax
    x86.mov eax, 4
    x86.add r9, eax
    x86.mov eax, 5
    x86.add esi, eax
    x86.mov eax, 6
    x86.add edi, eax
    x86.lea eax, [ecx + edx]
    x86.lea ebx, [r8 + r9]
    x86.mov [rbp-8], ecx
    x86.lea ecx, [esi + edi]
    x86.add eax, ebx
    x86.add ecx, eax
    x86.mov eax, [rbp-8]
    x86.add ecx, eax
    x86.add ecx, edx
    x86.add ecx, r8
    x86.add ecx, r9
    x86.add ecx, esi
    x86.lea eax, [ecx + edi]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.mov rdx, 2
    x86.mov r8, 3
    x86.mov r9, 4
    x86.mov rsi, 5
    x86.mov rdi, 6
    x86.call arithmetic.manyVars
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_43]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

// Test: register-pressure
function manyVars(a int, b int, c int, d int, e int, f int) returns int
  var v1 = a + 1
  var v2 = b + 2
  var v3 = c + 3
  var v4 = d + 4
  var v5 = e + 5
  var v6 = f + 6
  var v7 = v1 + v2
  var v8 = v3 + v4
  var v9 = v5 + v6
  var v10 = v7 + v8
  var v11 = v9 + v10
  var v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
  return v12
end 'manyVars'

function main() returns int
  return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
module {
  func @manyVars(a: i64, b: i64, c: i64, d: i64, e: i64, f: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.add ecx, eax
    x86.mov eax, 2
    x86.add edx, eax
    x86.mov eax, 3
    x86.add r8, eax
    x86.mov eax, 4
    x86.add r9, eax
    x86.mov eax, 5
    x86.add esi, eax
    x86.mov eax, 6
    x86.add edi, eax
    x86.mov eax, ecx
    x86.add eax, edx
    x86.mov ebx, r8
    x86.add ebx, r9
    x86.mov [rbp-8], ecx
    x86.mov ecx, esi
    x86.add ecx, edi
    x86.add eax, ebx
    x86.add ecx, eax
    x86.mov eax, [rbp-8]
    x86.add ecx, eax
    x86.add ecx, edx
    x86.add ecx, r8
    x86.add ecx, r9
    x86.add ecx, esi
    x86.add ecx, edi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 3
    x86.mov ebx, 4
    x86.mov esi, 5
    x86.mov edi, 6
    x86.mov r8, rdx
    x86.mov r9, rbx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp manyVars
  }
}

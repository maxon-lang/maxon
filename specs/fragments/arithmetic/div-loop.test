// Test: div-loop
function divLoop(n int) returns int
  var sum = 0
  var i = 1
  while i <= n 'loop'
    sum = sum + trunc(100 / i)
    i = i + 1
  end 'loop'
  return sum
end 'divLoop'

function main() returns int
  return divLoop(5)
end 'main'
---
ExitCode: 228
---
module {
  func @divLoop(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.mov eax, 1
    x86.mov [rbp-24], eax
    x86.jmp divLoop.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.cmp eax, ecx
    x86.jg divLoop.loop_0.exit
  loop_0:
    x86.mov eax, 100
    x86.mov ecx, [rbp-24]
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ecx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si edx, xmm2
    x86.mov ebx, [rbp-16]
    x86.add ebx, edx
    x86.mov [rbp-16], ebx
    x86.mov esi, 1
    x86.mov edi, [rbp-24]
    x86.add edi, esi
    x86.mov [rbp-24], edi
    x86.jmp divLoop.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.call divLoop
    x86.ret
  }
}

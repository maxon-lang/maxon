// Test: multi-div
function multiDiv(a int, b int, c int, d int) returns int
    var r1 = a / b
    var r2 = c / d
    return r1 + r2
end 'multiDiv'

function main() returns int
    return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.epilogue
    x86.ret
}
---

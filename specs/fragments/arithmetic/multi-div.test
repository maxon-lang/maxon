// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @arithmetic.multiDiv(a: i64, b: i64, c: i64, d: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov [rbp-16], eax
    x86.mov eax, r8
    x86.cqo
    x86.idiv r9
    x86.mov ecx, [rbp-16]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 20
    x86.mov ebx, 4
    x86.mov r8, rdx
    x86.mov r9, rbx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call arithmetic.multiDiv
    x86.mov [rbp-8], eax
    x86.xor esi, esi
    x86.cmp eax, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je arithmetic.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

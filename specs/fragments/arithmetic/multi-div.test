// Test: multi-div
function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns Integer
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @arithmetic.multiDiv(a: i64, b: i64, c: i64, d: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov ebx, edx
    x86.mov [rbp-8], edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov [rbp-16], eax
    x86.mov eax, r8
    x86.cqo
    x86.idiv r9
    x86.mov ecx, [rbp-16]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }
  func @arithmetic.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 20
    x86.mov ebx, 4
    x86.mov r8, rdx
    x86.mov r9, rbx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp arithmetic.multiDiv
  }
}
---

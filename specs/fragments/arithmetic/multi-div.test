// Test: multi-div
function multiDiv(a int, b int, c int, d int) returns int
  var r1 = a / b
  var r2 = c / d
  return trunc(r1 + r2)
end 'multiDiv'

function main() returns int
  return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @multiDiv(a: i64, b: i64, c: i64, d: i64) -> i64 {
  entry:
    x86.cvtsi2sd xmm0, ecx
    x86.cvtsi2sd xmm1, edx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvtsi2sd xmm3, r8
    x86.cvtsi2sd xmm4, r9
    x86.movsd xmm5, xmm3
    x86.divsd xmm5, xmm4
    x86.movsd xmm6, xmm2
    x86.addsd xmm6, xmm5
    x86.cvttsd2si eax, xmm6
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 20
    x86.mov ebx, 4
    x86.mov r8, rdx
    x86.mov r9, rbx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp multiDiv
  }
}
---

// Test: multi-div
function multiDiv(a int, b int, c int, d int) returns int
    var r1 = a / b
    var r2 = c / d
    return r1 + r2
end 'multiDiv'

function main() returns int
    return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
func.func @multiDiv(%a: i64, %b: i64, %c: i64, %d: i64) -> i64 {
  ^entry(%a: i64, %b: i64, %c: i64, %d: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.mov r10, rcx
    x86.cdq
    x86.idiv r10
    x86.mov r10, rax
    x86.mov rcx, r9
    x86.mov rax, r8
    x86.cdq
    x86.idiv rcx
    x86.mov rcx, rax
    x86.mov rdx, r10
    x86.add rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 10
    x86.mov rdx, 20
    x86.mov r8, 4
    x86.mov r10, rax
    x86.mov r11, 2
    x86.push rdx
    x86.push r8
    x86.pop r9
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call multiDiv
    x86.mov r8, rax
    x86.mov rax, r8
    x86.epilogue
    x86.ret
}
---

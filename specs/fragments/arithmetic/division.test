// Test: division
function main() returns int
  return 100 / 4
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 4
    x86.mov [rbp-8], eax
    x86.cqo
    x86.idiv ecx
    x86.epilogue
    x86.ret
  }
}
---

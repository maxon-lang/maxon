    x86.mov r10, ecx
    x86.mov rcx, r8
    x86.mov rdx, rax
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @closure-capture.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func eax, [__closure_0]
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov edx, 10
    x86.mov ebx, [rbp-8]
    x86.mov rcx, rax
    x86.mov r8, rdx
    x86.mov rdx, rbx
    x86.epilogue

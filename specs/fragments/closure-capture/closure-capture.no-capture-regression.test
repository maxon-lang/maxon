// Test: closure-capture.no-capture-regression
function apply(f (int) returns int, x int) returns int
  return f(x)
end 'apply'

function main() returns int
  var result = apply(f: (n int) gives n * 3, x: 10)
  return result
end 'main'
---
ExitCode: 30
---

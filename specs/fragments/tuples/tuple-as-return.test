    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+8], esi
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @tuples.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10

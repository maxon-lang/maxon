    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [edx+0]
    x86.mov esi, [rbp-8]
    x86.mov edi, [esi+8]
    x86.add ebx, edi
    x86.mov [rbp-16], ebx
    x86.xor r8, r8
    x86.cmp ebx, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rbx, rax
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je tuples.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_16]

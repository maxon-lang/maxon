// Test: tuple-as-return

typealias Integer = i64

function makePair(a Integer, b Integer) returns (Integer, Integer)
  return (a, b)
end 'makePair'

function main() returns ExitCode
  var t = makePair(10, b: 32)
  return t.0 + t.1
end 'main'
---
ExitCode: 42
---

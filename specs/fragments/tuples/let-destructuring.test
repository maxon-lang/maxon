// Test: let-destructuring
function main() returns ExitCode
  let (x, y) = (10, 32)
  return x + y
end 'main'
---
ExitCode: 42
---
module {
  func @tuples.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.lea rdi, [rbp-24]
    x86.xor eax, eax
    x86.mov ecx, 3
    x86.rep_stosq
    x86.lea rdx, [rbp-24]
    x86.mov rbx, rdx
    x86.mov esi, 8
    x86.add ebx, esi
    x86.mov [rbp-32], ebx
    x86.mov edi, [rbp-32]
    x86.mov r8, 10
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-32]
    x86.mov eax, 32
    x86.mov [r9+8], eax
    x86.mov eax, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call mm_incref
    x86.mov eax, [rbp-32]
    x86.mov ecx, [eax+0]
    x86.mov eax, [rbp-32]
    x86.mov edx, [eax+8]
    x86.add ecx, edx
    x86.mov [rbp-40], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je tuples.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_14]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [rbp-32]
    x86.call mm_decref
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
}

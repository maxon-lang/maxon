// Test: basic-tuple
function main() returns Integer
  var t = (10, 32)
  return t.0 + t.1
end 'main'
---
ExitCode: 42
---
module {
  func @tuples.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 32
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, [r9+0]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+8]
    x86.add eax, edx
    x86.epilogue
    x86.ret
  }
}
---

// Test: tuple-as-param

typealias Integer = int(i64.min to i64.max)

function sum(t (Integer, Integer)) returns Integer
  return t.0 + t.1
end 'sum'

function main() returns ExitCode
  var t = (10, 32)
  return sum(t)
end 'main'

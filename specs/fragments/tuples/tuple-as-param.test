// Test: tuple-as-param
function sum(t (Integer, Integer)) returns Integer
  return t.0 + t.1
end 'sum'

function main() returns Integer
  var t = (10, 32)
  return sum(t)
end 'main'
---
ExitCode: 42
---
module {
  func @tuples.sum(t: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @tuples.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 32
    x86.mov [edi+8], r8
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp tuples.sum
  }
}
---

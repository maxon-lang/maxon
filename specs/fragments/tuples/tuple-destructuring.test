    x86.mov ecx, [rbp-16]
    x86.mov [eax+0], ecx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-24]
    x86.mov [edx+8], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @tuples.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 10
    x86.mov rdx, 32
    x86.call tuples.makePair
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [edx+8]
    x86.add ecx, ebx
    x86.mov [rbp-16], ecx
    x86.xor esi, esi
    x86.cmp ecx, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rcx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je tuples.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-16]

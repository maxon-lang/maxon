// Test: tuple-destructuring

typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
  return (a, b)
end 'makePair'

function main() returns ExitCode
  var (x, y) = makePair(10, b: 32)
  return x + y
end 'main'
---
ExitCode: 42
---

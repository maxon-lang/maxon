// Test: pow.int-promotion.1
function main() returns int
    var result = Math.pow(3, 2)  // Ints promoted to float
    return trunc(result)
end 'main'
---
ExitCode: 9
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 3
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_const.1 = const.i64 i64 2
    %tmp_sitofp.1 = sitofp f64 %tmp_const.1
    %tmp_call = call f64 @Math$pow(%tmp_sitofp, %tmp_sitofp.1)
    %tmp_fptosi = fptosi i64 %tmp_call
    ret %tmp_fptosi
}

---

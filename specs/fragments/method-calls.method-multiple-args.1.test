// Test: method-calls.method-multiple-args.1
type Calculator
    var result int

    function addTwo(a int, b int)
        result = result + a + b
    end 'addTwo'

    function get() returns int
        return result
    end 'get'
end 'Calculator'

function main() returns int
    var calc = Calculator{result: 0}
    calc.addTwo(20, 22)
    return calc.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %calc = alloca.sized ptr 8
    memset %calc 0 8
    %tmp_fieldptr = getfieldptr ptr %calc 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 20
    %tmp_const.2 = const.i64 i64 22
    call @Calculator$addTwo(%calc, %tmp_const.1, %tmp_const.2)
    %tmp_call = call i64 @Calculator$get(%calc)
    ret %tmp_call
}

function Calculator$addTwo() -> void {
entry_0:
    %self = param ptr 0
    %a = param i64 1
    %b = param i64 2
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_add = add i64 %tmp_load %a
    %tmp_add.1 = add i64 %tmp_add %b
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add.1
    ret
}

function Calculator$get() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

---

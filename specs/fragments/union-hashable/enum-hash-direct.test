// Test: enum-hash-direct
union Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var d = Direction.south
  var h = d.hash()
  return h
end 'main'
---
ExitCode: 1
---
module {
  func @Direction.hash(self: i64) -> i64 {
  entry:
    x86.jmp stdlib.int.hash
  }
  func @union-hashable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov [rbp-8], rax
    x86.mov rcx, [rbp-8]
    x86.call Direction.hash
    x86.mov [rbp-16], rax
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je union-hashable.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

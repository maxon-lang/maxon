// Test: error.enum-eq-associated

typealias Integer = int(i64.min to i64.max)

union Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var a = Container.empty
  var b = Container.empty
  if a == b 'check'
    return 1
  end 'check'
  return 0
end 'main'

    %tmp_const.5 = const.i64 i64 1
    store %tmp_heap.1 %tmp_const.5
    %tmp_const.6 = const.i64 i64 99
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_heap.1 8
    store %tmp_fieldptr.2 %tmp_const.6
    store %tmp_alloca.2 %tmp_heap.1
    br @try_merge_3
try_merge_3:
    %tmp_load.4 = load ptr %tmp_alloca.2
    br @match_check_4
match_check_4:
    %tmp_const.9 = const.i64 i64 0
    %tmp_load.7 = load i64 %tmp_load.4
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.7 %tmp_const.9
    br.cond %tmp_icmp.1 @match_body_5 @match_check_6
match_body_5:
    %tmp_const.10 = const.i64 i64 1
    ret %tmp_const.10
match_check_6:
    %tmp_const.11 = const.i64 i64 1

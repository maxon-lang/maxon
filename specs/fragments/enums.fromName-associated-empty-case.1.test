// Test: enums.fromName-associated-empty-case.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = try Container.fromName("empty") otherwise Container.value(99)
    match c 'check'
        empty then return 1
        value(_n) then return 0
    end 'check'
end 'main'
---
ExitCode: 1
---

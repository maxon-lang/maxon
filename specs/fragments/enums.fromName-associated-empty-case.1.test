    store %tmp_fieldptr %tmp_heap
    %tmp_const.3 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_const.2 %tmp_const.3
    %tmp_alloca.2 = alloca ptr
    br.cond %tmp_icmp @try_success_1 @try_default_2
try_success_1:
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_alloca.1 8

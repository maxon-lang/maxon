    x86.mov [rbp-24], edx
    x86.test eax, eax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov ecx, [rbp-24]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-8]
    x86.mov [esi+8], ebx
    x86.epilogue
    x86.ret
  }

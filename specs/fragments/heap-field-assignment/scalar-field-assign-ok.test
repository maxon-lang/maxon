// Test: scalar-field-assign-ok
type Counter
  var count Count

  export function increment()
    count = count + 1
  end 'increment'

  export function value() returns Count
    return count
  end 'value'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 0}
  c.increment()
  c.increment()
  return c.value()
end 'main'

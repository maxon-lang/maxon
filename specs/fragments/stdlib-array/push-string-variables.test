// Test: push-string-variables
typealias StringArray = Array with String

function main() returns ExitCode
  var arr = StringArray{}
  var s1 = "first"
  var s2 = "second"
  arr.push(s1)
  arr.push(s2)

  var v0 = try arr.get(0) otherwise ""
  var v1 = try arr.get(1) otherwise ""
  print(v0)
  print(v1)
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
firstsecond
```

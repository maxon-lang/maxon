// Test: set-element
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  arr.set(1, value: 99)

  var val = try arr.get(1) otherwise -1
  if val != 99 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---

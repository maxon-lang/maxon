// Test: reserve-capacity
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr.reserve(100)

  if arr.capacity() < 100 'cap'
    return 1
  end 'cap'

  if arr.count() != 0 'cnt'
    return 2
  end 'cnt'

  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> i64 {
  entry:
    x86.prologue stack_size=160
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 100
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.lea r8, [rbp-40]
    x86.mov rcx, r8
    x86.mov rdx, rdi
    x86.call IntArray.reserve
    x86.mov r9, [rbp-8]
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-32]
    x86.mov ebx, [rbp-40]
    x86.mov [rbp-48], r9
    x86.mov [rbp-56], eax
    x86.mov [rbp-64], ecx
    x86.mov [rbp-72], edx
    x86.mov [rbp-80], ebx
    x86.lea rax, [rbp-80]
    x86.mov rcx, rax
    x86.call IntArray.capacity
    x86.mov ecx, [rbp-48]
    x86.mov [rbp-88], ecx
    x86.mov ecx, [rbp-56]
    x86.mov [rbp-96], ecx
    x86.mov ecx, [rbp-64]
    x86.mov [rbp-104], ecx
    x86.mov ecx, [rbp-72]
    x86.mov [rbp-112], ecx
    x86.mov ecx, [rbp-80]
    x86.mov [rbp-120], ecx
    x86.mov ecx, 100
    x86.cmp eax, ecx
    x86.jge stdlib-array.main.cap_0.after
  cap_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  cap_0.after:
    x86.mov eax, [rbp-88]
    x86.mov [rbp-128], eax
    x86.mov ecx, [rbp-96]
    x86.mov [rbp-136], ecx
    x86.mov edx, [rbp-104]
    x86.mov [rbp-144], edx
    x86.mov ebx, [rbp-112]
    x86.mov [rbp-152], ebx
    x86.mov esi, [rbp-120]
    x86.mov [rbp-160], esi
    x86.lea rdi, [rbp-160]
    x86.mov rcx, rdi
    x86.call IntArray.count
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.je stdlib-array.main.cnt_1.after
  cnt_1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  cnt_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

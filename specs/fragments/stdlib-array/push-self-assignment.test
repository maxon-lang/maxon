// Test: push-self-assignment
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr = arr.push(1)
  arr = arr.push(2)
  arr = arr.push(3)

  var sum = 0
  for n in arr 'loop'
    sum = sum + n
  end 'loop'

  // 1 + 2 + 3 = 6
  return sum
end 'main'
---
ExitCode: 6

    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, 10
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, 20
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, 30
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call IntArray.pop
    x86.mov ecx, -1

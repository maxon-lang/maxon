    x86.jmp stdlib-array.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 30
    x86.cmp eax, ecx
    x86.je stdlib-array.main.check_4.after
  check_4:
    x86.mov eax, [rbp-16]
    x86.test eax, eax
    x86.jz __destruct_nullguard_0
    x86.mov rcx, [rbp-16]

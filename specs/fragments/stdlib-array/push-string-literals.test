// Test: push-string-literals
typealias StringArray = Array with String

function main() returns int
  var arr = StringArray{}
  arr.push("hello")
  arr.push("world")

  if arr.count() != 2 'cnt'
    return 1
  end 'cnt'

  var s0 = try arr.get(0) otherwise ""
  var s1 = try arr.get(1) otherwise ""
  print(s0)
  print(s1)
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
helloworld
```

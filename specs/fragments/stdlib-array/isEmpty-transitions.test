// Test: isEmpty-transitions
typealias IntArray = Array with int

function main() returns ExitCode
  var arr = IntArray{}

  if arr.isEmpty() == false 'e1'
    return 1
  end 'e1'

  arr.push(42)

  if arr.isEmpty() == true 'e2'
    return 2
  end 'e2'

  var _ = try arr.pop() otherwise 0

  if arr.isEmpty() == false 'e3'
    return 3
  end 'e3'

  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.isEmpty
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne stdlib-array.main.e1_0.after
  e1_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  e1_0.after:
    x86.mov eax, 42
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov edx, [rbp-16]
    x86.mov rcx, rdx
    x86.call IntArray.isEmpty
    x86.mov ebx, 1
    x86.cmp eax, ebx
    x86.jne stdlib-array.main.e2_1.after
  e2_1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  e2_1.after:
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.pop
    x86.xor ecx, ecx
    x86.mov [rbp-24], ecx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je stdlib-array.main.otherwise_default_continue_5
  otherwise_default_error_4:
    x86.mov eax, [rbp-24]
    x86.jmp stdlib-array.main.otherwise_default_continue_5
  otherwise_default_continue_5:
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.isEmpty
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne stdlib-array.main.e3_6.after
  e3_6:
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  e3_6.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

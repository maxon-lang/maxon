// Test: string-array-iteration
typealias StringArray = Array with String

function main() returns ExitCode
  var arr = StringArray{}
  arr.push("a")
  arr.push("b")
  arr.push("c")

  for item in arr 'loop'
    print(item)
  end 'loop'
  return 0
end 'main'

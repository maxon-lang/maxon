    x86.mov rcx, 16
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.xor edx, edx
    x86.mov [ecx+0], edx
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [edx+8], ecx
    x86.mov edx, [rbp-24]
    x86.mov r8, 1
    x86.call mm_move
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 10
    x86.call IntArray.push
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 20
    x86.call IntArray.push
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 30
    x86.call IntArray.push
    x86.xor eax, eax
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.mov eax, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call mm_incref
    x86.jmp stdlib-array.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call IntArray.next
    x86.mov [rbp-48], eax

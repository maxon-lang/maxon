// Test: for-in-iteration
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  var sum = 0
  for item in arr 'loop'
    sum = sum + item
  end 'loop'

  if sum != 60 'check'
    return 1
  end 'check'

  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.xor esi, esi
    x86.mov edi, 8
    x86.mov r8, 32
    x86.xor r9, r9
    x86.mov rcx, r8
    x86.mov rdx, r9
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.xor ecx, ecx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.xor edx, edx
    x86.mov [ecx+0], edx
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [edx+8], ecx
    x86.mov edx, [rbp-24]
    x86.xor ebx, ebx
    x86.mov r8, rbx
    x86.call mm_reparent
    x86.mov eax, 10
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 20
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 30
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.xor eax, eax
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.jmp stdlib-array.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-40]
    x86.mov rcx, rax
    x86.call IntArray.next
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.jne stdlib-array.main.loop_0.exit
  loop_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-56], eax
    x86.mov ecx, [rbp-48]
    x86.mov edx, [rbp-32]
    x86.add edx, ecx
    x86.mov [rbp-32], edx
    x86.mov rcx, [rbp-56]
    x86.call mm_scope_exit
    x86.jmp stdlib-array.main.loop_0.header
  loop_0.exit:
    x86.mov eax, 60
    x86.mov ecx, [rbp-32]
    x86.cmp ecx, eax
    x86.je stdlib-array.main.check_3.after
  check_3:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-64], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-64]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_3.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.mov ecx, [rbp-40]
    x86.call mm_decref
    x86.mov edx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue

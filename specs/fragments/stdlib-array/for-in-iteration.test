// Test: for-in-iteration
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  var sum = 0
  for item in arr 'loop'
    sum = sum + item
  end 'loop'

  if sum != 60 'check'
    return 1
  end 'check'

  return 0
end 'main'

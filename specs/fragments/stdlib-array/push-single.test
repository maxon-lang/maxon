    x86.xor ecx, ecx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+8], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, 1
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_move
    x86.mov eax, 42
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call IntArray.get
    x86.mov ecx, -1
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je stdlib-array.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-40], eax
    x86.jmp stdlib-array.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 42
    x86.cmp eax, ecx
    x86.je stdlib-array.main.check_4.after
  check_4:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-48], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-48]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]

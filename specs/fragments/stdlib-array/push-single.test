// Test: push-single
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr.push(42)
  var val = try arr.get(0) otherwise -1
  if val != 42 'check'
    return 1
  end 'check'
  return 0
end 'main'

// Test: empty-array
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  if arr.count() != 0 'check'
    return 1
  end 'check'
  if arr.isEmpty() == false 'empty'
    return 2
  end 'empty'
  return 0
end 'main'

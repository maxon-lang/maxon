// Test: first-last
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  var f = try arr.first() otherwise -1
  if f != 10 'fc'
    return 1
  end 'fc'

  var l = try arr.last() otherwise -1
  if l != 30 'lc'
    return 3
  end 'lc'

  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 10
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 20
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 30
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.first
    x86.mov ecx, -1
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je stdlib-array.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.jmp stdlib-array.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 10
    x86.cmp eax, ecx
    x86.je stdlib-array.main.fc_4.after
  fc_4:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov edx, 8
    x86.call maxon_release_with_managed
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  fc_4.after:
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.last
    x86.mov ecx, -1
    x86.mov [rbp-40], ecx
    x86.mov [rbp-48], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je stdlib-array.main.otherwise_default_continue_8
  otherwise_default_error_7:
    x86.mov eax, [rbp-40]
    x86.mov [rbp-48], eax
    x86.jmp stdlib-array.main.otherwise_default_continue_8
  otherwise_default_continue_8:
    x86.mov eax, [rbp-48]
    x86.mov ecx, 30
    x86.cmp eax, ecx
    x86.je stdlib-array.main.lc_9.after
  lc_9:
    x86.mov eax, 3
    x86.mov ecx, [rbp-16]
    x86.mov edx, 8
    x86.call maxon_release_with_managed
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  lc_9.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 8
    x86.call maxon_release_with_managed
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

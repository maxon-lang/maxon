// Test: array-literal
function main() returns ExitCode
  var arr = [1, 2, 3]
  
  if arr.count() != 3 'cnt'
    return 1
  end 'cnt'
  
  var v = try arr.get(1) otherwise -1
  if v != 2 'check'
    return 2
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov edx, 3
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.xor r8, r8
    x86.mov rcx, rdi
    x86.mov rdx, r8
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov r9, [rbp-16]
    x86.xor eax, eax
    x86.mov [r9+0], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.xor eax, eax
    x86.mov ecx, 16
    x86.xor edx, edx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+8], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, 1
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_move
    x86.lea_rdata rax, [__const_array_stdlib-array.main_arr]
    x86.mov rcx, rax
    x86.mov eax, [rbp-24]
    x86.mov edx, [eax+8]
    x86.mov [edx+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov rcx, rax
    x86.call stdlib.Array.count
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.je stdlib-array.main.cnt_1.after
  cnt_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  cnt_1.after:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rax
    x86.call stdlib.Array.get
    x86.mov ecx, -1
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je stdlib-array.main.otherwise_default_continue_5
  otherwise_default_error_4:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-40], eax
    x86.jmp stdlib-array.main.otherwise_default_continue_5
  otherwise_default_continue_5:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.je stdlib-array.main.check_6.after
  check_6:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  check_6.after:

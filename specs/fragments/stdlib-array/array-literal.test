// Test: array-literal
function main() returns ExitCode
  var arr = [1, 2, 3]
  
  if arr.count() != 3 'cnt'
    return 1
  end 'cnt'
  
  var v = try arr.get(1) otherwise -1
  if v != 2 'check'
    return 2
  end 'check'
  return 0
end 'main'

// Test: string-array-get
typealias StringArray = Array with String

function main() returns ExitCode
  var arr = StringArray{}
  arr.push("one")
  arr.push("two")
  arr.push("three")

  var val = try arr.get(1) otherwise ""
  print(val)
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
two
```

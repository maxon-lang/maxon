// Test: clear-array
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  arr.clear()

  if arr.count() != 0 'cnt'
    return 1
  end 'cnt'

  if arr.isEmpty() == false 'empty'
    return 2
  end 'empty'

  return 0
end 'main'

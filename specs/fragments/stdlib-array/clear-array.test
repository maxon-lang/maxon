// Test: clear-array
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr.push(10)
  arr.push(20)
  arr.push(30)

  arr.clear()

  if arr.count() != 0 'cnt'
    return 1
  end 'cnt'

  if arr.isEmpty() == false 'empty'
    return 2
  end 'empty'

  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], edx
    x86.mov [rbp-48], ebx
    x86.mov [rbp-56], esi
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-32]
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-40]
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-48]
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-56]
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 10
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 20
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, 30
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.clear
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.count
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.je stdlib-array.main.cnt_0.after
  cnt_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  cnt_0.after:
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call IntArray.isEmpty
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne stdlib-array.main.empty_1.after
  empty_1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  empty_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }

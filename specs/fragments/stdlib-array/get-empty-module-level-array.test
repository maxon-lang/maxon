// Test: get-empty-module-level-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int
var arr = IntArray{}

function main() returns ExitCode
  var val = try arr.get(0) otherwise -1
  if val == -1 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @stdlib-array.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, qword [rip+arr]
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov rcx, [rbp-16]
    x86.call IntArray.get
    x86.mov esi, -1
    x86.mov [rbp-24], esi
    x86.mov [rbp-32], eax
    x86.xor edi, edi
    x86.cmp edx, edi
    x86.je stdlib-array.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.jmp stdlib-array.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-32]
    x86.mov ecx, -1
    x86.cmp eax, ecx
    x86.jne stdlib-array.main.check_4.after
  check_4:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-40]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_4.after:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
  func @stdlib-array.__module_init() {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.xor r8, r8
    x86.mov rcx, rdi
    x86.mov rdx, r8
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov r9, [rbp-8]
    x86.xor eax, eax
    x86.mov [r9+0], eax
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.xor ecx, ecx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call mm_move
    x86.mov eax, [rbp-16]
    x86.mov qword [rip+arr], eax
    x86.epilogue
    x86.ret
  }
  func @__maxon_global_cleanup() {
  entry:
    x86.mov eax, qword [rip+arr]
    x86.mov rcx, rax
    x86.call mm_free
    x86.ret
  }
}
---

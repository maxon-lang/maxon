end 'getCode'

function main() returns int
    var code = getCode()
    var status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
    if status == HttpStatus.notFound 'check'
        return 1
    end 'check'
    return 0
end 'main'

// Test: string-keys-get-multiple
function main() returns ExitCode
  var m = ["hello": 10, "world": 20, "foo": 30]
  var a = try m.get("hello") otherwise 0
  var b = try m.get("world") otherwise 0
  return a + b
end 'main'

// Test: remove-reinsert
function main() returns ExitCode
  var m = [1: 10, 2: 20, 3: 30]
  let _ = m.remove(2)
  m.insert(2, value: 200)
  var result = try m.get(2) otherwise 0
  return result
end 'main'

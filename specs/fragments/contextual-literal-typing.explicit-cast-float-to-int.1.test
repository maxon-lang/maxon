// Test: contextual-literal-typing.explicit-cast-float-to-int.1
function main() returns int
    var x = 5
    var y = 5.0
    if x == trunc(y) 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_fconst = const.f64 f64 5
    %tmp_fptosi = fptosi i64 %tmp_fconst
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_fptosi
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

---

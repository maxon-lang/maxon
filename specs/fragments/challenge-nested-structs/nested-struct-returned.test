    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @challenge-nested-structs.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call challenge-nested-structs.makeOuter
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov ebx, [edx+0]
    x86.mov [rbp-24], ebx
    x86.xor esi, esi
    x86.cmp ebx, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rbx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je challenge-nested-structs.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]

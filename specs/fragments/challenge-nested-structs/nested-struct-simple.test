// Test: nested-struct-simple
type Inner
  export var x int
  export var y int
end 'Inner'

type Outer
  export var inner Inner
  export var z int
end 'Outer'

function main() returns int
  var inner = Inner{x: 10, y: 20}
  var outer = Outer{inner: inner, z: 30}
  return outer.inner.x + outer.inner.y + outer.z
end 'main'
---
ExitCode: 60
---
module {
  func @challenge-nested-structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 30
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-8]
    x86.add ebx, esi
    x86.mov edi, [rbp-24]
    x86.lea eax, [ebx + edi]
    x86.epilogue
    x86.ret
  }
}
---

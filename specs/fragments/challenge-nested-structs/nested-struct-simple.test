    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-32], ebx
    x86.mov esi, 30
    x86.mov edi, [rbp-24]
    x86.mov [rbp-40], edi
    x86.mov r8, [rbp-32]
    x86.mov [rbp-48], r8
    x86.mov [rbp-56], esi
    x86.mov r9, [rbp-56]
    x86.mov [rbp-64], r9
    x86.mov eax, [rbp-40]
    x86.mov [rbp-72], eax
    x86.mov eax, [rbp-48]
    x86.mov [rbp-80], eax
    x86.mov eax, [rbp-80]
    x86.mov ecx, [rbp-72]
    x86.add eax, ecx
    x86.mov ecx, [rbp-64]
    x86.add eax, ecx
    x86.epilogue

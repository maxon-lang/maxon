// Test: deeply-nested-struct
type Level1
  export var value int
end 'Level1'

type Level2
  export var inner Level1
end 'Level2'

type Level3
  export var inner Level2
end 'Level3'

function main() returns int
  var l1 = Level1{value: 42}
  var l2 = Level2{inner: l1}
  var l3 = Level3{inner: l2}
  return l3.inner.inner.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-nested-structs.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.mov [rbp-48], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-48]
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, 8
    x86.mov rcx, r9
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-32], ecx
    x86.mov eax, [rbp-32]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-40], ecx
    x86.mov eax, [rbp-40]
    x86.mov ecx, [eax+0]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

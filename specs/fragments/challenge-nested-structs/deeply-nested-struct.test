// Test: deeply-nested-struct
type Level1
  export var value int
end 'Level1'

type Level2
  export var inner Level1
end 'Level2'

type Level3
  export var inner Level2
end 'Level3'

function main() returns int
  var l1 = Level1{value: 42}
  var l2 = Level2{inner: l1}
  var l3 = Level3{inner: l2}
  return l3.inner.inner.value
end 'main'
---
ExitCode: 42
---
module {
  func @challenge-nested-structs.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, 8
    x86.mov rcx, r9
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-32], ecx
    x86.mov eax, [rbp-32]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-40], ecx
    x86.mov eax, [rbp-40]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-48], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je challenge-nested-structs.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-48]
    x86.epilogue
    x86.ret
  }
}

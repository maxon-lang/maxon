// Test: transitive
// pow -> log, exp
function main() returns Integer
  var result = Math.pow(2.0, exponent: 3.0)
  if result > 7.5 'check'
    return 8
  end 'check'
  return 0
end 'main'
---
ExitCode: 8
---
module {
  func @stdlib-autodiscovery.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_2]
    x86.movsd xmm1, [rip+__float_3]
    x86.call stdlib.Math.pow
    x86.movsd xmm2, [rip+__float_7.5]
    x86.ucomisd xmm0, xmm2
    x86.jbe stdlib-autodiscovery.main.check_0.after
  check_0:
    x86.mov eax, 8
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

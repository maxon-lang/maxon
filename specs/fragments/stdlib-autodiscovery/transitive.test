// Test: transitive
// pow -> log, exp
function main() returns ExitCode
  var result = Math.pow(2.0, exponent: 3.0)
  if result > 7.5 'check'
    return 8
  end 'check'
  return 0
end 'main'
---
ExitCode: 8
---
module {
  func @stdlib-autodiscovery.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_2]
    x86.movsd xmm1, [rip+__float_3]
    x86.call stdlib.Math.pow
    x86.movsd xmm2, [rip+__float_7.5]
    x86.ucomisd xmm0, xmm2
    x86.jbe stdlib-autodiscovery.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.mov eax, 8
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 8
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: docs-example-1
function main() returns int
  // pow() is automatically found in stdlib/math/
  var result = Math.pow(2.0, exponent: 3.0)
  return trunc(result)
end 'main'

---
ExitCode: 8
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_2]
    x86.movsd xmm1, [rip+__float_3]
    x86.call Math.pow
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.epilogue
    x86.ret
  }
}
---

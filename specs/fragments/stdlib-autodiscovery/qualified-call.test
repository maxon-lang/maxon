// Test: qualified-call
function main() returns Integer
  return trunc(Math.pow(2.0, exponent: 4.0))
end 'main'
---
ExitCode: 16
---
module {
  func @stdlib-autodiscovery.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_2]
    x86.movsd xmm1, [rip+__float_4]
    x86.call stdlib.Math.pow
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}

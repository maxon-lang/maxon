// Test: ref-creates-alias
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = ref a
  if a is b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @reference-identity.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, 1
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-16]
    x86.mov edi, 2
    x86.mov [esi+8], edi
    x86.mov [rbp-24], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, [rbp-24]
    x86.cmp r8, r9
    x86.jne reference-identity.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

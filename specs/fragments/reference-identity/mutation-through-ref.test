// Test: mutation-through-ref
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = ref a
  b.x = 99
  return a.x
end 'main'
---
ExitCode: 99
---
module {
  func @reference-identity.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 1
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 2
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov [rbp-16], r9
    x86.mov rcx, r9
    x86.call maxon_incref
    x86.mov eax, 99
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-24], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je reference-identity.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-32], eax
    x86.call maxon_release
    x86.mov rcx, [rbp-16]
    x86.call maxon_release
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}

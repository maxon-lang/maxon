    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.cmp eax, ebx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
  func @reference-identity.main() -> u32 {
  entry:
    x86.prologue stack_size=48

    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-16]
    x86.mov esi, 42
    x86.mov [ebx+0], esi
    x86.mov edi, 42
    x86.lea rdi, [rbp-24]
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.rep_stosq
    x86.lea r8, [rbp-24]
    x86.mov r9, r8
    x86.mov [rbp-32], r9
    x86.mov eax, [rbp-32]
    x86.mov ecx, 42
    x86.mov [eax+0], ecx
    x86.xor eax, eax
    x86.mov [rbp-40], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-16]
    x86.call reference-identity.areSame
    x86.test eax, eax
    x86.je reference-identity.main.same_0.merge
  same_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-40]
    x86.add ecx, eax
    x86.mov [rbp-40], ecx
    x86.jmp reference-identity.main.same_0.merge
  same_0.merge:
    x86.mov eax, [rbp-16]

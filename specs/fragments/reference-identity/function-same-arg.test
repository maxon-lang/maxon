// Test: function-same-arg
typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer
end 'Box'

function areSame(a Box, b Box) returns bool
  return a is b
end 'areSame'

function main() returns ExitCode
  var x = Box{value: 42}
  var y = Box{value: 42}
  var result = 0
  if areSame(x, b: x) 'same'
    result = result + 1
  end 'same'
  if areSame(x, b: y) 'diff'
    result = result + 10
  end 'diff'
  return result
end 'main'
---
ExitCode: 1
---

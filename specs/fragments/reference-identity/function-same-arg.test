    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rdi, [rbp-16]
    x86.mov r8, 42
    x86.mov [rdi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.xor rax, rax
    x86.mov [rbp-24], rax
    x86.mov rax, [rbp-8]

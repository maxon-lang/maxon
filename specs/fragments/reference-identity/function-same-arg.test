// Test: function-same-arg
typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer
end 'Box'

function areSame(a Box, b Box) returns bool
  return a is b
end 'areSame'

function main() returns ExitCode
  var x = Box{value: 42}
  var y = Box{value: 42}
  var result = 0
  if areSame(x, b: x) 'same'
    result = result + 1
  end 'same'
  if areSame(x, b: y) 'diff'
    result = result + 10
  end 'diff'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @reference-identity.areSame(a: i64, b: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.cmp eax, ebx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
  func @reference-identity.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 42
    x86.mov [r8+0], r9
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call reference-identity.areSame
    x86.test eax, eax
    x86.je reference-identity.main.same_0.merge
  same_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.jmp reference-identity.main.same_0.merge
  same_0.merge:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call reference-identity.areSame
    x86.test eax, eax
    x86.je reference-identity.main.diff_1.merge
  diff_1:
    x86.mov eax, 10
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.jmp reference-identity.main.diff_1.merge
  diff_1.merge:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je reference-identity.main.__range_ok_2
  __range_panic_2:

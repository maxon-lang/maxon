    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 1
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov edi, 2
    x86.mov [esi+8], edi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-8]
    x86.mov eax, [rbp-8]
    x86.cmp r9, eax
    x86.je reference-identity.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __nonnull_skip_18
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_18
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __nonnull_skip_19
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_19
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

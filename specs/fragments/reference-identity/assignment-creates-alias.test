// Test: assignment-creates-alias
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = a
  if a is b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @reference-identity.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 1
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov edi, 2
    x86.mov [esi+8], edi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-8]
    x86.mov [rbp-16], r9
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.cmp eax, ecx
    x86.jne reference-identity.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov ecx, [rbp-16]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov ecx, [rbp-16]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_3
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @__destruct_Point(ptr: i64) {
  entry:
    x86.jmp __destruct_Point.done
  done:
    x86.ret
  }
}
---

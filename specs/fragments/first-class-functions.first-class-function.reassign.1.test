// Test: first-class-functions.first-class-function.reassign.1
function double(x int) returns int
    return x * 2
end 'double'

function triple(x int) returns int
    return x * 3
end 'triple'

function main() returns int
    var f = double
    var a = f(10)
    f = triple
    var b = f(10)
    return a + b
end 'main'
---
ExitCode: 50
---
function double() -> i64 {
entry_0:
    %x = param i64 0
    %tmp_const = const.i64 i64 2
    %tmp_mul = mul i64 %x %tmp_const
    ret %tmp_mul
}

function triple() -> i64 {
entry_0:
    %x = param i64 0
    %tmp_const = const.i64 i64 3
    %tmp_mul = mul i64 %x %tmp_const
    ret %tmp_mul
}

function main() -> i64 {
entry_0:
    %tmp_funcaddr = func.addr ptr @double
    %tmp_const = const.i64 i64 10
    %tmp_call_ind = call.indirect i64 %tmp_funcaddr(%tmp_const)
    %tmp_funcaddr.1 = func.addr ptr @triple
    %tmp_const.1 = const.i64 i64 10
    %tmp_call_ind.1 = call.indirect i64 %tmp_funcaddr.1(%tmp_const.1)
    %tmp_add = add i64 %tmp_call_ind %tmp_call_ind.1
    ret %tmp_add
}


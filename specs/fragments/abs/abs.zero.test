// Test: abs.zero
function main() returns ExitCode
  var x = abs(0.0)
  if x == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @abs.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, xmm0
    x86.andpd xmm1, [rip+__abs_mask]
    x86.movsd xmm2, [rip+__float_0]
    x86.ucomisd xmm1, xmm2
    x86.jne abs.main.check_0.after
    x86.jp abs.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

// Test: abs.negative-int-as-float
function main() returns int
  var neg = 0.0 - 42.0
  var x = abs(neg)
  return trunc(x)
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_42]
    x86.movsd xmm2, xmm0
    x86.subsd xmm2, xmm1
    x86.movsd xmm3, xmm2
    x86.andpd xmm3, [rip+__abs_mask]
    x86.cvttsd2si eax, xmm3
    x86.ret
  }
}
---

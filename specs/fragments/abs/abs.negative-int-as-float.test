// Test: abs.negative-int-as-float
function main() returns int
    var neg = 0.0 - 42.0
    var x = abs(neg)
    return trunc(x)
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, -4592264245034352640
    x86.movq xmm0, rax
    x86.mov rax, 9223372036854775807
    x86.movq xmm1, rax
    x86.movsd xmm2, xmm0
    x86.andpd xmm2, xmm1
    x86.cvttsd2si rax, xmm2
    x86.epilogue
    x86.ret
}

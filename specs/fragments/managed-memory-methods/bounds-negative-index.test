// Test: bounds-negative-index
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = IntArray{}
  arr.push(1)
  arr.push(2)
  arr.push(3)
  arr.push(4)
  var v = arr.managed.get(0 - 1)
  return v
end 'main'

    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 10
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 20
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 30
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 1
    x86.mov ecx, 99
    x86.mov edx, 255
    x86.and ecx, edx
    x86.mov edx, [rbp-16]
    x86.mov r8, rcx
    x86.mov rcx, rdx
    x86.mov rdx, rax
    x86.call ByteArray.set
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.get
    x86.xor ecx, ecx
    x86.mov ebx, 255
    x86.and ecx, ebx
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.jmp arrays.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }

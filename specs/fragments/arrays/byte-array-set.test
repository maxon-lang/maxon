// Test: byte-array-set
typealias ByteArray = Array with byte

function main() returns int
  var arr = ByteArray{}
  arr.push(10 as byte)
  arr.push(20 as byte)
  arr.push(30 as byte)

  arr.set(1, value: 99 as byte)

  var val = try arr.get(1) otherwise 0 as byte
  return val as int
end 'main'
---
ExitCode: 99
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax

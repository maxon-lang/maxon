// Test: byte-array-set
typealias ByteArray is Array with byte

function main() returns int
  var arr = ByteArray{}
  arr.push(10 as byte)
  arr.push(20 as byte)
  arr.push(30 as byte)

  arr.set(1, value: 99 as byte)

  var val = try arr.get(1) otherwise 0 as byte
  return val as int
end 'main'

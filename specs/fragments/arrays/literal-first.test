// Test: literal-first
function main() returns int
  return try [10, 20, 30].get(0) otherwise 0
end 'main'
---
ExitCode: 10
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=80
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 30
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.mov ebx, 3
    x86.xor esi, esi
    x86.mov edi, 8
    x86.xor r8, r8
    x86.lea r9, [rbp-24]
    x86.mov rax, r9
    x86.xor ecx, ecx
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], esi
    x86.mov [rbp-48], ebx
    x86.mov [rbp-56], eax
    x86.mov [rbp-64], r8
    x86.lea rax, [rbp-64]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call IntArray.get
    x86.xor ecx, ecx
    x86.mov [rbp-72], ecx
    x86.mov [rbp-80], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-72]
    x86.mov [rbp-80], eax
    x86.jmp arrays.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-80]
    x86.epilogue
    x86.ret
  }
}
---

// Test: array-literal-constant
let numbers = [1, 2, 3, 4, 5]

function main() returns int
  var sum = 0
  for n in numbers 'loop'
    sum = sum + n
  end 'loop'
  return sum
end 'main'
---
ExitCode: 15

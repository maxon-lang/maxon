// Test: append-empty-to-nonempty
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
  var a = [1, 2, 3]
  var b = IntArray{}
  a.append(b)
  return a.count()
end 'main'

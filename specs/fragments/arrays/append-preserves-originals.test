// Test: append-preserves-originals
function main() returns int
  var a = [1, 2]
  var b = [3, 4]
  a.append(b)
  // b should still have its original elements
  var b0 = try b.get(0) otherwise 0
  var b1 = try b.get(1) otherwise 0
  return b0 + b1
end 'main'
---

    x86.mov r11, 30
    x86.mov r9, qword ptr [r8]
    x86.mov r8, 16
    x86.lea r10, qword ptr [r9+r8]
    x86.mov qword ptr [r10], r11
    x86.mov qword ptr [rax], r12
    x86.lea rax, qword ptr [rbp-104]
    x86.lea r11, qword ptr [rax]
    x86.mov qword ptr [r11], r14
    x86.lea r11, qword ptr [rax+8]
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r11
    x86.mov rsi, rdx
    x86.cld
    x86.rep_movsb

    x86.push rcx
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Array$int.set
    x86.lea r13, qword ptr [rbp-160]
    x86.mov r10, r13
    x86.mov r11, r12
    x86.push rbx
    x86.pop r8
    x86.mov rdx, r11

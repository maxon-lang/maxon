    x86.xor eax, eax
    x86.mov ecx, 100
    x86.mov edx, [rbp-88]
    x86.mov [rbp-96], edx
    x86.mov edx, [rbp-80]
    x86.mov [rbp-104], edx
    x86.mov edx, [rbp-72]
    x86.mov [rbp-112], edx
    x86.mov edx, [rbp-64]
    x86.mov [rbp-120], edx
    x86.lea rdx, [rbp-120]
    x86.mov r8, rcx
    x86.mov rcx, rdx
    x86.mov rdx, rax
    x86.call Array.set
    x86.mov eax, [rbp-120]
    x86.mov [rbp-64], eax
    x86.mov eax, [rbp-112]

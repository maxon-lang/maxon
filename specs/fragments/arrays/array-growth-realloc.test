// Test: array-growth-realloc
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
    var arr = IntArray{}
    var i = 0
    while i < 100 'loop'
        arr.push(i)
        i = i + 1
    end 'loop'
    return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---

// Test: array-growth-realloc
typealias IntArray = Array with int

function main() returns Integer
    var arr = IntArray{}
    var i = 0
    while i < 100 'loop'
        arr.push(i)
        i = i + 1
    end 'loop'
    return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp arrays.main.loop_0.header
  loop_0.header:
    x86.mov eax, 100
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge arrays.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov edx, 1
    x86.mov ebx, [rbp-24]
    x86.add ebx, edx
    x86.mov [rbp-24], ebx
    x86.jmp arrays.main.loop_0.header
  loop_0.exit:
    x86.mov eax, 99
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.get
    x86.mov ecx, -1
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-40], eax
    x86.jmp arrays.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov [rbp-8], eax
    x86.mov [rbp-16], esi
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.mov [rbp-40], ecx
    x86.xor edi, edi
    x86.mov [rbp-48], edi
    x86.jmp arrays.main.loop_0.header
  loop_0.header:
    x86.mov eax, 100
    x86.mov ecx, [rbp-48]
    x86.cmp ecx, eax
    x86.jge arrays.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-56], ecx
    x86.mov edx, [rbp-24]
    x86.mov [rbp-64], edx
    x86.mov ebx, [rbp-32]
    x86.mov [rbp-72], ebx
    x86.mov esi, [rbp-40]
    x86.mov [rbp-80], esi
    x86.mov edi, [rbp-8]
    x86.mov [rbp-88], edi
    x86.lea r8, [rbp-88]
    x86.mov rcx, r8
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov r9, [rbp-56]
    x86.mov [rbp-16], r9
    x86.mov eax, [rbp-64]
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-72]
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-80]
    x86.mov [rbp-40], eax
    x86.mov eax, [rbp-88]
    x86.mov [rbp-8], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-48]
    x86.add ecx, eax
    x86.mov [rbp-48], ecx
    x86.jmp arrays.main.loop_0.header
  loop_0.exit:
    x86.mov eax, 99
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-96], ecx
    x86.mov edx, [rbp-24]
    x86.mov [rbp-104], edx
    x86.mov ebx, [rbp-32]
    x86.mov [rbp-112], ebx
    x86.mov esi, [rbp-40]
    x86.mov [rbp-120], esi
    x86.mov edi, [rbp-8]
    x86.mov [rbp-128], edi
    x86.lea r8, [rbp-128]
    x86.mov rcx, r8
    x86.mov rdx, rax
    x86.call IntArray.get
    x86.mov r9, -1
    x86.mov [rbp-136], r9
    x86.mov [rbp-144], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_4
  otherwise_default_error_3:

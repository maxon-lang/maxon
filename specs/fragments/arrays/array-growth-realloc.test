    x86.xor ebx, ebx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], eax
    x86.mov esi, [rbp-8]
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-16]
    x86.mov [rbp-48], edi
    x86.mov r8, [rbp-24]
    x86.mov [rbp-56], r8
    x86.mov r9, [rbp-32]
    x86.mov [rbp-64], r9
    x86.mov eax, [rbp-40]
    x86.mov [rbp-72], eax
    x86.mov eax, [rbp-48]
    x86.mov [rbp-80], eax
    x86.mov eax, [rbp-56]
    x86.mov [rbp-88], eax
    x86.xor eax, eax
    x86.mov [rbp-96], eax
    x86.jmp main.loop_0.header
  loop_0.header:
    x86.mov eax, 100
    x86.mov ecx, [rbp-96]
    x86.cmp ecx, eax
    x86.jge main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-96]
    x86.mov ecx, [rbp-88]
    x86.mov [rbp-104], ecx
    x86.mov edx, [rbp-80]
    x86.mov [rbp-112], edx
    x86.mov ebx, [rbp-72]
    x86.mov [rbp-120], ebx
    x86.mov esi, [rbp-64]
    x86.mov [rbp-128], esi
    x86.lea rdi, [rbp-128]
    x86.mov rcx, rdi
    x86.mov edx, eax
    x86.call Array.push
    x86.mov r8, [rbp-128]
    x86.mov [rbp-64], r8
    x86.mov r9, [rbp-120]
    x86.mov [rbp-72], r9
    x86.mov eax, [rbp-112]
    x86.mov [rbp-80], eax
    x86.mov eax, [rbp-104]
    x86.mov [rbp-88], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-96]
    x86.add ecx, eax
    x86.mov [rbp-96], ecx
    x86.jmp main.loop_0.header
  loop_0.exit:
    x86.mov eax, 99
    x86.mov ecx, [rbp-88]
    x86.mov [rbp-136], ecx
    x86.mov edx, [rbp-80]
    x86.mov [rbp-144], edx
    x86.mov ebx, [rbp-72]
    x86.mov [rbp-152], ebx
    x86.mov esi, [rbp-64]
    x86.mov [rbp-160], esi
    x86.lea rdi, [rbp-160]
    x86.mov rcx, rdi
    x86.mov edx, eax
    x86.call Array.get
    x86.mov [rbp-168], edx
    x86.mov r8, [rbp-160]
    x86.mov [rbp-64], r8

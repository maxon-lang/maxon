// Test: array-growth-realloc
typealias IntArray = Array with int

function main() returns int
    var arr = IntArray{}
    var i = 0
    while i < 100 'loop'
        arr.push(i)
        i = i + 1
    end 'loop'
    return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
module {
  func @arrays.main() -> i64 {

    x86.lea_symdata rax, [__tag_IntArray]
    x86.mov rcx, rax
    x86.mov rdx, rcx
    x86.mov rcx, 16
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+8], eax
    x86.mov ecx, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.mov r8, 1
    x86.call mm_move
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.xor eax, eax
    x86.mov [rbp-32], eax
    x86.jmp arrays.main.loop_0.header
  loop_0.header:
    x86.mov eax, 100
    x86.mov ecx, [rbp-32]
    x86.cmp ecx, eax
    x86.jge arrays.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, [rbp-32]
    x86.call IntArray.push
    x86.mov edx, 1
    x86.mov ebx, [rbp-32]
    x86.add ebx, edx
    x86.mov [rbp-32], ebx
    x86.jmp arrays.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, 99
    x86.call IntArray.get
    x86.mov ecx, -1
    x86.mov [rbp-40], ecx
    x86.mov [rbp-48], eax
    x86.xor eax, eax

// Test: array-growth-realloc
typealias IntArray is Array with int

function main() returns int
    var arr = IntArray{}
    var i = 0
    while i < 100 'loop'
        arr.push(i)
        i = i + 1
    end 'loop'
    return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=192
    x86.xor eax, eax
    x86.xor ecx, ecx

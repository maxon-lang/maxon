// Test: byte-array-count
typealias ByteArray = Array with byte

function main() returns Integer
  var arr = ByteArray{}
  arr.push(1 as Byte)
  arr.push(2 as Byte)
  arr.push(3 as Byte)
  arr.push(4 as Byte)
  arr.push(5 as Byte)

  return arr.count()
end 'main'
---
ExitCode: 5
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 1
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 2
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 3
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 4
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 5
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp ByteArray.count
  }
}

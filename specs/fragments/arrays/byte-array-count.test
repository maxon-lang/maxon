// Test: byte-array-count
typealias ByteArray is Array with byte

function main() returns int
  var arr = ByteArray{}
  arr.push(1 as byte)
  arr.push(2 as byte)
  arr.push(3 as byte)
  arr.push(4 as byte)
  arr.push(5 as byte)

  return arr.count()
end 'main'

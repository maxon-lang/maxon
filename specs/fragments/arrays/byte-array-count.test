    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-32]
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-40]
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-48]
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-56]
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 1
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 2
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 3
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call ByteArray.push
    x86.mov eax, 4

    x86.mov rdx, r8
    x86.call IntArray.get
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-48], ecx
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-56], ecx
    x86.mov ecx, [rbp-24]
    x86.mov [rbp-64], ecx
    x86.mov ecx, [rbp-32]
    x86.mov [rbp-72], ecx
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-80], ecx
    x86.xor ecx, ecx
    x86.mov [rbp-88], ecx
    x86.mov [rbp-96], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-88]
    x86.mov [rbp-96], eax
    x86.jmp arrays.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-96]
    x86.mov [rbp-104], eax
    x86.mov ecx, 4
    x86.mov edx, [rbp-48]
    x86.mov [rbp-112], edx
    x86.mov ebx, [rbp-56]
    x86.mov [rbp-120], ebx
    x86.mov esi, [rbp-64]
    x86.mov [rbp-128], esi
    x86.mov edi, [rbp-72]
    x86.mov [rbp-136], edi
    x86.mov r8, [rbp-80]
    x86.mov [rbp-144], r8
    x86.lea r9, [rbp-144]
    x86.mov rdx, rcx
    x86.mov rcx, r9
    x86.call IntArray.get
    x86.xor ecx, ecx

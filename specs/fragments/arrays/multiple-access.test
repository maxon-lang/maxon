// Test: multiple-access
function main() returns int
  var arr = [5, 10, 15, 20, 25]
  var a = try arr.get(2) otherwise 0
  var b = try arr.get(4) otherwise 0
  return a + b
end 'main'
---
ExitCode: 40
---

  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=160
    x86.mov eax, 5
    x86.xor ecx, ecx
    x86.mov edx, 8
    x86.xor ebx, ebx
    x86.lea_rdata rsi, [__const_array_arrays.main_arr]
    x86.mov rdi, rsi
    x86.mov r8, 2

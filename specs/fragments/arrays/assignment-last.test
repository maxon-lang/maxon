// Test: assignment-last
function main() returns int
  var arr = [1, 2, 3, 4, 5]
  arr.set(4, value: 99)
  return try arr.get(4) otherwise 0
end 'main'
---
ExitCode: 99
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=96
    x86.mov eax, 5
    x86.xor ecx, ecx
    x86.mov edx, 8
    x86.xor ebx, ebx
    x86.lea_rdata rsi, [__const_array_arrays.main_arr]
    x86.mov rdi, rsi
    x86.mov r8, 4
    x86.mov r9, 99
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], ebx
    x86.lea rax, [rbp-40]
    x86.mov rcx, rax
    x86.mov rdx, r8
    x86.mov r8, r9
    x86.call IntArray.set
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov ebx, [rbp-32]
    x86.mov esi, [rbp-40]
    x86.mov edi, 4
    x86.mov [rbp-48], eax
    x86.mov [rbp-56], ecx
    x86.mov [rbp-64], edx
    x86.mov [rbp-72], ebx
    x86.mov [rbp-80], esi
    x86.lea rax, [rbp-80]
    x86.mov rcx, rax
    x86.mov rdx, rdi
    x86.call IntArray.get
    x86.xor ecx, ecx
    x86.mov [rbp-88], ecx
    x86.mov [rbp-96], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-88]
    x86.mov [rbp-96], eax
    x86.jmp arrays.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-96]
    x86.epilogue
    x86.ret
  }
}
---

// Test: slice-to-end
function main() returns ExitCode
  var arr = [10, 20, 30, 40, 50]
  var sub = arr.slice(3, endIndex: 5)
  var a = try sub.get(0) otherwise 0
  var b = try sub.get(1) otherwise 0
  return a + b
end 'main'

// Test: array-literal-return-push-no-leak
function makeNumbers(a Integer, b Integer) returns IntArray
  var arr = [a, b]
  arr.push(a + b)
  return arr
end 'makeNumbers'

function main() returns Integer
  var nums = makeNumbers(10, b: 20)
  var c = try nums.get(2) otherwise 0
  return c
end 'main'
---

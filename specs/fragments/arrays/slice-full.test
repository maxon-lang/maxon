// Test: slice-full
function main() returns ExitCode
  var arr = [10, 20, 30]
  var sub = arr.slice(0, endIndex: 3)
  var a = try sub.get(0) otherwise 0
  var b = try sub.get(1) otherwise 0
  var c = try sub.get(2) otherwise 0
  return a + b + c
end 'main'

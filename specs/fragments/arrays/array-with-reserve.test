// Test: array-with-reserve
typealias IntArray = Array with int

function main() returns int
  var arr = IntArray{}
  arr.reserve(5)
  arr.push(42)
  return try arr.get(0) otherwise 0
end 'main'
---
ExitCode: 42
---
module {
  func @arrays.main() -> i64 {
  entry:
    x86.prologue stack_size=144
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 5
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.lea r8, [rbp-40]
    x86.mov rcx, r8
    x86.mov rdx, rdi
    x86.call IntArray.reserve
    x86.mov r9, [rbp-8]
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-32]
    x86.mov ebx, [rbp-40]
    x86.mov esi, 42
    x86.mov [rbp-48], r9
    x86.mov [rbp-56], eax
    x86.mov [rbp-64], ecx
    x86.mov [rbp-72], edx
    x86.mov [rbp-80], ebx
    x86.lea rax, [rbp-80]
    x86.mov rcx, rax
    x86.mov rdx, rsi
    x86.call IntArray.push
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-56]
    x86.mov edx, [rbp-64]
    x86.mov ebx, [rbp-72]
    x86.mov esi, [rbp-80]
    x86.xor edi, edi
    x86.mov [rbp-88], eax
    x86.mov [rbp-96], ecx
    x86.mov [rbp-104], edx
    x86.mov [rbp-112], ebx
    x86.mov [rbp-120], esi
    x86.lea rax, [rbp-120]
    x86.mov rcx, rax
    x86.mov rdx, rdi
    x86.call IntArray.get
    x86.xor ecx, ecx
    x86.mov [rbp-128], ecx
    x86.mov [rbp-136], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je arrays.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-128]
    x86.mov [rbp-136], eax
    x86.jmp arrays.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-136]
    x86.epilogue
    x86.ret
  }
}
---

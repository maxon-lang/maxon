// Test: array-literal-with-dependency
let FIRST = 10
let SECOND = 20
let values = [FIRST, SECOND, 30]

function main() returns int
  var v0 = try values.get(0) otherwise 0
  var v1 = try values.get(1) otherwise 0
  var v2 = try values.get(2) otherwise 0
  return v0 + v1 + v2
end 'main'

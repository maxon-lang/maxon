// Test: slice-basic
function main() returns int
  var arr = [10, 20, 30, 40, 50]
  var sub = arr.slice(1, endIndex: 4)
  var a = try sub.get(0) otherwise 0
  var b = try sub.get(1) otherwise 0
  var c = try sub.get(2) otherwise 0
  return a + b + c
end 'main'

// Test: math-intrinsic-int-promotion
function main() returns int
  var result = sqrt(16)
  return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.mov eax, 16
    x86.cvtsi2sd xmm0, eax
    x86.sqrtsd xmm1, xmm0
    x86.cvttsd2si eax, xmm1
    x86.ret
  }
}
---

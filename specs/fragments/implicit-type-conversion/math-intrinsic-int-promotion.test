// Test: math-intrinsic-int-promotion
function main() returns int
  var result = sqrt(16)
  return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 16
    x86.cvtsi2sd xmm0, eax
    x86.sqrtsd xmm1, xmm0
    x86.movsd [rbp-8], xmm1
    x86.cvttsd2si ecx, xmm1
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

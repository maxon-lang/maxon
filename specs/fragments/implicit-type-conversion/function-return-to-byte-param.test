// Test: function-return-to-byte-param
function getInt() returns Integer
  return 300
end 'getInt'

function takeByte(x Byte) returns Integer
  return x as Integer
end 'takeByte'

function main() returns Integer
  return takeByte(getInt())
end 'main'
---
ExitCode: 44
---
module {
  func @implicit-type-conversion.getInt() -> i64 {
  entry:
    x86.mov eax, 300
    x86.ret
  }
  func @implicit-type-conversion.takeByte(x: i8) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.call implicit-type-conversion.getInt
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.jmp implicit-type-conversion.takeByte
  }
}
---

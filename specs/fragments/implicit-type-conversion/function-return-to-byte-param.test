// Test: function-return-to-byte-param
function getInt() returns int
  return 300
end 'getInt'

function takeByte(x byte) returns int
  return x as int
end 'takeByte'

function main() returns int
  return takeByte(getInt())
end 'main'
---
ExitCode: 44
---
module {
  func @implicit-type-conversion.getInt() -> i64 {
  entry:
    x86.mov eax, 300
    x86.ret
  }
  func @implicit-type-conversion.takeByte(x: i8) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.call implicit-type-conversion.getInt
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.call implicit-type-conversion.takeByte
    x86.ret
  }
}
---

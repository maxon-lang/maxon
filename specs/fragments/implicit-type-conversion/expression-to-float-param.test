    x86.cvtsi2sd xmm0, eax
    x86.call implicit-type-conversion.takeFloat
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je implicit-type-conversion.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_12]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:

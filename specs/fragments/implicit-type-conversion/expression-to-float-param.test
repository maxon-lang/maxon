// Test: expression-to-float-param
function takeFloat(x float) returns int
  return trunc(x)
end 'takeFloat'

function main() returns int
  var a = 20
  var b = 22
  return takeFloat(a + b)
end 'main'
---
ExitCode: 42
---
module {
  func @takeFloat(x: f64) -> i64 {
  entry:
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.add eax, ecx
    x86.cvtsi2sd xmm0, eax
    x86.jmp takeFloat
  }
}
---

// Test: byte-to-int-param
function takeInt(x int) returns int
  return x
end 'takeInt'

function main() returns int
  var b = 42 as byte
  return takeInt(b)
end 'main'
---
ExitCode: 42
---
module {
  func @takeInt(x: i64) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.jmp takeInt
  }
}
---

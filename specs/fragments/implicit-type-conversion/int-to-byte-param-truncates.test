    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @implicit-type-conversion.main() -> u32 {

// Test: int-to-byte-param-truncates
function takeByte(x byte) returns int
  return x as int
end 'takeByte'

function main() returns int
  return takeByte(300)
end 'main'
---
ExitCode: 44
---
module {
  func @implicit-type-conversion.takeByte(x: i8) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.mov eax, 300
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.jmp implicit-type-conversion.takeByte
  }
}

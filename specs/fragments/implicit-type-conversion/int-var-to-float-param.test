// Test: int-var-to-float-param

typealias Integer = i64
typealias Float = f64

function takeFloat(x Float) returns Integer
  return trunc(x)
end 'takeFloat'

function main() returns ExitCode
  var i = 42
  return takeFloat(i)
end 'main'
---
ExitCode: 42
---
module {

// Test: int-var-to-float-param
function takeFloat(x float) returns int
  return trunc(x)
end 'takeFloat'

function main() returns int
  var i = 42
  return takeFloat(i)
end 'main'
---
ExitCode: 42
---
module {
  func @takeFloat(x: f64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.cvtsi2sd xmm0, eax
    x86.call takeFloat
    x86.epilogue
    x86.ret
  }
}
---

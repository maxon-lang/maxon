// Test: int-var-to-byte-param
function takeByte(x byte) returns int
  return x as int
end 'takeByte'

function main() returns int
  var i = 300
  return takeByte(i)
end 'main'
---
ExitCode: 44
---
module {
  func @takeByte(x: i8) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 300
    x86.mov [rbp-8], eax
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.call takeByte
    x86.epilogue
    x86.ret
  }
}
---

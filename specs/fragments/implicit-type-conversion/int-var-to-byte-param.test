// Test: int-var-to-byte-param

typealias Integer = i64
typealias Byte = u8

function takeByte(x Byte) returns Integer
  return x as Integer
end 'takeByte'

function main() returns ExitCode
  var i = 300
  return takeByte(i)
end 'main'
---
ExitCode: 44
---
module {
  func @implicit-type-conversion.takeByte(x: i8) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @implicit-type-conversion.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 300
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov rcx, rax
    x86.call implicit-type-conversion.takeByte
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je implicit-type-conversion.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

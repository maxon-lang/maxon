// Test: int-literal-to-float-param
function takeFloat(x Float) returns Integer
  return trunc(x)
end 'takeFloat'

function main() returns Integer
  return takeFloat(42)
end 'main'
---
ExitCode: 42
---
module {
  func @implicit-type-conversion.takeFloat(x: f64) -> i64 {
  entry:
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.cvtsi2sd xmm0, eax
    x86.jmp implicit-type-conversion.takeFloat
  }
}

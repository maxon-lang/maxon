// Test: float-to-int-param-truncates
function takeInt(x Integer) returns Integer
  return x
end 'takeInt'

function main() returns Integer
  var f = 3.7
  return takeInt(f)
end 'main'
---
ExitCode: 3
---
module {
  func @implicit-type-conversion.takeInt(x: i64) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.7]
    x86.cvttsd2si eax, xmm0
    x86.mov rcx, rax
    x86.jmp implicit-type-conversion.takeInt
  }
}

// Test: float-to-int-param-truncates
function takeInt(x int) returns int
  return x
end 'takeInt'

function main() returns int
  var f = 3.7
  return takeInt(f)
end 'main'
---
ExitCode: 3
---
module {
  func @implicit-type-conversion.takeInt(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @implicit-type-conversion.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.7]
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.mov rcx, rax
    x86.call implicit-type-conversion.takeInt
    x86.epilogue
    x86.ret
  }
}

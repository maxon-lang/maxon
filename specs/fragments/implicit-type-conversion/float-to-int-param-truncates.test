// Test: float-to-int-param-truncates
function takeInt(x int) returns int
  return x
end 'takeInt'

function main() returns int
  var f = 3.7
  return takeInt(f)
end 'main'
---
ExitCode: 3
---
module {
  func @takeInt(x: i64) -> i64 {
  entry:
    x86.mov eax, ecx
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.7]
    x86.cvttsd2si eax, xmm0
    x86.mov rcx, rax
    x86.jmp takeInt
  }
}

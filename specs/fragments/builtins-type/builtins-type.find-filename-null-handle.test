// Test: builtins-type.find-filename-null-handle
function main() returns ExitCode
  let managed = __Builtins.findFilename(0)
  let s = String{managed: managed, _iterPos: 0}
  if s == "" 'check'
    return 0
  end 'check'
  return 1
end 'main'

// Test: builtins-type.float-to-bits
function main() returns ExitCode
  let bits = __Builtins.floatToBits(1.0)
  // IEEE 754: 1.0 = 0x3FF0000000000000 = 4607182418800017408
  if bits == 4607182418800017408 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @builtins-type.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_1]
    x86.movq rax, xmm0
    x86.mov rcx, 4607182418800017408
    x86.cmp rax, rcx
    x86.jne builtins-type.main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

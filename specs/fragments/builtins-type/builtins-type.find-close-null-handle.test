// Test: builtins-type.find-close-null-handle
function main() returns ExitCode
  __Builtins.findClose(0)
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @builtins-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call maxon_find_close
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

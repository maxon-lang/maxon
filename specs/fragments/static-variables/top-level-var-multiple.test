// Test: top-level-var-multiple
var a = 1
var b = 2
var c = 3

function main() returns int
    a = a * 10
    b = b * 10
    c = c * 10
    return a + b + c
end 'main'
---
ExitCode: 60
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.lea_global rax, @global.a
    x86.mov rcx, qword ptr [rax]
    x86.mov rax, 10
    x86.imul rdx, rcx, rax
    x86.lea_global rcx, @global.a
    x86.mov qword ptr [rcx], rdx
    x86.lea_global rdx, @global.b
    x86.mov rcx, qword ptr [rdx]
    x86.imul rdx, rcx, rax
    x86.lea_global rcx, @global.b
    x86.mov qword ptr [rcx], rdx
    x86.lea_global rdx, @global.c
    x86.mov rcx, qword ptr [rdx]
    x86.imul rdx, rcx, rax
    x86.lea_global rcx, @global.c
    x86.mov qword ptr [rcx], rdx
    x86.lea_global rdx, @global.a
    x86.mov rcx, qword ptr [rdx]
    x86.lea_global rdx, @global.b
    x86.mov rax, qword ptr [rdx]
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.lea_global rax, @global.c
    x86.mov rcx, qword ptr [rax]
    x86.mov rax, rdx
    x86.add rax, rcx
    x86.epilogue
    x86.ret
}
---

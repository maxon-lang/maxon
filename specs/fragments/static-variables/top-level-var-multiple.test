// Test: top-level-var-multiple
var a = 1
var b = 2
var c = 3

function main() returns ExitCode
  a = a * 10
  b = b * 10
  c = c * 10
  return a + b + c
end 'main'
---
ExitCode: 60
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, qword [rip+a]
    x86.mov rcx, 10
    x86.imul rax, rcx
    x86.mov qword [rip+a], rax
    x86.mov rdx, qword [rip+b]
    x86.mov rbx, 10
    x86.imul rdx, rbx
    x86.mov qword [rip+b], rdx
    x86.mov rsi, qword [rip+c]
    x86.mov rdi, 10
    x86.imul rsi, rdi
    x86.mov qword [rip+c], rsi
    x86.mov r8, qword [rip+a]
    x86.mov r9, qword [rip+b]
    x86.add r8, r9
    x86.mov rax, qword [rip+c]
    x86.add r8, rax
    x86.mov [rbp-8], r8
    x86.xor rax, rax
    x86.cmp r8, rax
    x86.setl rax
    x86.movzx rax, raxb
    x86.mov rcx, 4294967295
    x86.cmp r8, rcx
    x86.setg rcx
    x86.movzx rcx, rcxb
    x86.or rax, rcx
    x86.test rax, rax
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov rax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

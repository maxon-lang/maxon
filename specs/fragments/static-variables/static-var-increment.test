// Test: static-var-increment
type Counter
    static var count = 0

    static function increment()
        Counter.count = Counter.count + 1
    end 'increment'
end 'Counter'

function main() returns int
    Counter.increment()
    Counter.increment()
    Counter.increment()
    return Counter.count
end 'main'
---
ExitCode: 3
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.lea_global rax, @global.Counter.count
    x86.mov rcx, qword ptr [rax]
    x86.mov rax, 1
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.lea_global rcx, @global.Counter.count
    x86.mov qword ptr [rcx], rdx
    x86.lea_global rdx, @global.Counter.count
    x86.mov rcx, qword ptr [rdx]
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.lea_global rcx, @global.Counter.count
    x86.mov qword ptr [rcx], rdx
    x86.lea_global rdx, @global.Counter.count
    x86.mov rcx, qword ptr [rdx]
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.lea_global rax, @global.Counter.count
    x86.mov qword ptr [rax], rdx
    x86.lea_global rdx, @global.Counter.count
    x86.mov rax, qword ptr [rdx]
    x86.epilogue
    x86.ret
}
---

// Test: static-var-multiple-types
type TypeA
    static var value = 10
end 'TypeA'

type TypeB
    static var value = 20
end 'TypeB'

function main() returns int
    TypeA.value = TypeA.value + 2
    TypeB.value = TypeB.value + 10
    return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.lea_global rax, @global.TypeA.value
    x86.mov rcx, qword ptr [rax]
    x86.mov rax, 2
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.lea_global rax, @global.TypeA.value
    x86.mov qword ptr [rax], rdx
    x86.lea_global rdx, @global.TypeB.value
    x86.mov rax, qword ptr [rdx]
    x86.mov rdx, 10
    x86.mov rcx, rax
    x86.add rcx, rdx
    x86.lea_global rdx, @global.TypeB.value
    x86.mov qword ptr [rdx], rcx
    x86.lea_global rdx, @global.TypeA.value
    x86.mov rcx, qword ptr [rdx]
    x86.lea_global rdx, @global.TypeB.value
    x86.mov rax, qword ptr [rdx]
    x86.mov rdx, rcx
    x86.add rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

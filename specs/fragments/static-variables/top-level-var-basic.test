// Test: top-level-var-basic
var counter = 0

function main() returns Integer
  counter = 42
  return counter
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.mov [rip+counter], eax
    x86.mov eax, [rip+counter]
    x86.ret
  }
}
---

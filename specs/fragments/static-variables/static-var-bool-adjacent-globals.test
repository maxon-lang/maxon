// Test: static-var-bool-adjacent-globals
var flag = false
var counter = 42

function main() returns ExitCode
  if flag 'checkFalse'
    print("flag should be false\n")
    return 1
  end 'checkFalse'
  if counter == 42 'checkCounter'
    return 0
  end 'checkCounter'
  print("counter wrong\n")
  return 1
end 'main'
---
ExitCode: 0
---

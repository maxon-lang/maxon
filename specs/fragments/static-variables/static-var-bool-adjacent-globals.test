// Test: static-var-bool-adjacent-globals
var flag = false
var counter = 42

function main() returns ExitCode
  if flag 'checkFalse'
    print("flag should be false\n")
    return 1
  end 'checkFalse'
  if counter == 42 'checkCounter'
    return 0
  end 'checkCounter'
  print("counter wrong\n")
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.movzx eax, byte [rip+flag]
    x86.test eax, eax
    x86.je static-variables.main.checkFalse_0.after
  checkFalse_0:
    x86.lea_rdata rax, [__str_1]
    x86.mov rcx, rax
    x86.mov edx, 21
    x86.mov ebx, 32
    x86.mov [rbp-40], ecx
    x86.mov rcx, rbx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-40]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 21
    x86.mov [r8+8], r9
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call stdlib.Print.print
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call maxon_release_with_managed
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  checkFalse_0.after:
    x86.mov eax, qword [rip+counter]
    x86.mov ecx, 42
    x86.cmp eax, ecx
    x86.jne static-variables.main.checkCounter_1.after
  checkCounter_1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  checkCounter_1.after:
    x86.lea_rdata rax, [__str_7]
    x86.mov rcx, rax
    x86.mov edx, 14
    x86.mov ebx, 32
    x86.mov [rbp-40], ecx
    x86.mov rcx, rbx
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov esi, [rbp-24]
    x86.mov edi, [rbp-40]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov r9, 14
    x86.mov [r8+8], r9
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-32]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-32]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-32]
    x86.mov rcx, rax
    x86.call stdlib.Print.print
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call maxon_release_with_managed
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

    x86.call stdlib.Print.print
    x86.mov eax, [rbp-24]
    x86.test eax, eax
    x86.jz __destruct_nullguard_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_1
    x86.mov rcx, [rbp-24]

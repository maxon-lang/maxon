// Test: top-level-var-byte-ranged-type
typealias SmallInt = int(0 to 255)

var counter = SmallInt{42}

function main() returns ExitCode
    return counter
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movzx eax, byte [rip+counter]
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_6]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

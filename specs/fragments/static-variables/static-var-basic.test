// Test: static-var-basic
type Counter
    static var count = 0
end 'Counter'

function main() returns int
    Counter.count = 42
    return Counter.count
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.lea_global rcx, @global.Counter.count
    x86.mov qword ptr [rcx], rax
    x86.lea_global rcx, @global.Counter.count
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

// Test: top-level-var-increment

typealias Integer = int(i64.min to i64.max)

var total = 10

function add(n Integer)
  total = total + n
end 'add'

function main() returns ExitCode
  add(5)
  add(27)
  return total
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.add(n: i64) {
  entry:
    x86.mov eax, qword [rip+total]
    x86.add eax, ecx
    x86.mov qword [rip+total], eax
    x86.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call static-variables.add
    x86.mov rcx, 27
    x86.call static-variables.add
    x86.mov eax, qword [rip+total]
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

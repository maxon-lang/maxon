// Test: top-level-var-increment
var total = 10

function add(n int)
  total = total + n
end 'add'

function main() returns int
  add(5)
  add(27)
  return total
end 'main'
---
ExitCode: 42
---
module {
  func @add(n: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rip+total]
    x86.add eax, ecx
    x86.mov [rip+total], eax
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, eax
    x86.call add
    x86.mov ecx, 27
    x86.call add
    x86.mov edx, [rip+total]
    x86.mov eax, edx
    x86.ret
  }
}
---

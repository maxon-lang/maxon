// Test: top-level-var-increment
var total = 10

function add(n int)
    total = total + n
end 'add'

function main() returns int
    add(5)
    add(27)
    return total
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.lea_global rcx, @global.total
    x86.mov rdx, qword ptr [rcx]
    x86.mov rcx, rdx
    x86.add rcx, rax
    x86.lea_global rax, @global.total
    x86.mov qword ptr [rax], rcx
    x86.mov rcx, 27
    x86.lea_global rax, @global.total
    x86.mov rdx, qword ptr [rax]
    x86.mov rax, rdx
    x86.add rax, rcx
    x86.lea_global rcx, @global.total
    x86.mov qword ptr [rcx], rax
    x86.lea_global rcx, @global.total
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

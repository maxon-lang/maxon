// Test: top-level-var-increment
var total = 10

function add(n Integer)
  total = total + n
end 'add'

function main() returns Integer
  add(5)
  add(27)
  return total
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.add(n: i64) {
  entry:
    x86.mov eax, [rip+total]
    x86.add eax, ecx
    x86.mov [rip+total], eax
    x86.ret
  }
  func @static-variables.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.call static-variables.add
    x86.mov ecx, 27
    x86.call static-variables.add
    x86.mov eax, [rip+total]
    x86.ret
  }
}
---

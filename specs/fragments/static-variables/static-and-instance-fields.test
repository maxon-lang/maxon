// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
  static var created = 0
  export var id Integer

  static function make(n Integer) returns Thing
    Thing.created = Thing.created + 1
    return Thing{id: n}
  end 'make'
end 'Thing'

function main() returns ExitCode
  var a = Thing.make(10)
  var b = Thing.make(20)
  return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
module {
  func @Thing.make(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, qword [rip+Thing.created]
    x86.mov edx, 1
    x86.add eax, edx
    x86.mov qword [rip+Thing.created], eax
    x86.mov [rbp-16], ecx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 10
    x86.call Thing.make
    x86.mov [rbp-8], eax
    x86.mov rcx, 20
    x86.call Thing.make
    x86.mov [rbp-16], eax
    x86.mov eax, qword [rip+Thing.created]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+0]
    x86.add eax, edx
    x86.mov ebx, [rbp-16]
    x86.mov esi, [ebx+0]
    x86.add eax, esi
    x86.mov [rbp-24], eax
    x86.xor edi, edi
    x86.cmp eax, edi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_38
    x86.call mm_decref
    x86.label __nonnull_skip_38
    x86.mov eax, [rbp-16]
    x86.test eax, eax
    x86.jz __nonnull_skip_39
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_39
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

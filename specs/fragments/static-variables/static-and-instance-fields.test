// Test: static-and-instance-fields
type Thing
  static var created = 0
  export var id int

  static function make(n int) returns Thing
    Thing.created = Thing.created + 1
    return {id: n}
  end 'make'
end 'Thing'

function main() returns int
  var a = Thing.make(10)
  var b = Thing.make(20)
  return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
module {
  func @Thing.make(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, [rip+Thing.created]
    x86.mov edx, 1
    x86.add eax, edx
    x86.mov [rip+Thing.created], eax
    x86.mov eax, 8
    x86.mov [rbp-16], ecx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @static-variables.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov rcx, rax
    x86.call Thing.make
    x86.mov [rbp-8], eax
    x86.mov ecx, 20
    x86.call Thing.make
    x86.mov [rbp-16], eax
    x86.mov edx, [rip+Thing.created]
    x86.mov ebx, [rbp-8]
    x86.mov esi, [ebx+0]
    x86.add edx, esi
    x86.mov edi, [rbp-16]
    x86.mov r8, [edi+0]
    x86.lea eax, [edx + r8]
    x86.epilogue
    x86.ret
  }
}
---

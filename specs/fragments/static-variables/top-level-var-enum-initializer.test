  check_0.cmp2:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne static-variables.main.check_0.merge
  check_0.case2:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp static-variables.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-16]
    x86.test eax, eax
    x86.je static-variables.main.check_1.merge
  check_1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 2
    x86.mov qword [rip+current], ecx
    x86.mov edx, qword [rip+current]
    x86.xor ebx, ebx
    x86.mov [rbp-40], ebx
    x86.mov [rbp-48], edx
    x86.jmp static-variables.main.check2_2.cmp0
  check2_2.cmp0:
    x86.mov eax, [rbp-48]

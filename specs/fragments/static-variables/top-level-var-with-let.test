// Test: top-level-var-with-let
let BASE = 40
var offset = 0

function main() returns ExitCode
  offset = 2
  return BASE + offset
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rip+offset], eax
    x86.mov ecx, 40
    x86.mov edx, [rip+offset]
    x86.add ecx, edx
    x86.mov [rbp-8], ecx
    x86.xor ebx, ebx
    x86.cmp ecx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rcx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

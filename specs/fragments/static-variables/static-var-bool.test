// Test: static-var-bool
var initialized = false

function init()
  initialized = true
end 'init'

function main() returns ExitCode
  if initialized 'check1'
    return 1
  end 'check1'
  init()
  if initialized 'check2'
    return 42
  end 'check2'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.init() {
  entry:
    x86.mov eax, 1
    x86.mov [rip+initialized], eax
    x86.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x86.mov eax, [rip+initialized]
    x86.test eax, eax
    x86.je static-variables.main.check1_0.after
  check1_0:
    x86.mov eax, 1
    x86.ret
  check1_0.after:
    x86.call static-variables.init
    x86.mov eax, [rip+initialized]
    x86.test eax, eax
    x86.je static-variables.main.check2_1.after
  check2_1:
    x86.mov eax, 42
    x86.ret
  check2_1.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

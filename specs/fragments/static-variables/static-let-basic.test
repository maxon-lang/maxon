// Test: static-let-basic
type Config
    static let MAX_SIZE = 42
end 'Config'

function main() returns int
    return Config.MAX_SIZE
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.lea_global rax, @global.Config.MAX_SIZE
    x86.mov rcx, qword ptr [rax]
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

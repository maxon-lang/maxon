// Test: top-level-var-const-expr
let BASE = 20
var offset = BASE + 1

function main() returns ExitCode
  offset = offset * 2
  return offset
end 'main'
---
ExitCode: 42
---
module {
  func @static-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, qword [rip+offset]
    x86.mov ecx, 2
    x86.imul eax, ecx
    x86.mov qword [rip+offset], eax
    x86.mov edx, qword [rip+offset]
    x86.mov [rbp-8], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je static-variables.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

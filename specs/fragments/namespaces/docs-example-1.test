// Test: docs-example-1
export function add(a Integer, b Integer) returns Integer
  return a + b
end 'add'

export function multiply(x Integer, y Integer) returns Integer
  return x * y
end 'multiply'

function main() returns Integer
  return add(3, b: 4)  // Called from within same file
end 'main'

---
ExitCode: 7
---
module {
  func @namespaces.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @namespaces.main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp namespaces.add
  }
}

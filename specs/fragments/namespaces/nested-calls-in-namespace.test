// Test: nested-calls-in-namespace
function add(a int, b int) returns int
  return a + b
end 'add'

function sum_three(a int, b int, c int) returns int
  return add(add(a, b: b), b: c)
end 'sum_three'

function main() returns int
  return sum_three(1, b: 2, c: 3)
end 'main'
---
ExitCode: 6
---
module {
  func @add(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @sum_three(a: i64, b: i64, c: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], r8
    x86.call add
    x86.mov ecx, eax
    x86.mov edx, [rbp-24]
    x86.call add
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 3
    x86.mov r8, edx
    x86.mov edx, ecx
    x86.mov ecx, eax
    x86.call sum_three
    x86.ret
  }
}
---

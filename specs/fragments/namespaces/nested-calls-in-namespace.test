// Test: nested-calls-in-namespace
function add(a int, b int) returns int
  return a + b
end 'add'

function sum_three(a int, b int, c int) returns int
  return add(add(a, b: b), b: c)
end 'sum_three'

function main() returns int
  return sum_three(1, b: 2, c: 3)
end 'main'
---
ExitCode: 6
---
module {
  func @namespaces.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @namespaces.sum_three(a: i64, b: i64, c: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], r8
    x86.call namespaces.add
    x86.mov rdx, [rbp-8]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp namespaces.add
  }
  func @namespaces.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 3
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp namespaces.sum_three
  }
}
---

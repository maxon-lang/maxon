// Test: nested-calls-in-namespace

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
  return a + b
end 'add'

function sum_three(a Integer, b Integer, c Integer) returns Integer
  return add(add(a, b: b), b: c)
end 'sum_three'

function main() returns ExitCode
  return sum_three(1, b: 2, c: 3)
end 'main'
---
ExitCode: 6
---
module {
  func @namespaces.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @namespaces.sum_three(a: i64, b: i64, c: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], r8
    x86.call namespaces.add
    x86.mov rdx, [rbp-8]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp namespaces.add
  }
  func @namespaces.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 1
    x86.mov rdx, 2
    x86.mov r8, 3
    x86.call namespaces.sum_three
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je namespaces.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

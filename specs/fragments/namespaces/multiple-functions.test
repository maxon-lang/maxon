// Test: multiple-functions
export function double(x Integer) returns Integer
  return x * 2
end 'double'

export function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns Integer
  return double(5) + triple(4)
end 'main'
---
ExitCode: 22
---
module {
  func @namespaces.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @namespaces.triple(x: i64) -> i64 {
  entry:
    x86.mov eax, 3
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @namespaces.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.call namespaces.double
    x86.mov ecx, 4
    x86.mov [rbp-8], eax
    x86.call namespaces.triple
    x86.mov edx, [rbp-8]
    x86.lea eax, [edx + eax]
    x86.epilogue
    x86.ret
  }
}
---

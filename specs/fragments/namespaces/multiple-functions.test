// Test: multiple-functions

typealias Integer = int(i64.min to i64.max)

export function double(x Integer) returns Integer
  return x * 2
end 'double'

export function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  return double(5) + triple(4)
end 'main'
---
ExitCode: 22
---
module {
  func @namespaces.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @namespaces.triple(x: i64) -> i64 {
  entry:
    x86.mov eax, 3
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @namespaces.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.call namespaces.double
    x86.mov ecx, 4
    x86.mov [rbp-16], eax
    x86.call namespaces.triple
    x86.mov edx, [rbp-16]
    x86.add edx, eax
    x86.mov [rbp-8], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je namespaces.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: int-rawvalue-in-function

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns Integer
  return s.rawValue
end 'getCode'

function main() returns ExitCode
  var status = HttpStatus.notFound
  var code = getCode(status)
  if code == 404 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getCode(s: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 404
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov rcx, rdx
    x86.call constants.getCode
    x86.mov ebx, 404
    x86.cmp eax, ebx
    x86.jne constants.main.check_0.after
  check_0:
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: explicit-int-values
enum HttpStatus
  ok = 200
  notFound = 404
  serverError = 500
end 'HttpStatus'

function main() returns ExitCode
  var s = HttpStatus.notFound
  if s == HttpStatus.notFound 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 404
    x86.mov [rbp-8], rax
    x86.mov rcx, 404
    x86.mov rdx, [rbp-8]
    x86.cmp rdx, rcx
    x86.jne constants.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  }
}
---

// Test: arithmetic-with-int
enum Step
  first
  second
  third
end 'Step'

function main() returns ExitCode
  let stride = 10
  let offset = Step.second * stride
  return offset
end 'main'
---
ExitCode: 10
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 1
    x86.imul ecx, eax
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je constants.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

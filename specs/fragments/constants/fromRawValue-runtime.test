// Test: fromRawValue-runtime

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode() returns Integer
  return 404
end 'getCode'

function main() returns ExitCode
  var code = getCode()
  var status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
  if status == HttpStatus.notFound 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getCode() -> i64 {
  entry:
    x86.mov eax, 404
    x86.ret
  }
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call constants.getCode
    x86.mov ecx, 1
    x86.xor edx, edx
    x86.mov ebx, 200
    x86.cmp eax, ebx
    x86.sete esi
    x86.movzx esi, esib
    x86.xor edi, edi
    x86.test esi, esi
    x86.mov r8, ecx
    x86.cmovne r8, edi
    x86.mov r9, 200
    x86.test esi, esi
    x86.mov ecx, edx
    x86.cmovne ecx, r9
    x86.mov edx, 404
    x86.cmp eax, edx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.xor edx, edx
    x86.test eax, eax
    x86.mov ebx, r8
    x86.cmovne ebx, edx
    x86.mov edx, 404
    x86.test eax, eax
    x86.mov esi, ecx
    x86.cmovne esi, edx
    x86.mov eax, 200
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], esi
    x86.xor eax, eax
    x86.cmp ebx, eax
    x86.je constants.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp constants.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.mov ecx, 404
    x86.mov edx, [rbp-32]
    x86.cmp edx, ecx
    x86.jne constants.main.check_4.after
  check_4:
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

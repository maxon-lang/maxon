// Test: name-from-function
enum Direction
  north
  south
  east
  west
end 'Direction'

function getName(d Direction) returns String
  return d.name
end 'getName'

function main() returns ExitCode
  var d = Direction.west
  var n = getName(d)
  if n == "west" 'check'
    return 1
  end 'check'
  return 0
end 'main'

// Test: float-arithmetic
enum Weight
  light = 0.5
  heavy = 2.0
end 'Weight'

function main() returns ExitCode
  let scale = 4.0
  let result = Weight.light * scale
  if result == 2.0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_4]
    x86.movsd xmm1, [rip+__float_0.5]
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm0
    x86.movsd xmm3, [rip+__float_2]
    x86.ucomisd xmm2, xmm3
    x86.jne constants.main.check_0.after
    x86.jp constants.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

// Test: fromRawValue-int-backed
enum HttpStatus
  ok = 200
  notFound = 404
  serverError = 500
end 'HttpStatus'

function main() returns ExitCode
  var status = try HttpStatus.fromRawValue(404) otherwise HttpStatus.ok
  if status == HttpStatus.notFound 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 404
    x86.mov edx, 1
    x86.xor ebx, ebx
    x86.mov esi, 200
    x86.cmp ecx, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.xor r8, r8
    x86.test edi, edi
    x86.mov r9, edx
    x86.cmovne r9, r8
    x86.mov eax, 200
    x86.test edi, edi
    x86.mov edx, ebx
    x86.cmovne edx, eax
    x86.mov eax, 404
    x86.cmp ecx, eax
    x86.sete eax
    x86.movzx eax, eaxb
    x86.xor ebx, ebx
    x86.test eax, eax
    x86.mov esi, r9
    x86.cmovne esi, ebx
    x86.mov ebx, 404
    x86.test eax, eax
    x86.mov edi, edx
    x86.cmovne edi, ebx
    x86.mov eax, 500
    x86.cmp ecx, eax
    x86.sete eax
    x86.movzx eax, eaxb
    x86.xor ecx, ecx
    x86.test eax, eax
    x86.mov edx, esi
    x86.cmovne edx, ecx
    x86.mov ecx, 500
    x86.test eax, eax
    x86.mov ebx, edi
    x86.cmovne ebx, ecx
    x86.mov eax, 200
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ebx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je constants.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp constants.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.mov ecx, 404
    x86.mov edx, [rbp-32]
    x86.cmp edx, ecx
    x86.jne constants.main.check_4.after
  check_4:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

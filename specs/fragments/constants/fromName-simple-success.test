// Test: fromName-simple-success
enum Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = try Direction.fromName("south") otherwise Direction.north
  if dir == Direction.south 'check'
    return 1
  end 'check'
  return 0
end 'main'

// Test: not-equal
enum Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = Color.red
  if c != Color.blue 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.mov ecx, 2
    x86.mov edx, [rbp-16]
    x86.cmp edx, ecx
    x86.je constants.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

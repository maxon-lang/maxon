// Test: export
// --- file: defs.maxon
export enum Permission
  none = 0
  read = 1
  write = 2
end 'Permission'

// --- file: main.maxon
function main() returns ExitCode
  var p = Permission.read
  if p == Permission.read 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, [rbp-8]
    x86.cmp edx, ecx
    x86.jne main.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

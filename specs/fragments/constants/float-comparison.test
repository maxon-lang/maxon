// Test: float-comparison
enum Threshold
  low = 0.1
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  let val = 0.5
  if val > Threshold.low and val < Threshold.high 'inRange'
    return 1
  end 'inRange'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_0.5]
    x86.movsd xmm1, [rip+__float_0.1]
    x86.ucomisd xmm0, xmm1
    x86.seta ecx
    x86.movzx ecx, ecxb
    x86.movsd xmm2, [rip+__float_0.9]
    x86.ucomisd xmm0, xmm2
    x86.setb edx
    x86.movzx edx, edxb
    x86.and ecx, edx
    x86.test ecx, ecx
    x86.je constants.main.inRange_0.after
  inRange_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  inRange_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

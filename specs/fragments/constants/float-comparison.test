// Test: float-comparison
enum Threshold
  low = 0.1
  high = 0.9
end 'Threshold'

function main() returns ExitCode
  let val = 0.5
  if val > Threshold.low and val < Threshold.high 'inRange'
    return 1
  end 'inRange'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0.5]
    x86.movsd xmm1, [rip+__float_0.1]
    x86.ucomisd xmm0, xmm1
    x86.seta rax
    x86.movzx rax, raxb
    x86.movsd xmm2, [rip+__float_0.9]
    x86.ucomisd xmm0, xmm2
    x86.setb rcx
    x86.movzx rcx, rcxb
    x86.and rax, rcx
    x86.test rax, rax
    x86.je constants.main.inRange_0.after
  inRange_0:
    x86.mov rax, 1
    x86.ret
  inRange_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

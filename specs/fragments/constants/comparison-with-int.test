// Test: comparison-with-int
enum State
  idle
  running
  done
end 'State'

function main() returns ExitCode
  var s = State.running
  if s >= State.idle and s <= State.done 'inRange'
    return 1
  end 'inRange'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov ebx, [rbp-16]
    x86.cmp ebx, edx
    x86.setge esi
    x86.movzx esi, esib
    x86.mov edi, 2
    x86.mov r8, [rbp-16]
    x86.cmp r8, edi
    x86.setle r9
    x86.movzx r9, r9b
    x86.and esi, r9
    x86.test esi, esi
    x86.je constants.main.inRange_0.after
  inRange_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  inRange_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

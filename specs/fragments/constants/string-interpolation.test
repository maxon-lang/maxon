// Test: string-interpolation
enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function main() returns ExitCode
  var s = HttpStatus.notFound
  var msg = "status: {s}"
  if msg == "status: 404" 'check'
    return 1
  end 'check'
  return 0
end 'main'

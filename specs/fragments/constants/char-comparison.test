// Test: char-comparison
enum Escape
  newline = '\n'
  tab = '\t'
end 'Escape'

function main() returns ExitCode
  let ch = '\n'
  if ch == Escape.newline 'check'
    return 1
  end 'check'
  return 0
end 'main'

// Test: mixed-values
enum Priority
  low
  medium
  high = 10
  critical
end 'Priority'

function main() returns ExitCode
  var result = match Priority.critical 'check'
    Priority.low gives 0
    Priority.medium gives 1
    Priority.high gives 10
    Priority.critical gives 11
    default gives 99
  end 'check'
  return result
end 'main'
---
ExitCode: 11
---
module {
  func @constants.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 11
    x86.mov [rbp-8], rax
    x86.jmp constants.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.cmp1
  check_0.case0:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.cmp2
  check_0.case1:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 10
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.cmp3
  check_0.case2:
    x86.mov rax, 10
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.cmp3:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 11
    x86.cmp rax, rcx
    x86.jne constants.main.check_0.case4
  check_0.case3:
    x86.mov rax, 11
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.case4:
    x86.mov rax, 99
    x86.mov [rbp-16], rax
    x86.jmp constants.main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je constants.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_34]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}

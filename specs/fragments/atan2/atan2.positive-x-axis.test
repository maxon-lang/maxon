// Test: atan2.positive-x-axis
function main() returns ExitCode
  var angle = Math.atan2(0.0, x: 1.0)
  if angle == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @atan2.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_1]
    x86.call stdlib.Math.atan2
    x86.movsd xmm2, [rip+__float_0]
    x86.ucomisd xmm0, xmm2
    x86.jne atan2.main.check_0.after
    x86.jp atan2.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

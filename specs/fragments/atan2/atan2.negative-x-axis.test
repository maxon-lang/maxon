// Test: atan2.negative-x-axis
function main() returns int
  // π ≈ 3.14159
  var angle = Math.atan2(0.0, x: -1.0)
  print("{angle}\n")
  // Should be approximately π
  if angle > 3.14 'check1'
    if angle < 3.15 'check2'
      return 0
    end 'check2'
  end 'check1'
  return 1
end 'main'

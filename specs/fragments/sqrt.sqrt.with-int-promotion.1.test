// Test: sqrt.sqrt.with-int-promotion.1
function main() returns int
    var x = 16  // int
    var result = sqrt(x)  // x promoted to 16.0
    return trunc(result)
end 'main'
---
ExitCode: 4
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 16
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_fsqrt = fsqrt f64 %tmp_sitofp
    %tmp_fptosi = fptosi i64 %tmp_fsqrt
    ret %tmp_fptosi
}

---

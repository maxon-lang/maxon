// Test: if-try-in-loop
enum MyError is Error
  failed
end 'MyError'

function mayFail(n int) returns int throws MyError
  if n < 3 'check'
    throw MyError.failed
  end 'check'
  return n
end 'mayFail'

function main() returns int
  var sum = 0
  var i = 0
  while i < 5 'loop'
    if let val = try mayFail(i) 'check'
      sum = sum + val
    end 'check'
    i = i + 1
  end 'loop'
  return sum
end 'main'
---
ExitCode: 7
---
module {
  func @if-try.mayFail(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, 3
    x86.cmp ecx, eax
    x86.jge if-try.mayFail.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @if-try.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp if-try.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge if-try.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call if-try.mayFail
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.jne if-try.main.check_3.merge
  check_3:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp if-try.main.check_3.merge
  check_3.merge:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.jmp if-try.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

// Test: if-try-else-success
enum MyError implements Error
  failed
end 'MyError'

function mayFail(succeed bool) returns int throws MyError
  if not succeed 'check'
    throw MyError.failed
  end 'check'
  return 42
end 'mayFail'

function main() returns int
  var result = 0
  if try mayFail(true) 'check'
    result = 1
  end 'check' else 'err'
    result = 2
  end 'err'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x86.mov eax, 1
    x86.xor ecx, eax
    x86.test ecx, ecx
    x86.je if-try.mayFail.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 42
    x86.xor edx, edx
    x86.ret
  }
  func @if-try.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov rcx, rax
    x86.call if-try.mayFail
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.jne if-try.main.err_3
  check_2:
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.jmp if-try.main.check_2.merge
  err_3:
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.jmp if-try.main.check_2.merge
  check_2.merge:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: if-try-else-success

typealias Integer = int(i64.min to i64.max)

union MyError implements Error
  failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
  if not succeed 'check'
    throw MyError.failed
  end 'check'
  return 42
end 'mayFail'

function main() returns ExitCode
  var result = 0
  if try mayFail(true) 'check'
    result = 1
  end 'check' else 'err'
    result = 2
  end 'err'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, [rbp-24]
    x86.xor edx, ecx
    x86.test edx, edx
    x86.je if-try.mayFail.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.mov edx, [rbp-16]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov esi, 1
    x86.xor edi, edi
    x86.lea edx, [edi + esi]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 42
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.call if-try.mayFail
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.jne if-try.main.err_3
  check_2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.mov ecx, 1
    x86.mov [rbp-24], ecx
    x86.mov edx, [rbp-16]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.jmp if-try.main.check_2.merge
  err_3:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 2
    x86.mov [rbp-24], ecx
    x86.mov edx, [rbp-32]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.jmp if-try.main.check_2.merge
  check_2.merge:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je if-try.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_33]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-48], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-48]
    x86.epilogue
    x86.ret
  }
}

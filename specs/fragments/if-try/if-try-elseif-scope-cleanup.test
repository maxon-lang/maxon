// Test: if-try-elseif-scope-cleanup
union MyError implements Error
  failed
end 'MyError'

typealias Int = int(i64.min to i64.max)

function mayFail() returns Int throws MyError
  throw MyError.failed
end 'mayFail'

function helper(x Int) returns Int throws MyError
  if x == 1 'case1'
    return 10
  end 'case1' else if x == 2 'case2'
    let r = try mayFail()
    return r
  end 'case2' else 'default'
    return 30
  end 'default'
end 'helper'

function main() returns ExitCode
  return try helper(3) otherwise 99
end 'main'
---
ExitCode: 30
---
module {
  func @if-try.mayFail() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  }
  func @if-try.helper(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, 1
    x86.cmp ecx, eax
    x86.jne if-try.helper.case1_0.elseif
  case1_0:
    x86.mov eax, 10
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  case1_0.elseif:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne if-try.helper.default_6
  case2_1:
    x86.call if-try.mayFail
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je if-try.helper.try_continue_3
  propagate_error_2:
    x86.mov edx, [rbp-16]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  try_continue_3:
    x86.mov eax, [rbp-24]
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  default_6:
    x86.mov eax, 30
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rcx, 3
    x86.call if-try.helper
    x86.mov ecx, 99
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je if-try.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.jmp if-try.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je if-try.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_38]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

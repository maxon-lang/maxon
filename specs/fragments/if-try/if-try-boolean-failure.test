// Test: if-try-boolean-failure

typealias Integer = int(i64.min to i64.max)

union MyError implements Error
  failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
  if not succeed 'check'
    throw MyError.failed
  end 'check'
  return 42
end 'mayFail'

function main() returns ExitCode
  var result = 0
  if try mayFail(false) 'check'
    result = 1
  end 'check'
  return result
end 'main'
---
ExitCode: 0
---
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x86.mov eax, 1
    x86.xor ecx, eax
    x86.test ecx, ecx
    x86.je if-try.mayFail.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 42
    x86.xor edx, edx
    x86.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor rcx, rcx
    x86.call if-try.mayFail
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.jne if-try.main.check_2.merge
  check_2:
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.jmp if-try.main.check_2.merge
  check_2.merge:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je if-try.main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

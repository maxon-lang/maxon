    x86.je memory-safety.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_37]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-56]
    x86.mov ecx, [rbp-16]
    x86.call mm_decref
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.mov ecx, [rbp-48]

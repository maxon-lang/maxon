// Test: ref-identity-in-cloned-function
typealias Integer = int(i64.min to i64.max)

type Box
  export var value Integer
end 'Box'

function isSame(a Box, b Box) returns Integer
  if a is b 'same'
    return 1
  end 'same'
  return 0
end 'isSame'

function main() returns ExitCode
  var x = Box{value: 10}
  var y = x
  var z = Box{value: 10}
  var same = isSame(a: x, b: y)
  var diff = isSame(a: x, b: z)
  return same + diff
end 'main'
---
ExitCode: 1
---
module {
  func @memory-safety.isSame(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.cmp eax, ebx
    x86.jne memory-safety.isSame.same_0.after
  same_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  same_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.lea_symdata rax, [__tag_memory-safety_main]
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov edx, 10
    x86.lea_symdata rbx, [__tag_Box]
    x86.mov rsi, rbx
    x86.mov rdx, rsi
    x86.mov rcx, 8
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-16]
    x86.mov r8, 10
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, 10
    x86.lea rdi, [rbp-40]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rax, [rbp-40]
    x86.mov rcx, rax
    x86.mov eax, 8
    x86.add ecx, eax
    x86.mov [rbp-48], ecx
    x86.mov eax, [rbp-48]
    x86.mov ecx, 10
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-48]
    x86.mov rcx, [rbp-48]
    x86.call mm_incref
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.call memory-safety.isSame
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-48]
    x86.mov [rbp-64], eax
    x86.call memory-safety.isSame
    x86.mov ecx, [rbp-64]
    x86.add ecx, eax
    x86.mov [rbp-56], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295

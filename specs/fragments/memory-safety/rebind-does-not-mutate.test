// Test: rebind-does-not-mutate
typealias Integer = int(i64.min to i64.max)

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = a
  b = Point{x: 99, y: 99}
  print("{a.x}")
  return 0
end 'main'
---

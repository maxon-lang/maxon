// Test: non-cloneable-assignment-ok
typealias Integer = int(i64.min to i64.max)

enum Color
  red
  green
  blue
end 'Color'

type Item
  export var color Color
  export var value Integer
end 'Item'

function main() returns ExitCode
  var a = Item{color: Color.red, value: 42}
  var b = a
  b.value = 99
  return a.value
end 'main'
---
ExitCode: 99
---
module {
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.mov ecx, 42
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov edx, [rbp-16]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-16]
    x86.mov edi, 42
    x86.mov [esi+8], edi
    x86.mov [rbp-24], eax
    x86.mov r8, 99
    x86.mov r9, [rbp-24]
    x86.mov [r9+8], r8
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+8]
    x86.mov [rbp-32], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je memory-safety.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_35]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

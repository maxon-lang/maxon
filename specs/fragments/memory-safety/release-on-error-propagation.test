// Test: release-on-error-propagation
typealias Integer = int(i64.min to i64.max)

type Resource
  export var id Integer
end 'Resource'

enum ResourceError
  case notFound
end 'ResourceError'

function loadResource() returns Resource throws ResourceError
  throw ResourceError.notFound
end 'loadResource'

function process() returns Integer throws ResourceError
  var marker = Resource{id: 42}
  var res = try loadResource()
  return res.id + marker.id
end 'process'

function main() returns ExitCode
  var result = try process() otherwise 'err'
    return 99
  end 'err'
  return result
end 'main'
---
ExitCode: 99
---
module {
  func @memory-safety.loadResource() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  }
  func @memory-safety.process() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 42
    x86.lea rdi, [rbp-24]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-32], edx
    x86.mov esi, [rbp-32]
    x86.mov edi, 42
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call mm_incref
    x86.call memory-safety.loadResource
    x86.mov [rbp-40], edx
    x86.mov [rbp-48], eax
    x86.xor r9, r9
    x86.cmp edx, r9
    x86.je memory-safety.process.try_continue_1
  propagate_error_0:
    x86.mov edx, [rbp-40]
    x86.mov eax, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call mm_decref
    x86.mov ecx, [rbp-48]
    x86.call mm_decref
    x86.mov edx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-40]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  try_continue_1:
    x86.mov eax, [rbp-48]
    x86.mov [rbp-56], eax
    x86.mov ecx, [rbp-56]
    x86.call mm_incref
    x86.mov edx, [rbp-56]
    x86.mov ebx, [edx+0]
    x86.mov esi, [rbp-32]
    x86.mov edi, [esi+0]
    x86.add ebx, edi
    x86.mov r8, [rbp-32]
    x86.mov [rbp-64], ebx
    x86.mov rcx, [rbp-32]
    x86.call mm_decref
    x86.mov r9, [rbp-48]
    x86.mov rcx, [rbp-48]
    x86.call mm_decref
    x86.mov eax, [rbp-56]
    x86.mov rcx, [rbp-56]
    x86.call mm_decref
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-64]
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call memory-safety.process
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je memory-safety.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, 99
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je memory-safety.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_48]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:

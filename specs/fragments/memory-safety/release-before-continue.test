// Test: release-before-continue
typealias Integer = int(i64.min to i64.max)

type Counter
  export var n Integer
end 'Counter'

function main() returns ExitCode
  var total = 0
  var i = 0
  while i < 5 'loop'
    i = i + 1
    var c = Counter{n: i}
    if c.n == 3 'skip'
      continue
    end 'skip'
    total = total + c.n
  end 'loop'
  return total
end 'main'
---
ExitCode: 12
---

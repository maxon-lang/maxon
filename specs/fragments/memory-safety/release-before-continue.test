    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp memory-safety.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge memory-safety.main.loop_0.exit
  loop_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov edx, [rbp-24]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov edi, [rbp-24]
    x86.mov r8, [edi+0]
    x86.mov r9, 3
    x86.cmp r8, r9
    x86.jne memory-safety.main.skip_1.after
  skip_1:
    x86.mov eax, [rbp-24]
    x86.test eax, eax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.jmp memory-safety.main.loop_0.header
  skip_1.after:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [eax+0]
    x86.mov edx, [rbp-8]
    x86.add edx, ecx
    x86.mov [rbp-8], edx
    x86.mov ebx, [rbp-24]
    x86.test ebx, ebx
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp memory-safety.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je memory-safety.main.__range_ok_2
  __range_panic_2:

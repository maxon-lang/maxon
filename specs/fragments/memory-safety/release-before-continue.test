// Test: release-before-continue
typealias Integer = int(i64.min to i64.max)

type Counter
  export var n Integer
end 'Counter'

function main() returns ExitCode
  var total = 0
  var i = 0
  while i < 5 'loop'
    i = i + 1
    var c = Counter{n: i}
    if c.n == 3 'skip'
      continue
    end 'skip'
    total = total + c.n
  end 'loop'
  return total
end 'main'
---
ExitCode: 12
---
module {
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.xor rcx, rcx
    x86.mov [rbp-16], rcx
    x86.jmp memory-safety.main.loop_0.header
  loop_0.header:
    x86.mov rax, 5
    x86.mov rcx, [rbp-16]
    x86.cmp rcx, rax
    x86.jge memory-safety.main.loop_0.exit
  loop_0:
    x86.mov rax, 1
    x86.mov rcx, [rbp-16]
    x86.add rcx, rax
    x86.mov [rbp-16], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-24], rax
    x86.mov rdx, [rbp-24]
    x86.mov rbx, [rbp-16]
    x86.mov [rdx+0], rbx
    x86.mov rsi, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov rdi, [rbp-24]
    x86.mov r8, [rdi+0]
    x86.mov r9, 3
    x86.cmp r8, r9
    x86.jne memory-safety.main.skip_1.after
  skip_1:
    x86.mov rax, [rbp-24]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.jmp memory-safety.main.loop_0.header
  skip_1.after:
    x86.mov rax, [rbp-24]
    x86.mov rcx, [rax+0]
    x86.mov rdx, [rbp-8]
    x86.add rdx, rcx
    x86.mov [rbp-8], rdx
    x86.mov rbx, [rbp-24]
    x86.test rbx, rbx
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp memory-safety.main.loop_0.header
  loop_0.exit:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-32], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je memory-safety.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_32]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov rax, [rbp-32]
    x86.epilogue

// Test: array-clone
function main() returns ExitCode
  var a = [1, 2, 3]
  var b = a
  if a is not b 'diff'
    return 1
  end 'diff'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov ecx, 3
    x86.xor edx, edx
    x86.mov ebx, 8
    x86.mov esi, 32
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edi, [rbp-8]
    x86.xor r8, r8
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, 3
    x86.mov [r9+8], eax
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.xor eax, eax
    x86.mov ecx, 16
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.lea_rdata rax, [__const_array_memory-safety.main_a]
    x86.mov rcx, rax
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+8]
    x86.mov [edx+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call stdlib.Array.clone
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.cmp eax, ecx
    x86.je memory-safety.main.diff_1.after
  diff_1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.call __destroy_Array
    x86.mov rcx, [rbp-24]
    x86.call __destroy_Array
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  diff_1.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.call __destroy_Array
    x86.mov eax, [rbp-24]
    x86.mov rcx, rax
    x86.call __destroy_Array
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

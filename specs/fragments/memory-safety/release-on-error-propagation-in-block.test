    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je memory-safety.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_53]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov rax, [rbp-16]
    x86.epilogue

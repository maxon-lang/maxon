    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov rbx, [rbp-8]
    x86.mov rsi, [rbx+0]
    x86.xor rdi, rdi
    x86.cmp rsi, rdi
    x86.jle memory-safety.compute.positive_0.after
  positive_0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov rdx, 2
    x86.imul rcx, rdx
    x86.mov [rbp-40], rcx
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rbx, [rbp-16]
    x86.mov rsi, [rbp-40]
    x86.mov [rbx+0], rsi
    x86.mov rdi, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.call memory-safety.failingLookup
    x86.mov [rbp-24], rdx
    x86.mov [rbp-32], rax
    x86.xor r8, r8
    x86.cmp rdx, r8
    x86.je memory-safety.compute.try_continue_2
  propagate_error_1:
    x86.mov rdx, [rbp-24]
    x86.mov rax, [rbp-16]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-24]
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  try_continue_2:
    x86.mov rax, [rbp-32]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rcx+0]
    x86.add rax, rdx
    x86.mov rbx, [rbp-16]
    x86.mov [rbp-40], rax
    x86.test rbx, rbx
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rsi, [rbp-8]
    x86.test rsi, rsi
    x86.jz __nonnull_skip_3
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_3
    x86.mov rax, [rbp-40]
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  positive_0.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_4
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_4
    x86.xor rax, rax
    x86.xor rdx, rdx
    x86.epilogue
    x86.ret
  }
  func @memory-safety.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call memory-safety.compute
    x86.mov [rbp-8], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je memory-safety.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov rax, 77
    x86.epilogue

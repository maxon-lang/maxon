    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.mov rcx, rax
    x86.call stdlib.String.clone
    x86.mov [rbp-40], eax
    x86.mov eax, [rbp-32]

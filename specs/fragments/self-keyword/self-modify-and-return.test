// Test: self-modify-and-return
type Value
  var n int

  function double()
    self.n = self.n * 2
  end 'double'

  function get() returns int
    return self.n
  end 'get'
end 'Value'

function main() returns int
  var v = Value{n: 21}
  v.double()
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.double(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov ebx, [rbp-8]
    x86.mov [ebx+0], ecx
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.epilogue
    x86.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @self-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 21
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call Value.double
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], edx
    x86.lea rbx, [rbp-16]
    x86.mov rcx, rbx
    x86.call Value.get
    x86.epilogue
    x86.ret
  }
}

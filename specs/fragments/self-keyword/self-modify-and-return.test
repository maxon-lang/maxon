// Test: self-modify-and-return
type Value
  var n Integer

  function double()
    self.n = self.n * 2
  end 'double'

  function get() returns Integer
    return self.n
  end 'get'
end 'Value'

function main() returns Integer
  var v = Value{n: 21}
  v.double()
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.double(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @self-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 21
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 21
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call Value.double
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Value.get
  }
}
---

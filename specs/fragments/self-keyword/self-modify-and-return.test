// Test: self-modify-and-return
type Value
    var n int

    function double()
        self.n = self.n * 2
    end 'double'

    function get() returns int
        return self.n
    end 'get'
end 'Value'

function main() returns int
    var v = Value{n: 21}
    v.double()
    return v.get()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 21
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov rdx, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rbx
    x86.mov rsi, rcx
    x86.mov rcx, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, rbx
    x86.call Value.double
    x86.mov rcx, rbx
    x86.call Value.get
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Value.double(%self: memref<!maxon.struct<Value>>) {
  ^entry(%self: memref<!maxon.struct<Value>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 1
    x86.mov r8, rax
    x86.push rcx
    x86.shl r8, rdx
    x86.pop rcx
    x86.mov qword ptr [rcx], r8
    x86.epilogue
    x86.ret
}

func.func @Value.get(%self: memref<!maxon.struct<Value>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Value>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

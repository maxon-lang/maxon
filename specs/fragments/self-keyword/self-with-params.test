    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Accumulator.getTotal(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }

    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Accumulator.add
    x86.mov r8, 20
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Accumulator.add
    x86.mov eax, 12
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rax
    x86.call Accumulator.add
    x86.mov rcx, [rbp-8]

// Test: self-with-params
type Accumulator
    var total int

    function add(value int)
        self.total = self.total + value
    end 'add'

    function getTotal() returns int
        return self.total
    end 'getTotal'
end 'Accumulator'

function main() returns int
    var acc = Accumulator{total: 0}
    acc.add(10)
    acc.add(20)
    acc.add(12)
    return acc.getTotal()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov rdx, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rbx
    x86.mov rsi, rcx
    x86.mov rcx, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rdx, 10
    x86.mov r10, rbx
    x86.mov r11, rdx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Accumulator.add
    x86.mov rdx, 20
    x86.mov r10, rbx
    x86.mov r11, rdx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Accumulator.add
    x86.mov rdx, 12
    x86.mov r10, rbx
    x86.mov r11, rdx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Accumulator.add
    x86.mov rcx, rbx
    x86.call Accumulator.getTotal
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Accumulator.add(%self: memref<!maxon.struct<Accumulator>>, %value: i64) {
  ^entry(%self: memref<!maxon.struct<Accumulator>>, %value: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov rax, qword ptr [rdx]
    x86.mov r8, rax
    x86.add r8, rcx
    x86.mov qword ptr [rdx], r8
    x86.epilogue
    x86.ret
}

func.func @Accumulator.getTotal(%self: memref<!maxon.struct<Accumulator>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Accumulator>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}

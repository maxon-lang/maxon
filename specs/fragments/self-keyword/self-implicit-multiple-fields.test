// Test: self-implicit-multiple-fields
type Rectangle
    var width int
    var height int

    function area() returns int
        return width * height
    end 'area'
end 'Rectangle'

function main() returns int
    var r = Rectangle{width: 6, height: 7}
    return r.area()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 6
    x86.mov rcx, 7
    x86.lea rdx, qword ptr [rbp-48]
    x86.lea r8, qword ptr [rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rdx+8]
    x86.mov qword ptr [r8], rcx
    x86.lea r8, qword ptr [rbp-64]
    x86.mov rcx, 16
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r8
    x86.mov rsi, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, r8
    x86.call Rectangle.area
    x86.mov r8, rax
    x86.mov rax, r8
    x86.epilogue
    x86.ret
}

func.func @Rectangle.area(%self: memref<!maxon.struct<Rectangle>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Rectangle>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rdx, qword ptr [rcx]
    x86.lea rcx, qword ptr [rax+8]
    x86.mov rax, qword ptr [rcx]
    x86.imul rcx, rdx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

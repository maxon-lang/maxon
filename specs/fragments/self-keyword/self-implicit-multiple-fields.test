// Test: self-implicit-multiple-fields
type Rectangle
  var width int
  var height int

  function area() returns int
    return width * height
  end 'area'
end 'Rectangle'

function main() returns int
  var r = Rectangle{width: 6, height: 7}
  return r.area()
end 'main'
---
ExitCode: 42
---
module {
  func @Rectangle.area(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+8]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.imul ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 6
    x86.mov ecx, 7
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-32]
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-24]
    x86.mov [rbp-48], edi
    x86.lea r8, [rbp-48]
    x86.mov ecx, r8
    x86.call Rectangle.area
    x86.mov r9, [rbp-48]
    x86.mov [rbp-24], r9
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-32], ecx
    x86.epilogue
    x86.ret
  }
}
---

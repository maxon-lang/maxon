// Test: self-implicit-multiple-fields
type Rectangle
  var width int
  var height int

  function area() returns int
    return width * height
  end 'area'
end 'Rectangle'

function main() returns int
  var r = Rectangle{width: 6, height: 7}
  return r.area()
end 'main'
---
ExitCode: 42
---
module {
  func @Rectangle.area(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov [ebx+8], edi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @self-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 6
    x86.mov ecx, 7
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.lea rdx, [rbp-16]
    x86.mov rcx, rdx
    x86.call Rectangle.area
    x86.epilogue
    x86.ret
  }
}
---

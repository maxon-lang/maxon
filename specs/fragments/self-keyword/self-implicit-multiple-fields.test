// Test: self-implicit-multiple-fields
type Rectangle
  var width int
  var height int

  function area() returns int
    return width * height
  end 'area'
end 'Rectangle'

function main() returns int
  var r = Rectangle{width: 6, height: 7}
  return r.area()
end 'main'
---
ExitCode: 42
---
module {
  func @Rectangle.area(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.imul edx, ebx
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @self-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 6
    x86.mov ecx, 7
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 6
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 7
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp Rectangle.area
  }
}
---

// Test: self-multiple-fields

typealias Integer = int(i64.min to i64.max)

type Point
  var x Integer
  var y Integer

  function sum() returns Integer
    return self.x + self.y
  end 'sum'

  function setX(newX Integer)
    self.x = newX
  end 'setX'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 10, y: 32}
  return p.sum()
end 'main'

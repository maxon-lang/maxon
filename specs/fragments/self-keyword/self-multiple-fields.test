// Test: self-multiple-fields
type Point
    var x int
    var y int

    function sum() returns int
        return self.x + self.y
    end 'sum'

    function setX(newX int)
        self.x = newX
    end 'setX'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 32}
    return p.sum()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 10
    x86.mov rcx, 32
    x86.lea rdx, qword ptr [rbp-48]
    x86.lea r8, qword ptr [rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rdx+8]
    x86.mov qword ptr [r8], rcx
    x86.lea r8, qword ptr [rbp-64]
    x86.mov qword ptr [r8], rdx
    x86.mov rdx, [r8]
    x86.mov rcx, rdx
    x86.call Point.sum
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @Point.sum(%self: !maxon.struct<Point>) -> i64 {
  ^entry(%self: !maxon.struct<Point>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rdx, qword ptr [rcx]
    x86.lea rcx, qword ptr [rax+8]
    x86.mov rax, qword ptr [rcx]
    x86.mov rcx, rdx
    x86.add rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

// Test: self-multiple-fields
type Point
  var x int
  var y int

  function sum() returns int
    return self.x + self.y
  end 'sum'

  function setX(newX int)
    self.x = newX
  end 'setX'
end 'Point'

function main() returns int
  var p = Point{x: 10, y: 32}
  return p.sum()
end 'main'

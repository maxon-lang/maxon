// Test: self-implicit-access
type Counter
    var count int

    function increment()
        count = count + 1
    end 'increment'

    function get() returns int
        return count
    end 'get'
end 'Counter'

function main() returns int
    var c = Counter{count: 0}
    c.increment()
    c.increment()
    c.increment()
    return c.get()
end 'main'
---
ExitCode: 3
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.push rbx
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov qword ptr [rbx], rcx
    x86.mov rcx, qword ptr [rbx]
    x86.call Counter.increment
    x86.mov rcx, qword ptr [rbx]
    x86.call Counter.increment
    x86.mov rcx, qword ptr [rbx]
    x86.call Counter.increment
    x86.mov rcx, qword ptr [rbx]
    x86.call Counter.get
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.pop rbx
    x86.epilogue
    x86.ret
}

func.func @Counter.increment(%self: !maxon.struct<Counter>) {
  ^entry(%self: !maxon.struct<Counter>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rdx, qword ptr [rcx]
    x86.mov rcx, 1
    x86.mov r8, rdx
    x86.add r8, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov qword ptr [rcx], r8
    x86.epilogue
    x86.ret
}

func.func @Counter.get(%self: !maxon.struct<Counter>) -> i64 {
  ^entry(%self: !maxon.struct<Counter>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

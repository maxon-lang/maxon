// Test: self-explicit-access
type Counter
    var count int

    function increment()
        self.count = self.count + 1
    end 'increment'

    function get() returns int
        return self.count
    end 'get'
end 'Counter'

function main() returns int
    var c = Counter{count: 0}
    c.increment()
    c.increment()
    return c.get()
end 'main'
---
ExitCode: 2
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov rdx, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rbx
    x86.mov rsi, rcx
    x86.mov rcx, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, rbx
    x86.call Counter.increment
    x86.mov rcx, rbx
    x86.call Counter.increment
    x86.mov rcx, rbx
    x86.call Counter.get
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Counter.increment(%self: memref<!maxon.struct<Counter>>) {
  ^entry(%self: memref<!maxon.struct<Counter>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.mov rdx, 1
    x86.mov r8, rax
    x86.add r8, rdx
    x86.mov qword ptr [rcx], r8
    x86.epilogue
    x86.ret
}

func.func @Counter.get(%self: memref<!maxon.struct<Counter>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Counter>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

// Test: self-explicit-access
type Counter
  var count int

  function increment()
    self.count = self.count + 1
  end 'increment'

  function get() returns int
    return self.count
  end 'get'
end 'Counter'

function main() returns int
  var c = Counter{count: 0}
  c.increment()
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 2
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-16]
    x86.mov ebx, 1
    x86.add edx, ebx
    x86.mov [rbp-16], edx
    x86.mov esi, [rbp-8]
    x86.mov [esi+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-16]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov ecx, rbx
    x86.call Counter.increment
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.mov edi, [rbp-16]
    x86.mov [rbp-32], edi
    x86.lea r8, [rbp-32]
    x86.mov ecx, r8
    x86.call Counter.increment
    x86.mov r9, [rbp-32]
    x86.mov [rbp-16], r9
    x86.mov eax, [rbp-16]
    x86.mov [rbp-40], eax
    x86.lea rax, [rbp-40]
    x86.mov ecx, rax
    x86.call Counter.get
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-16], ecx
    x86.epilogue
    x86.ret
  }
}
---

// Test: tan.zero
function main() returns ExitCode
  var result = Math.tan(0.0)
  if result == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @tan.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.call stdlib.Math.tan
    x86.movsd xmm1, [rip+__float_0]
    x86.ucomisd xmm0, xmm1
    x86.jne tan.main.check_0.after
    x86.jp tan.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

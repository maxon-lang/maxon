// Test: tan.multiple-values
function main() returns int
  var x1 = Math.tan(0.0)
  var x2 = Math.tan(0.5)
  var x3 = Math.tan(1.0)
  var x4 = Math.tan(0.7854)
  print("{x1}\n")
  print("{x2}\n")
  print("{x3}\n")
  print("{x4}\n")
  return 0
end 'main'

// Test: type-method-returning-value
type Calculator
  var value int

  function double() returns int
    return value * 2
  end 'double'
end 'Calculator'

function main() returns int
  var c = Calculator{value: 21}
  return c.double()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 21
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 21
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.epilogue
    x86.jmp Calculator.double
  }
}
---

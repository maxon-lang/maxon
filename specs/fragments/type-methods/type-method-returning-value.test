// Test: type-method-returning-value
type Calculator
    var value int

    function double() returns int
        return value * 2
    end 'double'
end 'Calculator'

function main() returns int
    var c = Calculator{value: 21}
    return c.double()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 21
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rdx, qword ptr [rbp-48]
    x86.mov rax, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rdx
    x86.mov rsi, rcx
    x86.mov rcx, rax
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, rdx
    x86.call Calculator.double
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @Calculator.double(%self: memref<!maxon.struct<Calculator>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Calculator>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.mov rcx, 1
    x86.mov rdx, rax
    x86.shl rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

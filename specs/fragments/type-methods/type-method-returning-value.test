// Test: type-method-returning-value
type Calculator
    var value int

    function double() returns int
        return value * 2
    end 'double'
end 'Calculator'

function main() returns int
    var c = Calculator{value: 21}
    return c.double()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 21
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rbp-48]
    x86.mov qword ptr [r8], rcx
    x86.mov rcx, qword ptr [r8]
    x86.call Calculator.double
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}

func.func @Calculator.double(%self: !maxon.struct<Calculator>) -> i64 {
  ^entry(%self: !maxon.struct<Calculator>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.mov rcx, 1
    x86.mov rdx, rax
    x86.shl rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

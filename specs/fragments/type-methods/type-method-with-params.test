// Test: type-method-with-params
type Adder
    var total int

    function add(value int)
        total = total + value
    end 'add'

    function getTotal() returns int
        return total
    end 'getTotal'
end 'Adder'

function main() returns int
    var a = Adder{total: 0}
    a.add(10)
    a.add(32)
    return a.getTotal()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov qword ptr [rbx], rcx
    x86.mov rcx, qword ptr [rbx]
    x86.mov rdx, 10
    x86.mov r10, rcx
    x86.mov r11, rdx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.add
    x86.mov rdx, qword ptr [rbx]
    x86.mov rcx, 32
    x86.mov r10, rdx
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.add
    x86.mov rcx, qword ptr [rbx]
    x86.mov rcx, rcx
    x86.call Adder.getTotal
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Adder.add(%self: !maxon.struct<Adder>, %value: i64) {
  ^entry(%self: !maxon.struct<Adder>, %value: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov rax, qword ptr [rdx]
    x86.mov r8, rax
    x86.add r8, rcx
    x86.mov qword ptr [rdx], r8
    x86.epilogue
    x86.ret
}

func.func @Adder.getTotal(%self: !maxon.struct<Adder>) -> i64 {
  ^entry(%self: !maxon.struct<Adder>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

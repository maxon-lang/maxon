// Test: type-method-with-params

typealias Integer = int(i64.min to i64.max)

type Adder
  var total Integer

  function add(value Integer)
    total = total + value
  end 'add'

  function getTotal() returns Integer
    return total
  end 'getTotal'
end 'Adder'

function main() returns ExitCode
  var a = Adder{total: 0}
  a.add(10)
  a.add(32)
  return a.getTotal()
end 'main'
---
ExitCode: 42

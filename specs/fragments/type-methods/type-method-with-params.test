// Test: type-method-with-params
type Adder
  var total int

  function add(value int)
    total = total + value
  end 'add'

  function getTotal() returns int
    return total
  end 'getTotal'
end 'Adder'

function main() returns int
  var a = Adder{total: 0}
  a.add(10)
  a.add(32)
  return a.getTotal()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, value: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Adder.getTotal(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Adder.add
    x86.mov r8, 32
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Adder.add
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Adder.getTotal
  }
}
---

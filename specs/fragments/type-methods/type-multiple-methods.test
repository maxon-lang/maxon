// Test: type-multiple-methods
type Counter
  var count int

  function increment()
    count = count + 1
  end 'increment'

  function decrement()
    count = count - 1
  end 'decrement'

  function reset()
    count = 0
  end 'reset'

  function get() returns int
    return count
  end 'get'
end 'Counter'

function main() returns int
  var c = Counter{count: 10}
  c.increment()
  c.increment()
  c.decrement()
  return c.get()
end 'main'
---
ExitCode: 11
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.decrement(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.sub edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.call Counter.increment
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.call Counter.increment
    x86.mov r8, [rbp-8]
    x86.mov rcx, r8
    x86.call Counter.decrement
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp Counter.get
  }
}
---

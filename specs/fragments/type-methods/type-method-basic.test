// Test: type-method-basic
type Counter
  var count int

  function increment()
    count = count + 1
  end 'increment'

  function get() returns int
    return count
  end 'get'
end 'Counter'

function main() returns int
  var c = Counter{count: 0}
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov ebx, [rbp-8]
    x86.mov [ebx+0], ecx
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.epilogue
    x86.ret
  }
  func @Counter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Counter.increment
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.mov edi, [rbp-16]
    x86.mov [rbp-32], edi
    x86.lea r8, [rbp-32]
    x86.mov rcx, r8
    x86.call Counter.get
    x86.mov r9, [rbp-32]
    x86.mov [rbp-16], r9
    x86.epilogue
    x86.ret
  }
}
---

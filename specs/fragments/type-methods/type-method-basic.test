// Test: type-method-basic
type Counter
  var count Integer

  function increment()
    count = count + 1
  end 'increment'

  function get() returns Integer
    return count
  end 'get'
end 'Counter'

function main() returns ExitCode
  var c = Counter{count: 0}
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call Counter.increment
    x86.mov rcx, [rbp-8]
    x86.call Counter.get
    x86.mov [rbp-16], eax
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je type-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

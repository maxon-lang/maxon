// Test: type-method-chain
type Value
  var n int

  function add(x int)
    n = n + x
  end 'add'

  function get() returns int
    return n
  end 'get'
end 'Value'

function main() returns int
  var v = Value{n: 0}
  v.add(10)
  v.add(20)
  v.add(12)
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.add(__self_ptr: i64, x: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.add ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [edx+0], ecx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.epilogue
    x86.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov ecx, 10
    x86.mov [rbp-8], eax
    x86.lea rdx, [rbp-8]
    x86.xchg rdx, rcx
    x86.call Value.add
    x86.mov ebx, [rbp-8]
    x86.mov esi, 20
    x86.mov [rbp-16], ebx
    x86.lea rdi, [rbp-16]
    x86.mov rcx, rdi
    x86.mov rdx, rsi
    x86.call Value.add
    x86.mov r8, [rbp-16]
    x86.mov r9, 12
    x86.mov [rbp-24], r8
    x86.lea rax, [rbp-24]
    x86.mov rcx, rax
    x86.mov rdx, r9
    x86.call Value.add
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.lea rax, [rbp-32]
    x86.mov rcx, rax
    x86.call Value.get
    x86.epilogue
    x86.ret
  }
}

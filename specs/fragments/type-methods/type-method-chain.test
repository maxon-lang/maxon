// Test: type-method-chain
type Value
  var n int

  function add(x int)
    n = n + x
  end 'add'

  function get() returns int
    return n
  end 'get'
end 'Value'

function main() returns int
  var v = Value{n: 0}
  v.add(10)
  v.add(20)
  v.add(12)
  return v.get()
end 'main'

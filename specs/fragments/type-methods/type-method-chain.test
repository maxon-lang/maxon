// Test: type-method-chain

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function add(x Integer)
    n = n + x
  end 'add'

  function get() returns Integer
    return n
  end 'get'
end 'Value'

function main() returns ExitCode
  var v = Value{n: 0}
  v.add(10)
  v.add(20)
  v.add(12)
  return v.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.add(__self_ptr: i64, x: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @type-methods.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Value.add
    x86.mov r8, 20
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Value.add
    x86.mov eax, 12
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rax
    x86.call Value.add
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call Value.get
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je type-methods.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_18]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}

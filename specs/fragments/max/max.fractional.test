// Test: max.fractional
function main() returns int
  var x = max(3.5, 5.2)
  // max of 3.5 and 5.2 is 5.2, trunc gives 5
  return trunc(x)
end 'main'
---
ExitCode: 5
---
module {
  func @max.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.5]
    x86.movsd xmm1, [rip+__float_5.2]
    x86.movsd xmm2, xmm0
    x86.maxsd xmm2, xmm1
    x86.movsd [rbp-8], xmm2
    x86.cvttsd2si eax, xmm2
    x86.epilogue
    x86.ret
  }
}
---

// Test: max.fractional
function main() returns int
    var x = max(3.5, 5.2)
    // max of 3.5 and 5.2 is 5.2, trunc gives 5
    return trunc(x)
end 'main'
---
ExitCode: 5
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 4615063718147915776
    x86.movq xmm0, rax
    x86.mov rax, 4617540697942969549
    x86.movq xmm1, rax
    x86.movsd xmm2, xmm0
    x86.maxsd xmm2, xmm1
    x86.cvttsd2si rax, xmm2
    x86.epilogue
    x86.ret
}

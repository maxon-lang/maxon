// Test: double-negation
function main() returns int
  var x = 10
  var y = - -x
  return y
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.sub ecx, eax
    x86.xor edx, edx
    x86.sub edx, ecx
    x86.mov [rbp-16], edx
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

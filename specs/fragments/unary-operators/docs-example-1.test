// Test: docs-example-1
function main() returns int
  var x = 42
  var y = -x      // y is -42
  var z = -y      // z is 42
  return z
end 'main'

---
ExitCode: 42
---
module {
  func @unary-operators.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.xor ecx, ecx
    x86.sub ecx, eax
    x86.xor edx, edx
    x86.sub edx, ecx
    x86.mov eax, edx
    x86.ret
  }
}
---

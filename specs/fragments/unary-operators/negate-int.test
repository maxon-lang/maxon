// Test: negate-int
function main() returns int
  var x = -42
  var y = -x
  if y == 42 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, -42
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.sub ecx, eax
    x86.mov [rbp-16], ecx
    x86.mov edx, 42
    x86.cmp ecx, edx
    x86.jne main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

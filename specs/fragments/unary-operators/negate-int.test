// Test: negate-int
function main() returns int
    var x = -42
    var y = -x
    if y == 42 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

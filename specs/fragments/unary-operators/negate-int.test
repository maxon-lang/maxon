// Test: negate-int
function main() returns ExitCode
  var x = -42
  var y = -x
  if y == 42 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @unary-operators.main() -> u32 {
  entry:
    x86.mov rax, -42
    x86.xor rcx, rcx
    x86.sub rcx, rax
    x86.mov rdx, 42
    x86.cmp rcx, rdx
    x86.jne unary-operators.main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

// Test: conformance-extra-methods-ok
interface Simple
  function getValue() returns int
end 'Simple'

type Extended implements Simple
  var value int

  function getValue() returns int
    return value
  end 'getValue'

  function extraMethod() returns int
    return 100
  end 'extraMethod'
end 'Extended'

function main() returns int
  var e = Extended{value: 42}
  return e.getValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Extended.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.epilogue
    x86.jmp Extended.getValue
  }
}
---

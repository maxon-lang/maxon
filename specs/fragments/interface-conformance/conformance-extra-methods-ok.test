// Test: conformance-extra-methods-ok
interface Simple
  function getValue() returns int
end 'Simple'

type Extended is Simple
  var value int

  function getValue() returns int
    return value
  end 'getValue'

  function extraMethod() returns int
    return 100
  end 'extraMethod'
end 'Extended'

function main() returns int
  var e = Extended{value: 42}
  return e.getValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Extended.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Extended.getValue
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.epilogue
    x86.ret
  }
}
---

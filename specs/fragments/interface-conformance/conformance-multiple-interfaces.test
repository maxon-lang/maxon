// Test: conformance-multiple-interfaces
interface Readable
  function read() returns int
end 'Readable'

interface Writable
  function write(value int)
end 'Writable'

type Buffer implements Readable, Writable
  var data int

  function read() returns int
    return data
  end 'read'

  function write(value int)
    data = value
  end 'write'
end 'Buffer'

function main() returns int
  var buf = Buffer{data: 0}
  buf.write(42)
  return buf.read()
end 'main'
---
ExitCode: 42
---
module {
  func @Buffer.read(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Buffer.write(__self_ptr: i64, value: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Buffer.write
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Buffer.read
  }
}
---

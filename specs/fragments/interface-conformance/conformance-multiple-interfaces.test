// Test: conformance-multiple-interfaces
interface Readable
  function read() returns Integer
end 'Readable'

interface Writable
  function write(value Integer)
end 'Writable'

type Buffer implements Readable, Writable
  var data Integer

  function read() returns Integer
    return data
  end 'read'

  function write(value Integer)
    data = value
  end 'write'
end 'Buffer'

function main() returns ExitCode
  var buf = Buffer{data: 0}
  buf.write(42)
  return buf.read()
end 'main'
---
ExitCode: 42
---
module {
  func @Buffer.read(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Buffer.write(__self_ptr: i64, value: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Buffer.write
    x86.mov r8, [rbp-8]
    x86.mov rcx, r8
    x86.call Buffer.read
    x86.mov [rbp-16], eax
    x86.xor r9, r9
    x86.cmp eax, r9
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je interface-conformance.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov ecx, [rbp-8]
    x86.xor edx, edx
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov esi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, 42
    x86.call Buffer.write
    x86.mov edi, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call Buffer.read
    x86.mov [rbp-16], eax
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je interface-conformance.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_24]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]

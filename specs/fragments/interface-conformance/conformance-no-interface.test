    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call Standalone.get
    x86.mov [rbp-16], eax
    x86.xor edi, edi
    x86.cmp eax, edi

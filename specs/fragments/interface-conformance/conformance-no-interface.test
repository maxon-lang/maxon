// Test: conformance-no-interface

typealias Integer = int(i64.min to i64.max)

type Standalone
  var value Integer

  function get() returns Integer
    return value
  end 'get'
end 'Standalone'

function main() returns ExitCode
  var s = Standalone{value: 42}
  return s.get()
end 'main'
---
ExitCode: 42
---
module {

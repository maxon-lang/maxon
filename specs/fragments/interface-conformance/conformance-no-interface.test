// Test: conformance-no-interface
type Standalone
  var value int

  function get() returns int
    return value
  end 'get'
end 'Standalone'

function main() returns int
  var s = Standalone{value: 42}
  return s.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Standalone.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Standalone.get
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je interface-conformance.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:

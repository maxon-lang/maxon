// Test: conformance-no-interface
type Standalone
  var value int

  function get() returns int
    return value
  end 'get'
end 'Standalone'

function main() returns int
  var s = Standalone{value: 42}
  return s.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Standalone.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.epilogue
    x86.jmp Standalone.get
  }
}
---

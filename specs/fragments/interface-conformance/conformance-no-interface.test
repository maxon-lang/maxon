    x86.je interface-conformance.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_21]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]

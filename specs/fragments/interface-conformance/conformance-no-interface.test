    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-16]
    x86.mov esi, 42
    x86.mov [ebx+0], esi
    x86.mov rcx, [rbp-16]
    x86.call Standalone.get
    x86.mov [rbp-24], eax
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax

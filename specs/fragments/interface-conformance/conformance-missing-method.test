// Test: conformance-missing-method

typealias Integer = i64

interface Counter
  function get() returns Integer
  function increment()
end 'Counter'

type BadCounter implements Counter
  var value Integer

  function get() returns Integer
    return value
  end 'get'
end 'BadCounter'

function main() returns ExitCode
  return 0
end 'main'

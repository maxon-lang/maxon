// Test: conformance-basic
interface Counter
  function get() returns int
  function increment()
end 'Counter'

type SimpleCounter implements Counter
  var value int

  function get() returns int
    return value
  end 'get'

  function increment()
    value = value + 1
  end 'increment'
end 'SimpleCounter'

function main() returns int
  var c = SimpleCounter{value: 40}
  c.increment()
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 42
---
module {
  func @SimpleCounter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @SimpleCounter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 40
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 40
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call SimpleCounter.increment
    x86.mov rcx, [rbp-8]
    x86.call SimpleCounter.increment
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp SimpleCounter.get
  }
}
---

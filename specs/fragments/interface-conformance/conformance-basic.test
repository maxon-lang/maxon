// Test: conformance-basic
interface Counter
  function get() returns int
  function increment()
end 'Counter'

type SimpleCounter is Counter
  var value int

  function get() returns int
    return value
  end 'get'

  function increment()
    value = value + 1
  end 'increment'
end 'SimpleCounter'

function main() returns int
  var c = SimpleCounter{value: 40}
  c.increment()
  c.increment()
  return c.get()
end 'main'
---
ExitCode: 42
---
module {
  func @SimpleCounter.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @SimpleCounter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov ebx, [rbp-8]
    x86.mov [ebx+0], ecx
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.epilogue
    x86.ret
  }
  func @interface-conformance.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 40
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call SimpleCounter.increment
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], edx
    x86.lea rbx, [rbp-16]
    x86.mov rcx, rbx
    x86.call SimpleCounter.increment
    x86.mov esi, [rbp-16]
    x86.mov [rbp-24], esi
    x86.lea rdi, [rbp-24]
    x86.mov rcx, rdi
    x86.call SimpleCounter.get
    x86.epilogue
    x86.ret
  }
}
---

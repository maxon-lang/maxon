// Test: error.closure-return

typealias Integer = i64

type Point
  var x Integer
  var y Integer
end 'Point'

function transform(f (Integer) returns Point, n Integer) returns Point
  return f(n)
end 'transform'

function main() returns ExitCode
  var p = transform((x Integer) gives Point{x: x, y: x * 2}, n: 5)
  return p.x
end 'main'

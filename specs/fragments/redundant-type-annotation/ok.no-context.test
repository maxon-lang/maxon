// Test: ok.no-context
type Point
  export var x int
  export var y int
end 'Point'

function main() returns int
  var p = Point{x: 1, y: 2}
  return p.x
end 'main'
---
ExitCode: 1
---
module {
  func @redundant-type-annotation.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}

// Test: docs-example-1
export function add(a int, b int) returns int
  return a + b
end 'add'

function main() returns int
  return add(10, b: 20)  // Unqualified call within same namespace
end 'main'

---
ExitCode: 30
---
module {
  func @add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp add
  }
}
---

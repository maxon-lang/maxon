  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [edx+0]
    x86.mov [rbp-24], eax
    x86.mov edx, [rbp-24]
    x86.cmp ecx, edx
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }

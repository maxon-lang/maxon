    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov rdx, [rbp-24]
    x86.test rdx, rdx
    x86.jz __nonnull_skip_2
    x86.mov rcx, [rbp-24]
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  neq_1.after:

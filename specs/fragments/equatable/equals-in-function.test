// Test: equals-in-function
type Id implements Equatable
  export var n int

  function equals(other Id) returns bool
    return n == other.n
  end 'equals'
end 'Id'

function areEqual(a Id, b Id) returns bool
  return a.equals(b)
end 'areEqual'

function main() returns int
  var x = Id{n: 5}
  var y = Id{n: 5}
  var z = Id{n: 6}
  if areEqual(x, b: y) 'eq'
    if areEqual(x, b: z) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Id.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov esi, [eax+0]
    x86.cmp ebx, esi
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
  func @equatable.areEqual(a: i64, b: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov rcx, rax
    x86.mov rdx, rbx
    x86.epilogue
    x86.jmp Id.equals
  }
  func @equatable.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 5
    x86.mov [edx+0], ebx
    x86.mov esi, 5
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 5
    x86.mov [r8+0], r9
    x86.mov eax, 6
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, 6
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call equatable.areEqual
    x86.test eax, eax
    x86.je equatable.main.eq_0.after
  eq_0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call equatable.areEqual
    x86.test eax, eax
    x86.je equatable.main.neq_1.after
  neq_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

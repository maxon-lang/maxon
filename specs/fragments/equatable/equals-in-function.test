// Test: equals-in-function
type Id is Equatable
  export var n int

  function equals(other Id) returns bool
    return n == other.n
  end 'equals'
end 'Id'

function areEqual(a Id, b Id) returns bool
  return a.equals(b)
end 'areEqual'

function main() returns int
  var x = Id{n: 5}
  var y = Id{n: 5}
  var z = Id{n: 6}
  if areEqual(x, b: y) 'eq'
    if areEqual(x, b: z) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Id.equals(__self_ptr: i64, other.n: i64) -> i1 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov edx, [rbp-24]
    x86.cmp ecx, edx
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @areEqual(a.n: i64, b.n: i64) -> i1 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov [rbp-24], eax
    x86.lea rcx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.mov ecx, rcx
    x86.call Id.equals
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-8], ebx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 5
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov esi, 6
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-40]
    x86.mov [rbp-48], edi
    x86.mov r8, [rbp-16]
    x86.mov r9, [rbp-32]
    x86.mov ecx, r8
    x86.mov edx, r9
    x86.call areEqual
    x86.test eax, eax
    x86.je main.eq_0.after
  eq_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-48]
    x86.mov edx, ecx
    x86.mov ecx, eax
    x86.call areEqual
    x86.test eax, eax
    x86.je main.neq_1.after
  neq_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}

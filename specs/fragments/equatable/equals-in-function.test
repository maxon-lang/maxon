    x86.mov [rbp-8], eax
    x86.mov ecx, [edx+0]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov esi, [rbp-16]
    x86.mov [rbp-32], esi
    x86.lea rdi, [rbp-32]
    x86.mov rcx, rbx
    x86.mov rdx, rdi
    x86.call Id.equals
    x86.mov r8, [rbp-24]
    x86.mov [rbp-8], r8
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> i64 {
  entry:
    x86.prologue stack_size=80
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 5
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov esi, 6
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-40]
    x86.mov [rbp-48], edi
    x86.mov r8, [rbp-16]
    x86.mov [rbp-56], r8
    x86.lea r9, [rbp-56]
    x86.mov eax, [rbp-32]
    x86.mov [rbp-64], eax
    x86.lea rax, [rbp-64]
    x86.mov rcx, r9
    x86.mov rdx, rax
    x86.call equatable.areEqual
    x86.test eax, eax

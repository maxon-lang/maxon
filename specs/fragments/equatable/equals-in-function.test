// Test: equals-in-function
type Id is Equatable
  export var n int

  function equals(other Id) returns bool
    return n == other.n
  end 'equals'
end 'Id'

function areEqual(a Id, b Id) returns bool
  return a.equals(b)
end 'areEqual'

function main() returns int
  var x = Id{n: 5}
  var y = Id{n: 5}
  var z = Id{n: 6}
  if areEqual(x, b: y) 'eq'
    if areEqual(x, b: z) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---

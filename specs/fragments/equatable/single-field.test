// Test: single-field
type Wrapper is Equatable
  export var value int

  function equals(other Wrapper) returns bool
    return value == other.value
  end 'equals'
end 'Wrapper'

function main() returns int
  var a = Wrapper{value: 42}
  var b = Wrapper{value: 42}
  var c = Wrapper{value: 99}
  if a.equals(b) 'eq'
    if a.equals(c) 'neq'
      return 1
    end 'neq'
    return 0
  end 'eq'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Wrapper.equals(__self_ptr: i64, other.value: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], edx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, [rbp-16]
    x86.cmp ecx, eax
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 42
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov esi, 99
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-40]
    x86.mov [rbp-48], edi
    x86.mov r8, [rbp-16]
    x86.mov [rbp-56], r8
    x86.lea r9, [rbp-56]
    x86.mov eax, [rbp-32]
    x86.mov rcx, r9
    x86.mov rdx, rax
    x86.call Wrapper.equals
    x86.mov ecx, [rbp-56]
    x86.mov [rbp-16], ecx
    x86.test eax, eax
    x86.je main.eq_0.after
  eq_0:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-64], eax
    x86.lea rcx, [rbp-64]
    x86.mov edx, [rbp-48]
    x86.call Wrapper.equals
    x86.mov ebx, [rbp-64]
    x86.mov [rbp-16], ebx
    x86.test eax, eax
    x86.je main.neq_1.after
  neq_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  neq_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-16]
    x86.mov r8, 42
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, 99

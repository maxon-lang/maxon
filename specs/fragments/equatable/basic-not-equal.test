// Test: basic-not-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 3, y: 4}
  if a.equals(b) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov esi, [eax+8]
    x86.mov eax, [rbp-16]
    x86.mov edi, [eax+0]
    x86.cmp ebx, edi
    x86.sete eax
    x86.movzx eax, eaxb
    x86.mov ebx, [rbp-16]
    x86.mov edi, [ebx+8]
    x86.cmp esi, edi
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.and eax, ebx
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 1
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 2
    x86.mov [edi+8], r8
    x86.mov r9, 3
    x86.mov eax, 4
    x86.mov ecx, 16
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, 4
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Point.equals
    x86.test eax, eax
    x86.je equatable.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call __destroy_Point
    x86.mov rcx, [rbp-16]
    x86.call __destroy_Point
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call __destroy_Point
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call __destroy_Point
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

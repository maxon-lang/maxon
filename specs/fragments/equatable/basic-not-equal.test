// Test: basic-not-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 3, y: 4}
  if a.equals(b) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], edx
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [ecx+0]
    x86.mov ebx, [rbp-16]
    x86.mov esi, [ebx+8]
    x86.mov edi, [rbp-24]
    x86.mov r8, [edi+0]
    x86.cmp edx, r8
    x86.sete r9
    x86.movzx r9, r9b
    x86.mov eax, [rbp-24]
    x86.mov ecx, [eax+8]
    x86.cmp esi, ecx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.and r9, eax
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], r9
    x86.mov rcx, rax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, 2
    x86.mov ebx, 16
    x86.xor esi, esi
    x86.mov rcx, rbx
    x86.mov rdx, rsi
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-16]
    x86.mov r8, 1
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov eax, 2
    x86.mov [r9+8], eax
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov edx, 16
    x86.xor ebx, ebx
    x86.mov rcx, rdx
    x86.mov rdx, rbx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, 3
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, 4
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Point.equals
    x86.test eax, eax
    x86.je equatable.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-32]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: partial-field-match
type Point is Equatable
  export var x int
  export var y int

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns int
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 99}
  if a.equals(b) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=48
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov eax, [rbp-16]
    x86.mov ebx, [edx+8]
    x86.mov [rbp-32], ebx
    x86.mov ebx, [edx+0]
    x86.mov [rbp-40], ebx
    x86.mov edx, [rbp-40]
    x86.cmp ecx, edx
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.mov esi, [rbp-32]
    x86.cmp eax, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.and ebx, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-24]
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-16]
    x86.mov [r8+8], eax
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.mov edx, 1
    x86.mov ebx, 99
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.lea rsi, [rbp-16]
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.lea rdi, [rbp-32]
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call Point.equals
    x86.test eax, eax
    x86.je equatable.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

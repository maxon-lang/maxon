    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-32]
    x86.mov [edi+8], r8
    x86.mov r9, 1
    x86.mov eax, 99
    x86.mov ecx, 16
    x86.mov [rbp-40], eax
    x86.mov [rbp-48], r9
    x86.call maxon_alloc
    x86.mov [rbp-16], eax

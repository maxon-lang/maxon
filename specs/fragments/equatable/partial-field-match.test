// Test: partial-field-match

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 99}
  if a.equals(b) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov esi, [eax+8]
    x86.mov eax, [rbp-16]
    x86.mov edi, [eax+0]
    x86.cmp ebx, edi
    x86.sete eax
    x86.movzx eax, eaxb
    x86.mov ebx, [rbp-16]
    x86.mov edi, [ebx+8]
    x86.cmp esi, edi
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.and eax, ebx
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.lea rdi, [rbp-16]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov [rbp-24], ebx
    x86.mov esi, [rbp-24]
    x86.mov edi, 1
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov r9, 2
    x86.mov [r8+8], r9
    x86.mov eax, 1
    x86.mov ecx, 99
    x86.lea rdi, [rbp-40]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rax, [rbp-40]
    x86.mov rcx, rax
    x86.mov [rbp-48], ecx
    x86.mov eax, [rbp-48]
    x86.mov ecx, 1
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-48]
    x86.mov ecx, 99
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-48]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, [rbp-48]
    x86.call Point.equals
    x86.test eax, eax
    x86.je equatable.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: basic-equal
type Point is Equatable
  export var x int
  export var y int

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns int
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 2}
  if a.equals(b) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---

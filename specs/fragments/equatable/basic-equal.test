    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-32], ebx
    x86.mov esi, 1
    x86.mov edi, 2
    x86.mov [rbp-40], esi
    x86.mov [rbp-48], edi
    x86.mov r8, [rbp-40]
    x86.mov [rbp-56], r8
    x86.mov r9, [rbp-48]
    x86.mov [rbp-64], r9
    x86.mov eax, [rbp-32]
    x86.mov [rbp-72], eax

  entry:
    x86.prologue stack_size=16
    x86.mov rax, 1
    x86.mov rcx, 2
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], rax
    x86.mov rdx, [rbp-8]
    x86.mov rbx, 1
    x86.mov [rdx+0], rbx
    x86.mov rsi, [rbp-8]
    x86.mov rdi, 2
    x86.mov [rsi+8], rdi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, 1
    x86.mov rax, 2
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], rax
    x86.mov rax, [rbp-16]
    x86.mov rcx, 1
    x86.mov [rax+0], rcx
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.mov [rax+8], rcx
    x86.mov rax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rcx, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.call Point.equals
    x86.test rax, rax
    x86.je equatable.main.check_0.after
  check_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rcx, [rbp-16]
    x86.test rcx, rcx
    x86.jz __nonnull_skip_1
    x86.call mm_decref
    x86.label __nonnull_skip_1

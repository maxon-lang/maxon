// Test: basic-equal

typealias Integer = int(i64.min to i64.max)

type Point implements Equatable
  export var x Integer
  export var y Integer

  function equals(other Point) returns bool
    return x == other.x and y == other.y
  end 'equals'
end 'Point'

function main() returns ExitCode
  var a = Point{x: 1, y: 2}
  var b = Point{x: 1, y: 2}
  if a.equals(b) 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Point.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rdx
    x86.mov rax, [rbp-8]

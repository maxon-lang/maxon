    x86.mov rax, [rbp-8]
    x86.mov rsi, [rax+8]
    x86.mov rax, [rbp-16]
    x86.mov rdi, [rax+0]
    x86.cmp rbx, rdi
    x86.sete rax
    x86.movzx rax, raxb
    x86.mov rbx, [rbp-16]
    x86.mov rdi, [rbx+8]
    x86.cmp rsi, rdi
    x86.sete rbx
    x86.movzx rbx, rbxb
    x86.and rax, rbx
    x86.epilogue
    x86.ret
  }

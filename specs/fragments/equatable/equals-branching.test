// Test: equals-branching

typealias Integer = int(i64.min to i64.max)

type Token implements Equatable
  export var id Integer

  function equals(other Token) returns bool
    return id == other.id
  end 'equals'
end 'Token'

function main() returns ExitCode
  var a = Token{id: 10}
  var b = Token{id: 10}
  var c = Token{id: 20}
  var result = 0
  if a.equals(b) 'first'
    result = result + 1
  end 'first'
  if a.equals(c) 'second'
    result = result + 10
  end 'second'
  if b.equals(c) 'third'
    result = result + 100
  end 'third'
  return result
end 'main'
---
ExitCode: 1

    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-24], edx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [rbp-24]
    x86.cmp ecx, eax
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }

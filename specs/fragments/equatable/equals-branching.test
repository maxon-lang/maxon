// Test: equals-branching
type Token is Equatable
  export var id int

  function equals(other Token) returns bool
    return id == other.id
  end 'equals'
end 'Token'

function main() returns int
  var a = Token{id: 10}
  var b = Token{id: 10}
  var c = Token{id: 20}
  var result = 0
  if a.equals(b) 'first'
    result = result + 1
  end 'first'
  if a.equals(c) 'second'
    result = result + 10
  end 'second'
  if b.equals(c) 'third'
    result = result + 100
  end 'third'
  return result
end 'main'
---
ExitCode: 1
---

    x86.mov esi, 20
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-40]
    x86.mov [rbp-48], edi
    x86.xor r8, r8
    x86.mov [rbp-56], r8
    x86.mov r9, [rbp-16]
    x86.mov [rbp-64], r9
    x86.lea rax, [rbp-64]
    x86.mov ecx, [rbp-32]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Token.equals
    x86.mov ecx, [rbp-64]
    x86.mov [rbp-16], ecx

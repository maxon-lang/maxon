// Test: equals-branching

typealias Integer = i64

type Token implements Equatable
  export var id Integer

  function equals(other Token) returns bool
    return id == other.id
  end 'equals'
end 'Token'

function main() returns ExitCode
  var a = Token{id: 10}
  var b = Token{id: 10}
  var c = Token{id: 20}
  var result = 0
  if a.equals(b) 'first'
    result = result + 1
  end 'first'
  if a.equals(c) 'second'
    result = result + 10
  end 'second'
  if b.equals(c) 'third'
    result = result + 100
  end 'third'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @Token.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov esi, [eax+0]
    x86.cmp ebx, esi
    x86.sete eax
    x86.movzx eax, eaxb
    x86.epilogue
    x86.ret
  }
  func @equatable.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 10
    x86.mov [r8+0], r9
    x86.mov eax, 20
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, 20
    x86.mov [eax+0], ecx
    x86.xor eax, eax
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Token.equals
    x86.test eax, eax
    x86.je equatable.main.first_0.merge
  first_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-32]
    x86.add ecx, eax
    x86.mov [rbp-32], ecx
    x86.jmp equatable.main.first_0.merge
  first_0.merge:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Token.equals
    x86.test eax, eax
    x86.je equatable.main.second_1.merge
  second_1:
    x86.mov eax, 10
    x86.mov ecx, [rbp-32]
    x86.add ecx, eax
    x86.mov [rbp-32], ecx
    x86.jmp equatable.main.second_1.merge
  second_1.merge:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Token.equals
    x86.test eax, eax
    x86.je equatable.main.third_2.merge
  third_2:
    x86.mov eax, 100
    x86.mov ecx, [rbp-32]

// Test: bool-type.doc-example-1.1
function isPositive(x int) returns bool
    if x > 0 'check'
        return true
    end 'check'
    return false
end 'isPositive'

function main() returns int
    if isPositive(5) 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
ExitCode: 1
---
function isPositive() -> i64 {
entry_0:
    %x = param i64 0
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.gt i64 %x %tmp_const
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_call = call i64 @isPositive(%tmp_const)
    br.cond %tmp_call @then$test_1 @end$test_2
then$test_1:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end$test_2:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}


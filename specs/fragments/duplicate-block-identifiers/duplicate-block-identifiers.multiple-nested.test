// Test: duplicate-block-identifiers.multiple-nested
function main() returns int
    var x = 0
    if true 'outer'
        x = 1
        while true 'inner'
            x = 2
            break
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 2
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.epilogue
    x86.ret
}
---

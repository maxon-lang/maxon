// Test: docs-example-1
function main() returns int
    var x = 0
    if true 'outer'
        x = 1
    end 'outer'

    if true 'inner'
        x = 2
    end 'inner'

    return x
end 'main'

---
ExitCode: 2
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.epilogue
    x86.ret
}
---

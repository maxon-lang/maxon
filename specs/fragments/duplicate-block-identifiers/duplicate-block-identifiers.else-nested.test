// Test: duplicate-block-identifiers.else-nested
function main() returns ExitCode
  var x = 0
  if false 'check'
    x = 1
  end 'check' else 'else_check'
    if true 'nested'
      x = 2
    end 'nested'
  end 'else_check'
  return x
end 'main'
---
ExitCode: 2
---
module {
  func @duplicate-block-identifiers.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.test edx, edx
    x86.je duplicate-block-identifiers.main.else_check_1
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov ecx, 1
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-24]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.jmp duplicate-block-identifiers.main.check_0.merge
  else_check_1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 1
    x86.test ecx, ecx
    x86.je duplicate-block-identifiers.main.nested_2.merge
  nested_2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov ecx, 2
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-40]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.jmp duplicate-block-identifiers.main.nested_2.merge
  nested_2.merge:
    x86.mov rcx, [rbp-32]
    x86.call mm_scope_exit
    x86.jmp duplicate-block-identifiers.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je duplicate-block-identifiers.main.__range_ok_3
  __range_panic_3:
    x86.lea_symdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_3:
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-56], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-56]
    x86.epilogue
    x86.ret
  }
}

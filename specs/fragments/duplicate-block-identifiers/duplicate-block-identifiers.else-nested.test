// Test: duplicate-block-identifiers.else-nested
function main() returns int
    var x = 0
    if false 'check'
        x = 1
    end 'check' else 'else_check'
        if true 'nested'
            x = 2
        end 'nested'
    end 'else_check'
    return x
end 'main'
---
ExitCode: 2
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.jmp merge
  ^merge(%7: i64):
    x86.epilogue
    x86.ret
}
---

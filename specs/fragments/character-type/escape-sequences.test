// Test: escape-sequences
function main() returns int
  var newline = '\n'
  var tab = '\t'
  var backslash = '\\'
  var quote = '\''
  print("{newline.bytes().count()}\n")
  print("{tab.bytes().count()}\n")
  print("{backslash.bytes().count()}\n")
  print("{quote.bytes().count()}\n")
  return 0
end 'main'

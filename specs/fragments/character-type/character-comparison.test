// Test: character-comparison
function main() returns int
  var a = 'A'
  var b = 'B'
  if a < b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @character-type.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.lea_rdata rax, [__chr_0]
    x86.mov rcx, rax
    x86.mov edx, 1
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.lea_rdata rdi, [__chr_1]
    x86.mov r8, rdi
    x86.mov r9, 1
    x86.xor eax, eax
    x86.mov edi, 1
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.lea rcx, [rbp-32]
    x86.mov [rbp-40], edi
    x86.mov [rbp-48], eax
    x86.mov [rbp-56], r9
    x86.mov [rbp-64], r8
    x86.lea rax, [rbp-64]
    x86.mov rdx, rax
    x86.call stdlib.Character.compare
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jge character-type.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

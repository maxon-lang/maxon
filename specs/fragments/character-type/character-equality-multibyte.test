    x86.mov ecx, [rbp-8]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [edx+0], ecx
    x86.mov [rbp-24], eax
    x86.lea_rdata rax, [__chr_1]
    x86.mov rcx, rax
    x86.mov eax, 2
    x86.mov edx, 32
    x86.mov [rbp-64], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-64]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-32]
    x86.mov ecx, 2
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-32]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-32]

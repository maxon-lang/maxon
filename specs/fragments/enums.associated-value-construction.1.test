// Test: enums.associated-value-construction.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = Container.value(42)
    var e = Container.empty
    // Construction works - verify by checking tags are different
    if c != e 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 16
    %tmp_heap = heap.alloc ptr %tmp_const tag="enum storage"
    %tmp_const.1 = const.i64 i64 1
    store %tmp_heap %tmp_const.1
    %tmp_const.2 = const.i64 i64 42
    %tmp_fieldptr = getfieldptr ptr %tmp_heap 8
    store %tmp_fieldptr %tmp_const.2
    %tmp_const.3 = const.i64 i64 16
    %tmp_heap.1 = heap.alloc ptr %tmp_const.3 tag="enum storage"
    %tmp_const.4 = const.i64 i64 0
    store %tmp_heap.1 %tmp_const.4
    %tmp_icmp = icmp.ne i64 %tmp_heap %tmp_heap.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.5 = const.i64 i64 1
    ret %tmp_const.5
end$check_2:
    %tmp_const.6 = const.i64 i64 0
    ret %tmp_const.6
}


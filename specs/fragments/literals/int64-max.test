// Test: int64-max
// Test INT64_MAX (9223372036854775807)
function main() returns int
    var x = 9223372036854775807
    if x > 0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 9223372036854775807
    x86.mov rcx, 0
    x86.cmp rax, rcx
    x86.setg rcx
    x86.test rcx, rcx
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}

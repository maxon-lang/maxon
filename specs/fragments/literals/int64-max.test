// Test: int64-max
// Test INT64_MAX (9223372036854775807)
function main() returns int
  var x = 9223372036854775807
  if x > 0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 9223372036854775807
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jle literals.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

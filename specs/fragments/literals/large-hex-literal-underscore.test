// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns int
    var x = 0x0000_0001_4000_0000
    if x == 5368709120 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns int
  var x = 0x0000_0001_4000_0000
  if x == 5368709120 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5368709120
    x86.mov [rbp-8], eax
    x86.mov rcx, 5368709120
    x86.cmp eax, ecx
    x86.jne literals.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

// Test: boolean
function main() returns int
  var flag = true
  if flag 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je literals.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

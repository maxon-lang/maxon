// Test: underscore-separator
function main() returns int
  var x = 1_000
  return x - 990
end 'main'
---
ExitCode: 10
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1000
    x86.mov [rbp-8], eax
    x86.mov ecx, 990
    x86.sub eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

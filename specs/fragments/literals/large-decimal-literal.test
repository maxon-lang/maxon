// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
  var x = 5368709120
  if x == 0x140000000 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @literals.main() -> u32 {
  entry:
    x86.mov rax, 5368709120
    x86.mov rcx, 5368709120
    x86.cmp rax, rcx
    x86.jne literals.main.check_0.after
  check_0:
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 1
    x86.ret
  }
}
---

// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns int
    var x = 5368709120
    if x == 0x140000000 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5368709120
    x86.mov rcx, 5368709120
    x86.cmp rax, rcx
    x86.sete rcx
    x86.test rcx, rcx
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}
---

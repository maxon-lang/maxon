// Test: scientific-notation-uppercase
function main() returns int
    var x = 1.0E3
    return trunc(x) - 990
end 'main'
---
ExitCode: 10
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 4652007308841189376
    x86.movq xmm0, rax
    x86.cvttsd2si rax, xmm0
    x86.mov rcx, 990
    x86.mov rdx, rax
    x86.sub rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

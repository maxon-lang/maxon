// Test: scientific-notation-uppercase
function main() returns int
  var x = 1.0E3
  return trunc(x) - 990
end 'main'
---
ExitCode: 10
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_1000]
    x86.cvttsd2si eax, xmm0
    x86.mov ecx, 990
    x86.sub eax, ecx
    x86.ret
  }
}
---

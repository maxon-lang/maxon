// Test: scientific-notation-explicit-positive
function main() returns int
  var x = 2.5e+02
  return trunc(x) - 240
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_250]
    x86.cvttsd2si eax, xmm0
    x86.mov ecx, 240
    x86.sub eax, ecx
    x86.ret
  }
}

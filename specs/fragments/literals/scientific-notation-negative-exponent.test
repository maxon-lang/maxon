// Test: scientific-notation-negative-exponent
function main() returns int
  var x = 5.0e-1
  return trunc(x * 20.0)
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0.5]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rip+__float_20]
    x86.movsd xmm2, xmm0
    x86.mulsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.epilogue
    x86.ret
  }
}
---

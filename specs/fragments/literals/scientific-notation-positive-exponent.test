  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_150]
    x86.cvttsd2si eax, xmm0
    x86.mov ecx, 140
    x86.sub eax, ecx
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je literals.main.__range_ok_0
  __range_panic_0:

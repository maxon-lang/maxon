// Test: scientific-notation-positive-exponent
function main() returns int
  var x = 1.5e2
  return trunc(x) - 140
end 'main'
---
ExitCode: 10
---
module {
  func @literals.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_150]
    x86.cvttsd2si eax, xmm0
    x86.mov ecx, 140
    x86.sub eax, ecx
    x86.ret
  }
}

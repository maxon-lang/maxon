// Test: large-hex-literal
// Test hex literal above 32-bit range (0x140000000 = 5368709120)
function main() returns int
  var x = 0x0000000140000000
  // Verify the value wasn't truncated to 32-bit (which would give 0x40000000 = 1073741824)
  if x == 5368709120 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 5368709120
    x86.mov [rbp-8], eax
    x86.mov rcx, 5368709120
    x86.cmp eax, ecx
    x86.jne main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

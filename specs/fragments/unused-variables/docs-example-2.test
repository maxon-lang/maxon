// Test: docs-example-2
typealias Integer = int(i64.min to i64.max)

function sideEffect() returns Integer
  print("hello\n")
  return 42
end 'sideEffect'

function main() returns ExitCode
  let _ = sideEffect()  // OK: underscore discards return value
  return 0
end 'main'

---
ExitCode: 0
---
module {
  func @unused-variables.sideEffect() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.lea_rdata rcx, [__str_1]
    x86.mov rdx, rcx
    x86.mov ebx, 6
    x86.mov esi, 16
    x86.xor edi, edi
    x86.mov [rbp-32], edx
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, 32
    x86.xor r9, r9
    x86.mov rcx, r8
    x86.mov rdx, rax
    x86.mov r8, r9
    x86.call mm_alloc_in
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-32]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, 6
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov rcx, [rbp-16]
    x86.call stdlib.Print.print
    x86.mov eax, 42
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
  func @unused-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call unused-variables.sideEffect
    x86.xor ecx, ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

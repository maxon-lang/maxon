// Test: used-in-nested-scope

function main() returns ExitCode
  var x = 42
  if x > 0 'check'
    return x
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @unused-variables.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 42
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.jle unused-variables.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-32], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je unused-variables.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]
    x86.mov [rbp-40], eax
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: int-pair-field-write
typealias IntPair = Pair with (int, int)

function main() returns int
  var p = IntPair{key: 0, value: 0}
  p.key = 20
  p.value = 22
  return p.key + p.value
end 'main'
---
ExitCode: 42
---
module {
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.mov edx, 16
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov [edi+8], r8
    x86.mov r9, 20
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], r9
    x86.mov eax, 22
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+8]
    x86.lea eax, [ecx + edx]
    x86.epilogue
    x86.ret
  }
}
---

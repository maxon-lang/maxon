// Test: int-pair-field-write
typealias IntPair = Pair with (int, int)

function main() returns int
  var p = IntPair{key: 0, value: 0}
  p.key = 20
  p.value = 22
  return p.key + p.value
end 'main'
---
ExitCode: 42
---
module {
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 20
    x86.mov [rbp-8], eax
    x86.mov ecx, 22
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
}
---

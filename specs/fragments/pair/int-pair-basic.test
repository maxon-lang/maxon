// Test: int-pair-basic
typealias IntPair = Pair with (int, int)

function main() returns int
  var p = IntPair{key: 10, value: 32}
  return p.key + p.value
end 'main'
---
ExitCode: 42
---
module {
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-32]
    x86.mov edi, [rbp-24]
    x86.lea eax, [esi + edi]
    x86.epilogue
    x86.ret
  }
}
---

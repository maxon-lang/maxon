// Test: int-pair-basic
typealias IntPair = Pair with (int, int)

function main() returns int
  var p = IntPair{key: 10, value: 32}
  return p.key + p.value
end 'main'
---
ExitCode: 42
---
module {
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, [r9+0]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+8]
    x86.add eax, edx
    x86.epilogue
    x86.ret
  }
}
---

// Test: mixed-type-pair
typealias MixedPair is Pair with (int, float)

function main() returns int
  var p = MixedPair{key: 40, value: 2.5}
  return p.key + trunc(p.value)
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 40
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov [rbp-8], eax
    x86.movsd [rbp-16], xmm0
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-24], ecx
    x86.movsd xmm1, [rbp-16]
    x86.movsd [rbp-32], xmm1
    x86.mov edx, [rbp-24]
    x86.movsd xmm2, [rbp-32]
    x86.cvttsd2si ebx, xmm2
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
}
---

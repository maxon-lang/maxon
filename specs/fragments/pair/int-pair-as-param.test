// Test: int-pair-as-param
typealias IntPair = Pair with (int, int)

function sum(p IntPair) returns int
  return p.key + p.value
end 'sum'

function main() returns int
  var p = IntPair{key: 10, value: 32}
  return sum(p)
end 'main'
---
ExitCode: 42
---
module {
  func @pair.sum(p: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp pair.sum
  }
}
---

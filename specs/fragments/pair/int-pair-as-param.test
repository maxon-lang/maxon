// Test: int-pair-as-param
typealias IntPair = Pair with (int, int)

function sum(p IntPair) returns int
  return p.key + p.value
end 'sum'

function main() returns int
  var p = IntPair{key: 10, value: 32}
  return sum(p)
end 'main'
---
ExitCode: 42
---
module {
  func @pair.sum(p: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, [ecx+8]
    x86.mov [rbp-8], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.lea eax, [ecx + edx]
    x86.epilogue
    x86.ret
  }
  func @pair.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-24]
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-32]
    x86.mov [rbp-48], edi
    x86.lea r8, [rbp-48]
    x86.mov rcx, r8
    x86.call pair.sum
    x86.epilogue
    x86.ret
  }
}
---

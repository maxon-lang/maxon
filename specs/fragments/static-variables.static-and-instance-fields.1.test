// Test: static-variables.static-and-instance-fields.1
type Thing
    static var created = 0
    export var id int

    static function make(n int) returns Thing
        Thing.created = Thing.created + 1
        return {id: n}
    end 'make'
end 'Thing'

function main() returns int
    var a = Thing.make(10)
    var b = Thing.make(20)
    return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_globaladdr = global.addr ptr @global.Thing.created elemsize=8
    store %tmp_globaladdr %tmp_const
    %a = alloca.sized ptr 16
    %tmp_const.1 = const.i64 i64 10
    %tmp_call = call ptr @Thing$make(%a, %tmp_const.1)
    %b = alloca.sized ptr 16
    %tmp_const.2 = const.i64 i64 20
    %tmp_call.1 = call ptr @Thing$make(%b, %tmp_const.2)
    %tmp_globaladdr.1 = global.addr ptr @global.Thing.created elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.1
    %tmp_fieldptr = getfieldptr ptr %a 8
    %tmp_load.1 = load i64 %tmp_fieldptr
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %b 8
    %tmp_load.2 = load i64 %tmp_fieldptr.1
    %tmp_add.1 = add i64 %tmp_add %tmp_load.2
    ret %tmp_add.1
}

function Thing$make() -> ptr {
entry_0:
    %tmp_param = param ptr 0
    %n = param i64 1
    %tmp_globaladdr = global.addr ptr @global.Thing.created elemsize=8
    %tmp_load = load i64 %tmp_globaladdr
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    %tmp_globaladdr.1 = global.addr ptr @global.Thing.created elemsize=8
    store %tmp_globaladdr.1 %tmp_add
    memset %tmp_param 0 16
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %n
    %tmp_fieldptr.1 = getfieldptr ptr %tmp_param 0
    %tmp_const.1 = const.i64 i64 0
    store %tmp_fieldptr.1 %tmp_const.1
    ret %tmp_param
}

---

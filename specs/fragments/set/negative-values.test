// Test: negative-values
function main() returns int
  var s = Set from [0 - 5, 0 - 3, 0 - 1, 0, 1, 3, 5]
  if s.contains(0 - 3) 'check'
    return s.count()
  end 'check'
  return 0 - 1
end 'main'

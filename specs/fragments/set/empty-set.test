    x86.mov esi, 8
    x86.xor edi, edi
    x86.xor r8, r8
    x86.xor r9, r9
    x86.mov [rbp-112], eax
    x86.xor eax, eax
    x86.mov [rbp-120], ecx
    x86.mov ecx, 8
    x86.mov [rbp-128], edx
    x86.xor edx, edx
    x86.mov [rbp-136], ebx
    x86.xor ebx, ebx
    x86.mov [rbp-144], esi
    x86.xor esi, esi
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.mov [rbp-48], r9
    x86.mov [rbp-56], r8
    x86.mov [rbp-64], edi
    x86.mov eax, [rbp-144]
    x86.mov [rbp-72], eax
    x86.mov eax, [rbp-136]
    x86.mov [rbp-80], eax
    x86.mov eax, [rbp-128]
    x86.mov [rbp-88], eax
    x86.mov eax, [rbp-120]
    x86.mov [rbp-96], eax
    x86.mov eax, [rbp-112]
    x86.mov [rbp-104], eax
    x86.lea rax, [rbp-104]
    x86.mov rcx, rax
    x86.call IntSet.count
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.je set.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }

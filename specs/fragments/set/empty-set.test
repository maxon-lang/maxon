// Test: empty-set
typealias Int = int(i64.min to i64.max)
typealias IntSet = Set with Int

function main() returns ExitCode
  var s = IntSet{}
  if s.count() != 0 'check'
    return 1
  end 'check'
  return 0
end 'main'

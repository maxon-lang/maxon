// Test: empty-set
typealias IntSet = Set with int

function main() returns int
  var s = IntSet{}
  if s.count() != 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @set.main() -> i64 {
  entry:
    x86.prologue stack_size=144
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx

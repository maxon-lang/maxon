// Test: remove-reinsert
function main() returns Integer
  var s = Set from [1, 2, 3]
  s.remove(2)
  s.insert(2)
  if s.contains(2) 'check'
    return s.count()
  end 'check'
  return 0 - 1
end 'main'
---
ExitCode: 3

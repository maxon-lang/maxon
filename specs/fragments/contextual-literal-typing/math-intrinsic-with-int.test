// Test: math-intrinsic-with-int
function main() returns int
  var x = 16
  var result = sqrt(x)
  return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @contextual-literal-typing.main() -> i64 {
  entry:
    x86.mov eax, 16
    x86.cvtsi2sd xmm0, eax
    x86.sqrtsd xmm1, xmm0
    x86.cvttsd2si ecx, xmm1
    x86.mov eax, ecx
    x86.ret
  }
}
---

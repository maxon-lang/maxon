// Test: docs-example-3
typealias Decimal = float(f64.min to f64.max)

function main() returns ExitCode
  var x = 5
  var y = 5.0
  if (x as Decimal) == y 'check'
    return 1
  end 'check'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @contextual-literal-typing.main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.movsd xmm0, [rip+__float_5]
    x86.cvtsi2sd xmm1, rax
    x86.ucomisd xmm1, xmm0
    x86.jne contextual-literal-typing.main.check_0.after
    x86.jp contextual-literal-typing.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

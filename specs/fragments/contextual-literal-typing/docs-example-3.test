// Test: docs-example-3
function main() returns int
  var x = 5
  var y = 5.0
  if (x as float) == y 'check'
    return 1
  end 'check'
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.movsd xmm0, [rip+__float_5]
    x86.cvtsi2sd xmm1, eax
    x86.ucomisd xmm1, xmm0
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

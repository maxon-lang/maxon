// Test: int-literal-vs-byte-valid

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
  var b = 42 as Byte
  if b == 42 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @contextual-literal-typing.main() -> u32 {
  entry:
    x86.mov eax, 42
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 42
    x86.cmp eax, edx
    x86.jne contextual-literal-typing.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

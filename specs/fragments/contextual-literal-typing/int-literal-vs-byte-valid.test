// Test: int-literal-vs-byte-valid
function main() returns int
  var b = 42 as byte
  if b == 42 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @contextual-literal-typing.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov [rbp-8], eax
    x86.mov edx, 42
    x86.cmp eax, edx
    x86.jne contextual-literal-typing.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

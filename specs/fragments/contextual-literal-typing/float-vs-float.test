// Test: float-vs-float
function main() returns int
  var a = 3.14
  var b = 3.14
  if a == b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rip+__float_3.14]
    x86.movsd [rbp-16], xmm1
    x86.ucomisd xmm0, xmm1
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

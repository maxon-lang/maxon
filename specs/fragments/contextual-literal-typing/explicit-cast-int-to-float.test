// Test: explicit-cast-int-to-float
function main() returns int
    var x = 5
    var y = 5.0
    if (x as float) == y 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.mov rcx, 4617315517961601024
    x86.movq xmm0, rcx
    x86.cvtsi2sd xmm1, rax
    x86.comisd xmm1, xmm0
    x86.sete rax
    x86.movzx rax, rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

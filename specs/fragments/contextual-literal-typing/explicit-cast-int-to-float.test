// Test: explicit-cast-int-to-float
function main() returns Integer
  var x = 5
  var y = 5.0
  if (x as Float) == y 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @contextual-literal-typing.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.movsd xmm0, [rip+__float_5]
    x86.cvtsi2sd xmm1, eax
    x86.ucomisd xmm1, xmm0
    x86.jne contextual-literal-typing.main.check_0.after
    x86.jp contextual-literal-typing.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: explicit-cast-float-to-int
function main() returns int
  var x = 5
  var y = 5.0
  if x == trunc(y) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_5]
    x86.movsd [rbp-16], xmm0
    x86.cvttsd2si ecx, xmm0
    x86.cmp eax, ecx
    x86.jne main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: explicit-cast-float-to-int
function main() returns int
    var x = 5
    var y = 5.0
    if x == trunc(y) 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}
---

// Test: explicit-cast-float-to-int
function main() returns ExitCode
  var x = 5
  var y = 5.0
  if x == trunc(y) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @contextual-literal-typing.main() -> u32 {
  entry:
    x86.mov eax, 5
    x86.movsd xmm0, [rip+__float_5]
    x86.cvttsd2si ecx, xmm0
    x86.cmp eax, ecx
    x86.jne contextual-literal-typing.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

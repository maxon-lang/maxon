// Test: float.compare.positive-negative-zero
function main() returns ExitCode
  var pos = 0.0
  var neg = 0.0 - 0.0
  var result = pos.compare(neg)
  if result == Ordering.equalTo 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd xmm2, [rip+__float_0]
    x86.movsd xmm3, xmm1
    x86.subsd xmm3, xmm2
    x86.movsd xmm1, xmm3
    x86.call stdlib.float.compare
    x86.mov [rbp-8], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne primitive-comparable.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

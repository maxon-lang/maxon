// Test: bool.compare.equal
function main() returns int
  var a = true
  var b = true
  return a.compare(b)
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.cmp eax, ecx
    x86.setg ebx
    x86.movzx ebx, ebxb
    x86.sub ebx, edx
    x86.mov eax, ebx
    x86.ret
  }
}

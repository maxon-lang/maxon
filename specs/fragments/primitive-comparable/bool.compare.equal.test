// Test: bool.compare.equal
function main() returns ExitCode
  var a = true
  var b = true
  var result = a.compare(b)
  match result 'check'
    Ordering.lessThan then return 1
    Ordering.equalTo then return 0
    Ordering.greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call stdlib.bool.compare
    x86.mov [rbp-8], eax
    x86.jmp primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.cmp2
  check_0.case1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.merge
  check_0.case2:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

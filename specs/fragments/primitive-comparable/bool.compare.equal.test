// Test: bool.compare.equal
function main() returns ExitCode
  var a = true
  var b = true
  var result = a.compare(b)
  if result == Ordering.equalTo 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call stdlib.bool.compare
    x86.mov [rbp-8], eax
    x86.mov edx, 1
    x86.mov ebx, [rbp-8]
    x86.cmp ebx, edx
    x86.jne primitive-comparable.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

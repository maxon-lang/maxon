// Test: bool.compare.equal
function main() returns Integer
  var a = true
  var b = true
  return a.compare(b)
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp stdlib.bool.compare
  }
}

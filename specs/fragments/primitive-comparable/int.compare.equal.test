// Test: int.compare.equal
function main() returns Integer
  var a = 42
  var b = 42
  return a.compare(b)
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.mov ecx, 42
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp stdlib.int.compare
  }
}

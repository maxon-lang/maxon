// Test: byte.compare.less
function main() returns Integer
  var a = 10 as Byte
  var b = 20 as Byte
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 20
    x86.mov ebx, 255
    x86.and edx, ebx
    x86.mov rcx, rax
    x86.jmp stdlib.byte.compare
  }
}
---

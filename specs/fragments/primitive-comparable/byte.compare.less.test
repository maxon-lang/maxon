// Test: byte.compare.less
function main() returns ExitCode
  var a = 10 as Byte
  var b = 20 as Byte
  var result = a.compare(b)
  if result == Ordering.lessThan 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 20
    x86.mov ebx, 255
    x86.and edx, ebx
    x86.mov rcx, rax
    x86.call stdlib.byte.compare
    x86.mov [rbp-8], eax
    x86.xor esi, esi
    x86.mov edi, [rbp-8]
    x86.cmp edi, esi
    x86.jne primitive-comparable.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

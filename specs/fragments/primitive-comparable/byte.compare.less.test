// Test: byte.compare.less
function main() returns int
  var a = 10 as byte
  var b = 20 as byte
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 20
    x86.mov ebx, 255
    x86.and edx, ebx
    x86.cmp eax, edx
    x86.setl esi
    x86.movzx esi, esib
    x86.cmp eax, edx
    x86.setg edi
    x86.movzx edi, edib
    x86.sub edi, esi
    x86.mov eax, edi
    x86.ret
  }
}
---

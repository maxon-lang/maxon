// Test: float.compare.less
function main() returns Integer
  var a = 1.5
  var b = 2.5
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_1.5]
    x86.movsd xmm1, [rip+__float_2.5]
    x86.jmp stdlib.float.compare
  }
}
---

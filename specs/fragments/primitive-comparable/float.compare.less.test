// Test: float.compare.less
function main() returns int
  var a = 1.5
  var b = 2.5
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_1.5]
    x86.movsd xmm1, [rip+__float_2.5]
    x86.ucomisd xmm0, xmm1
    x86.setb eax
    x86.movzx eax, eaxb
    x86.ucomisd xmm0, xmm1
    x86.seta ecx
    x86.movzx ecx, ecxb
    x86.sub ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
}
---

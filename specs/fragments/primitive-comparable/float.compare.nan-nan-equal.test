// Test: float.compare.nan-nan-equal
function main() returns ExitCode
  var a = 0.0 / 0.0
  var b = 0.0 / 0.0
  var result = a.compare(b)
  match result 'check'
    Ordering.lessThan then return 1
    Ordering.equalTo then return 0
    Ordering.greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.movsd xmm3, [rip+__float_0]
    x86.movsd xmm4, [rip+__float_0]
    x86.movsd xmm5, xmm3
    x86.divsd xmm5, xmm4
    x86.movsd xmm0, xmm2
    x86.movsd xmm1, xmm5
    x86.call stdlib.float.compare
    x86.mov [rbp-16], eax
    x86.jmp primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.cmp1
  check_0.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.cmp2
  check_0.case1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-32]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne primitive-comparable.main.check_0.merge
  check_0.case2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-40]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}

// Test: int.compare.greater
function main() returns int
  var a = 20
  var b = 10
  return a.compare(b)
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 10
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp stdlib.int.compare
  }
}
---

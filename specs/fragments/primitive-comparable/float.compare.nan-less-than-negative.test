// Test: float.compare.nan-less-than-negative
function main() returns ExitCode
  var nan = 0.0 / 0.0
  var x = 0.0 - 999999.0
  var result = nan.compare(x)
  match result 'check'
    Ordering.lessThan then return 0
    Ordering.equalTo then return 1
    Ordering.greaterThan then return 1
  end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-comparable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.movsd xmm3, [rip+__float_0]
    x86.movsd xmm4, [rip+__float_999999]
    x86.movsd xmm5, xmm3
    x86.subsd xmm5, xmm4
    x86.movsd xmm0, xmm2
    x86.movsd xmm1, xmm5
    x86.call stdlib.float.compare
    x86.mov [rbp-8], rax
    x86.jmp primitive-comparable.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp1
  check_0.case0:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.cmp2
  check_0.case1:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne primitive-comparable.main.check_0.merge
  check_0.case2:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

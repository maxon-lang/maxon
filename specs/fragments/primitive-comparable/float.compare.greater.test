// Test: float.compare.greater
function main() returns int
  var a = 3.14
  var b = 2.71
  return a.compare(b)
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movsd xmm1, [rip+__float_2.71]
    x86.jmp stdlib.float.compare
  }
}
---

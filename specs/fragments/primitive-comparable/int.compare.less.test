// Test: int.compare.less
function main() returns int
  var a = 10
  var b = 20
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp stdlib.int.compare
  }
}

// Test: int.compare.less
function main() returns int
  var a = 10
  var b = 20
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.cmp eax, ecx
    x86.setg ebx
    x86.movzx ebx, ebxb
    x86.sub ebx, edx
    x86.mov eax, ebx
    x86.ret
  }
}
---

// Test: bool.compare.false-true
function main() returns int
  var a = false
  var b = true
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.cmp eax, ecx
    x86.setg ebx
    x86.movzx ebx, ebxb
    x86.sub ebx, edx
    x86.mov eax, ebx
    x86.ret
  }
}
---

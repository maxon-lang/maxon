// Test: bool.compare.false-true
function main() returns Integer
  var a = false
  var b = true
  return a.compare(b)
end 'main'
---
ExitCode: -1
---
module {
  func @primitive-comparable.main() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp stdlib.bool.compare
  }
}
---

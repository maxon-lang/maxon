// Test: ownership.if-else-then-terminates.1
type Position
    export var x int
    export var y int
end 'Position'

function test(take_first bool) returns int
    var pos = Position{x: 10, y: 20}

    if take_first 'branch'
        var temp = pos  // Move pos
        return temp.x
    end 'branch' else 'other'
        // pos should still be owned here since then returned
        return pos.y
    end 'other'
end 'test'

function main() returns int
    return test(false)
end 'main'
---
ExitCode: 20
---
function test() -> i64 {
entry_0:
    %take_first = param i64 0
    %pos = alloca.sized ptr 16
    memset %pos 0 16
    %tmp_fieldptr = getfieldptr ptr %pos 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %pos 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    br.cond %take_first @then$branch_1 @else$branch_2
then$branch_1:
    %temp = alloca.sized ptr 16
    track.copy tag="Position"
    memcpy %temp %pos 16
    %tmp_fieldptr.2 = getfieldptr ptr %temp 0
    %tmp_load.1 = load i64 %tmp_fieldptr.2
    ret %tmp_load.1
else$branch_2:
    %tmp_fieldptr.3 = getfieldptr ptr %pos 8
    %tmp_load.3 = load i64 %tmp_fieldptr.3
    ret %tmp_load.3
end$branch_3:
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_call = call i64 @test(%tmp_const)
    ret %tmp_call
}

---

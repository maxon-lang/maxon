// Test: basic-extension-on-array

typealias Integer = int(i64.min to i64.max)

interface Countable
  function value() returns Integer
end 'Countable'

extension Countable
  function count() returns Integer
    return 42
  end 'count'
end 'Countable'

type IntList implements Countable
  var data Integer

  function value() returns Integer
    return data
  end 'value'
end 'IntList'

function main() returns ExitCode
  var list = IntList{data: 5}
  return list.count()
end 'main'
---
ExitCode: 42
---
module {
  func @IntList.count(__self_ptr: i64) -> i64 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
  func @interface-extensions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.lea rdi, [rbp-16]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-24], edx
    x86.mov esi, [rbp-24]
    x86.mov edi, 5
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov r9, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call IntList.count
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je interface-extensions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_27]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]
    x86.call mm_decref
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

// Test: basic-extension-on-array
interface Countable
  function value() returns int
end 'Countable'

extension Countable
  function count() returns int
    return 42
  end 'count'
end 'Countable'

type IntList is Countable
  var data int

  function value() returns int
    return data
  end 'value'
end 'IntList'

function main() returns int
  var list = IntList{data: 5}
  return list.count()
end 'main'
---
ExitCode: 42
---
module {
  func @IntList.count(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 42
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call IntList.count
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.epilogue
    x86.ret
  }
}
---

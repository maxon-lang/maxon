// Test: extension-returns-struct
interface Pointlike
  function getX() returns int
  function getY() returns int
end 'Pointlike'

type SimplePoint
  export var x int
  export var y int
end 'SimplePoint'

extension Pointlike
  function asSimple() returns SimplePoint
    return {x: self.getX(), y: self.getY()}
  end 'asSimple'
end 'Pointlike'

type Coord implements Pointlike
  var cx int
  var cy int

  function getX() returns int
    return cx
  end 'getX'

  function getY() returns int
    return cy
  end 'getY'
end 'Coord'

function main() returns int
  var c = Coord{cx: 10, cy: 32}
  var p = c.asSimple()
  return p.x + p.y
end 'main'
---
ExitCode: 42
---

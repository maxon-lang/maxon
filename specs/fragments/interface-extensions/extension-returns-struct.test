    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Coord.getY(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+8]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 32
    x86.mov edx, 16
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-32]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]

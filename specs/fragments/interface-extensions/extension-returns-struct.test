    x86.mov rcx, rax
    x86.call Coord.getX
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-24], eax
    x86.call Coord.getY
    x86.mov edx, 16
    x86.mov [rbp-32], eax
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov r8, [rbp-32]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-16]
    x86.mov eax, r9
    x86.epilogue
    x86.ret
  }
  func @Coord.getX(__self_ptr: i64) -> i64 {

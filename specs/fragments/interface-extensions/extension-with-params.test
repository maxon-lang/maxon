// Test: extension-with-params
interface Scalable
  function base() returns int
end 'Scalable'

extension Scalable
  function scale(factor int) returns int
    return self.base() * factor
  end 'scale'
end 'Scalable'

type Amount implements Scalable
  var amount int

  function base() returns int
    return amount
  end 'base'
end 'Amount'

function main() returns int
  var a = Amount{amount: 7}
  return a.scale(6)
end 'main'
---
ExitCode: 42
---
module {
  func @Amount.scale(__self_ptr: i64, factor: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], edx
    x86.mov rcx, rax
    x86.call Amount.base
    x86.mov ecx, [rbp-16]
    x86.imul eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Amount.base(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 7
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 7
    x86.mov [edx+0], ebx
    x86.mov esi, 6
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.mov rdx, rsi
    x86.epilogue
    x86.jmp Amount.scale
  }
}
---

// Test: extension-with-params
interface Scalable
  function base() returns int
end 'Scalable'

extension Scalable
  function scale(factor int) returns int
    return self.base() * factor
  end 'scale'
end 'Scalable'

type Amount is Scalable
  var amount int

  function base() returns int
    return amount
  end 'base'
end 'Amount'

function main() returns int
  var a = Amount{amount: 7}
  return a.scale(6)
end 'main'
---
ExitCode: 42
---
module {
  func @Amount.scale(__self_ptr: i64, factor: i64) -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.lea rax, [rbp-24]
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], edx
    x86.mov rcx, rax
    x86.call Amount.base
    x86.mov edx, [rbp-24]
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-40]
    x86.imul eax, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-16]
    x86.mov [r8+0], r9
    x86.epilogue
    x86.ret
  }
  func @Amount.base(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 7
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 6
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-24], ebx
    x86.lea rsi, [rbp-24]
    x86.mov rcx, rsi
    x86.call Amount.scale
    x86.mov edi, [rbp-24]
    x86.mov [rbp-16], edi
    x86.epilogue
    x86.ret
  }
}

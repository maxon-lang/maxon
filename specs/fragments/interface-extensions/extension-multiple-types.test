// Test: extension-multiple-types
interface Valued
  function val() returns int
end 'Valued'

extension Valued
  function valPlusTen() returns int
    return self.val() + 10
  end 'valPlusTen'
end 'Valued'

type TypeA is Valued
  var a int
  function val() returns int
    return a
  end 'val'
end 'TypeA'

type TypeB is Valued
  var b int
  function val() returns int
    return b * 2
  end 'val'
end 'TypeB'

function main() returns int
  var ta = TypeA{a: 5}
  var tb = TypeB{b: 10}
  return ta.valPlusTen() + tb.valPlusTen()
end 'main'
---
ExitCode: 45
---
module {
  func @TypeA.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], eax
    x86.lea rcx, [rbp-24]
    x86.call TypeA.val
    x86.mov edx, [rbp-24]
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, 10
    x86.add eax, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-16]
    x86.mov [r8+0], r9
    x86.epilogue
    x86.ret
  }
  func @TypeB.valPlusTen(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], eax
    x86.lea rcx, [rbp-24]
    x86.call TypeB.val
    x86.mov edx, [rbp-24]
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, 10
    x86.add eax, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-16]
    x86.mov [r8+0], r9
    x86.epilogue
    x86.ret
  }
  func @TypeA.val(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @TypeB.val(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interface-extensions.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.mov ecx, 10
    x86.mov [rbp-8], eax
    x86.lea rdx, [rbp-8]
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call TypeA.valPlusTen
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-16], ebx
    x86.lea rsi, [rbp-16]
    x86.mov [rbp-32], eax
    x86.mov rcx, rsi
    x86.call TypeB.valPlusTen
    x86.mov edi, [rbp-32]
    x86.lea eax, [edi + eax]
    x86.epilogue
    x86.ret
  }
}

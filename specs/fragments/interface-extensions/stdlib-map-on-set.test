// Test: stdlib-map-on-set
typealias IntSet = Set with int

function main() returns int
  var s = IntSet{}
  s.insert(10)
  s.insert(20)
  s.insert(30)
  var mapped = s.map((x int) gives x + 1)

  var sum = 0
  for n in mapped 'loop'
    sum = sum + n
  end 'loop'

  // 11 + 21 + 31 = 63 (order may vary but sum is same)
  return sum
end 'main'

// Test: stdlib-map-on-map
function main() returns ExitCode
  var m = ["a": 1, "b": 2, "c": 3]

  var sum = 0
  for pair in m 'loop'
    sum = sum + pair.1 * 10
  end 'loop'

  // 10 + 20 + 30 = 60
  return sum
end 'main'

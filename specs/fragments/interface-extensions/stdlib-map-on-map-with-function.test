// Test: stdlib-map-on-map-with-function
function main() returns ExitCode
  var m = ["a": 1, "b": 2, "c": 3]
  var mapped = m.map((p) gives p)

  var sum = 0
  for pair in mapped 'loop'
    sum = sum + pair.1
  end 'loop'

  // 1 + 2 + 3 = 6
  return sum
end 'main'

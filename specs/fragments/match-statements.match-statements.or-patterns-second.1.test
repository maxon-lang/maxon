// Test: match-statements.match-statements.or-patterns-second.1
function main() returns int
    var x = 2
    match x 'check'
        1 or 2 then return 10
        3 or 4 then return 20
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    br @match_check_1
match_check_1:
    %tmp_const.5 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.5
    %tmp_const.6 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_const %tmp_const.6
    %tmp_bitor = bitor i64 %tmp_icmp %tmp_icmp.1
    br.cond %tmp_bitor @match_body_2 @match_check_3
match_body_2:
    %tmp_const.7 = const.i64 i64 10
    ret %tmp_const.7
match_check_3:
    %tmp_const.8 = const.i64 i64 3
    %tmp_icmp.2 = icmp.eq i64 %tmp_const %tmp_const.8
    %tmp_const.9 = const.i64 i64 4
    %tmp_icmp.3 = icmp.eq i64 %tmp_const %tmp_const.9
    %tmp_bitor.1 = bitor i64 %tmp_icmp.2 %tmp_icmp.3
    br.cond %tmp_bitor.1 @match_body_4 @match_default_5
match_body_4:
    %tmp_const.10 = const.i64 i64 20
    ret %tmp_const.10
match_default_5:
    %tmp_const.11 = const.i64 i64 0
    ret %tmp_const.11
match_merge_6:
}

---

// Test: basic-float
function main() returns int
  var x = 3.14
  var y = 2.0
  var z = x + y
  var result = trunc(z)
  return result
end 'main'
---
ExitCode: 5
---
module {
  func @float-type.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rip+__float_2]
    x86.movsd [rbp-16], xmm1
    x86.movsd xmm2, xmm0
    x86.addsd xmm2, xmm1
    x86.movsd [rbp-24], xmm2
    x86.cvttsd2si eax, xmm2
    x86.mov [rbp-32], eax
    x86.epilogue
    x86.ret
  }
}
---

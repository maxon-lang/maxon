// Test: float-arithmetic
function main() returns int
  var a = 10.0
  var b = 3.0
  var result = a / b
  return trunc(result)
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_10]
    x86.movsd xmm1, [rip+__float_3]
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.ret
  }
}
---

// Test: docs-example-1
function circleArea(radius float) returns float
  return 3.14159 * radius * radius
end 'circleArea'

function main() returns int
  var area = circleArea(5.0)
  return trunc(area)  // Returns 78
end 'main'

---
ExitCode: 78
---
module {
  func @float-type.circleArea(radius: f64) -> f64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rip+__float_3.14159]
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm0
    x86.movsd xmm1, xmm2
    x86.mulsd xmm1, xmm0
    x86.movsd xmm0, xmm1
    x86.epilogue
    x86.ret
  }
  func @float-type.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_5]
    x86.call float-type.circleArea
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.epilogue
    x86.ret
  }
}

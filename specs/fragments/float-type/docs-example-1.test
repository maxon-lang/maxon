  ^entry(%radius: f64):
    x86.prologue stack_size=32
    x86.movsd xmm0, xmm0
    x86.mov rax, 4614256650576692846
    x86.movq xmm1, rax
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm0
    x86.movsd xmm1, xmm2
    x86.mulsd xmm1, xmm0
    x86.movsd xmm0, xmm1
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 4617315517961601024
    x86.movq xmm0, rax
    x86.movsd xmm0, xmm0
    x86.call circleArea
    x86.movsd xmm0, xmm0
    x86.cvttsd2si rax, xmm0

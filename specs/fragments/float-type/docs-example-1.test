  func @float-type.circleArea(radius: f64) -> f64 {
  entry:
    x86.movsd xmm1, [rip+__float_3.14159]
    x86.movsd xmm2, xmm1
    x86.mulsd xmm2, xmm0
    x86.movsd xmm1, xmm2
    x86.mulsd xmm1, xmm0
    x86.movsd xmm0, xmm1
    x86.ret
  }
  func @float-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_5]
    x86.call float-type.circleArea
    x86.cvttsd2si eax, xmm0
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je float-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_12]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

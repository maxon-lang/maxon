// Test: float-comparison
function main() returns int
    var x = 3.5
    var y = 2.1
    if x > y 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}
---

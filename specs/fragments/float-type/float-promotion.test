// Test: float-promotion
function main() returns int
  var x = 5
  var y = 2.0
  var result = x + y
  return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @float-type.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.movsd xmm0, [rip+__float_2]
    x86.cvtsi2sd xmm1, eax
    x86.movsd xmm2, xmm1
    x86.addsd xmm2, xmm0
    x86.cvttsd2si ecx, xmm2
    x86.mov eax, ecx
    x86.ret
  }
}
---

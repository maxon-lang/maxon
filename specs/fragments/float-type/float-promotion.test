// Test: float-promotion
function main() returns ExitCode
  var x = 5
  var y = 2.0
  var result = x + y
  return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @float-type.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.movsd xmm0, [rip+__float_2]
    x86.cvtsi2sd xmm1, eax
    x86.movsd xmm2, xmm1
    x86.addsd xmm2, xmm0
    x86.cvttsd2si ecx, xmm2
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je float-type.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

// Test: enums.float-rawvalue-in-function.1
enum Weights
    light = 1.5
    medium = 2.5
end 'Weights'

function getRaw(w Weights) returns float
    return w.rawValue
end 'getRaw'

function main() returns int
    var w = Weights.medium
    var raw = getRaw(w)
    if raw > 2.0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function getRaw() -> f64 {
entry_0:
    %w = param i64 0
    %tmp_bitcast = bitcast.i64.f64 f64 %w
    ret %tmp_bitcast
}

function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 2.5
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    %tmp_call = call f64 @getRaw(%tmp_bitcast)
    %tmp_fconst.1 = const.f64 f64 2
    %tmp_fcmp = fcmp.gt i64 %tmp_call %tmp_fconst.1
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

// Test: if-statements.simple
function main() returns ExitCode
  var x = 10
  if x > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @if-statements.main() -> u32 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.cmp eax, ecx
    x86.jle if-statements.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: if-statements.else-if-in-helper
function classify(x int) returns int
  if x == 0 'zero'
    return 0
  end 'zero' else if x < 10 'small'
    return 1
  end 'small' else if x < 100 'medium'
    return 2
  end 'medium' else 'large'
    return 3
  end 'large'
end 'classify'

function main() returns int
  var a = classify(0)
  var b = classify(5)
  var c = classify(50)
  var d = classify(200)
  return a + b * 10 + c * 100 + d * 1000
end 'main'
---
ExitCode: 3210
---
module {
  func @if-statements.classify(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.jne if-statements.classify.zero_0.elseif
  zero_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  zero_0.elseif:
    x86.mov eax, 10
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge if-statements.classify.small_1.elseif
  small_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  small_1.elseif:
    x86.mov eax, 100
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jge if-statements.classify.large_3
  medium_2:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  large_3:
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  }
  func @if-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call if-statements.classify
    x86.mov ecx, 5
    x86.mov [rbp-8], eax
    x86.call if-statements.classify
    x86.mov edx, 50
    x86.mov [rbp-16], eax
    x86.mov rcx, rdx
    x86.call if-statements.classify
    x86.mov ebx, 200
    x86.mov [rbp-24], eax
    x86.mov rcx, rbx
    x86.call if-statements.classify
    x86.mov esi, 10
    x86.mov edi, [rbp-16]
    x86.imul edi, esi
    x86.mov r8, [rbp-8]
    x86.add r8, edi
    x86.mov r9, 100
    x86.mov ecx, [rbp-24]
    x86.imul ecx, r9
    x86.add r8, ecx
    x86.mov ecx, 1000
    x86.imul eax, ecx
    x86.lea eax, [r8 + eax]
    x86.epilogue
    x86.ret
  }
}
---

// Test: if-statements.nested
function main() returns ExitCode
  var x = 3
  if x == 1 'outer'
    return 1
  end 'outer' else 'else_outer'
    if x == 2 'inner'
      return 2
    end 'inner' else 'else_inner'
      return 3
    end 'else_inner'
  end 'else_outer'
end 'main'
---
ExitCode: 3
---
module {
  func @if-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 3
    x86.mov [rbp-16], ecx
    x86.mov edx, 1
    x86.cmp ecx, edx
    x86.jne if-statements.main.else_outer_1
  outer_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  else_outer_1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 2
    x86.mov edx, [rbp-16]
    x86.cmp edx, ecx
    x86.jne if-statements.main.else_inner_3
  inner_2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov eax, 2
    x86.mov ecx, [rbp-40]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-32]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  else_inner_3:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-48], eax
    x86.mov eax, 3
    x86.mov ecx, [rbp-48]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-32]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  }
}
---

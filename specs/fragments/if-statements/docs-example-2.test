// Test: docs-example-2
function main() returns ExitCode
  var x = 3
  if x > 5 'gt5'
    return 1
  end 'gt5' else 'not_gt5'
    return 0
  end 'not_gt5'
end 'main'

---
ExitCode: 0
---
module {
  func @if-statements.main() -> u32 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 5
    x86.cmp eax, ecx
    x86.jle if-statements.main.not_gt5_1
  gt5_0:
    x86.mov eax, 1
    x86.ret
  not_gt5_1:
    x86.xor eax, eax
    x86.ret
  }
}
---

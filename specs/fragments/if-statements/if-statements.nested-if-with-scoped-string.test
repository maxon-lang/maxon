// Test: if-statements.nested-if-with-scoped-string
function test(x int) returns int
  if x == 0 'outer'
    let inner = "hello"
    if inner == "hello" 'checkInner'
      return 1
    end 'checkInner'
  end 'outer'
  return 42
end 'test'

function main() returns int
  return test(5)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=96
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.jne if-statements.test.outer_0.merge
  outer_0:
    x86.lea_rdata rax, [__str_3]
    x86.mov rcx, rax
    x86.mov edx, 5
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.xor edi, edi
    x86.lea_rdata r8, [__str_4]
    x86.mov r9, r8
    x86.mov eax, 5
    x86.xor r8, r8
    x86.mov [rbp-88], ecx
    x86.mov ecx, 1
    x86.mov [rbp-96], edx
    x86.xor edx, edx
    x86.mov [rbp-8], edi
    x86.mov [rbp-16], esi
    x86.mov [rbp-24], ebx
    x86.mov ebx, [rbp-96]
    x86.mov [rbp-32], ebx
    x86.mov ebx, [rbp-88]
    x86.mov [rbp-40], ebx
    x86.lea rbx, [rbp-40]
    x86.mov [rbp-48], edx
    x86.mov [rbp-56], ecx
    x86.mov [rbp-64], r8
    x86.mov [rbp-72], eax
    x86.mov [rbp-80], r9
    x86.lea rax, [rbp-80]
    x86.mov rcx, rbx
    x86.mov rdx, rax
    x86.call stdlib.String.equals
    x86.test eax, eax
    x86.je if-statements.test.checkInner_1.after
  checkInner_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  checkInner_1.after:
    x86.jmp if-statements.test.outer_0.merge
  outer_0.merge:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
  func @if-statements.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.jmp if-statements.test
  }
}
---

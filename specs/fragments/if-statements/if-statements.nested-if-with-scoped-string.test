// Test: if-statements.nested-if-with-scoped-string
function test(x int) returns int
  if x == 0 'outer'
    let inner = "hello"
    if inner == "hello" 'checkInner'
      return 1
    end 'checkInner'
  end 'outer'
  return 42
end 'test'

function main() returns int
  return test(5)
end 'main'

// Test: docs-example-3
function main() returns int
  var x = 2
  if x == 1 'case1'
    return 1
  end 'case1' else if x == 2 'case2'
    return 2
  end 'case2' else 'default'
    return 0
  end 'default'
end 'main'

---
ExitCode: 2
---
module {
  func @if-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne if-statements.main.case1_0.elseif
  case1_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  case1_0.elseif:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne if-statements.main.default_2
  case2_1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  default_2:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

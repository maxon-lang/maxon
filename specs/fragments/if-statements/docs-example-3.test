// Test: docs-example-3
function main() returns ExitCode
  var x = 2
  if x == 1 'case1'
    return 1
  end 'case1' else if x == 2 'case2'
    return 2
  end 'case2' else 'default'
    return 0
  end 'default'
end 'main'

---
ExitCode: 2
---
module {
  func @if-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.mov [rbp-16], ecx
    x86.mov edx, 1
    x86.cmp ecx, edx
    x86.jne if-statements.main.case1_0.elseif
  case1_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  case1_0.elseif:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov ecx, 2
    x86.mov edx, [rbp-16]
    x86.cmp edx, ecx
    x86.jne if-statements.main.default_2
  case2_1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov eax, 2
    x86.mov ecx, [rbp-40]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-32]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  default_2:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-48], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-48]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-32]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

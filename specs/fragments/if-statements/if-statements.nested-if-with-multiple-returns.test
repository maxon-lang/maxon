// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
  if c == 0 'maybePrefix'
    if next == 1 'isHex'
      return 1
    end 'isHex'
    if next == 2 'isBinary'
      return 2
    end 'isBinary'
  end 'maybePrefix'
  return 42
end 'test'

function main() returns ExitCode
  return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(c: i64, next: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.jne if-statements.test.maybePrefix_0.merge
  maybePrefix_0:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne if-statements.test.isHex_1.after
  isHex_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  isHex_1.after:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne if-statements.test.isBinary_2.after
  isBinary_2:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  isBinary_2.after:
    x86.jmp if-statements.test.maybePrefix_0.merge
  maybePrefix_0.merge:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
  func @if-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.xor rdx, rdx
    x86.call if-statements.test
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je if-statements.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

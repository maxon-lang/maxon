// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
  if c == 0 'maybePrefix'
    if next == 1 'isHex'
      return 1
    end 'isHex'
    if next == 2 'isBinary'
      return 2
    end 'isBinary'
  end 'maybePrefix'
  return 42
end 'test'

function main() returns ExitCode
  return test(5, next: 0)
end 'main'
---
ExitCode: 42
---

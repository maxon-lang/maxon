// Test: method-with-args-on-same-type-parameter
type Adder
  var value int
  
  function addTo(n int) returns int
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n int) returns int
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns int
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.add ecx, edx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [edx+0]
    x86.mov [rbp-24], ecx
    x86.lea rdx, [rbp-24]
    x86.mov rcx, rdx
    x86.mov rdx, r8
    x86.call Adder.addTo
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 50
    x86.mov edx, 7
    x86.mov [rbp-8], eax
    x86.lea rbx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.lea rsi, [rbp-16]
    x86.mov rcx, rbx
    x86.mov r8, rdx
    x86.mov rdx, rsi
    x86.call Adder.delegateAdd
    x86.epilogue
    x86.ret
  }
}
---

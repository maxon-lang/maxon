// Test: method-with-args-on-same-type-parameter
type Adder
  var value int
  
  function addTo(n int) returns int
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n int) returns int
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns int
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.lea eax, [ebx + edx]
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, r8
    x86.epilogue
    x86.jmp Adder.addTo
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 100
    x86.mov [edx+0], ebx
    x86.mov esi, 50
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 50
    x86.mov [r8+0], r9
    x86.mov eax, 7
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov r8, rax
    x86.epilogue
    x86.jmp Adder.delegateAdd
  }
}
---

// Test: method-with-args-on-same-type-parameter
type Adder
  var value int
  
  function addTo(n int) returns int
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n int) returns int
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns int
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, [ecx+0]
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.lea eax, [ecx + edx]
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other.value: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], edx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.lea rax, [rbp-24]
    x86.mov [rbp-32], ecx
    x86.mov rcx, rax
    x86.mov rdx, r8
    x86.call Adder.addTo
    x86.mov edx, [rbp-24]
    x86.mov [rbp-16], edx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 100
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 50
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov esi, 7
    x86.mov edi, [rbp-16]
    x86.mov [rbp-40], edi
    x86.lea r8, [rbp-40]
    x86.mov r9, [rbp-32]
    x86.mov rcx, r8
    x86.mov rdx, r9
    x86.mov r8, rsi
    x86.call Adder.delegateAdd
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-16], ecx
    x86.epilogue
    x86.ret
  }
}
---

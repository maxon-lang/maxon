// Test: method-with-args-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Adder
  var value Integer
  
  function addTo(n Integer) returns Integer
    return value + n
  end 'addTo'
  
  function delegateAdd(other Adder, n Integer) returns Integer
    return other.addTo(n)
  end 'delegateAdd'
end 'Adder'

function main() returns ExitCode
  var a = Adder{value: 100}
  var b = Adder{value: 50}
  return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
module {
  func @Adder.addTo(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.lea eax, [ebx + edx]
    x86.epilogue
    x86.ret
  }
  func @Adder.delegateAdd(__self_ptr: i64, other: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.mov rcx, [rbp-8]
    x86.mov rdx, r8
    x86.epilogue
    x86.jmp Adder.addTo
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 100
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 100
    x86.mov [edx+0], ebx
    x86.mov esi, 50
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 50
    x86.mov [r8+0], r9
    x86.mov eax, 7
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov r8, rax
    x86.call Adder.delegateAdd
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je method-call-on-parameter.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-32], eax
    x86.call maxon_release
    x86.mov rcx, [rbp-16]
    x86.call maxon_release
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}

// Test: method-with-args-on-same-type-parameter
type Adder
    var value int
    
    function addTo(n int) returns int
        return value + n
    end 'addTo'
    
    function delegateAdd(other Adder, n int) returns int
        return other.addTo(n)
    end 'delegateAdd'
end 'Adder'

function main() returns int
    var a = Adder{value: 100}
    var b = Adder{value: 50}
    return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 100
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rbp-48]
    x86.mov qword ptr [r8], rcx
    x86.mov rcx, 50
    x86.lea rax, qword ptr [rbp-56]
    x86.lea r9, qword ptr [rax+rdx]
    x86.mov qword ptr [r9], rcx
    x86.lea r9, qword ptr [rbp-64]
    x86.mov qword ptr [r9], rax
    x86.mov rax, qword ptr [r8]
    x86.mov r8, qword ptr [r9]
    x86.mov r9, 7
    x86.mov r10, rax
    x86.mov r11, r8
    x86.push r9
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.delegateAdd
    x86.mov r9, rax
    x86.mov rax, r9
    x86.epilogue
    x86.ret
}

func.func @Adder.addTo(%self: !maxon.struct<Adder>, %n: i64) -> i64 {
  ^entry(%self: !maxon.struct<Adder>, %n: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov rax, qword ptr [rdx]
    x86.mov rdx, rax
    x86.add rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @Adder.delegateAdd(%self: !maxon.struct<Adder>, %other: !maxon.struct<Adder>, %n: i64) -> i64 {
  ^entry(%self: !maxon.struct<Adder>, %other: !maxon.struct<Adder>, %n: i64):
    x86.prologue stack_size=32
    x86.mov rax, rdx
    x86.mov rcx, r8
    x86.mov r10, rax
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.addTo
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

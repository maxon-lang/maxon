// Test: sibling-method-call-still-works
type Calculator
  var base Integer
  
  function double() returns Integer
    return base * 2
  end 'double'
  
  function quadruple() returns Integer
    // Sibling call - calls self.double()
    return double() * 2
  end 'quadruple'
end 'Calculator'

function main() returns Integer
  var calc = Calculator{base: 5}
  return calc.quadruple()
end 'main'
---
ExitCode: 20
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Calculator.quadruple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call Calculator.double
    x86.mov ecx, 2
    x86.imul eax, ecx
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 5
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Calculator.quadruple
  }
}
---

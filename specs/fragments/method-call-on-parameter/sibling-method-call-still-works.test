// Test: sibling-method-call-still-works

typealias Integer = int(i64.min to i64.max)

type Calculator
  var base Integer
  
  function double() returns Integer
    return base * 2
  end 'double'
  
  function quadruple() returns Integer
    // Sibling call - calls self.double()
    return double() * 2
  end 'quadruple'
end 'Calculator'

function main() returns ExitCode
  var calc = Calculator{base: 5}
  return calc.quadruple()
end 'main'
---
ExitCode: 20
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Calculator.quadruple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call Calculator.double
    x86.mov ecx, 2
    x86.imul eax, ecx
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 5
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call Calculator.quadruple
    x86.mov [rbp-16], eax
    x86.xor edi, edi
    x86.cmp eax, edi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rax, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je method-call-on-parameter.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: sibling-method-call-still-works
type Calculator
  var base int
  
  function double() returns int
    return base * 2
  end 'double'
  
  function quadruple() returns int
    // Sibling call - calls self.double()
    return double() * 2
  end 'quadruple'
end 'Calculator'

function main() returns int
  var calc = Calculator{base: 5}
  return calc.quadruple()
end 'main'
---
ExitCode: 20
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Calculator.quadruple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], eax
    x86.lea rcx, [rbp-24]
    x86.call Calculator.double
    x86.mov edx, [rbp-24]
    x86.mov [rbp-16], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, 2
    x86.imul eax, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-16]
    x86.mov [r8+0], r9
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call Calculator.quadruple
    x86.epilogue
    x86.ret
  }
}
---

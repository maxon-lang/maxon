// Test: method-call-chain-same-type
type Value
    var n int
    
    function get() returns int
        return n
    end 'get'
    
    function add(other Value) returns int
        return n + other.get()
    end 'add'
    
    function multiply(other Value) returns int
        return n * other.get()
    end 'multiply'
end 'Value'

function main() returns int
    var a = Value{n: 5}
    var b = Value{n: 3}
    var c = Value{n: 2}
    // a.add(b) = 5 + 3 = 8
    // a.multiply(c) = 5 * 2 = 10
    // total = 8 + 10 = 18
    return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=80
    x86.push rbx
    x86.push r12
    x86.push r13
    x86.mov rax, 5
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov qword ptr [rbx], rcx
    x86.mov rcx, 3
    x86.lea r8, qword ptr [rbp-56]
    x86.mov rax, 0
    x86.lea rdx, qword ptr [r8+rax]
    x86.mov qword ptr [rdx], rcx
    x86.lea rdx, qword ptr [rbp-64]
    x86.mov qword ptr [rdx], r8
    x86.mov r8, 2
    x86.lea rcx, qword ptr [rbp-72]
    x86.mov rax, 0
    x86.lea r9, qword ptr [rcx+rax]
    x86.mov qword ptr [r9], r8
    x86.lea r12, qword ptr [rbp-80]
    x86.mov qword ptr [r12], rcx
    x86.mov rcx, qword ptr [rbx]
    x86.mov r9, qword ptr [rdx]
    x86.mov r10, rcx
    x86.mov r11, r9
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Value.add
    x86.mov r13, rax
    x86.mov r9, qword ptr [rbx]
    x86.mov rcx, qword ptr [r12]
    x86.mov r10, r9
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Value.multiply
    x86.mov rcx, rax
    x86.mov r9, r13
    x86.add r9, rcx
    x86.mov rax, r9
    x86.pop r13
    x86.pop r12
    x86.pop rbx
    x86.epilogue
    x86.ret
}

func.func @Value.get(%self: !maxon.struct<Value>) -> i64 {
  ^entry(%self: !maxon.struct<Value>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}

func.func @Value.add(%self: !maxon.struct<Value>, %other: !maxon.struct<Value>) -> i64 {
  ^entry(%self: !maxon.struct<Value>, %other: !maxon.struct<Value>):
    x86.prologue stack_size=32
    x86.push rbx
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov rbx, qword ptr [rdx]
    x86.call Value.get
    x86.mov rcx, rax
    x86.mov rdx, rbx
    x86.add rdx, rcx
    x86.mov rax, rdx
    x86.pop rbx
    x86.epilogue
    x86.ret
}

func.func @Value.multiply(%self: !maxon.struct<Value>, %other: !maxon.struct<Value>) -> i64 {
  ^entry(%self: !maxon.struct<Value>, %other: !maxon.struct<Value>):
    x86.prologue stack_size=32
    x86.push rbx
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov rbx, qword ptr [rdx]
    x86.call Value.get
    x86.mov rcx, rax
    x86.imul rdx, rbx, rcx
    x86.mov rax, rdx
    x86.pop rbx
    x86.epilogue
    x86.ret
}
---

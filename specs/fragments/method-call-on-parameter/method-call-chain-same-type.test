    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], ebx
    x86.mov rcx, [rbp-16]
    x86.call Value.get
    x86.mov ecx, [rbp-24]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }

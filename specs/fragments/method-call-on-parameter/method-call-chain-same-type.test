// Test: method-call-chain-same-type
type Value
  var n int
  
  function get() returns int
    return n
  end 'get'
  
  function add(other Value) returns int
    return n + other.get()
  end 'add'
  
  function multiply(other Value) returns int
    return n * other.get()
  end 'multiply'
end 'Value'

function main() returns int
  var a = Value{n: 5}
  var b = Value{n: 3}
  var c = Value{n: 2}
  // a.add(b) = 5 + 3 = 8
  // a.multiply(c) = 5 * 2 = 10
  // total = 8 + 10 = 18
  return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
module {
  func @Value.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Value.add(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [edx+0]
    x86.mov [rbp-24], eax
    x86.lea rdx, [rbp-24]
    x86.mov [rbp-32], ecx
    x86.mov rcx, rdx
    x86.call Value.get
    x86.mov ebx, [rbp-32]
    x86.add ebx, eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @Value.multiply(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [edx+0]
    x86.mov [rbp-24], eax
    x86.lea rdx, [rbp-24]
    x86.mov [rbp-32], ecx
    x86.mov rcx, rdx
    x86.call Value.get
    x86.mov ebx, [rbp-32]
    x86.imul ebx, eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.mov edx, 2
    x86.mov [rbp-8], eax
    x86.lea rbx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.lea rsi, [rbp-16]
    x86.mov [rbp-40], edx
    x86.mov rcx, rbx
    x86.mov rdx, rsi
    x86.call Value.add
    x86.mov edi, [rbp-8]
    x86.mov [rbp-24], edi
    x86.lea r8, [rbp-24]
    x86.mov r9, [rbp-40]
    x86.mov [rbp-32], r9
    x86.lea rcx, [rbp-32]
    x86.mov [rbp-48], eax
    x86.mov rdx, rcx
    x86.mov rcx, r8
    x86.call Value.multiply
    x86.mov ecx, [rbp-48]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }
}

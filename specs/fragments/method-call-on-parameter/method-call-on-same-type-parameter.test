// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
  var x Integer
  
  function bar() returns Integer
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns Integer
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns ExitCode
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Foo.bar
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 42
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Foo.callBarOn
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je method-call-on-parameter.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

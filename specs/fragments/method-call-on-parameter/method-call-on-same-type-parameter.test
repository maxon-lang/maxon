// Test: method-call-on-same-type-parameter
type Foo
  var x int
  
  function bar() returns int
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns int
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns int
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other.x: i64) -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov edx, [rbp-24]
    x86.mov [rbp-32], edx
    x86.lea rbx, [rbp-32]
    x86.mov [rbp-40], ecx
    x86.mov rcx, rbx
    x86.call Foo.bar
    x86.mov esi, [rbp-32]
    x86.mov [rbp-24], esi
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 42
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-16]
    x86.mov [rbp-40], esi
    x86.lea rdi, [rbp-40]
    x86.mov r8, [rbp-32]
    x86.mov rcx, rdi
    x86.mov edx, r8
    x86.call Foo.callBarOn
    x86.mov r9, [rbp-40]
    x86.mov [rbp-16], r9
    x86.epilogue
    x86.ret
  }
}
---

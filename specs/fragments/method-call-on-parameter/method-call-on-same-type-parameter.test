// Test: method-call-on-same-type-parameter
type Foo
  var x int
  
  function bar() returns int
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns int
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns int
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Foo.bar
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, 42
    x86.mov edi, 8
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, [rbp-16]
    x86.mov r9, 42
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp Foo.callBarOn
  }
}
---

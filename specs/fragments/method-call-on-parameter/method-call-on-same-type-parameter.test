// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
  var x Integer
  
  function bar() returns Integer
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns Integer
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns ExitCode
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], ecx
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, [ecx+0]
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], eax
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-16], edx
    x86.xor eax, eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-16]
    x86.call Foo.bar
    x86.mov edx, [rbp-8]
    x86.mov [rbp-32], eax
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 10
    x86.mov edx, 8
    x86.xor ebx, ebx
    x86.mov rcx, rdx
    x86.mov rdx, rbx
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov esi, [rbp-16]
    x86.mov edi, 10
    x86.mov [esi+0], edi
    x86.mov r8, 42
    x86.mov r9, 8
    x86.xor eax, eax
    x86.mov rcx, r9
    x86.mov rdx, rax
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, 42
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Foo.callBarOn
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax

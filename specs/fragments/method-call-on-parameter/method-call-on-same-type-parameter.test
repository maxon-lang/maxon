// Test: method-call-on-same-type-parameter
type Foo
    var x int
    
    function bar() returns int
        return x
    end 'bar'
    
    function callBarOn(other Foo) returns int
        return other.bar()
    end 'callBarOn'
end 'Foo'

function main() returns int
    var f1 = Foo{x: 10}
    var f2 = Foo{x: 42}
    return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 10
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rdx, qword ptr [rbp-48]
    x86.mov rax, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rdx
    x86.mov rsi, rcx
    x86.mov rcx, rax
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, 42
    x86.lea r8, qword ptr [rbp-56]
    x86.lea r9, qword ptr [r8]
    x86.mov qword ptr [r9], rcx
    x86.lea r9, qword ptr [rbp-64]
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r9
    x86.mov rsi, r8
    x86.mov rcx, rax
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rax, qword ptr [r9]
    x86.mov r10, rdx
    x86.mov r11, rax
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Foo.callBarOn
    x86.epilogue
    x86.ret
}

func.func @Foo.bar(%self: memref<!maxon.struct<Foo>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Foo>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}

func.func @Foo.callBarOn(%self: memref<!maxon.struct<Foo>>, %other: memref<!maxon.struct<Foo>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Foo>>, %other: memref<!maxon.struct<Foo>>):
    x86.prologue stack_size=32
    x86.mov rax, rdx
    x86.mov rcx, rax
    x86.call Foo.bar
    x86.epilogue
    x86.ret
}
---

// Test: method-call-on-same-type-parameter
type Foo
  var x int
  
  function bar() returns int
    return x
  end 'bar'
  
  function callBarOn(other Foo) returns int
    return other.bar()
  end 'callBarOn'
end 'Foo'

function main() returns int
  var f1 = Foo{x: 10}
  var f2 = Foo{x: 42}
  return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [edx+0]
    x86.mov [rbp-24], ecx
    x86.lea rdx, [rbp-24]
    x86.mov rcx, rdx
    x86.call Foo.bar
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.epilogue
    x86.ret
  }
  func @method-call-on-parameter.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 42
    x86.mov [rbp-8], eax
    x86.lea rdx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.lea rbx, [rbp-16]
    x86.mov rcx, rdx
    x86.mov rdx, rbx
    x86.call Foo.callBarOn
    x86.epilogue
    x86.ret
  }
}
---

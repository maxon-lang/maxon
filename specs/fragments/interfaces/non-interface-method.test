// Test: non-interface-method
type Calculator
  var value int

  function double() returns int
    return value * 2
  end 'double'

  function triple() returns int
    return value * 3
  end 'triple'
end 'Calculator'

function main() returns int
  var c = Calculator{value: 7}
  return c.double() + c.triple()
end 'main'
---
ExitCode: 35
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Calculator.triple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 3
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 7
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call Calculator.double
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], edx
    x86.lea rbx, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov rcx, rbx
    x86.call Calculator.triple
    x86.mov esi, [rbp-24]
    x86.lea eax, [esi + eax]
    x86.epilogue
    x86.ret
  }
}

// Test: non-interface-method
type Calculator
  var value int

  function double() returns int
    return value * 2
  end 'double'

  function triple() returns int
    return value * 3
  end 'triple'
end 'Calculator'

function main() returns int
  var c = Calculator{value: 7}
  return c.double() + c.triple()
end 'main'
---
ExitCode: 35
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Calculator.triple(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 3
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 7
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.call Calculator.double
    x86.mov edi, [rbp-8]
    x86.mov [rbp-24], eax
    x86.mov rcx, rdi
    x86.call Calculator.triple
    x86.mov r8, [rbp-24]
    x86.lea eax, [r8 + eax]
    x86.epilogue
    x86.ret
  }
}
---

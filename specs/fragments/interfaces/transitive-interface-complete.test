// Test: transitive-interface-complete
interface BaseInterface
  function baseMethod() returns int
end 'BaseInterface'

interface DerivedInterface extends BaseInterface
  function derivedMethod() returns int
end 'DerivedInterface'

// CompleteType implements all methods from both interfaces
type CompleteType is DerivedInterface
  var value int

  function baseMethod() returns int
    return value
  end 'baseMethod'

  function derivedMethod() returns int
    return value * 2
  end 'derivedMethod'
end 'CompleteType'

function main() returns int
  var t = CompleteType{value: 21}
  return t.baseMethod() + t.derivedMethod()
end 'main'
---
ExitCode: 63
---
module {
  func @CompleteType.baseMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @CompleteType.derivedMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 21
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call CompleteType.baseMethod
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], edx
    x86.lea rbx, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov rcx, rbx
    x86.call CompleteType.derivedMethod
    x86.mov esi, [rbp-24]
    x86.lea eax, [esi + eax]
    x86.epilogue
    x86.ret
  }
}
---

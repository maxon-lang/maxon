    x86.prologue stack_size=48
    x86.mov eax, 21
    x86.lea rdi, [rbp-16]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-24], edx
    x86.mov esi, [rbp-24]
    x86.mov edi, 21
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov r9, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call CompleteType.baseMethod
    x86.mov ecx, [rbp-24]
    x86.mov [rbp-40], eax
    x86.call CompleteType.derivedMethod
    x86.mov ecx, [rbp-40]
    x86.add ecx, eax
    x86.mov [rbp-32], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je interfaces.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]

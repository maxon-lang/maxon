// Test: transitive-interface-complete

typealias Integer = int(i64.min to i64.max)

interface BaseInterface
  function baseMethod() returns Integer
end 'BaseInterface'

interface DerivedInterface extends BaseInterface
  function derivedMethod() returns Integer
end 'DerivedInterface'

// CompleteType implements all methods from both interfaces
type CompleteType implements DerivedInterface
  var value Integer

  function baseMethod() returns Integer
    return value
  end 'baseMethod'

  function derivedMethod() returns Integer
    return value * 2
  end 'derivedMethod'
end 'CompleteType'

function main() returns ExitCode
  var t = CompleteType{value: 21}
  return t.baseMethod() + t.derivedMethod()
end 'main'
---
ExitCode: 63
---
module {
  func @CompleteType.baseMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @CompleteType.derivedMethod(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 2
    x86.imul edx, eax
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> u32 {

// Test: method-with-params
interface Calculator
  function add(n int) returns int
end 'Calculator'

type Accumulator implements Calculator
  var total int

  function add(n int) returns int
    return total + n
  end 'add'
end 'Accumulator'

function main() returns int
  var acc = Accumulator{total: 10}
  return acc.add(5)
end 'main'
---
ExitCode: 15
---
module {
  func @Accumulator.add(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.lea eax, [ebx + edx]
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, 5
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.mov rdx, rsi
    x86.epilogue
    x86.jmp Accumulator.add
  }
}
---

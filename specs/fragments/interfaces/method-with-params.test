// Test: method-with-params
interface Calculator
  function add(n int) returns int
end 'Calculator'

type Accumulator is Calculator
  var total int

  function add(n int) returns int
    return total + n
  end 'add'
end 'Accumulator'

function main() returns int
  var acc = Accumulator{total: 10}
  return acc.add(5)
end 'main'
---
ExitCode: 15
---
module {
  func @Accumulator.add(__self_ptr: i64, n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.add ecx, edx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.mov [rbp-8], eax
    x86.lea rdx, [rbp-8]
    x86.xchg rdx, rcx
    x86.call Accumulator.add
    x86.epilogue
    x86.ret
  }
}
---

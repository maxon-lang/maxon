// Test: basic-interface

typealias Integer = int(i64.min to i64.max)

type Point implements Hashable
  var x Integer
  var y Integer

  function hash() returns HashValue
    return x + y * 31
  end 'hash'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 10, y: 20}
  print("{p.hash()}\n")
  return 0
end 'main'

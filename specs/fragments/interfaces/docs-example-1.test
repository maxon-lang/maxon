// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

type Point implements Hashable
  var x Score
  var y Score

  function hash() returns HashValue
    return x + y * 31
  end 'hash'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 10, y: 20}
  var h = p.hash()
  print("{h}\n")
  return 0
end 'main'


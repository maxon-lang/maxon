// Test: docs-example-1
type Point implements Hashable
  var x Integer
  var y Integer

  function hash() returns Integer
    return x + y * 31
  end 'hash'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 10, y: 20}
  var h = p.hash()
  print("{h}\n")
  return 0
end 'main'

---
ExitCode: 0
---

    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.mov eax, 31
    x86.imul ebx, eax
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }

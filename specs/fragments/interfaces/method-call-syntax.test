// Test: method-call-syntax
interface Incrementable
  function inc() returns Integer
end 'Incrementable'

type Value implements Incrementable
  var n Integer

  function inc() returns Integer
    return n + 1
  end 'inc'
end 'Value'

function main() returns Integer
  var v = Value{n: 41}
  return v.inc()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.inc(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.lea eax, [edx + eax]
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 41
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 41
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Value.inc
  }
}
---

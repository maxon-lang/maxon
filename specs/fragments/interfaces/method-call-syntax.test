// Test: method-call-syntax
interface Incrementable
  function inc() returns int
end 'Incrementable'

type Value is Incrementable
  var n int

  function inc() returns int
    return n + 1
  end 'inc'
end 'Value'

function main() returns int
  var v = Value{n: 41}
  return v.inc()
end 'main'
---
ExitCode: 42
---
module {
  func @Value.inc(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @interfaces.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 41
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.call Value.inc
    x86.epilogue
    x86.ret
  }
}
---

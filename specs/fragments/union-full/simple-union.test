    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.cmp3
  check_0.case2:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp union-full.main.check_0.merge
  check_0.cmp3:
    x86.mov rax, [rbp-24]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.merge
  check_0.case3:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp union-full.main.check_0.merge
  check_0.merge:
    x86.mov rax, [rbp-16]

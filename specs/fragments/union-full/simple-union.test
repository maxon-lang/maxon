// Test: simple-union
union Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = Direction.north
  var result = match dir 'check'
    Direction.north gives 1
    Direction.south gives 0
    Direction.east gives 0
    Direction.west gives 0
  end 'check'
  return result
end 'main'
---
ExitCode: 1
---

    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.mov [rbp-16], rax
    x86.jmp union-full.main.check_0.merge
  check_0.cmp1:

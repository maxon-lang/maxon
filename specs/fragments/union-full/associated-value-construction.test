// Test: associated-value-construction

typealias Integer = int(i64.min to i64.max)

union Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.value(42)
  match c 'check'
    value(n) then return 1
    empty then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @union-full.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 42
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov ecx, 1
    x86.mov [eax+0], ecx
    x86.mov edx, 42
    x86.mov [eax+8], edx
    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov esi, [rbp-16]
    x86.mov edi, [esi+0]
    x86.mov r8, [rbp-16]
    x86.mov [rbp-24], r8
    x86.mov r9, [rbp-24]
    x86.mov [rbp-40], edi
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, [rbp-40]
    x86.mov [rbp-32], eax
    x86.jmp union-full.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne union-full.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.mov ecx, [rbp-24]
    x86.call mm_decref
    x86.mov edx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne union-full.main.check_0.merge
  check_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.mov ecx, [rbp-24]
    x86.call mm_decref
    x86.mov edx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

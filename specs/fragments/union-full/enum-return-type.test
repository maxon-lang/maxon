// Test: enum-return-type
union Result
  success
  failure
end 'Result'

function getResult(succeed bool) returns Result
  if succeed 'check'
    return Result.success
  end 'check'
  return Result.failure
end 'getResult'

function main() returns ExitCode
  var r = getResult(true)
  var result = match r 'handle'
    Result.success gives 1
    Result.failure gives 0
  end 'handle'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @union-full.getResult(succeed: i1) -> i64 {
  entry:
    x86.test ecx, ecx
    x86.je union-full.getResult.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
  func @union-full.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 1
    x86.mov rcx, rax
    x86.call union-full.getResult
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.xor edx, edx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.jmp union-full.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne union-full.main.handle_0.cmp1
  handle_0.case0:
    x86.mov eax, 1
    x86.mov [rbp-16], eax
    x86.jmp union-full.main.handle_0.merge
  handle_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne union-full.main.handle_0.merge
  handle_0.case1:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp union-full.main.handle_0.merge
  handle_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je union-full.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:

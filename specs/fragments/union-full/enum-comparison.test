// Test: enum-comparison
union Status
  pending
  active
  done
end 'Status'

function main() returns ExitCode
  var s1 = Status.pending
  match s1 'check'
    Status.pending then return 1
    Status.active then return 0
    Status.done then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @union-full.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp union-full.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.cmp2
  check_0.case1:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne union-full.main.check_0.merge
  check_0.case2:
    x86.xor rax, rax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

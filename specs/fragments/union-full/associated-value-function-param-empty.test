    x86.mov ebx, [edx+8]
    x86.mov esi, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.mov [rbp-40], esi
    x86.jmp union-full.process.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-40]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne union-full.process.handle_0.cmp1

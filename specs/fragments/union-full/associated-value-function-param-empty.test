    x86.xor eax, eax
    x86.epilogue
    x86.ret
  handle_0.cmp1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne union-full.process.handle_0.merge
  handle_0.case1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  handle_0.merge:
  }
  func @union-full.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, 16
    x86.xor rdx, rdx

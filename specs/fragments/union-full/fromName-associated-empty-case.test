// Test: fromName-associated-empty-case

typealias Integer = int(i64.min to i64.max)

union Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = try Container.fromName("empty") otherwise Container.value(99)
  match c 'check'
    empty then return 1
    value(_n) then return 0
  end 'check'
end 'main'

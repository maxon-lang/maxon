// Test: export-type-basic

typealias Integer = int(i64.min to i64.max)

export type Point
  var x Integer
  var y Integer

  export function sum() returns Integer
    return x + y
  end 'sum'
end 'Point'

function main() returns ExitCode
  var p = Point{x: 20, y: 22}
  return p.sum()
end 'main'

// Test: export-type-basic
export type Point
  var x int
  var y int

  export function sum() returns int
    return x + y
  end 'sum'
end 'Point'

function main() returns int
  var p = Point{x: 20, y: 22}
  return p.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Point.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @export-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.mov edx, 16
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp Point.sum
  }
}

// Test: mixed-export-and-non-export
export function publicFunc() returns Integer
  return privateFunc() + 20
end 'publicFunc'

function privateFunc() returns Integer
  return 22
end 'privateFunc'

function main() returns ExitCode
  return publicFunc()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.publicFunc() -> i64 {
  entry:
    x86.call export-keyword.privateFunc
    x86.mov ecx, 20
    x86.add eax, ecx
    x86.ret
  }
  func @export-keyword.privateFunc() -> i64 {
  entry:
    x86.mov eax, 22
    x86.ret
  }
  func @export-keyword.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.publicFunc
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je export-keyword.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

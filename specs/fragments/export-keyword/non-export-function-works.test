// Test: non-export-function-works
function helper() returns int
  return 42
end 'helper'

function main() returns int
  return helper()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.helper() -> i64 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
  func @export-keyword.main() -> i64 {
  entry:
    x86.call export-keyword.helper
    x86.ret
  }
}

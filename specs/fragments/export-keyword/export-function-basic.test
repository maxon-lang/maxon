// Test: export-function-basic

typealias Integer = int(i64.min to i64.max)

export function helper() returns Integer
  return 21
end 'helper'

function main() returns ExitCode
  return helper() + helper()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.helper() -> i64 {
  entry:
    x86.mov eax, 21
    x86.ret
  }
  func @export-keyword.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.helper
    x86.mov [rbp-16], eax
    x86.call export-keyword.helper
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rdx, 4294967295
    x86.cmp rcx, rdx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je export-keyword.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

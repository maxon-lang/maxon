// Test: export-function-basic
export function helper() returns int
  return 21
end 'helper'

function main() returns int
  return helper() + helper()
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.helper() -> i64 {
  entry:
    x86.mov eax, 21
    x86.ret
  }
  func @export-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call export-keyword.helper
    x86.mov [rbp-8], eax
    x86.call export-keyword.helper
    x86.mov ecx, [rbp-8]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }
}
---

// Test: non-exported-type-same-file

typealias Integer = int(i64.min to i64.max)

type InternalPoint
  export var x Integer
  export var y Integer
end 'InternalPoint'

function main() returns ExitCode
  var p = InternalPoint{x: 20, y: 22}
  return p.x + p.y
end 'main'

export typealias IntArray = Array with int

function makeArray() returns IntArray
  var arr = IntArray{}
  arr.push(42)
  return arr
end 'makeArray'

function main() returns int
  var arr = makeArray()
  return try arr.get(0) otherwise 0
end 'main'

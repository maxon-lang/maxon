// Test: export-typealias-as-return-type
export typealias IntArray = Array with Integer

function makeArray() returns IntArray
  var arr = IntArray{}
  arr.push(42)
  return arr
end 'makeArray'

function main() returns Integer
  var arr = makeArray()
  return try arr.get(0) otherwise 0
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.makeArray() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 32
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call IntArray.push
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @export-keyword.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.call export-keyword.makeArray
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rax
    x86.call IntArray.get
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je export-keyword.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp export-keyword.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}

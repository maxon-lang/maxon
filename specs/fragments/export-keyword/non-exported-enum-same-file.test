// Test: non-exported-enum-same-file
union Direction
  up
  down
end 'Direction'

function main() returns ExitCode
  var d = Direction.up
  match d 'check'
    Direction.up then return 42
    Direction.down then return 0
  end 'check'
end 'main'
---
ExitCode: 42
---
module {
  func @export-keyword.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp export-keyword.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne export-keyword.main.check_0.cmp1
  check_0.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne export-keyword.main.check_0.merge
  check_0.case1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-32]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

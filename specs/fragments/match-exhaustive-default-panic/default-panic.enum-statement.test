// Test: default-panic.enum-statement
enum Color
    red
    green
    blue
end 'Color'

function main() returns ExitCode
  var c = Color.red
  match c 'check'
    Color.red then return 1
    default then panic("unhandled color")
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @match-exhaustive-default-panic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp match-exhaustive-default-panic.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne match-exhaustive-default-panic.main.check_0.case1
  check_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.lea_symdata rax, [__panic_msg_15]
    x86.mov rcx, rax
    x86.call maxon_panic
  check_0.merge:
  }
}
---

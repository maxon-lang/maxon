// Test: default-panic.statement
function main() returns ExitCode
  var x = 2
  match x 'check'
    1 then return 10
    2 then return 20
    default panic("unexpected value")
  end 'check'
end 'main'
---
ExitCode: 20
---
module {
  func @match-exhaustive-default-panic.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp match-exhaustive-default-panic.main.check_0.cmp0
  check_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne match-exhaustive-default-panic.main.check_0.cmp1
  check_0.case0:
    x86.mov rax, 10
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne match-exhaustive-default-panic.main.check_0.case2
  check_0.case1:
    x86.mov rax, 20
    x86.epilogue
    x86.ret
  check_0.case2:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  check_0.merge:
  }
}
---

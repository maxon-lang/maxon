// Test: negative-range
typealias Temp = int(-50 to 50)

function main() returns Integer
  var t = Temp{-10}
  return t + 60
end 'main'
---
---
module {
  func @ranged-typealias.main() -> i64 {
  entry:
    x86.mov eax, -10
    x86.mov ecx, 60
    x86.mov edx, eax
    x86.mov ebx, ecx
    x86.add edx, ebx
    x86.movsxd rax, edx
    x86.ret
  }
}
---

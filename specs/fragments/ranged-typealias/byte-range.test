// Test: byte-range
typealias Integer = int(i64.min to i64.max)
typealias AsciiCode = byte(0 to 127)

function main() returns ExitCode
  var c = AsciiCode{65}
  return c as Integer
end 'main'
---
ExitCode: 65
---
module {
  func @ranged-typealias.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 65
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je ranged-typealias.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_7]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: same-type-arithmetic
typealias Score = int(0 to 100)

function main() returns Integer
  var a = Score{30}
  var b = Score{12}
  return a + b
end 'main'
---
---
module {
  func @ranged-typealias.main() -> i64 {
  entry:
    x86.mov eax, 30
    x86.mov ecx, 12
    x86.mov edx, eax
    x86.mov ebx, ecx
    x86.lea eax, [edx + ebx]
    x86.ret
  }
}
---

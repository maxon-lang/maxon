// Test: return-literal-in-range
typealias Score = int(0 to 100)

function getScore() returns Score
  return 42
end 'getScore'

function main() returns ExitCode
  return getScore()
end 'main'
---
ExitCode: 42
---
module {
  func @ranged-typealias.getScore() -> u8 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
  func @ranged-typealias.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call ranged-typealias.getScore
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je ranged-typealias.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_7]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

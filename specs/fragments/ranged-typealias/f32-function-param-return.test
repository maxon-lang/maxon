// Test: f32-function-param-return
typealias F = f32

function double(x F) returns F
  return x * 2.0
end 'double'

function main() returns ExitCode
  var x = F{21.0}
  return trunc(double(x))
end 'main'
---
---
module {
  func @ranged-typealias.double(x: f32) -> f32 {
  entry:
    x86.movsd xmm1, [rip+__float_2]
    x86.cvtsd2ss xmm2, xmm1
    x86.movsd xmm1, xmm0
    x86.mulss xmm1, xmm2
    x86.movsd xmm0, xmm1
    x86.ret
  }
  func @ranged-typealias.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movss xmm0, [rip+__float32_21]
    x86.call ranged-typealias.double
    x86.cvttss2si eax, xmm0
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je ranged-typealias.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: ownership.reassign-arithmetic.1
function main() returns int
    var x = 100
    x = x - 50
    x = x * 2
    x = trunc(x / 5)
    return x
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_mul = const.i64 i64 100
    %tmp_const.3 = const.i64 i64 5
    %tmp_sitofp = sitofp f64 %tmp_mul
    %tmp_sitofp.1 = sitofp f64 %tmp_const.3
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    ret %tmp_fptosi
}

---

// Test: self-referential-mutation
typealias Integer = int(i64.min to i64.max)

union Link
  tail
  link(value Integer, next Link)
end 'Link'

function sumChain(c Link) returns Integer
  match c 'walk'
    link(v, next) then return v + sumChain(next)
    tail then return 0
  end 'walk'
end 'sumChain'

function main() returns ExitCode
  var c2 = Link.link(32, Link.tail)
  var c1 = Link.link(10, Link.tail)
  match c1 'link1'
    link(_v, next) then next = c2
    tail then return 0
  end 'link1'
  return sumChain(c1)
end 'main'
---
ExitCode: 42
---
// Compilation failed: error E4014: type 'Link' contains a reference cycle (via Link -> Link); recursive type references are not allowed
---

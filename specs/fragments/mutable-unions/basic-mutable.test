  update_0.merge:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.jmp mutable-unions.main.read_1.cmp0
  read_1.cmp0:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne mutable-unions.main.read_1.cmp1
  read_1.case0:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je mutable-unions.main.__range_ok_2
  __range_panic_2:

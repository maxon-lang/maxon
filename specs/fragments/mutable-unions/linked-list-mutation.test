// Test: linked-list-mutation
typealias Integer = int(i64.min to i64.max)

union Node
  empty
  item(value Integer, next Node)
end 'Node'

function main() returns ExitCode
  var n1 = Node.item(10, Node.empty)
  var n2 = Node.item(32, Node.empty)
  match n1 'link'
    item(_value, next) then next = n2
    empty then return 0
  end 'link'
  match n1 'read'
    item(v1, tail) then return v1 + nodeValue(tail)
    empty then return 0
  end 'read'
end 'main'

function nodeValue(n Node) returns Integer
  match n 'get'
    item(v, _next) then return v
    empty then return 0
  end 'get'
end 'nodeValue'
---
ExitCode: 42
---
// Compilation failed: error E4014: type 'Node' contains a reference cycle (via Node -> Node); recursive type references are not allowed
---

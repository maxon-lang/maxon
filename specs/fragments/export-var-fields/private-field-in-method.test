// Test: private-field-in-method
type Counter
  var count int

  function increment()
    count = count + 1
  end 'increment'

  function getCount() returns int
    return count
  end 'getCount'
end 'Counter'

function main() returns int
  var c = Counter{count: 40}
  c.increment()
  c.increment()
  return c.getCount()
end 'main'
---
ExitCode: 42
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov ebx, [rbp-8]
    x86.mov [ebx+0], ecx
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.epilogue
    x86.ret
  }
  func @Counter.getCount(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 40
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Counter.increment
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.mov edi, [rbp-16]
    x86.mov [rbp-32], edi
    x86.lea r8, [rbp-32]
    x86.mov rcx, r8
    x86.call Counter.increment
    x86.mov r9, [rbp-32]
    x86.mov [rbp-16], r9
    x86.mov eax, [rbp-16]
    x86.mov [rbp-40], eax
    x86.lea rax, [rbp-40]
    x86.mov rcx, rax
    x86.call Counter.getCount
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-16], ecx
    x86.epilogue
    x86.ret
  }
}
---

// Test: private-field-in-method
type Counter
  var count int

  function increment()
    count = count + 1
  end 'increment'

  function getCount() returns int
    return count
  end 'getCount'
end 'Counter'

function main() returns int
  var c = Counter{count: 40}
  c.increment()
  c.increment()
  return c.getCount()
end 'main'
---
ExitCode: 42
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.getCount(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 40
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 40
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.call Counter.increment
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.call Counter.increment
    x86.mov r8, [rbp-8]
    x86.mov rcx, r8
    x86.epilogue
    x86.jmp Counter.getCount
  }
}
---

// Test: docs-example-1
type Counter
  var count int              // private
  export var name int     // public

  function increment()
    count = count + 1      // OK - accessing within method
  end 'increment'

  export function getCount() returns int
    return count           // OK - accessing within method
  end 'getCount'
end 'Counter'

function main() returns int
  var c = Counter{count: 0, name: 5}
  c.increment()
  return c.getCount()
  // c.count would be an error - not exported
end 'main'

---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.epilogue
    x86.ret
  }
  func @Counter.getCount(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 5
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.xor esi, esi
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 5
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.call Counter.increment
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp Counter.getCount
  }
}
---

// Test: docs-example-1
type Counter
  var count int              // private
  export var name int     // public

  function increment()
    count = count + 1      // OK - accessing within method
  end 'increment'

  export function getCount() returns int
    return count           // OK - accessing within method
  end 'getCount'
end 'Counter'

function main() returns int
  var c = Counter{count: 0, name: 5}
  c.increment()
  return c.getCount()
  // c.count would be an error - not exported
end 'main'

---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+8]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov ebx, 1
    x86.add ecx, ebx
    x86.mov [rbp-32], ecx
    x86.mov esi, [rbp-8]
    x86.mov [esi+0], ecx
    x86.epilogue
    x86.ret
  }
  func @Counter.getCount(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+8]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov ecx, 5
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-32]
    x86.mov [rbp-40], esi
    x86.mov edi, [rbp-24]
    x86.mov [rbp-48], edi
    x86.lea r8, [rbp-48]
    x86.mov ecx, r8
    x86.call Counter.increment
    x86.mov r9, [rbp-48]
    x86.mov [rbp-24], r9
    x86.mov eax, [rbp-40]
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.mov [rbp-56], eax
    x86.mov eax, [rbp-24]
    x86.mov [rbp-64], eax
    x86.lea rax, [rbp-64]
    x86.mov ecx, rax
    x86.call Counter.getCount
    x86.mov ecx, [rbp-64]
    x86.mov [rbp-24], ecx
    x86.mov ecx, [rbp-56]
    x86.mov [rbp-32], ecx
    x86.epilogue
    x86.ret
  }
}

// Test: export-var-write

typealias Integer = int(i64.min to i64.max)

type Value
  export var n Integer

  static function create() returns Self
    return Value{n: 10}
  end 'create'
end 'Value'

function main() returns ExitCode
  var v = Value.create()
  v.n = 42
  return v.n
end 'main'

    x86.mov ecx, [rbp-8]
    x86.mov edx, 10
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call Value.create
    x86.mov [rbp-16], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, [edx+0]
    x86.mov [rbp-24], ebx
    x86.xor esi, esi
    x86.cmp ebx, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rbx, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je export-var-fields.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_25]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.call mm_decref
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]

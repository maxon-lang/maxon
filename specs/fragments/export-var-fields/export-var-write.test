    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je export-var-fields.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_12]
    x86.mov rcx, rax

// Test: export-var-write
type Value
  export var n Integer

  static function create() returns Self
    return {n: 10}
  end 'create'
end 'Value'

function main() returns Integer
  var v = Value.create()
  v.n = 42
  return v.n
end 'main'
---
ExitCode: 42
---
module {
  func @Value.create() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call Value.create
    x86.mov [rbp-8], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+0], eax
    x86.mov edx, [rbp-8]
    x86.mov eax, [edx+0]
    x86.epilogue
    x86.ret
  }
}
---

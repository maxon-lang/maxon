    x86.mov esi, [rbp-8]
    x86.mov edi, 100
    x86.mov [esi+8], edi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> u32 {

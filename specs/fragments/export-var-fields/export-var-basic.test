// Test: export-var-basic

typealias Integer = i64

type Value
  export var n Integer
  var private Integer

  static function create() returns Self
    return {n: 42, private: 100}
  end 'create'
end 'Value'

function main() returns ExitCode
  var v = Value.create()
  return v.n
end 'main'
---
ExitCode: 42
---
module {
  func @Value.create() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 100
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 42
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 100
    x86.mov [edi+8], r8
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call Value.create
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je export-var-fields.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

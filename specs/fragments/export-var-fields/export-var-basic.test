    x86.mov ecx, [eax+0]
    x86.mov [rbp-24], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je export-var-fields.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_29]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.call mm_decref
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]

// Test: mixed-export-fields
type Box
  export var value int
  var secret int

  static function create(v int, s int) returns Self
    return {value: v, secret: s}
  end 'create'

  function getSecret() returns int
    return secret
  end 'getSecret'
end 'Box'

function main() returns int
  var b = Box.create(20, s: 22)
  return b.value + b.getSecret()
end 'main'
---
ExitCode: 42
---
module {
  func @Box.create(__sret: i64, v: i64, s: i64) {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], r8
    x86.mov eax, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [eax+0], edx
    x86.mov edx, [rbp-24]
    x86.mov [eax+8], edx
    x86.epilogue
    x86.ret
  }
  func @Box.getSecret(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov [ebx+8], edi
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.xor edx, edx
    x86.mov [rbp-8], edx
    x86.xor ebx, ebx
    x86.mov [rbp-16], ebx
    x86.lea rsi, [rbp-16]
    x86.mov rdx, rax
    x86.mov r8, rcx
    x86.mov rcx, rsi
    x86.call Box.create
    x86.mov edi, [rbp-8]
    x86.mov [rbp-24], edi
    x86.mov r8, [rbp-16]
    x86.mov [rbp-32], r8
    x86.mov r9, [rbp-32]
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.mov eax, [rbp-32]
    x86.mov [rbp-48], eax
    x86.lea rax, [rbp-48]
    x86.mov [rbp-56], r9
    x86.mov rcx, rax
    x86.call Box.getSecret
    x86.mov ecx, [rbp-40]
    x86.mov [rbp-24], ecx
    x86.mov ecx, [rbp-48]
    x86.mov [rbp-32], ecx
    x86.mov ecx, [rbp-56]
    x86.lea eax, [ecx + eax]
    x86.epilogue
    x86.ret
  }
}

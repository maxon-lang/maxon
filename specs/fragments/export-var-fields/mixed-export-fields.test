// Test: mixed-export-fields
type Box
  export var value int
  var secret int

  static function create(v int, s int) returns Self
    return {value: v, secret: s}
  end 'create'

  function getSecret() returns int
    return secret
  end 'getSecret'
end 'Box'

function main() returns int
  var b = Box.create(20, s: 22)
  return b.value + b.getSecret()
end 'main'
---
ExitCode: 42
---
module {
  func @Box.create(v: i64, s: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 16
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], edx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+8], esi
    x86.mov edi, [rbp-8]
    x86.mov eax, edi
    x86.epilogue
    x86.ret
  }
  func @Box.getSecret(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+8]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Box.create
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [edx+0]
    x86.mov esi, [rbp-8]
    x86.mov [rbp-16], ebx
    x86.mov rcx, rsi
    x86.call Box.getSecret
    x86.mov edi, [rbp-16]
    x86.lea eax, [edi + eax]
    x86.epilogue
    x86.ret
  }
}
---

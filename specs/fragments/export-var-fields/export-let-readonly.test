// Test: export-let-readonly
type Config
  export let version int

  static function create() returns Self
    return {version: 42}
  end 'create'
end 'Config'

function main() returns int
  var c = Config.create()
  return c.version
end 'main'
---
ExitCode: 42
---
module {
  func @Config.create() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call Config.create
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}

    x86.call Simple.make
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call Simple.sum
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx

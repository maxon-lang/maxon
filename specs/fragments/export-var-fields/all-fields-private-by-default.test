// Test: all-fields-private-by-default
type Simple
  var x int
  var y int

  static function make(a int, b int) returns Self
    return {x: a, y: b}
  end 'make'

  function sum() returns int
    return x + y
  end 'sum'
end 'Simple'

function main() returns int
  var s = Simple.make(20, b: 22)
  return s.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Simple.make(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 16
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], edx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+8], esi
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @Simple.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Simple.make
    x86.mov [rbp-8], eax
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Simple.sum
  }
}
---

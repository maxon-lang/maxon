// Test: all-fields-private-by-default
type Simple
  var x int
  var y int

  static function make(a int, b int) returns Self
    return {x: a, y: b}
  end 'make'

  function sum() returns int
    return x + y
  end 'sum'
end 'Simple'

function main() returns int
  var s = Simple.make(20, b: 22)
  return s.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Simple.make(__sret: i64, a: i64, b: i64) {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], r8
    x86.mov eax, [rbp-8]
    x86.mov edx, [rbp-16]
    x86.mov [eax+0], edx
    x86.mov edx, [rbp-24]
    x86.mov [eax+8], edx
    x86.epilogue
    x86.ret
  }
  func @Simple.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.add ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov [ebx+8], edi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @export-var-fields.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 20
    x86.mov ecx, 22
    x86.xor edx, edx
    x86.mov [rbp-8], edx
    x86.xor ebx, ebx
    x86.mov [rbp-16], ebx
    x86.lea rsi, [rbp-16]
    x86.mov rdx, rax
    x86.mov r8, rcx
    x86.mov rcx, rsi
    x86.call Simple.make
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [rbp-24], edi
    x86.mov [rbp-32], r8
    x86.lea r9, [rbp-32]
    x86.mov rcx, r9
    x86.call Simple.sum
    x86.epilogue
    x86.ret
  }
}
---

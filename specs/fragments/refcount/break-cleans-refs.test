  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp refcount.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge refcount.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-16]
    x86.lea rdi, [rbp-32]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-32]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-40], edx
    x86.mov esi, [rbp-40]
    x86.mov edi, [rbp-16]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call mm_incref
    x86.mov r9, 3
    x86.mov eax, [rbp-16]
    x86.cmp eax, r9
    x86.jne refcount.main.brk_1.after
  brk_1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [eax+0]
    x86.mov edx, [rbp-8]
    x86.add edx, ecx
    x86.mov [rbp-8], edx
    x86.mov ebx, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call mm_decref
    x86.jmp refcount.main.loop_0.exit
  brk_1.after:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [eax+0]
    x86.mov edx, [rbp-8]
    x86.add edx, ecx
    x86.mov [rbp-8], edx
    x86.mov ebx, 1
    x86.mov esi, [rbp-16]
    x86.add esi, ebx
    x86.mov [rbp-16], esi
    x86.mov edi, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call mm_decref
    x86.jmp refcount.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je refcount.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_40]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov eax, [rbp-48]
    x86.epilogue

// Test: ownership-transfer-to-outer
typealias Integer = int(i64.min to i64.max)
type Token
    export var kind Integer
end 'Token'
function main() returns ExitCode
    var t = Token{kind: 0}
    if true 'a'
        var inner = Token{kind: 50}
        t = inner
    end 'a'
    return t.kind
end 'main'
---
ExitCode: 50
---

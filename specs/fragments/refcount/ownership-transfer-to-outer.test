// Test: ownership-transfer-to-outer
typealias Integer = int(i64.min to i64.max)
type Token
    export var kind Integer
end 'Token'
function main() returns ExitCode
    var t = Token{kind: 0}
    if true 'a'
        var inner = Token{kind: 50}
        t = inner
    end 'a'
    return t.kind
end 'main'
---
ExitCode: 50
---
module {
  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.xor edx, edx
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov esi, 1
    x86.test esi, esi
    x86.je refcount.main.a_0.merge
  a_0:
    x86.mov eax, 50
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.mov r8, 1
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 50
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov esi, [rbp-8]
    x86.test esi, esi
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov edi, [rbp-16]
    x86.mov [rbp-8], edi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-16]
    x86.test r9, r9
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp refcount.main.a_0.merge
  a_0.merge:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-24], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je refcount.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_2
    x86.call mm_decref
    x86.label __nonnull_skip_2
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Token(ptr: i64) {
  entry:
    x86.jmp __destruct_Token.done

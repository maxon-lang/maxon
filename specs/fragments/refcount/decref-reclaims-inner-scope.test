// Test: decref-reclaims-inner-scope
typealias Integer = int(i64.min to i64.max)
type Cell
    export var value Integer
end 'Cell'
function main() returns ExitCode
    var a = Cell{value: 10}
    var result = 0
    if true 'inner'
        var b = a
        a = Cell{value: 20}
        result = b.value
    end 'inner'
    return result + a.value
end 'main'
---
ExitCode: 30
---
module {
  func @refcount.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor rcx, rcx

    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, 10
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.xor esi, esi
    x86.mov [rbp-24], esi
    x86.mov edi, 1
    x86.test edi, edi
    x86.je refcount.main.inner_0.merge
  inner_0:
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-16]
    x86.mov [rbp-40], eax
    x86.mov ecx, [rbp-40]
    x86.call mm_incref
    x86.mov edx, 20
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-48], eax
    x86.mov ebx, [rbp-48]
    x86.mov esi, 20
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.mov r8, [rbp-48]
    x86.mov [rbp-16], r8
    x86.mov r9, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-8]
    x86.xor r8, r8
    x86.call mm_move
    x86.mov eax, [rbp-40]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-24], ecx
    x86.mov eax, [rbp-40]
    x86.mov rcx, [rbp-40]
    x86.call mm_decref
    x86.mov eax, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call mm_scope_exit
    x86.jmp refcount.main.inner_0.merge
  inner_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+0]
    x86.mov edx, [rbp-24]
    x86.add edx, ecx
    x86.mov [rbp-56], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8

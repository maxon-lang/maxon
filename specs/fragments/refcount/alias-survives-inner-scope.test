    x86.test rsi, rsi
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rdi, [rbp-16]
    x86.mov [rbp-8], rdi
    x86.mov r8, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov r9, [rbp-16]
    x86.test r9, r9
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.jmp refcount.main.blk_0.merge
  blk_0.merge:
    x86.mov rax, [rbp-8]
    x86.mov rcx, [rax+0]
    x86.mov [rbp-24], rcx
    x86.xor rdx, rdx

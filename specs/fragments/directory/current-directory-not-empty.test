// Test: current-directory-not-empty
function main() returns ExitCode
  let cwd = Directory.currentDirectory()
  if cwd.count() > 0 'ok'
    return 42
  end 'ok'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call stdlib.Directory.currentDirectory
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call stdlib.String.count
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jle directory.main.ok_0.after
  ok_0:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_1
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+0]
    x86.mov rcx, rdx
    x86.call mm_decref_if_owned
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_1
    x86.label __destruct_nullguard_0
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_3
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+0]
    x86.mov rcx, rdx
    x86.call mm_decref_if_owned
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_3
    x86.label __destruct_nullguard_2
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

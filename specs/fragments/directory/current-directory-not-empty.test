    x86.mov rcx, [rbp-8]
    x86.call stdlib.String.count
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jle directory.main.ok_0.after
  ok_0:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov rax, 42
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.mov rax, [rbp-8]
    x86.test rax, rax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_decref
    x86.label __nonnull_skip_1

// Test: current-directory-not-empty
function main() returns ExitCode
  let cwd = Directory.currentDirectory()
  if cwd.count() > 0 'ok'
    return 42
  end 'ok'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call stdlib.Directory.currentDirectory
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call stdlib.String.count
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jle directory.main.ok_0.after
  ok_0:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

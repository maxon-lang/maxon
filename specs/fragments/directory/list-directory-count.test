// Test: list-directory-count
function main() returns Integer
  let files = try Directory.list("../bin") otherwise 'err'
    return 99
  end 'err'
  // bin directory has at least maxon.exe
  if files.count() >= 1 'ok'
    return 42
  end 'ok'
  return files.count()
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.lea_rdata rax, [__str_0]
    x86.mov rcx, rax
    x86.mov edx, 6
    x86.mov ebx, 32
    x86.mov [rbp-40], ecx
    x86.mov rcx, rbx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-40]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 6
    x86.mov [r8+8], r9
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call stdlib.Directory.list
    x86.mov [rbp-24], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je directory.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, 99
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.mov ecx, [rbp-32]
    x86.call StringArray.count
    x86.mov edx, 1
    x86.cmp eax, edx
    x86.jl directory.main.ok_4.after
  ok_4:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  ok_4.after:
    x86.mov rcx, [rbp-32]
    x86.epilogue
    x86.jmp StringArray.count
  }
}
---

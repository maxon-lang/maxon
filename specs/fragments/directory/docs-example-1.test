// Test: docs-example-1
function main() returns ExitCode
  let files = try Directory.list("./") otherwise 'err'
    print("Failed to list directory")
    return 1
  end 'err'
  for f in files 'loop'
    print("{f}\n")
  end 'loop'
  return 0
end 'main'


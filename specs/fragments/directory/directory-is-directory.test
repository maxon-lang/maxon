// Test: directory-is-directory
function main() returns ExitCode
  if Directory.isDirectory("../bin") 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_rdata rax, [__str_1]
    x86.mov rcx, rax
    x86.mov edx, 6
    x86.mov ebx, 16
    x86.xor esi, esi
    x86.mov [rbp-24], ecx
    x86.mov rcx, rbx
    x86.mov rdx, rsi
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov edi, 32
    x86.xor r8, r8
    x86.mov rcx, rdi
    x86.mov rdx, rax
    x86.call mm_alloc_in
    x86.mov [rbp-16], eax
    x86.mov r9, [rbp-16]
    x86.mov eax, [rbp-24]
    x86.mov [r9+0], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 6
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call stdlib.Directory.isDirectory
    x86.test eax, eax
    x86.je directory.main.check_0.after
  check_0:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: directory-is-directory
function main() returns int
  if Directory.isDirectory("../bin") 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.lea_rdata rax, [__str_0]
    x86.mov rcx, rax
    x86.mov edx, 6
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.xor edi, edi
    x86.mov [rbp-8], edi
    x86.mov [rbp-16], esi
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.mov [rbp-40], ecx
    x86.lea r8, [rbp-40]
    x86.mov rcx, r8
    x86.call stdlib.Directory.isDirectory
    x86.test eax, eax
    x86.je directory.main.check_0.after
  check_0:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: list-directory
function main() returns int
  let files = try Directory.list("../bin") otherwise 'err'
    return 0
  end 'err'
  // bin directory should contain maxon.exe
  var foundMaxon = false
  for f in files 'loop'
    if f == "maxon.exe" 'check'
      foundMaxon = true
    end 'check'
  end 'loop'
  if foundMaxon 'result'
    return 42
  end 'result'
  return 1
end 'main'

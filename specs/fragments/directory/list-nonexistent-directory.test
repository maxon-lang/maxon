// Test: list-nonexistent-directory
function main() returns int
  var files = try Directory.list("nonexistent_dir_12345") otherwise 'err'
    print("Directory not found")
    return 0
  end 'err'
  print("Found {files.count()} files\n")
  return 1
end 'main'

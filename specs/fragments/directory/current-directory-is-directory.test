// Test: current-directory-is-directory
function main() returns ExitCode
  let cwd = Directory.currentDirectory()
  if Directory.exists(cwd) 'ok'
    return 42
  end 'ok'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @directory.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call stdlib.Directory.currentDirectory
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call stdlib.Directory.exists
    x86.test eax, eax
    x86.je directory.main.ok_0.after
  ok_0:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_13
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_14
    x86.mov [rbp-16], eax
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_14
    x86.label __destruct_nullguard_13
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  ok_0.after:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_15
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_16
    x86.mov [rbp-16], eax
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_16
    x86.label __destruct_nullguard_15
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

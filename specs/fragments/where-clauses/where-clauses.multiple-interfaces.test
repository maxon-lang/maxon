    x86.call mm_incref
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov esi, [rbp-16]
    x86.mov edi, [rbp-24]
    x86.mov [edi+0], esi
    x86.mov r8, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.mov r8, 1
    x86.call mm_move
    x86.mov r9, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, [rbp-24]
    x86.mov ecx, [eax+0]
    x86.mov [rbp-32], ecx
    x86.mov eax, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call Person.age
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx

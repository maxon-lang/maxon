// Test: where-clauses.user-defined
interface Valuable
    function value() returns Integer
end 'Valuable'

type Wrapper implements Valuable
    var n Integer

    function value() returns Integer
        return self.n
    end 'value'
end 'Wrapper'

type Holder uses T where T is Valuable
    export var item T
end 'Holder'

typealias WrapperHolder = Holder with Wrapper

function main() returns Integer
    var w = Wrapper{n: 10}
    var h = WrapperHolder{item: w}
    return h.item.value()
end 'main'
---
ExitCode: 10
---
module {
  func @Wrapper.value(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @where-clauses.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, [rbp-16]
    x86.mov eax, [r9+0]
    x86.mov [rbp-24], eax
    x86.mov rcx, [rbp-24]
    x86.epilogue
    x86.jmp Wrapper.value
  }
}
---

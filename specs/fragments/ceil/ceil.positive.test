// Test: ceil.positive
function main() returns Integer
  var x = 3.1
  var y = trunc(ceil(x))
  return y
end 'main'
---
ExitCode: 4
---
module {
  func @ceil.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.1]
    x86.roundsd xmm1, xmm0, 2
    x86.cvttsd2si eax, xmm1
    x86.ret
  }
}
---

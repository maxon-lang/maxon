// Test: ceil.exact
function main() returns int
  var x = 5.0
  var y = trunc(ceil(x))
  return y
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_5]
    x86.movsd [rbp-8], xmm0
    x86.roundsd xmm1, xmm0, 2
    x86.cvttsd2si eax, xmm1
    x86.mov [rbp-16], eax
    x86.epilogue
    x86.ret
  }
}
---

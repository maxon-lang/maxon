    x86.roundsd xmm1, xmm0, Ceil
    x86.cvttsd2si rax, xmm1
    x86.mov rcx, 10
    x86.mov rdx, rax
    x86.add rdx, rcx
    x86.mov rax, rdx
    x86.epilogue

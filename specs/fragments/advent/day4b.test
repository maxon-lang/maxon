// Test: day4b

typealias Integer = int(i64.min to i64.max)

function multiply(x Integer) returns Integer
    return x * 2
end 'multiply'

function main() returns ExitCode
  let args = CommandLine.args()
  let a = try int.fromString(try args.get(0) otherwise "") otherwise 0
  return multiply(3)
end 'main'

// Test: static-string-slice
function main() returns int
  var s = "hello world"
  var start = s.startIndex()
  var idx = try s.find(" ") otherwise s.endIndex()
  var sub = s.slice(start, endIndex: idx)
  print("{sub}\n")
  return 0
end 'main'

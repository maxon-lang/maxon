    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, 10
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.lea_rdata rax, [__const_array_vector.main_v]
    x86.mov rcx, rax
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+8]
    x86.mov [edx+0], ecx
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp vector.main.fill_1.header
  fill_1.header:
    x86.mov eax, 10
    x86.mov ecx, [rbp-24]
    x86.cmp ecx, eax
    x86.jge vector.main.fill_1.exit
  fill_1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 10
    x86.mov edx, [rbp-24]
    x86.imul edx, ecx
    x86.mov rcx, [rbp-16]
    x86.mov r8, rdx
    x86.mov rdx, rax
    x86.call Vec10.set
    x86.mov esi, 1
    x86.mov edi, [rbp-24]
    x86.add edi, esi
    x86.mov [rbp-24], edi
    x86.jmp vector.main.fill_1.header
  fill_1.exit:
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov rdx, rax
    x86.call Vec10.get
    x86.mov ecx, -1
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je vector.main.otherwise_default_continue_5
  otherwise_default_error_4:
    x86.mov eax, [rbp-32]

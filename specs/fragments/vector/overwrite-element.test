// Test: overwrite-element
typealias Vec3 = Vector with 3 int

function main() returns int
  var v = Vec3{}
  v.set(1, value: 10)
  v.set(1, value: 42)
  return try v.get(1) otherwise 0
end 'main'
---
ExitCode: 42
---

// Test: create-zero-initialized
typealias Vec3 = Vector with 3 int

function main() returns int
  var v = Vec3{}
  return try v.get(0) otherwise -1
end 'main'
---
ExitCode: 0
---
module {
  func @vector.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov ecx, 3
    x86.xor edx, edx
    x86.mov ebx, 8
    x86.lea_rdata rsi, [__const_array_vector.main_v]
    x86.mov rdi, rsi
    x86.xor r8, r8
    x86.mov [rbp-8], ebx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], eax
    x86.lea r9, [rbp-40]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Vec3.get
    x86.mov ecx, -1
    x86.mov [rbp-48], ecx
    x86.mov [rbp-56], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je vector.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-48]
    x86.mov [rbp-56], eax
    x86.jmp vector.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-56]
    x86.epilogue
    x86.ret
  }
}
---

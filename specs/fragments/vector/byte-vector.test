// Test: byte-vector
typealias ByteVec4 is Vector with 4 byte

function main() returns int
  var v = ByteVec4{}
  v.set(0, value: 10)
  v.set(1, value: 20)
  v.set(2, value: 30)
  v.set(3, value: 40)
  var a = try v.get(0) otherwise 0
  var b = try v.get(3) otherwise 0
  return (a as int) + (b as int)
end 'main'

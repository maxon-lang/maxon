// Test: get-out-of-bounds
typealias Vec2 = Vector with 2 int

function main() returns int
  var v = Vec2{}
  v.set(0, value: 10)
  var result = try v.get(5) otherwise -1
  return result
end 'main'
---
ExitCode: -1
---
module {
  func @vector.main() -> i64 {
  entry:
    x86.prologue stack_size=96
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.xor edx, edx
    x86.mov ebx, 8
    x86.lea_rdata rsi, [__const_array_vector.main_v]
    x86.mov rdi, rsi
    x86.xor r8, r8
    x86.mov r9, 10
    x86.mov [rbp-8], ebx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], eax
    x86.lea rax, [rbp-40]
    x86.mov rcx, rax
    x86.mov rdx, r8
    x86.mov r8, r9
    x86.call Vec2.set
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov ebx, [rbp-32]
    x86.mov esi, [rbp-40]
    x86.mov edi, 5
    x86.mov [rbp-48], eax
    x86.mov [rbp-56], ecx
    x86.mov [rbp-64], edx
    x86.mov [rbp-72], ebx
    x86.mov [rbp-80], esi
    x86.lea rax, [rbp-80]
    x86.mov rcx, rax
    x86.mov rdx, rdi
    x86.call Vec2.get
    x86.mov ecx, -1
    x86.mov [rbp-88], ecx
    x86.mov [rbp-96], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je vector.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-88]
    x86.mov [rbp-96], eax
    x86.jmp vector.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-96]
    x86.epilogue
    x86.ret
  }
}
---

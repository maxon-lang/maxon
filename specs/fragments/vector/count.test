// Test: count
typealias Vec4 = Vector with 4 int

function main() returns int
  var v = Vec4{}
  return v.count()
end 'main'
---
ExitCode: 4
---
module {
  func @vector.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov ecx, 4
    x86.xor edx, edx
    x86.mov ebx, 8
    x86.lea_rdata rsi, [__const_array_vector.main_v]
    x86.mov rdi, rsi
    x86.mov [rbp-8], ebx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], eax
    x86.lea r8, [rbp-40]
    x86.mov rcx, r8
    x86.call Vec4.count
    x86.epilogue
    x86.ret
  }
}
---

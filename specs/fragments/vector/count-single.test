// Test: count-single
typealias Int = int(i64.min to i64.max)
typealias Vec1 = Vector with 1 Int

function main() returns ExitCode
  var v = Vec1{}
  return v.count()
end 'main'
---
ExitCode: 1
---
module {
  func @vector.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov ebx, 1
    x86.xor esi, esi
    x86.mov edi, 8
    x86.mov rcx, 32
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov r8, [rbp-24]
    x86.xor r9, r9
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-32]
    x86.mov [ecx+8], eax
    x86.mov ecx, [rbp-32]
    x86.mov rcx, [rbp-24]
    x86.mov rdx, [rbp-32]
    x86.mov r8, 1
    x86.call mm_move
    x86.lea rax, [rbp-16]
    x86.mov rcx, rax
    x86.mov eax, [rbp-32]
    x86.mov edx, [eax+8]
    x86.mov [edx+0], ecx
    x86.mov eax, [rbp-32]
    x86.mov rcx, [rbp-32]
    x86.call Vec1.count
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je vector.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
}

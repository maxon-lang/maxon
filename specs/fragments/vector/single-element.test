    x86.xor eax, eax
    x86.mov ecx, 77
    x86.mov edx, [rbp-16]
    x86.mov r8, rcx
    x86.mov rcx, rdx
    x86.mov rdx, rax
    x86.call Vec1.set
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]

// Test: docs-example-1
function factorial(n int) returns int
    if n <= 1 'base'
        return 1
    end 'base'
    return n * factorial(n - 1)
end 'factorial'

function main() returns int
    return factorial(5)  // Returns 120
end 'main'

---
ExitCode: 120
---
func.func @factorial(%n: i64) -> i64 {
  ^entry(%n: i64):
    x86.prologue stack_size=40 saved_gprs=[RBX]
    x86.mov rbx, rcx
    x86.mov rax, 1
    x86.cmp rbx, rax
    x86.setle rax
    x86.movzx rax, rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 1
    x86.epilogue saved_gprs=[RBX]
    x86.ret
  ^merge:
    x86.mov rax, 1
    x86.mov rcx, rbx
    x86.sub rcx, rax
    x86.mov rcx, rcx
    x86.call factorial
    x86.mov rcx, rax
    x86.imul rax, rbx, rcx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 5
    x86.call factorial
    x86.epilogue
    x86.ret
}
---

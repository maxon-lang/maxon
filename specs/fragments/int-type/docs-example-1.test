// Test: docs-example-1
function factorial(n int) returns int
    if n <= 1 'base'
        return 1
    end 'base'
    return n * factorial(n - 1)
end 'factorial'

function main() returns int
    return factorial(5)  // Returns 120
end 'main'

---
ExitCode: 120

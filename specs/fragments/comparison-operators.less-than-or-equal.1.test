// Test: comparison-operators.less-than-or-equal.1
function main() returns int
    var a = 5
    var b = 10
    if a <= b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 10
    %tmp_icmp = icmp.le i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

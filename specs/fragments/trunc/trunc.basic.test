// Test: trunc.basic
function main() returns int
  var neg = 0.0 - 3.7
  var y = trunc(neg)
  return y + 10
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_3.7]
    x86.movsd xmm2, xmm0
    x86.subsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.mov ecx, 10
    x86.add eax, ecx
    x86.ret
  }
}
---

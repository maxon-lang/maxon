// Test: trunc.positive
function main() returns int
    var x = 7.9
    var y = trunc(x)
    return y
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_7.9]
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.mov [rbp-16], eax
    x86.epilogue
    x86.ret
  }
}

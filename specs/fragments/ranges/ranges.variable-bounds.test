// Test: ranges.variable-bounds
function main() returns int
    var start = 2
    var finish = 4
    var sum = 0
    for i in start to finish 'loop'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 9
---
module {
  func @ranges.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 2
    x86.mov ecx, 4
    x86.xor edx, edx
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.jmp ranges.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.cmp eax, ecx
    x86.jg ranges.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-24]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-24], ecx
    x86.mov ebx, [rbp-8]
    x86.add ebx, eax
    x86.mov [rbp-8], ebx
    x86.jmp ranges.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

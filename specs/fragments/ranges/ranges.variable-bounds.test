// Test: ranges.variable-bounds
function main() returns ExitCode
    var start = 2
    var finish = 4
    var sum = 0
    for i in start to finish 'loop'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 9
---
module {
  func @ranges.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 2
    x86.mov ecx, 4
    x86.xor edx, edx
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.jmp ranges.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.cmp eax, ecx
    x86.jg ranges.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp ranges.main.loop_0.incr
  loop_0.incr:
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.add ecx, eax
    x86.mov [rbp-24], ecx
    x86.jmp ranges.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je ranges.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

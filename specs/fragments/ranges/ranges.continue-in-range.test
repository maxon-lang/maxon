// Test: ranges.continue-in-range
function main() returns int
    var sum = 0
    for i in 1 to 10 'loop'
        if i mod 2 == 0 'skip'
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
ExitCode: 25
---
module {
  func @ranges.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, 10
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.jmp ranges.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.cmp eax, ecx
    x86.jg ranges.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-24], ecx
    x86.mov ebx, 2
    x86.cqo
    x86.idiv ebx
    x86.xor esi, esi
    x86.cmp edx, esi
    x86.jne ranges.main.skip_1.after
  skip_1:
    x86.jmp ranges.main.loop_0.header
  skip_1.after:
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-32]
    x86.add eax, ecx
    x86.mov [rbp-8], eax
    x86.jmp ranges.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

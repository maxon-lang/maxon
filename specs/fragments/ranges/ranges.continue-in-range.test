// Test: ranges.continue-in-range
function main() returns ExitCode
    var sum = 0
    for i in 1 to 10 'loop'
        if i mod 2 == 0 'skip'
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'

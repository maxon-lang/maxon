// Test: ranges.break-in-range
function main() returns ExitCode
    var last = 0
    for i in 1 to 100 'loop'
        last = i
        if i == 5 'done'
            break
        end 'done'
    end 'loop'
    return last
end 'main'
---
ExitCode: 5
---
module {
  func @ranges.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, 1
    x86.mov edx, 100
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.jmp ranges.main.loop_0.header
  loop_0.header:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.cmp eax, ecx
    x86.jg ranges.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-24]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov [rbp-24], ecx
    x86.mov [rbp-8], eax
    x86.mov ebx, 5
    x86.cmp eax, ebx
    x86.jne ranges.main.done_1.after
  done_1:
    x86.jmp ranges.main.loop_0.exit
  done_1.after:
    x86.jmp ranges.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je ranges.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_18]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

// Test: first-class-function.basic-reference
function double(x int) returns int
  return x * 2
end 'double'

function main() returns int
  var f = double
  return f(21)
end 'main'
---
ExitCode: 42
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func eax, [first-class-functions.double]
    x86.mov ecx, 21
    x86.xor edx, edx
    x86.mov [rbp-8], eax
    x86.mov r10, eax
    x86.call r10
    x86.epilogue
    x86.ret
  }
}
---

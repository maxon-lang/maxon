// Test: first-class-function.multiple-params
function calculate(f (int, int) returns int, a int, b int) returns int
  return f(a, b)
end 'calculate'

function add(x int, y int) returns int
  return x + y
end 'add'

function main() returns int
  return calculate(add, a: 15, b: 27)
end 'main'
---
ExitCode: 42
---
module {
  func @calculate(f: fn(i64, i64) returns i64, a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], r8
    x86.mov r10, ecx
    x86.mov rcx, rdx
    x86.mov rdx, r8
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @add(x: i64, y: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.lea_func eax, [add]
    x86.mov ecx, 15
    x86.mov edx, 27
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call calculate
    x86.ret
  }
}

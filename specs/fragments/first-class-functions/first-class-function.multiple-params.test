// Test: first-class-function.multiple-params
function calculate(f (Integer, Integer) returns Integer, a Integer, b Integer) returns Integer
  return f(a, b)
end 'calculate'

function add(x Integer, y Integer) returns Integer
  return x + y
end 'add'

function main() returns Integer
  return calculate(add, a: 15, b: 27)
end 'main'
---
ExitCode: 42
---
module {
  func @first-class-functions.calculate(f: i64, __env_f: i64, a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov r10, ecx
    x86.mov rcx, r8
    x86.mov r8, rdx
    x86.mov rdx, r9
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @first-class-functions.add(x: i64, y: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @first-class-functions.main() -> i64 {
  entry:
    x86.lea_func eax, [first-class-functions.add]
    x86.mov ecx, 15
    x86.mov edx, 27
    x86.xor ebx, ebx
    x86.mov r8, rcx
    x86.mov r9, rdx
    x86.mov rcx, rax
    x86.mov rdx, rbx
    x86.jmp first-class-functions.calculate
  }
}
---

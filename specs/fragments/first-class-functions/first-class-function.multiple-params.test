// Test: first-class-function.multiple-params

typealias Integer = int(i64.min to i64.max)

function calculate(f (Integer, Integer) returns Integer, a Integer, b Integer) returns Integer
  return f(a, b)
end 'calculate'

function add(x Integer, y Integer) returns Integer
  return x + y
end 'add'

function main() returns ExitCode
  return calculate(add, a: 15, b: 27)
end 'main'
---
ExitCode: 42
---
module {
  func @first-class-functions.calculate(f: i64, __env_f: i64, a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov r10, ecx
    x86.mov rcx, r8
    x86.mov r8, rdx
    x86.mov rdx, r9
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @first-class-functions.add(x: i64, y: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @first-class-functions.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func eax, [first-class-functions.add]
    x86.mov rcx, rax
    x86.xor rdx, rdx
    x86.mov r8, 15
    x86.mov r9, 27
    x86.call first-class-functions.calculate
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je first-class-functions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

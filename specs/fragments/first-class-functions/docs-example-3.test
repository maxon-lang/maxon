// Test: docs-example-3
function main() returns int
  var f = (x int) gives x * 2
  return f(21)  // returns 42
end 'main'

---
ExitCode: 42
---
module {
  func @first-class-functions.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func eax, [__closure_0]
    x86.mov ecx, 21
    x86.mov [rbp-8], eax
    x86.mov r10, eax
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @__closure_0(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
}

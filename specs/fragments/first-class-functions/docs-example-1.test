// Test: docs-example-1
function double(x int) returns int
  return x * 2
end 'double'

function main() returns int
  var f = double      // f is a function reference
  return f(21)        // calls double(21), returns 42
end 'main'

---
ExitCode: 42
---
module {
  func @double(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.lea_func eax, [double]
    x86.mov [rbp-8], eax
    x86.mov ecx, 21
    x86.call eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: first-class-function.closure-as-argument
function apply(f (int) returns int, x int) returns int
  return f(x)
end 'apply'

function main() returns int
  return apply((n int) gives n + 7, x: 10)
end 'main'
---
ExitCode: 17
---
module {
  func @first-class-functions.apply(f: fn(i64) returns i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov r10, ecx
    x86.mov rcx, rdx
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @first-class-functions.main() -> i64 {
  entry:
    x86.lea_func eax, [__closure_0]
    x86.mov ecx, 10
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp first-class-functions.apply
  }
  func @__closure_0(n: i64) -> i64 {
  entry:
    x86.mov eax, 7
    x86.lea eax, [ecx + eax]
    x86.ret
  }
}

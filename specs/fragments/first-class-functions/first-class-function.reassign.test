// Test: first-class-function.reassign
function double(x int) returns int
  return x * 2
end 'double'

function triple(x int) returns int
  return x * 3
end 'triple'

function main() returns int
  var f = double
  var a = f(10)
  f = triple
  var b = f(10)
  return a + b
end 'main'
---
ExitCode: 50
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.triple(x: i64) -> i64 {
  entry:
    x86.mov eax, 3
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.lea_func eax, [first-class-functions.double]
    x86.mov ecx, 10
    x86.xor edx, edx
    x86.mov [rbp-8], eax
    x86.mov r10, eax
    x86.call r10
    x86.lea_func ebx, [first-class-functions.triple]
    x86.mov esi, 10
    x86.xor edi, edi
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ebx
    x86.mov r10, ebx
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call r10
    x86.mov r8, [rbp-16]
    x86.lea eax, [r8 + eax]
    x86.epilogue
    x86.ret
  }
}
---

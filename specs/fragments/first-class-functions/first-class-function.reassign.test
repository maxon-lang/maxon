// Test: first-class-function.reassign

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
  return x * 2
end 'double'

function triple(x Integer) returns Integer
  return x * 3
end 'triple'

function main() returns ExitCode
  var f = double
  var a = f(10)
  f = triple
  var b = f(10)
  return a + b
end 'main'
---
ExitCode: 50
---
module {
  func @first-class-functions.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.triple(x: i64) -> i64 {
  entry:
    x86.mov eax, 3
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_func eax, [first-class-functions.double]
    x86.mov ecx, 10
    x86.xor edx, edx
    x86.mov [rbp-16], eax
    x86.mov r10, eax
    x86.call r10
    x86.lea_func ebx, [first-class-functions.triple]
    x86.mov esi, 10
    x86.xor edi, edi
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], ebx
    x86.mov r10, ebx
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call r10
    x86.mov r8, [rbp-24]
    x86.add r8, eax
    x86.mov [rbp-8], r8
    x86.xor r9, r9
    x86.cmp r8, r9
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rcx, 4294967295
    x86.cmp r8, rcx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je first-class-functions.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_18]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

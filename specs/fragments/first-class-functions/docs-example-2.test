// Test: docs-example-2
function apply(f (Integer) returns Integer, x Integer) returns Integer
  return f(x)
end 'apply'

function triple(n Integer) returns Integer
  return n * 3
end 'triple'

function main() returns Integer
  return apply(triple, x: 10)  // returns 30
end 'main'

---
ExitCode: 30
---
module {
  func @first-class-functions.apply(f: i64, __env_f: i64, x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov r10, ecx
    x86.mov rcx, r8
    x86.call r10
    x86.epilogue
    x86.ret
  }
  func @first-class-functions.triple(n: i64) -> i64 {
  entry:
    x86.mov eax, 3
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @first-class-functions.main() -> i64 {
  entry:
    x86.lea_func eax, [first-class-functions.triple]
    x86.mov ecx, 10
    x86.xor edx, edx
    x86.mov r8, rcx
    x86.mov rcx, rax
    x86.jmp first-class-functions.apply
  }
}
---

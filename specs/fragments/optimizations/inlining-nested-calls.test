// Test: inlining-nested-calls
function double(x int) returns int
    return x * 2
end 'double'

function quadruple(x int) returns int
    return double(double(x))
end 'quadruple'

function main() returns int
    return quadruple(5)
end 'main'
---
ExitCode: 20
RequiredMlir: ```
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 20
    x86.epilogue
    x86.ret
}
```

// Test: licm-deeply-nested-correctness
function main() returns int
    var result = 0
    var a = 0
    while a < 2 'outer'
        var b = 0
        while b < 2 'middle'
            var c = 0
            while c < 2 'inner'
                result = result + 1
                c = c + 1
            end 'inner'
            b = b + 1
        end 'middle'
        a = a + 1
    end 'outer'
    return result
end 'main'

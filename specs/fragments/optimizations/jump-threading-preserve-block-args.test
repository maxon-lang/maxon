    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, r9
    x86.add rdx, r10
    x86.mov rax, r10
    x86.add rax, r8
    x86.mov r9, rdx
    x86.mov r10, rax
    x86.jmp while.cond
  ^while.exit:

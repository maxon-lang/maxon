ExitCode: 20
RequiredMlir: ```
module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rax, 10
      x86.sub rsp, 8
      x86.lea rcx, qword ptr [rsp]
      x86.mov qword ptr [rcx], rax
      x86.mov rdx, qword ptr [rcx]
      x86.mov r8, 1
      x86.mov r9, rdx
      x86.shl r9, r8
      x86.mov rax, r9
      x86.epilogue
      x86.ret
  }
}

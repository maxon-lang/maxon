// Test: licm-no-hoist-load-with-store
function main() returns int
    var y = 0
    var i = 0
    while i < 3 'loop'
        y = y + 1
        i = i + 1
    end 'loop'
    return y
end 'main'
---
ExitCode: 3
RequiredMlir: ```
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 0
    x86.mov rcx, 3
    x86.mov r8, 1
    x86.mov r9, rax
    x86.mov r10, rax
    x86.jmp while.cond
  ^while.cond(%14: i64, %16: i64):
    x86.cmp r10, rcx
    x86.setl rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit
  ^while.body:
    x86.mov rdx, r9
    x86.add rdx, r8
    x86.mov rax, r10
    x86.add rax, r8
    x86.mov r9, rdx
    x86.mov r10, rax
    x86.jmp while.cond
  ^while.exit:
    x86.mov rax, r9
    x86.epilogue
    x86.ret
}
```

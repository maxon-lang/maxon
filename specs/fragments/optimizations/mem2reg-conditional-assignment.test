// Test: mem2reg-conditional-assignment
function test(cond int) returns int
    var x = 0
    if cond > 0 'check'
        x = 10
    end 'check' else 'else'
        x = 20
    end 'else'
    return x
end 'test'

function main() returns int
    return test(1)
end 'main'
---
ExitCode: 10
RequiredMlir: ```
func.func @test(%cond: i64) -> i64 {
  ^entry(%cond: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, 0
    x86.cmp rax, rcx
    x86.setg rcx
    x86.test rcx, rcx
    x86.jne then
    x86.jmp else
  ^then:
    x86.mov rax, 10
    x86.jmp merge
  ^else:
    x86.mov rax, 20
    x86.jmp merge
  ^merge(%11: i64):
    x86.epilogue
    x86.ret
}
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 1
    x86.call test
    x86.epilogue
    x86.ret
}
```

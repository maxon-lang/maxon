// Test: mem2reg-conditional-assignment
function main() returns int
    var x = 0
    if true 'check'
        x = 10
    end 'check' else 'else'
        x = 20
    end 'else'
    return x
end 'main'
---
ExitCode: 10
RequiredMlir: ```
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.test rax, rax
    x86.jne then
    x86.jmp else
  ^then:
    x86.mov rcx, 10
    x86.jmp merge
  ^else:
    x86.mov rcx, 20
    x86.jmp merge
  ^merge(%6: i64):
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
```

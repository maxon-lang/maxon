// Test: mem2reg-loop-variable
function main() returns int
    var sum = 0
    var i = 1
    while i <= 5 'loop'
        sum = sum + i
        i = i + 1
    end 'loop'
    return sum
end 'main'
---
ExitCode: 15
RequiredMlir: ```
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov r8, 0
    x86.mov r9, 1
    x86.jmp while.cond
  ^while.cond(%15: i64, %18: i64):
    x86.mov rdx, 5
    x86.cmp r9, rdx
    x86.setle rdx
    x86.test rdx, rdx
    x86.jne while.body
    x86.jmp while.exit.args
    while.exit.args:
    x86.mov rdx, r8
    x86.jmp while.exit
  ^while.body:
    x86.mov rax, r8
    x86.add rax, r9
    x86.mov rcx, 1
    x86.mov r10, r9
    x86.add r10, rcx
    x86.mov r8, rax
    x86.mov r9, r10
    x86.jmp while.cond
  ^while.exit(%16: i64):
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

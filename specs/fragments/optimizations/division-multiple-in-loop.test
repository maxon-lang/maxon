// Test: division-multiple-in-loop
function main() returns int
    var sum = 0
    var i = 1
    while i <= 10 'loop'
        sum = sum + (i / 2) + (i mod 3)
        i = i + 1
    end 'loop'
    return sum
end 'main'
---

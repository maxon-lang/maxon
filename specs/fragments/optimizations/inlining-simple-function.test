// Test: inlining-simple-function
function add(a int, b int) returns int
    return a + b
end 'add'

function main() returns int
    return add(3, b: 4)
end 'main'
---
ExitCode: 7
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 7
    x86.epilogue
    x86.ret
}
---

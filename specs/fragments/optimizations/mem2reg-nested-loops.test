// Test: mem2reg-nested-loops
function main() returns int
    var total = 0
    var i = 1
    while i <= 3 'outer'
        var j = 1
        while j <= 3 'inner'
            total = total + i * j
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return total
end 'main'
---
ExitCode: 36
RequiredMlir: ```

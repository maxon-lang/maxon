  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov qword ptr [rcx], rax
    x86.mov rax, 1
    x86.mov r8, rax
    x86.jmp while.cond
  ^while.cond(%25: i64):
    x86.mov rdx, 3
    x86.cmp r8, rdx
    x86.setle rdx

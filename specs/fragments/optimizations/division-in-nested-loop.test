// Test: division-in-nested-loop
function main() returns int
    var result = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            result = result + ((i + j) mod 2)
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return result
end 'main'

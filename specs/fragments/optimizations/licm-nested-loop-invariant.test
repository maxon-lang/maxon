// Test: licm-nested-loop-invariant
function main() returns int
    var total = 0
    var i = 1
    while i <= 3 'outer'
        var j = 1
        while j <= 2 'inner'
            total = total + i
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return total
end 'main'

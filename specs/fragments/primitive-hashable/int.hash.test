// Test: int.hash
function main() returns ExitCode
  var i = 42
  var h = i.hash()
  return h
end 'main'
---
ExitCode: 42
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 42
    x86.call stdlib.int.hash
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx

// Test: int.equals.different
function main() returns int
  var a = 42
  var b = 17
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-hashable.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.mov ecx, 17
    x86.cmp eax, ecx
    x86.jne primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov eax, 1
    x86.ret
  eq_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: int.equals.different
function main() returns ExitCode
  var a = 42
  var b = 17
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.mov rcx, 42
    x86.mov rdx, 17
    x86.call stdlib.int.equals
    x86.test rax, rax
    x86.je primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov rax, 1
    x86.ret
  eq_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

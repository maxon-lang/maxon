// Test: bool.equals
function main() returns ExitCode
  var a = true
  var b = true
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call stdlib.bool.equals
    x86.test eax, eax
    x86.je primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov eax, 1
    x86.ret
  eq_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: float.hash.nonzero
function main() returns ExitCode
  var f = 3.14
  var h = f.hash()
  if h != 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_3.14]
    x86.call stdlib.float.hash
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.je primitive-hashable.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

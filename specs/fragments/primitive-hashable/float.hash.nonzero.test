// Test: float.hash.nonzero
function main() returns int
  var f = 3.14
  var h = f.hash()
  if h != 0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.14]
    x86.movq eax, xmm0
    x86.mov rcx, -9223372036854775808
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, 1
    x86.sub ebx, edx
    x86.imul eax, ebx
    x86.xor esi, esi
    x86.cmp eax, esi
    x86.je primitive-hashable.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}

// Test: float.hash.zero-normalization
function main() returns ExitCode
  var pos = 0.0
  var neg = -0.0
  var h1 = pos.hash()
  var h2 = neg.hash()
  if h1 == h2 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.movsd [rbp-8], xmm1
    x86.call stdlib.float.hash
    x86.mov [rbp-16], eax
    x86.movsd xmm1, [rbp-8]
    x86.movsd xmm0, xmm1
    x86.call stdlib.float.hash
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jne primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  eq_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

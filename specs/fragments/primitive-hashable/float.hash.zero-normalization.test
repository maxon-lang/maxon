// Test: float.hash.zero-normalization
function main() returns int
  var pos = 0.0
  var neg = -0.0
  var h1 = pos.hash()
  var h2 = neg.hash()
  if h1 == h2 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @primitive-hashable.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_0]
    x86.movq eax, xmm0
    x86.mov rcx, -9223372036854775808
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, 1
    x86.sub ebx, edx
    x86.imul eax, ebx
    x86.movq esi, xmm1
    x86.mov rdi, -9223372036854775808
    x86.cmp esi, edi
    x86.sete r8
    x86.movzx r8, r8b
    x86.mov r9, 1
    x86.sub r9, r8
    x86.imul esi, r9
    x86.cmp eax, esi
    x86.jne primitive-hashable.main.eq_0.after
  eq_0:
    x86.mov eax, 1
    x86.ret
  eq_0.after:
    x86.xor eax, eax
    x86.ret
  }
}

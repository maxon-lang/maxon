// Test: chained-byte-int-float
function main() returns Integer
  var b = 25 as Byte
  var i = b as Integer
  var f = i as Float
  return trunc(f)
end 'main'
---
ExitCode: 25
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.mov eax, 25
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.cvtsi2sd xmm0, eax
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}
---

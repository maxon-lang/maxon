// Test: int-literal-to-float
function main() returns int
  var f = 99 as float
  return trunc(f)
end 'main'
---
ExitCode: 99
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 99
    x86.cvtsi2sd xmm0, eax
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si ecx, xmm0
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

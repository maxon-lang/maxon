// Test: same-type-byte
function main() returns ExitCode
  var b = 42 as Byte
  var c = b as Byte
  return c as Integer
end 'main'
---
ExitCode: 42
---
module {
  func @type-casting.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 255
    x86.and eax, edx
    x86.mov [rbp-8], eax
    x86.xor ebx, ebx
    x86.cmp eax, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je type-casting.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

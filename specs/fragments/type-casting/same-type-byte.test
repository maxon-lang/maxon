// Test: same-type-byte
function main() returns int
  var b = 42 as byte
  var c = b as byte
  return c as int
end 'main'
---
ExitCode: 42
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov edx, 255
    x86.and eax, edx
    x86.ret
  }
}
---

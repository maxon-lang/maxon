// Test: same-type-float
function main() returns int
  var f = 42.0
  var g = f as float
  return trunc(g)
end 'main'
---
ExitCode: 42
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_42]
    x86.movsd [rbp-8], xmm0
    x86.movsd [rbp-16], xmm0
    x86.cvttsd2si eax, xmm0
    x86.epilogue
    x86.ret
  }
}
---

// Test: byte-to-int
function main() returns int
  var b = 100 as byte
  return b as int
end 'main'
---
ExitCode: 100
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov [rbp-8], eax
    x86.epilogue
    x86.ret
  }
}
---

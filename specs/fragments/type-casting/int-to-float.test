// Test: int-to-float
function main() returns int
  var x = 42
  var f = x as float
  return trunc(f)
end 'main'
---
ExitCode: 42
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.cvtsi2sd xmm0, eax
    x86.movsd [rbp-16], xmm0
    x86.cvttsd2si ecx, xmm0
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

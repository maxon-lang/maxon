// Test: byte-to-float
function main() returns int
  var b = 50 as byte
  var f = b as float
  return trunc(f)
end 'main'
---
ExitCode: 50
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 50
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.mov [rbp-8], eax
    x86.cvtsi2sd xmm0, eax
    x86.movsd [rbp-16], xmm0
    x86.cvttsd2si edx, xmm0
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
}
---

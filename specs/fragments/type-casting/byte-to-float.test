// Test: byte-to-float
function main() returns Integer
  var b = 50 as Byte
  var f = b as Float
  return trunc(f)
end 'main'
---
ExitCode: 50
---
module {
  func @type-casting.main() -> i64 {
  entry:
    x86.mov eax, 50
    x86.mov ecx, 255
    x86.and eax, ecx
    x86.cvtsi2sd xmm0, eax
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}
---

// Test: square
function main() returns Integer
  var result = Math.pow(5.0, exponent: 2.0)
  return trunc(result)
end 'main'
---
ExitCode: 25
---
module {
  func @pow.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_5]
    x86.movsd xmm1, [rip+__float_2]
    x86.call stdlib.Math.pow
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}
---

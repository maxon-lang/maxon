// Test: float-type-disambiguation
typealias Integer = int(i64.min to i64.max)
typealias Decimal = float(f64.min to f64.max)

function measure(value Integer) returns Integer
  return value
end 'measure'

function measure(value Decimal) returns Integer
  return trunc(value)
end 'measure'

function main() returns ExitCode
  return measure(42.0)
end 'main'
---
ExitCode: 42
---
module {
  func @function-overloads.measure$value_f64(value: f64) -> i64 {
  entry:
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
  func @function-overloads.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_42]
    x86.call function-overloads.measure$value_f64
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je function-overloads.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

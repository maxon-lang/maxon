    x86.mov rcx, [rbp-8]
    x86.call mm_incref
    x86.mov ecx, [rbp-8]
    x86.mov rdx, 21
    x86.call Converter.convert$value_i64
    x86.mov [rbp-16], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je function-overloads.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_23]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @__destruct_Converter(ptr: i64) {
  entry:
    x86.jmp __destruct_Converter.done

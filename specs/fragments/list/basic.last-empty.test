    x86.mov r8, [rbp-16]
    x86.xor r9, r9
    x86.mov [r8+8], r9
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+24], ecx
    x86.xor eax, eax
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+0], eax
    x86.mov ecx, [rbp-24]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, [rbp-24]
    x86.mov r8, 1
    x86.call mm_move
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call IntList.last
    x86.mov ecx, 99
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je list.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-40], eax
    x86.jmp list.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-40]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je list.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-24]
    x86.call mm_decref
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]

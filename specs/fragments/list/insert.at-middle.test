// Test: insert.at-middle
function main() returns ExitCode
  var list = List from [10, 30]
  list.insert(at: 1, value: 20)
  var v0 = try list.get(0) otherwise 0
  var v1 = try list.get(1) otherwise 0
  var v2 = try list.get(2) otherwise 0
  print("{v0}\n")
  print("{v1}\n")
  print("{v2}\n")
  return 0
end 'main'

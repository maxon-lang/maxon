// Test: memory.remove-frees-strings
typealias StringList = List with String

function testRemove()
  var list = StringList{}
  list.append("hello world!!!!!!!!!!!!!!")
  list.append("goodbye world!!!!!!!!!!!!!")
  var removed = try list.removeFirst() otherwise "none"
  print("{removed}\n")
  print("{list.count()}\n")
end 'testRemove'

function main() returns ExitCode
  testRemove()
  return 0
end 'main'

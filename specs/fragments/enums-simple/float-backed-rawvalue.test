// Test: float-backed-rawvalue
enum Weights
  light = 1.5
  medium = 2.5
  heavy = 3.5
end 'Weights'

function main() returns Integer
  var w = Weights.medium
  var rawVal = w.rawValue
  if rawVal > 2.0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rbp-8]
    x86.movsd xmm2, [rip+__float_2]
    x86.ucomisd xmm1, xmm2
    x86.jbe enums-simple.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: simple-enum
enum Direction
  north
  south
  east
  west
end 'Direction'

function main() returns int
  var dir = Direction.north
  if dir == Direction.north 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

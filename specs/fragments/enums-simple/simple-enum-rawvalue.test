// Test: simple-enum-rawvalue
enum Direction
  north
  south
  east
end 'Direction'

function main() returns int
  var d = Direction.south
  return d.rawValue
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

// Test: enum-comparison
enum Status
  pending
  active
  done
end 'Status'

function main() returns ExitCode
  var s1 = Status.pending
  match s1 'check'
    Status.pending then return 1
    Status.active then return 0
    Status.done then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp enums-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.cmp2
  check_0.case1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.cmp2:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.merge
  check_0.case2:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

// Test: enum-assignment
enum Color
  red
  green
  blue
end 'Color'

function main() returns int
  var c = Color.red
  c = Color.blue
  if c == Color.blue 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.mov edx, [rbp-8]
    x86.cmp edx, ecx
    x86.jne enums-simple.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: enum-assignment
enum Color
  red
  green
  blue
end 'Color'

function main() returns ExitCode
  var c = Color.red
  c = Color.blue
  var result = match c 'check'
    Color.red gives 0
    Color.green gives 0
    Color.blue gives 1
  end 'check'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.xor edx, edx
    x86.mov [rbp-16], edx
    x86.mov [rbp-24], ecx
    x86.jmp enums-simple.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.cmp1
  check_0.case0:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp enums-simple.main.check_0.merge
  check_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.cmp2
  check_0.case1:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp enums-simple.main.check_0.merge
  check_0.cmp2:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne enums-simple.main.check_0.merge
  check_0.case2:
    x86.mov eax, 1
    x86.mov [rbp-16], eax
    x86.jmp enums-simple.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enums-simple.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}

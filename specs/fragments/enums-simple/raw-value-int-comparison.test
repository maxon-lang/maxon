// Test: raw-value-int-comparison
enum Priority
  low = 1
  medium = 5
  high = 10
end 'Priority'

function main() returns int
  var p = Priority.high
  if p.rawValue > 5 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.cmp eax, ecx
    x86.jle enums-simple.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

// Test: keyword-case-with-method
enum TokenType
  function
  return
  end
  if

  function isKeyword() returns bool
    return true
  end 'isKeyword'
end 'TokenType'

function main() returns ExitCode
  var t = TokenType.function
  if t.isKeyword() 'check'
    return t.rawValue
  end 'check'
  return 99
end 'main'
---
ExitCode: 0
---
module {
  func @TokenType.isKeyword(self: i64) -> i1 {
  entry:
    x86.mov eax, 1
    x86.ret
  }
  func @enums-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.call TokenType.isKeyword
    x86.test eax, eax
    x86.je enums-simple.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enums-simple.main.__range_ok_1
  __range_panic_1:
    x86.lea_rdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 99
    x86.epilogue
    x86.ret
  }
}
---

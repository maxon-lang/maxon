// Test: float-rawvalue-in-function
enum Weights
  light = 1.5
  medium = 2.5
end 'Weights'

function getRaw(w Weights) returns float
  return w.rawValue
end 'getRaw'

function main() returns int
  var w = Weights.medium
  var raw = getRaw(w)
  if raw > 2.0 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @getRaw(w: f64) -> f64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd [rbp-8], xmm0
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd [rbp-8], xmm0
    x86.call getRaw
    x86.movsd [rbp-16], xmm0
    x86.movsd xmm1, [rip+__float_2]
    x86.ucomisd xmm0, xmm1
    x86.jbe main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

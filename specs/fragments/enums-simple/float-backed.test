// Test: float-backed
enum FloatBacked
  North = 1.1
  South = 2.2
  East = 3.3
end 'FloatBacked'

function main() returns int
  var f = FloatBacked.North
  if f == FloatBacked.South 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_1.1]
    x86.movsd xmm1, [rip+__float_2.2]
    x86.ucomisd xmm0, xmm1
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

// Test: keyword-as-case-name
enum TokenType
  function
  return
  end
  if
  else
  let
  var
  identifier
end 'TokenType'

function main() returns ExitCode
  var t = TokenType.function
  if t == TokenType.function 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enums-simple.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov edx, [rbp-8]
    x86.cmp edx, ecx
    x86.jne enums-simple.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

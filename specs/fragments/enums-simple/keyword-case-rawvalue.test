// Test: keyword-case-rawvalue
enum TokenType
  function
  return
  end
  if
end 'TokenType'

function main() returns int
  var t = TokenType.end
  return t.rawValue
end 'main'
---
ExitCode: 2
---
module {
  func @enums-simple.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 2
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

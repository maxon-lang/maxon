// Test: enum-not-equal
enum Status
  pending
  active
  done
end 'Status'

function main() returns int
  var s = Status.pending
  if s != Status.active 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.je main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

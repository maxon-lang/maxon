// Test: enum-struct-field-match-direct
typealias SmallInt = int(0 to u8.max)

export union Shape
    circle(radius SmallInt)
    square(side SmallInt)
end 'Shape'

export type Drawing
    export var shape Shape
end 'Drawing'

function isCircle(d Drawing) returns bool
    match d.shape 'ms'
        circle(radius) then return true
        square(side) then return false
    end 'ms'
    return false
end 'isCircle'

function main() returns ExitCode
    let d = Drawing{shape: Shape.circle(10)}
    if isCircle(d) 'ok'
        return 1
    end 'ok'
    return 0
end 'main'

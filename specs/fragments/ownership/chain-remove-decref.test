// Test: chain-remove-decref
typealias Integer = int(i64.min to i64.max)

type Item
  export var value Integer
end 'Item'

typealias ItemChain = __Chain with Item

function main() returns ExitCode
  var chain = ItemChain{}
  var node = chain.insertFirst(Item{value: 50})
  chain.remove(node)
  print("{chain.count()}\n")
  return 0
end 'main'

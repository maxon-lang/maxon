// Test: break-cleanup
typealias Integer = int(i64.min to i64.max)

type Counter
  export var val Integer
end 'Counter'

function main() returns ExitCode
  var total = 0
  var i = 0
  while i < 5 'loop'
    var c = Counter{val: i}
    if i == 3 'brk'
      total = total + c.val
      break
    end 'brk'
    total = total + c.val
    i = i + 1
  end 'loop'
  print("{total}\n")
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
6
```

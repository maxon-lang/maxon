// Test: if-then-block-cleanup
typealias Integer = int(i64.min to i64.max)

type Widget
  export var id Integer
end 'Widget'

function main() returns ExitCode
  var result = 0
  if true 'check'
    var w = Widget{id: 5}
    result = w.id
  end 'check'
  print("{result}\n")
  return 0
end 'main'

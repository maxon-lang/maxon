// Test: unary-operators.negate-int.1
function main() returns int
    var x = -42
    var y = -x
    if y == 42 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_sub = const.i64 i64 42
    %tmp_const.2 = const.i64 i64 42
    %tmp_icmp = icmp.eq i64 %tmp_sub %tmp_const.2
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
end$check_2:
    %tmp_const.4 = const.i64 i64 1
    ret %tmp_const.4
}

---

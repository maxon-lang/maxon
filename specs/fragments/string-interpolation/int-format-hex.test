// Test: int-format-hex
function main() returns ExitCode
  var n = 255
  print("{n:x}\n")
  print("{n:X}\n")
  var m = 0
  print("{m:x}\n")
  var big = 65535
  print("{big:x}\n")
  return 0
end 'main'

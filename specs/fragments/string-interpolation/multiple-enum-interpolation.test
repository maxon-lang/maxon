// Test: multiple-enum-interpolation
union Priority
  low = 1
  medium = 2
  high = 3
end 'Priority'

function main() returns ExitCode
  var p1 = Priority.low
  var p2 = Priority.high
  print("Priorities: {p1} and {p2}\n")
  return 0
end 'main'

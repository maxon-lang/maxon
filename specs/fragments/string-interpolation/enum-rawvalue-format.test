// Test: enum-rawvalue-format
enum ErrorCode
  ok = 0
  notFound = 404
  serverError = 500
end 'ErrorCode'

function main() returns ExitCode
  var code = ErrorCode.notFound
  print("E{code.rawValue:04}\n")
  var ok = ErrorCode.ok
  print("E{ok.rawValue:04}\n")
  return 0
end 'main'

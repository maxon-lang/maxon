// Test: custom-stringable
type Pair is Stringable
  var first int
  var second int

  function toString(_ String) returns String
    return "[{first}, {second}]"
  end 'toString'
end 'Pair'

function main() returns int
  var p = Pair{first: 1, second: 2}
  print("{p}\n")
  return 0
end 'main'

// Test: stringable-format-spec
type Counter is Stringable
  var value int

  function toString(format String) returns String
    if format == "verbose" 'verbose'
      return "Counter(value={value})"
    end 'verbose'
    return "{value}"
  end 'toString'
end 'Counter'

function main() returns int
  var c = Counter{value: 42}
  print("{c}\n")
  print("{c:verbose}\n")
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
42
Counter(value=42)
```

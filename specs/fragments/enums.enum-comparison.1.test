// Test: enums.enum-comparison.1
enum Status
    pending
    active
    done
end 'Status'

function main() returns int
    var s1 = Status.pending
    var s2 = Status.pending
    var s3 = Status.active
    if s1 == s2 'eq'
        if s1 != s3 'neq'
            return 1
        end 'neq'
    end 'eq'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %s1 = alloca ptr
    store %s1 %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %tmp_const.2 = const.i64 i64 1
    %s3 = alloca ptr
    store %s3 %tmp_const.2
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$eq_1 @end$eq_4
then$eq_1:
    %tmp_load.2 = load i64 %s1
    %tmp_load.3 = load i64 %s3
    %tmp_icmp.1 = icmp.ne i64 %tmp_load.2 %tmp_load.3
    br.cond %tmp_icmp.1 @then$neq_2 @end$neq_3
then$neq_2:
    %tmp_const.3 = const.i64 i64 1
    ret %tmp_const.3
end$neq_3:
    br @end$eq_4
end$eq_4:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
}

---

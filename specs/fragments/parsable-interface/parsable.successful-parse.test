// Test: parsable.successful-parse
// Parsable.fromString returns struct on success
enum ParseError implements Error
  Invalid = 1
end 'ParseError'

type Value implements Parsable
  export var n Integer

  static function fromString(input String) returns Self throws ParseError
    return {n: input.byteLength()}
  end 'fromString'
end 'Value'

function main() returns Integer
  var v = try Value.fromString("hello") otherwise 'err'
    return 0
  end 'err'
  return v.n
end 'main'
---
ExitCode: 5
---
module {
  func @Value.fromString(input: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call stdlib.String.byteLength
    x86.mov ecx, 8
    x86.mov [rbp-24], eax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, [rbp-24]
    x86.mov [edx+0], ebx
    x86.mov eax, [rbp-16]
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @parsable-interface.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.lea_rdata rax, [__str_12]
    x86.mov rcx, rax
    x86.mov edx, 5
    x86.mov ebx, 32
    x86.mov [rbp-40], ecx
    x86.mov rcx, rbx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-40]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 5
    x86.mov [r8+8], r9
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+24], eax
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call Value.fromString
    x86.mov [rbp-24], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je parsable-interface.main.otherwise_continue_1
  otherwise_error_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.mov ecx, [rbp-32]
    x86.mov eax, [ecx+0]
    x86.epilogue
    x86.ret
  }
}

// Test: parsable.successful-parse
// Parsable.fromString returns struct on success
enum ParseError is Error
  Invalid = 1
end 'ParseError'

type Value is Parsable
  export var n int

  static function fromString(input String) returns Self throws ParseError
    return {n: input.byteLength()}
  end 'fromString'
end 'Value'

function main() returns int
  var v = try Value.fromString("hello") otherwise 'err'
    return 0
  end 'err'
  return v.n
end 'main'
---
ExitCode: 5
---
module {
  func @Value.fromString(__sret: i64, input: i64) {
  entry:
    x86.prologue stack_size=64
    x86.mov [rbp-8], ecx
    x86.mov eax, [edx+32]
    x86.xor ebx, ebx
    x86.add edx, ebx
    x86.mov ebx, [edx+24]
    x86.mov esi, [edx+16]
    x86.mov edi, [edx+8]
    x86.mov r8, [edx+0]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], esi
    x86.mov [rbp-40], edi
    x86.mov [rbp-48], r8
    x86.lea rax, [rbp-48]
    x86.mov rcx, rax
    x86.call stdlib.String.byteLength
    x86.mov [rbp-56], eax
    x86.mov ecx, [rbp-8]
    x86.mov edx, [rbp-56]
    x86.mov [ecx+0], edx
    x86.xor edx, edx
    x86.epilogue
    x86.ret
  }
  func @parsable-interface.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.lea_rdata rax, [__str_4]
    x86.mov rcx, rax
    x86.mov edx, 5
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.xor edi, edi
    x86.xor r8, r8
    x86.mov [rbp-8], r8
    x86.lea r9, [rbp-8]
    x86.mov [rbp-16], edi
    x86.mov [rbp-24], esi
    x86.mov [rbp-32], ebx
    x86.mov [rbp-40], edx
    x86.mov [rbp-48], ecx
    x86.lea rax, [rbp-48]
    x86.mov rcx, r9
    x86.mov rdx, rax
    x86.call Value.fromString
    x86.mov eax, [rbp-8]
    x86.mov [rbp-56], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je parsable-interface.main.otherwise_continue_1
  otherwise_error_0:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.mov eax, [rbp-56]
    x86.mov [rbp-64], eax
    x86.mov ecx, [rbp-64]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}

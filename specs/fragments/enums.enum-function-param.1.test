// Test: enums.enum-function-param.1
enum Status
    on
    off
end 'Status'

function isOn(s Status) returns bool
    if s == Status.on 'check'
        return true
    end 'check'
    return false
end 'isOn'

function main() returns int
    var status = Status.on
    if isOn(status) 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
ExitCode: 1
---
function isOn() -> i64 {
entry_0:
    %s = param i64 0
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %s %tmp_const
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end$check_2:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_call = call i64 @isOn(%tmp_const)
    br.cond %tmp_call @then$test_1 @end$test_2
then$test_1:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end$test_2:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}

---

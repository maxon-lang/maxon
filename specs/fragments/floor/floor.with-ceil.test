// Test: floor.with-ceil
function main() returns ExitCode
  var x = 3.7
  var a = trunc(floor(x))
  var b = trunc(ceil(x))
  return a + b
end 'main'
---
ExitCode: 7
---
module {
  func @floor.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.7]
    x86.roundsd xmm1, xmm0, 1
    x86.cvttsd2si eax, xmm1
    x86.roundsd xmm2, xmm0, 2
    x86.cvttsd2si ecx, xmm2
    x86.add eax, ecx
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je floor.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}

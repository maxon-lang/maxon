// Test: floor.negative
function main() returns int
  var neg = 0.0 - 3.2
  var y = trunc(floor(neg))
  return y + 10
end 'main'
---
ExitCode: 6
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.movsd xmm1, [rip+__float_3.2]
    x86.movsd xmm2, xmm0
    x86.subsd xmm2, xmm1
    x86.movsd [rbp-8], xmm2
    x86.roundsd xmm3, xmm2, 1
    x86.cvttsd2si eax, xmm3
    x86.mov [rbp-16], eax
    x86.mov ecx, 10
    x86.add eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 4615964438073389875
    x86.movq xmm0, rax
    x86.roundsd xmm1, xmm0, Floor
    x86.cvttsd2si rax, xmm1
    x86.epilogue
    x86.ret
}

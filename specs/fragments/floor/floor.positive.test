// Test: floor.positive
function main() returns int
    var x = 3.9
    var y = trunc(floor(x))
    return y
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_3.9]
    x86.movsd [rbp-8], xmm0
    x86.roundsd xmm1, xmm0, 1
    x86.cvttsd2si eax, xmm1
    x86.mov [rbp-16], eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: multiple-variables
function main() returns int
  let a = 10
  let b = 20
  return a + b
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.mov ecx, 20
    x86.mov [rbp-16], ecx
    x86.add eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

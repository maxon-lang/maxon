// Test: multiple-constants
let A = 1
let B = 2
let C = 3

function main() returns int
  return A + B + C
end 'main'
---
ExitCode: 6
---
module {
  func @top-level-let.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 2
    x86.add eax, ecx
    x86.mov edx, 3
    x86.add eax, edx
    x86.ret
  }
}

// Test: basic-float-constant
let PI = 3.14
let PI_INT = 3

function main() returns ExitCode
  return PI_INT
end 'main'
---
ExitCode: 3
---
module {
  func @top-level-let.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 3
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 3
    x86.epilogue
    x86.ret
  }
}
---

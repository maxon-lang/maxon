// Test: boolean-constant
let DEBUG = true

function main() returns int
  if DEBUG 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

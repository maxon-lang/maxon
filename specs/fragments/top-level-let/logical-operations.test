// Test: logical-operations
let BOTH = true and true
let EITHER = false or true
let NEITHER = not false

function main() returns int
  if BOTH and EITHER and NEITHER 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @top-level-let.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.mov edx, 1
    x86.test eax, eax
    x86.je top-level-let.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

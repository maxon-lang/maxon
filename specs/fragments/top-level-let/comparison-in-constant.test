// Test: comparison-in-constant
let IS_LARGE = 100 > 50

function main() returns ExitCode
  if IS_LARGE 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @top-level-let.main() -> u32 {
  entry:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je top-level-let.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

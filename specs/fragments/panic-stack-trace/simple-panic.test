// Test: simple-panic
typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to 255)

function dangerous(value Integer) returns Byte
  return Byte{value}
end

function main() returns ExitCode
  let result = dangerous(Integer{300})
  return 0 as ExitCode
end

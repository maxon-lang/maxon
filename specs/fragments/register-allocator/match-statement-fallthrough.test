// Test: match-statement-fallthrough
function main() returns ExitCode
  var x = 1
  var result = 0
  match x 'cascade'
    1 then result = result + 10 and fallthrough
    2 then result = result + 20 and fallthrough
    3 then result = result + 30
    default then result = 100
  end 'cascade'
  return result
end 'main'

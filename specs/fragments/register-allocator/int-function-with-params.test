module {
  func @add(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.add ecx, edx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 30
    x86.mov ecx, 12
    x86.mov edx, ecx
    x86.mov ecx, eax
    x86.call add
    x86.ret

// Test: int-nested-loops
function main() returns ExitCode
  var total = 0
  var i = 0
  while i < 5 'outer'
    var j = 0
    while j < 4 'inner'
      total = total + 1
      j = j + 1
    end 'inner'
    i = i + 1
  end 'outer'
  return total
end 'main'

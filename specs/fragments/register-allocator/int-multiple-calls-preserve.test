// Test: int-multiple-calls-preserve
function getTen() returns int
  return 10
end 'getTen'

function getTwo() returns int
  return 2
end 'getTwo'

function main() returns int
  var a = 5
  var b = getTen()
  var c = 7
  var d = getTwo()
  return a + b + c + d
end 'main'
---

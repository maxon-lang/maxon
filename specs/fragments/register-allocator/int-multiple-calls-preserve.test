  func @register-allocator.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.call register-allocator.getTen
    x86.mov ecx, 7
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.call register-allocator.getTwo
    x86.mov edx, [rbp-16]
    x86.mov ebx, [rbp-8]
    x86.add ebx, edx
    x86.mov esi, [rbp-24]
    x86.add ebx, esi

    %6 = maxon.binop %2, %3 {op = add} {kind = i64}
    %7 = maxon.binop %6, %4 {op = add} {kind = i64}
    %8 = maxon.binop %7, %5 {op = add} {kind = i64}
    maxon.return %8
  }
}

// Test: error-value-survives-try
enum MyError is Error
  failed
end 'MyError'

function mayFail() returns int throws MyError
  throw MyError.failed
end 'mayFail'

function main() returns int
  var base = 40
  let extra = try mayFail() otherwise 2
  return base + extra
end 'main'
---
ExitCode: 42
RequiredMLIR: ```
=== maxon
module {
  func @mayFail() -> i64 {
  entry:
    %0 = maxon.enum_literal @MyError.failed
    maxon.throw @MyError %0
  }
  func @main() -> i64 {
  entry:
    %1 = maxon.literal {value = 40 : i64}
    maxon.assign %1 {var = base} {kind = i64} {decl = 1 : i1} {mut = 1 : i1}
    %4, %3 = maxon.try_call @mayFail
    %5 = maxon.literal {value = 2 : i64}
    maxon.assign %5 {var = __try_default_1} {kind = i64} {decl = 1 : i1} {mut = 1 : i1}
    maxon.assign %4 {var = __try_result_0} {kind = i64} {decl = 1 : i1} {mut = 1 : i1}
    %6 = maxon.literal {value = 0 : i64}
    %7 = maxon.binop %3, %6 {op = ne} {kind = i64}
    maxon.cond_br %7 [then: otherwise_default_error_2, else: otherwise_default_continue_3]
  otherwise_default_error_2:
    %8 = maxon.var_ref {var = __try_default_1} {type = i64}
    maxon.assign %8 {var = __try_result_0} {kind = i64} {mut = 1 : i1}
    maxon.br otherwise_default_continue_3
  otherwise_default_continue_3:
    %9 = maxon.var_ref {var = __try_result_0} {type = i64}
    maxon.assign %9 {var = extra} {kind = i64} {decl = 1 : i1}
    %10 = maxon.var_ref {var = base} {type = i64}
    %11 = maxon.binop %10, %9 {op = add} {kind = i64}
    maxon.return %11
  }
}

// Test: int-sequential-divisions
function main() returns ExitCode
  var a = 100
  var b = 5
  var c = 84
  var d = 4
  return a / b + c / d
end 'main'
---
ExitCode: 41
---
module {
  func @register-allocator.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 5
    x86.mov edx, 84
    x86.mov ebx, 4
    x86.cqo
    x86.idiv ecx
    x86.mov esi, 84
    x86.mov [rbp-16], eax
    x86.mov eax, esi
    x86.cqo
    x86.idiv ebx
    x86.mov edi, [rbp-16]
    x86.add edi, eax
    x86.mov [rbp-8], edi
    x86.xor r8, r8
    x86.cmp edi, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rax, 4294967295
    x86.cmp rdi, rax
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je register-allocator.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

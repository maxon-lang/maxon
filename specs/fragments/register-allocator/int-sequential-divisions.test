// Test: int-sequential-divisions
function main() returns Integer
  var a = 100
  var b = 5
  var c = 84
  var d = 4
  return a / b + c / d
end 'main'
---
ExitCode: 41
---
module {
  func @register-allocator.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov ecx, 5
    x86.mov edx, 84
    x86.mov ebx, 4
    x86.cqo
    x86.idiv ecx
    x86.mov esi, 84
    x86.mov [rbp-8], eax
    x86.mov eax, esi
    x86.cqo
    x86.idiv ebx
    x86.mov edi, [rbp-8]
    x86.lea eax, [edi + eax]
    x86.epilogue
    x86.ret
  }
}
---

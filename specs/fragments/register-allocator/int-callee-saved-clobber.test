// Test: int-callee-saved-clobber
function useRegs(a int, b int, c int, d int) returns int
  var x = a + b
  var y = c + d
  var z = x + y
  return z
end 'useRegs'

function main() returns int
  var sentinel = 42
  var result = useRegs(1, b: 2, c: 3, d: 4)
  return sentinel + result
end 'main'

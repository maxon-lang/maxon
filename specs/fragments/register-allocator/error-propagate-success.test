// Test: error-propagate-success
enum MyError is Error
  failed
end 'MyError'

function inner() returns int throws MyError
  return 77
end 'inner'

function middle() returns int throws MyError
  let x = try inner()
  return x
end 'middle'

function main() returns int
  let x = try middle() otherwise 99
  return x
end 'main'

// Test: match-statement-with-function-call
function double(n int) returns int
  return n * 2
end 'double'

function main() returns int
  var x = 2
  var result = 0
  match x 'process'
    1 then result = double(10)
    2 then result = double(20)
    default then result = 0
  end 'process'
  return result
end 'main'

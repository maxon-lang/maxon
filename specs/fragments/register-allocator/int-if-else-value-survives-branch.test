// Test: int-if-else-value-survives-branch
function main() returns ExitCode
  var base = 40
  var cond = 1
  var extra = 0
  if cond == 1 'check'
    extra = 2
  end 'check' else 'other'
    extra = 100
  end 'other'
  return base + extra
end 'main'

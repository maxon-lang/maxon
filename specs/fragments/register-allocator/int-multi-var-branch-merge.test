// Test: int-multi-var-branch-merge
function main() returns int
    var x = 0
    var y = 0
    var z = 0
    if 1 < 2 'branch'
        x = 10
        y = 20
        z = 12
    end 'branch' else 'other'
        x = 1
        y = 2
        z = 3
    end 'other'
    return x + y + z
end 'main'

// Test: error-otherwise-block-no-error
enum MyError is Error
  failed
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
  if shouldFail 'check'
    throw MyError.failed
  end 'check'
  return 100
end 'mayFail'

function main() returns int
  var result = 0
  try mayFail(false) otherwise 'err'
    result = 99
  end 'err'
  return result
end 'main'
---

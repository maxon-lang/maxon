// Test: int-loop-pressure-with-call
function identity(x int) returns int
  return x
end 'identity'

function main() returns int
  var a = 1
  var b = 2
  var c = 3
  var d = 4
  var e = 5
  var f = 6
  var i = 0
  while i < 3 'loop'
    a = a + identity(b)
    c = c + identity(d)
    e = e + identity(f)
    i = i + 1
  end 'loop'
  return (a + c + d + e + f) mod 256
end 'main'
---

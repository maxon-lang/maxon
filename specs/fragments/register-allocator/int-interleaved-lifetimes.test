// Test: int-interleaved-lifetimes
function main() returns Integer
  var a = 10
  var b = 20
  var ab = a + b
  var c = 30
  var d = 40
  var cd = c + d
  var e = 50
  var f = 60
  var ef = e + f
  var result = ab + cd + ef
  return result mod 256
end 'main'

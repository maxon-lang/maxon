// Test: int-subtraction-high-pressure
function main() returns Integer
  var a = 100
  var b = 1
  var c = 2
  var d = 3
  var e = 4
  var f = 5
  var g = 6
  var h = 7
  return a - b - c - d - e - f - g - h
end 'main'

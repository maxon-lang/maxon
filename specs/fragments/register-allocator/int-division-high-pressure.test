// Test: int-division-high-pressure
function main() returns Integer
  var a = 10
  var b = 20
  var c = 30
  var d = 40
  var e = 50
  var f = 60
  var g = 70
  var h = 2
  return (a + b + c + d + e + f + g) / h
end 'main'
---
ExitCode: 140
---
module {
  func @register-allocator.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 30
    x86.mov ebx, 40
    x86.mov esi, 50
    x86.mov edi, 60
    x86.mov r8, 70
    x86.mov r9, 2
    x86.add eax, ecx
    x86.add eax, edx
    x86.add eax, ebx
    x86.add eax, esi
    x86.add eax, edi
    x86.add eax, r8
    x86.mov [rbp-8], eax
    x86.cqo
    x86.idiv r9
    x86.epilogue
    x86.ret
  }
}
---

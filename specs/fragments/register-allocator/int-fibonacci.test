// Test: int-fibonacci
function main() returns ExitCode
  var a = 0
  var b = 1
  var i = 0
  while i < 13 'loop'
    var temp = a + b
    a = b
    b = temp
    i = i + 1
  end 'loop'
  return a
end 'main'

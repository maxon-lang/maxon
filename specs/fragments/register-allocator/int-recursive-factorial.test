// Test: int-recursive-factorial
function factorial(n Integer) returns Integer
  if n <= 1 'base'
    return 1
  end 'base'
  return n * factorial(n - 1)
end 'factorial'

function main() returns ExitCode
  return factorial(5) mod 256
end 'main'

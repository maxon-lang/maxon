// Test: int-loop-with-function-call
function double(x int) returns int
  return x * 2
end 'double'

function main() returns int
  var sum = 0
  var i = 0
  while i < 5 'loop'
    sum = sum + double(i)
    i = i + 1
  end 'loop'
  return sum
end 'main'

// Test: int-loop-with-function-call

typealias Integer = i64

function double(x Integer) returns Integer
  return x * 2
end 'double'

function main() returns ExitCode
  var sum = 0
  var i = 0
  while i < 5 'loop'
    sum = sum + double(i)
    i = i + 1
  end 'loop'
  return sum
end 'main'

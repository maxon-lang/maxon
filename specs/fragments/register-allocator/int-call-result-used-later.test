  %2 = maxon.call @compute
  maxon.assign %2 {var = b} {kind = i64} {decl = 1 : i1} {mut = 1 : i1}
  %3 = maxon.binop %1, %2 {op = add} {kind = i64}
  %4 = maxon.literal {value = 256 : i64}
  %5 = maxon.binop %3, %4 {op = mod} {kind = i64}
  maxon.return %5

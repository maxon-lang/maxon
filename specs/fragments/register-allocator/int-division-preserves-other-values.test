// Test: int-division-preserves-other-values
function main() returns Integer
  var x = 10
  var a = 84
  var b = 2
  var quotient = a / b
  return quotient - x
end 'main'
---
ExitCode: 32
---
module {
  func @register-allocator.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 84
    x86.mov edx, 2
    x86.mov ebx, edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov ebx, 10
    x86.sub eax, ebx
    x86.ret
  }
}
---

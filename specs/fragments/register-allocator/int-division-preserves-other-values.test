// Test: int-division-preserves-other-values
function main() returns ExitCode
  var x = 10
  var a = 84
  var b = 2
  var quotient = a / b
  return quotient - x
end 'main'
---
ExitCode: 32
---
module {
  func @register-allocator.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 84
    x86.mov edx, 2
    x86.mov ebx, edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov ebx, 10
    x86.sub eax, ebx
    x86.mov [rbp-8], eax
    x86.xor esi, esi
    x86.cmp eax, esi
    x86.setl edi
    x86.movzx edi, edib
    x86.mov r8, 4294967295
    x86.cmp rax, r8
    x86.setg r9
    x86.movzx r9, r9b
    x86.or edi, r9
    x86.test edi, edi
    x86.je register-allocator.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

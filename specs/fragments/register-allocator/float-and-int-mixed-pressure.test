// Test: float-and-int-mixed-pressure
function main() returns int
    var x = 3.14
    var y = 2.86
    var sum_f = x + y
    var a = 10
    var b = 20
    var sum_i = a + b
    return trunc(sum_f) + sum_i
end 'main'

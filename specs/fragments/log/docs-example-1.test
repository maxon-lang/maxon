// Test: docs-example-1
function main() returns int
  var e = 2.71828
  var result = Math.log(e)  // ln(e) ≈ 1.0
  return trunc(result)
end 'main'

---
ExitCode: 0
---
module {
  func @log.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_2.71828]
    x86.call stdlib.Math.log
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}

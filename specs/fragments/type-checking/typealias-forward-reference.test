// Test: typealias-forward-reference
typealias FooArray = Array with Foo

type Foo
  let value int
end 'Foo'

function main() returns int
  var arr = FooArray{}
  arr.push({value: 42})
  return arr.count() - 1
end 'main'
---
ExitCode: 0
---
module {
  func @type-checking.main() -> i64 {
  entry:
    x86.prologue stack_size=80

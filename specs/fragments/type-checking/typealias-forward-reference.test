    x86.mov [rbp-32], eax
    x86.mov [rbp-40], ecx
    x86.mov [rbp-48], edx
    x86.mov [rbp-56], ebx
    x86.mov [rbp-64], esi
    x86.mov rcx, rdi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-40]
    x86.mov [r8+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-48]
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-56]
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-64]
    x86.mov [eax+24], ecx
    x86.mov eax, 16
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-32]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.mov [rbp-72], eax
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-72]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call FooArray.push
    x86.mov eax, [rbp-16]
    x86.mov rcx, rax
    x86.call FooArray.count
    x86.mov ecx, 1
    x86.sub eax, ecx
    x86.epilogue
    x86.ret

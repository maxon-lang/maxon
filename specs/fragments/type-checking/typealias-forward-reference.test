// Test: typealias-forward-reference
typealias FooArray = Array with Foo

type Foo
  let value int
end 'Foo'

function main() returns int
  var arr = FooArray{}
  arr.push({value: 42})
  return arr.count() - 1
end 'main'
---
ExitCode: 0
---
module {
  func @type-checking.main() -> i64 {
  entry:
    x86.prologue stack_size=96
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.mov esi, 8
    x86.mov edi, 42
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ebx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.mov [rbp-40], eax
    x86.lea r8, [rbp-40]
    x86.mov [rbp-48], edi
    x86.lea r9, [rbp-48]
    x86.mov rcx, r8
    x86.mov rdx, r9
    x86.call FooArray.push
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov ebx, [rbp-32]
    x86.mov esi, [rbp-40]
    x86.mov [rbp-56], eax
    x86.mov [rbp-64], ecx
    x86.mov [rbp-72], edx
    x86.mov [rbp-80], ebx
    x86.mov [rbp-88], esi
    x86.lea rax, [rbp-88]
    x86.mov rcx, rax
    x86.call FooArray.count
    x86.mov ecx, 1
    x86.sub eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

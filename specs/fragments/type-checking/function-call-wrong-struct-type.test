// Test: function-call-wrong-struct-type
type Point
  export var x int
  export var y int
end 'Point'

type Size
  export var w int
  export var h int
end 'Size'

function takePoint(p Point) returns int
  return p.x
end 'takePoint'

function main() returns int
  var s = Size{}
  takePoint(s)
  return 0
end 'main'
---

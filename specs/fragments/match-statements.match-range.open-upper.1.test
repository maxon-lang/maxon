// Test: match-statements.match-range.open-upper.1
function main() returns int
    var x = 100
    match x 'check'
        10.. then return 1
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 100
    br @match_check_1
match_check_1:
    %tmp_const.2 = const.i64 i64 10
    %tmp_icmp = icmp.ge i64 %tmp_const %tmp_const.2
    br.cond %tmp_icmp @match_body_2 @match_default_3
match_body_2:
    %tmp_const.3 = const.i64 i64 1
    ret %tmp_const.3
match_default_3:
    %tmp_const.4 = const.i64 i64 0
    ret %tmp_const.4
match_merge_4:
}

---

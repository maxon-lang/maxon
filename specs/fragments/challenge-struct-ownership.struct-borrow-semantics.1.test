// Test: challenge-struct-ownership.struct-borrow-semantics.1
type Data
    export var value int
end 'Data'

function readOnly(d Data) returns int
    return d.value
end 'readOnly'

function main() returns int
    var d = Data{value: 42}
    var result = readOnly(d)
    return d.value + result
end 'main'
---
ExitCode: 84
---
function readOnly() -> i64 {
entry_0:
    %d = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function main() -> i64 {
entry_0:
    %d = alloca.sized ptr 8
    memset %d 0 8
    %tmp_fieldptr = getfieldptr ptr %d 0
    %tmp_const = const.i64 i64 42
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @readOnly(%d)
    %tmp_add = add i64 %tmp_const %tmp_call
    ret %tmp_add
}


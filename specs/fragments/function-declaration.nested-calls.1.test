    ret %tmp_mul
}

function quadruple() -> i64 {
entry_0:
    %x = param i64 0
    %tmp_call = call i64 @double(%x)
    %tmp_call.1 = call i64 @double(%tmp_call)
    ret %tmp_call.1
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 3
    %tmp_call = call i64 @quadruple(%tmp_const)

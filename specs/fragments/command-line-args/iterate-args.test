// Test: iterate-args
function main() returns ExitCode
  let args = CommandLine.args()
  var i = 0
  while i < args.count() 'loop'
    var arg = try args.get(i) otherwise ""
    print(arg)
    print("\n")
    i = i + 1
  end 'loop'
  return 0
end 'main'
---
Args: a b c
ExitCode: 0
Stdout: ```
a
b
c
```

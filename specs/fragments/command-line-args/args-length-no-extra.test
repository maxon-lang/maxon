// Test: args-length-no-extra
function main() returns ExitCode
  // Without extra args, count should be 0 (no user arguments)
  let args = CommandLine.args()
  return args.count()
end 'main'
---
ExitCode: 0
---
module {
  func @command-line-args.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_symdata rax, [__tag_command-line-args_main]
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call stdlib.CommandLine.args
    x86.mov [rbp-16], eax
    x86.mov edx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call StringArray.count
    x86.mov [rbp-24], eax
    x86.xor ebx, ebx
    x86.cmp eax, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rax, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je command-line-args.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.call mm_decref
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

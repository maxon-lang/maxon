// Test: args-length-no-extra
function main() returns int
  // Without extra args, count should be 0 (no user arguments)
  let args = CommandLine.args()
  return args.count()
end 'main'
---
ExitCode: 0
---
module {
  func @command-line-args.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call stdlib.CommandLine.args
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp StringArray.count
  }
}
---

// Test: numeric-args
function main() returns int
  let args = CommandLine.args()
  // Args are strings, just verify we can access them
  if args.count() == 1 'check'
    var arg = try args.get(0) otherwise ""
    print(arg)
    return 0
  end 'check'
  return 1
end 'main'

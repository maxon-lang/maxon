// Test: access-multiple-args
function main() returns ExitCode
  let args = CommandLine.args()
  var arg1 = try args.get(0) otherwise ""
  var arg2 = try args.get(1) otherwise ""
  var arg3 = try args.get(2) otherwise ""
  print(arg1)
  print("\n")
  print(arg2)
  print("\n")
  print(arg3)
  print("\n")
  return 0
end 'main'

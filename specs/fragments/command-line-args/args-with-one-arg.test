// Test: args-with-one-arg
function main() returns int
  let args = CommandLine.args()
  return args.count()
end 'main'
---
Args: hello
ExitCode: 1
---
module {
  func @command-line-args.main() -> i64 {
  entry:
    x86.prologue stack_size=80
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.xor ebx, ebx
    x86.mov [rbp-32], ebx
    x86.xor esi, esi
    x86.mov [rbp-40], esi
    x86.lea rdi, [rbp-40]
    x86.mov rcx, rdi
    x86.call stdlib.CommandLine.args
    x86.mov r8, [rbp-8]
    x86.mov r9, [rbp-16]
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-32]
    x86.mov edx, [rbp-40]
    x86.mov [rbp-48], r8
    x86.mov [rbp-56], r9
    x86.mov [rbp-64], eax
    x86.mov [rbp-72], ecx
    x86.mov [rbp-80], edx
    x86.lea rax, [rbp-80]
    x86.mov rcx, rax
    x86.call StringArray.count
    x86.epilogue
    x86.ret
  }
}
---

// Test: args-with-one-arg
function main() returns int
  let args = CommandLine.args()
  return args.count()
end 'main'
---
Args: hello
ExitCode: 1
---
module {
  func @command-line-args.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call stdlib.CommandLine.args
    x86.mov [rbp-8], eax
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp StringArray.count
  }
}
---

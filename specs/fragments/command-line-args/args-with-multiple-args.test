// Test: args-with-multiple-args
function main() returns ExitCode
  let args = CommandLine.args()
  return args.count()
end 'main'
---
Args: one two three
ExitCode: 3
---
module {
  func @command-line-args.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.call stdlib.CommandLine.args
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call StringArray.count
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je command-line-args.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.xor edx, edx
    x86.mov [rbp-24], eax
    x86.call maxon_release_array_of_with_managed
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

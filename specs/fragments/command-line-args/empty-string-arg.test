// Test: empty-string-arg
function main() returns ExitCode
  let args = CommandLine.args()
  // Empty quoted arg
  var arg = try args.get(0) otherwise "x"
  if arg == "" 'check'
    return 0
  end 'check'
  return 1
end 'main'

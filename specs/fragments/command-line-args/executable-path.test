// Test: executable-path
function main() returns ExitCode
  let exe = CommandLine.executablePath()
  // Just verify it returns something (the actual path varies)
  if exe.byteLength() > 0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @command-line-args.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call stdlib.CommandLine.executablePath
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call stdlib.String.byteLength
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jle command-line-args.main.check_0.after
  check_0:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_0
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_1
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_1
    x86.label __destruct_nullguard_0
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, [rbp-8]
    x86.test eax, eax
    x86.jz __destruct_nullguard_2
    x86.mov rcx, [rbp-8]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_3
    x86.mov rcx, [rbp-8]
    x86.call mm_free
    x86.label __destruct_skip_3
    x86.label __destruct_nullguard_2
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

// Test: min.zero
function main() returns int
    var x = min(0.0, 5.0)
    if x == 0.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 0
    x86.movq xmm0, rax
    x86.mov rax, 4617315517961601024
    x86.movq xmm1, rax
    x86.movsd xmm2, xmm0
    x86.minsd xmm2, xmm1
    x86.comisd xmm2, xmm0
    x86.sete rax
    x86.test rax, rax
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}
---

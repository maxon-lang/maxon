// Test: min.both-negative
function main() returns int
  var x = min(-2.0, -8.0)
  return trunc(x)
end 'main'
---
ExitCode: -8
---
module {
  func @min.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_-2]
    x86.movsd xmm1, [rip+__float_-8]
    x86.movsd xmm2, xmm0
    x86.minsd xmm2, xmm1
    x86.movsd [rbp-8], xmm2
    x86.cvttsd2si eax, xmm2
    x86.epilogue
    x86.ret
  }
}
---

// Test: min.rt-zero
function main() returns int
  let args = CommandLine.args()
  var a = try float.fromString(try args.get(0) otherwise "") otherwise 0.0
  var b = try float.fromString(try args.get(1) otherwise "") otherwise 0.0
  var result = min(a, b)
  if result == 0.0 'check'
    return 0
  end 'check'
  return 1
end 'main'

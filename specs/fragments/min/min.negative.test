// Test: min.negative
function main() returns Integer
  var x = min(-5.0, 3.0)
  return trunc(x)
end 'main'
---
ExitCode: -5
---
module {
  func @min.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_-5]
    x86.movsd xmm1, [rip+__float_3]
    x86.movsd xmm2, xmm0
    x86.minsd xmm2, xmm1
    x86.cvttsd2si eax, xmm2
    x86.ret
  }
}
---

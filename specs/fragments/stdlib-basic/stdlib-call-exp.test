// Test: stdlib-call-exp
function main() returns ExitCode
  var result = Math.exp(0.0)
  if result == 1.0 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @stdlib-basic.main() -> u32 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.call stdlib.Math.exp
    x86.movsd xmm1, [rip+__float_1]
    x86.ucomisd xmm0, xmm1
    x86.jne stdlib-basic.main.check_0.after
    x86.jp stdlib-basic.main.check_0.after
  check_0:
    x86.mov rax, 42
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

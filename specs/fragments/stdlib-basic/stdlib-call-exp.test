// Test: stdlib-call-exp
function main() returns int
  var result = Math.exp(0.0)
  if result == 1.0 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_0]
    x86.call Math.exp
    x86.movsd [rbp-8], xmm0
    x86.movsd xmm1, [rip+__float_1]
    x86.ucomisd xmm0, xmm1
    x86.jne main.check_0.after
    x86.jp main.check_0.after
  check_0:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

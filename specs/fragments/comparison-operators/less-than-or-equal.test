// Test: less-than-or-equal
function main() returns ExitCode
  var a = 5
  var b = 10
  if a <= b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @comparison-operators.main() -> u32 {
  entry:
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.cmp rax, rcx
    x86.jg comparison-operators.main.check_0.after
  check_0:
    x86.mov rax, 1
    x86.ret
  check_0.after:
    x86.xor rax, rax
    x86.ret
  }
}
---

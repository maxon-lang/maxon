// Test: less-than-or-equal
function main() returns int
    var a = 5
    var b = 10
    if a <= b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.cmp rax, rcx
    x86.setle rcx
    x86.test rcx, rcx
    x86.jne then
    x86.jmp merge
  ^then:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  ^merge:
    x86.mov rax, 0
    x86.epilogue
    x86.ret
}
---

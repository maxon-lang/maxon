// Test: less-than-or-equal
function main() returns Integer
  var a = 5
  var b = 10
  if a <= b 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @comparison-operators.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, 10
    x86.cmp eax, ecx
    x86.jg comparison-operators.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

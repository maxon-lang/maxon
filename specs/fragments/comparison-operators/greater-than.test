// Test: greater-than
function main() returns Integer
  if 5 > 3 'check'
    return 42
  end 'check'
  return 0
end 'main'
---
ExitCode: 42
---
module {
  func @comparison-operators.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jle comparison-operators.main.check_0.after
  check_0:
    x86.mov eax, 42
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

module {
  func.func @main() -> i64 {
    ^entry:
      x86.prologue stack_size=32
      x86.mov rax, 10
      x86.mov rcx, 20
      x86.cmp rax, rcx
      x86.setne rcx
      x86.test rcx, rcx
      x86.jne then
      x86.jmp merge
    ^then:
      x86.mov rax, 1
      x86.epilogue
      x86.ret
    ^merge:
      x86.mov rax, 0
      x86.epilogue
      x86.ret

// Test: not-equal
function main() returns ExitCode
  var x = 10
  if x != 20 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @comparison-operators.main() -> u32 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.cmp eax, ecx
    x86.je comparison-operators.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

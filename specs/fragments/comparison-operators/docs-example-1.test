// Test: docs-example-1
function main() returns int
  var x = 10
  var y = 20
  
  if x < y 'check'
    return 1
  end 'check'
  
  return 0
end 'main'

---
ExitCode: 1
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.mov ecx, 20
    x86.mov [rbp-16], ecx
    x86.cmp eax, ecx
    x86.jge main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: docs-example-1
function main() returns int
    var x = 10
    var y = 20
    
    if x < y 'check'
        return 1
    end 'check'
    
    return 0
end 'main'

---
ExitCode: 1
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 1
    x86.epilogue
    x86.ret
}

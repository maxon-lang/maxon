// Test: cos.zero
function main() returns int
  var result = Math.cos(0.0)
  if result == 1.0 'check'
    return 0
  end 'check'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @cos.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.call stdlib.Math.cos
    x86.movsd xmm1, [rip+__float_1]
    x86.ucomisd xmm0, xmm1
    x86.jne cos.main.check_0.after
    x86.jp cos.main.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

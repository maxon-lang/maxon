// Test: sqrt.sqrt.zero.1
function main() returns int
    var result = sqrt(0.0)
    if result == 0.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 0
    %tmp_fsqrt = fsqrt f64 %tmp_fconst
    %tmp_fconst.1 = const.f64 f64 0
    %tmp_fcmp = fcmp.eq i64 %tmp_fsqrt %tmp_fconst.1
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

---

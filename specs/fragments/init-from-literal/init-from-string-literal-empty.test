// Test: init-from-string-literal-empty
type Wrapper is InitableFromStringLiteral
  var _value String

  static function init(value String) returns Wrapper
    return {_value: value}
  end 'init'

  export function len() returns int
    return _value.byteLength()
  end 'len'
end 'Wrapper'

function main() returns int
  var w = Wrapper from ""
  print("len: {w.len()}\n")
  return 0
end 'main'
---
Stdout: ```
len: 0
```

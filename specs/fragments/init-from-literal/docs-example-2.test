// Test: docs-example-2
type MyChar is InitableFromCharLiteral
  var _value Character

  static function init(value Character) returns MyChar
    return {_value: value}
  end 'init'

  export function len() returns int
    return _value.byteLength()
  end 'len'
end 'MyChar'

function main() returns int
  var mc = MyChar from 'A'
  print("{mc.len()}\n")
  return 0
end 'main'


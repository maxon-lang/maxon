    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov r9, 10
    x86.mov rdx, 2
    x86.lea rcx, qword ptr [rbp-112]
    x86.lea r11, qword ptr [rcx]
    x86.mov qword ptr [r11], r9
    x86.lea r11, qword ptr [rcx+8]
    x86.mov qword ptr [r11], rdx
    x86.lea r11, qword ptr [rbp-128]
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r11
    x86.mov rsi, rcx
    x86.mov rcx, rax
    x86.cld
    x86.rep_movsb

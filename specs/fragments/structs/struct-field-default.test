    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-32]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-40]
    x86.mov [edi+8], r8
    x86.mov r9, 40
    x86.mov eax, 1
    x86.mov ecx, 16
    x86.mov [rbp-48], eax
    x86.mov [rbp-56], r9
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-56]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-48]
    x86.mov [eax+8], ecx
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 16
    x86.mov [rbp-64], eax
    x86.mov [rbp-72], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-64]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-72]
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+0]
    x86.add ecx, edx
    x86.mov eax, [rbp-24]
    x86.mov edx, [eax+8]
    x86.lea eax, [ecx + edx]

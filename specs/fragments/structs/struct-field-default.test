// Test: struct-field-default
type Counter
	export var value = 0
	export var step = 1
end 'Counter'

function main() returns int
	var c1 = Counter{}
	var c2 = Counter{value: 40}
	var c3 = Counter{value: 10, step: 2}
	return c1.value + c2.value + c3.step
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=128
    x86.mov rax, 0
    x86.mov rcx, 1
    x86.lea rdx, qword ptr [rbp-48]
    x86.lea r8, qword ptr [rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rdx+8]
    x86.mov qword ptr [r8], rcx
    x86.lea r8, qword ptr [rbp-64]
    x86.mov qword ptr [r8], rdx
    x86.mov rdx, 40
    x86.lea rax, qword ptr [rbp-80]
    x86.lea r9, qword ptr [rax]
    x86.mov qword ptr [r9], rdx
    x86.lea r9, qword ptr [rax+8]
    x86.mov qword ptr [r9], rcx
    x86.lea r9, qword ptr [rbp-96]
    x86.mov qword ptr [r9], rax
    x86.mov rax, 10
    x86.mov rcx, 2
    x86.lea rdx, qword ptr [rbp-112]
    x86.lea r10, qword ptr [rdx]
    x86.mov qword ptr [r10], rax
    x86.lea r10, qword ptr [rdx+8]
    x86.mov qword ptr [r10], rcx
    x86.lea r10, qword ptr [rbp-128]
    x86.mov qword ptr [r10], rdx
    x86.mov rdx, [r8]
    x86.lea r8, qword ptr [rdx]
    x86.mov rdx, qword ptr [r8]
    x86.mov r8, [r9]
    x86.lea r9, qword ptr [r8]
    x86.mov r8, qword ptr [r9]
    x86.mov r9, rdx
    x86.add r9, r8
    x86.mov r8, [r10]
    x86.lea r10, qword ptr [r8+8]
    x86.mov r8, qword ptr [r10]
    x86.mov r10, r9
    x86.add r10, r8
    x86.mov rax, r10
    x86.epilogue
    x86.ret
}
---

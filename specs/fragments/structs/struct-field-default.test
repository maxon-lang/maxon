// Test: struct-field-default
type Counter
  export var value = 0
  export var step = 1
end 'Counter'

function main() returns int
  var c1 = Counter{}
  var c2 = Counter{value: 40}
  var c3 = Counter{value: 10, step: 2}
  return c1.value + c2.value + c3.step
end 'main'
---
ExitCode: 42
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, 40
    x86.mov [rbp-16], ecx
    x86.mov edx, 2
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.add ebx, esi
    x86.mov edi, [rbp-24]
    x86.lea eax, [ebx + edi]
    x86.epilogue
    x86.ret
  }
}
---

// Test: struct-field-default
type Counter
  export var value = 0
  export var step = 1
end 'Counter'

function main() returns int
  var c1 = Counter{}
  var c2 = Counter{value: 40}
  var c3 = Counter{value: 10, step: 2}
  return c1.value + c2.value + c3.step
end 'main'
---
ExitCode: 42
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.xor esi, esi
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 1
    x86.mov [edi+8], r8
    x86.mov r9, 40
    x86.mov eax, 1
    x86.mov ecx, 16
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 40
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.mov [eax+8], ecx
    x86.mov eax, 10
    x86.mov ecx, 2
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, 10
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+0]
    x86.add ecx, edx
    x86.mov eax, [rbp-24]
    x86.mov edx, [eax+8]
    x86.lea eax, [ecx + edx]
    x86.epilogue
    x86.ret
  }
}

// Test: var-struct-field-assign
type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns Integer
  var p = Point{x: 10, y: 20}
  p.x = 30
  return p.x
end 'main'
---
ExitCode: 30
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 20
    x86.mov [edi+8], r8
    x86.mov r9, 30
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

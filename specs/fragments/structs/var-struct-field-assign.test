// Test: var-struct-field-assign
type Point
    export var x int
    export var y int
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    p.x = 30
    return p.x
end 'main'
---
ExitCode: 30
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.lea rdx, qword ptr [rbp-48]
    x86.mov r8, 0
    x86.lea r9, qword ptr [rdx+r8]
    x86.mov qword ptr [r9], rax
    x86.mov r9, 8
    x86.lea rax, qword ptr [rdx+r9]
    x86.mov qword ptr [rax], rcx
    x86.lea rcx, qword ptr [rbp-64]
    x86.mov qword ptr [rcx], rdx
    x86.mov rdx, [rcx]
    x86.mov rax, 30
    x86.lea r9, qword ptr [rdx]
    x86.mov qword ptr [r9], rax
    x86.mov r9, [rcx]
    x86.lea rcx, qword ptr [r9]
    x86.mov r9, qword ptr [rcx]
    x86.mov rax, r9
    x86.epilogue
    x86.ret
}
---

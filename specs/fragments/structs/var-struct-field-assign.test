// Test: var-struct-field-assign
type Point
    export var x int
    export var y int
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    p.x = 30
    return p.x
end 'main'
---
ExitCode: 30
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 10
    x86.mov rcx, 20
    x86.lea rdx, qword ptr [rbp-48]
    x86.lea r8, qword ptr [rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rdx+8]
    x86.mov qword ptr [r8], rcx
    x86.lea r8, qword ptr [rbp-64]
    x86.mov rcx, 16
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r8
    x86.mov rsi, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, [r8]
    x86.mov rdx, 30
    x86.lea rax, qword ptr [rcx]
    x86.mov qword ptr [rax], rdx
    x86.mov rdx, [r8]
    x86.lea r8, qword ptr [rdx]
    x86.mov rdx, qword ptr [r8]
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

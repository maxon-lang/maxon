// Test: simple-type
type Point
  export var x int
  export var y int
end 'Point'

function main() returns int
  var p = Point { x: 3, y: 4 }
  return p.x + p.y
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-24]
    x86.mov edi, [rbp-32]
    x86.lea eax, [esi + edi]
    x86.epilogue
    x86.ret
  }
}

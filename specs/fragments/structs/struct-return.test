// Test: struct-return
type Pair
    export var first int
    export var second int
end 'Pair'

function makePair(a int, b int) returns Pair
    return { first: a, second: b }
end 'makePair'

function main() returns int
    var p = makePair(5, b: 7)
    return p.first + p.second
end 'main'
---
ExitCode: 12
---
func.func @makePair(%__sret: ptr<!maxon.struct<Pair>>, %a: i64, %b: i64) {
  ^entry(%__sret: ptr<!maxon.struct<Pair>>, %a: i64, %b: i64):
    x86.prologue stack_size=32
    x86.mov r10, rcx
    x86.mov r11, rdx
    x86.mov rax, r8
    x86.mov rcx, r10
    x86.mov rdx, r11
    x86.lea r8, qword ptr [rcx]
    x86.mov qword ptr [r8], rdx
    x86.lea r8, qword ptr [rcx+8]
    x86.mov qword ptr [r8], rax
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=72 saved_gprs=[RBX]
    x86.mov rax, 5
    x86.mov rcx, 7
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov r10, rbx
    x86.mov r11, rax
    x86.push rcx
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call makePair
    x86.lea rcx, qword ptr [rbp-64]
    x86.mov qword ptr [rcx], rbx
    x86.mov rax, [rcx]
    x86.lea rdx, qword ptr [rax]
    x86.mov rax, qword ptr [rdx]
    x86.mov rdx, [rcx]
    x86.lea rcx, qword ptr [rdx+8]
    x86.mov rdx, qword ptr [rcx]
    x86.mov rcx, rax
    x86.add rcx, rdx
    x86.mov rax, rcx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}
---

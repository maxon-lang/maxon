// Test: error.let-struct-field-assign

typealias Integer = i64

type Point
  export var x Integer
  export var y Integer
end 'Point'

function main() returns ExitCode
  let p = Point{x: 10, y: 20}
  p.x = 30
  return p.x
end 'main'

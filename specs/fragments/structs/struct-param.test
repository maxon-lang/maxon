// Test: struct-param
type Vec2
  export var x int
  export var y int
end 'Vec2'

function dot(a Vec2, b Vec2) returns int
  return a.x * b.x + a.y * b.y
end 'dot'

function main() returns int
  var v1 = Vec2 { x: 3, y: 4 }
  var v2 = Vec2 { x: 2, y: 1 }
  return dot(v1, b: v2)
end 'main'

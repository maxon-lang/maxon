// Test: struct-param
type Vec2
    export var x int
    export var y int
end 'Vec2'

function dot(a Vec2, b Vec2) returns int
    return a.x * b.x + a.y * b.y
end 'dot'

function main() returns int
    var v1 = Vec2 { x: 3, y: 4 }
    var v2 = Vec2 { x: 2, y: 1 }
    return dot(v1, b: v2)
end 'main'
---
ExitCode: 10
---
func.func @dot(%a: !maxon.struct<Vec2>, %b: !maxon.struct<Vec2>) -> i64 {
  ^entry(%a: !maxon.struct<Vec2>, %b: !maxon.struct<Vec2>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov r8, qword ptr [rdx]
    x86.lea rdx, qword ptr [rcx]
    x86.mov r9, qword ptr [rdx]
    x86.imul rdx, r8, r9
    x86.lea r9, qword ptr [rax+8]
    x86.mov rax, qword ptr [r9]
    x86.lea r9, qword ptr [rcx+8]
    x86.mov rcx, qword ptr [r9]
    x86.imul r9, rax, rcx
    x86.mov rcx, rdx
    x86.add rcx, r9
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=96
    x86.mov rax, 3
    x86.mov rcx, 4
    x86.lea rdx, qword ptr [rbp-48]
    x86.mov r8, 0
    x86.lea r9, qword ptr [rdx+r8]
    x86.mov qword ptr [r9], rax
    x86.mov r9, 8
    x86.lea rax, qword ptr [rdx+r9]
    x86.mov qword ptr [rax], rcx
    x86.lea rcx, qword ptr [rbp-64]
    x86.mov qword ptr [rcx], rdx
    x86.mov rdx, 2
    x86.mov rax, 1
    x86.lea r10, qword ptr [rbp-80]
    x86.lea r11, qword ptr [r10+r8]
    x86.mov qword ptr [r11], rdx
    x86.lea r11, qword ptr [r10+r9]
    x86.mov qword ptr [r11], rax
    x86.lea r11, qword ptr [rbp-96]
    x86.mov qword ptr [r11], r10
    x86.mov r10, [rcx]
    x86.mov rcx, [r11]
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call dot
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

// Test: struct-param
type Vec2
  export var x int
  export var y int
end 'Vec2'

function dot(a Vec2, b Vec2) returns int
  return a.x * b.x + a.y * b.y
end 'dot'

function main() returns int
  var v1 = Vec2 { x: 3, y: 4 }
  var v2 = Vec2 { x: 2, y: 1 }
  return dot(v1, b: v2)
end 'main'
---
ExitCode: 10
---
module {
  func @structs.dot(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, [ecx+8]
    x86.mov [rbp-8], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [edx+8]
    x86.mov [rbp-24], ecx
    x86.mov eax, [edx+0]
    x86.mov [rbp-32], eax
    x86.mov edx, [rbp-16]
    x86.mov ebx, [rbp-32]
    x86.imul edx, ebx
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-24]
    x86.imul esi, edi
    x86.lea eax, [edx + esi]
    x86.epilogue
    x86.ret
  }
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov edx, 2
    x86.mov ebx, 1
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.lea rsi, [rbp-16]
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.lea rdi, [rbp-32]
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call structs.dot
    x86.epilogue
    x86.ret
  }
}

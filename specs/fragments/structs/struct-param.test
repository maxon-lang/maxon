// Test: struct-param
type Vec2
  export var x int
  export var y int
end 'Vec2'

function dot(a Vec2, b Vec2) returns int
  return a.x * b.x + a.y * b.y
end 'dot'

function main() returns int
  var v1 = Vec2 { x: 3, y: 4 }
  var v2 = Vec2 { x: 2, y: 1 }
  return dot(v1, b: v2)
end 'main'
---
ExitCode: 10
---
module {
  func @structs.dot(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov esi, [eax+0]
    x86.imul ebx, esi
    x86.mov eax, [rbp-8]
    x86.mov esi, [eax+8]
    x86.mov eax, [rbp-16]
    x86.mov edi, [eax+8]
    x86.imul esi, edi
    x86.lea eax, [ebx + esi]
    x86.epilogue
    x86.ret
  }
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 3
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 4
    x86.mov [edi+8], r8
    x86.mov r9, 2
    x86.mov eax, 1
    x86.mov ecx, 16
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.mov [eax+8], ecx
    x86.mov eax, [rbp-8]
    x86.mov rdx, [rbp-16]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp structs.dot

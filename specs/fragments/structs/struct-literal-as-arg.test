// Test: struct-literal-as-arg
type Point
  export var x int
  export var y int
end 'Point'

function acceptPoint(p Point) returns int
  return p.x + p.y
end 'acceptPoint'

function main() returns int
  return acceptPoint({x: 3, y: 4})
end 'main'
---
ExitCode: 7
---
module {
  func @acceptPoint(p.x: i64, p.y: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.add eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov ecx, edx
    x86.mov edx, ebx
    x86.call acceptPoint
    x86.epilogue
    x86.ret
  }
}

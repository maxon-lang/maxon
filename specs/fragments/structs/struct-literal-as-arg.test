    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.lea eax, [ecx + edx]
    x86.epilogue
    x86.ret
  }
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx

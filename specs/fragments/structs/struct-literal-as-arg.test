// Test: struct-literal-as-arg
type Point
  export var x int
  export var y int
end 'Point'

function acceptPoint(p Point) returns int
  return p.x + p.y
end 'acceptPoint'

function main() returns int
  return acceptPoint({x: 3, y: 4})
end 'main'

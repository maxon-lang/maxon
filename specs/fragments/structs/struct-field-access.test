    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-32], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]

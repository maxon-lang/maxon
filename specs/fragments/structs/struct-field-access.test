    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-16]
    x86.mov r8, 5
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-16]
    x86.mov eax, 10
    x86.mov [r9+8], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+0]
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+8]

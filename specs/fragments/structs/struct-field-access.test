// Test: struct-field-access
type Rect
    export var width int
    export var height int
end 'Rect'

function main() returns int
    var r = Rect { width: 5, height: 10 }
    return r.width * r.height
end 'main'
---
ExitCode: 50
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=64
    x86.mov rax, 5
    x86.mov rcx, 10
    x86.lea rdx, qword ptr [rbp-48]
    x86.lea r8, qword ptr [rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rdx+8]
    x86.mov qword ptr [r8], rcx
    x86.lea r8, qword ptr [rbp-64]
    x86.mov rcx, 16
    x86.push rsi
    x86.push rdi
    x86.mov rdi, r8
    x86.mov rsi, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.lea rcx, qword ptr [r8]
    x86.mov rdx, qword ptr [rcx]
    x86.lea rcx, qword ptr [r8+8]
    x86.mov r8, qword ptr [rcx]
    x86.imul rcx, rdx, r8
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

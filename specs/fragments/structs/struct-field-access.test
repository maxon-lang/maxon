// Test: struct-field-access
type Rect
  export var width int
  export var height int
end 'Rect'

function main() returns int
  var r = Rect { width: 5, height: 10 }
  return r.width * r.height
end 'main'
---
ExitCode: 50
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 5
    x86.mov ecx, 10
    x86.mov edx, 16
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-24]
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, [r9+0]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+8]
    x86.imul eax, edx
    x86.epilogue
    x86.ret
  }
}
---

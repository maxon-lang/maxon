// Test: struct-field-access

typealias Integer = int(i64.min to i64.max)

type Rect
  export var width Integer
  export var height Integer
end 'Rect'

function main() returns ExitCode
  var r = Rect { width: 5, height: 10 }
  return r.width * r.height
end 'main'
---
ExitCode: 50
---
module {
  func @structs.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov ecx, 10
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 5
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 10
    x86.mov [edi+8], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, [r9+0]
    x86.mov ecx, [rbp-8]
    x86.mov edx, [ecx+8]
    x86.imul eax, edx
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je structs.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_17]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}

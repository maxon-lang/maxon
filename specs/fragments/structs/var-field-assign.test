// Test: var-field-assign
type Config
  export let version int
  export var count int
end 'Config'

function main() returns int
  var c = Config{version: 1, count: 0}
  c.count = 5
  return c.count
end 'main'
---
ExitCode: 5
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

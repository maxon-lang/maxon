// Test: var-field-assign
type Config
  export let version int
  export var count int
end 'Config'

function main() returns int
  var c = Config{version: 1, count: 0}
  c.count = 5
  return c.count
end 'main'
---
ExitCode: 5
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 1
    x86.xor ecx, ecx
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov esi, 5
    x86.mov [rbp-24], esi
    x86.mov edi, [rbp-24]
    x86.mov eax, edi
    x86.epilogue
    x86.ret
  }
}
---

// Test: var-field-assign
type Config
  export let version Integer
  export var count Integer
end 'Config'

function main() returns Integer
  var c = Config{version: 1, count: 0}
  c.count = 5
  return c.count
end 'main'
---
ExitCode: 5
---
module {
  func @structs.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.xor ecx, ecx
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 1
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.xor r8, r8
    x86.mov [edi+8], r8
    x86.mov r9, 5
    x86.mov eax, [rbp-8]
    x86.mov [eax+8], r9
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+8]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}

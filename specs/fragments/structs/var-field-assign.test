// Test: var-field-assign

typealias Integer = int(i64.min to i64.max)

type Config
  export let version Integer
  export var count Integer
end 'Config'

function main() returns ExitCode
  var c = Config{version: 1, count: 0}
  c.count = 5
  return c.count
end 'main'

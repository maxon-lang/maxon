entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_call = call i64 @Toggle$flip(%tmp_const)
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_call %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

function Toggle$flip() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %self %tmp_const

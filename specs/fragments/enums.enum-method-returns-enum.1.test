// Test: enums.enum-method-returns-enum.1
enum Toggle
    on
    off

    function flip() returns Toggle
        if self == Toggle.on 'check'
            return Toggle.off
        end 'check'
        return Toggle.on
    end 'flip'
end 'Toggle'

function main() returns int
    let t = Toggle.on
    let flipped = t.flip()
    if flipped == Toggle.off 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1

// Test: file-exists
function main() returns ExitCode
  // Test File.exists on a nonexistent file (returns false)
  if File.exists("nonexistent_xyz_12345.txt") 'check'
    return 1
  end 'check'
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @file-io.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_rdata rax, [__str_1]
    x86.mov rcx, rax
    x86.mov edx, 25
    x86.mov [rbp-24], ecx
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov rdx, [rbp-8]
    x86.mov rcx, 32
    x86.xor r8, r8
    x86.call mm_alloc_in
    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov r8, 25
    x86.mov [edi+8], r8
    x86.xor r9, r9
    x86.mov eax, [rbp-16]
    x86.mov [eax+16], r9
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call stdlib.File.exists
    x86.test eax, eax
    x86.je file-io.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
}
---

// Test: file-exists
function main() returns ExitCode
  // Test File.exists on a nonexistent file (returns false)
  if File.exists("nonexistent_xyz_12345.txt") 'check'
    return 1
  end 'check'
  return 42
end 'main'
---
ExitCode: 42
---

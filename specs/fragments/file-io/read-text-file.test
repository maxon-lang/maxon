// Test: read-text-file
function main() returns ExitCode
  // Try to read a nonexistent file - this tests the error path
  let content = try File.readText("nonexistent_file_xyz.txt") otherwise 'err'
    print("File not found")
    return 42
  end 'err'
  print("Content:{content}\n")
  return 0
end 'main'

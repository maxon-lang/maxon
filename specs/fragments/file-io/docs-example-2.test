// Test: docs-example-2
function main() returns ExitCode
  let bytes = try File.readBinary("data.bin") otherwise 'err'
    print("Could not read file\n")
    return 0
  end 'err'
  print("Read {bytes.count()} bytes\n")
  return 1
end 'main'


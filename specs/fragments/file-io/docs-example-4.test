    x86.mov [rbp-72], edx
    x86.mov [rbp-80], ecx
    x86.lea r8, [rbp-80]
    x86.mov rcx, r8
    x86.call stdlib.Print.print
    x86.mov r9, 1
    x86.mov eax, r9
    x86.epilogue
    x86.ret
  otherwise_continue_1:
    x86.lea_rdata rax, [__str_8]
    x86.mov rcx, rax
    x86.mov edx, 12
    x86.xor ebx, ebx
    x86.mov esi, 1
    x86.xor edi, edi
    x86.mov [rbp-88], edi
    x86.mov [rbp-96], esi
    x86.mov [rbp-104], ebx
    x86.mov [rbp-112], edx
    x86.mov [rbp-120], ecx

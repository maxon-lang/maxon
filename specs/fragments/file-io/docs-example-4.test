// Test: docs-example-4
function main() returns int
  try File.delete("temp/old_file.txt") otherwise 'err'
    print("Could not delete file")
    return 1
  end 'err'
  print("File deleted")
  return 0
end 'main'

---
ExitCode: 1
---

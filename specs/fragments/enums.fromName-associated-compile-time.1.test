// Test: enums.fromName-associated-compile-time.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = try Container.fromName("value", 42) otherwise Container.empty
    match c 'check'
        value(n) then return n
        empty then return 0
    end 'check'
end 'main'

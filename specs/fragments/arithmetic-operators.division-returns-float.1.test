// Test: arithmetic-operators.division-returns-float.1
function main() returns int
    var result = 20 / 3      // 6.666...
    return trunc(result * 10.0)  // 66.666... * 10 = 66.666..., trunc = 66
end 'main'
---
ExitCode: 66
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 20
    %tmp_const.1 = const.i64 i64 3
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_sitofp.1 = sitofp f64 %tmp_const.1
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fconst = const.f64 f64 10
    %tmp_fmul = fmul f64 %tmp_fdiv %tmp_fconst
    %tmp_fptosi = fptosi i64 %tmp_fmul
    ret %tmp_fptosi
}

---

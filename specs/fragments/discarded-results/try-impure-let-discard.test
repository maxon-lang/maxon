    x86.mov rdx, [rbp-8]
    x86.mov rcx, 32
    x86.xor r8, r8
    x86.call mm_alloc_in
    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-16]
    x86.mov esi, [rbp-40]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov r8, 3
    x86.mov [edi+8], r8
    x86.xor r9, r9
    x86.mov eax, [rbp-16]
    x86.mov [eax+16], r9
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov eax, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call discarded-results.parseNum
    x86.xor ecx, ecx
    x86.mov [rbp-32], ecx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je discarded-results.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-32]
    x86.jmp discarded-results.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-24]
    x86.test eax, eax
    x86.jz __destruct_nullguard_0
    x86.mov rcx, [rbp-24]
    x86.call mm_decref_check
    x86.test eax, eax
    x86.jnz __destruct_skip_1
    x86.mov rcx, [rbp-24]
    x86.call mm_free
    x86.label __destruct_skip_1
    x86.label __destruct_nullguard_0
    x86.xor eax, eax
    x86.epilogue
    x86.ret

// Test: try-impure-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

union ParseError implements Error
  invalidFormat
end 'ParseError'

function parseNum(s String) returns Integer throws ParseError
  counter = counter + s.byteLength()
  throw ParseError.invalidFormat
end 'parseNum'

function main() returns ExitCode
  let _ = try parseNum("abc") otherwise 0
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.parseNum(s: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, qword [rip+counter]
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov rcx, rdx
    x86.call stdlib.String.byteLength
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov qword [rip+counter], ecx
    x86.xor edx, edx
    x86.mov ebx, 1
    x86.add edx, ebx
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.lea_rdata rax, [__str_16]
    x86.mov rcx, rax
    x86.mov edx, 3
    x86.mov ebx, 16
    x86.xor esi, esi
    x86.mov [rbp-32], ecx
    x86.mov rcx, rbx
    x86.mov rdx, rsi
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov edi, 32
    x86.xor r8, r8
    x86.mov rcx, rdi
    x86.mov rdx, rax
    x86.call mm_alloc_in
    x86.mov [rbp-16], eax
    x86.mov r9, [rbp-16]
    x86.mov eax, [rbp-32]
    x86.mov [r9+0], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call discarded-results.parseNum
    x86.xor ecx, ecx
    x86.mov [rbp-24], ecx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je discarded-results.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-24]
    x86.jmp discarded-results.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

// Test: impure-mutating-param

typealias Integer = int(i64.min to i64.max)

function doubleInPlace(x Integer) returns Integer
  x = x * 2
  return x
end 'doubleInPlace'

function main() returns ExitCode
  var n = 5 as Integer
  let _ = doubleInPlace(n)
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.doubleInPlace(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [eax+0]
    x86.mov edx, 2
    x86.imul ecx, edx
    x86.mov [rbp-16], ecx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.lea rcx, [rbp-8]
    x86.mov rdx, rcx
    x86.mov rcx, rdx
    x86.call discarded-results.doubleInPlace
    x86.xor ebx, ebx
    x86.mov eax, ebx
    x86.epilogue
    x86.ret
  }
}
---

// Test: impure-mutating-param

typealias Integer = int(i64.min to i64.max)

function doubleInPlace(x Integer) returns Integer
  x = x * 2
  return x
end 'doubleInPlace'

function main() returns ExitCode
  var n = 5 as Integer
  let _ = doubleInPlace(n)
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.doubleInPlace(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-32], ecx
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-32]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov ebx, [edx+0]
    x86.mov esi, 2
    x86.imul ebx, esi
    x86.mov [rbp-24], ebx
    x86.mov edi, [rbp-16]
    x86.mov r8, [rbp-24]
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 5
    x86.mov [rbp-16], ecx
    x86.lea rdx, [rbp-16]
    x86.mov rbx, rdx
    x86.mov rcx, rbx
    x86.call discarded-results.doubleInPlace
    x86.xor esi, esi
    x86.mov edi, [rbp-8]
    x86.mov [rbp-24], eax
    x86.mov rcx, rdi
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

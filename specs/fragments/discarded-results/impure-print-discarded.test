// Test: impure-print-discarded

typealias Integer = int(i64.min to i64.max)

function computeAndPrint(x Integer) returns Integer
  print("computing")
  return x * 2
end 'computeAndPrint'

function main() returns ExitCode
  let _ = computeAndPrint(5)
  return 0
end 'main'

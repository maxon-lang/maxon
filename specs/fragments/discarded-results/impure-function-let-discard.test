// Test: impure-function-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

function incrementAndGet() returns Integer
  counter = counter + 1
  return counter
end 'incrementAndGet'

function main() returns ExitCode
  let _ = incrementAndGet()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.incrementAndGet() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, qword [rip+counter]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov qword [rip+counter], ecx
    x86.mov eax, qword [rip+counter]
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov rcx, rbx
    x86.call mm_scope_exit
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call discarded-results.incrementAndGet
    x86.xor ecx, ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

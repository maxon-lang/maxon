// Test: chainable-method-discarded

typealias Count = int(i64.min to i64.max)

type Counter
  export var value Count

  function increment() returns Counter
    value = value + 1
    return self
  end 'increment'
end 'Counter'

function main() returns ExitCode
  var c = Counter{value: 0}
  c.increment()
  return c.value
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], edx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.lea rdi, [rbp-16]
    x86.xor eax, eax
    x86.mov ecx, 2
    x86.rep_stosq
    x86.lea rcx, [rbp-16]
    x86.mov rdx, rcx
    x86.mov ebx, 8
    x86.add edx, ebx
    x86.mov [rbp-24], edx
    x86.mov esi, [rbp-24]
    x86.xor edi, edi
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call mm_incref
    x86.mov r9, [rbp-24]
    x86.mov rcx, [rbp-24]
    x86.call Counter.increment
    x86.mov ecx, [rbp-24]
    x86.mov edx, [ecx+0]
    x86.mov [rbp-32], edx
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rbx, 4294967295
    x86.cmp rdx, rbx
    x86.setg edx
    x86.movzx edx, edxb
    x86.or ecx, edx
    x86.test ecx, ecx
    x86.je discarded-results.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_27]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-24]
    x86.call mm_decref
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}

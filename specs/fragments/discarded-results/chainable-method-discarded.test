// Test: chainable-method-discarded

typealias Count = int(i64.min to i64.max)

type Counter
  export var value Count

  function increment() returns Counter
    value = value + 1
    return self
  end 'increment'
end 'Counter'

function main() returns ExitCode
  var c = Counter{value: 0}
  c.increment()
  return c.value
end 'main'
---
ExitCode: 1
---
module {
  func @Counter.increment(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-16], ecx
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+0]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov ebx, [rbp-16]
    x86.mov [ebx+0], ecx
    x86.mov esi, [rbp-16]
    x86.mov edi, [rbp-8]
    x86.mov r8, [edi+8]
    x86.mov rcx, [rbp-16]
    x86.mov rdx, r8
    x86.xor r8, r8
    x86.call mm_move
    x86.mov r9, [rbp-8]
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.mov rcx, 8
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.xor edx, edx
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call Counter.increment
    x86.mov esi, [rbp-16]
    x86.mov edi, [esi+0]
    x86.mov [rbp-24], edi
    x86.xor r8, r8
    x86.cmp edi, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rdi, rcx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or r9, ecx
    x86.test r9, r9
    x86.je discarded-results.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_25]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}

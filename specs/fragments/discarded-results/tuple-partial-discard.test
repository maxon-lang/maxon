// Test: tuple-partial-discard

typealias Small = int(0 to 100)

function makePair() returns (Small, Small)
  return (10, 20)
end 'makePair'

function main() returns ExitCode
  var (a, _) = makePair()
  return a
end 'main'
---
ExitCode: 10
---
module {
  func @discarded-results.makePair() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 16
    x86.xor ebx, ebx
    x86.mov rcx, rdx
    x86.mov rdx, rbx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov esi, [rbp-8]
    x86.mov edi, 10
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 20
    x86.mov [r8+8], r9
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @discarded-results.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call discarded-results.makePair
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [ecx+0]
    x86.mov [rbp-24], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.setl esi
    x86.movzx esi, esib
    x86.mov rdi, 4294967295
    x86.cmp rdx, rdi
    x86.setg r8
    x86.movzx r8, r8b
    x86.or esi, r8
    x86.test esi, esi
    x86.je discarded-results.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_14]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-32], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

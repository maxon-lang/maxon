    x86.mov [rbp-8], eax
    x86.mov ecx, qword [rip+state]
    x86.mov [rbp-16], ecx
    x86.mov edx, 42
    x86.mov ebx, [rbp-16]
    x86.mov [ebx+0], edx
    x86.mov esi, qword [rip+state]
    x86.mov [rbp-24], esi
    x86.mov edi, [rbp-24]
    x86.mov r8, [edi+0]
    x86.mov [rbp-32], r8
    x86.xor r9, r9
    x86.cmp r8, r9
    x86.setl eax
    x86.movzx eax, eaxb
    x86.mov rcx, 4294967295
    x86.cmp r8, rcx
    x86.setg ecx
    x86.movzx ecx, ecxb
    x86.or eax, ecx
    x86.test eax, eax
    x86.je module-level-struct-var.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-40], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
  func @module-level-struct-var.__module_init() {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.xor edx, edx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.xor esi, esi
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov qword [rip+state], edi
    x86.epilogue
    x86.ret
  }
  func @__maxon_global_cleanup() {
  entry:
    x86.mov eax, qword [rip+state]
    x86.mov rcx, rax
    x86.call mm_free
    x86.ret
  }
}

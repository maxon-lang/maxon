// Test: module-struct-field-assign
typealias SmallInt = int(0 to u8.max)

type Counter
    export var value SmallInt
end 'Counter'

var state = Counter{value: 0}

function main() returns ExitCode
    state.value = 42
    return state.value
end 'main'
---
ExitCode: 42
---
module {

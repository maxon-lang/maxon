// Test: duplicate-block-identifiers.duplicate-block-identifiers.nested-same-id.1
function main() returns int
    var x = 0
    if true 'check'
        x = 1
        if true 'check'
            x = 2
        end 'check'
    end 'check'
    return x
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    br.cond %tmp_const.1 @then$check_1 @end$check_4
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    store %x %tmp_const.2
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @then$check_2 @end$check_3
then$check_2:
    %tmp_const.4 = const.i64 i64 2
    store %x %tmp_const.4
    br @end$check_3
end$check_3:
    br @end$check_4
end$check_4:

// Test: no-leak.string-scope
function make_string()
  var s = "this string is long enough to require heap allocation for sure and even more text"
  print(s)
end 'make_string'

function main() returns ExitCode
  make_string()
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
this string is long enough to require heap allocation for sure and even more text
```
---
module {
  func @leak-checker.make_string() {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.lea_rdata rcx, [__str_1]
    x86.mov rdx, rcx
    x86.mov ebx, 81
    x86.mov esi, 16
    x86.xor edi, edi
    x86.mov [rbp-40], edx
    x86.mov rcx, rsi
    x86.mov rdx, rdi
    x86.call mm_alloc
    x86.mov [rbp-16], eax
    x86.mov r8, 32
    x86.xor r9, r9
    x86.mov rcx, r8
    x86.mov rdx, rax
    x86.mov r8, r9
    x86.call mm_alloc_in
    x86.mov [rbp-24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-40]
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-24]
    x86.mov ecx, 81
    x86.mov [eax+8], ecx
    x86.xor eax, eax
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+16], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.mov [ecx+24], eax
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+0], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.mov rcx, rax
    x86.call stdlib.Print.print
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.epilogue
    x86.ret
  }
  func @leak-checker.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call leak-checker.make_string
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

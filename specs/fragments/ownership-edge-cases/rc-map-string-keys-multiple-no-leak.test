// Test: rc-map-string-keys-multiple-no-leak
function main() returns ExitCode
    var m = ["a": 1, "b": 2, "c": 3]
    let a = try m.get("a") otherwise 0
    let b = try m.get("b") otherwise 0
    let c = try m.get("c") otherwise 0
    return a + b + c
end 'main'

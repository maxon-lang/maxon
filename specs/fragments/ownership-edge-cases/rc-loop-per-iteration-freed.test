// Test: rc-loop-per-iteration-freed
typealias Integer = int(i64.min to i64.max)

type Counter
  export var n Integer
end 'Counter'

function main() returns ExitCode
  var total = 0
  var i = 0
  while i < 4 'loop'
    var c = Counter{n: i}
    total = total + c.n
    i = i + 1
  end 'loop'
  return total
end 'main'
---

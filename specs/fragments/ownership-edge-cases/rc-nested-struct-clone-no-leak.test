    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [ecx+0], edx
    x86.mov ebx, [rbp-16]
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }

incref Node #3 rc=2 [NodeArray.get]
incref Node #3 rc=3 [ownership-edge-cases.main]
decref NodeArray #2 rc=0 [ownership-edge-cases.main]
decref ElementMemory #1 rc=0 [~NodeArray]
  free ElementMemory #1

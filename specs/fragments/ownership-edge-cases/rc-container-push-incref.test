// Test: rc-container-push-incref
typealias Integer = int(i64.min to i64.max)

type Node
  export var id Integer
end 'Node'

typealias NodeArray = Array with Node

function main() returns ExitCode
  var arr = NodeArray{}
  if true 'scope'
    var n = Node{id: 10}
    arr.push(n)
  end 'scope'
  var got = try arr.get(0) otherwise Node{id: -1}
  return got.id
end 'main'

// Test: rc-return-from-inner-block-cleanup
typealias Integer = int(i64.min to i64.max)

type Step
  export var n Integer
end 'Step'

function compute(flag bool) returns Integer
  var outer = Step{n: 1}
  if flag 'inner'
    var inner = Step{n: 2}
    return outer.n + inner.n
  end 'inner'
  return outer.n
end 'compute'

function main() returns ExitCode
  return compute(true)
end 'main'
---

// Test: rc-enum-name-reassign-no-leak
enum Status
  pending
  active
  done
end 'Status'

function main() returns ExitCode
  var s = Status.pending
  s = Status.done
  if s.name == "done" 'check'
    return 1
  end 'check'
  return 0
end 'main'

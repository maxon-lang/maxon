// Test: interfaces.method-call-syntax.1
interface Incrementable
    function inc() returns int
end 'Incrementable'

type Value is Incrementable
    var n int

    function Incrementable.inc() returns int
        return n + 1
    end 'inc'
end 'Value'

function main() returns int
    var v = Value{n: 41}
    return v.inc()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %v = alloca.sized ptr 8
    memset %v 0 8
    %tmp_fieldptr = getfieldptr ptr %v 0
    %tmp_const = const.i64 i64 41
    store %tmp_fieldptr %tmp_const
    %tmp_call = call i64 @Value$inc(%v)
    ret %tmp_call
}

function Value$inc() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    ret %tmp_add
}


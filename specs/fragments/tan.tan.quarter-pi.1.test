// Test: tan.tan.quarter-pi.1
function main() returns int
    var quarterPi = 0.785398163
    var result = Math.tan(quarterPi)
    // Should be approximately 1.0
    var diff = abs(result - 1.0)
    if diff < 0.01 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 0.785398163
    %tmp_call = call f64 @Math$tan(%tmp_fconst)
    %tmp_fconst.1 = const.f64 f64 1
    %tmp_fsub = fsub f64 %tmp_call %tmp_fconst.1
    %tmp_fabs = fabs f64 %tmp_fsub
    %tmp_fconst.2 = const.f64 f64 0.01
    %tmp_fcmp = fcmp.lt i64 %tmp_fabs %tmp_fconst.2
    br.cond %tmp_fcmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end$check_2:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

---

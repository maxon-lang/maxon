// Test: static-variables.top-level-var-multiple.1
var a = 1
var b = 2
var c = 3

function main() returns int
    a = a * 10
    b = b * 10
    c = c * 10
    return a + b + c
end 'main'
---
ExitCode: 60
---
function main() -> i64 {

    %tmp_globaladdr.4 = global.addr ptr @global.a elemsize=8
    store %tmp_globaladdr.4 %tmp_mul
    %tmp_globaladdr.5 = global.addr ptr @global.b elemsize=8
    %tmp_load.1 = load i64 %tmp_globaladdr.5
    %tmp_const.4 = const.i64 i64 10
    %tmp_mul.1 = mul i64 %tmp_load.1 %tmp_const.4
    %tmp_globaladdr.6 = global.addr ptr @global.b elemsize=8
    store %tmp_globaladdr.6 %tmp_mul.1
    %tmp_globaladdr.7 = global.addr ptr @global.c elemsize=8
    %tmp_load.2 = load i64 %tmp_globaladdr.7
    %tmp_const.5 = const.i64 i64 10
    %tmp_mul.2 = mul i64 %tmp_load.2 %tmp_const.5
    %tmp_globaladdr.8 = global.addr ptr @global.c elemsize=8

// Test: var-redeclare-after-scope
function main() returns Integer
  if true 'check'
    var x = 10
  end 'check'
  var x = 42
  return x
end 'main'
---
ExitCode: 42
---
module {
  func @block-scoping.main() -> i64 {
  entry:
    x86.mov eax, 1
    x86.test eax, eax
    x86.je block-scoping.main.check_0.merge
  check_0:
    x86.jmp block-scoping.main.check_0.merge
  check_0.merge:
    x86.mov eax, 42
    x86.ret
  }
}
---

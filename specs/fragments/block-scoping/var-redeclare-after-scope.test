// Test: var-redeclare-after-scope
function main() returns ExitCode
  if true 'check'
    var x = 10
  end 'check'
  var x = 42
  return x
end 'main'
---
ExitCode: 42
---
module {
  func @block-scoping.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.test eax, eax
    x86.je block-scoping.main.check_0.merge
  check_0:
    x86.jmp block-scoping.main.check_0.merge
  check_0.merge:
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je block-scoping.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_8]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

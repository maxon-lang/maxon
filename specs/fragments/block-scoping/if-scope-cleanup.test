// Test: if-scope-cleanup
typealias IntArray = Array with int

function main() returns int
  var outer = IntArray{}
  outer.resize(3)
  outer.set(0, value: 10)
  if true 'block'
    var inner = IntArray{}
    inner.resize(5)
    inner.set(0, value: 20)
  end 'block'
  return try outer.get(0) otherwise 0
end 'main'

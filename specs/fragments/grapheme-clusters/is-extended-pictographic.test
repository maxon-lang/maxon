// Test: is-extended-pictographic
function main() returns ExitCode
  if isExtendedPictographic(128512) 'c1'
    print("{1}\n")  // 😀
  end 'c1'
  if isExtendedPictographic(65) 'c2'
    print("{0}\n")      // 'A'
  end 'c2'
  return 0
end 'main'

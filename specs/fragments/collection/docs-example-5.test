// Test: docs-example-5
function main() returns int
  var numbers = [1, 2, 3]
  var squared = numbers.map((x int) gives x * x)
  var val0 = try squared.get(0) otherwise 0
  var val1 = try squared.get(1) otherwise 0
  var val2 = try squared.get(2) otherwise 0
  print("{val0}\n")
  print("{val1}\n")
  print("{val2}\n")
  return 0
end 'main'


// Test: get-out-of-bounds
function main() returns int
  var arr = [1, 2, 3]
  var val = try arr.get(10) otherwise 6
  return val
end 'main'
---
ExitCode: 6
---
module {
  func @collection.main() -> i64 {
  entry:
    x86.prologue stack_size=64
    x86.mov eax, 3
    x86.xor ecx, ecx
    x86.mov edx, 8
    x86.xor ebx, ebx
    x86.lea_rdata rsi, [__const_array_collection.main_arr]
    x86.mov rdi, rsi
    x86.mov r8, 10
    x86.mov [rbp-8], edx
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], edi
    x86.mov [rbp-40], ebx
    x86.lea r9, [rbp-40]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call IntArray.get
    x86.mov ecx, 6
    x86.mov [rbp-48], ecx
    x86.mov [rbp-56], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je collection.main.otherwise_default_continue_4
  otherwise_default_error_3:
    x86.mov eax, [rbp-48]
    x86.mov [rbp-56], eax
    x86.jmp collection.main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x86.mov eax, [rbp-56]
    x86.epilogue
    x86.ret
  }
}
---

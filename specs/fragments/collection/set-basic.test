// Test: set-basic
function main() returns int
  var arr = [1, 2, 3]
  arr.set(0, value: 100)
  arr.set(2, value: 300)
  var val0 = try arr.get(0) otherwise 0
  var val1 = try arr.get(1) otherwise 0
  var val2 = try arr.get(2) otherwise 0
  print("{val0}\n")
  print("{val1}\n")
  print("{val2}\n")
  return 0
end 'main'

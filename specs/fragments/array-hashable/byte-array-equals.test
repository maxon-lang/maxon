// Test: byte-array-equals
typealias ByteVal = byte(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
  var a = ByteArr{}
  a.push(65)
  a.push(66)
  var b = ByteArr{}
  b.push(65)
  b.push(66)
  if a.equals(b) 'eq'
    return 1
  end 'eq'
  return 0
end 'main'
---
ExitCode: 1
---

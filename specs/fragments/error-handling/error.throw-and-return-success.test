// Test: error.throw-and-return-success

typealias Integer = int(i64.min to i64.max)

// Test that throwing function can return success value
union MyError implements Error
  failed
end 'MyError'

function mayFail(shouldFail bool) returns Integer throws MyError
  if shouldFail 'check'
    throw MyError.failed
  end 'check'
  return 42
end 'mayFail'

function main() returns ExitCode
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
}
---

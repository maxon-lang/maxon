// Test: error.assoc-value-throw-catch-2
// Test error enum with associated value - second case
enum MyError is Error
  notFound(code int)
  failed
end 'MyError'

function mayFail() returns int throws MyError
  throw MyError.notFound(42)
end 'mayFail'

function main() returns int
  var result = 0
  try mayFail() otherwise (e) 'handler'
    match e 'check'
      notFound(code) then result = code
      failed then result = 0
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov ebx, [rbp-8]
    x86.mov [eax+0], ebx
    x86.mov esi, [rbp-16]
    x86.mov [eax+8], esi
    x86.mov edx, eax
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.call error-handling.mayFail
    x86.mov [rbp-16], edx
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [ecx+0]
    x86.mov ebx, [rbp-24]
    x86.mov esi, [ebx+8]
    x86.mov [rbp-32], edx
    x86.mov edi, [rbp-32]
    x86.mov [rbp-40], esi
    x86.mov [rbp-48], edi
    x86.jmp error-handling.main.check_4.cmp0
  check_4.cmp0:
    x86.mov eax, [rbp-48]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.cmp1
  check_4.case0:
    x86.mov eax, [rbp-40]
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp1:
    x86.mov eax, [rbp-48]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.merge
  check_4.case1:
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

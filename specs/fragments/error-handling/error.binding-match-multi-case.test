// Test: error.binding-match-multi-case

typealias Integer = i64

// Test matching on error binding with multiple cases
enum MyError implements Error
  failed
  timeout
  notFound
end 'MyError'

function mayFail(code Integer) returns Integer throws MyError
  if code == 1 'c1'
    throw MyError.failed
  end 'c1'
  if code == 2 'c2'
    throw MyError.timeout
  end 'c2'
  throw MyError.notFound
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail(2) otherwise (e) 'handler'
    match e 'check'
      MyError.failed then result = 10
      MyError.timeout then result = 20
      MyError.notFound then result = 30
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @error-handling.mayFail(code: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, 1
    x86.cmp ecx, eax
    x86.jne error-handling.mayFail.c1_0.after
  c1_0:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  c1_0.after:
    x86.mov eax, 2
    x86.mov ecx, [rbp-8]
    x86.cmp ecx, eax
    x86.jne error-handling.mayFail.c2_1.after
  c2_1:
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  c2_1.after:
    x86.mov eax, 2
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.call error-handling.mayFail
    x86.mov [rbp-16], edx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.sub eax, ecx
    x86.mov [rbp-24], eax
    x86.jmp error-handling.main.check_4.cmp0
  check_4.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.cmp1
  check_4.case0:
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.cmp2
  check_4.case1:
    x86.mov eax, 20
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp2:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.merge
  check_4.case2:
    x86.mov eax, 30
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_5
  __range_panic_5:
    x86.lea_rdata rax, [__panic_msg_47]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov esi, 1
    x86.xor edi, edi
    x86.lea edx, [edi + esi]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  c1_0.after:
    x86.mov eax, 2
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jne error-handling.mayFail.c2_1.after
  c2_1:
    x86.xor eax, eax
    x86.mov rcx, rax

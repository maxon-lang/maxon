// Test: error.binding-match-single-case

typealias Integer = int(i64.min to i64.max)

// Test matching on typed error binding
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail() otherwise (e) 'handler'
    match e 'check'
      MyError.failed then result = 42
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, qword [rip+counter]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov qword [rip+counter], ecx
    x86.xor ebx, ebx
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov edi, 1
    x86.xor r8, r8
    x86.lea edx, [r8 + edi]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.call error-handling.mayFail
    x86.mov [rbp-24], edx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.sub eax, ecx
    x86.mov [rbp-32], eax
    x86.jmp error-handling.main.check_4.cmp0
  check_4.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.merge
  check_4.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-40], eax
    x86.mov ecx, 42
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-40]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.jmp error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_36]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-56], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-56]
    x86.epilogue
    x86.ret
  }
}
---

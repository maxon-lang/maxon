// Test: error.otherwise-block-with-binding

typealias Integer = int(i64.min to i64.max)

// Test try otherwise block with error binding - block is entered on error
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  var caught = 0
  try mayFail() otherwise (e) 'handler'
    caught = 42
  end 'handler'
  return caught
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.mov eax, qword [rip+counter]
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov qword [rip+counter], eax
    x86.xor edx, edx
    x86.mov ebx, 1
    x86.add edx, ebx
    x86.xor eax, eax
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.call error-handling.mayFail
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, 42
    x86.mov [rbp-16], eax
    x86.jmp error-handling.main.otherwise_continue_1
  otherwise_continue_1:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_30]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-24]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

// Test: error.otherwise-ignore
// Test try otherwise ignore
enum MyError is Error
  failed
end 'MyError'

function mayFail() returns int throws MyError
  throw MyError.failed
end 'mayFail'

function main() returns int
  try mayFail() otherwise ignore
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  }
  func @error-handling.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.call error-handling.mayFail
    x86.mov [rbp-8], edx
    x86.mov ecx, 42
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
}
---

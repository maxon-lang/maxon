// Test: error.otherwise-ignore

typealias Integer = int(i64.min to i64.max)

// Test try otherwise ignore
union MyError implements Error
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  try mayFail() otherwise ignore
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, qword [rip+counter]
    x86.mov edx, 1
    x86.add ecx, edx
    x86.mov qword [rip+counter], ecx
    x86.xor ebx, ebx
    x86.mov rcx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov edi, 1
    x86.xor r8, r8
    x86.lea edx, [r8 + edi]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call error-handling.mayFail
    x86.mov ecx, 42
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], edx
    x86.mov rcx, rbx
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
}
---

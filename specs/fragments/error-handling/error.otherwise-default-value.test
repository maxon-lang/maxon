// Test: error.otherwise-default-value

typealias Integer = int(i64.min to i64.max)

// Test try otherwise with default value
union MyError implements Error
  failed
end 'MyError'

function mayFail() returns Integer throws MyError
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  let val = try mayFail() otherwise 42
  return val
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov ebx, 1
    x86.xor esi, esi
    x86.lea edx, [esi + ebx]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call error-handling.mayFail
    x86.mov ecx, 42
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je error-handling.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp error-handling.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_24]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-32]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-40], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
}
---

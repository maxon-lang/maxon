// Test: error.enum-simple-error
// Simple union error type
union MyError implements Error
  invalidInput
  notFound
end 'MyError'

function main() returns ExitCode
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.main() -> u32 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
}
---

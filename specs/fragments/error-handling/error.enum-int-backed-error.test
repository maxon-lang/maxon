// Test: error.enum-int-backed-error
// Int-backed enum error type (type inferred from values)
enum MyError implements Error
  invalidInput = 1
  notFound = 404
end 'MyError'

function main() returns Integer
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.main() -> i64 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
}
---

// Test: error.enum-int-backed-error
// Int-backed union error type (type inferred from values)
union MyError implements Error
  invalidInput = 1
  notFound = 404
end 'MyError'

function main() returns ExitCode
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.main() -> u32 {
  entry:
    x86.mov eax, 42
    x86.ret
  }
}
---

// Test: error.enum-int-backed-error
// Int-backed union error type (type inferred from values)
union MyError implements Error
  invalidInput = 1
  notFound = 404
end 'MyError'

function main() returns ExitCode
  return 42
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 42
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 42
    x86.epilogue
    x86.ret
  }
}
---

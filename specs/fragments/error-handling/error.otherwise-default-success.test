// Test: error.otherwise-default-success

typealias Integer = int(i64.min to i64.max)

// Test try otherwise when no error occurs
union MyError implements Error
  failed
end 'MyError'

function mayFail(shouldFail bool) returns Integer throws MyError
  if shouldFail 'check'
    throw MyError.failed
  end 'check'
  return 100
end 'mayFail'

function main() returns ExitCode
  let val = try mayFail(false) otherwise 42
  return val
end 'main'
---
ExitCode: 100
---
module {
  func @error-handling.mayFail(shouldFail: i1) -> i64 {
  entry:
    x86.test rcx, rcx
    x86.je error-handling.mayFail.check_0.after
  check_0:
    x86.xor rax, rax
    x86.mov rcx, 1
    x86.add rax, rcx
    x86.mov rdx, rax
    x86.xor rax, rax
    x86.ret
  check_0.after:
    x86.mov rax, 100
    x86.xor rdx, rdx
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor rcx, rcx
    x86.call error-handling.mayFail
    x86.mov rcx, 42
    x86.mov [rbp-8], rcx
    x86.mov [rbp-16], rax
    x86.xor rax, rax
    x86.cmp rdx, rax
    x86.je error-handling.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov rax, [rbp-8]
    x86.mov [rbp-16], rax
    x86.jmp error-handling.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov rax, [rbp-16]
    x86.mov [rbp-24], rax
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.setl rdx
    x86.movzx rdx, rdxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg rsi
    x86.movzx rsi, rsib
    x86.or rdx, rsi
    x86.test rdx, rdx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_symdata rax, [__panic_msg_25]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

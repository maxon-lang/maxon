// Test: error.otherwise-default-success
// Test try otherwise when no error occurs
enum MyError implements Error
  failed
end 'MyError'

function mayFail(shouldFail bool) returns int throws MyError
  if shouldFail 'check'
    throw MyError.failed
  end 'check'
  return 100
end 'mayFail'

function main() returns int
  let val = try mayFail(false) otherwise 42
  return val
end 'main'
---
ExitCode: 100
---
module {
  func @error-handling.mayFail(shouldFail: i1) -> i64 {
  entry:
    x86.test ecx, ecx
    x86.je error-handling.mayFail.check_0.after
  check_0:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 100
    x86.xor edx, edx
    x86.ret
  }
  func @error-handling.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call error-handling.mayFail
    x86.mov ecx, 42
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je error-handling.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.jmp error-handling.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

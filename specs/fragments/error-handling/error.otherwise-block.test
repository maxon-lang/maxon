// Test: error.otherwise-block
// Test try otherwise block handler
enum MyError implements Error
  failed
end 'MyError'

function mayFail() returns Integer throws MyError
  throw MyError.failed
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail() otherwise 'err'
    result = 42
  end 'err'
  return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.xor eax, eax
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov edx, eax
    x86.xor eax, eax
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.call error-handling.mayFail
    x86.xor ecx, ecx
    x86.cmp edx, ecx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.jmp error-handling.main.otherwise_continue_1
  otherwise_continue_1:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_4
  __range_panic_4:
    x86.lea_rdata rax, [__panic_msg_23]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_4:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: error.assoc-value-throw-catch

typealias Integer = int(i64.min to i64.max)

// Test error union with associated value - throw and catch
union MyError implements Error
  notFound(code Integer)
  failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
  counter = counter + 1
  throw MyError.notFound(404)
end 'mayFail'

function main() returns ExitCode
  var result = 0
  try mayFail() otherwise (e) 'handler'
    match e 'check'
      notFound(code) then result = code
      failed then result = 1
    end 'check'
  end 'handler'
  return result
end 'main'
---
ExitCode: 404
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, qword [rip+counter]
    x86.mov ecx, 1
    x86.add eax, ecx
    x86.mov qword [rip+counter], eax
    x86.mov edx, 404
    x86.mov rcx, 16
    x86.xor rdx, rdx
    x86.call mm_alloc
    x86.mov [rbp-8], eax
    x86.xor ebx, ebx
    x86.mov [eax+0], ebx
    x86.mov esi, 404
    x86.mov [eax+8], esi
    x86.mov edx, [rbp-8]
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x86.prologue stack_size=64
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.call error-handling.mayFail
    x86.mov [rbp-32], edx
    x86.xor ebx, ebx
    x86.cmp edx, ebx
    x86.je error-handling.main.otherwise_continue_1
  otherwise_error_0:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.call mm_incref
    x86.mov edx, [rbp-8]
    x86.mov ebx, [edx+0]
    x86.mov esi, [rbp-8]
    x86.mov [rbp-16], esi
    x86.mov edi, [rbp-16]
    x86.mov [rbp-56], ebx
    x86.mov rcx, [rbp-16]
    x86.call mm_incref
    x86.mov r8, [rbp-56]
    x86.mov [rbp-40], r8
    x86.jmp error-handling.main.check_4.cmp0
  check_4.cmp0:
    x86.mov eax, [rbp-40]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.cmp1
  check_4.case0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [eax+8]
    x86.mov [rbp-24], ecx
    x86.jmp error-handling.main.check_4.merge
  check_4.cmp1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne error-handling.main.check_4.merge
  check_4.case1:
    x86.mov eax, 1
    x86.mov [rbp-24], eax
    x86.jmp error-handling.main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je error-handling.main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov eax, [rbp-48]
    x86.mov ecx, [rbp-8]
    x86.test ecx, ecx
    x86.jz __nonnull_skip_0
    x86.call mm_decref
    x86.label __nonnull_skip_0
    x86.mov eax, [rbp-16]
    x86.test eax, eax
    x86.jz __nonnull_skip_1
    x86.mov rcx, [rbp-16]
    x86.call mm_decref
    x86.label __nonnull_skip_1
    x86.mov eax, [rbp-48]
    x86.epilogue
    x86.ret
  }
}
---

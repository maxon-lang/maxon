    x86.test edx, edx
    x86.je missing-return-error.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_12]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:

// Test: valid-all-paths

typealias Integer = i64

function test(x Integer) returns Integer
  if x > 0 'check'
    return 1
  end 'check'
  return 0
end 'test'

function main() returns ExitCode
  return test(5)
end 'main'
---
ExitCode: 1
---
module {

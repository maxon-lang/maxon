// Test: pass-by-reference.mutate-primitive-ref

typealias Integer = int(i64.min to i64.max)

function setTo99(x Integer)
  x = 99
end 'setTo99'

function main() returns ExitCode
  var n = 0
  setTo99(x: n)
  print("{n}")
  return 0
end 'main'

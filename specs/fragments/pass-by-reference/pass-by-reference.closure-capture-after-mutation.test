// Test: pass-by-reference.closure-capture-after-mutation

typealias Integer = int(i64.min to i64.max)

function apply(f () returns Integer) returns Integer
  return f()
end 'apply'

function main() returns ExitCode
  var x = 10
  var f = () gives x
  x = 99
  var result = apply(f: f)
  return result
end 'main'

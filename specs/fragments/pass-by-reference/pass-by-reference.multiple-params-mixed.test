// Test: pass-by-reference.multiple-params-mixed

typealias Integer = int(i64.min to i64.max)

function process(a Integer, b Integer, c Integer)
  b = a + c + 90
end 'process'

function main() returns ExitCode
  var x = 1
  var y = 2
  var z = 3
  process(a: x, b: y, c: z)
  print("{x}\n")
  print("{y}\n")
  print("{z}\n")
  return 0
end 'main'

// Test: pass-by-reference.default-param-value

typealias Integer = int(i64.min to i64.max)

function addOffset(x Integer, offset Integer = 10) returns Integer
  return x + offset
end 'addOffset'

function main() returns ExitCode
  var result = addOffset(x: 32)
  return result
end 'main'
---
ExitCode: 42
---
module {
  func @pass-by-reference.addOffset(x: i64, offset: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret

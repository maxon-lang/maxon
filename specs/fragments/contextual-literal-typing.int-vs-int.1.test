// Test: contextual-literal-typing.int-vs-int.1
function main() returns int
    var a = 1000
    var b = 1000
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1000
    %tmp_const.1 = const.i64 i64 1000
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$check_1 @end$check_2
then$check_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$check_2:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

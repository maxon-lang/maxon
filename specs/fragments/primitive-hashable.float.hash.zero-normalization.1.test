// Test: primitive-hashable.float.hash.zero-normalization.1
function main() returns int
    var pos = 0.0
    var neg = -0.0
    var h1 = pos.hash()
    var h2 = neg.hash()
    if h1 == h2 'eq'
        return 1
    end 'eq'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 0
    %tmp_fconst.1 = const.f64 f64 -0
    %neg = alloca ptr
    store %neg %tmp_fconst.1
    %tmp_fconst.2 = const.f64 f64 0
    %tmp_fcmp = fcmp.eq i64 %tmp_fconst %tmp_fconst.2
    %tmp_alloca.2 = alloca ptr
    br.cond %tmp_fcmp @float_hash_zero_1 @float_hash_nonzero_2
float_hash_zero_1:
    %tmp_const = const.i64 i64 0
    store %tmp_alloca.2 %tmp_const
    br @float_hash_end_3
float_hash_nonzero_2:
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    store %tmp_alloca.2 %tmp_bitcast
    br @float_hash_end_3
float_hash_end_3:
    %tmp_load.1 = load i64 %tmp_alloca.2
    %h1 = alloca ptr
    store %h1 %tmp_load.1
    %tmp_load.2 = load f64 %neg
    %tmp_fconst.3 = const.f64 f64 0
    %tmp_fcmp.1 = fcmp.eq i64 %tmp_load.2 %tmp_fconst.3
    %tmp_alloca.4 = alloca ptr
    br.cond %tmp_fcmp.1 @float_hash_zero_4 @float_hash_nonzero_5
float_hash_zero_4:
    %tmp_const.1 = const.i64 i64 0
    store %tmp_alloca.4 %tmp_const.1
    br @float_hash_end_6
float_hash_nonzero_5:
    %tmp_bitcast.1 = bitcast.f64.i64 i64 %tmp_load.2
    store %tmp_alloca.4 %tmp_bitcast.1
    br @float_hash_end_6
float_hash_end_6:
    %tmp_load.3 = load i64 %tmp_alloca.4
    %tmp_load.4 = load i64 %h1
    %tmp_icmp = icmp.eq i64 %tmp_load.4 %tmp_load.3
    br.cond %tmp_icmp @then$eq_7 @end$eq_8
then$eq_7:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$eq_8:
    %tmp_const.3 = const.i64 i64 0
    ret %tmp_const.3
}

---

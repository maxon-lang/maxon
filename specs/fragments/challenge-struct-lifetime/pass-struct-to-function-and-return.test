// Test: pass-struct-to-function-and-return
type Counter
  export var value int
end 'Counter'

function increment(c Counter) returns Counter
  return {value: c.value + 1}
end 'increment'

function main() returns int
  var c1 = Counter{value: 10}
  var c2 = increment(c1)
  return c2.value
end 'main'
---
ExitCode: 11
---
module {
  func @challenge-struct-lifetime.increment(c: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, 1
    x86.add edx, eax
    x86.mov eax, 8
    x86.mov [rbp-24], edx
    x86.mov rcx, rax
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-24]
    x86.mov [ecx+0], edx
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
  func @challenge-struct-lifetime.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 10
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call challenge-struct-lifetime.increment
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-16]
    x86.mov r8, [edi+0]
    x86.mov eax, r8
    x86.epilogue
    x86.ret
  }
}

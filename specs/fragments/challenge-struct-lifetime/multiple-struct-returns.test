// Test: multiple-struct-returns
type Value
  export var n int
end 'Value'

function step1() returns Value
  return {n: 1}
end 'step1'

function step2(v Value) returns Value
  return {n: v.n + 10}
end 'step2'

function step3(v Value) returns Value
  return {n: v.n + 100}
end 'step3'

function main() returns int
  var v1 = step1()
  var v2 = step2(v1)
  var v3 = step3(v2)
  return v3.n
end 'main'
---
ExitCode: 111

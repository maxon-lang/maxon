// Test: int-promotion
function main() returns int
  var result = Math.exp(3)  // Int promoted to float
  return trunc(result)
end 'main'
---
ExitCode: 20
---
module {
  func @main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.cvtsi2sd xmm0, eax
    x86.call Math.exp
    x86.cvttsd2si ecx, xmm0
    x86.mov eax, ecx
    x86.ret
  }
}
---

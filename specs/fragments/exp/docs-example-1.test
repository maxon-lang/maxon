// Test: docs-example-1
function main() returns Integer
  var result = Math.exp(0.0)  // e^0 = 1
  return trunc(result)
end 'main'

---
ExitCode: 1
---
module {
  func @exp.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_0]
    x86.call stdlib.Math.exp
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}

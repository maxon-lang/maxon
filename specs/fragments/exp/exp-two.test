// Test: exp-two
function main() returns int
  var result = Math.exp(2.0)  // e^2 ≈ 7.389
  return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @exp.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_2]
    x86.call stdlib.Math.exp
    x86.cvttsd2si eax, xmm0
    x86.ret
  }
}
---

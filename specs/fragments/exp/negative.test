// Test: negative
function main() returns int
  var result = Math.exp(-1.0)  // e^-1 ≈ 0.368
  return trunc(result)
end 'main'
---
ExitCode: 0
---
module {
  func @exp.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.movsd xmm0, [rip+__float_-1]
    x86.call stdlib.Math.exp
    x86.movsd [rbp-8], xmm0
    x86.cvttsd2si eax, xmm0
    x86.epilogue
    x86.ret
  }
}
---

// Test: match-range.open-upper
function main() returns ExitCode
  var x = 100
  match x 'check'
    10 to max then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 100
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 10
    x86.cmp eax, ecx
    x86.jl match-statements.main.check_0.case1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

// Test: match-enum.expression
union Status
  pending
  approved
  rejected
end 'Status'

function main() returns ExitCode
  var s = Status.approved
  let code = match s 'eval'
    Status.pending gives 0
    Status.approved gives 1
    Status.rejected gives 2
  end 'eval'
  return code
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.xor rcx, rcx
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov eax, 1
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.xor edx, edx
    x86.mov [rbp-24], edx
    x86.mov [rbp-32], ecx
    x86.jmp match-statements.main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne match-statements.main.eval_0.cmp1
  eval_0.case0:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-statements.main.eval_0.cmp2
  eval_0.case1:
    x86.mov eax, 1
    x86.mov [rbp-24], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.cmp2:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-statements.main.eval_0.merge
  eval_0.case2:
    x86.mov eax, 2
    x86.mov [rbp-24], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.merge:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-statements.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_31]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  }
}

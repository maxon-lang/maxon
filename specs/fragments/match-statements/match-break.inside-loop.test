// Test: match-break.inside-loop
function main() returns Integer
  var result = 0
  var i = 0
  while i < 5 'loop'
    match i 'check'
      3 then break 'loop'
      default then result = result + 1
    end 'check'
    i = i + 1
  end 'loop'
  return result
end 'main'
---
ExitCode: 3
---
module {
  func @match-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp match-statements.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge match-statements.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp match-statements.main.check_1.cmp0
  check_1.cmp0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_1.case1
  check_1.case0:
    x86.jmp match-statements.main.loop_0.exit
  check_1.case1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-statements.main.check_1.merge
  check_1.merge:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.jmp match-statements.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

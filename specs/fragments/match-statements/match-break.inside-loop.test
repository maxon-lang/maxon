  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.jmp match-statements.main.loop_0.header
  loop_0.header:
    x86.mov eax, 5
    x86.mov ecx, [rbp-16]
    x86.cmp ecx, eax
    x86.jge match-statements.main.loop_0.exit
  loop_0:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.jmp match-statements.main.check_1.cmp0
  check_1.cmp0:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_1.case1
  check_1.case0:
    x86.jmp match-statements.main.loop_0.exit
  check_1.case1:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-statements.main.check_1.merge
  check_1.merge:
    x86.mov eax, 1
    x86.mov ecx, [rbp-16]
    x86.add ecx, eax
    x86.mov [rbp-16], ecx
    x86.jmp match-statements.main.loop_0.header
  loop_0.exit:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-statements.main.__range_ok_2
  __range_panic_2:
    x86.lea_symdata rax, [__panic_msg_21]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:

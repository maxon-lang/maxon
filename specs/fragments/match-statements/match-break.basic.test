// Test: match-break.basic
function main() returns int
  var result = 0
  match 2 'check'
    1 then result = 10
    2 then break
    default then result = 99
  end 'check'
  return result
end 'main'
---
ExitCode: 0
---
module {
  func @match-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, 2
    x86.mov [rbp-16], ecx
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.merge
  check_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_0.case2
  check_0.case1:
    x86.jmp match-statements.main.check_0.merge
  check_0.case2:
    x86.mov eax, 99
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

// Test: match-range.expression
function main() returns ExitCode
  var temp = 22
  let category = match temp 'weather'
    min upto 0 gives 1
    0 upto 15 gives 2
    15 upto 25 gives 3
    25 to max gives 4
  end 'weather'
  return category
end 'main'
---
ExitCode: 3

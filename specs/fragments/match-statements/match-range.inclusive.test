// Test: match-range.inclusive
function main() returns Integer
  var x = 5
  match x 'check'
    1 to 5 then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.setge edx
    x86.movzx edx, edxb
    x86.mov ebx, [rbp-8]
    x86.mov esi, 5
    x86.cmp ebx, esi
    x86.setle edi
    x86.movzx edi, edib
    x86.and edx, edi
    x86.test edx, edx
    x86.je match-statements.main.check_0.case1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

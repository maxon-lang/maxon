// Test: match-range.float
function main() returns ExitCode
  var x = 2.5
  match x 'check'
    0.0 to 5.0 then return 1
    default then return 0
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.movsd xmm0, [rip+__float_2.5]
    x86.movsd [rbp-16], xmm0
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.movsd xmm0, [rbp-16]
    x86.movsd xmm1, [rip+__float_0]
    x86.ucomisd xmm0, xmm1
    x86.setae eax
    x86.movzx eax, eaxb
    x86.movsd xmm2, [rbp-16]
    x86.movsd xmm3, [rip+__float_5]
    x86.ucomisd xmm2, xmm3
    x86.setbe ecx
    x86.movzx ecx, ecxb
    x86.and eax, ecx
    x86.test eax, eax
    x86.je match-statements.main.check_0.case1
  check_0.case0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-24], eax
    x86.mov eax, 1
    x86.mov ecx, [rbp-24]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.case1:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-32], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-32]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

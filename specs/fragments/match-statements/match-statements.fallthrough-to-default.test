// Test: match-statements.fallthrough-to-default
function main() returns ExitCode
  var x = 3
  var result = 0
  match x 'check'
    1 then result = 10
    2 then result = 20
    3 then result = result + 30 and fallthrough
    default then result = result + 100
  end 'check'
  return result
end 'main'
---
ExitCode: 130
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 3
    x86.xor ecx, ecx
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.merge
  check_0.cmp1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_0.cmp2
  check_0.case1:
    x86.mov eax, 20
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.check_0.merge
  check_0.cmp2:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 3
    x86.cmp eax, ecx
    x86.jne match-statements.main.check_0.case3
  check_0.case2:
    x86.mov eax, 30
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-statements.main.check_0.case3
  check_0.case3:
    x86.mov eax, 100
    x86.mov ecx, [rbp-8]
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.jmp match-statements.main.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je match-statements.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_25]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

    x86.mov ebx, [rbp-8]
    x86.mov esi, 2
    x86.cmp ebx, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.or edx, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 3
    x86.cmp r8, r9
    x86.sete eax
    x86.movzx eax, eaxb
    x86.or edx, eax
    x86.test edx, edx
    x86.je match-statements.categorize.cat_0.cmp1
  cat_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  cat_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 4
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, [rbp-8]
    x86.mov esi, 5
    x86.cmp ebx, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.or edx, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 6
    x86.cmp r8, r9
    x86.sete eax
    x86.movzx eax, eaxb
    x86.or edx, eax
    x86.test edx, edx
    x86.je match-statements.categorize.cat_0.case2
  cat_0.case1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  cat_0.case2:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  cat_0.merge:
  }
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov rcx, 5
    x86.call match-statements.categorize
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx

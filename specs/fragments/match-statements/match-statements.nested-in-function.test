// Test: match-statements.nested-in-function
function categorize(n Integer) returns Integer
  match n 'cat'
    1 or 2 or 3 then return 1
    4 or 5 or 6 then return 2
    default then return 0
  end 'cat'
end 'categorize'

function main() returns Integer
  return categorize(5)
end 'main'
---
ExitCode: 2
---
module {
  func @match-statements.categorize(n: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.jmp match-statements.categorize.cat_0.cmp0
  cat_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, [rbp-8]
    x86.mov esi, 2
    x86.cmp ebx, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.or edx, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 3
    x86.cmp r8, r9
    x86.sete eax
    x86.movzx eax, eaxb
    x86.or edx, eax
    x86.test edx, edx
    x86.je match-statements.categorize.cat_0.cmp1
  cat_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  cat_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 4
    x86.cmp eax, ecx
    x86.sete edx
    x86.movzx edx, edxb
    x86.mov ebx, [rbp-8]
    x86.mov esi, 5
    x86.cmp ebx, esi
    x86.sete edi
    x86.movzx edi, edib
    x86.or edx, edi
    x86.mov r8, [rbp-8]
    x86.mov r9, 6
    x86.cmp r8, r9
    x86.sete eax
    x86.movzx eax, eaxb
    x86.or edx, eax
    x86.test edx, edx
    x86.je match-statements.categorize.cat_0.case2
  cat_0.case1:
    x86.mov eax, 2
    x86.epilogue
    x86.ret
  cat_0.case2:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  cat_0.merge:
  }
  func @match-statements.main() -> i64 {
  entry:
    x86.mov eax, 5
    x86.mov rcx, rax
    x86.jmp match-statements.categorize
  }
}
---

    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je match-statements.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_38]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:

// Test: match-expression.used-in-expression
function main() returns ExitCode
  var x = 2
  let doubled = match x 'eval'
    1 gives 10
    2 gives 20
    default gives 0
  end 'eval' * 2
  return doubled
end 'main'
---
ExitCode: 40
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov rax, 2
    x86.mov [rbp-8], rax
    x86.jmp match-statements.main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne match-statements.main.eval_0.cmp1
  eval_0.case0:
    x86.mov rax, 10
    x86.mov [rbp-16], rax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne match-statements.main.eval_0.case2
  eval_0.case1:
    x86.mov rax, 20
    x86.mov [rbp-16], rax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.case2:
    x86.xor rax, rax
    x86.mov [rbp-16], rax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.merge:
    x86.mov rax, [rbp-16]
    x86.mov rcx, 2
    x86.imul rax, rcx
    x86.mov [rbp-24], rax
    x86.xor rdx, rdx
    x86.cmp rax, rdx
    x86.setl rbx
    x86.movzx rbx, rbxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg rdi
    x86.movzx rdi, rdib
    x86.or rbx, rdi
    x86.test rbx, rbx
    x86.je match-statements.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_19]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov rax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

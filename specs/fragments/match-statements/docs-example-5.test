// Test: docs-example-5
union Direction
  north
  south
  east
  west
end 'Direction'

function main() returns ExitCode
  var dir = Direction.north
  match dir 'navigate'
    Direction.north then return 1
    Direction.south then return 2
    Direction.east then return 3
    Direction.west then return 4
  end 'navigate'
end 'main'

---
ExitCode: 1
---
module {
  func @match-statements.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor rax, rax
    x86.mov [rbp-8], rax
    x86.jmp match-statements.main.navigate_0.cmp0
  navigate_0.cmp0:
    x86.mov rax, [rbp-8]
    x86.xor rcx, rcx
    x86.cmp rax, rcx
    x86.jne match-statements.main.navigate_0.cmp1
  navigate_0.case0:
    x86.mov rax, 1
    x86.epilogue
    x86.ret
  navigate_0.cmp1:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 1
    x86.cmp rax, rcx
    x86.jne match-statements.main.navigate_0.cmp2
  navigate_0.case1:
    x86.mov rax, 2
    x86.epilogue
    x86.ret
  navigate_0.cmp2:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 2
    x86.cmp rax, rcx
    x86.jne match-statements.main.navigate_0.cmp3
  navigate_0.case2:
    x86.mov rax, 3
    x86.epilogue
    x86.ret
  navigate_0.cmp3:
    x86.mov rax, [rbp-8]
    x86.mov rcx, 3
    x86.cmp rax, rcx
    x86.jne match-statements.main.navigate_0.merge
  navigate_0.case3:
    x86.mov rax, 4
    x86.epilogue
    x86.ret
  navigate_0.merge:
  }
}
---

// Test: docs-example-8
function charType(c Character) returns int
  match c 'classify'
    'a' to 'z' then return 1  // lowercase
    'A' to 'Z' then return 2  // uppercase
    '0' to '9' then return 3  // digit
    default then return 0    // other
  end 'classify'
end 'charType'

function main() returns int
  return charType('G')
end 'main'


// Test: match-expression.default
function main() returns Integer
  var x = 99
  let result = match x 'eval'
    1 gives 10
    2 gives 20
    default gives 0
  end 'eval'
  return result
end 'main'
---
ExitCode: 0
---
module {
  func @match-statements.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 99
    x86.mov [rbp-8], eax
    x86.jmp match-statements.main.eval_0.cmp0
  eval_0.cmp0:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne match-statements.main.eval_0.cmp1
  eval_0.case0:
    x86.mov eax, 10
    x86.mov [rbp-16], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.cmp1:
    x86.mov eax, [rbp-8]
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.jne match-statements.main.eval_0.case2
  eval_0.case1:
    x86.mov eax, 20
    x86.mov [rbp-16], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.case2:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp match-statements.main.eval_0.merge
  eval_0.merge:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

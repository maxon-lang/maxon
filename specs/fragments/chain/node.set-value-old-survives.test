// Test: node.set-value-old-survives
typealias StringChain = Chain with String

function main() returns ExitCode
  var chain = StringChain{}
  var node = chain.insertFirst("hello world!!!!!!!!!!!!!!")
  var old = node.value()
  node.setValue(v: "replacement!!!!!!!!!!!!!!")
  print("{old}\n")
  print("{node.value()}\n")
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello world!!!!!!!!!!!!!!
replacement!!!!!!!!!!!!!!
```

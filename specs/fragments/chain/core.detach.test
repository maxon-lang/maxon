// Test: core.detach
typealias Integer = int(i64.min to i64.max)
typealias IntChain = __Chain with Integer

function main() returns ExitCode
  var chain = IntChain{}
  var n1 = chain.insertLast(10)
  var n2 = chain.insertLast(20)
  var n3 = chain.insertLast(30)
  // Detach middle node
  chain.detach(node: n2)
  print("{chain.count()}\n")
  // Verify remaining via handles
  print("{n1.value()}\n")
  print("{n3.value()}\n")
  // Detached node still holds its value
  print("{n2.value()}\n")
  return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
10
30
20
```

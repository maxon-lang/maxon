// Test: node.prev-begin-throws
typealias Integer = int(i64.min to i64.max)
typealias IntChain = __Chain with Integer

function main() returns ExitCode
  var chain = IntChain{}
  var node = chain.insertFirst(42)
  // Use the node handle
  print("{node.value()}\n")
  var h = try chain.head() otherwise 'err'
    return 1
  end 'err'
  // Try to go before beginning
  if try h.prev() 'try'
    return 1
  end 'try' else 'err2'
    print("caught\n")
    return 0
  end 'err2'
end 'main'

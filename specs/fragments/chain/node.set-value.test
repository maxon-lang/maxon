// Test: node.set-value
typealias Integer = int(i64.min to i64.max)
typealias IntChain = __Chain with Integer

function main() returns ExitCode
  var chain = IntChain{}
  var node = chain.insertFirst(10)
  print("{node.value()}\n")
  node.setValue(v: 99)
  print("{node.value()}\n")
  // Verify through chain head too
  var h = try chain.head() otherwise 'err'
    return 1
  end 'err'
  print("{h.value()}\n")
  return 0
end 'main'
---

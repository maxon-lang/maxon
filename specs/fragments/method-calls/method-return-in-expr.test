// Test: method-return-in-expr
type Box
  var value int

  function getValue() returns int
    return value
  end 'getValue'
end 'Box'

function main() returns int
  var b = Box{value: 40}
  return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
module {
  func @Box.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 40
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Box.getValue
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.mov edi, 2
    x86.add eax, edi
    x86.epilogue
    x86.ret
  }
}
---

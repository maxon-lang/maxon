// Test: method-return-in-expr
type Box
    var value int

    function getValue() returns int
        return value
    end 'getValue'
end 'Box'

function main() returns int
    var b = Box{value: 40}
    return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 40
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rdx, qword ptr [rbp-48]
    x86.mov rax, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rdx
    x86.mov rsi, rcx
    x86.mov rcx, rax
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rcx, rdx
    x86.call Box.getValue
    x86.mov rdx, rax
    x86.mov rax, 2
    x86.mov rcx, rdx
    x86.add rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}

func.func @Box.getValue(%self: memref<!maxon.struct<Box>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Box>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

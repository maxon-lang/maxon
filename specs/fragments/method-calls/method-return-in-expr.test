// Test: method-return-in-expr
type Box
    var value int

    function getValue() returns int
        return value
    end 'getValue'
end 'Box'

function main() returns int
    var b = Box{value: 40}
    return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.mov rax, 40
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea r8, qword ptr [rbp-48]
    x86.mov qword ptr [r8], rcx
    x86.mov rcx, qword ptr [r8]
    x86.call Box.getValue
    x86.mov rcx, rax
    x86.mov r8, 2
    x86.mov rax, rcx
    x86.add rax, r8
    x86.epilogue
    x86.ret
}

func.func @Box.getValue(%self: !maxon.struct<Box>) -> i64 {
  ^entry(%self: !maxon.struct<Box>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

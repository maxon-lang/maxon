// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
  var value Integer

  function getValue() returns Integer
    return value
  end 'getValue'
end 'Box'

function main() returns ExitCode
  var b = Box{value: 40}
  return b.getValue() + 2
end 'main'
---
ExitCode: 42
---

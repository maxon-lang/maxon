// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
  var value Integer

  function getValue() returns Integer
    return value
  end 'getValue'
end 'Box'

function main() returns ExitCode
  var b = Box{value: 40}
  return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
module {
  func @Box.getValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 40
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 40
    x86.mov [edx+0], ebx
    x86.mov rcx, [rbp-8]
    x86.call Box.getValue
    x86.mov edi, 2
    x86.add eax, edi
    x86.mov [rbp-16], eax
    x86.xor r8, r8
    x86.cmp eax, r8
    x86.setl r9
    x86.movzx r9, r9b
    x86.mov rcx, 4294967295
    x86.cmp rax, rcx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r9, eax
    x86.test r9, r9
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

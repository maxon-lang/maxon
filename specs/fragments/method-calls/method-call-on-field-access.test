    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, [rbp-16]
    x86.mov rcx, r9
    x86.call Outer.getInnerValue
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295

    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp Inner.get
  }

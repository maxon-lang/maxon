// Test: method-call-on-field-access

typealias Integer = i64

type Inner
  var value Integer

  function get() returns Integer
    return value
  end 'get'
end 'Inner'

type Outer
  var inner Inner

  function getInnerValue() returns Integer
    return inner.get()
  end 'getInnerValue'
end 'Outer'

function main() returns ExitCode
  var o = Outer{inner: Inner{value: 42}}
  return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp Inner.get
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov r9, [rbp-16]
    x86.mov rcx, r9
    x86.call Outer.getInnerValue
    x86.mov [rbp-24], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_16]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

// Test: method-call-on-field-access
type Inner
  var value int

  function get() returns int
    return value
  end 'get'
end 'Inner'

type Outer
  var inner Inner

  function getInnerValue() returns int
    return inner.get()
  end 'getInnerValue'
end 'Outer'

function main() returns int
  var o = Outer{inner: Inner{value: 42}}
  return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.xor eax, eax
    x86.add ecx, eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-24], ecx
    x86.lea rdx, [rbp-24]
    x86.mov rcx, rdx
    x86.call Inner.get
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-16], ebx
    x86.mov esi, [rbp-8]
    x86.xor edi, edi
    x86.add esi, edi
    x86.mov r8, [rbp-16]
    x86.mov [esi+0], r8
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-24]
    x86.mov [rbp-32], ebx
    x86.lea rsi, [rbp-32]
    x86.mov rcx, rsi
    x86.call Outer.getInnerValue
    x86.mov edi, [rbp-32]
    x86.mov [rbp-24], edi
    x86.epilogue
    x86.ret
  }
}
---

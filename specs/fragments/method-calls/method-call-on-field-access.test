// Test: method-call-on-field-access
type Inner
  var value int

  function get() returns int
    return value
  end 'get'
end 'Inner'

type Outer
  var inner Inner

  function getInnerValue() returns int
    return inner.get()
  end 'getInnerValue'
end 'Outer'

function main() returns int
  var o = Outer{inner: Inner{value: 42}}
  return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov [rbp-16], edx
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp Inner.get
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, 8
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [r8+0], edi
    x86.mov rcx, [rbp-16]
    x86.epilogue
    x86.jmp Outer.getInnerValue
  }
}
---

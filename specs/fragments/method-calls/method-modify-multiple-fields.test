// Test: method-modify-multiple-fields
type Point
    var x int
    var y int

    function moveBy(dx int, dy int)
        x = x + dx
        y = y + dy
    end 'moveBy'

    function sum() returns int
        return x + y
    end 'sum'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 10}
    p.moveBy(10, dy: 12)
    return p.sum()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=72 saved_gprs=[RBX]
    x86.mov rax, 10
    x86.lea rcx, qword ptr [rbp-48]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rdx, qword ptr [rcx+8]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-64]
    x86.mov qword ptr [rbx], rcx
    x86.mov rcx, [rbx]
    x86.mov rdx, 12
    x86.mov r10, rcx
    x86.mov r11, rax
    x86.push rdx
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Point.moveBy
    x86.mov rdx, [rbx]
    x86.mov rcx, rdx
    x86.call Point.sum
    x86.mov rdx, rax
    x86.mov rax, rdx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Point.moveBy(%self: !maxon.struct<Point>, %dx: i64, %dy: i64) {
  ^entry(%self: !maxon.struct<Point>, %dx: i64, %dy: i64):
    x86.prologue stack_size=32
    x86.mov r10, rcx
    x86.mov r11, rdx
    x86.mov rax, r8
    x86.mov rcx, r10
    x86.mov rdx, r11
    x86.lea r8, qword ptr [rcx]
    x86.mov r9, qword ptr [r8]
    x86.mov r10, r9
    x86.add r10, rdx
    x86.mov qword ptr [r8], r10
    x86.lea r10, qword ptr [rcx+8]
    x86.mov rcx, qword ptr [r10]
    x86.mov r8, rcx
    x86.add r8, rax
    x86.mov qword ptr [r10], r8
    x86.epilogue
    x86.ret
}

func.func @Point.sum(%self: !maxon.struct<Point>) -> i64 {
  ^entry(%self: !maxon.struct<Point>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rdx, qword ptr [rcx]
    x86.lea rcx, qword ptr [rax+8]
    x86.mov rax, qword ptr [rcx]
    x86.mov rcx, rdx
    x86.add rcx, rax
    x86.mov rax, rcx
    x86.epilogue
    x86.ret
}
---

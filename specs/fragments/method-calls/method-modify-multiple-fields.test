// Test: method-modify-multiple-fields
type Point
  var x int
  var y int

  function moveBy(dx int, dy int)
    x = x + dx
    y = y + dy
  end 'moveBy'

  function sum() returns int
    return x + y
  end 'sum'
end 'Point'

function main() returns int
  var p = Point{x: 10, y: 10}
  p.moveBy(10, dy: 12)
  return p.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Point.moveBy(__self_ptr: i64, dx: i64, dy: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov esi, [eax+8]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.add esi, r8
    x86.mov eax, [rbp-8]
    x86.mov [eax+8], esi
    x86.epilogue
    x86.ret
  }
  func @Point.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+8]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 10
    x86.mov ecx, 10
    x86.mov edx, 16
    x86.mov rcx, rdx
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov ebx, [rbp-8]
    x86.mov esi, 10
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, 10
    x86.mov [edi+8], r8
    x86.mov r9, 10
    x86.mov eax, 12
    x86.mov ecx, [rbp-8]
    x86.mov rdx, r9
    x86.mov r8, rax
    x86.call Point.moveBy
    x86.mov rcx, [rbp-8]
    x86.epilogue
    x86.jmp Point.sum
  }
}
---

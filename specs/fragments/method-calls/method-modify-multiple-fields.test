// Test: method-modify-multiple-fields
type Point
  var x int
  var y int

  function moveBy(dx int, dy int)
    x = x + dx
    y = y + dy
  end 'moveBy'

  function sum() returns int
    return x + y
  end 'sum'
end 'Point'

function main() returns int
  var p = Point{x: 10, y: 10}
  p.moveBy(10, dy: 12)
  return p.sum()
end 'main'
---
ExitCode: 42
---
module {
  func @Point.moveBy(__self_ptr: i64, dx: i64, dy: i64) {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov eax, [rbp-16]
    x86.add ecx, edx
    x86.mov [rbp-24], ecx
    x86.mov edx, [rbp-8]
    x86.mov [edx+0], ecx
    x86.add eax, r8
    x86.mov [rbp-16], eax
    x86.mov ebx, [rbp-8]
    x86.mov [ebx+8], eax
    x86.mov esi, [rbp-8]
    x86.mov edi, [rbp-24]
    x86.mov [esi+0], edi
    x86.mov r8, [rbp-16]
    x86.mov [esi+8], r8
    x86.epilogue
    x86.ret
  }
  func @Point.sum(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+8]
    x86.mov [rbp-16], eax
    x86.mov eax, [ecx+0]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.add ecx, edx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-24]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-16]
    x86.mov [ebx+8], edi
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 10
    x86.mov edx, 10
    x86.mov ebx, 12
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], eax
    x86.lea rsi, [rbp-16]
    x86.mov rcx, rsi
    x86.mov r8, rbx
    x86.call Point.moveBy
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-16]
    x86.mov [rbp-24], edi
    x86.mov [rbp-32], r8
    x86.lea r9, [rbp-32]
    x86.mov rcx, r9
    x86.call Point.sum
    x86.epilogue
    x86.ret
  }

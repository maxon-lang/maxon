// Test: method-call-with-args
type Adder
    var total int

    function add(n int)
        total = total + n
    end 'add'

    function get() returns int
        return total
    end 'get'
end 'Adder'

function main() returns int
    var a = Adder{total: 0}
    a.add(10)
    a.add(20)
    a.add(12)
    return a.get()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=48
    x86.push rbx
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.mov rdx, 0
    x86.lea r8, qword ptr [rcx+rdx]
    x86.mov qword ptr [r8], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov qword ptr [rbx], rcx
    x86.mov rcx, qword ptr [rbx]
    x86.mov r8, 10
    x86.mov r10, rcx
    x86.mov r11, r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.add
    x86.mov r8, qword ptr [rbx]
    x86.mov rcx, 20
    x86.mov r10, r8
    x86.mov r11, rcx
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.add
    x86.mov rcx, qword ptr [rbx]
    x86.mov r8, 12
    x86.mov r10, rcx
    x86.mov r11, r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Adder.add
    x86.mov r8, qword ptr [rbx]
    x86.mov rcx, r8
    x86.call Adder.get
    x86.mov r8, rax
    x86.mov rax, r8
    x86.pop rbx
    x86.epilogue
    x86.ret
}

func.func @Adder.add(%self: !maxon.struct<Adder>, %n: i64) {
  ^entry(%self: !maxon.struct<Adder>, %n: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rdx
    x86.lea rdx, qword ptr [rax]
    x86.mov r8, qword ptr [rdx]
    x86.mov rdx, r8
    x86.add rdx, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov qword ptr [rcx], rdx
    x86.epilogue
    x86.ret
}

func.func @Adder.get(%self: !maxon.struct<Adder>) -> i64 {
  ^entry(%self: !maxon.struct<Adder>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

// Test: method-call-with-args
type Adder
  var total int

  function add(n int)
    total = total + n
  end 'add'

  function get() returns int
    return total
  end 'get'
end 'Adder'

function main() returns int
  var a = Adder{total: 0}
  a.add(10)
  a.add(20)
  a.add(12)
  return a.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, n: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Adder.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.mov [rbp-16], eax
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov edi, [rbp-8]
    x86.mov rcx, rdi
    x86.mov rdx, rsi
    x86.call Adder.add
    x86.mov r8, 20
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Adder.add
    x86.mov eax, 12
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rax
    x86.call Adder.add
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.epilogue
    x86.jmp Adder.get
  }
}
---

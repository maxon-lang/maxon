// Test: method-call-with-args

typealias Integer = int(i64.min to i64.max)

type Adder
  var total Integer

  function add(n Integer)
    total = total + n
  end 'add'

  function get() returns Integer
    return total
  end 'get'
end 'Adder'

function main() returns ExitCode
  var a = Adder{total: 0}
  a.add(10)
  a.add(20)
  a.add(12)
  return a.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, n: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Adder.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 10
    x86.mov rcx, [rbp-8]
    x86.mov rdx, rsi
    x86.call Adder.add
    x86.mov r8, 20
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.mov rdx, r8
    x86.call Adder.add
    x86.mov eax, 12
    x86.mov ecx, [rbp-8]
    x86.mov rdx, rax
    x86.call Adder.add
    x86.mov eax, [rbp-8]
    x86.mov rcx, rax
    x86.call Adder.get
    x86.mov [rbp-16], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_21]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  }
}
---

// Test: method-call-with-args
type Adder
  var total int

  function add(n int)
    total = total + n
  end 'add'

  function get() returns int
    return total
  end 'get'
end 'Adder'

function main() returns int
  var a = Adder{total: 0}
  a.add(10)
  a.add(20)
  a.add(12)
  return a.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Adder.add(__self_ptr: i64, n: i64) {
  entry:
    x86.prologue stack_size=32
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.add ecx, edx
    x86.mov [rbp-32], ecx
    x86.mov edx, [rbp-8]
    x86.mov [edx+0], ecx
    x86.epilogue
    x86.ret
  }
  func @Adder.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, 10
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-24], ebx
    x86.lea rsi, [rbp-24]
    x86.mov ecx, rsi
    x86.call Adder.add
    x86.mov edi, [rbp-24]
    x86.mov [rbp-16], edi
    x86.mov r8, 20
    x86.mov r9, [rbp-16]
    x86.mov [rbp-32], r9
    x86.lea rax, [rbp-32]
    x86.mov ecx, rax
    x86.mov edx, r8
    x86.call Adder.add
    x86.mov eax, [rbp-32]
    x86.mov [rbp-16], eax
    x86.mov eax, 12
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-40], ecx
    x86.lea rcx, [rbp-40]
    x86.mov ecx, rcx
    x86.mov edx, eax
    x86.call Adder.add
    x86.mov eax, [rbp-40]
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.mov [rbp-48], eax
    x86.lea rax, [rbp-48]
    x86.mov ecx, rax
    x86.call Adder.get
    x86.mov ecx, [rbp-48]
    x86.mov [rbp-16], ecx
    x86.epilogue
    x86.ret
  }

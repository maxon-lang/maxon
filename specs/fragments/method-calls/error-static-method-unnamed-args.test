// Test: error-static-method-unnamed-args
type Factory
    static function create(x int, y int) returns int
        return x * 10 + y
    end 'create'
end 'Factory'

function main() returns int
    return Factory.create(4, 2)
end 'main'
---
ExpectedError: Second and subsequent arguments must be named. Use 'name: value' syntax

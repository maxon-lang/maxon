// Test: error-method-unnamed-args
type Adder
    var total int

    function addTwo(a int, b int)
        total = total + a + b
    end 'addTwo'
end 'Adder'

function main() returns int
    var x = Adder{total: 0}
    x.addTwo(10, 20)
    return 0
end 'main'

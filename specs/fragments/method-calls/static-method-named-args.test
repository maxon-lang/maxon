// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
  static function create(x Integer, y Integer) returns Integer
    return x * 10 + y
  end 'create'
end 'Factory'

function main() returns ExitCode
  return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
module {
  func @Factory.create(x: i64, y: i64) -> i64 {
  entry:
    x86.mov eax, 10
    x86.imul ecx, eax
    x86.lea eax, [ecx + edx]
    x86.ret
  }
  func @method-calls.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 4
    x86.mov ecx, 2
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call Factory.create
    x86.mov [rbp-8], eax
    x86.xor edx, edx
    x86.cmp eax, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rax, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je method-calls.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_20]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

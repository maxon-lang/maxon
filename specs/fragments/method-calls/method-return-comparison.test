// Test: method-return-comparison

typealias Integer = int(i64.min to i64.max)

type Value
  var n Integer

  function isPositive() returns Integer
    if n > 0 'positive'
      return 1
    end 'positive'
    return 0
  end 'isPositive'
end 'Value'

function main() returns ExitCode
  var v = Value{n: 42}
  return v.isPositive()
end 'main'
---
ExitCode: 1
---

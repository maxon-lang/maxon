// Test: method-return-comparison
type Value
  var n int

  function isPositive() returns int
    if n > 0 'positive'
      return 1
    end 'positive'
    return 0
  end 'isPositive'
end 'Value'

function main() returns int
  var v = Value{n: 42}
  return v.isPositive()
end 'main'
---
ExitCode: 1
---
module {
  func @Value.isPositive(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.jle Value.isPositive.positive_0.after
  positive_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  positive_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 42
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov ebx, 42
    x86.mov [edx+0], ebx
    x86.mov esi, [rbp-8]
    x86.mov rcx, rsi
    x86.epilogue
    x86.jmp Value.isPositive
  }
}
---

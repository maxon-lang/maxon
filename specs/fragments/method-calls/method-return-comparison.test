// Test: method-return-comparison
type Value
  var n int

  function isPositive() returns int
    if n > 0 'positive'
      return 1
    end 'positive'
    return 0
  end 'isPositive'
end 'Value'

function main() returns int
  var v = Value{n: 42}
  return v.isPositive()
end 'main'
---
ExitCode: 1
---
module {
  func @Value.isPositive(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.jle Value.isPositive.positive_0.after
  positive_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  positive_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 42
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-16]
    x86.mov [rbp-24], edx
    x86.lea rbx, [rbp-24]
    x86.mov rcx, rbx
    x86.call Value.isPositive
    x86.mov esi, [rbp-24]
    x86.mov [rbp-16], esi
    x86.epilogue
    x86.ret
  }
}
---

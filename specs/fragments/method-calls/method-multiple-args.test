// Test: method-multiple-args
type Calculator
    var result int

    function addTwo(a int, b int)
        result = result + a + b
    end 'addTwo'

    function get() returns int
        return result
    end 'get'
end 'Calculator'

function main() returns int
    var calc = Calculator{result: 0}
    calc.addTwo(20, b: 22)
    return calc.get()
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=56 saved_gprs=[RBX]
    x86.mov rax, 0
    x86.lea rcx, qword ptr [rbp-40]
    x86.lea rdx, qword ptr [rcx]
    x86.mov qword ptr [rdx], rax
    x86.lea rbx, qword ptr [rbp-48]
    x86.mov rdx, 8
    x86.push rsi
    x86.push rdi
    x86.mov rdi, rbx
    x86.mov rsi, rcx
    x86.mov rcx, rdx
    x86.cld
    x86.rep_movsb
    x86.pop rdi
    x86.pop rsi
    x86.mov rdx, 20
    x86.mov rcx, 22
    x86.mov r10, rbx
    x86.mov r11, rdx
    x86.push rcx
    x86.pop r8
    x86.mov rdx, r11
    x86.mov rcx, r10
    x86.call Calculator.addTwo
    x86.mov rcx, rbx
    x86.call Calculator.get
    x86.mov rcx, rax
    x86.mov rax, rcx
    x86.epilogue saved_gprs=[RBX]
    x86.ret
}

func.func @Calculator.addTwo(%self: memref<!maxon.struct<Calculator>>, %a: i64, %b: i64) {
  ^entry(%self: memref<!maxon.struct<Calculator>>, %a: i64, %b: i64):
    x86.prologue stack_size=32
    x86.mov r10, rcx
    x86.mov r11, rdx
    x86.mov rax, r8
    x86.mov rcx, r10
    x86.mov rdx, r11
    x86.lea r8, qword ptr [rcx]
    x86.mov rcx, qword ptr [r8]
    x86.mov r9, rcx
    x86.add r9, rdx
    x86.mov rdx, r9
    x86.add rdx, rax
    x86.mov qword ptr [r8], rdx
    x86.epilogue
    x86.ret
}

func.func @Calculator.get(%self: memref<!maxon.struct<Calculator>>) -> i64 {
  ^entry(%self: memref<!maxon.struct<Calculator>>):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.lea rcx, qword ptr [rax]
    x86.mov rax, qword ptr [rcx]
    x86.epilogue
    x86.ret
}
---

// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
  var result Integer

  function addTwo(a Integer, b Integer)
    result = result + a + b
  end 'addTwo'

  function get() returns Integer
    return result
  end 'get'
end 'Calculator'

function main() returns ExitCode
  var calc = Calculator{result: 0}
  calc.addTwo(20, b: 22)
  return calc.get()
end 'main'

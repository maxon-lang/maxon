// Test: method-multiple-args
type Calculator
  var result int

  function addTwo(a int, b int)
    result = result + a + b
  end 'addTwo'

  function get() returns int
    return result
  end 'get'
end 'Calculator'

function main() returns int
  var calc = Calculator{result: 0}
  calc.addTwo(20, b: 22)
  return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.addTwo(__self_ptr: i64, a: i64, b: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov ebx, [eax+0]
    x86.add ebx, edx
    x86.add ebx, r8
    x86.mov eax, [rbp-8]
    x86.mov [eax+0], ebx
    x86.epilogue
    x86.ret
  }
  func @Calculator.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.mov edx, [eax+0]
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 8
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.xor ebx, ebx
    x86.mov [edx+0], ebx
    x86.mov esi, 20
    x86.mov edi, 22
    x86.mov r8, [rbp-8]
    x86.mov rcx, r8
    x86.mov rdx, rsi
    x86.mov r8, rdi
    x86.call Calculator.addTwo
    x86.mov r9, [rbp-8]
    x86.mov rcx, r9
    x86.epilogue
    x86.jmp Calculator.get
  }
}
---

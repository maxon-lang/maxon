// Test: method-multiple-args
type Calculator
  var result int

  function addTwo(a int, b int)
    result = result + a + b
  end 'addTwo'

  function get() returns int
    return result
  end 'get'
end 'Calculator'

function main() returns int
  var calc = Calculator{result: 0}
  calc.addTwo(20, b: 22)
  return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.addTwo(__self_ptr: i64, a: i64, b: i64) {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.add ecx, edx
    x86.add ecx, r8
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [edx+0], ecx
    x86.mov ebx, [rbp-8]
    x86.mov esi, [rbp-16]
    x86.mov [ebx+0], esi
    x86.epilogue
    x86.ret
  }
  func @Calculator.get(__self_ptr: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [ecx+0]
    x86.mov [rbp-16], eax
    x86.mov ecx, [rbp-16]
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.mov [edx+0], ebx
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @method-calls.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 20
    x86.mov edx, 22
    x86.mov [rbp-8], eax
    x86.lea rbx, [rbp-8]
    x86.mov r8, rdx
    x86.mov rdx, rcx
    x86.mov rcx, rbx
    x86.call Calculator.addTwo
    x86.mov esi, [rbp-8]
    x86.mov [rbp-16], esi
    x86.lea rdi, [rbp-16]
    x86.mov rcx, rdi
    x86.call Calculator.get
    x86.epilogue
    x86.ret
  }
}
---

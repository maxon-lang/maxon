// Test: nested-calls
function double(x int) returns int
  return x * 2
end 'double'

function quadruple(x int) returns int
  return double(double(x))
end 'quadruple'

function main() returns int
  return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @double(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.epilogue
    x86.ret
  }
  func @quadruple(x: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.call double
    x86.mov ecx, eax
    x86.call double
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, eax
    x86.call quadruple
    x86.ret
  }
}
---

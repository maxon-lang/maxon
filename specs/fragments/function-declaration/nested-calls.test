// Test: nested-calls
function double(x int) returns int
  return x * 2
end 'double'

function quadruple(x int) returns int
  return double(double(x))
end 'quadruple'

function main() returns int
  return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @function-declaration.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @function-declaration.quadruple(x: i64) -> i64 {
  entry:
    x86.call function-declaration.double
    x86.mov rcx, rax
    x86.jmp function-declaration.double
  }
  func @function-declaration.main() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov rcx, rax
    x86.jmp function-declaration.quadruple
  }
}
---

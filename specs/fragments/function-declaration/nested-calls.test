// Test: nested-calls
function double(x int) returns int
    return x * 2
end 'double'

function quadruple(x int) returns int
    return double(double(x))
end 'quadruple'

function main() returns int
    return quadruple(3)
end 'main'
---
ExitCode: 12
---
func.func @double(%x: i64) -> i64 {
  ^entry(%x: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, 1
    x86.mov rdx, rax
    x86.shl rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}

func.func @quadruple(%x: i64) -> i64 {
  ^entry(%x: i64):
    x86.prologue stack_size=32
    x86.mov rax, rcx
    x86.mov rcx, rax
    x86.call double
    x86.mov rcx, rax
    x86.call double
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rcx, 3
    x86.call quadruple
    x86.epilogue
    x86.ret
}
---

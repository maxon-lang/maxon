// Test: nested-calls
function double(x Integer) returns Integer
  return x * 2
end 'double'

function quadruple(x Integer) returns Integer
  return double(double(x))
end 'quadruple'

function main() returns ExitCode
  return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @function-declaration.double(x: i64) -> i64 {
  entry:
    x86.mov eax, 2
    x86.imul ecx, eax
    x86.mov eax, ecx
    x86.ret
  }
  func @function-declaration.quadruple(x: i64) -> i64 {
  entry:
    x86.call function-declaration.double
    x86.mov rcx, rax
    x86.jmp function-declaration.double
  }
  func @function-declaration.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov rcx, rax
    x86.call function-declaration.quadruple
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je function-declaration.main.__range_ok_0
  __range_panic_0:
    x86.lea_rdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

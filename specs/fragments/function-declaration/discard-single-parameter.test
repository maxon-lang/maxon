// Test: discard-single-parameter
function useSecond(_ int, b int) returns int
    return b
end 'useSecond'

function main() returns int
    return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 42
    x86.epilogue
    x86.ret
}
---

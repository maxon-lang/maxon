// Test: discard-single-parameter
function useSecond(_ int, b int) returns int
  return b
end 'useSecond'

function main() returns int
  return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
module {
  func @useSecond(_: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov [rbp-16], edx
    x86.mov eax, edx
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 42
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.call useSecond
    x86.ret
  }
}
---

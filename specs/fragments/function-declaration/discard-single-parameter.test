// Test: discard-single-parameter
function useSecond(_ Integer, b Integer) returns Integer
  return b
end 'useSecond'

function main() returns Integer
  return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
module {
  func @function-declaration.useSecond(_: i64, b: i64) -> i64 {
  entry:
    x86.mov eax, edx
    x86.ret
  }
  func @function-declaration.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 42
    x86.mov rdx, rcx
    x86.mov rcx, rax
    x86.jmp function-declaration.useSecond
  }

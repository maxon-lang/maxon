// Test: void-return-type
function doNothing()
  var x = 1
end 'doNothing'

function main() returns int
  doNothing()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @doNothing() {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.epilogue
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.call doNothing
    x86.xor eax, eax
    x86.ret
  }
}
---

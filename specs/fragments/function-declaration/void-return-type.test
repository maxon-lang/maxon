// Test: void-return-type
function doNothing()
  var x = 1
end 'doNothing'

function main() returns int
  doNothing()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @function-declaration.doNothing() {
  entry:
    x86.mov eax, 1
    x86.ret
  }
  func @function-declaration.main() -> i64 {
  entry:
    x86.call function-declaration.doNothing
    x86.xor eax, eax
    x86.ret
  }
}

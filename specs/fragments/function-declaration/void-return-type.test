// Test: void-return-type
function doNothing()
end 'doNothing'

function main() returns ExitCode
  doNothing()
  return 0
end 'main'
---
ExitCode: 0
---
module {
  func @function-declaration.doNothing() {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.epilogue
    x86.ret
  }
  func @function-declaration.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.call function-declaration.doNothing
    x86.xor eax, eax
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

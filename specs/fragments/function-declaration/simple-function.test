// Test: simple-function
function add() returns int
    return 3 + 4
end 'add'

function main() returns int
    return add()
end 'main'
---
ExitCode: 7
---
func.func @add() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, 7
    x86.epilogue
    x86.ret
}

func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.call add
    x86.epilogue
    x86.ret
}
---

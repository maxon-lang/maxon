// Test: simple-function
function add() returns int
  return 3 + 4
end 'add'

function main() returns int
  return add()
end 'main'
---
ExitCode: 7
---
module {
  func @add() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.add eax, ecx
    x86.ret
  }
  func @main() -> i64 {
  entry:
    x86.call add
    x86.ret
  }
}

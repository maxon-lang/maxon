// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
  return 3 + 4
end 'add'

function main() returns ExitCode
  return add()
end 'main'
---
ExitCode: 7
---
module {
  func @function-declaration.add() -> i64 {
  entry:
    x86.mov eax, 3
    x86.mov ecx, 4
    x86.add eax, ecx
    x86.ret
  }
  func @function-declaration.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.call function-declaration.add
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl ecx
    x86.movzx ecx, ecxb
    x86.mov rdx, 4294967295
    x86.cmp rax, rdx
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or ecx, eax
    x86.test ecx, ecx
    x86.je function-declaration.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_9]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
}
---

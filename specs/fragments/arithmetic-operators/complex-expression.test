// Test: complex-expression
function main() returns int
  var a = 10
  var b = 3
  var result = (a + b) * 2 - trunc(a / b)
  return result
end 'main'
---
ExitCode: 23
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 3
    x86.lea edx, [eax + ecx]
    x86.mov ebx, 2
    x86.imul edx, ebx
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ecx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si esi, xmm2
    x86.sub edx, esi
    x86.mov eax, edx
    x86.ret
  }
}
---

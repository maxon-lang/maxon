// Test: trunc-division-optimizes
function main() returns int
  return trunc(20 / 3)     // Optimized to sdiv, returns 6
end 'main'
---
ExitCode: 6
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 3
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ecx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si edx, xmm2
    x86.mov eax, edx
    x86.ret
  }
}
---

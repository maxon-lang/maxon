// Test: trunc-division-optimizes
function main() returns Integer
  return 20 / 3             // int/int = truncating int, returns 6
end 'main'
---
ExitCode: 6
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 3
    x86.cqo
    x86.idiv ecx
    x86.ret
  }
}
---

// Test: negative-division
function main() returns ExitCode
  var neg = -7
  let a = neg / 2           // -7/2 = -3 (truncating toward zero)
  if a == -3 'pass'
      return 0
  end 'pass'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @arithmetic-operators.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, -7
    x86.mov edx, 2
    x86.mov ebx, edx
    x86.mov eax, ecx
    x86.cqo
    x86.idiv ebx
    x86.mov ebx, -3
    x86.cmp eax, ebx
    x86.jne arithmetic-operators.main.pass_0.after
  pass_0:
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-16], eax
    x86.xor eax, eax
    x86.mov ecx, [rbp-16]
    x86.call mm_scope_exit
    x86.mov edx, [rbp-8]
    x86.mov rcx, rdx
    x86.call mm_scope_exit
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  pass_0.after:
    x86.mov eax, 1
    x86.mov ecx, [rbp-8]
    x86.call mm_scope_exit
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  }
}
---

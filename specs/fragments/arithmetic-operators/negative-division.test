// Test: negative-division
function main() returns Integer
  var neg = -7
  let a = neg / 2           // -7/2 = -3 (truncating toward zero)
  if a == -3 'pass'
      return 0
  end 'pass'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, -7
    x86.mov ecx, 2
    x86.cqo
    x86.idiv ecx
    x86.mov edx, -3
    x86.cmp eax, edx
    x86.jne arithmetic-operators.main.pass_0.after
  pass_0:
    x86.xor eax, eax
    x86.ret
  pass_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

// Test: negative-division
function main() returns int
  var neg = -7
  let a = trunc(neg / 2)    // -7/2 = -3.5, trunc = -3 (toward zero)
  if a == -3 'pass'
      return 0
  end 'pass'
  return 1
end 'main'
---
ExitCode: 0
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, -7
    x86.mov ecx, 2
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ecx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.cvttsd2si edx, xmm2
    x86.mov ebx, -3
    x86.cmp edx, ebx
    x86.jne arithmetic-operators.main.pass_0.after
  pass_0:
    x86.xor eax, eax
    x86.ret
  pass_0.after:
    x86.mov eax, 1
    x86.ret
  }
}
---

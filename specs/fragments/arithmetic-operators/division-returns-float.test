// Test: division-returns-float
function main() returns int
  var result = 20 / 3      // 6.666...
  return trunc(result * 10.0)  // 66.666... * 10 = 66.666..., trunc = 66
end 'main'
---
ExitCode: 66
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, 20
    x86.mov ecx, 3
    x86.cvtsi2sd xmm0, eax
    x86.cvtsi2sd xmm1, ecx
    x86.movsd xmm2, xmm0
    x86.divsd xmm2, xmm1
    x86.movsd xmm3, [rip+__float_10]
    x86.movsd xmm4, xmm2
    x86.mulsd xmm4, xmm3
    x86.cvttsd2si edx, xmm4
    x86.mov eax, edx
    x86.ret
  }
}
---

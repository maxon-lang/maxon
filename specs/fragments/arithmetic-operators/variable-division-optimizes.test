// Test: variable-division-optimizes
function main() returns Integer
  var a = 7
  var b = 2
  return a / b              // int/int = truncating int, returns 3
end 'main'
---
ExitCode: 3
---
module {
  func @arithmetic-operators.main() -> i64 {
  entry:
    x86.mov eax, 7
    x86.mov ecx, 2
    x86.cqo
    x86.idiv ecx
    x86.ret
  }
}
---

// Test: docs-example-1
function main() returns ExitCode
  var a = 10
  var b = 3
  var sum = a + b          // 13
  var diff = a - b         // 7
  var prod = a * b         // 30
  var div = a / b          // 3 (truncating integer division)
  var rem = a mod b        // 1

  // Use the values
  print("{sum}\n")
  print("{diff}\n")
  print("{prod}\n")
  print("{div}\n")
  print("{rem}\n")

  return 0
end 'main'


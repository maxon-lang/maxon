// Test: if-statements.doc-example-3.1
function main() returns int
    var x = 2
    if x == 1 'case1'
        return 1
    end 'case1' else if x == 2 'case2'
        return 2
    end 'case2' else 'default'
        return 0
    end 'default'
end 'main'
---
ExitCode: 2
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    %x = alloca ptr
    store %x %tmp_const
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_const %tmp_const.1
    br.cond %tmp_icmp @then$case1_1 @else$case1_2
then$case1_1:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
else$case1_2:
    %tmp_load.2 = load i64 %x
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.2 %tmp_const.3
    br.cond %tmp_icmp.1 @then$case2_3 @else$case2_4
then$case2_3:
    %tmp_const.4 = const.i64 i64 2
    ret %tmp_const.4
else$case2_4:
    %tmp_const.5 = const.i64 i64 0
    ret %tmp_const.5
end$case2_5:
    br @end$case1_6
end$case1_6:
}

---

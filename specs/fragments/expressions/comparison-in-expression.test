// Test: comparison-in-expression
function main() returns int
  var isGreater = 10 > 5
  if isGreater 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @expressions.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 5
    x86.cmp eax, ecx
    x86.setg edx
    x86.movzx edx, edxb
    x86.test edx, edx
    x86.je expressions.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.ret
  }
}
---

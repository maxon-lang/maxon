// Test: with-function-call
function main() returns int
  var x = 3
  return 5 + add(x, b: 4)
end 'main'

function add(a int, b int) returns int
  return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @expressions.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 3
    x86.mov ecx, 5
    x86.mov edx, 4
    x86.mov [rbp-8], ecx
    x86.mov rcx, rax
    x86.call expressions.add
    x86.mov ebx, [rbp-8]
    x86.lea eax, [ebx + eax]
    x86.epilogue
    x86.ret
  }
  func @expressions.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
}
---

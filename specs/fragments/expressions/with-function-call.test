// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
  var x = 3
  return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
  return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @expressions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 3
    x86.mov edx, 5
    x86.mov ebx, 4
    x86.mov rdx, rbx
    x86.call expressions.add
    x86.mov esi, 5
    x86.add esi, eax
    x86.mov [rbp-16], esi
    x86.xor edi, edi
    x86.cmp esi, edi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rsi, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je expressions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_11]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-24], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
  func @expressions.add(a: i64, b: i64) -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], edx
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-24]
    x86.mov edx, [rbp-16]
    x86.add edx, ecx
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-32], edx
    x86.mov rcx, rbx
    x86.call mm_scope_exit
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }
}
---

// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
  var x = 3
  return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
  return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @expressions.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 5
    x86.mov rcx, 3
    x86.mov rdx, 4
    x86.call expressions.add
    x86.mov ecx, 5
    x86.add ecx, eax
    x86.mov [rbp-8], ecx
    x86.xor edx, edx
    x86.cmp ecx, edx
    x86.setl ebx
    x86.movzx ebx, ebxb
    x86.mov rsi, 4294967295
    x86.cmp rcx, rsi
    x86.setg edi
    x86.movzx edi, edib
    x86.or ebx, edi
    x86.test ebx, ebx
    x86.je expressions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_10]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @expressions.add(a: i64, b: i64) -> i64 {
  entry:
    x86.lea eax, [ecx + edx]
    x86.ret
  }
}
---

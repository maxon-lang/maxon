// Test: mixed-operators
function main() returns Integer
  var a = 10
  var b = 3
  return a * 2 + b - 1
end 'main'
---
ExitCode: 22
---
module {
  func @expressions.main() -> i64 {
  entry:
    x86.mov eax, 10
    x86.mov ecx, 3
    x86.mov edx, 2
    x86.imul eax, edx
    x86.add eax, ecx
    x86.mov ebx, 1
    x86.sub eax, ebx
    x86.ret
  }
}
---

// Test: mixed-operators
function main() returns ExitCode
  var a = 10
  var b = 3
  return a * 2 + b - 1
end 'main'
---
ExitCode: 22
---
module {
  func @expressions.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.mov rcx, rax
    x86.call mm_scope_enter
    x86.mov [rbp-8], eax
    x86.mov ecx, 10
    x86.mov edx, 3
    x86.mov ebx, 2
    x86.imul ecx, ebx
    x86.add ecx, edx
    x86.mov esi, 1
    x86.sub ecx, esi
    x86.mov [rbp-16], ecx
    x86.xor edi, edi
    x86.cmp ecx, edi
    x86.setl r8
    x86.movzx r8, r8b
    x86.mov r9, 4294967295
    x86.cmp rcx, r9
    x86.setg eax
    x86.movzx eax, eaxb
    x86.or r8, eax
    x86.test r8, r8
    x86.je expressions.main.__range_ok_0
  __range_panic_0:
    x86.lea_symdata rax, [__panic_msg_13]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_0:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-8]
    x86.mov [rbp-24], eax
    x86.call mm_scope_exit
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

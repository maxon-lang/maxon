// Test: char-literal-codepoint-iteration
function main() returns ExitCode
  var count = 0
  for cp in "a-b-c".codepoints() 'chars'
    if cp == '-' 'dash'
      count = count + 1
    end 'dash'
  end 'chars'
  return count
end 'main'

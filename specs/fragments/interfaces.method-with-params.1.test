// Test: interfaces.method-with-params.1
interface Calculator
    function add(n int) returns int
end 'Calculator'

type Accumulator is Calculator
    var total int

    function Calculator.add(n int) returns int
        return total + n
    end 'add'
end 'Accumulator'

function main() returns int
    var acc = Accumulator{total: 10}
    return acc.add(5)
end 'main'
---
ExitCode: 15
---
function main() -> i64 {
entry_0:
    %acc = alloca.sized ptr 8
    memset %acc 0 8
    %tmp_fieldptr = getfieldptr ptr %acc 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 5
    %tmp_call = call i64 @Accumulator$add(%acc, %tmp_const.1)
    ret %tmp_call
}

function Accumulator$add() -> i64 {
entry_0:
    %self = param ptr 0
    %n = param i64 1
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_add = add i64 %tmp_load %n
    ret %tmp_add
}

---

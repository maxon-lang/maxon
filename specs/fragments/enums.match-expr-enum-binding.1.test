// Test: enums.match-expr-enum-binding.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = Container.value(10)
    var result = match c 'get'
        empty gives 0
        value(n) gives n * 2
    end 'get'
    return result
end 'main'
---
ExitCode: 20
---
function main() -> i64 {

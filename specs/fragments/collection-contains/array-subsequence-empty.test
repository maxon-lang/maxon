// Test: array-subsequence-empty
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
  var arr = [1, 2, 3]
  if arr.contains(sequence: IntArray{}) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---

// Test: array-predicate-found

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
  var arr = [1, 2, 3, 4, 5]
  if arr.contains(predicate: (n Integer) gives n > 3) 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @collection-contains.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.xor eax, eax
    x86.mov ecx, 5
    x86.xor edx, edx
    x86.mov ebx, 8
    x86.mov esi, 32
    x86.mov rcx, rsi
    x86.call maxon_alloc
    x86.mov [rbp-8], eax
    x86.mov edi, [rbp-8]
    x86.xor r8, r8
    x86.mov [edi+0], r8
    x86.mov r9, [rbp-8]
    x86.mov eax, 5
    x86.mov [r9+8], eax
    x86.mov eax, [rbp-8]
    x86.xor ecx, ecx
    x86.mov [eax+16], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, 8
    x86.mov [eax+24], ecx
    x86.xor eax, eax
    x86.mov ecx, 16
    x86.call maxon_alloc
    x86.mov [rbp-16], eax
    x86.mov eax, [rbp-16]
    x86.xor ecx, ecx
    x86.mov [eax+0], ecx
    x86.mov eax, [rbp-8]
    x86.mov ecx, [rbp-16]
    x86.mov [ecx+8], eax
    x86.lea_rdata rax, [__const_array_collection-contains.main_arr]
    x86.mov rcx, rax
    x86.mov eax, [rbp-16]
    x86.mov edx, [eax+8]
    x86.mov [edx+0], ecx
    x86.lea_func eax, [__closure_0]
    x86.mov ecx, [rbp-16]
    x86.xor edx, edx
    x86.mov r8, rdx
    x86.mov rdx, rax
    x86.call stdlib.Array.contains$predicate
    x86.test eax, eax
    x86.je collection-contains.main.check_1.after
  check_1:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_1.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
  func @__closure_0(n: i64) -> i1 {
  entry:
    x86.mov eax, 3
    x86.cmp ecx, eax
    x86.setg eax
    x86.movzx eax, eaxb
    x86.ret
  }
}

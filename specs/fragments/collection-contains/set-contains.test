// Test: set-contains
function main() returns ExitCode
  var s = Set from [1, 2, 3, 4, 5]
  if s.contains(3) 'check'
    print("found\n")
  end 'check'
  if s.contains(99) 'check2'
    print("not found\n")
  end 'check2'
  return 0
end 'main'

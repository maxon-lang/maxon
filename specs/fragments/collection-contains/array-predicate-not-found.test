// Test: array-predicate-not-found

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
  var arr = [1, 2, 3, 4, 5]
  if arr.contains(predicate: (n Integer) gives n > 10) 'check'
    return 1
  end 'check'
  return 0
end 'main'

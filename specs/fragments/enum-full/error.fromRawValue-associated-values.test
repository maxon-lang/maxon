// Test: error.fromRawValue-associated-values

typealias Integer = int(i64.min to i64.max)

enum Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  let _c = try Container.fromRawValue(0) otherwise Container.empty
  return 0
end 'main'

    x86.mov [rbp-32], ebx
    x86.mov [rbp-40], esi
    x86.mov [rbp-48], edi
    x86.mov [rbp-56], r9
    x86.jmp enum-full.main.handle_0.cmp0
  handle_0.cmp0:

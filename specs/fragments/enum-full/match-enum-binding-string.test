// Test: match-enum-binding-string
enum StringResult
  ok(value int)
  err(message String)
end 'StringResult'

function main() returns int
  var r = StringResult.err("bad")
  match r 'handle'
    ok(v) then return v
    err(msg) then return msg.byteLength()
  end 'handle'
end 'main'

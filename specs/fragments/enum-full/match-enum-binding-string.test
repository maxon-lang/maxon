    x86.mov [rbp-64], esi
    x86.mov [rbp-72], ebx
    x86.mov [rbp-80], edx
    x86.mov [rbp-88], ecx
    x86.mov [rbp-96], eax
    x86.lea rdi, [rbp-96]

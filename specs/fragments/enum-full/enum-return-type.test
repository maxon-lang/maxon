// Test: enum-return-type
enum Result
  success
  failure
end 'Result'

function getResult(succeed bool) returns Result
  if succeed 'check'
    return Result.success
  end 'check'
  return Result.failure
end 'getResult'

function main() returns Integer
  var r = getResult(true)
  if r == Result.success 'handle'
    return 1
  end 'handle'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.getResult(succeed: i1) -> i64 {
  entry:
    x86.test ecx, ecx
    x86.je enum-full.getResult.check_0.after
  check_0:
    x86.xor eax, eax
    x86.ret
  check_0.after:
    x86.mov eax, 1
    x86.ret
  }
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov rcx, rax
    x86.call enum-full.getResult
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov edx, [rbp-8]
    x86.cmp edx, ecx
    x86.jne enum-full.main.handle_0.after
  handle_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  handle_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

  check_0.case1:
    x86.xor eax, eax
    x86.mov [rbp-16], eax
    x86.jmp Toggle.flip.check_0.merge
  check_0.merge:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  }

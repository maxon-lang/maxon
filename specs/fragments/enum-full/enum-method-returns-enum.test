// Test: enum-method-returns-enum
enum Toggle
  on
  off

  function flip() returns Toggle
    var result = match self 'check'
      Toggle.on gives Toggle.off
      Toggle.off gives Toggle.on
    end 'check'
    return result
  end 'flip'
end 'Toggle'

function main() returns ExitCode
  let t = Toggle.on
  let flipped = t.flip()
  var result = match flipped 'check'
    Toggle.off gives 1
    Toggle.on gives 0
  end 'check'
  return result
end 'main'
---
ExitCode: 1
---

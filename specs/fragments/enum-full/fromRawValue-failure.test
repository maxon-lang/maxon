// Test: fromRawValue-failure

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode() returns Integer
  return 999
end 'getCode'

function main() returns ExitCode
  var code = getCode()
  var status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
  var result = match status 'check'
    HttpStatus.ok gives 1
    HttpStatus.notFound gives 0
  end 'check'
  return result
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.getCode() -> i64 {
  entry:
    x86.mov eax, 999
    x86.ret
  }
  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.call enum-full.getCode
    x86.mov ecx, 1
    x86.xor edx, edx
    x86.mov ebx, 200
    x86.cmp eax, ebx
    x86.sete ebx
    x86.movzx ebx, ebxb
    x86.xor esi, esi
    x86.test ebx, ebx
    x86.mov edi, ecx
    x86.cmovne edi, esi
    x86.mov ecx, 200
    x86.test ebx, ebx
    x86.mov esi, edx
    x86.cmovne esi, ecx
    x86.mov ecx, 404
    x86.cmp eax, ecx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.xor ecx, ecx
    x86.test eax, eax
    x86.mov edx, edi
    x86.cmovne edx, ecx
    x86.mov ebx, 404
    x86.test eax, eax
    x86.mov ecx, esi
    x86.cmovne ecx, ebx
    x86.mov esi, 200
    x86.mov [rbp-8], esi
    x86.mov [rbp-16], ecx
    x86.xor edi, edi
    x86.cmp edx, edi
    x86.je enum-full.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.jmp enum-full.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov ecx, [rbp-24]
    x86.xor edx, edx
    x86.mov [rbp-32], edx
    x86.mov [rbp-40], ecx
    x86.jmp enum-full.main.check_4.cmp0
  check_4.cmp0:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 200
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_4.cmp1
  check_4.case0:
    x86.mov eax, 1
    x86.mov [rbp-32], eax
    x86.jmp enum-full.main.check_4.merge
  check_4.cmp1:
    x86.mov eax, [rbp-40]
    x86.mov ecx, 404
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_4.merge
  check_4.case1:
    x86.xor eax, eax
    x86.mov [rbp-32], eax
    x86.jmp enum-full.main.check_4.merge
  check_4.merge:
    x86.mov eax, [rbp-32]
    x86.mov [rbp-48], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enum-full.main.__range_ok_5
  __range_panic_5:
    x86.lea_symdata rax, [__panic_msg_35]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_5:
    x86.mov eax, [rbp-48]
    x86.epilogue
    x86.ret

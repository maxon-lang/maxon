// Test: match-enum-no-binding

typealias Integer = i64

enum Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.empty
  match c 'check'
    empty then return 1
    value(n) then return n
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=32
    x86.xor eax, eax
    x86.xor ecx, ecx
    x86.mov [rbp-8], eax
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], ecx
    x86.mov [rbp-24], edx
    x86.jmp enum-full.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_0.merge
  check_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enum-full.main.__range_ok_1
  __range_panic_1:
    x86.lea_rdata rax, [__panic_msg_17]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

// Test: match-enum-no-binding
enum Container
  empty
  value(n int)
end 'Container'

function main() returns int
  var c = Container.empty
  match c 'check'
    empty then return 1
    value(n) then return n
  end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-24], edx
    x86.mov ebx, [rbp-16]
    x86.mov [rbp-32], ebx
    x86.mov esi, [rbp-24]
    x86.mov edi, [rbp-24]
    x86.mov r8, [rbp-32]
    x86.mov [rbp-40], r8
    x86.mov [rbp-48], esi
    x86.jmp enum-full.main.check_0.cmp0
  check_0.cmp0:
    x86.mov eax, [rbp-48]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_0.cmp1
  check_0.case0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.cmp1:
    x86.mov eax, [rbp-48]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.check_0.merge
  check_0.case1:
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  check_0.merge:
  }
}
---

// Test: error.match-enum-wrong-binding-count

typealias Integer = i64

enum Container
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.value(42)
  match c 'extract'
    value(a, b) then return a
  end 'extract'
end 'main'

// Test: fromRawValue-string-backed
enum Planet
  earth = "Earth"
  mars = "Mars"
end 'Planet'

function main() returns ExitCode
  var p = try Planet.fromRawValue("Mars") otherwise Planet.earth
  var result = match p 'check'
    Planet.mars gives 1
    Planet.earth gives 0
  end 'check'
  return result
end 'main'

// Test: implicit-string-backed-rawvalue
enum Direction
  "North"
  "South"
  "East"
end 'Direction'

function main() returns int
  var d = Direction.South
  var name = d.rawValue
  if name == "South" 'check'
    return 1
  end 'check'
  return 0
end 'main'

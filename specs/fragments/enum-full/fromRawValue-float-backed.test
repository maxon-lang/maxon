// Test: fromRawValue-float-backed
enum Weights
  light = 1.5
  medium = 2.5
  heavy = 3.5
end 'Weights'

function main() returns Integer
  var w = try Weights.fromRawValue(2.5) otherwise Weights.light
  if w == Weights.medium 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.movsd xmm0, [rip+__float_2.5]
    x86.mov eax, 1
    x86.movsd xmm1, [rip+__float_1.5]
    x86.ucomisd xmm0, xmm1
    x86.sete ecx
    x86.movzx ecx, ecxb
    x86.xor edx, edx
    x86.test ecx, ecx
    x86.mov ebx, eax
    x86.cmovne ebx, edx
    x86.movsd xmm2, [rip+__float_2.5]
    x86.ucomisd xmm0, xmm2
    x86.sete esi
    x86.movzx esi, esib
    x86.xor edi, edi
    x86.test esi, esi
    x86.mov r8, ebx
    x86.cmovne r8, edi
    x86.movsd xmm3, [rip+__float_3.5]
    x86.ucomisd xmm0, xmm3
    x86.sete r9
    x86.movzx r9, r9b
    x86.xor eax, eax
    x86.test r9, r9
    x86.mov ecx, r8
    x86.cmovne ecx, eax
    x86.movsd xmm4, [rip+__float_1.5]
    x86.movsd [rbp-8], xmm4
    x86.movsd [rbp-16], xmm0
    x86.xor eax, eax
    x86.cmp ecx, eax
    x86.je enum-full.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.movsd xmm0, [rbp-8]
    x86.movsd [rbp-16], xmm0
    x86.jmp enum-full.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.movsd xmm0, [rbp-16]
    x86.movsd [rbp-24], xmm0
    x86.movsd xmm1, [rip+__float_2.5]
    x86.movsd xmm2, [rbp-24]
    x86.ucomisd xmm2, xmm1
    x86.jne enum-full.main.check_4.after
    x86.jp enum-full.main.check_4.after
  check_4:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

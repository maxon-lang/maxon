// Test: associated-value-construction

typealias Integer = i64

enum Container
  empty
  value(n Integer)
end 'Container'

function main() returns ExitCode
  var c = Container.value(42)
  var e = Container.empty
  // Construction works - verify by checking tags are different
  if c != e 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 1
    x86.mov [rbp-8], eax
    x86.xor ecx, ecx
    x86.mov [rbp-16], ecx
    x86.mov edx, [rbp-8]
    x86.mov ebx, [rbp-16]
    x86.cmp edx, ebx
    x86.je enum-full.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

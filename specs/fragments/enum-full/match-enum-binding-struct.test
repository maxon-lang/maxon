    x86.mov esi, [rbp-48]
    x86.mov [ebx+0], esi
    x86.mov edi, [rbp-8]
    x86.mov r8, [rbp-56]
    x86.mov [edi+8], r8
    x86.mov r9, 1
    x86.mov [rbp-16], r9
    x86.mov ecx, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov [rbp-32], ecx
    x86.jmp enum-full.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.cmp1
  handle_0.case0:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  handle_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.merge
  handle_0.case1:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.mov ecx, [rbp-40]
    x86.mov edx, [ecx+0]
    x86.mov ebx, [rbp-40]
    x86.mov esi, [ebx+8]
    x86.lea eax, [edx + esi]

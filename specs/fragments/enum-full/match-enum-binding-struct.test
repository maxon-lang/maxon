// Test: match-enum-binding-struct
type EnumPoint
  export var x int
  export var y int
end 'EnumPoint'

enum Shape
  circle(radius int)
  rect(origin EnumPoint)
end 'Shape'

function main() returns int
  var s = Shape.rect(EnumPoint{x: 10, y: 20})
  match s 'handle'
    circle(r) then return r
    rect(p) then return p.x + p.y
  end 'handle'
end 'main'
---
ExitCode: 30
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov ecx, 20
    x86.mov edx, 1
    x86.mov [rbp-8], edx
    x86.mov ebx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], ecx
    x86.mov [rbp-32], ebx
    x86.jmp enum-full.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.cmp1
  handle_0.case0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  handle_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.merge
  handle_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, [rbp-24]
    x86.mov [rbp-40], ecx
    x86.mov [rbp-48], eax
    x86.mov edx, [rbp-48]
    x86.mov ebx, [rbp-40]
    x86.lea eax, [edx + ebx]
    x86.epilogue
    x86.ret
  handle_0.merge:
  }
}

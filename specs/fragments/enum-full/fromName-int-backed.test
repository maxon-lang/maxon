enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function main() returns int
  var status = try HttpStatus.fromName("notFound") otherwise HttpStatus.ok
  if status.rawValue == 404 'check'
    return 1
  end 'check'
  return 0
end 'main'

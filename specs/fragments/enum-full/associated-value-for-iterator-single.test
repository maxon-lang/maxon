// Test: associated-value-for-iterator-single

typealias Integer = int(i64.min to i64.max)

enum Box
    empty
    full(n Integer)
end 'Box'

typealias BoxArray = Array with Box

function main() returns ExitCode
    var boxes = BoxArray{}
    boxes.push(Box.full(42))
    var result = 0
    for b in boxes 'loop'
        match b 'check'
            empty then result = 0
            full(n) then result = n
        end 'check'
    end 'loop'
    return result
end 'main'
---
ExitCode: 42

// Test: associated-value-for-iterator-single
enum Box
    empty
    full(n int)
end 'Box'

typealias BoxArray = Array with Box

function main() returns int
    var boxes = BoxArray{}
    boxes.push(Box.full(42))
    var result = 0
    for b in boxes 'loop'
        match b 'check'
            empty then result = 0
            full(n) then result = n
        end 'check'
    end 'loop'
    return result
end 'main'
---
ExitCode: 42

// Test: match-enum-binding-multiple

typealias Integer = int(i64.min to i64.max)

enum Result
  success(value Integer)
  failure(code Integer)
end 'Result'

function main() returns ExitCode
  var r = Result.failure(99)
  match r 'handle'
    success(v) then return v
    failure(c) then return c
  end 'handle'
end 'main'
---
ExitCode: 99
---
module {
  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 99
    x86.mov ecx, 1
    x86.mov [rbp-8], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], edx
    x86.jmp enum-full.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.cmp1
  handle_0.case0:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-32], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enum-full.main.__range_ok_1
  __range_panic_1:
    x86.lea_rdata rax, [__panic_msg_14]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-32]
    x86.epilogue
    x86.ret
  handle_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.merge
  handle_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enum-full.main.__range_ok_2
  __range_panic_2:
    x86.lea_rdata rax, [__panic_msg_26]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_2:
    x86.mov eax, [rbp-40]
    x86.epilogue
    x86.ret
  handle_0.merge:
  }
}
---

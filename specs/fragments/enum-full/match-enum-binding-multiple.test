// Test: match-enum-binding-multiple
enum Result
  success(value Integer)
  failure(code Integer)
end 'Result'

function main() returns Integer
  var r = Result.failure(99)
  match r 'handle'
    success(v) then return v
    failure(c) then return c
  end 'handle'
end 'main'
---
ExitCode: 99
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 99
    x86.mov ecx, 1
    x86.mov [rbp-8], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.mov [rbp-24], edx
    x86.jmp enum-full.main.handle_0.cmp0
  handle_0.cmp0:
    x86.mov eax, [rbp-24]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.cmp1
  handle_0.case0:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  handle_0.cmp1:
    x86.mov eax, [rbp-24]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.handle_0.merge
  handle_0.case1:
    x86.mov eax, [rbp-16]
    x86.epilogue
    x86.ret
  handle_0.merge:
  }
}
---

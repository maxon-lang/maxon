// Test: fromRawValue-simple
enum Color
  red
  green
  blue
end 'Color'

function main() returns int
  var c = try Color.fromRawValue(1) otherwise Color.red
  if c == Color.green 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 1
    x86.mov ecx, 1
    x86.xor edx, edx
    x86.xor ebx, ebx
    x86.cmp eax, ebx
    x86.sete esi
    x86.movzx esi, esib
    x86.xor edi, edi
    x86.test esi, esi
    x86.mov r8, ecx
    x86.cmovne r8, edi
    x86.xor r9, r9
    x86.test esi, esi
    x86.mov ecx, edx
    x86.cmovne ecx, r9
    x86.mov edx, 1
    x86.cmp eax, edx
    x86.sete edx
    x86.movzx edx, edxb
    x86.xor ebx, ebx
    x86.test edx, edx
    x86.mov esi, r8
    x86.cmovne esi, ebx
    x86.mov ebx, 1
    x86.test edx, edx
    x86.mov edi, ecx
    x86.cmovne edi, ebx
    x86.mov ecx, 2
    x86.cmp eax, ecx
    x86.sete eax
    x86.movzx eax, eaxb
    x86.xor ecx, ecx
    x86.test eax, eax
    x86.mov edx, esi
    x86.cmovne edx, ecx
    x86.mov ecx, 2
    x86.test eax, eax
    x86.mov ebx, edi
    x86.cmovne ebx, ecx
    x86.xor eax, eax
    x86.mov [rbp-8], eax
    x86.mov [rbp-16], ebx
    x86.xor eax, eax
    x86.cmp edx, eax
    x86.je enum-full.main.otherwise_default_continue_3
  otherwise_default_error_2:
    x86.mov eax, [rbp-8]
    x86.mov [rbp-16], eax
    x86.jmp enum-full.main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x86.mov eax, [rbp-16]
    x86.mov [rbp-24], eax
    x86.mov ecx, 1
    x86.mov edx, [rbp-24]
    x86.cmp edx, ecx
    x86.jne enum-full.main.check_4.after
  check_4:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_4.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}

// Test: associated-value-function-param
enum Container
    empty
    value(n Integer)
end 'Container'

function process(c Container) returns Integer
    match c 'handle'
        empty then return 0
        value(n) then return n
    end 'handle'
end 'process'

function main() returns ExitCode
    var c = Container.value(42)
    return process(c)
end 'main'

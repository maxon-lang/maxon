// Test: fromName-associated-runtime-empty
enum Container
  empty
  value(n int)
end 'Container'

function getName() returns String
  return "empty"
end 'getName'

function main() returns int
  var name = getName()
  var c = try Container.fromName(name) otherwise Container.value(99)
  match c 'check'
    empty then return 1
    value(_n) then return 0
  end 'check'
end 'main'

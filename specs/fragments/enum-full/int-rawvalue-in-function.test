// Test: int-rawvalue-in-function
enum HttpStatus
  ok = 200
  notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns Integer
  return s.rawValue
end 'getCode'

function main() returns ExitCode
  var status = HttpStatus.notFound
  var code = getCode(status)
  if code == 404 'check'
    return 1
  end 'check'
  return 0
end 'main'
---
ExitCode: 1
---
module {
  func @enum-full.getCode(s: i64) -> i64 {
  entry:
    x86.prologue stack_size=16
    x86.mov [rbp-8], ecx
    x86.mov eax, [rbp-8]
    x86.epilogue
    x86.ret
  }
  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=16
    x86.mov eax, 404
    x86.mov [rbp-8], eax
    x86.mov ecx, [rbp-8]
    x86.call enum-full.getCode
    x86.mov edx, 404
    x86.cmp eax, edx
    x86.jne enum-full.main.check_0.after
  check_0:
    x86.mov eax, 1
    x86.epilogue
    x86.ret
  check_0.after:
    x86.xor eax, eax
    x86.epilogue
    x86.ret
  }
}
---

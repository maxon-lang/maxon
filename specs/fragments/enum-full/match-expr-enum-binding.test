// Test: match-expr-enum-binding
enum Container
  empty
  value(n int)
end 'Container'

function main() returns int
  var c = Container.value(10)
  var result = match c 'get'
    empty gives 0
    value(n) gives n * 2
  end 'get'
  return result
end 'main'
---
ExitCode: 20
---
module {
  func @enum-full.main() -> i64 {
  entry:
    x86.prologue stack_size=32
    x86.mov eax, 10
    x86.mov ecx, 1
    x86.mov [rbp-8], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ebx, ebx
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.jmp enum-full.main.get_0.cmp0
  get_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.get_0.cmp1
  get_0.case0:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp enum-full.main.get_0.merge
  get_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.get_0.merge
  get_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.imul eax, ecx
    x86.mov [rbp-24], eax
    x86.jmp enum-full.main.get_0.merge
  get_0.merge:
    x86.mov eax, [rbp-24]
    x86.epilogue
    x86.ret
  }
}
---

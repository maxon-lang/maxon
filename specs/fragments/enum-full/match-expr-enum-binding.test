  func @enum-full.main() -> u32 {
  entry:
    x86.prologue stack_size=48
    x86.mov eax, 10
    x86.mov ecx, 1
    x86.mov [rbp-8], ecx
    x86.mov edx, [rbp-8]
    x86.mov [rbp-16], eax
    x86.xor ebx, ebx
    x86.mov [rbp-24], ebx
    x86.mov [rbp-32], edx
    x86.jmp enum-full.main.get_0.cmp0
  get_0.cmp0:
    x86.mov eax, [rbp-32]
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.jne enum-full.main.get_0.cmp1
  get_0.case0:
    x86.xor eax, eax
    x86.mov [rbp-24], eax
    x86.jmp enum-full.main.get_0.merge
  get_0.cmp1:
    x86.mov eax, [rbp-32]
    x86.mov ecx, 1
    x86.cmp eax, ecx
    x86.jne enum-full.main.get_0.merge
  get_0.case1:
    x86.mov eax, [rbp-16]
    x86.mov ecx, 2
    x86.imul eax, ecx
    x86.mov [rbp-24], eax
    x86.jmp enum-full.main.get_0.merge
  get_0.merge:
    x86.mov eax, [rbp-24]
    x86.mov [rbp-40], eax
    x86.xor ecx, ecx
    x86.cmp eax, ecx
    x86.setl edx
    x86.movzx edx, edxb
    x86.mov rbx, 4294967295
    x86.cmp rax, rbx
    x86.setg esi
    x86.movzx esi, esib
    x86.or edx, esi
    x86.test edx, edx
    x86.je enum-full.main.__range_ok_1
  __range_panic_1:
    x86.lea_symdata rax, [__panic_msg_22]
    x86.mov rcx, rax
    x86.call maxon_panic
  __range_ok_1:
    x86.mov eax, [rbp-40]
    x86.epilogue

// Test: round.basic
function main() returns Integer
  var x = 3.7
  var y = trunc(round(x))
  return y
end 'main'
---
ExitCode: 4
---
module {
  func @round.main() -> i64 {
  entry:
    x86.movsd xmm0, [rip+__float_3.7]
    x86.roundsd xmm1, xmm0, 0
    x86.cvttsd2si eax, xmm1
    x86.ret
  }
}
---

// Test: round.negative
function main() returns int
    var neg = 0.0 - 2.3
    var y = trunc(round(neg))
    return y + 10
end 'main'
---
ExitCode: 8
---
func.func @main() -> i64 {
  ^entry:
    x86.prologue stack_size=32
    x86.mov rax, -4611010478483282330
    x86.movq xmm0, rax
    x86.roundsd xmm1, xmm0, Nearest
    x86.cvttsd2si rax, xmm1
    x86.mov rcx, 10
    x86.mov rdx, rax
    x86.add rdx, rcx
    x86.mov rax, rdx
    x86.epilogue
    x86.ret
}
---

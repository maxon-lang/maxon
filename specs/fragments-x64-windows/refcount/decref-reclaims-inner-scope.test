// Test: decref-reclaims-inner-scope
typealias Integer = int(i64.min to i64.max)
type Cell
		export var value Integer

		static function create(value Integer) returns Self
			return Self{value: value}
		end 'create'
end 'Cell'
function main() returns ExitCode
		var a = Cell.create(value: 10)
		var result = 0
		if true 'inner'
				let b = a
				a = Cell.create(value: 20)
				result = b.value
		end 'inner'
		return result + a.value
end 'main'
---
ExitCode: 30
---
module {
  func @Cell.create(value: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 10
    x64.call Cell.create
    x64.mov [rbp-8], rax
    x64.xor rax, rax
    x64.mov [rbp-16], rax
    x64.mov rcx, 1
    x64.test rcx, rcx
    x64.je main.inner_0.merge
  inner_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rax
    x64.mov rcx, [rbp-24]
    x64.call mm_incref
    x64.mov rcx, 20
    x64.call Cell.create
    x64.mov rdx, [rbp-8]
    x64.mov [rbp-32], rax
    x64.test rdx, rdx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rbx, [rbp-32]
    x64.mov [rbp-8], rbx
    x64.mov rsi, [rbp-24]
    x64.mov rdi, [rsi+0]
    x64.mov [rbp-16], rdi
    x64.mov r8, [rbp-24]
    x64.test r8, r8
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-24]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.jmp main.inner_0.merge
  inner_0.merge:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.mov rdx, [rbp-16]
    x64.add rdx, rcx
    x64.xor rbx, rbx
    x64.mov esi, 4294967295
    x64.cmp rdx, rsi
    x64.jg main.__range_panic_1
    x64.cmp rdx, rbx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-32], rdx
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.mov rax, [rbp-32]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Cell(ptr: i64) {
  entry:
    x64.jmp __destruct_Cell.done
  done:
    x64.ret
  }
}
---

// Test: break-cleans-refs
typealias Integer = int(i64.min to i64.max)
type Counter
		export var val Integer

		static function create(val Integer) returns Self
			return Self{val: val}
		end 'create'
end 'Counter'
function main() returns ExitCode
		var total = 0
		var i = 0
		while i < 5 'loop'
				let c = Counter.create(val: i)
				if i == 3 'brk'
						total = total + c.val
						break
				end 'brk'
				total = total + c.val
				i = i + 1
		end 'loop'
		return total
end 'main'
---

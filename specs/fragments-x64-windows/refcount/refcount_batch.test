			return Self{v: v}
		end 'create'
end 'Num'
function makeNum(n Integer) returns Num
		return Num.create(v: n)
end 'makeNum'
function addOne(x Num) returns Num
		return Num.create(v: x.v + 1)
end 'addOne'
function main() returns ExitCode
		let result = addOne(makeNum(10))
		return result.v
end 'main'

// Test: basic-aliasing
typealias Integer = int(i64.min to i64.max)
type Point
		export var x as Integer
		export var y as Integer

		static function create(x Integer, y Integer) returns Self
			return Self{x: x, y: y}
		end 'create'
end 'Point'
function main() returns ExitCode
		let a = Point.create(10, y: 20)
		let b = a
		return a.x + b.y
end 'main'

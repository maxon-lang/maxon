// Test: reassignment-decrefs-old
typealias Integer = int(i64.min to i64.max)
type Item
		export var val Integer

		static function create(val Integer) returns Self
			return Self{val: val}
		end 'create'
end 'Item'
function main() returns ExitCode
		var a = Item.create(val: 10)
		a = Item.create(val: 20)
		return a.val
end 'main'
---
ExitCode: 20
---
module {
  func @Item.create(val: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 10
    x64.call Item.create
    x64.mov [rbp-8], rax
    x64.mov rcx, 20
    x64.call Item.create
    x64.mov rcx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rcx+0]
    x64.xor rbx, rbx
    x64.mov rsi, 4294967295
    x64.cmp rdx, rsi
    x64.jg main.__range_panic_0
    x64.cmp rdx, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rdx
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    x64.jmp __destruct_Item.done
  done:
    x64.ret
  }
}
---

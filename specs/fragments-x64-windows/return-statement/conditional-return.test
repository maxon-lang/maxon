// Test: conditional-return
function main() returns ExitCode
	var x = 5
	if x > 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 5
    x64.mov rcx, 3
    x64.cmp rax, rcx
    x64.jle main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

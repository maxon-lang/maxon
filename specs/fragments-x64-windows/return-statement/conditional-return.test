// Test: conditional-return
function main() returns ExitCode
	let x = 5
	if x > 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rbx, 5
    x64.cmp rbx, 3
    x64.jle check_1.after
  check_1:
    x64.mov rax, 1
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

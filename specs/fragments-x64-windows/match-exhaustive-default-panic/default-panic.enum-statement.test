// Test: default-panic.enum-statement
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	match c 'check'
		red then return 1
		default panic("unhandled color")
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @match-exhaustive-default-panic.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.jmp match-exhaustive-default-panic.main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne match-exhaustive-default-panic.main.check_0.case1
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.case1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  check_0.merge:
  }
}
---

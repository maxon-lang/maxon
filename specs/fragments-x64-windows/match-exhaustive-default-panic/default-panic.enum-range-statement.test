// Test: default-panic.enum-range-statement
typealias Integer = int(i64.min to i64.max)

union Op
	add
	sub
	mul
	exec(code Integer)
end 'Op'

function main() returns ExitCode
	let op = Op.sub
	match op 'check'
		add to mul then return 1
		default panic("unexpected op")
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12d, 1
    x64.xor edx, edx
    x64.mov ecx, 16
    x64.mov rax, r12
    x64.call stdlib.__mm_alloc
    x64.mov [r8+0], r12 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 2
    x64.setle r8
    x64.test r9, r9
    x64.setge r9
    x64.and r9, r8
    x64.je check_0.case1
  check_0.case0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.case1:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov r8d, 1
    x64.mov [r12+0], r8 (8b)
    x64.xor r8d, r8d
    x64.mov [r12+8], r8 (8b)
    x64.mov r13, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.cmp r13, 2
    x64.setle r8
    x64.test r13, r13
    x64.setge r9
    x64.and r9, r8
    x64.je check_0.case1
  check_0.case0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.case1:
    x64.lea r12, [rip+__panic_msg_606664f334c368f6]
    x64.mov rcx, r12
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

// Test: default-panic.enum-range-expression
typealias Integer = int(i64.min to i64.max)

union Op
	add
	sub
	mul
	exec(code Integer)
end 'Op'

function main() returns ExitCode
	let op = Op.mul
	let result = match op 'eval'
		add to sub gives 1
		mul gives 2
		default panic("unexpected op")
	end 'eval'
	return result
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=48
    x64.mov rcx, 16
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rcx, 2
    x64.mov [rax+0], rcx
    x64.xor ecx, ecx
    x64.mov [rax+8], rcx
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.mov rdx, [rbp-8]
    x64.mov [rbp-16], rdx
    x64.mov rbx, [rbp-16]
    x64.mov [rbp-40], rcx
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.xor esi, esi
    x64.mov [rbp-24], rsi
    x64.mov rdi, [rbp-40]
    x64.mov [rbp-32], rdi
    x64.jmp main.eval_0.cmp0
  eval_0.cmp0:
    x64.mov rax, [rbp-32]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-32]
    x64.mov rsi, 1
    x64.cmp rbx, rsi
    x64.setle rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.eval_0.cmp1
  eval_0.case0:
    x64.mov rax, 1
    x64.mov [rbp-24], rax
    x64.jmp main.eval_0.merge
  eval_0.cmp1:
    x64.mov rax, [rbp-32]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.eval_0.case2
  eval_0.case1:
    x64.mov rax, 2
    x64.mov [rbp-24], rax
    x64.jmp main.eval_0.merge
  eval_0.case2:
    x64.mov rax, [rbp-16]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.xor ecx, ecx
    x64.mov [rbp-16], rcx
    x64.mov rdx, [rbp-8]
    x64.test rdx, rdx
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.xor ebx, ebx
    x64.mov [rbp-8], rbx
    x64.lea_symdata rsi, [__panic_msg_0]
    x64.mov rdi, rsi
    x64.mov rcx, rdi
    x64.call mrt_panic
  eval_0.merge:
    x64.mov rax, [rbp-24]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.mov rbx, [rbp-16]
    x64.test rbx, rbx
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_3
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_3
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Op(ptr: i64) {

    x64.mov rax, r12
    x64.call stdlib.__mm_alloc
    x64.mov [r8+0], r12 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 1
    x64.setle rsi
    x64.test r9, r9
    x64.setge r9
    x64.and r9, rsi
    x64.je eval_0.next0
    x64.jmp eval_0.case0
  eval_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  eval_0.case0:
    x64.mov r8d, 1
    x64.jmp eval_0.merge
  eval_0.next0:
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 2
    x64.jne eval_0.case2
  eval_0.case1:
    x64.mov r8d, 2
    x64.jmp eval_0.merge
  eval_0.case2:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_1]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

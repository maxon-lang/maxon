// Batch: hex-escape
// Tests: hex-escape.byte-string-basic, hex-escape.byte-string-ff, hex-escape.mixed-content, hex-escape.character-literal, hex-escape.string-literal, hex-escape.lowercase-digits
---
// Test: hex-escape.byte-string-basic
function main() returns ExitCode
		let bytes = b"\x41\x42"
		let a = try bytes.get(0) otherwise 0
		let b = try bytes.get(1) otherwise 0
		print("{a} {b}")
		return bytes.count()
end 'main'
---
ExitCode: 2
Stdout: ```
65 66
```
---
// Test: hex-escape.byte-string-ff
function main() returns ExitCode
		let bytes = b"\xFF"
		let v = try bytes.get(0) otherwise 0
		print("{v}")
		return bytes.count()
end 'main'
---
ExitCode: 1
Stdout: ```
255
```
---
// Test: hex-escape.mixed-content
function main() returns ExitCode
		let bytes = b"A\x42C"
		let a = try bytes.get(0) otherwise 0
		let b = try bytes.get(1) otherwise 0
		let c = try bytes.get(2) otherwise 0
		print("{a} {b} {c}")
		return bytes.count()
end 'main'
---
ExitCode: 3
Stdout: ```
65 66 67
```
---
// Test: hex-escape.character-literal
function main() returns ExitCode
		let ch = '\x41'
		if ch == 'A' 'check'
				return 0
		end 'check'
		return 1
end 'main'
---
ExitCode: 0
---
// Test: hex-escape.string-literal
function main() returns ExitCode
		let s = "\x48\x69"
		print(s)
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
Hi
```
---
// Test: hex-escape.lowercase-digits
function main() returns ExitCode
		let bytes = b"\x0a"
		let v = try bytes.get(0) otherwise 0
		print("{v}")
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10
```
---

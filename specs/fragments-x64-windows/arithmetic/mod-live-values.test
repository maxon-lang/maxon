// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	var preserved = x + 1
	var result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
module {
  func @mod-live-values.modLive(ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.add r8, 1
    x64.mov rax, rcx
    x64.mov rcx, rdx
    x64.cqo
    x64.idiv rcx
    x64.add rdx, r8
    x64.mov rax, -9223372036854775807
    x64.cmp rdx, rax
    x64.jge __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 3
    x64.mov r8, 5
    x64.call mod-live-values.modLive
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

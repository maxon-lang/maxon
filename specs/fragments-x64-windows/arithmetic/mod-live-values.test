// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	let preserved = x + 1
	let result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
module {
  func @arithmetic.modLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.add r8, rax
    x64.mov rbx, rdx
    x64.mov [rbp-8], rdx
    x64.mov rax, rcx
    x64.cqo
    x64.idiv rbx
    x64.lea rax, [rdx + r8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 3
    x64.mov r8, 5
    x64.call arithmetic.modLive
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

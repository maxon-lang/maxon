    x64.idiv r9
    x64.mov rax, rbx
    x64.add rax, 1
    x64.mov r8, rdx
    x64.add r8, rax
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov eax, 5

// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	let preserved = x + 1
	let result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @arithmetic.modLive(rcx: i64, rdx: i64, rax: i64) -> i64 {
  entry:
    x64.mov r8, rdx
    x64.mov r9, rax
    x64.mov rax, rcx
    x64.cqo
    x64.idiv r8
    x64.add r9, 1
    x64.add r9, rdx
    x64.mov r8, r9
    x64.ret
  }
  func @arithmetic.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 5
    x64.mov r9d, 3
    x64.mov esi, 10
    x64.mov rcx, rsi
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call arithmetic.modLive
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_3]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}

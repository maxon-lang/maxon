// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	let preserved = x + 1
	let result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 3
    x64.mov eax, 10
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rdx
    x64.add r8, 6
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: register-pressure

typealias Integer = int(i64.min to i64.max)

function manyVars(a Integer, b Integer, c Integer, d Integer, e Integer, f Integer) returns Integer
	let v1 = a + 1
	let v2 = b + 2
	let v3 = c + 3
	let v4 = d + 4
	let v5 = e + 5
	let v6 = f + 6
	let v7 = v1 + v2
	let v8 = v3 + v4
	let v9 = v5 + v6
	let v10 = v7 + v8
	let v11 = v9 + v10
	let v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
	return v12
end 'manyVars'

function main() returns ExitCode
	return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'
---
ExitCode: 84
---
module {
  func @register-pressure.manyVars(ptr: i64, ptr: i64, ptr: i64, ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.add r9, 4
    x64.add r8, 3
    x64.mov rbx, r8
    x64.add rbx, r9
    x64.add rdx, 2
    x64.add rcx, 1
    x64.mov r12, rcx
    x64.add r12, rdx
    x64.add r12, rbx
    x64.add rdi, 6
    x64.add rsi, 5
    x64.mov rbx, rsi
    x64.add rbx, rdi
    x64.add rbx, r12
    x64.add rbx, rcx
    x64.add rbx, rdx
    x64.add rbx, r8
    x64.add rbx, r9
    x64.add rbx, rsi
    x64.add rbx, rdi
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.mov rdx, 2
    x64.mov r8, 3
    x64.mov r9, 4
    x64.mov rsi, 5
    x64.mov rdi, 6
    x64.call register-pressure.manyVars
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: div-loop

typealias Integer = int(i64.min to i64.max)

function divLoop(n Integer) returns Integer
	var sum = 0
	var i = 1
	while i <= n 'loop'
		sum = sum + trunc(100 / i)
		i = i + 1
	end 'loop'
	return sum
end 'divLoop'

function main() returns ExitCode
	return divLoop(5)
end 'main'
---
ExitCode: 228
---
module {
  func @div-loop.divLoop(ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.mov [rbp+-24], rcx
    x64.mov rax, 1
    x64.mov [rbp-16], rax
  loop_1.header:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov rdx, [rbp+-24]
    x64.cmp rcx, rdx
    x64.jg loop_1.exit
  loop_1:
    x64.mov rax, [rbp+-16]
    x64.mov rcx, rax
    x64.add rcx, 1
    x64.mov rax, 100
    x64.cqo
    x64.mov rbx, [rbp+-16]
    x64.idiv rbx
    x64.mov rdx, [rbp+-8]
    x64.mov rbx, rdx
    x64.add rbx, rax
    x64.mov [rbp-8], rbx
    x64.mov [rbp-16], rcx
    x64.jmp loop_1.header
  loop_1.exit:
    x64.mov rax, [rbp+-8]
    x64.mov rcx, -9223372036854775807
    x64.cmp rax, rcx
    x64.jge __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call div-loop.divLoop
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

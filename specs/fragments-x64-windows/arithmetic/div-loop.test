// Test: div-loop

typealias Integer = int(i64.min to i64.max)

function divLoop(n Integer) returns Integer
	var sum = 0
	var i = 1
	while i <= n 'loop'
		sum = sum + trunc(50 / i)
		i = i + 1
	end 'loop'
	return sum
end 'divLoop'

function main() returns ExitCode
	return divLoop(5)
end 'main'
---
ExitCode: 113
---
module {
  func @div-loop.divLoop(ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.xor rbx, rbx
    x64.mov [rbp-8], rbx
    x64.mov [rbp+-24], rcx
    x64.mov rsi, 1
    x64.mov [rbp-16], rsi
  loop_1.header:
    x64.mov rbx, [rbp-8]
    x64.mov rsi, [rbp-16]
    x64.mov rdi, [rbp+-24]
    x64.cmp rsi, rdi
    x64.jg loop_1.exit
  loop_1:
    x64.mov r8, rsi
    x64.add r8, 1
    x64.mov rax, 50
    x64.cqo
    x64.idiv rsi
    x64.mov r9, rbx
    x64.add r9, rax
    x64.mov [rbp-8], r9
    x64.mov [rbp-16], r8
    x64.jmp loop_1.header
  loop_1.exit:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call div-loop.divLoop
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

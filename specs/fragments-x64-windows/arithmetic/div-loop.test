    x64.xchg r8, r9
  loop_1.header:
    x64.cmp r9, rcx
    x64.jg loop_1.exit
  loop_1:
    x64.mov esi, 50
    x64.mov rax, rsi
    x64.xor edx, edx
    x64.idiv r9
    x64.add r9, 1
    x64.add r8, rax
    x64.jmp loop_1.header
  loop_1.exit:
    x64.ret
  }
  func @arithmetic.main() -> u8 {
  entry:
    x64.prologue stack_size=16

    x64.mov [rbp-24], rax
    x64.jmp arithmetic.divLoop.loop_0.header
  loop_0.header:
    x64.mov rax, [rbp-24]
    x64.mov rcx, [rbp-8]
    x64.cmp rax, rcx
    x64.jg arithmetic.divLoop.loop_0.exit
  loop_0:
    x64.mov rax, 50
    x64.mov rcx, [rbp-24]
    x64.cqo
    x64.idiv rcx
    x64.mov rdx, [rbp-16]
    x64.add rdx, rax
    x64.mov [rbp-16], rdx
    x64.mov rbx, 1
    x64.mov rsi, [rbp-24]
    x64.add rsi, rbx
    x64.mov [rbp-24], rsi
    x64.jmp arithmetic.divLoop.loop_0.header
  loop_0.exit:
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call arithmetic.divLoop
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:

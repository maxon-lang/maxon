// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
	var preserved = x + 1
	var result = a / b
	return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
	return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @arithmetic.divLive(a: i64, b: i64, x: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.add r8, rax
    x64.mov rbx, rdx
    x64.mov [rbp-8], rdx
    x64.mov rax, rcx
    x64.cqo
    x64.idiv rbx
    x64.add rax, r8
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 2
    x64.mov r8, 5
    x64.call arithmetic.divLive
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
	let preserved = x + 1
	let result = a / b
	return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
	return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov r9d, 10
    x64.mov rax, r9
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rax
    x64.add r8, 6
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea r8, [rip+__panic_msg_2]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}

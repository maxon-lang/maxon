// Test: modulo
function main() returns ExitCode
	return 17 mod 5
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 17
    x64.cqo
    x64.mov rbx, 5
    x64.idiv rbx
    x64.cmp rdx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

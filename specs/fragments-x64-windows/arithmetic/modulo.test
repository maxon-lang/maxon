    x64.mov eax, 17
    x64.xor edx, edx
    x64.idiv r8
    x64.cmp rdx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:

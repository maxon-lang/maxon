// Test: modulo
function main() returns ExitCode
	return 17 mod 5
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @arithmetic.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 5
    x64.mov r9d, 17
    x64.mov rax, r9
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rdx
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

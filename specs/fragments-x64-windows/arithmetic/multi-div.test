  entry:
    x64.prologue stack_size=32
    x64.mov r8, rcx
    x64.mov rbx, rdx
    x64.mov rsi, rax
    x64.mov rdi, r9
    x64.mov rax, rsi
    x64.cqo
    x64.idiv rdi
    x64.mov rsi, rax
    x64.mov rax, r8
    x64.cqo
    x64.idiv rbx
    x64.mov r8, rax
    x64.add r8, rsi
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r9d, 4

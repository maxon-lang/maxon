// Test: division
function main() returns ExitCode
	return trunc(100 / 4)
end 'main'
---
ExitCode: 25
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 100
    x64.cqo
    x64.mov rcx, 4
    x64.idiv rcx
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

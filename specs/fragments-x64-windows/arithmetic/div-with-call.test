// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	let temp = trunc(a / b)
	let result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @div-with-call.helper(ptr: i64) -> i64 {
  entry:
    x64.mov rbx, 2
    x64.imul rcx, rbx
    x64.mov rax, rcx
    x64.ret
  }
  func @div-with-call.divCall(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov rax, rcx
    x64.mov rbx, rdx
    x64.cqo
    x64.idiv rbx
    x64.mov rcx, rax
    x64.mov r12, rcx
    x64.call div-with-call.helper
    x64.add rax, r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 2
    x64.call div-with-call.divCall
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

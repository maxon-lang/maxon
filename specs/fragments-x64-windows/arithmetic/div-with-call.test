// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	let temp = trunc(a / b)
	let result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @div-with-call.helper(rcx: i64) -> i64 {
  entry:
    x64.mov r9d, 2
    x64.mov r8, rcx
    x64.imul r8, r9
    x64.ret
  }
  func @div-with-call.divCall(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r8, rcx
    x64.mov r9, rdx
    x64.mov rax, r8
    x64.cqo
    x64.idiv r9
    x64.mov r12, rax
    x64.mov rcx, r12
    x64.call div-with-call.helper
    x64.add r8, r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 2
    x64.mov ecx, 10
    x64.call div-with-call.divCall
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

    x64.mov rax, rcx
    x64.cqo
    x64.idiv r8
    x64.mov r12, rax
    x64.mov rcx, r12
    x64.call arithmetic.helper
    x64.mov r9, r8
    x64.add r9, r12
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @arithmetic.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov r9d, 10
    x64.mov rcx, r9
    x64.mov rdx, r8
    x64.call arithmetic.divCall
    x64.cmp r8, 125
    x64.jbe __range_ok_5
  __range_panic_5:
    x64.lea r8, [rip+__panic_msg_5]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_5:
    x64.epilogue
    x64.ret
  }

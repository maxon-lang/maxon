// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	var temp = trunc(a / b)
	var result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @div-with-call.helper(ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 2
    x64.imul rcx, rax
    x64.mov rax, -9223372036854775807
    x64.cmp rcx, rax
    x64.jge __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
  func @div-with-call.divCall(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, rcx
    x64.mov rcx, rdx
    x64.cqo
    x64.idiv rcx
    x64.mov rcx, rax
    x64.mov [rbp+-8], rcx
    x64.call div-with-call.helper
    x64.mov rcx, [rbp+-8]
    x64.add rax, rcx
    x64.mov rcx, -9223372036854775807
    x64.cmp rax, rcx
    x64.jge __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 2
    x64.call div-with-call.divCall
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea rax, [rip+__panic_msg_2]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}

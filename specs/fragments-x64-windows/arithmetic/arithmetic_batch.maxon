// --- batched test: addition ---
function _b_addition_main() returns ExitCode
	return 10 + 5
end '_b_addition_main'

// --- batched test: subtraction ---
function _b_subtraction_main() returns ExitCode
	return 20-8
end '_b_subtraction_main'

// --- batched test: multiplication ---
function _b_multiplication_main() returns ExitCode
	return 6 * 7
end '_b_multiplication_main'

// --- batched test: division ---
function _b_division_main() returns ExitCode
	return trunc(100 / 4)
end '_b_division_main'

// --- batched test: modulo ---
function _b_modulo_main() returns ExitCode
	return 17 mod 5
end '_b_modulo_main'

// --- batched test: complex-expression ---
function _b_complex_expression_main() returns ExitCode
	return 10 + 5 * 2
end '_b_complex_expression_main'

// --- batched test: div-live-values ---

typealias _b_div_live_values_Integer = int(i64.min to i64.max)

function _b_div_live_values_divLive(a _b_div_live_values_Integer, b _b_div_live_values_Integer, x _b_div_live_values_Integer) returns _b_div_live_values_Integer
	let preserved = x + 1
	let result = a / b
	return trunc(result + preserved)
end '_b_div_live_values_divLive'

function _b_div_live_values_main() returns ExitCode
	return _b_div_live_values_divLive(10, b: 2, x: 5)
end '_b_div_live_values_main'

// --- batched test: mod-live-values ---

typealias _b_mod_live_values_Integer = int(i64.min to i64.max)

function _b_mod_live_values_modLive(a _b_mod_live_values_Integer, b _b_mod_live_values_Integer, x _b_mod_live_values_Integer) returns _b_mod_live_values_Integer
	let preserved = x + 1
	let result = a mod b
	return result + preserved
end '_b_mod_live_values_modLive'

function _b_mod_live_values_main() returns ExitCode
	return _b_mod_live_values_modLive(10, b: 3, x: 5)
end '_b_mod_live_values_main'

// --- batched test: div-loop ---

typealias _b_div_loop_Integer = int(i64.min to i64.max)

function _b_div_loop_divLoop(n _b_div_loop_Integer) returns _b_div_loop_Integer
	var sum = 0
	var i = 1
	while i <= n 'loop'
		sum = sum + trunc(50 / i)
		i = i + 1
	end 'loop'
	return sum
end '_b_div_loop_divLoop'

function _b_div_loop_main() returns ExitCode
	return _b_div_loop_divLoop(5)
end '_b_div_loop_main'

// --- batched test: div-with-call ---

typealias _b_div_with_call_Integer = int(i64.min to i64.max)

function _b_div_with_call_helper(x _b_div_with_call_Integer) returns _b_div_with_call_Integer
	return x * 2
end '_b_div_with_call_helper'

function _b_div_with_call_divCall(a _b_div_with_call_Integer, b _b_div_with_call_Integer) returns _b_div_with_call_Integer
	let temp = trunc(a / b)
	let result = _b_div_with_call_helper(temp)
	return result + temp
end '_b_div_with_call_divCall'

function _b_div_with_call_main() returns ExitCode
	return _b_div_with_call_divCall(10, b: 2)
end '_b_div_with_call_main'

// --- batched test: multi-div ---

typealias _b_multi_div_Integer = int(i64.min to i64.max)

function _b_multi_div_multiDiv(a _b_multi_div_Integer, b _b_multi_div_Integer, c _b_multi_div_Integer, d _b_multi_div_Integer) returns _b_multi_div_Integer
	let r1 = a / b
	let r2 = c / d
	return trunc(r1 + r2)
end '_b_multi_div_multiDiv'

function _b_multi_div_main() returns ExitCode
	return _b_multi_div_multiDiv(10, b: 2, c: 20, d: 4)
end '_b_multi_div_main'

// --- batched test: register-pressure ---

typealias _b_register_pressure_Integer = int(i64.min to i64.max)

function _b_register_pressure_manyVars(a _b_register_pressure_Integer, b _b_register_pressure_Integer, c _b_register_pressure_Integer, d _b_register_pressure_Integer, e _b_register_pressure_Integer, f _b_register_pressure_Integer) returns _b_register_pressure_Integer
	let v1 = a + 1
	let v2 = b + 2
	let v3 = c + 3
	let v4 = d + 4
	let v5 = e + 5
	let v6 = f + 6
	let v7 = v1 + v2
	let v8 = v3 + v4
	let v9 = v5 + v6
	let v10 = v7 + v8
	let v11 = v9 + v10
	let v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
	return v12
end '_b_register_pressure_manyVars'

function _b_register_pressure_main() returns ExitCode
	return _b_register_pressure_manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end '_b_register_pressure_main'

// --- batch dispatcher for arithmetic ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:addition>>>\n")
	let ec_addition = _b_addition_main()
	print("\n<<<MAXON_BATCH_TEST_END:addition:{ec_addition}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:subtraction>>>\n")
	let ec_subtraction = _b_subtraction_main()
	print("\n<<<MAXON_BATCH_TEST_END:subtraction:{ec_subtraction}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multiplication>>>\n")
	let ec_multiplication = _b_multiplication_main()
	print("\n<<<MAXON_BATCH_TEST_END:multiplication:{ec_multiplication}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:division>>>\n")
	let ec_division = _b_division_main()
	print("\n<<<MAXON_BATCH_TEST_END:division:{ec_division}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:modulo>>>\n")
	let ec_modulo = _b_modulo_main()
	print("\n<<<MAXON_BATCH_TEST_END:modulo:{ec_modulo}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:complex-expression>>>\n")
	let ec_complex_expression = _b_complex_expression_main()
	print("\n<<<MAXON_BATCH_TEST_END:complex-expression:{ec_complex_expression}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:div-live-values>>>\n")
	let ec_div_live_values = _b_div_live_values_main()
	print("\n<<<MAXON_BATCH_TEST_END:div-live-values:{ec_div_live_values}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:mod-live-values>>>\n")
	let ec_mod_live_values = _b_mod_live_values_main()
	print("\n<<<MAXON_BATCH_TEST_END:mod-live-values:{ec_mod_live_values}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:div-loop>>>\n")
	let ec_div_loop = _b_div_loop_main()
	print("\n<<<MAXON_BATCH_TEST_END:div-loop:{ec_div_loop}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:div-with-call>>>\n")
	let ec_div_with_call = _b_div_with_call_main()
	print("\n<<<MAXON_BATCH_TEST_END:div-with-call:{ec_div_with_call}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multi-div>>>\n")
	let ec_multi_div = _b_multi_div_main()
	print("\n<<<MAXON_BATCH_TEST_END:multi-div:{ec_multi_div}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:register-pressure>>>\n")
	let ec_register_pressure = _b_register_pressure_main()
	print("\n<<<MAXON_BATCH_TEST_END:register-pressure:{ec_register_pressure}>>>\n")
	return 0 as ExitCode
end 'main'

// Test: docs-example-1
function main() returns ExitCode
	let content = try File.readText(FilePath from "example.txt") otherwise 'err'
		print("Could not read file\n")
		return 0
	end 'err'
	print("File content: {content}\n")
	return 1
end 'main'

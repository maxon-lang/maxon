// Test: int-value-live-across-nested-control
function main() returns ExitCode
	let sentinel = 100
	var total = 0
	var i = 0
	while i < 3 'outer'
		var j = 0
		while j < 3 'inner'
			if i == j 'diag'
				total = total + 1
			end 'diag'
			j = j + 1
		end 'inner'
		i = i + 1
	end 'outer'
	return sentinel + total
end 'main'

module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 1
    x64.xor esi, esi
    x64.xchg r8, rsi
  loop_0.header:
    x64.cmp rsi, 13
    x64.jge loop_0.exit
  loop_0:
    x64.add rsi, 1
    x64.add r8, r9
    x64.xchg r8, r9
    x64.jmp loop_0.header
  loop_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

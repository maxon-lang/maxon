// Test: int-call-preserves-value

typealias Integer = int(i64.min to i64.max)

function getForty() returns Integer
	return 40
end 'getForty'

function main() returns ExitCode
	let x = 2
	let y = getForty()
	return x + y
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
}
---

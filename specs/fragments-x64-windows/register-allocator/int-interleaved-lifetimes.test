// Test: int-interleaved-lifetimes
function main() returns ExitCode
	let a = 10
	let b = 20
	let ab = a + b
	let c = 30
	let d = 40
	let cd = c + d
	let e = 50
	let f = 60
	let ef = e + f
	let result = ab + cd + ef
	return result and 125
end 'main'
---
ExitCode: 80
RequiredIRSelfhosted: ```
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 80
    x64.ret
  }
}

```

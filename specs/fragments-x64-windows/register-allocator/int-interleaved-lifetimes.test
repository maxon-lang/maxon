// Test: int-interleaved-lifetimes
function main() returns ExitCode
	let a = 10
	let b = 20
	let ab = a + b
	let c = 30
	let d = 40
	let cd = c + d
	let e = 50
	let f = 60
	let ef = e + f
	let result = ab + cd + ef
	return result mod 256
end 'main'
---
ExitCode: 210
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 256
    x64.mov eax, 210
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rdx
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

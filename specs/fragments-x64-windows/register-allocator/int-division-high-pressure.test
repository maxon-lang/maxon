// Test: int-division-high-pressure
function main() returns ExitCode
	var a = 10
	var b = 20
	var c = 30
	var d = 40
	var e = 50
	var f = 60
	var g = 70
	var h = 2
	return (a + b + c + d + e + f + g) / h
end 'main'
---
ExitCode: 140
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov rcx, 20
    x64.mov rdx, 30
    x64.mov rbx, 40
    x64.mov rsi, 50
    x64.mov rdi, 60
    x64.mov r8, 70
    x64.mov r9, 2
    x64.add rax, rcx
    x64.add rax, rdx
    x64.add rax, rbx
    x64.add rax, rsi
    x64.add rax, rdi
    x64.add rax, r8
    x64.mov [rbp-8], rax
    x64.cqo
    x64.idiv r9
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

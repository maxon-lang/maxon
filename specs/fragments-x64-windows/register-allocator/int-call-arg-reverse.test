// Test: int-call-arg-reverse

typealias Integer = int(i64.min to i64.max)

function sub(a Integer, b Integer) returns Integer
	return a - b
end 'sub'

function main() returns ExitCode
	let x = 10
	let y = 3
	let result = sub(y, b: x)
	return result + 45
end 'main'
---
ExitCode: 38
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 38
    x64.ret
  }
}
---

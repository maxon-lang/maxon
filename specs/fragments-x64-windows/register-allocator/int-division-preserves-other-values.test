// Test: int-division-preserves-other-values
function main() returns ExitCode
	let x = 10
	let a = 84
	let b = 2
	let quotient = a / b
	return quotient - x
end 'main'
---
ExitCode: 32
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov eax, 84
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r9d, 4294967295
    x64.mov r8, rax
    x64.sub r8, 10
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_e6fcf5fa8a7bd360]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

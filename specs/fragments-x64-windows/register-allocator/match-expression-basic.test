    x64.mov r8d, 20
    x64.jmp eval_0.merge
  eval_0.case2:
    x64.xor r8d, r8d
    x64.jmp eval_0.merge
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_ae6ffb269236c4fe]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:

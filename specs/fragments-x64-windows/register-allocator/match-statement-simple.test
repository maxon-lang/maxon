// Test: match-statement-simple
function main() returns ExitCode
	let x = 2
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 2
  check_0.next0:
    x64.cmp r8, 2
    x64.jne check_0.case2
  check_0.case1:
    x64.mov r8d, 20
    x64.ret
  check_0.case2:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

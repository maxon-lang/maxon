// Test: error.enum-eq-method
typealias Integer = int(i64.min to i64.max)

union Container
	empty
	value(n Integer)

	function isEmpty() returns bool
		if self == Container.empty 'check'
			return true
		end 'check'
		return false
	end 'isEmpty'
end 'Container'

function main() returns ExitCode
	let c = Container.empty
	if c.isEmpty() 'test'
		return 1
	end 'test'
	return 0
end 'main'

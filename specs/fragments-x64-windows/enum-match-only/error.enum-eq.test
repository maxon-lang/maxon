// Test: error.enum-eq
typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let c = Container.empty
	if c == Container.empty 'check'
		return 1
	end 'check'
	return 0
end 'main'

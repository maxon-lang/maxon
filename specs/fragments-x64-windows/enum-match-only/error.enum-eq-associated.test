// Test: error.enum-eq-associated

typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let a = Container.empty
	let b = Container.empty
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---

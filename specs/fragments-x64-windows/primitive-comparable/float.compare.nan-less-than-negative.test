// Test: float.compare.nan-less-than-negative
function main() returns ExitCode
	let nan = 0.0 / 0.0
	let x = -999999.0
	let result = nan.compare(x)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0]
    x64.movsd xmm1, [rip+__float_0]
    x64.movsd xmm2, xmm0
    x64.divsd xmm2, xmm1
    x64.movsd xmm3, [rip+__float_-999999]
    x64.movsd xmm0, xmm2
    x64.movsd xmm1, xmm3
    x64.call stdlib.float.compare
    x64.mov [rbp-8], rax
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp1
  check_0.case0:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp2
  check_0.case1:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp2:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0.case2:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

// Test: float.compare.greater
function main() returns ExitCode
	var a = 3.14
	var b = 2.71
	var result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 1
		greaterThan then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.14]
    x64.movsd xmm1, [rip+__float_2.71]
    x64.call stdlib.float.compare
    x64.mov [rbp-8], rax
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp1
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp2
  check_0.case1:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp2:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0.case2:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

// Batch: primitive-comparable
// Tests: int.compare.less, int.compare.equal, int.compare.greater, bool.compare.false-true, bool.compare.equal, float.compare.less, float.compare.greater, float.compare.nan-less-than-normal, float.compare.normal-greater-than-nan, float.compare.nan-nan-equal, float.compare.nan-less-than-negative, float.compare.positive-negative-zero, byte.compare.less
---
// Test: int.compare.less
function main() returns ExitCode
	let a = 10
	let b = 20
	let result = a.compare(b)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: int.compare.equal
function main() returns ExitCode
	let a = 42
	let b = 42
	let result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 0
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: int.compare.greater
function main() returns ExitCode
	let a = 20
	let b = 10
	let result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 1
		greaterThan then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: bool.compare.false-true
function main() returns ExitCode
	let a = false
	let b = true
	let result = a.compare(b)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: bool.compare.equal
function main() returns ExitCode
	let a = true
	let b = true
	let result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 0
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.less
function main() returns ExitCode
	let a = 1.5
	let b = 2.5
	let result = a.compare(b)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.greater
function main() returns ExitCode
	let a = 3.14
	let b = 2.71
	let result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 1
		greaterThan then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.nan-less-than-normal
function main() returns ExitCode
	let nan = 0.0 / 0.0
	let x = 42.0
	let result = nan.compare(x)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.normal-greater-than-nan
function main() returns ExitCode
	let nan = 0.0 / 0.0
	let x = 42.0
	let result = x.compare(nan)
	match result 'check'
		lessThan then return 1
		equalTo then return 1
		greaterThan then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.nan-nan-equal
function main() returns ExitCode
	let a = 0.0 / 0.0
	let b = 0.0 / 0.0
	let result = a.compare(b)
	match result 'check'
		lessThan then return 1
		equalTo then return 0
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.nan-less-than-negative
function main() returns ExitCode
	let nan = 0.0 / 0.0
	let x = -999999.0
	let result = nan.compare(x)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: float.compare.positive-negative-zero
function main() returns ExitCode
	let pos = 0.0
	let neg = -0.0
	let result = pos.compare(neg)
	match result 'check'
		lessThan then return 1
		equalTo then return 0
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: byte.compare.less

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let a = 10 as Byte
	let b = 20 as Byte
	let result = a.compare(b)
	match result 'check'
		lessThan then return 0
		equalTo then return 1
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---

// Test: float.compare.positive-negative-zero
function main() returns ExitCode
	let pos = 0.0
	let neg = -0.0
	let result = pos.compare(neg)
	match result 'check'
		lessThan then return 1
		equalTo then return 0
		greaterThan then return 1
	end 'check'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0]
    x64.movsd xmm1, [rip+__float_0]
    x64.subsd xmm1, xmm0
    x64.movsd xmm0, [rip+__float_0]
    x64.call float.compare
    x64.mov r9, r8
    x64.test r9, r9
    x64.jne check_0.next0
  check_0.case0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.next0:
    x64.cmp r9, 1
    x64.jne check_0.next1
  check_0.case1:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.next1:
    x64.cmp r9, 2
    x64.jne check_0.next2
  check_0.case2:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.next2:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

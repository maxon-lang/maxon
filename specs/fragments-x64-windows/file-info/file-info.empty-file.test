// Test: file-info.empty-file
function main() returns ExitCode
	let path = FilePath from "test_fi_empty.txt"
	try File.writeText(path, content: "") otherwise 'w'
		return 1
	end 'w'
	let fi = try File.info(path) otherwise 'e'
		try File.delete(path) otherwise 'de'
		end 'de'
		return 2
	end 'e'
	try File.delete(path) otherwise 'de2'
	end 'de2'
	if fi.size != 0 'check'
		print("wrong size: {fi.size}")
		return 3
	end 'check'
	print("empty size=0")
	return 0
end 'main'

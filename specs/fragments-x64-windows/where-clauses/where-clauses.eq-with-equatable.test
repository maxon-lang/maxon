// Test: where-clauses.eq-with-equatable
type Box uses T where T is Equatable
		var item T

		static function create(item T) returns Self
			return Self{item: item}
		end 'create'

		export function eq(other T) returns bool
				return item == other
		end 'eq'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
		let b = IntBox.create(42)
		if b.eq(42) 'yes'
				return 1
		end 'yes'
		return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov rcx, [r8+0] (8b)
    x64.mov edx, 42
    x64.lea r8, [rip+__witness_int_Equatable]
    x64.mov r10, [r8+24] (8b)
    x64.call r10
    x64.test r8, r8
    x64.je yes_0.after
  yes_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  yes_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

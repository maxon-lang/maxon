// Test: parsable.type-implements-parsable

typealias Integer = int(i64.min to i64.max)

// Type can implement Parsable with throwing static method
enum ParseError implements Error
	Invalid = 1
end 'ParseError'

type Value implements Parsable
	var n Integer

	static function fromString(input String) returns Self throws ParseError
		return Value{n: input.byteLength()}
	end 'fromString'
end 'Value'

function main() returns ExitCode
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @Value.fromString(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call String.byteLength
    x64.mov [r13+0], r8 (8b)
    x64.xor edx, edx
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

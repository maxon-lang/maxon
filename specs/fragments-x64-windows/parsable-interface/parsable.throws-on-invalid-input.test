    x64.call mrt_alloc
    x64.mov r12, r8
    x64.lea r8, [rip+__istr_0]
    x64.mov [r12+0], r8 (8b)
    x64.xor r8d, r8d
    x64.mov [r12+8], r8 (8b)
    x64.mov r8, -2
    x64.mov [r12+16], r8 (8b)
    x64.mov r8d, 1
    x64.mov [r12+24], r8 (8b)
    x64.xor r8d, r8d
    x64.mov [r12+32], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.mov r9d, 1
    x64.mov [r8+8], r9 (8b)
    x64.mov rcx, r8
    x64.call Value.fromString
    x64.mov r9, r8
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 42

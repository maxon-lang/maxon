    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call String.byteLength
    x64.mov [r13+0], r8 (8b)
    x64.xor edx, edx
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {

// Batch: string-trim
// Tests: trim-whitespace-both, trim-whitespace-start, trim-whitespace-end, trim-tabs-and-newlines, trim-all-whitespace, trim-no-whitespace, trim-empty-string, trim-mixed-whitespace, trim-internal-preserved, trim-charset-whitespace, trim-charset-digits, trim-charset-letters, trim-charset-digits-start, trim-charset-digits-end, trim-charset-no-match, trim-charset-all-match, trim-charset-empty, trim-charset-punctuation, trim-end-emoji, trim-end-only-multibyte, trim-end-combining-mark, trim-both-multibyte
---
// Test: trim-whitespace-both
function main() returns ExitCode
	let s = "  hello  "
	let ws = CharacterSet.whitespacesAndNewlines()
	let result = s.trim(ws)
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[hello]
```
---
// Test: trim-whitespace-start
function main() returns ExitCode
	let s = "  hello  "
	let result = s.trimStart()
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[hello  ]
```
---
// Test: trim-whitespace-end
function main() returns ExitCode
	let s = "  hello  "
	let result = s.trimEnd()
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[  hello]
```
---
// Test: trim-tabs-and-newlines
function main() returns ExitCode
	let s = "\t\nhello\r\n"
	let result = s.trim()
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[hello]
```
---
// Test: trim-all-whitespace
function main() returns ExitCode
	let s = "   "
	let result = s.trim()
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[]
```
---
// Test: trim-no-whitespace
function main() returns ExitCode
	let s = "hello"
	let result = s.trim()
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[hello]
```
---
// Test: trim-empty-string

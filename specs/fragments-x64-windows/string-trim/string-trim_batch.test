// Test: trim-charset-whitespace
function main() returns ExitCode
	let s = "  hello  "
	let result = s.trim(CharacterSet.whitespacesAndNewlines())
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```

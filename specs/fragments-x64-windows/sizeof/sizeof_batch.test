// Batch: sizeof
// Tests: sizeof.int, sizeof.float, sizeof.bool, sizeof.byte, sizeof.struct, sizeof.struct-three-fields, sizeof.enum, sizeof.arithmetic, sizeof.let-binding, sizeof.type-parameter, sizeof.type-parameter-struct
---
// Test: sizeof.int
function main() returns ExitCode
	return sizeof(int)
end 'main'
---

// Test: sizeof.struct
typealias Integer = int(i64.min to i64.max)

type Point
	export var x as Integer
	export var y as Integer
end 'Point'

function main() returns ExitCode
	return sizeof(Point)
end 'main'
---
ExitCode: 16
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 16
    x64.ret
  }
}
---

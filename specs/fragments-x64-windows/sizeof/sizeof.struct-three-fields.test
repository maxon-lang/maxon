// Test: sizeof.struct-three-fields
typealias Integer = int(i64.min to i64.max)

type Vec3
	export var x as Integer
	export var y as Integer
	export var z as Integer
end 'Vec3'

function main() returns ExitCode
	return sizeof(Vec3)
end 'main'
---
ExitCode: 24
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 24
    x64.ret
  }
}
---

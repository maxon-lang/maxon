// Test: sha256.64-zero-bytes
function main() returns ExitCode
	var data = ByteArray.create()
	var i = 0
	while i < 64 'fill'
		data.push(0)
		i = i + 1
	end 'fill'
	let hash = sha256(data)
	// SHA-256(64 * 0x00) = f5a5fd42...
	// first byte = 0xf5 = 245, last byte = 0x4b = 75
	let first = try hash.get(0) otherwise 0
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'

// Test: sha256.abc
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0x61)
	data.push(0x62)
	data.push(0x63)
	let hash = sha256(data)
	// SHA-256("abc") = ba7816bf 8f01cfea 414140de 5dae2223
	//                  b00361a3 96177a9c b410ff61 f20015ad
	var i = 0
	while i < 32 'print'
		let b = try hash.get(i) otherwise 0
		if i > 0 'space'
			print(" ")
		end 'space'
		print("{b}")
		i = i + 1
	end 'print'
	print("\n")
	return 0
end 'main'

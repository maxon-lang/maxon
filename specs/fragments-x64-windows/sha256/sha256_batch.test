// Batch: sha256
// Tests: sha256.empty, sha256.empty-last-byte, sha256.empty-length, sha256.single-zero-byte, sha256.single-byte-bd, sha256.abc, sha256.55-zero-bytes, sha256.56-zero-bytes, sha256.64-zero-bytes, sha256.nist-two-block, docs-example-1
---
// Test: sha256.empty
function main() returns ExitCode
	let hash = sha256(ByteArray.create())
	// SHA-256("") = e3b0c442...
	// first byte = 0xe3 = 227
	let b0 = try hash.get(0) otherwise 0
	print("{b0}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
227
```
---
// Test: sha256.empty-last-byte
function main() returns ExitCode
	let hash = sha256(ByteArray.create())
	// last byte = 0x55 = 85
	let b31 = try hash.get(31) otherwise 0
	print("{b31}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
85
```
---
// Test: sha256.empty-length
function main() returns ExitCode
	let hash = sha256(ByteArray.create())
	return hash.count()
end 'main'
---
ExitCode: 32
---
// Test: sha256.single-zero-byte
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0)
	let hash = sha256(data)
	// SHA-256(0x00) = 6e340b9c...
	// first byte = 0x6e = 110
	let b0 = try hash.get(0) otherwise 0
	print("{b0}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
110
```
---
// Test: sha256.single-byte-bd
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0xbd)
	let hash = sha256(data)
	// SHA-256(0xbd) = 68325720...
	// first byte = 0x68 = 104
	let b0 = try hash.get(0) otherwise 0
	print("{b0}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
104
```
---
// Test: sha256.abc
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0x61)
	data.push(0x62)
	data.push(0x63)
	let hash = sha256(data)
	// SHA-256("abc") = ba7816bf 8f01cfea 414140de 5dae2223
	//                  b00361a3 96177a9c b410ff61 f20015ad
	var i = 0
	while i < 32 'print'
		let b = try hash.get(i) otherwise 0
		if i > 0 'space'
			print(" ")
		end 'space'
		print("{b}")
		i = i + 1
	end 'print'
	print("\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
186 120 22 191 143 1 207 234 65 65 64 222 93 174 34 35 176 3 97 163 150 23 122 156 180 16 255 97 242 0 21 173
```
---
// Test: sha256.55-zero-bytes
function main() returns ExitCode
	var data = ByteArray.create()
	var i = 0
	while i < 55 'fill'
		data.push(0)
		i = i + 1
	end 'fill'
	let hash = sha256(data)
	// SHA-256(55 * 0x00) = 02779466...
	// first byte = 0x02 = 2, last byte = 0xf7 = 247
	let first = try hash.get(0) otherwise 255
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2 247
```
---
// Test: sha256.56-zero-bytes
function main() returns ExitCode
	var data = ByteArray.create()
	var i = 0
	while i < 56 'fill'
		data.push(0)
		i = i + 1
	end 'fill'
	let hash = sha256(data)
	// SHA-256(56 * 0x00) = d4817aa5...
	// first byte = 0xd4 = 212, last byte = 0xbb = 187
	let first = try hash.get(0) otherwise 0
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
212 187
```
---
// Test: sha256.64-zero-bytes
function main() returns ExitCode
	var data = ByteArray.create()
	var i = 0
	while i < 64 'fill'
		data.push(0)
		i = i + 1
	end 'fill'
	let hash = sha256(data)
	// SHA-256(64 * 0x00) = f5a5fd42...
	// first byte = 0xf5 = 245, last byte = 0x4b = 75
	let first = try hash.get(0) otherwise 0
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
245 75
```
---
// Test: sha256.nist-two-block
function main() returns ExitCode
	// "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq" (56 bytes)
	let msg = "abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq"
	let data = msg.toByteArray()
	let hash = sha256(data)
	// SHA-256 = 248d6a61 d20638b8 e5c02693 0c3e6039
	//           a33ce459 64ff2167 f6ecedd4 19db06c1
	let first = try hash.get(0) otherwise 0
	let last = try hash.get(31) otherwise 0
	print("{first} {last}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
36 193
```
---
// Test: docs-example-1
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0x61)
	data.push(0x62)
	data.push(0x63)
	let hash = sha256(data)
	// hash is the SHA-256 of "abc"
	// first byte is 0xba = 186
	let first = try hash.get(0) otherwise 0
	print("{first}\n")
	return 0
end 'main'

---
ExitCode: 0

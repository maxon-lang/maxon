end 'leaf'

function dispatch(kind Tally) returns Score
	match kind 'k'
		1 then return try leaf() otherwise 42
		default panic("unreachable")
	end 'k'
end 'dispatch'

function main() returns ExitCode
	return dispatch(1)
end 'main'

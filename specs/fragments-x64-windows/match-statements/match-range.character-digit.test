// Test: match-range.character-digit
function main() returns ExitCode
	let c = '7'
	match c 'classify'
		'a' to 'z' then return 1
		'A' to 'Z' then return 2
		'0' to '9' then return 3
		default then return 0
	end 'classify'
end 'main'

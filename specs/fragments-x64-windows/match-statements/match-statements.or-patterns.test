// Test: match-statements.or-patterns
function main() returns ExitCode
	let x = 3
	match x 'check'
		1 or 2 then return 10
		3 or 4 or 5 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @match-statements.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 3
    x64.mov [rbp-8], rax
    x64.jmp match-statements.main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.mov rdx, [rbp-8]
    x64.mov rbx, 2
    x64.cmp rdx, rbx
    x64.je match-statements.main.check_0.case0
    x64.cmp rax, rcx
    x64.je match-statements.main.check_0.case0
    x64.jmp match-statements.main.check_0.cmp1
  check_0.case0:
    x64.mov rax, 10
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 3
    x64.cmp rax, rcx
    x64.sete rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 4
    x64.cmp rbx, rsi
    x64.sete rdi
    x64.movzx rdi, rdib
    x64.or rdx, rdi
    x64.mov r8, [rbp-8]
    x64.mov r9, 5
    x64.cmp r8, r9
    x64.sete rax
    x64.movzx rax, raxb
    x64.or rdx, rax
    x64.test rdx, rdx
    x64.je match-statements.main.check_0.case2
  check_0.case1:
    x64.mov rax, 20
    x64.epilogue
    x64.ret
  check_0.case2:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

// Test: match-range.multiple-ranges
function main() returns ExitCode
	let score = 85
	match score 'grade'
		90 to 100 then return 65
		80 upto 90 then return 66
		70 upto 80 then return 67
		default then return 70
	end 'grade'
end 'main'
---
ExitCode: 66
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 85
    x64.mov [rbp-8], rax
    x64.jmp main.grade_0.cmp0
  grade_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 90
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 100
    x64.cmp rbx, rsi
    x64.setle rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.grade_0.cmp1
  grade_0.case0:
    x64.mov rax, 65
    x64.epilogue
    x64.ret
  grade_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 80
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 90
    x64.cmp rbx, rsi
    x64.setl rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.grade_0.cmp2
  grade_0.case1:
    x64.mov rax, 66
    x64.epilogue
    x64.ret
  grade_0.cmp2:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 70
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 80
    x64.cmp rbx, rsi
    x64.setl rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.grade_0.case3
  grade_0.case2:
    x64.mov rax, 67
    x64.epilogue
    x64.ret
  grade_0.case3:
    x64.mov rax, 70
    x64.epilogue
    x64.ret
  grade_0.merge:
  }
}
---

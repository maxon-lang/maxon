// Test: docs-example-10
function main() returns ExitCode
	let temp = 25
	let category = match temp 'weather'
		min upto 0 gives 1      // freezing
		0 upto 15 gives 2    // cold
		15 upto 25 gives 3   // mild
		25 to max gives 4      // warm
		default gives 0
	end 'weather'
	return category
end 'main'


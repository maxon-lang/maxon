// Test: match-break.inside-loop
function main() returns ExitCode
	var result = 0
	var i = 0
	while i < 5 'loop'
		match i 'check'
			3 then break 'loop'
			default then result = result + 1
		end 'check'
		i = i + 1
	end 'loop'
	return result
end 'main'

// Test: match-statements.try-propagate
typealias Tally = int(0 to 100)

enum Err implements Error
	bad
end 'Err'

function leaf() throws Err
	throw Err.bad
end 'leaf'

function dispatch(kind Tally) throws Err
	match kind 'k'
		1 then try leaf()
		default throws Err.bad
	end 'k'
end 'dispatch'

function main() returns ExitCode
	try dispatch(1) otherwise ignore
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @leaf() {
  entry:
    x64.xor eax, eax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.ret
  }
  func @dispatch(kind: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.jmp dispatch.k_0.cmp0
  k_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne dispatch.k_0.case1
  k_0.case0:
    x64.call leaf
    x64.mov [rbp-16], rdx
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je dispatch.try_continue_0
  propagate_error_0:
    x64.mov rdx, [rbp-16]
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  try_continue_0:
    x64.jmp dispatch.k_0.merge
  k_0.case1:
    x64.xor eax, eax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  k_0.merge:
    x64.xor edx, edx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.call dispatch
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

// Test: match-range.float
function main() returns ExitCode
	let x = 2.5
	match x 'check'
		0.0 to 5.0 then return 1
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_2.5]
    x64.movsd [rbp-8], xmm0
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.movsd xmm0, [rbp-8]
    x64.movsd xmm1, [rip+__float_0]
    x64.ucomisd xmm0, xmm1
    x64.setae rax
    x64.movzx rax, raxb
    x64.movsd xmm2, [rbp-8]
    x64.movsd xmm3, [rip+__float_5]
    x64.ucomisd xmm2, xmm3
    x64.setbe rcx
    x64.movzx rcx, rcxb
    x64.and rax, rcx
    x64.test rax, rax
    x64.je main.check_0.case1
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.case1:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

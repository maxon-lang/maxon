// Test: match-range.expression
function main() returns ExitCode
	let temp = 22
	let category = match temp 'weather'
		min upto 0 gives 1
		0 upto 15 gives 2
		15 upto 25 gives 3
		25 to max gives 4
		default gives 0
	end 'weather'
	return category
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 22
    x64.mov [rbp-8], rax
    x64.jmp main.weather_0.cmp0
  weather_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jge main.weather_0.cmp1
  weather_0.case0:
    x64.mov rax, 1
    x64.mov [rbp-16], rax
    x64.jmp main.weather_0.merge
  weather_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 15
    x64.cmp rbx, rsi
    x64.setl rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.weather_0.cmp2
  weather_0.case1:
    x64.mov rax, 2
    x64.mov [rbp-16], rax
    x64.jmp main.weather_0.merge
  weather_0.cmp2:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 15
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 25
    x64.cmp rbx, rsi
    x64.setl rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.weather_0.cmp3
  weather_0.case2:
    x64.mov rax, 3
    x64.mov [rbp-16], rax
    x64.jmp main.weather_0.merge
  weather_0.cmp3:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 25
    x64.cmp rax, rcx
    x64.jl main.weather_0.case4
  weather_0.case3:
    x64.mov rax, 4
    x64.mov [rbp-16], rax
    x64.jmp main.weather_0.merge
  weather_0.case4:
    x64.xor rax, rax
    x64.mov [rbp-16], rax
    x64.jmp main.weather_0.merge
  weather_0.merge:
    x64.mov rax, [rbp-16]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

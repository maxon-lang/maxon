    x64.jmp match-statements.classify.check_0.merge
  check_0.case2:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  check_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov rdx, 100
    x64.cmp rax, rdx
    x64.jg match-statements.classify.__range_panic_0
    x64.cmp rax, rcx
    x64.jl match-statements.classify.__range_panic_0
    x64.jmp match-statements.classify.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret

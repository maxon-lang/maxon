// Test: match-break.labeled
function main() returns ExitCode
	var result = 0
	match 3 'outer'
		1 then result = 10
		2 then result = 20
		3 then break 'outer'
		default then result = 99
	end 'outer'
	return result
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.mov rcx, 3
    x64.mov [rbp-16], rcx
    x64.jmp main.outer_0.cmp0
  outer_0.cmp0:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.outer_0.cmp1
  outer_0.case0:
    x64.mov rax, 10
    x64.mov [rbp-8], rax
    x64.jmp main.outer_0.merge
  outer_0.cmp1:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.outer_0.cmp2
  outer_0.case1:
    x64.mov rax, 20
    x64.mov [rbp-8], rax
    x64.jmp main.outer_0.merge
  outer_0.cmp2:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 3
    x64.cmp rax, rcx
    x64.jne main.outer_0.case3
  outer_0.case2:
    x64.jmp main.outer_0.merge
  outer_0.case3:
    x64.mov rax, 99
    x64.mov [rbp-8], rax
    x64.jmp main.outer_0.merge
  outer_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

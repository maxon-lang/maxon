// Batch: grapheme-clusters
// Tests: grapheme-boundary-ascii, grapheme-boundary-multibyte, grapheme-boundary-emoji, grapheme-boundary-flag, grapheme-boundary-multiple-flags, grapheme-boundary-skin-tone, grapheme-boundary-zwj-family, grapheme-boundary-zwj-profession, grapheme-boundary-crlf, grapheme-boundary-mixed, grapheme-break-property-ascii, grapheme-break-property-cr, grapheme-break-property-lf, grapheme-break-property-zwj, grapheme-break-property-regional, is-extended-pictographic, grapheme-boundary-combining-accent, grapheme-boundary-multiple-combiners, grapheme-boundary-combining-iteration, grapheme-boundary-odd-ri, grapheme-boundary-four-ri
---
// Test: grapheme-boundary-ascii
function main() returns ExitCode
	let s = "abc"
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```
---
// Test: grapheme-boundary-multibyte
function main() returns ExitCode
	let s = "中文"  // 2 CJK characters
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
```
---
// Test: grapheme-boundary-emoji
function main() returns ExitCode
	let s = "🎉🎊🎁"  // 3 emoji
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```
---
// Test: grapheme-boundary-flag
function main() returns ExitCode
	let s = "🇺🇸"  // US flag (2 regional indicators = 1 grapheme)
	print("{s.count()}\n")
	print("{s.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
8
```
---
// Test: grapheme-boundary-multiple-flags
function main() returns ExitCode
	let s = "🇺🇸🇬🇧🇫🇷"  // 3 flags
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```
---
// Test: grapheme-boundary-skin-tone
function main() returns ExitCode
	let s = "👋🏽"  // Wave + medium skin tone
	print("{s.count()}\n")
	print("{s.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
8
```
---
// Test: grapheme-boundary-zwj-family
function main() returns ExitCode
	let s = "👨‍👩‍👧"  // Man + ZWJ + Woman + ZWJ + Girl
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---
// Test: grapheme-boundary-zwj-profession
function main() returns ExitCode
	let s = "👨‍💻"  // Man + ZWJ + Computer = Man Technologist
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---
// Test: grapheme-boundary-crlf
function main() returns ExitCode
	let s = "\r\n"
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---
// Test: grapheme-boundary-mixed
function main() returns ExitCode
	let s = "Hi🎉中"  // H, i, party, 中 = 4 graphemes
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
4
```
---
// Test: grapheme-break-property-ascii
function main() returns ExitCode
	let prop = graphemeBreakProperty(65)  // 'A'
	print("{prop}\n")  // GBP_Other = 0
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
0
```
---
// Test: grapheme-break-property-cr
function main() returns ExitCode
	let prop = graphemeBreakProperty(13)  // CR
	print("{prop}\n")  // GBP_CR = 1
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---
// Test: grapheme-break-property-lf
function main() returns ExitCode
	let prop = graphemeBreakProperty(10)  // LF
	print("{prop}\n")  // GBP_LF = 2
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
```
---
// Test: grapheme-break-property-zwj
function main() returns ExitCode
	let prop = graphemeBreakProperty(8205)  // ZWJ U+200D
	print("{prop}\n")  // GBP_ZWJ = 5
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
5
```
---
// Test: grapheme-break-property-regional
function main() returns ExitCode
	let prop = graphemeBreakProperty(127482)  // Regional Indicator U
	print("{prop}\n")  // GBP_Regional_Indicator = 6
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
6
```
---
// Test: is-extended-pictographic
function main() returns ExitCode
	if isExtendedPictographic(128512) 'c1'
		print("{1}\n")  // 😀
	end 'c1'
	if isExtendedPictographic(65) 'c2'
		print("{0}\n")      // 'A'
	end 'c2'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---
// Test: grapheme-boundary-combining-accent
function main() returns ExitCode
	let s = "e\u0301"  // e + combining acute = é (1 grapheme, 3 bytes)
	print("{s.count()}\n")
	print("{s.byteLength()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
3
```
---
// Test: grapheme-boundary-multiple-combiners
function main() returns ExitCode
	let s = "a\u0308\u0301"  // a + diaeresis + acute = 1 grapheme
	print("{s.count()}\n")
	print("{s.byteLength()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
5
```
---
// Test: grapheme-boundary-combining-iteration
function main() returns ExitCode
	let s = "caf\u0065\u0301"  // c, a, f, e+combining accent = 4 graphemes
	var count = 0
	for _ in s 'loop'
		count = count + 1
	end 'loop'
	print("{count}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
4
```
---
// Test: grapheme-boundary-odd-ri
function main() returns ExitCode
	let s = "🇺🇸🇬"  // US flag (2 RIs) + standalone G (1 RI) = 2 graphemes
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
```
---
// Test: grapheme-boundary-four-ri
function main() returns ExitCode
	let s = "🇺🇸🇬🇧"  // US flag + GB flag = 2 graphemes
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
```
---

// Test: args-length-no-extra
function main() returns ExitCode
	// Without extra args, count should be 1 (just argv[0])
	let args = CommandLine.args()
	return args.count()
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call CommandLine.args
    x64.lea rdx, [rip+__layout_Array_SlotState]
    x64.mov rcx, r8
    x64.call Array.count
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

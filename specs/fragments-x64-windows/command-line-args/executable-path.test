// Test: executable-path
function main() returns ExitCode
	let exe = try Process.executablePath() otherwise return 2
	// Just verify it returns something (the actual path varies)
	if exe.path.byteLength() > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call mrt_executable_path
    x64.mov r12, r8
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call String.init
    x64.mov [r13+0], r8 (8b)
  try_0.merge:
    x64.mov rcx, [r13+0] (8b)
    x64.call String.byteLength
    x64.test r8, r8
    x64.jle check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

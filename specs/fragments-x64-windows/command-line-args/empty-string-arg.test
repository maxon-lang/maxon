// Test: empty-string-arg
function main() returns ExitCode
	let args = CommandLine.args()
	// Empty quoted arg is at index 1 (index 0 is argv[0])
	let arg = try args.get(1) otherwise "x"
	if arg == "" 'check'
		return 0
	end 'check'
	return 1
end 'main'

// Test: access-multiple-args
function main() returns ExitCode
	let args = CommandLine.args()
	let arg1 = try args.get(1) otherwise ""
	let arg2 = try args.get(2) otherwise ""
	let arg3 = try args.get(3) otherwise ""
	print(arg1)
	print("\n")
	print(arg2)
	print("\n")
	print(arg3)
	print("\n")
	return 0
end 'main'

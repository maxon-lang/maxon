// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
	var x Integer
	
	function bar() returns Integer
		return x
	end 'bar'
	
	function callBarOn(other Foo) returns Integer
		return other.bar()
	end 'callBarOn'

	static function create(x Integer) returns Self
		return Self{x: x}
	end 'create'
end 'Foo'

function main() returns ExitCode
	let f1 = Foo.create(x: 10)
	let f2 = Foo.create(x: 42)
	return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
module {
  func @Foo.bar(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @Foo.callBarOn(__self_ptr: i64, other: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rdx
    x64.mov rcx, [rbp-8]
    x64.epilogue
    x64.jmp Foo.bar
  }
  func @Foo.create(x: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 10
    x64.call Foo.create
    x64.mov [rbp-8], rax
    x64.mov rcx, 42
    x64.call Foo.create
    x64.mov [rbp-16], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.call Foo.callBarOn
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rcx, [rbp-16]
    x64.mov [rbp-24], rax
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Foo(ptr: i64) {
  entry:
    x64.jmp __destruct_Foo.done
  done:
    x64.ret
  }
}
---

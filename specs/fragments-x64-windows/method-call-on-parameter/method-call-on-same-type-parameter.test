// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
	var x Integer
	
	function bar() returns Integer
		return x
	end 'bar'
	
	function callBarOn(other Foo) returns Integer
		return other.bar()
	end 'callBarOn'

	static function create(x Integer) returns Self
		return Self{x: x}
	end 'create'
end 'Foo'

function main() returns ExitCode
	let f1 = Foo.create(x: 10)
	let f2 = Foo.create(x: 42)
	return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Foo.bar(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Foo.callBarOn(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, rdx
    x64.call Foo.bar
    x64.epilogue
    x64.ret
  }
  func @Foo.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @method-call-on-parameter.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 10
    x64.call Foo.create
    x64.mov r12, r8
    x64.mov ecx, 42
    x64.call Foo.create
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Foo.callBarOn
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

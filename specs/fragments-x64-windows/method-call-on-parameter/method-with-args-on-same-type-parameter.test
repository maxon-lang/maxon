// Test: method-with-args-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Adder
	var value Integer
	
	function addTo(n Integer) returns Integer
		return value + n
	end 'addTo'
	
	function delegateAdd(other Adder, n Integer) returns Integer
		return other.addTo(n)
	end 'delegateAdd'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Adder'

function main() returns ExitCode
	let a = Adder.create(value: 100)
	let b = Adder.create(value: 50)
	return a.delegateAdd(b, n: 7)
end 'main'
---
ExitCode: 57
---
// CompiledIR
module {
  func @Adder.addTo(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r8, rcx
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, r9
    x64.add r8, rdx
    x64.ret
  }
  func @Adder.delegateAdd(rcx: i64, rdx: i64, rax: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8, rdx
    x64.mov rcx, r8
    x64.mov rdx, rax
    x64.call Adder.addTo
    x64.epilogue
    x64.ret
  }
  func @Adder.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 100
    x64.call Adder.create
    x64.mov r12, r8
    x64.mov ecx, 50
    x64.call Adder.create
    x64.mov eax, 7
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Adder.delegateAdd
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

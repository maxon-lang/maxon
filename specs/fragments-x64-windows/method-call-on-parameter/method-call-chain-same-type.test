// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer
	
	function get() returns Integer
		return n
	end 'get'
	
	function add(other Value) returns Integer
		return n + other.get()
	end 'add'
	
	function multiply(other Value) returns Integer
		return n * other.get()
	end 'multiply'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let a = Value.create(n: 5)
	let b = Value.create(n: 3)
	let c = Value.create(n: 2)
	// a.add(b) = 5 + 3 = 8
	// a.multiply(c) = 5 * 2 = 10
	// total = 8 + 10 = 18
	return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 5
    x64.mov [r12+0], r8 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r13, r8
    x64.mov r8d, 3
    x64.mov [r13+0], r8 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 2
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, [r12+0] (8b)
    x64.mov rsi, [r13+0] (8b)
    x64.mov rdi, [r12+0] (8b)
    x64.imul r8, r9
    x64.add rdi, rsi
    x64.mov r9, rdi
    x64.add r9, r8
    x64.cmp r9, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer
	
	function get() returns Integer
		return n
	end 'get'
	
	function add(other Value) returns Integer
		return n + other.get()
	end 'add'
	
	function multiply(other Value) returns Integer
		return n * other.get()
	end 'multiply'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let a = Value.create(n: 5)
	let b = Value.create(n: 3)
	let c = Value.create(n: 2)
	// a.add(b) = 5 + 3 = 8
	// a.multiply(c) = 5 * 2 = 10
	// total = 8 + 10 = 18
	return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
// CompiledIR
module {
  func @Value.get(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Value.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r8, rcx
    x64.mov r12, [r8+0] (8b)
    x64.mov rcx, rdx
    x64.call Value.get
    x64.mov r9, r12
    x64.add r9, r8
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @Value.multiply(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r8, rcx
    x64.mov r12, [r8+0] (8b)
    x64.mov rcx, rdx
    x64.call Value.get
    x64.mov r9, r12
    x64.imul r9, r8
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @Value.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @method-call-on-parameter.main() -> u8 {
  entry:
    x64.prologue stack_size=48
    x64.mov ecx, 5
    x64.call Value.create
    x64.mov r12, r8
    x64.mov ecx, 3
    x64.call Value.create
    x64.mov r13, r8
    x64.mov ecx, 2
    x64.call Value.create
    x64.mov r14, r8
    x64.mov rcx, r12
    x64.mov rdx, r13
    x64.call Value.add
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.mov rdx, r14
    x64.call Value.multiply
    x64.mov r9, r13
    x64.add r9, r8
    x64.cmp r9, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_1]
    x64.call mrt_panic
  __range_ok_1:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

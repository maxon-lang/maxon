// Test: sibling-method-call-still-works

typealias Integer = int(i64.min to i64.max)

type Calculator
	var base Integer
	
	function double() returns Integer
		return base * 2
	end 'double'
	
	function quadruple() returns Integer
		// Sibling call - calls self.double()
		return double() * 2
	end 'quadruple'

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	var calc = Calculator.create(base: 5)
	return calc.quadruple()
end 'main'
---
ExitCode: 20
---
module {
  func @Calculator.double(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, 2
    x64.imul rdx, rax
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @Calculator.quadruple(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call Calculator.double
    x64.mov rcx, 2
    x64.imul rax, rcx
    x64.epilogue
    x64.ret
  }
  func @Calculator.create(base: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call Calculator.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call Calculator.quadruple
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rbx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Calculator(ptr: i64) {
  entry:
    x64.jmp __destruct_Calculator.done
  done:
    x64.ret
  }
}
---

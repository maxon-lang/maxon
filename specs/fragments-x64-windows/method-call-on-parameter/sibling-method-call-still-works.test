    x64.mov [r12+0], r8 (8b)
    x64.mov r8, [r12+0] (8b)
    x64.mov r9d, 2
    x64.mov r13, r8
    x64.imul r13, r9
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r9d, 2
    x64.mov r8, r13

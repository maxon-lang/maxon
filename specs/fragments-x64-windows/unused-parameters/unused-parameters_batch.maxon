// --- batched test: all-used-ok ---

typealias _b_all_used_ok_Integer = int(i64.min to i64.max)

function _b_all_used_ok_add(a _b_all_used_ok_Integer, b _b_all_used_ok_Integer) returns _b_all_used_ok_Integer
	return a + b
end '_b_all_used_ok_add'

function _b_all_used_ok_main() returns ExitCode
	return _b_all_used_ok_add(5, b: 10)
end '_b_all_used_ok_main'

// --- batched test: none-unused ---

typealias _b_none_unused_Integer = int(i64.min to i64.max)

function _b_none_unused_multiply(a _b_none_unused_Integer, b _b_none_unused_Integer) returns _b_none_unused_Integer
	return a * b
end '_b_none_unused_multiply'

function _b_none_unused_main() returns ExitCode
	return _b_none_unused_multiply(7, b: 6)
end '_b_none_unused_main'

// --- batch dispatcher for unused-parameters ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:all-used-ok>>>\n")
	let ec_all_used_ok = _b_all_used_ok_main()
	print("\n<<<MAXON_BATCH_TEST_END:all-used-ok:{ec_all_used_ok}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:none-unused>>>\n")
	let ec_none_unused = _b_none_unused_main()
	print("\n<<<MAXON_BATCH_TEST_END:none-unused:{ec_none_unused}>>>\n")
	return 0 as ExitCode
end 'main'

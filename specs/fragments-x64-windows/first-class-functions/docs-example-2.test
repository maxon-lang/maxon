// Test: docs-example-2
typealias Score = int(i64.min to i64.max)

function apply(f (Score) returns Score, x Score) returns Score
	return f(x)
end 'apply'

function triple(n Score) returns Score
	return n * 3
end 'triple'

function main() returns ExitCode
	return apply(triple, x: 10)  // returns 30
end 'main'

---
ExitCode: 30
---
module {
  func @first-class-functions.apply(f: i64, __env_f: i64, x: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov r10, rcx
    x64.mov rcx, r8
    x64.call r10
    x64.epilogue
    x64.ret
  }
  func @first-class-functions.triple(n: i64) -> i64 {
  entry:
    x64.mov rax, 3
    x64.imul rcx, rax
    x64.mov rax, rcx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea_func rax, [first-class-functions.triple]
    x64.mov rcx, rax
    x64.xor rdx, rdx
    x64.mov r8, 10
    x64.call first-class-functions.apply
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.mov ecx, 10
    x64.lea r13, [rip+__fnref_triple]
    x64.call r13
    x64.mov r9d, 4294967295
    x64.mov rsi, r12
    x64.add rsi, r8
    x64.cmp rsi, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_209646cbbde29440]

// Batch: character-type
// Tests: basic-character, character-comparison, character-in-variable, multibyte-character-2byte, multibyte-character-3byte, multibyte-character-4byte, character-to-string, multibyte-character-to-string, character-equality-multibyte, character-inequality-multibyte, emoji-character, flag-emoji-character, family-emoji-character, skin-tone-emoji, escape-sequences, ascii-value-letter, ascii-value-digit, ascii-value-lowercase, ascii-value-space, ascii-value-newline, ascii-value-non-ascii, ascii-value-emoji, match-escape-character
---
// Test: basic-character
function main() returns ExitCode
	let x = 'A'
	if x == 'A' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: character-comparison
function main() returns ExitCode
	let a = 'A'
	let b = 'B'
	if a < b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: character-in-variable
function main() returns ExitCode
	let letter = 'Z'
	if letter == 'Z' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: multibyte-character-2byte
function main() returns ExitCode
	let c = 'é'
	print("{c.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
```
---
// Test: multibyte-character-3byte
function main() returns ExitCode
	let c = '中'
	print("{c.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```
---
// Test: multibyte-character-4byte
function main() returns ExitCode
	let c = '🎉'
	print("{c.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
4
```
---
// Test: character-to-string
function main() returns ExitCode
	let c = 'A'
	let s = "{c}"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
A
```
---
// Test: multibyte-character-to-string
function main() returns ExitCode
	let c = '中'
	let s = "{c}"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
中
```
---
// Test: character-equality-multibyte
function main() returns ExitCode
	let a = 'é'
	let b = 'é'
	if a == b 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: character-inequality-multibyte
function main() returns ExitCode
	let a = 'é'
	let b = 'è'
	if a != b 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: emoji-character
function main() returns ExitCode
	let emoji = '🎉'
	print("{emoji}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
🎉
```
---
// Test: flag-emoji-character
function main() returns ExitCode
	let flag = '🇺🇸'
	print("{flag.bytes().count()}\n")
	print("{flag}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
8
🇺🇸
```
---
// Test: family-emoji-character
function main() returns ExitCode
	let family = '👨‍👩‍👧'
	print("{family.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
18
```
---
// Test: skin-tone-emoji
function main() returns ExitCode
	let wave = '👋🏽'
	print("{wave.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
8
```
---
// Test: escape-sequences
function main() returns ExitCode
	let newline = '\n'
	let tab = '\t'
	let backslash = '\\'
	let quote = '\''
	print("{newline.bytes().count()}\n")
	print("{tab.bytes().count()}\n")
	print("{backslash.bytes().count()}\n")
	print("{quote.bytes().count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
1
1
1
```
---
// Test: ascii-value-letter
function main() returns ExitCode
	let c = 'A'
	let val = try c.asciiValue() otherwise 0
	print("{val}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
65
```
---

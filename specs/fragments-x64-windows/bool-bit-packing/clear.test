// Test: clear
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	arr.push(true)
	arr.push(false)
	arr.clear()
	let c = arr.count()
	arr.push(true)
	let c2 = arr.count()
	return c * 10 + c2
end 'main'

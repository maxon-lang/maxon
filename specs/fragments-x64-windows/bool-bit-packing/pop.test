// Test: pop
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	arr.push(true)
	arr.push(false)
	arr.push(true)
	let popped = try arr.pop() otherwise false
	var sum = 0
	if popped 'p'
		sum = sum + 1
	end 'p'
	return sum * 10 + arr.count()
end 'main'

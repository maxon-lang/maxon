// Test: large-array
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	var i = 0
	while i < 100 'push'
		arr.push(i < 50)
		i = i + 1
	end 'push'
	var count = 0
	var j = 0
	while j < 100 'count'
		let v = try arr.get(j) otherwise false
		if v 'inc'
			count = count + 1
		end 'inc'
		j = j + 1
	end 'count'
	return count
end 'main'
---
ExitCode: 50

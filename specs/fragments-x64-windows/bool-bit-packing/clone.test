// Test: clone
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	arr.push(true)
	arr.push(false)
	var copy = arr.clone()
	copy.set(0, value: false)
	let orig = try arr.get(0) otherwise false
	let cloned = try copy.get(0) otherwise true
	var sum = 0
	if orig 'o'
		sum = sum + 1
	end 'o'
	if cloned 'c'
		sum = sum + 10
	end 'c'
	return sum
end 'main'

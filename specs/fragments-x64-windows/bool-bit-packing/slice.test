// Test: slice
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	arr.push(true)
	arr.push(false)
	arr.push(true)
	arr.push(false)
	arr.push(true)
	let sliced = arr.slice(1, endIndex: 4)
	var sum = 0
	let v0 = try sliced.get(0) otherwise true
	let v1 = try sliced.get(1) otherwise false
	let v2 = try sliced.get(2) otherwise true
	if v0 'c0'
		sum = sum + 10
	end 'c0'
	if v1 'c1'
		sum = sum + 1
	end 'c1'
	if v2 'c2'
		sum = sum + 10
	end 'c2'
	return sum
end 'main'

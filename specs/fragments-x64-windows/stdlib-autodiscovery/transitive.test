// Test: transitive
// pow -> log, exp
function main() returns ExitCode
	var result = Math.pow(2.0, exponent: 3.0)
	if result > 7.5 'check'
		return 8
	end 'check'
	return 0
end 'main'
---
ExitCode: 8
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_2]
    x64.movsd xmm1, [rip+__float_3]
    x64.call stdlib.Math.pow
    x64.movsd xmm2, [rip+__float_7.5]
    x64.ucomisd xmm0, xmm2
    x64.jbe main.check_0.after
  check_0:
    x64.mov rax, 8
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

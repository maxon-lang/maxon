// Test: transitive
// pow -> log, exp
function main() returns ExitCode
	let result = Math.pow(2.0, exponent: 3.0)
	if result > 7.5 'check'
		return 8
	end 'check'
	return 0
end 'main'
---
ExitCode: 8
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm1, [rip+__float_4613937818241073152]
    x64.movsd xmm0, [rip+__float_4611686018427387904]
    x64.call Math.pow
    x64.movsd xmm1, [rip+__float_4620130267728707584]
    x64.ucomisd xmm0, xmm1
    x64.jbe check_0.after
  check_0:
    x64.mov r8d, 8
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

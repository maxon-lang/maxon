    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  __lazy_init_2:
    x64.call Config.value.__lazy_init
    x64.jmp Config.getValue.__lazy_merge_2
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call Config.getValue
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rcx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @Config.value.__lazy_init() {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.mov byte [rip+Config.value.__initialized], rax
    x64.call Config.makeValue
    x64.mov [rbp-8], rax

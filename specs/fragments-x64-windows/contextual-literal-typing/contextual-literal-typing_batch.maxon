	if b == 42 'check'
		return 1
	end 'check'
	return 0
end '_b_int_literal_vs_byte_valid_main'

// --- batched test: explicit-cast-int-to-float ---

typealias _b_explicit_cast_int_to_float_Float = float(f64.min to f64.max)

function _b_explicit_cast_int_to_float_main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as _b_explicit_cast_int_to_float_Float) == y 'check'
		return 1
	end 'check'
	return 0
end '_b_explicit_cast_int_to_float_main'

// --- batched test: explicit-cast-float-to-int ---
function _b_explicit_cast_float_to_int_main() returns ExitCode
	let x = 5
	let y = 5.0
	if x == trunc(y) 'check'
		return 1
	end 'check'
	return 0
end '_b_explicit_cast_float_to_int_main'


module {
  func @main() -> u8 {
  entry:
    x64.movsd xmm0, [rip+__float_4617315517961601024]
    x64.cvttsd2si r8, xmm0
    x64.mov r9d, 5
    x64.cmp r9, r8
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}

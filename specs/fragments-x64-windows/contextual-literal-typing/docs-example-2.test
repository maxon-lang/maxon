// Test: docs-example-2
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
	let b = 200 as Pixel
	if b == 200 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

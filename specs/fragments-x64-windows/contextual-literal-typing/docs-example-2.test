// Test: docs-example-2
typealias Pixel = int(0 to u8.max)

function main() returns ExitCode
	let b = 200 as Pixel
	if b == 200 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 1
---
// CompiledIR
module {
  func @contextual-literal-typing.main() -> u32 {
  entry:
    x64.mov rax, 200
    x64.mov rcx, 200
    x64.cmp rax, rcx
    x64.jne contextual-literal-typing.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

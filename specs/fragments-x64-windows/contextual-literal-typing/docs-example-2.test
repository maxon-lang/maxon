// Test: docs-example-2
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
	let b = 200 as Pixel
	if b == 200 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 200
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rdx, 200
    x64.cmp rax, rdx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

// Test: int-literal-vs-byte-valid

typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	if b == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

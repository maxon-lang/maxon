// Test: int-literal-vs-byte-valid

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	if b == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 42
    x64.cmp r8, 42
    x64.jne check_1.after
  check_1:
    x64.mov r8d, 1
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

// Test: int-literal-vs-byte-valid

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	var b = 42 as Byte
	if b == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 42
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rdx, 42
    x64.cmp rax, rdx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

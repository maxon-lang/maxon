// Batch: contextual-literal-typing
// Tests: int-literal-vs-byte-valid, explicit-cast-int-to-float, explicit-cast-float-to-int, math-intrinsic-with-int, math-intrinsic-with-float-literal, byte-vs-byte, int-vs-int, float-vs-float, docs-example-1, docs-example-2, docs-example-3, docs-example-4
---
// Test: int-literal-vs-byte-valid

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	if b == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: explicit-cast-int-to-float

typealias Float = float(f64.min to f64.max)

function main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as Float) == y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: explicit-cast-float-to-int
function main() returns ExitCode
	let x = 5
	let y = 5.0
	if x == trunc(y) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: math-intrinsic-with-int
function main() returns ExitCode
	let x = 16
	let result = sqrt(x)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
// Test: math-intrinsic-with-float-literal
function main() returns ExitCode
	let x = sqrt(16.0)
	return trunc(x)
end 'main'
---
ExitCode: 4
---
// Test: byte-vs-byte

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let a = 50 as Byte
	let b = 50 as Byte
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: int-vs-int
function main() returns ExitCode
	let a = 1000
	let b = 1000
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: float-vs-float
function main() returns ExitCode
	let a = 3.14
	let b = 3.14
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: docs-example-1
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
	let b = 100 as Pixel
	if b == 50 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 0
---
// Test: docs-example-2
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
	let b = 200 as Pixel
	if b == 200 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 1
---
// Test: docs-example-3
typealias Decimal = float(f64.min to f64.max)

function main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as Decimal) == y 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 1
---
// Test: docs-example-4
function main() returns ExitCode
	let x = sqrt(16.0)
	return trunc(x)
end 'main'

---
ExitCode: 4
---

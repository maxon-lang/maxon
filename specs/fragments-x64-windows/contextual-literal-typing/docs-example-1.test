// Test: docs-example-1
typealias Pixel = byte(0 to u8.max)

function main() returns ExitCode
	let b = 100 as Pixel
	if b == 50 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 100
    x64.cmp r8, 50
    x64.jne check_1.after
  check_1:
    x64.mov r8d, 1
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

// Test: float-vs-float
function main() returns ExitCode
	let a = 3.14
	let b = 3.14
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_4614253070214989087]
    x64.movsd xmm1, [rip+__float_4614253070214989087]
    x64.ucomisd xmm1, xmm0
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

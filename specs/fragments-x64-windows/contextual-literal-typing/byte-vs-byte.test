// Test: byte-vs-byte

typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let a = 50 as Byte
	let b = 50 as Byte
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @contextual-literal-typing.main() -> u32 {
  entry:
    x64.mov rax, 50
    x64.mov rcx, 50
    x64.cmp rax, rcx
    x64.jne contextual-literal-typing.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

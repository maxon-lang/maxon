// Test: byte-vs-byte

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let a = 50 as Byte
	let b = 50 as Byte
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.ret
  }
}
---

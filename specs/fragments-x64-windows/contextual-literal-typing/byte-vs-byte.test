// Test: byte-vs-byte

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let a = 50 as Byte
	let b = 50 as Byte
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 50
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rdx, 50
    x64.mov rbx, 255
    x64.and rdx, rbx
    x64.cmp rax, rdx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

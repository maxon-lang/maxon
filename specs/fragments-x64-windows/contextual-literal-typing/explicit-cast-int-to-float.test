// Test: explicit-cast-int-to-float

typealias Float = float(f64.min to f64.max)

function main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as Float) == y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 5
    x64.cvtsi2sd xmm0, r8
    x64.movsd xmm1, [rip+__float_4617315517961601024]
    x64.ucomisd xmm0, xmm1
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

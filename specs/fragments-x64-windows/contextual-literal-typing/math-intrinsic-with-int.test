// Test: math-intrinsic-with-int
function main() returns ExitCode
	let x = 16
	let result = sqrt(x)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 16
    x64.cvtsi2sd xmm0, rax
    x64.sqrtsd xmm1, xmm0
    x64.cvttsd2si rcx, xmm1
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

// Test: math-intrinsic-with-int
function main() returns ExitCode
	let x = 16
	let result = sqrt(x)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 16
    x64.cvtsi2sd xmm0, r8
    x64.sqrtsd xmm1, xmm0
    x64.cvttsd2si r8, xmm1
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

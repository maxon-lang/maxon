// Test: docs-example-3
typealias Decimal = float(f64.min to f64.max)

function main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as Decimal) == y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 5
    x64.cvtsi2sd xmm0, r8
    x64.movsd xmm1, [rip+__float_4617315517961601024]
    x64.ucomisd xmm0, xmm1
    x64.jne check_1.after
  check_1:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.ret
  check_1.after:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}
---

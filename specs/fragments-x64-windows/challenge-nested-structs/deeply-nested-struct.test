// Test: deeply-nested-struct

typealias Integer = int(i64.min to i64.max)

type Level1
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Level1'

type Level2
	export var inner Level1

	static function create(inner Level1) returns Self
		return Self{inner: inner}
	end 'create'
end 'Level2'

type Level3
	export var inner Level2

	static function create(inner Level2) returns Self
		return Self{inner: inner}
	end 'create'
end 'Level3'

function main() returns ExitCode
	let l1 = Level1.create(42)
	let l2 = Level2.create(l1)
	let l3 = Level3.create(l2)
	return l3.inner.inner.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 42
    x64.mov [r12+0], r8 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r13, r8
    x64.mov [r13+0], r12 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r13 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov rsi, [r9+0] (8b)
    x64.mov r8, [rsi+0] (8b)
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @Outer.create(inner: i64, z: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.lea_func rax, [__destruct_Outer]
    x64.mov rbx, rax
    x64.mov [rbp-24], rdx
    x64.mov rdx, rbx
    x64.mov rcx, 16
    x64.mov r8, 2
    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.mov [rdx+0], rcx
    x64.call mm_incref
    x64.mov rbx, [rbp-16]
    x64.mov rsi, [rbp-24]
    x64.mov [rbx+8], rsi
    x64.mov rdi, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=48
    x64.mov rcx, 10
    x64.mov rdx, 20
    x64.call Inner.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 30
    x64.call Outer.create
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.mov rdx, [rcx+0]
    x64.mov [rbp-24], rdx
    x64.mov rbx, [rbp-24]
    x64.mov rsi, [rbx+0]
    x64.mov rdi, [rbp-16]

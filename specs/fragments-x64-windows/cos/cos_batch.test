// Batch: cos
// Tests: cos.basic, cos.zero, cos.with-int-promotion
---
// Test: cos.basic
function main() returns ExitCode
	let x1 = Math.cos(0.0)
	let x2 = Math.cos(0.5)
	let x3 = Math.cos(1.0)
	let x4 = Math.cos(1.5708)
	print("{x1}\n")
	print("{x2}\n")
	print("{x3}\n")
	print("{x4}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1.0
0.877583
0.540302
-0.000004
```
---
// Test: cos.zero
function main() returns ExitCode
	let result = Math.cos(0.0)
	if result == 1.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: cos.with-int-promotion
function main() returns ExitCode
	let x = 0  // int
	let result = Math.cos(x)  // x promoted to 0.0
	if result == 1.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0

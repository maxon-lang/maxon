// Batch: memory-safety
// Tests: assignment-creates-alias, rebind-does-not-mutate, non-cloneable-assignment-ok, auto-cloneable, string-clone, array-clone, nested-struct-clone, auto-equatable, is-compares-refs, is-after-clone, scope-cleanup, return-ownership-transfer, release-before-continue, release-labeled-break-nested, release-break-for-in, release-on-error-propagation, release-on-error-propagation-in-block, generic-function-with-scope-ops, ref-identity-in-cloned-function
---
// Test: assignment-creates-alias
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function main() returns ExitCode
	var a = Point.create(x: 1, y: 2)
	var b = a
	b.x = 99
	a = b
	print("{a.x}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
99
```
---
// Test: rebind-does-not-mutate
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function main() returns ExitCode
	var a = Point.create(x: 1, y: 2)
	a.x = 1
	var b = a
	b = Point.create(x: 99, y: 99)
	print("{a.x}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```

// Test: non-cloneable-assignment-ok
typealias Integer = int(i64.min to i64.max)

enum Color
	red
	green
	blue
end 'Color'

type Item
	export var color Color
	export var value Integer

	static function create(color Color, value Integer) returns Self
		return Self{color: color, value: value}
	end 'create'
end 'Item'

function main() returns ExitCode
	var a = Item.create(color: Color.red, value: 42)
	a.value = 42
	var b = a
	b.value = 99
	return a.value
end 'main'
---
ExitCode: 99
---
module {
  func @Item.create(color: i64, value: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rdx
    x64.mov rcx, 16
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.mov rdx, [rbp-8]
    x64.mov [rcx+0], rdx
    x64.mov rbx, [rbp-16]
    x64.mov rsi, [rbp-24]
    x64.mov [rbx+8], rsi
    x64.mov rdi, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor ecx, ecx
    x64.mov rdx, 42
    x64.call Item.create
    x64.mov [rbp-8], rax
    x64.mov rcx, 42
    x64.mov rdx, [rbp-8]
    x64.mov [rdx+8], rcx
    x64.mov [rbp-16], rax
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rcx, 99
    x64.mov rdx, [rbp-16]
    x64.mov [rdx+8], rcx
    x64.mov rbx, [rbp-8]
    x64.mov rsi, [rbx+8]
    x64.xor edi, edi
    x64.mov r8, 4294967295
    x64.cmp rsi, r8
    x64.jg main.__range_panic_0
    x64.cmp rsi, rdi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rsi
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Item(ptr: i64) {
  entry:
    x64.jmp __destruct_Item.done
  done:
    x64.ret
  }
}
---

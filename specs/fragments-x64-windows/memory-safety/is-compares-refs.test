    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.mov rdx, 2
    x64.call Point.create
    x64.mov [rbp-8], rax
    x64.mov [rbp-16], rax
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.cmp rcx, rdx
    x64.jne main.same_0.after
  same_0:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  same_0.after:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.mov rcx, [rbp-16]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_3
    x64.call mm_decref
    x64.label __nonnull_skip_3
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
  func @__destruct_Point(ptr: i64) {

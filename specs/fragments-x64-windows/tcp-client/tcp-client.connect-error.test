// Test: tcp-client.connect-error
function main() returns ExitCode
	if let client = try TcpClient.connect("192.0.2.1", port: 1) 'ok'
		return 1
	end 'ok' else (e) 'err'
		match e 'check'
			connectFailed then return 0
			default throws NetworkError.resolveFailed
		end 'check'
	end 'err'
end 'main'

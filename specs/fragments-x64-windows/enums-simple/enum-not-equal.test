// Test: enum-not-equal
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s = Status.pending
	let result = match s 'check'
		active gives 0
		pending gives 1
		done gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.xor r9d, r9d
    x64.jmp check_0.next0
  check_0.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  check_0.next0:
    x64.test r9, r9
    x64.jne check_0.next1
  check_0.case1:
    x64.mov r8d, 1
    x64.jmp check_0.merge
  check_0.next1:
    x64.cmp r9, 2
    x64.jne check_0.merge
  check_0.case2:
    x64.mov r8d, 1
    x64.jmp check_0.merge
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

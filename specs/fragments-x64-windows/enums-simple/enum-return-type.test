// Test: enum-return-type
enum Result
	success
	failure
end 'Result'

function getResult(succeed bool) returns Result
	if succeed 'check'
		return Result.success
	end 'check'
	return Result.failure
end 'getResult'

function main() returns ExitCode
	let r = getResult(true)
	let result = match r 'handle'
		success gives 1
		failure gives 0
	end 'handle'
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enums-simple.getResult(rcx: i1) -> u8 {
  entry:
    x64.test rcx, rcx
    x64.je check_1.after
  check_1:
    x64.xor r8d, r8d
    x64.ret
  check_1.after:
    x64.mov r8d, 1
    x64.ret
  }
  func @enums-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 1
    x64.call enums-simple.getResult
    x64.test r8, r8
    x64.xor r9d, r9d
    x64.jne handle_1.next0
    x64.jmp handle_1.case0
  handle_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_3
    x64.jmp __range_panic_3
  handle_1.case0:
    x64.mov r8d, 1
    x64.jmp handle_1.merge
  handle_1.next0:
    x64.cmp r8, 1
    x64.jne handle_1.merge
  handle_1.case1:
    x64.xor r8d, r8d
    x64.jmp handle_1.merge
  __range_panic_3:
    x64.lea rcx, [rip+__panic_msg_5]
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}

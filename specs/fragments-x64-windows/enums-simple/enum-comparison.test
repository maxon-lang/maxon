// Test: enum-comparison
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s1 = Status.pending
	match s1 'check'
		pending then return 1
		active then return 0
		done then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

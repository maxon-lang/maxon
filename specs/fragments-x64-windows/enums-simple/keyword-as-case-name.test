// Test: keyword-as-case-name
enum TokenType
	function
	return
	end
	if
	else
	let
	var
	identifier
end 'TokenType'

function main() returns ExitCode
	let t = TokenType.function
	let result = match t 'check'
		function gives 1
		return gives 0
		end gives 0
		if gives 0
		else gives 0
		let gives 0
		var gives 0
		identifier gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enums-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.xor r8d, r8d
    x64.jmp check_1.case0
  check_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_7
    x64.jmp __range_panic_7
  check_1.case0:
    x64.mov r8d, 1
    x64.jmp check_1.merge
  __range_panic_7:
    x64.lea rcx, [rip+__panic_msg_9]
    x64.call mrt_panic
  __range_ok_7:
    x64.epilogue
    x64.ret
  }
}
---

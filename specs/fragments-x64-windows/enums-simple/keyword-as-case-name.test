// Test: keyword-as-case-name
enum TokenType
	function
	return
	end
	if
	else
	let
	var
	identifier
end 'TokenType'

function main() returns ExitCode
	let t = TokenType.function
	let result = match t 'check'
		function gives 1
		return gives 0
		end gives 0
		if gives 0
		else gives 0
		let gives 0
		var gives 0
		identifier gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.xor edx, edx
    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rcx
    x64.mov rbx, [rbp-24]
    x64.jump_table rbx, 8 cases, default=main.check_0.merge
  check_0.case0:
    x64.mov rax, 1
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case1:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case2:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case3:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case4:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case5:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case6:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.case7:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.check_0.merge
  check_0.merge:
    x64.mov rax, [rbp-16]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

// Test: enum-assignment
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	var c = Color.red
	c = Color.blue
	let result = match c 'check'
		red gives 0
		green gives 0
		blue gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enums-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 2
    x64.jmp check_1.next0
  check_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_1
    x64.jmp __range_panic_1
  check_1.next0:
    x64.cmp r9, 1
    x64.jne check_1.next1
  check_1.case1:
    x64.xor r8d, r8d
    x64.jmp check_1.merge
  check_1.next1:
    x64.cmp r9, 2
    x64.jne check_1.merge
  check_1.case2:
    x64.mov r8d, 1
    x64.jmp check_1.merge
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_3]
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

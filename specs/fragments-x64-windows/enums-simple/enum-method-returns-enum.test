// Test: enum-method-returns-enum
enum Toggle
	on
	off

	function flip() returns Toggle
		let result = match self 'check'
			on gives Toggle.off
			off gives Toggle.on
		end 'check'
		return result
	end 'flip'
end 'Toggle'

function main() returns ExitCode
	let t = Toggle.on
	let flipped = t.flip()
	let result = match flipped 'check'
		off gives 1
		on gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---

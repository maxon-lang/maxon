// Test: enum-function-param
enum Status
	on
	off
end 'Status'

function isOn(s Status) returns bool
	let result = match s 'check'
		on gives true
		off gives false
	end 'check'
	return result
end 'isOn'

function main() returns ExitCode
	let status = Status.on
	if isOn(status) 'test'
		return 1
	end 'test'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enums-simple.isOn(rcx: u8) -> i1 {
  entry:
    x64.test rcx, rcx
    x64.xor r8d, r8d
    x64.jne check_1.next0
    x64.jmp check_1.case0
  check_1.merge:
    x64.ret
  check_1.case0:
    x64.mov r8d, 1
    x64.jmp check_1.merge
  check_1.next0:
    x64.cmp rcx, 1
    x64.jne check_1.merge
  check_1.case1:
    x64.xor r8d, r8d
    x64.jmp check_1.merge
  }
  func @enums-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor ecx, ecx
    x64.call enums-simple.isOn
    x64.test r8, r8
    x64.je test_1.after
  test_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  test_1.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

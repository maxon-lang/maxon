// Batch: managed-list
// Tests: core.create-empty, core.insert-first, core.insert-last, core.insert-first-multiple, core.insert-last-multiple, core.insert-after, core.insert-before, core.remove, core.detach, core.count, node.value, node.next-prev, node.set-value, node.set-value-old-survives, core.clear, core.head-empty-throws, core.tail-empty-throws, node.next-end-throws, node.prev-begin-throws, core.reinsert-first, core.reinsert-last, core.remove-head, core.remove-tail, core.remove-all
---
// Test: core.create-empty
typealias Integer = int(i64.min to i64.max)
typealias IntManagedList = __ManagedList with Integer

function main() returns ExitCode
	let list = IntManagedList.create()
	if list.isEmpty() 'check'
		print("{list.count()}\n")
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
Stdout: ```
0
```
---

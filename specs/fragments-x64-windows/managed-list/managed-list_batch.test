// Test: core.insert-after
typealias Integer = int(i64.min to i64.max)
typealias IntManagedList = __ManagedList with Integer

function main() returns ExitCode
	var list = IntManagedList.create()
	let n1 = list.insertFirst(10)
	let n3 = list.insertLast(30)
	// Insert 20 after n1
	let n2 = list.insertAfter(target: n1, value: 20)
	// Verify order via traversal
	let cur = try list.head() otherwise 'err'
		return 1
	end 'err'
	print("{cur.value()}\n")
	let cur2 = try cur.next() otherwise 'err2'
		return 1
	end 'err2'
	print("{cur2.value()}\n")
	let cur3 = try cur2.next() otherwise 'err3'
		return 1
	end 'err3'
	print("{cur3.value()}\n")
	// Also verify n2 and n3 are valid
	print("{n2.value()}\n")
	print("{n3.value()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10
20
30
20
30
```
---
// Test: core.insert-before
typealias Integer = int(i64.min to i64.max)
typealias IntManagedList = __ManagedList with Integer

function main() returns ExitCode
	var list = IntManagedList.create()
	let n1 = list.insertFirst(10)
	let n3 = list.insertLast(30)
	// Insert 20 before n3
	let n2 = list.insertBefore(target: n3, value: 20)
	// Verify order via traversal
	let cur = try list.head() otherwise 'err'
		return 1
	end 'err'
	print("{cur.value()}\n")
	let cur2 = try cur.next() otherwise 'err2'
		return 1
	end 'err2'
	print("{cur2.value()}\n")
	let cur3 = try cur2.next() otherwise 'err3'
		return 1
	end 'err3'
	print("{cur3.value()}\n")
	// Also verify n1 and n2 are valid
	print("{n1.value()}\n")
	print("{n2.value()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10
20
30
10
20
```

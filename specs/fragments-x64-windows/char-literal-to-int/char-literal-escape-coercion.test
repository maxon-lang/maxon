// Test: char-literal-escape-coercion
function main() returns ExitCode
	let cp = 10
	if cp == '\n' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 10
    x64.mov rcx, 10
    x64.cmp rax, rcx
    x64.jne main.check_0.after
  check_0:
    x64.xor eax, eax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

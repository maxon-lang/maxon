// Test: char-literal-lhs-coercion
function main() returns ExitCode
	let cp = 45
	if '-' == cp 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 45
    x64.mov rcx, 45
    x64.cmp rcx, rax
    x64.jne main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

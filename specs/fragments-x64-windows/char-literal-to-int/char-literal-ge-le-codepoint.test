// Test: char-literal-ge-le-codepoint
function main() returns ExitCode
	let cp = 53
	if cp >= '0' 'ge'
		if cp <= '9' 'le'
			return 0
		end 'le'
	end 'ge'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 53
  ge_0:
    x64.cmp r8, 57
    x64.jg ge_0.after
  le_0:
    x64.xor r8d, r8d
    x64.ret
  ge_0.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

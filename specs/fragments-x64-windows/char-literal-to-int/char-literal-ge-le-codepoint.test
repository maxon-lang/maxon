// Test: char-literal-ge-le-codepoint
function main() returns ExitCode
	let cp = 53
	if cp >= '0' 'ge'
		if cp <= '9' 'le'
			return 0
		end 'le'
	end 'ge'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 53
    x64.mov [rbp-8], rax
    x64.mov rcx, 48
    x64.cmp rax, rcx
    x64.jl main.ge_0.merge
  ge_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 57
    x64.cmp rax, rcx
    x64.jg main.le_1.after
  le_1:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  le_1.after:
    x64.jmp main.ge_0.merge
  ge_0.merge:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  }
}
---

// Batch: char-literal-to-int
// Tests: char-literal-eq-codepoint, char-literal-ne-codepoint, char-literal-ge-le-codepoint, char-literal-arithmetic, char-literal-escape-coercion, char-literal-lhs-coercion, char-literal-both-sides-still-character, char-literal-codepoint-iteration
---
// Test: char-literal-eq-codepoint
function main() returns ExitCode
	let cp = 45
	if cp == '-' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-ne-codepoint
function main() returns ExitCode
	let cp = 45
	if cp != '.' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-ge-le-codepoint
function main() returns ExitCode
	let cp = 53
	if cp >= '0' 'ge'
		if cp <= '9' 'le'
			return 0
		end 'le'
	end 'ge'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-arithmetic
function main() returns ExitCode
	let cp = 53
	let digit = cp - '0'
	return digit
end 'main'
---
ExitCode: 5
---
// Test: char-literal-escape-coercion
function main() returns ExitCode
	let cp = 10
	if cp == '\n' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-lhs-coercion
function main() returns ExitCode
	let cp = 45
	if '-' == cp 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-both-sides-still-character
function main() returns ExitCode
	if 'A' == 'A' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: char-literal-codepoint-iteration
function main() returns ExitCode
	var count = 0
	for cp in "a-b-c".codepoints() 'chars'
		if cp == '-' 'dash'
			count = count + 1
		end 'dash'
	end 'chars'
	return count
end 'main'
---
ExitCode: 2
---

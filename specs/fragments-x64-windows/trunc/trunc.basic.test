// Test: trunc.basic
function main() returns ExitCode
	let neg = -3.7
	let y = trunc(neg)
	return y + 10
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_-3.7]
    x64.cvttsd2si rax, xmm0
    x64.mov rcx, 10
    x64.add rax, rcx
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

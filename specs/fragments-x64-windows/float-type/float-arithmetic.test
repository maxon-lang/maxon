// Test: float-arithmetic
function main() returns ExitCode
	var a = 10.0
	var b = 3.0
	var result = a / b
	return trunc(result)
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4613937818241073152]
    x64.movsd xmm1, [rip+__float_4621819117588971520]
    x64.movsd xmm2, xmm1
    x64.divsd xmm2, xmm0
    x64.cvttsd2si rax, xmm2
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

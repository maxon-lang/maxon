// Test: float-arithmetic
function main() returns ExitCode
	let a = 10.0
	let b = 3.0
	let result = a / b
	return trunc(result)
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4613937818241073152]
    x64.movsd xmm1, [rip+__float_4621819117588971520]
    x64.movsd xmm2, xmm1
    x64.divsd xmm2, xmm0
    x64.cvttsd2si rbx, xmm2
    x64.cmp rbx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
}
---

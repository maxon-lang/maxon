// Test: float-comparison
function main() returns ExitCode
	let x = 3.5
	let y = 2.1
	if x > y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.movsd xmm0, [rip+__float_4611911198408756428]
    x64.movsd xmm1, [rip+__float_4615063718147915776]
    x64.ucomisd xmm1, xmm0
    x64.jbe check_1.after
  check_1:
    x64.mov rax, 1
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

// Test: float-promotion
function main() returns ExitCode
	var x = 5
	var y = 2.0
	var result = x + y
	return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 5
    x64.movsd xmm0, [rip+__float_2]
    x64.cvtsi2sd xmm1, rax
    x64.movsd xmm2, xmm1
    x64.addsd xmm2, xmm0
    x64.cvttsd2si rcx, xmm2
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

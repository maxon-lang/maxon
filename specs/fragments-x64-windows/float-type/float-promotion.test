// Test: float-promotion
function main() returns ExitCode
	var x = 5
	var y = 2.0
	var result = x + y
	return trunc(result)
end 'main'
---
ExitCode: 7
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 5
    x64.cvtsi2sd xmm0, rax
    x64.movsd xmm1, [rip+__float_4611686018427387904]
    x64.movsd xmm2, xmm0
    x64.addsd xmm2, xmm1
    x64.cvttsd2si rax, xmm2
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

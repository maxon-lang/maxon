// Test: remove-last
function main() returns ExitCode
	var list = List from [10, 20, 30]
	let removed = try list.removeLast() otherwise 0
	print("{removed}\n")
	print("{list.count()}\n")
	let l = try list.last() otherwise 0
	print("{l}\n")
	return 0
end 'main'

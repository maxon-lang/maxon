// Test: iteration.for-in
function main() returns ExitCode
	let list = List from [10, 20, 30]
	for item in list 'loop'
		print("{item}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10
20
30
```
---
// Test: iteration.large-list
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
	var list = IntList.create()
	for i in 1 to 100 'build'
		list.append(i)
	end 'build'
	var sum = 0
	for item in list 'loop'
		sum = sum + item
	end 'loop'
	return sum - 5050
end 'main'
---
ExitCode: 0
---
// Test: iteration.two-loops
function main() returns ExitCode
	let list = List from [1, 2, 3]
	var sum1 = 0
	for item in list 'loop1'
		sum1 = sum1 + item
	end 'loop1'
	var sum2 = 0
	for item in list 'loop2'
		sum2 = sum2 + item
	end 'loop2'
	if sum1 == sum2 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: mixed-operations
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
	var list = IntList.create()
	list.append(2)
	list.append(3)
	list.prepend(1)
	list.append(4)
	let removed1 = try list.removeFirst() otherwise 0
	let removed2 = try list.removeLast() otherwise 0
	print("{removed1}\n")
	print("{removed2}\n")
	print("{list.count()}\n")
	let v0 = try list.get(0) otherwise 0
	let v1 = try list.get(1) otherwise 0
	print("{v0}\n")
	print("{v1}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
4
2
2
3
```
---
// Test: strings
typealias StringList = List with String

function main() returns ExitCode
	var list = StringList.create()
	list.append("hello")
	list.append("world")
	let f = try list.first() otherwise "none"
	let l = try list.last() otherwise "none"
	print("{f}\n")
	print("{l}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello
world
```
---

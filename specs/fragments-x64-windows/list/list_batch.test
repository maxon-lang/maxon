// Batch: list
// Tests: basic.creation, basic.empty, basic.first-last, basic.first-empty, basic.last-empty, prepend.single, prepend.multiple, append.single, append.multiple, get.valid, get.out-of-bounds, insert.at-beginning, insert.at-middle, insert.at-end, remove-first, remove-last, remove.at-index, iteration.for-in, iteration.large-list, iteration.two-loops, mixed-operations, strings, clear
---
// Test: basic.creation
function main() returns ExitCode
	let list = List from [10, 20, 30]
	return list.count()
end 'main'
---
ExitCode: 3
---
// Test: basic.empty
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
	var list = IntList.create()
	if list.isEmpty() 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: basic.first-last
function main() returns ExitCode
	let list = List from [10, 20, 30]
	let f = try list.first() otherwise 0
	let l = try list.last() otherwise 0
	print("{f}\n")
	print("{l}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10
30
```
---
// Test: basic.first-empty
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode
	var list = IntList.create()
	let f = try list.first() otherwise 99
	return f
end 'main'
---
ExitCode: 99
---
// Test: basic.last-empty
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer

function main() returns ExitCode

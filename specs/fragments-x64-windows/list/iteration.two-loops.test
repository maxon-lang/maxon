// Test: iteration.two-loops
function main() returns ExitCode
	let list = List from [1, 2, 3]
	var sum1 = 0
	for item in list 'loop1'
		sum1 = sum1 + item
	end 'loop1'
	var sum2 = 0
	for item in list 'loop2'
		sum2 = sum2 + item
	end 'loop2'
	if sum1 == sum2 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0

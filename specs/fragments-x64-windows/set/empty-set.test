// Test: empty-set
typealias Int = int(i64.min to i64.max)
typealias IntSet = Set with Int

function main() returns ExitCode
	var s = IntSet.create()
	if s.count() != 0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea rdx, [rip+__destruct_Set]
    x64.mov ecx, 32
    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov r8, r12
    x64.sub r8, 8
    x64.lock inc qword ptr [r8]
    x64.lea r9, [rip+__witness_int_Equatable]
    x64.lea rax, [rip+__witness_int_Hashable]
    x64.lea rdx, [rip+__layout_Set_Int]
    x64.mov rcx, r12
    x64.call Set.count
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r13, r13
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: conformance-multiple-interfaces

typealias Integer = int(i64.min to i64.max)

interface Readable
	function read() returns Integer
end 'Readable'

interface Writable
	function write(value Integer)
end 'Writable'

type Buffer implements Readable, Writable
	var data Integer

	function read() returns Integer
		return data
	end 'read'

	function write(value Integer)
		data = value
	end 'write'

	static function create(data Integer) returns Self
		return Self{data: data}
	end 'create'
end 'Buffer'

function main() returns ExitCode
	var buf = Buffer.create(data: 0)
	buf.write(42)
	return buf.read()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Buffer.read(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Buffer.write(rcx: i64, rdx: i64) {
  entry:
    x64.mov [rcx+0], rdx (8b)
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_1]
    x64.call mrt_panic
  __range_ok_1:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

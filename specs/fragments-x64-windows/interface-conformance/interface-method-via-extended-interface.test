// Test: interface-method-via-extended-interface

typealias Integer = int(i64.min to i64.max)

interface Base
	function ping(payload Integer) returns Integer
end 'Base'

interface Extended extends Base
	function other() returns Integer
end 'Extended'

type Impl implements Extended
	let n Integer

	function ping(payload Integer) returns Integer
		return n
	end 'ping'

	function other() returns Integer
		return n + 1
	end 'other'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Impl'

function callPing(b Base) returns Integer
	return b.ping(payload: 7)
end 'callPing'

function main() returns ExitCode
	let i = Impl.create(n: 5)
	return callPing(i)
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @Impl.ping(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, r9
    x64.ret
  }
  func @Impl.other(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.mov r9, r8
    x64.add r9, 1
    x64.mov r8, r9
    x64.ret
  }
  func @callPing(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rdx
    x64.mov r8, [rbp-16]
    x64.mov r12, [r8+24] (8b)
    x64.mov r8, [rbp-8]
    x64.mov r9d, 7
    x64.mov rcx, r8
    x64.mov rdx, r9
    x64.call r12
    x64.mov r9, r8
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r9d, 5
    x64.mov [r8+0], r9 (8b)
    x64.lea r9, [rip+__witness_Impl_Base]
    x64.mov rcx, r8
    x64.mov rdx, r9
    x64.call callPing
    x64.cmp r8, 125
    x64.jbe __range_ok_5
  __range_panic_5:
    x64.lea r8, [rip+__panic_msg_5]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_5:
    x64.epilogue
    x64.ret
  }

    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rdx
    x64.mov r8, [rbp-16]
    x64.mov rcx, [rbp-8]
    x64.mov edx, 99
    x64.mov r10, [r8+24] (8b)
    x64.call r10
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.lea rdx, [rip+__witness_Silent_Greeter]
    x64.mov rcx, r8
    x64.call callGreet
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

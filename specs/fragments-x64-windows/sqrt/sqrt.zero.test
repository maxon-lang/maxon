// Test: sqrt.zero
function main() returns ExitCode
	let result = sqrt(0.0)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_0]
    x64.movsd xmm1, [rip+__float_0]
    x64.sqrtsd xmm2, xmm0
    x64.ucomisd xmm2, xmm1
    x64.jp check_0.after
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

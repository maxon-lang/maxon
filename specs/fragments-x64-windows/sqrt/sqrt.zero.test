// Test: sqrt.zero
function main() returns ExitCode
	let result = sqrt(0.0)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_0]
    x64.sqrtsd xmm1, xmm0
    x64.movsd xmm2, [rip+__float_0]
    x64.ucomisd xmm1, xmm2
    x64.jne main.check_0.after
    x64.jp main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

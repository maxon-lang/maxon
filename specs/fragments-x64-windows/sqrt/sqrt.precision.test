// Test: sqrt.precision
function main() returns ExitCode
	var x = sqrt(2.0)
	// sqrt(2) * sqrt(2) should be approximately 2
	var check = x * x
	// Trunc to get integer 2
	return trunc(check)
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_2]
    x64.sqrtsd xmm1, xmm0
    x64.movsd xmm2, xmm1
    x64.mulsd xmm2, xmm1
    x64.cvttsd2si rax, xmm2
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

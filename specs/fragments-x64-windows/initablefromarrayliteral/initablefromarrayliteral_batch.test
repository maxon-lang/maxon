// Batch: initablefromarrayliteral
// Tests: array-from-literal, array-from-literal-access, array-from-literal-first, array-from-literal-last
---
// Test: array-from-literal
function main() returns ExitCode
	let arr = [10, 20, 30]
	return arr.count()
end 'main'
---
ExitCode: 3
---
// Test: array-from-literal-access
function main() returns ExitCode
	let arr = [10, 20, 30]
	let val = try arr.get(1) otherwise 0
	return val
end 'main'
---
ExitCode: 20
---
// Test: array-from-literal-first
function main() returns ExitCode
	let arr = [42, 2, 3]
	let val = try arr.first() otherwise 0
	return val
end 'main'
---
ExitCode: 42
---
// Test: array-from-literal-last
function main() returns ExitCode
	let arr = [1, 2, 99]
	let val = try arr.last() otherwise 0
	return val
end 'main'
---
ExitCode: 99
---

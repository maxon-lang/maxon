// Test: alias-of-alias-forward
typealias Counter = Tally
typealias Tally = int(0 to 1000)

function main() returns ExitCode
	let c = 7 as Counter
	return c
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @type-alias-resolution.main() -> u8 {
  entry:
    x64.mov r8d, 7
    x64.ret
  }
}
---

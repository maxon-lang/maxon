// Test: alias-of-alias-backward
typealias Score = int(0 to 100)
typealias BoundedScore = Score

function main() returns ExitCode
	let s = 42 as BoundedScore
	return s
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-alias-resolution.main() -> u8 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
}
---

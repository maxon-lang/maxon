// Test: array-of-lists
typealias Integer = int(i64.min to i64.max)
typealias IntList = List with Integer
typealias IntListArray = Array with IntList

function main() returns ExitCode
	var list1 = IntList.create()
	list1.append(10)
	list1.append(20)
	var list2 = IntList.create()
	list2.append(30)
	var arr = [list1, list2]
	print("{arr.count()}\n")
	let first = try arr.get(0) otherwise IntList.create()
	print("{first.count()}\n")
	let val = try first.get(0) otherwise 0
	print("{val}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
2
10

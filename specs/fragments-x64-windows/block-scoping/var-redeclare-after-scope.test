// Test: var-redeclare-after-scope
function main() returns ExitCode
	if true 'check'
		let x = 10
	end 'check'
	let x = 42
	return x
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @block-scoping.main() -> u32 {
  entry:
    x64.mov rax, 1
    x64.test rax, rax
    x64.je block-scoping.main.check_0.merge
  check_0:
    x64.jmp block-scoping.main.check_0.merge
  check_0.merge:
    x64.mov rax, 42
    x64.ret
  }
}
---

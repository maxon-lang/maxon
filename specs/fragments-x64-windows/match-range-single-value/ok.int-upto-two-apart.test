// Test: ok.int-upto-two-apart
function main() returns ExitCode
	let x = 5
	let result = match x 'eval'
		5 upto 7 gives 0
		default gives 1
	end 'eval'
	return result
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
  eval_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_3ed0f34d7df228c2]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

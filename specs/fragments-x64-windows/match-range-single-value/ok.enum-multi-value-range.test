// Test: ok.enum-multi-value-range
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	let result = match c 'eval'
		red to blue gives 0
		default panic("unreachable")
	end 'eval'
	return result
end 'main'
---
ExitCode: 0

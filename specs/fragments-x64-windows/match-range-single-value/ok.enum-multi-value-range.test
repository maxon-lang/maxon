// Test: ok.enum-multi-value-range
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	let result = match c 'eval'
		red to blue gives 0
		default panic("unreachable")
	end 'eval'
	return result
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.xor r8d, r8d
  eval_0.merge:
    x64.ret
  }
}
---

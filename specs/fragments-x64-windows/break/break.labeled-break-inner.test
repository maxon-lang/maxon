// Test: break.labeled-break-inner
function main() returns ExitCode
	var x = 0
	var y = 0
	while x < 5 'outer'
		x = x + 1
		while y < 10 'inner'
			y = y + 1
			if y == 3 'check'
				break
			end 'check'
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 5

// Test: break.labeled-break-triple-nested
function main() returns ExitCode
	var result = 0
	while true 'outer'
		while true 'middle'
			while true 'inner'
				result = result + 1
				if result == 5 'check'
					break 'outer'
				end 'check'
			end 'inner'
		end 'middle'
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---

// Test: break.labeled-break-triple-nested
function main() returns ExitCode
	var result = 0
	while true 'outer'
		while true 'middle'
			while true 'inner'
				result = result + 1
				if result == 5 'check'
					break 'outer'
				end 'check'
			end 'inner'
		end 'middle'
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
  outer_0.header:
    x64.jmp middle_0.header
  outer_0.exit:
    x64.mov r8d, 4294967295
    x64.cmp r9, r8
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  middle_0.header:
  inner_0.header:
  inner_0:
    x64.add r8, 1
    x64.cmp r8, 5
    x64.jne inner_0.header
    x64.mov r9, r8
    x64.jmp outer_0.exit
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

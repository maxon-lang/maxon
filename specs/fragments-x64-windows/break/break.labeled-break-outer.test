// Test: break.labeled-break-outer
function main() returns ExitCode
	var x = 0
	while x < 10 'outer'
		x = x + 1
		while true 'inner'
			if x == 3 'check'
				break 'outer'
			end 'check'
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
  outer_0.header:
    x64.cmp r8, 10
    x64.jge outer_0.exit
  outer_0:
    x64.add r8, 1
    x64.jmp inner_0
  outer_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  inner_0:
    x64.cmp r8, 3
    x64.jne outer_0.header
    x64.jmp outer_0.exit
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

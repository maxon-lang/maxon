// Test: break.labeled-break-outer
function main() returns ExitCode
	var x = 0
	while x < 10 'outer'
		x = x + 1
		while true 'inner'
			if x == 3 'check'
				break 'outer'
			end 'check'
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 3
---

  func @break.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.jmp break.main.outer_0.header
  outer_0.header:
    x64.mov rax, 10
    x64.mov rcx, [rbp-8]
    x64.cmp rcx, rax
    x64.jge break.main.outer_0.exit
  outer_0:
    x64.mov rax, 1
    x64.mov rcx, [rbp-8]
    x64.add rcx, rax
    x64.mov [rbp-8], rcx
    x64.jmp break.main.inner_1.header
  inner_1.header:
    x64.mov rax, 1
    x64.test rax, rax
    x64.je break.main.inner_1.exit
  inner_1:
    x64.mov rax, 3
    x64.mov rcx, [rbp-8]
    x64.cmp rcx, rax
    x64.jne break.main.check_2.after
  check_2:
    x64.jmp break.main.outer_0.exit
  check_2.after:
    x64.jmp break.main.inner_1.exit
  inner_1.exit:
    x64.jmp break.main.outer_0.header
  outer_0.exit:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg break.main.__range_panic_3
    x64.cmp rax, rcx
    x64.jl break.main.__range_panic_3
    x64.jmp break.main.__range_ok_3
  __range_panic_3:
    x64.lea_symdata rax, [__panic_msg_3]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}

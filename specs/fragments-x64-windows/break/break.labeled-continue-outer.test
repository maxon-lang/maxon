// Test: break.labeled-continue-outer
function main() returns ExitCode
	var x = 0
	var count = 0
	while x < 3 'outer'
		x = x + 1
		var y = 0
		while y < 5 'inner'
			y = y + 1
			count = count + 1
			if y == 2 'check'
				continue 'outer'
			end 'check'
		end 'inner'
	end 'outer'
	return count
end 'main'
---

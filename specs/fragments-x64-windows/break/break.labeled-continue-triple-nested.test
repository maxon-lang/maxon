// Test: break.labeled-continue-triple-nested
function main() returns ExitCode
	var count = 0
	var a = 0
	while a < 2 'outer'
		a = a + 1
		var b = 0
		while b < 3 'middle'
			b = b + 1
			var c = 0
			while c < 4 'inner'
				c = c + 1
				count = count + 1
				if c == 2 'check'
					continue 'middle'
				end 'check'
			end 'inner'
		end 'middle'
	end 'outer'
	return count
end 'main'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.xor rcx, rcx
    x64.mov [rbp-16], rcx
    x64.jmp main.outer_0.header
  outer_0.header:
    x64.mov rax, 2
    x64.mov rcx, [rbp-16]
    x64.cmp rcx, rax
    x64.jge main.outer_0.exit
  outer_0:
    x64.mov rax, 1
    x64.mov rcx, [rbp-16]
    x64.add rcx, rax
    x64.mov [rbp-16], rcx
    x64.xor rdx, rdx
    x64.mov [rbp-24], rdx
    x64.jmp main.middle_1.header
  middle_1.header:
    x64.mov rax, 3
    x64.mov rcx, [rbp-24]
    x64.cmp rcx, rax
    x64.jge main.middle_1.exit
  middle_1:
    x64.mov rax, 1
    x64.mov rcx, [rbp-24]
    x64.add rcx, rax
    x64.mov [rbp-24], rcx
    x64.xor rdx, rdx
    x64.mov [rbp-32], rdx
    x64.jmp main.inner_2.header
  inner_2.header:
    x64.mov rax, 4
    x64.mov rcx, [rbp-32]
    x64.cmp rcx, rax
    x64.jge main.inner_2.exit
  inner_2:
    x64.mov rax, 1
    x64.mov rcx, [rbp-32]
    x64.add rcx, rax
    x64.mov [rbp-32], rcx
    x64.mov rdx, 1
    x64.mov rbx, [rbp-8]
    x64.add rbx, rdx
    x64.mov [rbp-8], rbx
    x64.mov rsi, 2
    x64.cmp rcx, rsi
    x64.jne main.check_3.after
  check_3:
    x64.jmp main.middle_1.header
  check_3.after:
    x64.jmp main.inner_2.header
  inner_2.exit:
    x64.jmp main.middle_1.header
  middle_1.exit:
    x64.jmp main.outer_0.header
  outer_0.exit:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_4
    x64.cmp rax, rcx
    x64.jl main.__range_panic_4
    x64.jmp main.__range_ok_4
  __range_panic_4:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_4:
    x64.epilogue
    x64.ret
  }
}

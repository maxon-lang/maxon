// Test: break.multiple-conditions
function main() returns ExitCode
	var x = 5
	var count = 0
	while x < 100 'loop'
		x = x + 1
		count = count + 1
		if count == 3 'check'
			break
		end 'check'
	end 'loop'
	return x
end 'main'
---
ExitCode: 8
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 5
  loop_0.header:
    x64.cmp r9, 100
    x64.jge __phi_trampoline_1_0
  loop_0:
    x64.add r8, 1
    x64.add r9, 1
    x64.cmp r8, 3
    x64.jne loop_0.header
    x64.mov r8, r9
    x64.jmp loop_0.exit
  loop_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  __phi_trampoline_1_0:
    x64.mov r8, r9
    x64.jmp loop_0.exit
  }
}
---

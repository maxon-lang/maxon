// Test: break.labeled-continue-inner
function main() returns ExitCode
	var sum = 0
	var x = 0
	while x < 3 'outer'
		x = x + 1
		var y = 0
		while y < 5 'inner'
			y = y + 1
			if y == 3 'check'
				continue
			end 'check'
			sum = sum + 1
		end 'inner'
	end 'outer'
	return sum
end 'main'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.xor rcx, rcx
    x64.mov [rbp-16], rcx
    x64.jmp main.outer_0.header
  outer_0.header:
    x64.mov rax, 3
    x64.mov rcx, [rbp-16]
    x64.cmp rcx, rax
    x64.jge main.outer_0.exit
  outer_0:
    x64.mov rax, 1
    x64.mov rcx, [rbp-16]
    x64.add rcx, rax
    x64.mov [rbp-16], rcx
    x64.xor rdx, rdx
    x64.mov [rbp-24], rdx
    x64.jmp main.inner_1.header
  inner_1.header:
    x64.mov rax, 5
    x64.mov rcx, [rbp-24]
    x64.cmp rcx, rax
    x64.jge main.inner_1.exit
  inner_1:
    x64.mov rax, 1
    x64.mov rcx, [rbp-24]
    x64.add rcx, rax
    x64.mov [rbp-24], rcx
    x64.mov rdx, 3
    x64.cmp rcx, rdx
    x64.jne main.check_2.after
  check_2:
    x64.jmp main.inner_1.header
  check_2.after:
    x64.mov rax, 1
    x64.mov rcx, [rbp-8]
    x64.add rcx, rax
    x64.mov [rbp-8], rcx
    x64.jmp main.inner_1.header
  inner_1.exit:
    x64.jmp main.outer_0.header
  outer_0.exit:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_3
    x64.cmp rax, rcx
    x64.jl main.__range_panic_3
    x64.jmp main.__range_ok_3
  __range_panic_3:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}
---

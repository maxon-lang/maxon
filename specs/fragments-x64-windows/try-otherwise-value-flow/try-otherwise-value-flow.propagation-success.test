// Test: try-otherwise-value-flow.propagation-success
enum E
	bad
end 'E'

function double(x ExitCode) returns ExitCode throws E
	return x * 2
end 'double'

function wrap() returns ExitCode throws E
	let v = try double(5)
	return v
end 'wrap'

function main() returns ExitCode
	let v = try wrap() otherwise 99
	return v
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @double(rcx: u8) -> u8 {
  entry:
    x64.mov r9d, 2
    x64.mov r8, rcx
    x64.imul r8, r9
    x64.xor edx, edx
    x64.ret
  }
  func @wrap() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5
    x64.call double
    x64.mov r9, r8
    x64.test rdx, rdx
    x64.je try_1.cont
  try_1.err:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  try_1.cont:
    x64.xor edx, edx
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.call wrap
    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r8d, 99
  try_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea rcx, [rip+__panic_msg_3]
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}
---

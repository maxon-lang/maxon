    x64.prologue stack_size=16
    x64.mov r8d, 5
    x64.mov rcx, r8
    x64.call try-otherwise-value-flow.double
    x64.mov r9, r8
    x64.mov rsi, rdx
    x64.test rsi, rsi
    x64.je try_1.cont

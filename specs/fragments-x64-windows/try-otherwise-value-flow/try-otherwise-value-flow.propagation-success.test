  try_1.cont:
    x64.xor esi, esi
    x64.mov r8, r9
    x64.mov rdx, rsi
    x64.epilogue
    x64.ret
  }
  func @try-otherwise-value-flow.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.call try-otherwise-value-flow.wrap
    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r8d, 99
  try_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_3]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}

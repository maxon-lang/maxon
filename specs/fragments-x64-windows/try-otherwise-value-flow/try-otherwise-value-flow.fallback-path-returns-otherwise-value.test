// Test: try-otherwise-value-flow.fallback-path-returns-otherwise-value
enum E
	bad
end 'E'

function alwaysThrows(x ExitCode) returns ExitCode throws E
	if x >= 0 'always'
		throw E.bad
	end 'always'
	return x
end 'alwaysThrows'

function main() returns ExitCode
	let v = try alwaysThrows(5) otherwise 99
	return v
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @alwaysThrows(rcx: u8) -> u8 {
  entry:
    x64.test rcx, rcx
    x64.jl always_0.after
  always_0:
    x64.xor r8d, r8d
    x64.mov edx, 1
    x64.ret
  always_0.after:
    x64.xor edx, edx
    x64.mov r8, rcx
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5
    x64.call alwaysThrows
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 99
  try_0.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_1]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

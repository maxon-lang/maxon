// Test: try-otherwise-value-flow.fallback-path-returns-otherwise-value
enum E
	bad
end 'E'

function alwaysThrows(x ExitCode) returns ExitCode throws E
	if x >= 0 'always'
		throw E.bad
	end 'always'
	return x
end 'alwaysThrows'

function main() returns ExitCode
	let v = try alwaysThrows(5) otherwise 99
	return v
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @alwaysThrows(rcx: u8) -> u8 {
  entry:
    x64.test rcx, rcx
    x64.jl always_1.after
  always_1:
    x64.xor r9d, r9d
    x64.mov esi, 1
    x64.mov r8, r9
    x64.mov rdx, rsi
    x64.ret
  always_1.after:
    x64.xor r9d, r9d
    x64.mov r8, rcx
    x64.mov rdx, r9
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 5
    x64.mov rcx, r8
    x64.call alwaysThrows
    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r8d, 99
  try_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

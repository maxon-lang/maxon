// Test: union-cases.match-exhaustive
typealias Integer = int(i64.min to i64.max)

union Shape
	circle(radius Integer)
	square(side Integer)
	point
end 'Shape'

function describe(k Shape.unionCases) returns Integer
	match k 'tag'
		circle then return 100
		square then return 200
		point then return 300
	end 'tag'
end 'describe'

function main() returns ExitCode
	let c = Shape.unionCases.circle
	let s = Shape.unionCases.square
	let p = Shape.unionCases.point
	let total = describe(c) + describe(s) + describe(p)
	if total == 600 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @describe(rcx: u8) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.jne tag_0.next0
  tag_0.case0:
    x64.mov r8d, 100
    x64.epilogue
    x64.ret
  tag_0.next0:
    x64.cmp rcx, 1
    x64.jne tag_0.next1
  tag_0.case1:
    x64.mov r8d, 200
    x64.epilogue
    x64.ret
  tag_0.next1:
    x64.cmp rcx, 2
    x64.jne tag_0.next2
  tag_0.case2:
    x64.mov r8d, 300
    x64.epilogue
    x64.ret
  tag_0.next2:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor ecx, ecx
    x64.call describe
    x64.mov r12, r8
    x64.mov ecx, 1
    x64.call describe
    x64.mov r13, r8
    x64.mov ecx, 2
    x64.call describe
    x64.add r12, r13
    x64.add r12, r8
    x64.cmp r12, 600
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

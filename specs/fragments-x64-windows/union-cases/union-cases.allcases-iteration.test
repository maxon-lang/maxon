// Test: union-cases.allcases-iteration
typealias Integer = int(i64.min to i64.max)

union Shape
	circle(radius Integer)
	square(side Integer)
	point
end 'Shape'

function main() returns ExitCode
	for kase in Shape.unionCases.allCases 'loop'
		print("{kase.name}\n")
	end 'loop'
	return 0
end 'main'

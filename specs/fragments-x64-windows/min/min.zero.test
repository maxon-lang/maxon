// Test: min.zero
function main() returns ExitCode
	var x = min(0.0, 5.0)
	if x == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_0]
    x64.movsd xmm1, [rip+__float_5]
    x64.movsd xmm2, xmm0
    x64.minsd xmm2, xmm1
    x64.movsd xmm3, [rip+__float_0]
    x64.ucomisd xmm2, xmm3
    x64.jne main.check_0.after
    x64.jp main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

// Test: closure-capture.interface-method-with-captured-field
typealias Integer = int(i64.min to i64.max)

interface Greeter
	function greet() returns Integer
end 'Greeter'

type Box implements Greeter
	var v as Integer

	static function make(v Integer) returns Self
		return Self{v: v}
	end 'make'

	function greet() returns Integer
		let myv = v
		let adder = function(x Integer) gives x + myv
		return adder(10)
	end 'greet'
end 'Box'

function main() returns ExitCode
	let m = Box.make(5)
	return m.greet()
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @Box.greet(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=48
    x64.mov r8, [rcx+0] (8b)
    x64.mov [rbp-24], r8
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.lea rax, [rbp-24]
    x64.mov r9, [rbp-32]
    x64.mov [r8+0], r9 (8b)
    x64.mov ecx, 10
    x64.lea r12, [rip+_$closure_0]
    x64.mov rdx, r8
    x64.call r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 5
    x64.mov [r8+0], r9 (8b)
    x64.mov rcx, r8
    x64.call Box.greet
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: module-function-same-directory
// --- file: feature/helper.maxon
typealias Integer = int(i64.min to i64.max)

module function helper() returns Integer
	return 42
end 'helper'

// --- file: feature/main.maxon
function main() returns ExitCode
	return helper()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
}
---

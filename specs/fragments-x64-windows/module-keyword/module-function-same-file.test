// Test: module-function-same-file
typealias Integer = int(i64.min to i64.max)

module function helper() returns Integer
	return 42
end 'helper'

function main() returns ExitCode
	return helper()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @module-keyword.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.call module-keyword.helper
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

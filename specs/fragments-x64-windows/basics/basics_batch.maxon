// --- batched test: return-function-call ---

typealias _b_return_function_call_Integer = int(i64.min to i64.max)

function _b_return_function_call_getValue() returns _b_return_function_call_Integer
	return 42
end '_b_return_function_call_getValue'

function _b_return_function_call_main() returns ExitCode
	return _b_return_function_call_getValue()
end '_b_return_function_call_main'

// --- batch dispatcher for basics ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:return-function-call>>>\n")
	let ec_return_function_call = _b_return_function_call_main()
	print("\n<<<MAXON_BATCH_TEST_END:return-function-call:{ec_return_function_call}>>>\n")
	return 0 as ExitCode
end 'main'

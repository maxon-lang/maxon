// Test: url.parse-ipv4
function main() returns ExitCode
	let url = try URL.parse("http://192.168.1.1:3000/api") otherwise 'err'
		return 1
	end 'err'
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("{host}\n")
	let port = try url.port() otherwise 'np'
		return 3
	end 'np'
	print("{port}\n")
	print("{url.path()}\n")
	return 0
end 'main'

// Batch: url
// Tests: url.parse-basic, url.parse-path, url.parse-full, url.parse-userinfo, url.parse-ipv6, url.parse-mailto, url.parse-urn, url.parse-scheme-lowercase, url.parse-empty-query, url.parse-empty-fragment, url.parse-percent-encoding, url.parse-port, url.parse-file-uri, url.parse-scheme-chars, url.parse-relative, url.parse-protocol-relative, url.parse-ipv4, url.parse-userinfo-no-pass, url.parse-err-empty, url.parse-err-whitespace, url.parse-err-port-overflow, url.parse-err-port-alpha, url.parse-err-bad-percent, url.parse-err-truncated-percent, url.parse-err-colon-start, url.parse-err-digit-scheme, url.tostring-basic, url.tostring-full, url.tostring-userinfo, url.tostring-mailto, url.tostring-ipv6, url.tostring-file, url.resolve-relative, url.resolve-dot, url.resolve-dotdot, url.resolve-absolute, url.resolve-authority, url.resolve-query-only, url.resolve-fragment-only, url.resolve-empty, url.resolve-full-relative, url.resolve-double-dotdot
---
// Test: url.parse-basic
function main() returns ExitCode
	let url = try URL.parse("https://example.com") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
https
```
---
// Test: url.parse-path
function main() returns ExitCode
	let url = try URL.parse("https://example.com/path/to/resource") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	let host = try url.host() otherwise 'nohost'
		return 2
	end 'nohost'
	print("{host}\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
https
example.com
/path/to/resource
```
---
// Test: url.parse-full
function main() returns ExitCode
	let url = try URL.parse("https://example.com:8080/path?query=value#frag") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("{host}\n")
	let port = try url.port() otherwise 'np'
		return 3
	end 'np'
	print("{port}\n")
	print("{url.path()}\n")
	let query = try url.query() otherwise 'nq'
		return 4
	end 'nq'
	print("{query}\n")
	let frag = try url.fragment() otherwise 'nf'
		return 5
	end 'nf'
	print("{frag}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
https
example.com
8080
/path
query=value
frag
```
---

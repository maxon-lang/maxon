// Test: mixed-operators
function main() returns ExitCode
	let a = 10
	let b = 3
	return a * 2 + b - 1
end 'main'
---
ExitCode: 22
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 22
    x64.mov ebx, 3
    x64.mov ebx, 10
    x64.epilogue
    x64.ret
  }
}
---

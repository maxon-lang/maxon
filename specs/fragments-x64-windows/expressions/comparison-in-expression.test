// Test: comparison-in-expression
function main() returns ExitCode
	let isGreater = 10 > 5
	if isGreater 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 10
    x64.cmp r8, 5
    x64.jle check_1.after
  check_1:
    x64.mov r8d, 1
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

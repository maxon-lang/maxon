// Test: comparison-in-expression
function main() returns ExitCode
	let isGreater = 10 > 5
	if isGreater 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @expressions.main() -> u8 {
  entry:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.ret
  }
}

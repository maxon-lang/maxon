// Test: multiple-variables
function main() returns ExitCode
	let x = 42
	let y = 10
	let result = x + y
	return result
end 'main'
---
ExitCode: 52
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 52
    x64.mov ebx, 10
    x64.mov ebx, 42
    x64.epilogue
    x64.ret
  }
}
---

// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 4
    x64.mov ecx, 3
    x64.call with-function-call.add
    x64.mov r9d, 5
    x64.add r9, r8
    x64.cmp r9, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @with-function-call.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r9, rcx
    x64.mov r8, r9
    x64.add r8, rdx
    x64.ret
  }
}
---

// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	var x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 3
    x64.mov rdx, 4
    x64.call with-function-call.add
    x64.mov rcx, 5
    x64.add rcx, rax
    x64.mov rax, 4294967295
    x64.cmp rcx, rax
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
  func @with-function-call.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.add rcx, rdx
    x64.mov rax, -9223372036854775807
    x64.cmp rcx, rax
    x64.jge __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

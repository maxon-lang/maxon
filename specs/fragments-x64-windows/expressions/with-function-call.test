// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 3
    x64.mov rdx, 4
    x64.call with-function-call.add
    x64.mov rbx, 5
    x64.mov rsi, rbx
    x64.add rsi, rax
    x64.cmp rsi, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rsi
    x64.epilogue
    x64.ret
  }
  func @with-function-call.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.add rcx, rdx
    x64.mov rax, rcx
    x64.ret
  }
}
---

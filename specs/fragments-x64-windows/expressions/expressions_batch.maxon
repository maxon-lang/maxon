// --- batched test: compound ---
function _b_compound_main() returns ExitCode
	return (2 + 3) * 5
end '_b_compound_main'

// --- batched test: with-function-call ---

typealias _b_with_function_call_Integer = int(i64.min to i64.max)

function _b_with_function_call_main() returns ExitCode
	let x = 3
	return 5 + _b_with_function_call_add(x, b: 4)
end '_b_with_function_call_main'

function _b_with_function_call_add(a _b_with_function_call_Integer, b _b_with_function_call_Integer) returns _b_with_function_call_Integer
	return a + b
end '_b_with_function_call_add'

// --- batched test: multiple-variables ---
function _b_multiple_variables_main() returns ExitCode
	let x = 42
	let y = 10
	let result = x + y
	return result
end '_b_multiple_variables_main'

// --- batched test: mixed-operators ---
function _b_mixed_operators_main() returns ExitCode
	let a = 10
	let b = 3
	return a * 2 + b - 1
end '_b_mixed_operators_main'

// --- batched test: comparison-in-expression ---
function _b_comparison_in_expression_main() returns ExitCode
	let isGreater = 10 > 5
	if isGreater 'check'
		return 1
	end 'check'
	return 0
end '_b_comparison_in_expression_main'

// --- batch dispatcher for expressions ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:compound>>>\n")
	let ec_compound = _b_compound_main()
	print("\n<<<MAXON_BATCH_TEST_END:compound:{ec_compound}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:with-function-call>>>\n")
	let ec_with_function_call = _b_with_function_call_main()
	print("\n<<<MAXON_BATCH_TEST_END:with-function-call:{ec_with_function_call}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multiple-variables>>>\n")
	let ec_multiple_variables = _b_multiple_variables_main()
	print("\n<<<MAXON_BATCH_TEST_END:multiple-variables:{ec_multiple_variables}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:mixed-operators>>>\n")
	let ec_mixed_operators = _b_mixed_operators_main()
	print("\n<<<MAXON_BATCH_TEST_END:mixed-operators:{ec_mixed_operators}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:comparison-in-expression>>>\n")
	let ec_comparison_in_expression = _b_comparison_in_expression_main()
	print("\n<<<MAXON_BATCH_TEST_END:comparison-in-expression:{ec_comparison_in_expression}>>>\n")
	return 0 as ExitCode
end 'main'

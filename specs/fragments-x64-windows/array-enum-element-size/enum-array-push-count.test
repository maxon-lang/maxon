// Test: enum-array-push-count
typealias Integer = int(i64.min to i64.max)

union Op
		add(value Integer)
		sub(value Integer)
		nop
end 'Op'

typealias OpArray = Array with Op

function main() returns ExitCode
		var ops = OpArray.create()
		ops.push(Op.add(1))
		ops.push(Op.sub(2))
		ops.push(Op.nop)
		ops.push(Op.add(3))
		ops.push(Op.sub(4))
		return ops.count()
end 'main'

// Batch: enum-allcasenames
// Tests: enum-allcasenames.simple, enum-allcasenames.count, enum-allcasenames.int-backed, enum-allcasenames.string-backed, enum-allcasenames.union-simple, enum-allcasenames.union-associated, enum-allcasenames.single-case, enum-allcasenames.index
---
// Test: enum-allcasenames.simple
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	for name in Color.allCaseNames 'loop'
		print("{name}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
red
green
blue
```
---
// Test: enum-allcasenames.count
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let count = Color.allCaseNames.count()
	if count == 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: enum-allcasenames.int-backed
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	for name in HttpStatus.allCaseNames 'loop'
		print("{name}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
ok
notFound
serverError
```
---
// Test: enum-allcasenames.string-backed
enum ContentType
	json = "application/json"
	html = "text/html"
	plain = "text/plain"
end 'ContentType'

function main() returns ExitCode
	for name in ContentType.allCaseNames 'loop'
		print("{name}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
json
html
plain
```
---
// Test: enum-allcasenames.union-simple
union Signal
	start
	stop
	pause
end 'Signal'

function main() returns ExitCode
	for name in Signal.allCaseNames 'loop'
		print("{name}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
start
stop
pause
```
---
// Test: enum-allcasenames.union-associated
typealias Integer = int(i64.min to i64.max)

union Container
	empty
	value(n Integer)
	pair(a Integer, b Integer)
end 'Container'

function main() returns ExitCode
	for name in Container.allCaseNames 'loop'
		print("{name}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
empty
value
pair
```
---
// Test: enum-allcasenames.single-case
enum Singleton
	only
end 'Singleton'

function main() returns ExitCode
	let count = Singleton.allCaseNames.count()
	if count == 1 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: enum-allcasenames.index
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	let names = Direction.allCaseNames
	let first = try names.get(0) otherwise "?"
	print("{first}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
north
```

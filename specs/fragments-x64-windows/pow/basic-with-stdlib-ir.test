// Test: basic-with-stdlib-ir
function main() returns ExitCode
	let result = Math.pow(2.0, exponent: 3.0)
	return trunc(result)
end 'main'
---
IncludeStdlibIr: true
ExitCode: 8
---
// CompiledIR
module {
  func @mrt_start() {
  entry:
    x64.prologue stack_size=16
    x64.call __slab_init
    x64.call main
    x64.xor r9d, r9d
    x64.mov [rbp-8], r8
    x64.call_import slot_0
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm1, [rip+__float_4613937818241073152]
    x64.movsd xmm0, [rip+__float_4611686018427387904]
    x64.call Math.pow
    x64.cvttsd2si r8, xmm0
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

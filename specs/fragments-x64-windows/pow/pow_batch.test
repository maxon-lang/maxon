// Batch: pow
// Tests: basic, square, zero-exponent, fractional-exponent, int-promotion, docs-example-1
---
// Test: basic
function main() returns ExitCode
	let result = Math.pow(2.0, exponent: 3.0)
	return trunc(result)
end 'main'
---
ExitCode: 8
---
// Test: square
function main() returns ExitCode
	let result = Math.pow(5.0, exponent: 2.0)
	return trunc(result)
end 'main'
---
ExitCode: 25
---
// Test: zero-exponent
function main() returns ExitCode
	let result = Math.pow(123.0, exponent: 0.0)
	return trunc(result)
end 'main'
---
ExitCode: 1
---
// Test: fractional-exponent
function main() returns ExitCode
	let result = Math.pow(4.0, exponent: 0.5)  // Square root
	print("{result}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1.999999
```
---
// Test: int-promotion
function main() returns ExitCode
	let result = Math.pow(3, exponent: 2)  // Ints promoted to float
	return trunc(result)
end 'main'
---
ExitCode: 9
---
// Test: docs-example-1

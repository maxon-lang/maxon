    x64.mov r9d, 3
    x64.cvtsi2sd xmm1, r8
    x64.cvtsi2sd xmm0, r9
    x64.call Math.pow
    x64.mov r9d, 4294967295
    x64.cvttsd2si r8, xmm0
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

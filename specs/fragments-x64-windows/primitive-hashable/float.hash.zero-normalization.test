// Test: float.hash.zero-normalization
function main() returns ExitCode
	let pos = 0.0
	let neg = -0.0
	let h1 = pos.hash()
	let h2 = neg.hash()
	if h1 == h2 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0]
    x64.call float.hash
    x64.mov r12, r8
    x64.movsd xmm1, [rip+__float_0]
    x64.movsd xmm0, [rip+__float_0]
    x64.subsd xmm0, xmm1
    x64.call float.hash
    x64.cmp r12, r8
    x64.jne eq_0.after
  eq_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  eq_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

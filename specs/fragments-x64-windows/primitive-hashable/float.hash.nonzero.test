// Test: float.hash.nonzero
function main() returns ExitCode
	let f = 3.14
	let h = f.hash()
	if h != 0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4614253070214989087]
    x64.call float.hash
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

// Test: float.hash.nonzero
function main() returns ExitCode
	let f = 3.14
	let h = f.hash()
	if h != 0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @primitive-hashable.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.14]
    x64.call stdlib.float.hash
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.je primitive-hashable.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

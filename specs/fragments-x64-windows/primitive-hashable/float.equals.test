// Test: float.equals
function main() returns ExitCode
	let a = 3.14
	let b = 3.14
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.14]
    x64.movsd xmm1, [rip+__float_3.14]
    x64.call stdlib.float.equals
    x64.test rax, rax
    x64.je main.eq_0.after
  eq_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  eq_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

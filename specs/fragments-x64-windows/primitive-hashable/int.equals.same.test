// Test: int.equals.same
function main() returns ExitCode
	let a = 42
	let b = 42
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 42
    x64.mov rdx, 42
    x64.call stdlib.int.equals
    x64.test rax, rax
    x64.je main.eq_0.after
  eq_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  eq_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

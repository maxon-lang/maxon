    x64.mov [r8+0], r9 (8b)
  inlined_Value.isPositive_0:
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.jle inlined_Value.isPositive_2
  inlined_Value.isPositive_1:
    x64.mov r8d, 1
    x64.jmp inline_cont_main_0
  inlined_Value.isPositive_2:
    x64.xor r8d, r8d
  inline_cont_main_0:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

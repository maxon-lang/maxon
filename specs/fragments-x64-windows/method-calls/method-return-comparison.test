// Test: method-return-comparison

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer

	function isPositive() returns Integer
		if n > 0 'positive'
			return 1
		end 'positive'
		return 0
	end 'isPositive'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let v = Value.create(n: 42)
	return v.isPositive()
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @Value.isPositive(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov rcx, [rbp-8]
    x64.mov rbx, [rcx+0] (8b)
    x64.mov [rbp-16], rbx
    x64.test rbx, rbx
    x64.jle positive_1.after
  positive_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  positive_1.after:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
  func @Value.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [rbp-8], r8
    x64.mov [rbp-16], r12
    x64.mov r8, [rbp-8]
    x64.mov r12, [rbp-16]
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 42
    x64.call Value.create
    x64.mov rcx, r8
    x64.call Value.isPositive
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

    x64.mov r8, [rcx+0] (8b)
    x64.add r8, 1
    x64.mov [rcx+0], r8 (8b)
    x64.xor r8d, r8d
    x64.ret
  }
  func @Counter.get(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Counter.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @method-calls.main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.xor ecx, ecx
    x64.call Counter.create
    x64.mov r12, r8
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.get
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

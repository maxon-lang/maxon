// Test: method-call-void

typealias Integer = int(i64.min to i64.max)

type Counter
	var count Integer

	function increment()
		count = count + 1
	end 'increment'

	function get() returns Integer
		return count
	end 'get'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	let c = Counter.create(count: 0)
	c.increment()
	c.increment()
	c.increment()
	return c.get()
end 'main'
---
ExitCode: 3
---
module {
  func @Counter.increment(rcx: i64) {
  entry:
    x64.prologue stack_size=48
    x64.mov [rbp-8], rcx
    x64.mov rcx, [rbp-8]
    x64.mov rbx, [rcx+0] (8b)
    x64.mov [rbp-16], rbx
    x64.add rbx, 1
    x64.mov r8d, 0
    x64.mov [rbp-8], rcx
    x64.mov [rbp-24], rbx
    x64.mov rcx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rcx+0], rbx (8b)
    x64.epilogue
    x64.ret
  }
  func @Counter.get(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rcx, [rbp-8]
    x64.mov r8, [rcx+0] (8b)
    x64.mov [rbp-16], r8
    x64.epilogue
    x64.ret
  }
  func @Counter.create(rcx: i64) -> Counter {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [rbp-8], r8
    x64.mov [rbp-16], r12
    x64.mov r8, [rbp-8]
    x64.mov r12, [rbp-16]
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 0
    x64.call Counter.create
    x64.mov r12, r8
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.get
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

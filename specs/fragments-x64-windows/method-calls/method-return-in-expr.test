// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
	var value Integer

	function getValue() returns Integer
		return value
	end 'getValue'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function main() returns ExitCode
	let b = Box.create(value: 40)
	return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
module {
  func @Box.getValue(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rcx, [rbp-8]
    x64.mov r8, [rcx+0] (8b)
    x64.mov [rbp-16], r8
    x64.epilogue
    x64.ret
  }
  func @Box.create(rcx: i64) -> Box {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [rbp-8], r8
    x64.mov [rbp-16], r12
    x64.mov r8, [rbp-8]
    x64.mov r12, [rbp-16]
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 40
    x64.call Box.create
    x64.mov rcx, r8
    x64.call Box.getValue
    x64.mov rbx, r8
    x64.add rbx, 2
    x64.cmp rbx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, rbx
    x64.epilogue
    x64.ret
  }
}
---

// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
	var value Integer

	function getValue() returns Integer
		return value
	end 'getValue'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function main() returns ExitCode
	let b = Box.create(value: 40)
	return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 40
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, r9
    x64.add r8, 2
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_2]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

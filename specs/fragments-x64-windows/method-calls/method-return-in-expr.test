// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
	var value Integer

	function getValue() returns Integer
		return value
	end 'getValue'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function main() returns ExitCode
	let b = Box.create(value: 40)
	return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Box.getValue(rcx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, r9
    x64.ret
  }
  func @Box.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r9, r8
    x64.mov [r9+0], r12 (8b)
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @method-calls.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 40
    x64.mov rcx, r8
    x64.call Box.create
    x64.mov rcx, r8
    x64.call Box.getValue
    x64.add r8, 2
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea r8, [rip+__panic_msg_2]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

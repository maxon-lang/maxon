// Test: method-named-args-reorder

typealias Integer = int(i64.min to i64.max)

type Calculator
	var result Integer

	function compute(a Integer, b Integer, c Integer)
		result = a + b * c
	end 'compute'

	function get() returns Integer
		return result
	end 'get'

	static function create(result Integer) returns Self
		return Self{result: result}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	let calc = Calculator.create(result: 0)
	calc.compute(10, c: 4, b: 8)
	return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.compute(rcx: i64, rdx: i64, rax: i64, r9: i64) {
  entry:
    x64.prologue stack_size=64
    x64.mov rbx, rcx
    x64.mov rsi, rdx
    x64.mov rdi, rax
    x64.mov rax, rdi
    x64.imul rax, r9
    x64.mov rdx, rsi
    x64.add rdx, rax
    x64.mov r8d, 0
    x64.mov [rbp-8], rbx
    x64.mov [rbp-16], rdx
    x64.mov rbx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.mov [rbx+0], rdx (8b)
    x64.mov [rbp-8], rbx
    x64.mov rbx, [rbp-8]
    x64.mov rsi, [rbx+0] (8b)
    x64.mov [rbp-24], rsi
    x64.epilogue
    x64.ret
  }
  func @Calculator.get(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rcx, [rbp-8]
    x64.mov r8, [rcx+0] (8b)
    x64.mov [rbp-16], r8
    x64.epilogue
    x64.ret
  }
  func @Calculator.create(rcx: i64) -> Calculator {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [rbp-8], r8
    x64.mov [rbp-16], r12
    x64.mov r8, [rbp-8]
    x64.mov r12, [rbp-16]
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 0
    x64.call Calculator.create
    x64.mov r12, r8
    x64.mov r9d, 8
    x64.mov eax, 4
    x64.mov edx, 10
    x64.mov rcx, r12
    x64.call Calculator.compute
    x64.mov rcx, r12
    x64.call Calculator.get
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 125
    x64.jbe __range_ok_7
  __range_panic_7:
    x64.lea rcx, [rip+__panic_msg_7]
    x64.call mrt_panic
  __range_ok_7:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

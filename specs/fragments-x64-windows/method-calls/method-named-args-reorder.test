    x64.mov eax, 8
    x64.mov edx, 10
    x64.mov rcx, r12
    x64.call Calculator.compute
    x64.mov rcx, r12
    x64.call Calculator.get
    x64.cmp r8, 125
    x64.jbe __range_ok_7
  __range_panic_7:
    x64.lea rcx, [rip+__panic_msg_7]

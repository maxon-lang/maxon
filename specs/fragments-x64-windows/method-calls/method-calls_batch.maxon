// --- batched test: method-multiple-args ---

typealias _b_method_multiple_args_Integer = int(i64.min to i64.max)

type _b_method_multiple_args_Calculator
	var result _b_method_multiple_args_Integer

	function addTwo(a _b_method_multiple_args_Integer, b _b_method_multiple_args_Integer)
		result = result + a + b
	end 'addTwo'

	function get() returns _b_method_multiple_args_Integer
		return result
	end 'get'

	static function create(result _b_method_multiple_args_Integer) returns Self
		return Self{result: result}
	end 'create'
end '_b_method_multiple_args_Calculator'

function _b_method_multiple_args_main() returns ExitCode
	var calc = _b_method_multiple_args_Calculator.create(result: 0)
	calc.addTwo(20, b: 22)
	return calc.get()
end '_b_method_multiple_args_main'

// --- batched test: method-call-on-field-access ---

typealias _b_method_call_on_field_access_Integer = int(i64.min to i64.max)

type _b_method_call_on_field_access_Inner
	var value _b_method_call_on_field_access_Integer

	function get() returns _b_method_call_on_field_access_Integer
		return value
	end 'get'

	static function create(value _b_method_call_on_field_access_Integer) returns Self
		return Self{value: value}
	end 'create'
end '_b_method_call_on_field_access_Inner'

type _b_method_call_on_field_access_Outer
	var inner _b_method_call_on_field_access_Inner

	function getInnerValue() returns _b_method_call_on_field_access_Integer
		return inner.get()
	end 'getInnerValue'

	static function create(inner _b_method_call_on_field_access_Inner) returns Self
		return Self{inner: inner}
	end 'create'
end '_b_method_call_on_field_access_Outer'

function _b_method_call_on_field_access_main() returns ExitCode
	let o = _b_method_call_on_field_access_Outer.create(inner: _b_method_call_on_field_access_Inner.create(value: 42))
	return o.getInnerValue()
end '_b_method_call_on_field_access_main'

// --- batched test: method-modify-multiple-fields ---

typealias _b_method_modify_multiple_fields_Integer = int(i64.min to i64.max)

type _b_method_modify_multiple_fields_Point
	var x _b_method_modify_multiple_fields_Integer
	var y _b_method_modify_multiple_fields_Integer

	function moveBy(dx _b_method_modify_multiple_fields_Integer, dy _b_method_modify_multiple_fields_Integer)
		x = x + dx
		y = y + dy
	end 'moveBy'

	function sum() returns _b_method_modify_multiple_fields_Integer
		return x + y
	end 'sum'

	static function create(x _b_method_modify_multiple_fields_Integer, y _b_method_modify_multiple_fields_Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end '_b_method_modify_multiple_fields_Point'

function _b_method_modify_multiple_fields_main() returns ExitCode
	var p = _b_method_modify_multiple_fields_Point.create(x: 10, y: 10)
	p.moveBy(10, dy: 12)
	return p.sum()
end '_b_method_modify_multiple_fields_main'

// --- batched test: method-return-comparison ---

typealias _b_method_return_comparison_Integer = int(i64.min to i64.max)

type _b_method_return_comparison_Value
	var n _b_method_return_comparison_Integer

	function isPositive() returns _b_method_return_comparison_Integer
		if n > 0 'positive'
			return 1
		end 'positive'
		return 0
	end 'isPositive'

	static function create(n _b_method_return_comparison_Integer) returns Self
		return Self{n: n}
	end 'create'
end '_b_method_return_comparison_Value'

function _b_method_return_comparison_main() returns ExitCode
	let v = _b_method_return_comparison_Value.create(n: 42)
	return v.isPositive()
end '_b_method_return_comparison_main'

// --- batched test: method-named-args-reorder ---

typealias _b_method_named_args_reorder_Integer = int(i64.min to i64.max)

type _b_method_named_args_reorder_Calculator
	var result _b_method_named_args_reorder_Integer

	function compute(a _b_method_named_args_reorder_Integer, b _b_method_named_args_reorder_Integer, c _b_method_named_args_reorder_Integer)
		result = a + b * c
	end 'compute'

	function get() returns _b_method_named_args_reorder_Integer
		return result
	end 'get'

	static function create(result _b_method_named_args_reorder_Integer) returns Self
		return Self{result: result}
	end 'create'
end '_b_method_named_args_reorder_Calculator'

function _b_method_named_args_reorder_main() returns ExitCode
	var calc = _b_method_named_args_reorder_Calculator.create(result: 0)
	calc.compute(10, c: 4, b: 8)
	return calc.get()
end '_b_method_named_args_reorder_main'

// --- batched test: static-method-named-args ---

typealias _b_static_method_named_args_Integer = int(i64.min to i64.max)

type _b_static_method_named_args_Factory
	static function create(x _b_static_method_named_args_Integer, y _b_static_method_named_args_Integer) returns _b_static_method_named_args_Integer
		return x * 10 + y
	end 'create'
end '_b_static_method_named_args_Factory'

function _b_static_method_named_args_main() returns ExitCode
	return _b_static_method_named_args_Factory.create(4, y: 2)
end '_b_static_method_named_args_main'


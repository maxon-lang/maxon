// --- batched test: method-call-void ---

typealias _b_method_call_void_Integer = int(i64.min to i64.max)

type _b_method_call_void_Counter
	var count _b_method_call_void_Integer

	function increment()
		count = count + 1
	end 'increment'

	function get() returns _b_method_call_void_Integer
		return count
	end 'get'

	static function create(count _b_method_call_void_Integer) returns Self
		return Self{count: count}
	end 'create'
end '_b_method_call_void_Counter'

function _b_method_call_void_main() returns ExitCode
	var c = _b_method_call_void_Counter.create(count: 0)
	c.increment()
	c.increment()
	c.increment()
	return c.get()
end '_b_method_call_void_main'

// --- batched test: method-call-with-args ---

typealias _b_method_call_with_args_Integer = int(i64.min to i64.max)

type _b_method_call_with_args_Adder
	var total _b_method_call_with_args_Integer

	function add(n _b_method_call_with_args_Integer)
		total = total + n
	end 'add'

	function get() returns _b_method_call_with_args_Integer
		return total
	end 'get'

	static function create(total _b_method_call_with_args_Integer) returns Self
		return Self{total: total}
	end 'create'
end '_b_method_call_with_args_Adder'

function _b_method_call_with_args_main() returns ExitCode
	var a = _b_method_call_with_args_Adder.create(total: 0)
	a.add(10)
	a.add(20)
	a.add(12)
	return a.get()
end '_b_method_call_with_args_main'


module {
  func @Calculator.addTwo(rcx: i64, rdx: i64, rax: i64) {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.add r8, rdx
    x64.add r8, rax
    x64.mov [rcx+0], r8 (8b)
    x64.ret
  }
  func @Calculator.get(rcx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, r9
    x64.ret
  }
  func @Calculator.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r9, r8
    x64.mov [r9+0], r12 (8b)
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @method-calls.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov rcx, r8
    x64.call Calculator.create
    x64.mov r12, r8
    x64.mov r8d, 22
    x64.mov r9d, 20
    x64.mov rcx, r12
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call Calculator.addTwo
    x64.mov rcx, r12
    x64.call Calculator.get
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_3]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }

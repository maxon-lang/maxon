    x64.add rdi, rax
    x64.mov [rbx+0], rdi (8b)
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
  func @Calculator.get(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)

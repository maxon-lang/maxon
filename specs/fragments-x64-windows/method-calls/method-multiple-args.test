// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
	var result Integer

	function addTwo(a Integer, b Integer)
		result = result + a + b
	end 'addTwo'

	function get() returns Integer
		return result
	end 'get'

	static function create(result Integer) returns Self
		return Self{result: result}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	var calc = Calculator.create(result: 0)
	calc.addTwo(20, b: 22)
	return calc.get()
end 'main'
---
ExitCode: 42
---
module {
  func @Calculator.addTwo(__self_ptr: i64, a: i64, b: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rbx, [rax+0]
    x64.add rbx, rdx
    x64.add rbx, r8
    x64.mov rax, [rbp-8]
    x64.mov [rax+0], rbx
    x64.epilogue
    x64.ret
  }
  func @Calculator.get(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @Calculator.create(result: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor rcx, rcx
    x64.call Calculator.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 20
    x64.mov r8, 22
    x64.call Calculator.addTwo
    x64.mov rcx, [rbp-8]
    x64.call Calculator.get
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rcx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Calculator(ptr: i64) {
  entry:
    x64.jmp __destruct_Calculator.done
  done:
    x64.ret
  }
}

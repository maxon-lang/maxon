// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
	var result Integer

	function addTwo(a Integer, b Integer)
		result = result + a + b
	end 'addTwo'

	function get() returns Integer
		return result
	end 'get'

	static function create(result Integer) returns Self
		return Self{result: result}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	var calc = Calculator.create(result: 0)
	calc.addTwo(20, b: 22)
	return calc.get()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.add r9, 20
    x64.add r9, 22
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea rcx, [rip+__panic_msg_3]
    x64.call mrt_panic
  __range_ok_3:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

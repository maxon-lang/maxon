  func @Calculator.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 0
    x64.call Calculator.create
    x64.mov r12, r8
    x64.mov eax, 22
    x64.mov edx, 20
    x64.mov rcx, r12
    x64.call Calculator.addTwo
    x64.mov rcx, r12
    x64.call Calculator.get
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }

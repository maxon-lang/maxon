// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Inner'

type Outer
	var inner Inner

	function getInnerValue() returns Integer
		return inner.get()
	end 'getInnerValue'

	static function create(inner Inner) returns Self
		return Self{inner: inner}
	end 'create'
end 'Outer'

function main() returns ExitCode
	let o = Outer.create(inner: Inner.create(value: 42))
	return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Inner.get(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Inner.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @Outer.getInnerValue(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov rbx, [rcx+0] (8b)
    x64.mov rcx, rbx
    x64.call Inner.get
    x64.epilogue
    x64.ret
  }
  func @Outer.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 42
    x64.call Inner.create
    x64.mov rcx, r8
    x64.call Outer.create
    x64.mov rcx, r8
    x64.call Outer.getInnerValue
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

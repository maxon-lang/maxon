// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Inner'

type Outer
	var inner Inner

	function getInnerValue() returns Integer
		return inner.get()
	end 'getInnerValue'

	static function create(inner Inner) returns Self
		return Self{inner: inner}
	end 'create'
end 'Outer'

function main() returns ExitCode
	var o = Outer.create(inner: Inner.create(value: 42))
	return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
module {
  func @Inner.get(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @Inner.create(value: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @Outer.getInnerValue(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov [rbp-16], rdx
    x64.mov rcx, [rbp-16]
    x64.epilogue
    x64.jmp Inner.get
  }
  func @Outer.create(inner: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.lea_func rax, [__destruct_Outer]
    x64.mov rdx, rax
    x64.mov rcx, 8
    x64.mov r8, 2
    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.mov [rdx+0], rcx
    x64.call mm_incref
    x64.mov rbx, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 42
    x64.call Inner.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call Outer.create
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.call Outer.getInnerValue
    x64.xor rdx, rdx
    x64.mov rbx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rcx, [rbp-8]
    x64.mov [rbp-24], rax
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Inner(ptr: i64) {
  entry:
    x64.jmp __destruct_Inner.done
  done:
    x64.ret
  }
  func @__destruct_Outer(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.mov [rbp-16], rcx
    x64.test rcx, rcx
    x64.jz __nonnull_skip_2
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.jmp __destruct_Outer.done
  done:
    x64.epilogue
    x64.ret
  }
}

// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Inner'

type Outer
	var inner Inner

	function getInnerValue() returns Integer
		return inner.get()
	end 'getInnerValue'

	static function create(inner Inner) returns Self
		return Self{inner: inner}
	end 'create'
end 'Outer'

function main() returns ExitCode
	let o = Outer.create(inner: Inner.create(value: 42))
	return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 42
    x64.mov [r12+0], r8 (8b)
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, [r9+0] (8b)
    x64.cmp r8, 125
    x64.jbe __range_ok_4
  __range_panic_4:
    x64.lea r8, [rip+__panic_msg_4]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_4:
    x64.epilogue
    x64.ret
  }
}
---

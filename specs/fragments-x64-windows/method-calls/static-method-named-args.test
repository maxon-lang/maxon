// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
	static function create(x Integer, y Integer) returns Integer
		return x * 10 + y
	end 'create'
end 'Factory'

function main() returns ExitCode
	return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Factory.create(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r8d, 10
    x64.imul rcx, r8
    x64.mov r8, rcx
    x64.add r8, rdx
    x64.ret
  }
  func @method-calls.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 2
    x64.mov ecx, 4
    x64.call Factory.create
    x64.cmp r8, 125
    x64.jbe __range_ok_8
  __range_panic_8:
    x64.lea rcx, [rip+__panic_msg_8]
    x64.call mrt_panic
  __range_ok_8:
    x64.epilogue
    x64.ret
  }
}
---

// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
	static function create(x Integer, y Integer) returns Integer
		return x * 10 + y
	end 'create'
end 'Factory'

function main() returns ExitCode
	return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
module {
  func @Factory.create(x: i64, y: i64) -> i64 {
  entry:
    x64.mov rax, 10
    x64.imul rcx, rax
    x64.lea rax, [rcx + rdx]
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 4
    x64.mov rdx, 2
    x64.call Factory.create
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
	static function create(x Integer, y Integer) returns Integer
		return x * 10 + y
	end 'create'
end 'Factory'

function main() returns ExitCode
	return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
module {
  func @Factory.create(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rbx, rcx
    x64.mov esi, 10
    x64.mov rcx, rbx
    x64.imul rcx, rsi
    x64.mov rbx, rcx
    x64.add rbx, rdx
    x64.mov r8, rbx
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 2
    x64.mov ecx, 4
    x64.call Factory.create
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

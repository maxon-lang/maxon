// Test: bool.clone
function main() returns ExitCode
	var x = true
	if x.clone() 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.call stdlib.bool.clone
    x64.test rax, rax
    x64.je main.ok_0.after
  ok_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  ok_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

// Test: byte.clone

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let x = 65 as Byte
	let y = x.clone() as Integer
	return y
end 'main'
---
ExitCode: 65
---
// CompiledIR
module {
  func @primitive-cloneable.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 65
    x64.call stdlib.int.clone
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg primitive-cloneable.main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl primitive-cloneable.main.__range_panic_0
    x64.jmp primitive-cloneable.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

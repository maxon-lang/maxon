// Test: byte.clone

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let x = 65 as Byte
	let y = x.clone() as Integer
	return y
end 'main'
---
ExitCode: 65
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 65
    x64.ret
  }
}
---

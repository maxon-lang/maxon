// Batch: primitive-cloneable
// Tests: int.clone, float.clone, bool.clone, byte.clone
---
// Test: int.clone
function main() returns ExitCode
	let x = 42
	return x.clone()
end 'main'
---
ExitCode: 42
---
// Test: float.clone
function main() returns ExitCode
	let x = 3.14
	let y = x.clone()
	if y == 3.14 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: bool.clone
function main() returns ExitCode
	let x = true
	if x.clone() 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: byte.clone

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let x = 65 as Byte
	let y = x.clone() as Integer
	return y
end 'main'
---
ExitCode: 65
---

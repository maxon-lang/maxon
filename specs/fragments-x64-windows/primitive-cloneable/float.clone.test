// Test: float.clone
function main() returns ExitCode
	let x = 3.14
	let y = x.clone()
	if y == 3.14 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @primitive-cloneable.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.14]
    x64.call stdlib.float.clone
    x64.movsd xmm1, [rip+__float_3.14]
    x64.ucomisd xmm0, xmm1
    x64.jne primitive-cloneable.main.ok_0.after
    x64.jp primitive-cloneable.main.ok_0.after
  ok_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  ok_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

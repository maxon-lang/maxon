// Test: tuple-assign-in-loop
typealias Integer = int(i64.min to i64.max)

function step(n Integer) returns (Integer, Integer)
	return (n + 1, n * 2)
end 'step'

function main() returns ExitCode
	var a = 0
	var b = 0
	var i = 0
	while i < 3 'loop'
		(a, b) = step(n: a)
		i = i + 1
	end 'loop'
	return b
end 'main'

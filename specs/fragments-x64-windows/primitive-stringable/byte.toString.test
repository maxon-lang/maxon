// Test: byte.toString

typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let x = 65 as Byte
	let s = x.toString()
	if s == "65" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1

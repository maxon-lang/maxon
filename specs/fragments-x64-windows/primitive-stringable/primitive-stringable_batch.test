// Batch: primitive-stringable
// Tests: int.toString, float.toString, bool.toString.true, bool.toString.false, byte.toString
---
// Test: int.toString
function main() returns ExitCode
	let x = 42
	let s = x.toString()
	if s == "42" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: float.toString
function main() returns ExitCode
	let x = 3.14
	let s = x.toString()
	if s == "3.14" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: bool.toString.true
function main() returns ExitCode
	let x = true
	let s = x.toString()
	if s == "true" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: bool.toString.false
function main() returns ExitCode
	let x = false
	let s = x.toString()
	if s == "false" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: byte.toString

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let x = 65 as Byte
	let s = x.toString()
	if s == "65" 'ok'
		return 1
	end 'ok'
	return 0
end 'main'
---
ExitCode: 1
---

    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 1
    x64.mov rdx, 2
    x64.call Point.create
    x64.mov [rbp-8], rax
    x64.mov [rbp-16], rax
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rcx, 99
    x64.mov rdx, [rbp-16]
    x64.mov [rdx+0], rcx
    x64.mov rbx, [rbp-8]
    x64.mov rsi, [rbx+0]
    x64.xor rdi, rdi
    x64.mov r8, 4294967295
    x64.cmp rsi, r8
    x64.jg main.__range_panic_0
    x64.cmp rsi, rdi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rsi
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Point(ptr: i64) {
  entry:
    x64.jmp __destruct_Point.done
  done:
    x64.ret
  }
}

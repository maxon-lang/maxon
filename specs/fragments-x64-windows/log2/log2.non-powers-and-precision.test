// Test: log2.non-powers-and-precision
function main() returns ExitCode
	// Non-powers of 2 require high precision
	let r3 = Math.log2(3.0)
	let r5 = Math.log2(5.0)
	let r6 = Math.log2(6.0)
	let r1000000 = Math.log2(1000000.0)
	
	print("{r3}\n")
	print("{r5}\n")
	print("{r6}\n")
	print("{r1000000}\n")
	
	return 0
end 'main'

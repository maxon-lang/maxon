    x64.je __destruct___ManagedMemory_Byte.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct___ManagedMemory_Byte.skip_buf_0
  skip_buf_0:

// Test: overwrite-element
typealias Int = int(i64.min to i64.max)
typealias Vec3 = Vector with 3 Int

function main() returns ExitCode
	var v = Vec3.create()
	v.set(1, value: 10)
	v.set(1, value: 42)
	return try v.get(1) otherwise 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.call Vec3.create
    x64.mov [rbp-8], rax

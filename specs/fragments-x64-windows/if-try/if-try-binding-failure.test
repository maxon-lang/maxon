// Test: if-try-binding-failure

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
	if not succeed 'check'
		throw MyError.failed
	end 'check'
	return 42
end 'mayFail'

function main() returns ExitCode
	if let value = try mayFail(false) 'check'
		return value
	end 'check'
	return 99
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
  inlined_mayFail_0:
    x64.mov r9d, 1
    x64.xor r8, r9
    x64.je inlined_mayFail_2
  inlined_mayFail_1:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.jmp inline_cont_main_0
  inlined_mayFail_2:
    x64.xor edx, edx
    x64.mov r8d, 42
  inline_cont_main_0:
    x64.test rdx, rdx
    x64.jne check_0.after
  check_0:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  check_0.after:
    x64.mov r8d, 99
    x64.epilogue
    x64.ret
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

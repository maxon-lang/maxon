// Test: if-try-in-loop

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail(n Integer) returns Integer throws MyError
	if n < 3 'check'
		throw MyError.failed
	end 'check'
	return n
end 'mayFail'

function main() returns ExitCode
	var sum = 0
	var i = 0
	while i < 5 'loop'
		if let val = try mayFail(i) 'check'
			sum = sum + val
		end 'check'
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.xor r9d, r9d
    x64.xchg r8, r9
  loop_0.header:
    x64.cmp r9, 5
    x64.jge loop_0.exit
  inlined_mayFail_0:
    x64.cmp r9, 3
    x64.jge inlined_mayFail_2
  inlined_mayFail_1:
    x64.mov edx, 1
    x64.xor esi, esi
    x64.jmp inline_cont_main_0
  inlined_mayFail_2:
    x64.xor edx, edx
    x64.mov rsi, r9
  inline_cont_main_0:
    x64.test rdx, rdx
    x64.jne check_0.after
    x64.jmp check_0
  loop_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  check_0:
    x64.add r8, rsi
  check_0.after:
    x64.add r9, 1
    x64.jmp loop_0.header
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

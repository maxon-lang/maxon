// Test: if-try-binding-with-else

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail(succeed bool) returns Integer throws MyError
	if not succeed 'check'
		throw MyError.failed
	end 'check'
	return 42
end 'mayFail'

function main() returns ExitCode
	if let value = try mayFail(false) 'check'
		return value
	end 'check' else 'err'
		return 77
	end 'err'
end 'main'
---
ExitCode: 77
---
// CompiledIR
module {
  func @if-try.mayFail(succeed: i1) -> i64 {
  entry:
    x64.mov rax, 1
    x64.xor rcx, rax
    x64.test rcx, rcx
    x64.je if-try.mayFail.check_0.after
  check_0:
    x64.xor eax, eax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.ret
  check_0.after:
    x64.mov rax, 42
    x64.xor edx, edx
    x64.ret
  }
  func @if-try.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor ecx, ecx
    x64.call if-try.mayFail
    x64.mov [rbp-8], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.jne if-try.main.err_0
  check_0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg if-try.main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl if-try.main.__range_panic_0
    x64.jmp if-try.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  err_0:
    x64.mov rax, 77
    x64.epilogue
    x64.ret
  }
}
---

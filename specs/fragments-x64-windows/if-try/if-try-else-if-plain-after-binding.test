// Test: if-try-else-if-plain-after-binding

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail() returns Integer throws MyError
	throw MyError.failed
end 'mayFail'

function main() returns ExitCode
	let x = 2
	var result = 0
	if let v = try mayFail() 'check'
		result = v
	end 'check' else if x == 2 'two'
		result = 22
	end 'two' else 'fallback'
		result = 99
	end 'fallback'
	return result
end 'main'
---
ExitCode: 22
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
  check_0.else:
    x64.cmp r8, 2
    x64.jne fallback_0
  two_0:
    x64.mov r8d, 22
    x64.jmp two_0.merge
  fallback_0:
    x64.mov r8d, 99
  two_0.merge:
  check_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

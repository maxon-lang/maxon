    x64.ret
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_7d44e0d15a8a17b9]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

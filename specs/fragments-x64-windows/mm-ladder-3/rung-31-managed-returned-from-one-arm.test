mm_incref Box #2 rc=1 [Box.create]
mm_move Box #2 -> return [Box.create]
mm_decref Box #2 rc=0 [pick]
  mm_free Box #2
mm_move Box #1 -> return [pick]
mm_decref Box #1 rc=0 [main]
  mm_free Box #1

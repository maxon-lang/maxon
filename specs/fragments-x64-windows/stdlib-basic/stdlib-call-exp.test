// Test: stdlib-call-exp
function main() returns ExitCode
	let result = Math.exp(0.0)
	if result == 1.0 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0]
    x64.call Math.exp
    x64.movsd xmm1, [rip+__float_4607182418800017408]
    x64.ucomisd xmm0, xmm1
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

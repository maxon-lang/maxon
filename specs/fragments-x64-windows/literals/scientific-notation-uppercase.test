// Test: scientific-notation-uppercase
function main() returns ExitCode
	let x = 1.0E3
	return trunc(x) - 990
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4652007308841189376]
    x64.cvttsd2si rbx, xmm0
    x64.sub rbx, 990
    x64.cmp rbx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
}
---

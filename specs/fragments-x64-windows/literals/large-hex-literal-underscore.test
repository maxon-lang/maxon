// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
	var x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rax, 5368709120
    x64.mov rcx, 5368709120
    x64.cmp rax, rcx
    x64.jne check_1.after
  check_1:
    x64.xor rax, rax
    x64.ret
  check_1.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
	let x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8, 5368709120
    x64.mov r9, 5368709120
    x64.cmp r9, r8
    x64.jne check_1.after
  check_1:
    x64.xor r8d, r8d
    x64.ret
  check_1.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

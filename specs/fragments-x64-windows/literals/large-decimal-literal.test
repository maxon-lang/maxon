// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
	let x = 5368709120
	if x == 0x140000000 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rbx, 5368709120
    x64.mov rsi, 5368709120
    x64.cmp rsi, rbx
    x64.jne check_1.after
  check_1:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  check_1.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

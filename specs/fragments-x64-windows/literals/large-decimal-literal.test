// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
	let x = 5368709120
	if x == 0x140000000 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}
---

// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
	let x = 5368709120
	if x == 0x140000000 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8, 5368709120
    x64.mov r9, 5368709120
    x64.cmp r9, r8
    x64.jne check_1.after
  check_1:
    x64.xor r8d, r8d
    x64.ret
  check_1.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

// Batch: literals
// Tests: integer, hex-integer, hex-integer-uppercase, binary-integer, octal-integer, underscore-separator, hex-underscore, binary-underscore, large-hex-literal, large-hex-literal-underscore, int64-max, large-decimal-literal, float, boolean, scientific-notation-positive-exponent, scientific-notation-negative-exponent, scientific-notation-explicit-positive, scientific-notation-uppercase
---
// Test: integer
function main() returns ExitCode
	return 5
end 'main'
---
ExitCode: 5
---
// Test: hex-integer
function main() returns ExitCode
	return 0x7d
end 'main'
---
ExitCode: 125
---
// Test: hex-integer-uppercase
function main() returns ExitCode
	return 0x5A
end 'main'
---
ExitCode: 90
---
// Test: binary-integer
function main() returns ExitCode
	return 0b1010
end 'main'
---
ExitCode: 10
---
// Test: octal-integer
function main() returns ExitCode
	return 0o77
end 'main'
---
ExitCode: 63
---
// Test: underscore-separator
function main() returns ExitCode
	let x = 1_000
	return x - 990
end 'main'
---
ExitCode: 10
---
// Test: hex-underscore
function main() returns ExitCode
	return 0xff_ff - 65525
end 'main'
---
ExitCode: 10
---
// Test: binary-underscore
function main() returns ExitCode
	return 0b0101_1010
end 'main'
---
ExitCode: 90
---
// Test: large-hex-literal
// Test hex literal above 32-bit range (0x140000000 = 5368709120)
function main() returns ExitCode
	let x = 0x0000000140000000
	// Verify the value wasn't truncated to 32-bit (which would give 0x40000000 = 1073741824)
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
	let x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: int64-max
// Test INT64_MAX (9223372036854775807)
function main() returns ExitCode
	let x = 9223372036854775807
	if x > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: large-decimal-literal
// Test decimal literal above 32-bit range
function main() returns ExitCode
	let x = 5368709120
	if x == 0x140000000 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: float
function main() returns ExitCode
	let x = 3.14
	return trunc(x)
end 'main'
---
ExitCode: 3
---
// Test: boolean
function main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: scientific-notation-positive-exponent
function main() returns ExitCode
	let x = 1.5e2
	return trunc(x) - 140
end 'main'
---
ExitCode: 10
---
// Test: scientific-notation-negative-exponent
function main() returns ExitCode
	let x = 5.0e-1
	return trunc(x * 20.0)
end 'main'
---
ExitCode: 10
---
// Test: scientific-notation-explicit-positive
function main() returns ExitCode
	let x = 2.5e+02
	return trunc(x) - 240
end 'main'
---
ExitCode: 10
---
// Test: scientific-notation-uppercase
function main() returns ExitCode
	let x = 1.0E3
	return trunc(x) - 990
end 'main'
---
ExitCode: 10
---

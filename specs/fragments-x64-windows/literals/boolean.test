// Test: boolean
function main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 1
    x64.test r8, r8
    x64.je check_1.after
  check_1:
    x64.mov r8d, 1
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

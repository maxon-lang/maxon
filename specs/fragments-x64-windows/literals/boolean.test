// Test: boolean
function main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ebx, 1
    x64.test rbx, rbx
    x64.je check_1.after
  check_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_1.after:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

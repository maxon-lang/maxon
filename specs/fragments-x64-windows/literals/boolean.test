// Test: boolean
function main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @literals.main() -> u32 {
  entry:
    x64.mov rax, 1
    x64.test rax, rax
    x64.je literals.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

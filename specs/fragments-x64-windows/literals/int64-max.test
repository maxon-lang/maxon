// Test: int64-max
// Test INT64_MAX (9223372036854775807)
function main() returns ExitCode
	let x = 9223372036854775807
	if x > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 9223372036854775807
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jle main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

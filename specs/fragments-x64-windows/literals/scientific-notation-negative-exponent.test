// Test: scientific-notation-negative-exponent
function main() returns ExitCode
	let x = 5.0e-1
	return trunc(x * 20.0)
end 'main'
---
ExitCode: 10
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4626322717216342016]
    x64.movsd xmm1, [rip+__float_4602678819172646912]
    x64.movsd xmm2, xmm1
    x64.mulsd xmm2, xmm0
    x64.cvttsd2si rbx, xmm2
    x64.cmp rbx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
}

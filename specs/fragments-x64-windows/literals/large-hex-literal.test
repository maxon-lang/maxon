// Test: large-hex-literal
// Test hex literal above 32-bit range (0x140000000 = 5368709120)
function main() returns ExitCode
	let x = 0x0000000140000000
	// Verify the value wasn't truncated to 32-bit (which would give 0x40000000 = 1073741824)
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rbx, 5368709120
    x64.mov rsi, 5368709120
    x64.cmp rbx, rsi
    x64.jne check_1.after
  check_1:
    x64.xor rax, rax
    x64.ret
  check_1.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

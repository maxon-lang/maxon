// --- batched test: integer ---
function _b_integer_main() returns ExitCode
	return 5
end '_b_integer_main'

// --- batched test: hex-integer ---
function _b_hex_integer_main() returns ExitCode
	return 0x7d
end '_b_hex_integer_main'

// --- batched test: hex-integer-uppercase ---
function _b_hex_integer_uppercase_main() returns ExitCode
	return 0x5A
end '_b_hex_integer_uppercase_main'

// --- batched test: binary-integer ---
function _b_binary_integer_main() returns ExitCode
	return 0b1010
end '_b_binary_integer_main'

// --- batched test: octal-integer ---
function _b_octal_integer_main() returns ExitCode
	return 0o77
end '_b_octal_integer_main'

// --- batched test: underscore-separator ---
function _b_underscore_separator_main() returns ExitCode
	let x = 1_000
	return x - 990
end '_b_underscore_separator_main'

// --- batched test: hex-underscore ---
function _b_hex_underscore_main() returns ExitCode
	return 0xff_ff - 65525
end '_b_hex_underscore_main'

// --- batched test: binary-underscore ---
function _b_binary_underscore_main() returns ExitCode
	return 0b0101_1010
end '_b_binary_underscore_main'

// --- batched test: large-hex-literal ---
// Test hex literal above 32-bit range (0x140000000 = 5368709120)
function _b_large_hex_literal_main() returns ExitCode
	let x = 0x0000000140000000
	// Verify the value wasn't truncated to 32-bit (which would give 0x40000000 = 1073741824)
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end '_b_large_hex_literal_main'

// --- batched test: large-hex-literal-underscore ---
// Test large hex literal with underscore separators
function _b_large_hex_literal_underscore_main() returns ExitCode
	let x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end '_b_large_hex_literal_underscore_main'

// --- batched test: int64-max ---
// Test INT64_MAX (9223372036854775807)
function _b_int64_max_main() returns ExitCode
	let x = 9223372036854775807
	if x > 0 'check'
		return 0
	end 'check'
	return 1
end '_b_int64_max_main'

// --- batched test: large-decimal-literal ---
// Test decimal literal above 32-bit range
function _b_large_decimal_literal_main() returns ExitCode
	let x = 5368709120
	if x == 0x140000000 'check'
		return 0
	end 'check'
	return 1
end '_b_large_decimal_literal_main'

// --- batched test: float ---
function _b_float_main() returns ExitCode
	let x = 3.14
	return trunc(x)
end '_b_float_main'

// --- batched test: boolean ---
function _b_boolean_main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end '_b_boolean_main'

// --- batched test: scientific-notation-positive-exponent ---
function _b_scientific_notation_positive_exponent_main() returns ExitCode
	let x = 1.5e2
	return trunc(x) - 140
end '_b_scientific_notation_positive_exponent_main'

// --- batched test: scientific-notation-negative-exponent ---
function _b_scientific_notation_negative_exponent_main() returns ExitCode
	let x = 5.0e-1
	return trunc(x * 20.0)
end '_b_scientific_notation_negative_exponent_main'

// --- batched test: scientific-notation-explicit-positive ---
function _b_scientific_notation_explicit_positive_main() returns ExitCode
	let x = 2.5e+02
	return trunc(x) - 240
end '_b_scientific_notation_explicit_positive_main'

// --- batched test: scientific-notation-uppercase ---
function _b_scientific_notation_uppercase_main() returns ExitCode
	let x = 1.0E3
	return trunc(x) - 990
end '_b_scientific_notation_uppercase_main'

// --- batch dispatcher for literals ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:integer>>>\n")
	let ec_integer = _b_integer_main()
	print("\n<<<MAXON_BATCH_TEST_END:integer:{ec_integer}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:hex-integer>>>\n")
	let ec_hex_integer = _b_hex_integer_main()
	print("\n<<<MAXON_BATCH_TEST_END:hex-integer:{ec_hex_integer}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:hex-integer-uppercase>>>\n")
	let ec_hex_integer_uppercase = _b_hex_integer_uppercase_main()
	print("\n<<<MAXON_BATCH_TEST_END:hex-integer-uppercase:{ec_hex_integer_uppercase}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:binary-integer>>>\n")
	let ec_binary_integer = _b_binary_integer_main()
	print("\n<<<MAXON_BATCH_TEST_END:binary-integer:{ec_binary_integer}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:octal-integer>>>\n")
	let ec_octal_integer = _b_octal_integer_main()
	print("\n<<<MAXON_BATCH_TEST_END:octal-integer:{ec_octal_integer}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:underscore-separator>>>\n")
	let ec_underscore_separator = _b_underscore_separator_main()
	print("\n<<<MAXON_BATCH_TEST_END:underscore-separator:{ec_underscore_separator}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:hex-underscore>>>\n")
	let ec_hex_underscore = _b_hex_underscore_main()
	print("\n<<<MAXON_BATCH_TEST_END:hex-underscore:{ec_hex_underscore}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:binary-underscore>>>\n")
	let ec_binary_underscore = _b_binary_underscore_main()
	print("\n<<<MAXON_BATCH_TEST_END:binary-underscore:{ec_binary_underscore}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:large-hex-literal>>>\n")
	let ec_large_hex_literal = _b_large_hex_literal_main()
	print("\n<<<MAXON_BATCH_TEST_END:large-hex-literal:{ec_large_hex_literal}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:large-hex-literal-underscore>>>\n")
	let ec_large_hex_literal_underscore = _b_large_hex_literal_underscore_main()
	print("\n<<<MAXON_BATCH_TEST_END:large-hex-literal-underscore:{ec_large_hex_literal_underscore}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:int64-max>>>\n")
	let ec_int64_max = _b_int64_max_main()
	print("\n<<<MAXON_BATCH_TEST_END:int64-max:{ec_int64_max}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:large-decimal-literal>>>\n")
	let ec_large_decimal_literal = _b_large_decimal_literal_main()
	print("\n<<<MAXON_BATCH_TEST_END:large-decimal-literal:{ec_large_decimal_literal}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:float>>>\n")
	let ec_float = _b_float_main()
	print("\n<<<MAXON_BATCH_TEST_END:float:{ec_float}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:boolean>>>\n")
	let ec_boolean = _b_boolean_main()
	print("\n<<<MAXON_BATCH_TEST_END:boolean:{ec_boolean}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:scientific-notation-positive-exponent>>>\n")
	let ec_scientific_notation_positive_exponent = _b_scientific_notation_positive_exponent_main()
	print("\n<<<MAXON_BATCH_TEST_END:scientific-notation-positive-exponent:{ec_scientific_notation_positive_exponent}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:scientific-notation-negative-exponent>>>\n")
	let ec_scientific_notation_negative_exponent = _b_scientific_notation_negative_exponent_main()
	print("\n<<<MAXON_BATCH_TEST_END:scientific-notation-negative-exponent:{ec_scientific_notation_negative_exponent}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:scientific-notation-explicit-positive>>>\n")
	let ec_scientific_notation_explicit_positive = _b_scientific_notation_explicit_positive_main()
	print("\n<<<MAXON_BATCH_TEST_END:scientific-notation-explicit-positive:{ec_scientific_notation_explicit_positive}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:scientific-notation-uppercase>>>\n")
	let ec_scientific_notation_uppercase = _b_scientific_notation_uppercase_main()
	print("\n<<<MAXON_BATCH_TEST_END:scientific-notation-uppercase:{ec_scientific_notation_uppercase}>>>\n")
	return 0 as ExitCode
end 'main'

// Test: method-type-disambiguation
typealias Integer = int(i64.min to i64.max)

type Converter
	static function create() returns Self
		return Self{}
	end 'create'

	function convert(value Integer) returns Integer
		return value * 2
	end 'convert'

	function convert(value String) returns Integer
		return value.count()
	end 'convert'
end 'Converter'

function main() returns ExitCode
	let c = Converter.create()
	return c.convert(21)
end 'main'
---
ExitCode: 42
---
module {
  func @Converter.create() -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @Converter.convert$value_i64(__self_ptr: i64, value: i64) -> i64 {
  entry:
    x64.mov rax, 2
    x64.imul rdx, rax
    x64.mov rax, rdx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call Converter.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 21
    x64.call Converter.convert$value_i64
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rbx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Converter(ptr: i64) {
  entry:
    x64.jmp __destruct_Converter.done
  done:
    x64.ret
  }
}

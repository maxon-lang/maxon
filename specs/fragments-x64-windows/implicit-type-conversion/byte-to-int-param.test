// Test: byte-to-int-param

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function takeInt(x Integer) returns Integer
	return x
end 'takeInt'

function main() returns ExitCode
	let b = 42 as Byte
	return takeInt(b)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @implicit-type-conversion.takeInt(rcx: i64) -> i64 {
  entry:
    x64.mov r8, rcx
    x64.ret
  }
  func @implicit-type-conversion.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 42
    x64.call implicit-type-conversion.takeInt
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea rcx, [rip+__panic_msg_2]
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

// Test: int-to-byte-param-truncates

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function takeByte(x Byte) returns Integer
	return x as Integer
end 'takeByte'

function main() returns ExitCode
	return takeByte(300)
end 'main'
---
ExitCode: 44
---
// CompiledIR
module {
  func @implicit-type-conversion.takeByte(rcx: u8) -> i64 {
  entry:
    x64.mov r9, rcx
    x64.mov r8, r9
    x64.ret
  }
  func @implicit-type-conversion.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 44
    x64.mov rcx, r8
    x64.call implicit-type-conversion.takeByte
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_3]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}

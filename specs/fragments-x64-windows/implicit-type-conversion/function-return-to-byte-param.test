// Test: function-return-to-byte-param

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function getInt() returns Integer
	return 300
end 'getInt'

function takeByte(x Byte) returns Integer
	return x as Integer
end 'takeByte'

function main() returns ExitCode
	return takeByte(getInt())
end 'main'
---
ExitCode: 44
---
module {
  func @implicit-type-conversion.getInt() -> i64 {
  entry:
    x64.mov rax, 300
    x64.ret
  }
  func @implicit-type-conversion.takeByte(x: i8) -> i64 {
  entry:
    x64.mov rax, rcx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call implicit-type-conversion.getInt
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rcx, rax
    x64.call implicit-type-conversion.takeByte
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

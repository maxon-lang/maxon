// Batch: implicit-type-conversion
// Tests: int-literal-to-float-param, int-var-to-float-param, byte-to-int-param, int-to-byte-param-truncates, int-var-to-byte-param, float-to-int-param-truncates, float-to-byte-param, function-return-to-byte-param, expression-to-float-param, math-intrinsic-int-promotion, docs-example-1
---
// Test: int-literal-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
	return trunc(x)
end 'takeFloat'

function main() returns ExitCode
	return takeFloat(42)
end 'main'
---
ExitCode: 42
---
// Test: int-var-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
	return trunc(x)
end 'takeFloat'

function main() returns ExitCode
	let i = 42
	return takeFloat(i)
end 'main'
---
ExitCode: 42
---
// Test: byte-to-int-param

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function takeInt(x Integer) returns Integer
	return x
end 'takeInt'

function main() returns ExitCode
	let b = 42 as Byte
	return takeInt(b)
end 'main'
---
ExitCode: 42
---
// Test: int-to-byte-param-truncates

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function takeByte(x Byte) returns Integer
	return x as Integer
end 'takeByte'

function main() returns ExitCode
	return takeByte(300)
end 'main'
---
ExitCode: 44
---

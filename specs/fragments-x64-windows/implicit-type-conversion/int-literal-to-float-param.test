// Test: int-literal-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
	return trunc(x)
end 'takeFloat'

function main() returns ExitCode
	return takeFloat(42)
end 'main'
---
ExitCode: 42
---
module {
  func @implicit-type-conversion.takeFloat(x: f64) -> i64 {
  entry:
    x64.cvttsd2si rax, xmm0
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 42
    x64.cvtsi2sd xmm0, rax
    x64.call implicit-type-conversion.takeFloat
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

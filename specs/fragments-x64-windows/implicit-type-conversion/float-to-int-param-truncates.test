// Test: float-to-int-param-truncates

typealias Integer = int(i64.min to i64.max)

function takeInt(x Integer) returns Integer
	return x
end 'takeInt'

function main() returns ExitCode
	var f = 3.7
	return takeInt(f)
end 'main'
---
ExitCode: 3
---
module {
  func @implicit-type-conversion.takeInt(x: i64) -> i64 {
  entry:
    x64.mov rax, rcx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.7]
    x64.cvttsd2si rax, xmm0
    x64.mov rcx, rax
    x64.call implicit-type-conversion.takeInt
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: jump-table.four-cases-expression
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		let d = Direction.east
		let code = match d 'dir'
				north gives 10
				south gives 20
				east gives 30
				west gives 40
		end 'dir'
		return code
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 2
    x64.jmp dir_0.next0
  dir_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  dir_0.next0:
    x64.cmp r9, 1
    x64.jne dir_0.next1
  dir_0.case1:
    x64.mov r8d, 20
    x64.jmp dir_0.merge
  dir_0.next1:
    x64.cmp r9, 2
    x64.jne dir_0.next2
  dir_0.case2:
    x64.mov r8d, 30
    x64.jmp dir_0.merge
  dir_0.next2:
    x64.cmp r9, 3
    x64.jne dir_0.merge
  dir_0.case3:
    x64.mov r8d, 40
    x64.jmp dir_0.merge
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_baa85ebefbc77b97]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

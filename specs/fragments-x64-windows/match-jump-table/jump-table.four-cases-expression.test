// Test: jump-table.four-cases-expression
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		let d = Direction.east
		let code = match d 'dir'
				north gives 10
				south gives 20
				east gives 30
				west gives 40
		end 'dir'
		return code
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rax, 2
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.xor edx, edx
    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rcx
    x64.mov rbx, [rbp-24]
    x64.jump_table rbx, 4 cases, default=main.dir_0.merge
  dir_0.case0:
    x64.mov rax, 10
    x64.mov [rbp-16], rax
    x64.jmp main.dir_0.merge
  dir_0.case1:
    x64.mov rax, 20
    x64.mov [rbp-16], rax
    x64.jmp main.dir_0.merge
  dir_0.case2:
    x64.mov rax, 30
    x64.mov [rbp-16], rax
    x64.jmp main.dir_0.merge
  dir_0.case3:
    x64.mov rax, 40
    x64.mov [rbp-16], rax
    x64.jmp main.dir_0.merge
  dir_0.merge:
    x64.mov rax, [rbp-16]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

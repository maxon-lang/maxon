// Batch: match-jump-table
// Tests: jump-table.four-cases-statement, jump-table.four-cases-expression, jump-table.seven-cases-first, jump-table.seven-cases-last, jump-table.seven-cases-middle, jump-table.five-cases-with-print, jump-table.default-panic, jump-table.enum-with-associated-values
---
// Test: jump-table.four-cases-statement
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		let d = Direction.west
		match d 'dir'
				north then print("N")
				south then print("S")
				east then print("E")
				west then print("W")
		end 'dir'
		return 0
end 'main'
---
Stdout: ```
W
```
---
// Test: jump-table.four-cases-expression
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		let d = Direction.east
		let code = match d 'dir'
				north gives 10
				south gives 20
				east gives 30
				west gives 40
		end 'dir'
		return code
end 'main'
---
ExitCode: 30
---
// Test: jump-table.seven-cases-first
enum Weekday
		mon
		tue
		wed
		thu
		fri
		sat
		sun
end 'Weekday'

function main() returns ExitCode
		let w = Weekday.mon
		let name = match w 'w'
				mon gives "Monday"
				tue gives "Tuesday"
				wed gives "Wednesday"
				thu gives "Thursday"
				fri gives "Friday"
				sat gives "Saturday"
				sun gives "Sunday"
		end 'w'
		print(name)
		return 0
end 'main'
---
Stdout: ```
Monday
```
---
// Test: jump-table.seven-cases-last
enum Weekday
		mon
		tue
		wed
		thu
		fri
		sat
		sun
end 'Weekday'

function main() returns ExitCode
		let w = Weekday.sun
		let name = match w 'w'
				mon gives "Monday"
				tue gives "Tuesday"
				wed gives "Wednesday"
				thu gives "Thursday"
				fri gives "Friday"
				sat gives "Saturday"
				sun gives "Sunday"
		end 'w'

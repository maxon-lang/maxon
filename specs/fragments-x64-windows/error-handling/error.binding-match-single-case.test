// Test: error.binding-match-single-case

typealias Integer = int(i64.min to i64.max)

// Test matching on typed error binding
enum MyError implements Error
	failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
	counter = counter + 1
	throw MyError.failed
end 'mayFail'

function main() returns ExitCode
	var result = 0
	try mayFail() otherwise (e) 'handler'
		match e 'check'
			failed then result = 42
		end 'check'
	end 'handler'
	return result
end 'main'
---
ExitCode: 42
---
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x64.mov rax, qword [rip+counter]
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov qword [rip+counter], rax
    x64.xor edx, edx
    x64.mov rbx, 1
    x64.add rdx, rbx
    x64.xor eax, eax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.call error-handling.mayFail
    x64.mov [rbp-16], rdx
    x64.xor ecx, ecx
    x64.cmp rdx, rcx
    x64.je main.otherwise_continue_1
  otherwise_error_0:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 1
    x64.sub rax, rcx
    x64.mov [rbp-24], rax
    x64.jmp main.check_4.cmp0
  check_4.cmp0:
    x64.mov rax, [rbp-24]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne main.check_4.merge
  check_4.case0:
    x64.mov rax, 42
    x64.mov [rbp-8], rax
    x64.jmp main.check_4.merge
  check_4.merge:
  otherwise_continue_1:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_5
    x64.cmp rax, rcx
    x64.jl main.__range_panic_5
    x64.jmp main.__range_ok_5
  __range_panic_5:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_5:
    x64.epilogue
    x64.ret
  }
}
---

    x64.mov rcx, 42
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je error-handling.main.otherwise_default_continue_0
  otherwise_default_error_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp error-handling.main.otherwise_default_continue_0
  otherwise_default_continue_0:
    x64.mov rax, [rbp-16]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg error-handling.main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl error-handling.main.__range_panic_0
    x64.jmp error-handling.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

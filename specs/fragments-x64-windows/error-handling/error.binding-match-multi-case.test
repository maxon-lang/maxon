  c2_0:
    x64.mov rax, 1
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  c2_0.after:
    x64.mov rax, 2
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
  func @error-handling.main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov rcx, 2
    x64.call error-handling.mayFail
    x64.mov [rbp-16], rdx
    x64.xor ecx, ecx
    x64.cmp rdx, rcx

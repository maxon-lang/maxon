    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, qword [rip+counter]
    x64.mov rdx, 1
    x64.add rax, rdx
    x64.mov qword [rip+counter], rax
    x64.mov rax, 1
    x64.cmp rcx, rax
    x64.jne error-handling.mayFail.c1_0.after
  c1_0:
    x64.xor eax, eax

// Test: error.binding-match-multi-case

typealias Integer = int(i64.min to i64.max)

// Test matching on error binding with multiple cases
enum MyError implements Error
	failed
	timeout
	notFound
end 'MyError'

var counter = 0 as Integer

function mayFail(code Integer) returns Integer throws MyError
	counter = counter + 1
	if code == 1 'c1'
		throw MyError.failed
	end 'c1'
	if code == 2 'c2'
		throw MyError.timeout
	end 'c2'
	throw MyError.notFound
end 'mayFail'

function main() returns ExitCode
	var result = 0
	try mayFail(2) otherwise (e) 'handler'
		match e 'check'
			failed then result = 10
			timeout then result = 20
			notFound then result = 30
		end 'check'
	end 'handler'
	return result
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @mayFail(rcx: i64) -> i64 {
  entry:
    x64.lea r8, [rip+__data_counter]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_counter]
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
    x64.cmp rcx, 1
    x64.jne c1_0.after
  c1_0:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.ret
  c1_0.after:
    x64.cmp rcx, 2
    x64.jne c2_0.after
  c2_0:
    x64.mov edx, 2
    x64.xor r8d, r8d
    x64.ret
  c2_0.after:
    x64.mov edx, 3
    x64.xor r8d, r8d
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 2
    x64.call mayFail
    x64.xor r9d, r9d
    x64.test rdx, rdx
    x64.je __phi_trampoline_0_0
  try_0.otherwise:
    x64.sub rdx, 1
    x64.test rdx, rdx
    x64.jne check_0.next0
    x64.jmp check_0.case0
  check_0.merge:
    x64.xor r9d, r9d
    x64.jmp try_0.merge
  check_0.case0:
    x64.mov r8d, 10
    x64.jmp check_0.merge
  check_0.next0:
    x64.cmp rdx, 1
    x64.jne check_0.next1
  check_0.case1:
    x64.mov r8d, 20
    x64.jmp check_0.merge
  check_0.next1:
    x64.cmp rdx, 2
    x64.jne __phi_trampoline_7_0
  check_0.case2:
    x64.mov r8d, 30
    x64.jmp check_0.merge
  try_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_6e7341df317252c2]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  __phi_trampoline_0_0:
    x64.xchg r8, r9
    x64.jmp try_0.merge
  __phi_trampoline_7_0:
    x64.mov r8, r9
    x64.jmp check_0.merge
  }
}

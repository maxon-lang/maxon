// Test: error.propagate-error-to-caller

typealias Integer = int(i64.min to i64.max)

// Test error propagation: inner function throws, middle propagates, outer handles with otherwise
enum MyError implements Error
	failed
end 'MyError'

function inner() returns Integer throws MyError
	throw MyError.failed
end 'inner'

function middle() returns Integer throws MyError
	let x = try inner()
	return x
end 'middle'

function main() returns ExitCode
	let x = try middle() otherwise 99
	return x
end 'main'
---
ExitCode: 99
---
module {
  func @error-handling.inner() -> i64 {
  entry:
    x64.xor rax, rax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor rax, rax
    x64.ret
  }
  func @error-handling.middle() -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.call error-handling.inner
    x64.mov [rbp-8], rdx
    x64.mov [rbp-16], rax
    x64.xor rax, rax
    x64.cmp rdx, rax
    x64.je error-handling.middle.try_continue_1
  propagate_error_0:
    x64.mov rdx, [rbp-8]
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  try_continue_1:
    x64.mov rax, [rbp-16]
    x64.xor rdx, rdx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call error-handling.middle
    x64.mov rcx, 99
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rax
    x64.xor rax, rax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-16]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_4
    x64.cmp rax, rcx
    x64.jl main.__range_panic_4
    x64.jmp main.__range_ok_4
  __range_panic_4:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_4:
    x64.epilogue
    x64.ret
  }
}
---

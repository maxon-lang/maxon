    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor edx, edx
    x64.mov r8, 4
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @error-handling.makeBox(flag: i1) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.je error-handling.makeBox.check_0.after
  check_0:
    x64.xor eax, eax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rcx, 7
    x64.call Box.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.xor edx, edx
    x64.epilogue
    x64.ret
  }
  func @error-handling.getBoxValue(flag: i1) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.call error-handling.makeBox
    x64.mov [rbp-8], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je error-handling.getBoxValue.otherwise_continue_1
  otherwise_stmt_0:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_6
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_6
    x64.mov rax, -1
    x64.epilogue
    x64.ret
  otherwise_continue_1:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rdx, [rbp-16]
    x64.mov rax, [rdx+0]
    x64.mov rbx, [rbp-8]
    x64.mov [rbp-24], rax
    x64.test rbx, rbx
    x64.jz __nonnull_skip_7
    x64.mov rcx, [rbp-8]

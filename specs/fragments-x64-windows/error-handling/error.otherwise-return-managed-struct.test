// Test: error.otherwise-return-managed-struct

typealias Integer = int(i64.min to i64.max)

// Regression: when a try call returns a heap-managed struct and the otherwise
// branch returns early, the uninitialized __try_result_ slot must not be
// decref'd on the error path (would crash mm_decref with garbage pointer).
enum MyError implements Error
	failed
end 'MyError'

type Box
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function makeBox(flag bool) returns Box throws MyError
	if flag 'check'
		throw MyError.failed
	end 'check'
	return Box.create(value: 7)
end 'makeBox'

function getBoxValue(flag bool) returns Integer
	let box = try makeBox(flag) otherwise return -1
	return box.value
end 'getBoxValue'

function main() returns ExitCode
	let good = getBoxValue(false)
	if good == 7 'g'
		let bad = getBoxValue(true)
		if bad == -1 'b'
			return 0
		end 'b'
	end 'g'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @makeBox(rcx: i1) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.je check_0.after
  check_0:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 7
    x64.mov [r8+0], r9 (8b)
    x64.xor edx, edx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor ecx, ecx
  inlined_getBoxValue_0:
    x64.call makeBox
    x64.test rdx, rdx
    x64.je inlined_getBoxValue_2
  inlined_getBoxValue_1:
    x64.mov r8d, 1
    x64.neg r8
    x64.mov r9, r8
    x64.jmp inline_cont_main_0
  inlined_getBoxValue_2:
    x64.mov r9, [r8+0] (8b)
  inline_cont_main_0:
    x64.cmp r9, 7
    x64.jne g_0.after
  g_0:
    x64.mov ecx, 1
  inlined_getBoxValue_0:
    x64.call makeBox
    x64.test rdx, rdx
    x64.je inlined_getBoxValue_2
  inlined_getBoxValue_1:
    x64.mov r8d, 1
    x64.neg r8
    x64.mov r9, r8
    x64.jmp inline_cont_main_1
  inlined_getBoxValue_2:
    x64.mov r9, [r8+0] (8b)
  inline_cont_main_1:
    x64.mov r8d, 1
    x64.neg r8
    x64.cmp r9, r8
    x64.jne g_0.after
  b_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  g_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

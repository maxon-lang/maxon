    x64.test rdx, rdx
    x64.je __phi_trampoline_0_0
  try_0.otherwise:
    x64.mov r8, [rdx+0] (8b)
    x64.test r8, r8
    x64.jne check_0.next0
    x64.jmp check_0.case0
  check_0.merge:
    x64.jmp try_0.merge
  check_0.case0:
    x64.mov r8, [rdx+8] (8b)
    x64.jmp check_0.merge
  check_0.next0:
    x64.mov r8, [rdx+0] (8b)
    x64.mov r8d, 1
    x64.mov r8, r9
    x64.jmp check_0.merge
  try_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]

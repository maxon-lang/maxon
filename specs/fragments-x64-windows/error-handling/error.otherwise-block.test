// Test: error.otherwise-block

typealias Integer = int(i64.min to i64.max)

// Test try otherwise block handler
enum MyError implements Error
	failed
end 'MyError'

var counter = 0 as Integer

function mayFail() returns Integer throws MyError
	counter = counter + 1
	throw MyError.failed
end 'mayFail'

function main() returns ExitCode
	var result = 0
	try mayFail() otherwise 'err'
		result = 42
	end 'err'
	return result
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_counter]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_counter]
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
  try_0.otherwise:
    x64.xor r8d, r8d
    x64.mov r9d, 42
    x64.xchg r8, r9
  try_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.xor r9d, r9d
    x64.xor esi, esi
    x64.test r8, r8
    x64.je __phi_trampoline_0_0
  try_0.otherwise:
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.jne check1_0.next0
    x64.jmp check1_0.case0
  check1_0.merge:
    x64.mov rdi, r8
    x64.mov r9, rsi
    x64.jmp try_0.merge
  check1_0.case0:
    x64.mov r9, [r8+8] (8b)
    x64.add r9, 0
    x64.mov r8, r9
    x64.jmp check1_0.merge
  check1_0.next0:
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 1
    x64.jne __phi_trampoline_5_0
  check1_0.case1:
    x64.mov r8, rsi
    x64.add r8, 1
    x64.jmp check1_0.merge
  try_0.merge:
    x64.mov r9d, 1
    x64.xor eax, eax
    x64.test r9, r9
    x64.je __phi_trampoline_8_0
  try_1.otherwise:
    x64.sub r9, 1
    x64.test r9, r9
    x64.jne check2_0.merge
    x64.jmp check2_0.case0
  check2_0.merge:
    x64.mov r8, rdi
    x64.mov rax, rsi
    x64.jmp try_1.merge
  check2_0.case0:
    x64.add rdi, 35
    x64.jmp check2_0.merge
  try_1.merge:
    x64.mov r9d, 4294967295

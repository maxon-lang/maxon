// Test: error.otherwise-return

typealias Integer = int(i64.min to i64.max)

// Single-statement otherwise: return on error
enum MyError implements Error
	failed
end 'MyError'

function mayFail() returns Integer throws MyError
	throw MyError.failed
end 'mayFail'

function runIt() returns Integer
	let value = try mayFail() otherwise return -1
	return value
end 'runIt'

function main() returns ExitCode
	let v = runIt()
	if v == -1 'check'
		return 99
	end 'check'
	return 0
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @error-handling.mayFail() -> i64 {
  entry:
    x64.xor eax, eax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor eax, eax
    x64.ret
  }
  func @error-handling.runIt() -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.call error-handling.mayFail
    x64.mov [rbp-8], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je error-handling.runIt.otherwise_continue_1
  otherwise_stmt_0:
    x64.mov rax, -1
    x64.epilogue
    x64.ret
  otherwise_continue_1:
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call error-handling.runIt
    x64.mov rcx, -1
    x64.cmp rax, rcx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 99
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

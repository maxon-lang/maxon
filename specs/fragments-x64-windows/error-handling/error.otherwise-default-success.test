    x64.test r8, r8
    x64.je inlined_mayFail_2_0
  inlined_mayFail_1_0:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.jmp inline_cont_main_0
  inlined_mayFail_2_0:
    x64.xor edx, edx
    x64.mov r8d, 100
  inline_cont_main_0:
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 42
  try_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_c8d9c82a5836ae5f]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: error.otherwise-default-success

typealias Integer = int(i64.min to i64.max)

// Test try otherwise when no error occurs
enum MyError implements Error
	failed
end 'MyError'

function mayFail(shouldFail bool) returns Integer throws MyError
	if shouldFail 'check'
		throw MyError.failed
	end 'check'
	return 100
end 'mayFail'

function main() returns ExitCode
	let val = try mayFail(false) otherwise 42
	return val
end 'main'
---
ExitCode: 100
---
module {
  func @error-handling.mayFail(shouldFail: i1) -> i64 {
  entry:
    x64.test rcx, rcx
    x64.je error-handling.mayFail.check_0.after
  check_0:
    x64.xor rax, rax
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, rax
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 100
    x64.xor rdx, rdx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor rcx, rcx
    x64.call error-handling.mayFail
    x64.mov rcx, 42
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rax
    x64.xor rax, rax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-16]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_4
    x64.cmp rax, rcx
    x64.jl main.__range_panic_4
    x64.jmp main.__range_ok_4
  __range_panic_4:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_4:
    x64.epilogue
    x64.ret
  }
}
---

    x64.cmp r8, 42
    x64.jne checkGood_0.after
  checkGood_0:
    x64.mov r8d, 1
  inlined_error-handling.runIt_0:
    x64.test r8, r8
    x64.je inlined_error-handling.runIt_2
  inlined_error-handling.runIt_1:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.jmp inlined_error-handling.runIt_3
  inlined_error-handling.runIt_2:
    x64.xor edx, edx
    x64.mov r8d, 42
  inlined_error-handling.runIt_3:
    x64.test rdx, rdx
    x64.je inline_cont_main_1
  inlined_error-handling.runIt_4:
    x64.mov r8d, 1
    x64.neg r8
  inline_cont_main_1:
    x64.mov r9d, 1
    x64.neg r9
    x64.cmp r8, r9
    x64.jne checkGood_0.after
  checkBad_0:
    x64.mov r8d, 7

// Batch: string-type
// Tests: basic-declaration, empty-string, long-string, inequality, equality-with-logical-and, print-string, print-literal, string-interpolation-concatenation, count-method, isEmpty-method, startsWith, endsWith, contains, find, find-last-basic, find-last-single, find-last-not-found, find-last-at-end, find-last-at-start, find-last-overlapping, replace-single, replace-multiple, replace-no-match, replace-empty-needle, replace-with-empty, replace-adjacent, replaceFirst-single, replaceFirst-multiple-occurrences, replaceFirst-no-match, for-in-string, byteview-iteration, utf16-ascii, utf16-bmp, utf16-surrogate-pair, utf16-mixed, utf16-length, utf16-is-lead-surrogate, utf16-is-trail-surrogate, utf16-is-surrogate, utf16-width, utf16-encode-surrogates, utf16-decode-surrogates, utf16-is-bmp, utf16-valid-surrogate-pair, heap-string-data-access, heap-string-equality, heap-string-inequality, heap-string-iteration, string-double-iteration, heap-string-byteview, memory-tracking-simple-interp, memory-tracking-chained-interp, memory-tracking-loop-interp, memory-tracking-no-leak-scope-exit, toLower, bytes-count-method, bytes-count-multibyte, count-graphemes, count-vs-bytes-count, grapheme-iteration-emoji, grapheme-iteration-flag, grapheme-iteration-zwj, codepoints-view, string-reassignment, slice-basic, slice-full, slice-empty, slice-iteration, clone-isolates-string-mutation, clone-preserves-original, cow-slice-independent, string-append-basic, string-append-interp, string-append-loop, string-append-variable, string-append-implicit-loop, string-append-multi-parts
---
// Test: basic-declaration
function main() returns ExitCode
	let s = "hello"
	if s == "hello" 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: empty-string
function main() returns ExitCode
	let s = ""
	if s == "" 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: long-string
function main() returns ExitCode
	let s = "this string is longer than fifteen bytes"
	if s == "this string is longer than fifteen bytes" 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: inequality
function main() returns ExitCode
	let s = "hello"
	if s != "world" 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: equality-with-logical-and
function main() returns ExitCode
	let s = "hello"
	let c = 'A'
	if s == "hello" and c == 'A' 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0

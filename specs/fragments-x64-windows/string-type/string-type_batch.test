	// 😀 U+1F600 = 128512
	print("{utf16LeadSurrogate(128512)}\n")   // 55357 (0xD83D)
	print("{utf16TrailSurrogate(128512)}\n")  // 56832 (0xDE00)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
55357

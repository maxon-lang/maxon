// Test: memory-tracking-loop-interp
function main() returns ExitCode
	var s = ""
	let x = "x"
	var i = 0
	while i < 3 'loop'
		s = "{s}{x}"
		i = i + 1
	end 'loop'
	print("{s.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```

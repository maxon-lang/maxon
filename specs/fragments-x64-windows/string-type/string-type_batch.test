	let s = "hello world"
	let idx = try s.findFirst("world") otherwise s.endIndex()
	print("{idx.charIndex()}\n")
	let idx2 = try s.findFirst("xyz") otherwise s.endIndex()
	if idx2 == s.endIndex() 'not_found'
		print("-1\n")
	end 'not_found'
	return 0
end 'main'

// Test: find-last-not-found
function main() returns ExitCode
	let s = "hello world"
	if try s.findLast("xyz") 'found'
		print("FOUND\n")
	end 'found' else 'not_found'
		print("NOT_FOUND\n")
	end 'not_found'
	return 0
end 'main'

// Test: self-method-call-in-closure

typealias Integer = int(i64.min to i64.max)

typealias FnTypeAlias1 = function(Integer) returns Integer
function apply(f FnTypeAlias1, x Integer) returns Integer
	return f(x)
end 'apply'

type Doubler
	export var base Integer

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'

	function doubled() returns Integer
		return self.base + self.base
	end 'doubled'

	export function run() returns Integer
		return apply(function(_ Integer) gives self.doubled(), x: 0)
	end 'run'
end 'Doubler'

function main() returns ExitCode
	let d = Doubler.create(5)
	return d.run()
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @Doubler.run(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.lea rax, [rbp-8]
    x64.mov r9, [rbp-16]
    x64.mov [r8+0], r9 (8b)
    x64.xor ecx, ecx
    x64.lea r12, [rip+_$closure_0]
    x64.mov rdx, r8
    x64.call r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 5
    x64.mov [r8+0], r9 (8b)
    x64.mov rcx, r8
    x64.call Doubler.run
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: self-method-call-in-closure

typealias Integer = int(i64.min to i64.max)

function apply(f (Integer) returns Integer, x Integer) returns Integer
	return f(x)
end 'apply'

type Doubler
	export var base Integer

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'

	function doubled() returns Integer
		return self.base + self.base
	end 'doubled'

	export function run() returns Integer
		return apply(f: (_ Integer) gives self.doubled(), x: 0)
	end 'run'
end 'Doubler'

function main() returns ExitCode
	let d = Doubler.create(base: 5)
	return d.run()
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @closure-self.apply(rcx: i64, rdx: i64, rax: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov rcx, rax
    x64.call r12
    x64.epilogue
    x64.ret
  }
  func @Doubler.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @Doubler.doubled(rcx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, [rcx+0] (8b)
    x64.add r8, r9
    x64.ret
  }
  func @Doubler.run(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.lea rax, [rbp-8]
    x64.mov r9, [rbp-16]
    x64.mov [r8+0], r9 (8b)
    x64.xor eax, eax
    x64.lea rcx, [rip+__closure_1]
    x64.mov rdx, r8
    x64.call closure-self.apply
    x64.epilogue
    x64.ret
  }
  func @closure-self.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5
    x64.call Doubler.create
    x64.mov rcx, r8
    x64.call Doubler.run
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_1]
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

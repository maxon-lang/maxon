    x64.call mrt_alloc
    x64.lea rax, [rbp-8]
    x64.mov r9, [rbp-16]
    x64.mov [r8+0], r9 (8b)
    x64.xor ecx, ecx
    x64.lea r12, [rip+_$closure_0]
    x64.mov rdx, r8
    x64.call r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 7
    x64.mov [r8+0], r9 (8b)
    x64.mov rcx, r8
    x64.call Holder.readViaClosure
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

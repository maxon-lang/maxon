// Test: short-type.u16-global-write
typealias U16 = int(0 to 65535)

var counter = 0 as U16

function main() returns ExitCode
	counter = 99 as U16
	return counter
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @short-type.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 99
    x64.mov qword [rip+counter], rax
    x64.mov rcx, qword [rip+counter]
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg short-type.main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl short-type.main.__range_panic_0
    x64.jmp short-type.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

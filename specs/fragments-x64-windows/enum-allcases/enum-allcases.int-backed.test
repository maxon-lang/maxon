// Test: enum-allcases.int-backed
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	for status in HttpStatus.allCases 'loop'
		print("{status.name}={status.rawValue}\n")
	end 'loop'
	return 0
end 'main'

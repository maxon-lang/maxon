// Test: named-args-multiply

typealias Integer = int(i64.min to i64.max)

function multiply(x Integer, y Integer) returns Integer
	return x * y
end 'multiply'

function main() returns ExitCode
	return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @parameter-labels.main() -> u8 {
  entry:
    x64.mov r9d, 42
    x64.mov r8, r9
    x64.ret
  }
}
---

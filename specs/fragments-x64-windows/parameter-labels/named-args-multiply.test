// Test: named-args-multiply

typealias Integer = int(i64.min to i64.max)

function multiply(x Integer, y Integer) returns Integer
	return x * y
end 'multiply'

function main() returns ExitCode
	return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @parameter-labels.multiply(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r8, rcx
    x64.imul r8, rdx
    x64.ret
  }
  func @parameter-labels.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 7
    x64.mov ecx, 6
    x64.call parameter-labels.multiply
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_1]
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}

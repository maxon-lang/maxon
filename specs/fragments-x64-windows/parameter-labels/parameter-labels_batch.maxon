// --- batched test: named-args ---

typealias _b_named_args_Integer = int(i64.min to i64.max)

function _b_named_args_add(a _b_named_args_Integer, b _b_named_args_Integer) returns _b_named_args_Integer
	return a + b
end '_b_named_args_add'

function _b_named_args_main() returns ExitCode
	return _b_named_args_add(a: 3, b: 4)
end '_b_named_args_main'

// --- batched test: named-args-multiply ---

typealias _b_named_args_multiply_Integer = int(i64.min to i64.max)

function _b_named_args_multiply_multiply(x _b_named_args_multiply_Integer, y _b_named_args_multiply_Integer) returns _b_named_args_multiply_Integer
	return x * y
end '_b_named_args_multiply_multiply'

function _b_named_args_multiply_main() returns ExitCode
	return _b_named_args_multiply_multiply(x: 6, y: 7)
end '_b_named_args_multiply_main'

// --- batched test: named-args-any-order ---

typealias _b_named_args_any_order_Integer = int(i64.min to i64.max)

function _b_named_args_any_order_subtract(a _b_named_args_any_order_Integer, b _b_named_args_any_order_Integer) returns _b_named_args_any_order_Integer
	return a - b
end '_b_named_args_any_order_subtract'

function _b_named_args_any_order_main() returns ExitCode
	return _b_named_args_any_order_subtract(b: 3, a: 10)
end '_b_named_args_any_order_main'

// --- batched test: docs-example-1 ---
typealias _b_docs_example_1_Score = int(i64.min to i64.max)

function _b_docs_example_1_add(a _b_docs_example_1_Score, b _b_docs_example_1_Score) returns _b_docs_example_1_Score
	return a + b
end '_b_docs_example_1_add'

function _b_docs_example_1_main() returns ExitCode
	return _b_docs_example_1_add(a: 3, b: 4)
end '_b_docs_example_1_main'

// --- batched test: docs-example-2 ---
typealias _b_docs_example_2_Score = int(i64.min to i64.max)

function _b_docs_example_2_subtract(a _b_docs_example_2_Score, b _b_docs_example_2_Score) returns _b_docs_example_2_Score
	return a - b
end '_b_docs_example_2_subtract'

function _b_docs_example_2_main() returns ExitCode
	return _b_docs_example_2_subtract(b: 3, a: 10)
end '_b_docs_example_2_main'

// --- batch dispatcher for parameter-labels ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:named-args>>>\n")
	let ec_named_args = _b_named_args_main()
	print("\n<<<MAXON_BATCH_TEST_END:named-args:{ec_named_args}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:named-args-multiply>>>\n")
	let ec_named_args_multiply = _b_named_args_multiply_main()
	print("\n<<<MAXON_BATCH_TEST_END:named-args-multiply:{ec_named_args_multiply}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:named-args-any-order>>>\n")
	let ec_named_args_any_order = _b_named_args_any_order_main()
	print("\n<<<MAXON_BATCH_TEST_END:named-args-any-order:{ec_named_args_any_order}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:docs-example-1>>>\n")
	let ec_docs_example_1 = _b_docs_example_1_main()
	print("\n<<<MAXON_BATCH_TEST_END:docs-example-1:{ec_docs_example_1}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:docs-example-2>>>\n")
	let ec_docs_example_2 = _b_docs_example_2_main()
	print("\n<<<MAXON_BATCH_TEST_END:docs-example-2:{ec_docs_example_2}>>>\n")
	return 0 as ExitCode
end 'main'

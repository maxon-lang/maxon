// Test: named-args-any-order

typealias Integer = int(i64.min to i64.max)

function subtract(a Integer, b Integer) returns Integer
	return a - b
end 'subtract'

function main() returns ExitCode
	return subtract(b: 3, a: 10)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 7
    x64.ret
  }
}
---

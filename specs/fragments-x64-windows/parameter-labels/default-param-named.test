// Test: default-param-named

typealias Integer = int(i64.min to i64.max)

function repeat(value Integer, times Integer = 1) returns Integer
	return value * times
end 'repeat'

function main() returns ExitCode
	return repeat(7, times: 6)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
}
---

// Test: named-args

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(a: 3, b: 4)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 7
    x64.mov r8, r9
    x64.ret
  }
}
---

// Batch: byte-string-literal
// Tests: byte-string-literal.basic, byte-string-literal.empty, byte-string-literal.escape-sequences, byte-string-literal.content, byte-string-literal.map-key, byte-string-literal.top-level-map, byte-string-literal.top-level-map-struct, byte-string-literal.field-access
---
// Test: byte-string-literal.basic
function main() returns ExitCode
		let bytes = b"hello"
		return bytes.count()
end 'main'
---
ExitCode: 5
---
// Test: byte-string-literal.empty
function main() returns ExitCode
		let bytes = b""
		return bytes.count()
end 'main'
---
ExitCode: 0
---
// Test: byte-string-literal.escape-sequences
function main() returns ExitCode
		let bytes = b"a\nb"
		return bytes.count()
end 'main'
---
ExitCode: 3
---
// Test: byte-string-literal.content
function main() returns ExitCode
		let bytes = b"AB"
		let a = try bytes.get(0) otherwise 0
		let b = try bytes.get(1) otherwise 0
		print("{a} {b}")
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
65 66
```
---
// Test: byte-string-literal.map-key
function main() returns ExitCode
		let m = [b"hello": 1, b"world": 2]
		let v1 = try m.get(key: b"hello") otherwise 0
		let v2 = try m.get(key: b"world") otherwise 0
		print("{v1} {v2}")
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1 2
```
---
// Test: byte-string-literal.top-level-map
var m = [b"hello": 1, b"world": 2]

function main() returns ExitCode
		let v1 = try m.get(key: b"hello") otherwise 0
		let v2 = try m.get(key: b"world") otherwise 0
		print("{v1} {v2}")
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1 2
```
---
// Test: byte-string-literal.top-level-map-struct
typealias Integer = int(i64.min to i64.max)

type Info
		export var value Integer

		static function create(value Integer) returns Self
			return Self{value: value}
		end 'create'
end 'Info'

var m = [b"hello": Info.create(value: 10), b"world": Info.create(value: 20)]

function main() returns ExitCode
		let v1 = try m.get(key: b"hello") otherwise Info.create(value: 0)
		let v2 = try m.get(key: b"world") otherwise Info.create(value: 0)
		print("{v1.value} {v2.value}")
		return 0
end 'main'
---
ExitCode: 0
Stdout: ```
10 20
```
---
// Test: byte-string-literal.field-access
function main() returns ExitCode
		let len = b"test".count()
		return len
end 'main'
---
ExitCode: 4
---

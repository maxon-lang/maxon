// Test: struct-backing-match
typealias Latency = int(0 to 50)

type Meta
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'Meta'

enum TestOp
	add = Meta.create(latency: 1)
	sub = Meta.create(latency: 1)
	mul = Meta.create(latency: 3)
end 'TestOp'

function main() returns ExitCode
	let op = TestOp.sub
	return match op 'dispatch'
		add gives 10
		sub gives 20
		mul gives 30
	end 'dispatch'
end 'main'
---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rax, 1
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.xor rdx, rdx
    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rcx
    x64.jmp main.dispatch_0.cmp0
  dispatch_0.cmp0:
    x64.mov rax, [rbp-24]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.dispatch_0.cmp1
  dispatch_0.case0:
    x64.mov rax, 10
    x64.mov [rbp-16], rax
    x64.jmp main.dispatch_0.merge
  dispatch_0.cmp1:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.dispatch_0.cmp2
  dispatch_0.case1:
    x64.mov rax, 20
    x64.mov [rbp-16], rax
    x64.jmp main.dispatch_0.merge
  dispatch_0.cmp2:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.dispatch_0.merge
  dispatch_0.case2:
    x64.mov rax, 30
    x64.mov [rbp-16], rax
    x64.jmp main.dispatch_0.merge
  dispatch_0.merge:
    x64.mov rax, [rbp-16]
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

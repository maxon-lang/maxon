// Test: struct-backing-match
typealias Latency = int(0 to 50)

type Meta
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'Meta'

enum TestOp
	add = Meta.create(latency: 1)
	sub = Meta.create(latency: 1)
	mul = Meta.create(latency: 3)
end 'TestOp'

function main() returns ExitCode
	let op = TestOp.sub
	return match op 'dispatch'
		add gives 10
		sub gives 20
		mul gives 30
	end 'dispatch'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 1
    x64.jmp dispatch_0.next0
  dispatch_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  dispatch_0.next0:
    x64.cmp r9, 1
    x64.jne dispatch_0.next1
  dispatch_0.case1:
    x64.mov r8d, 20
    x64.jmp dispatch_0.merge
  dispatch_0.next1:
    x64.cmp r9, 2
    x64.jne dispatch_0.merge
  dispatch_0.case2:
    x64.mov r8d, 30
    x64.jmp dispatch_0.merge
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

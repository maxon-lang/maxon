// Test: log10.one
function main() returns ExitCode
	let result = Math.log10(1.0)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_1]
    x64.call stdlib.Math.log10
    x64.movsd xmm1, [rip+__float_0]
    x64.ucomisd xmm0, xmm1
    x64.jne main.check_0.after
    x64.jp main.check_0.after
  check_0:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  }
}
---

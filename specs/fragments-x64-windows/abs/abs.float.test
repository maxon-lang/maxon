// Test: abs.float
function main() returns ExitCode
	let neg = -5.5
	let x = abs(neg)
	let y = trunc(x)
	return y
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_-5.5]
    x64.movsd xmm1, xmm0
    x64.andpd xmm1, [rip+__abs_mask]
    x64.cvttsd2si rax, xmm1
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

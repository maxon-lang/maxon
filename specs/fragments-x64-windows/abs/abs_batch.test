// Batch: abs
// Tests: abs.float, abs.negative-int-as-float, abs.zero
---
// Test: abs.float
function main() returns ExitCode
	let neg = -5.5
	let x = abs(neg)
	let y = trunc(x)
	return y
end 'main'
---
ExitCode: 5
---
// Test: abs.negative-int-as-float
function main() returns ExitCode
	let neg = -42.0
	let x = abs(neg)
	return trunc(x)
end 'main'
---
ExitCode: 42
---
// Test: abs.zero
function main() returns ExitCode
	let x = abs(0.0)
	if x == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0

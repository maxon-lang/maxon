// Batch: unicode-category
// Tests: cyrillic-letters, cjk-letters, arabic-digits, unicode-punctuation, unicode-symbols, custom-set-unchanged, trim-cyrillic, unicode-whitespace
---
// Test: cyrillic-letters
function main() returns ExitCode
	let letters = CharacterSet.letters()
	let a = '\u0410'
	let b = '\u0430'
	print("{letters.contains(a)}\n{letters.contains(b)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
true
```
---
// Test: cjk-letters
function main() returns ExitCode
	let letters = CharacterSet.letters()
	let c = '\u4E00'
	print("{letters.contains(c)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
```
---
// Test: arabic-digits
function main() returns ExitCode
	let digits = CharacterSet.decimalDigits()
	let d = '\u0660'
	print("{digits.contains(d)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
```
---
// Test: unicode-punctuation
function main() returns ExitCode
	let punct = CharacterSet.punctuation()
	let a = '\u00AB'
	let b = '\u00BB'
	print("{punct.contains(a)}\n{punct.contains(b)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
true
```
---
// Test: unicode-symbols
function main() returns ExitCode
	let syms = CharacterSet.symbols()
	let c = '\u00A9'
	print("{syms.contains(c)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
```
---
// Test: custom-set-unchanged
function main() returns ExitCode
	let cs = CharacterSet.from(CharSet from ['x', 'y', 'z'])
	print("{cs.contains('x')}\n{cs.contains('a')}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
false
```
---
// Test: trim-cyrillic
function main() returns ExitCode
	let s = "\u0410\u0411\u0412 123 \u0410\u0411\u0412"
	let result = s.trim(CharacterSet.letters())
	print("[{result}]")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[ 123 ]
```
---
// Test: unicode-whitespace
function main() returns ExitCode
	let ws = CharacterSet.whitespaces()
	let c = '\u2003'
	print("{ws.contains(c)}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
true
```
---

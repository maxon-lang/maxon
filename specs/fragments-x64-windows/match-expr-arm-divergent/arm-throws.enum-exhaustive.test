// Test: arm-throws.enum-exhaustive
enum Color
	red
	green
	blue
end 'Color'

enum E
	rejected
end 'E'

function classify(c Color) returns ExitCode throws E
	let result = match c 'eval'
		red throws E.rejected
		green gives 1
		blue gives 2
	end 'eval'
	return result
end 'classify'

function main() returns ExitCode
	let r = try classify(Color.green) otherwise 99
	return r
end 'main'

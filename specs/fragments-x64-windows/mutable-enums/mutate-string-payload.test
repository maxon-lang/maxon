// Test: mutate-string-payload
union Named
	anonymous
	named(name String)
end 'Named'

function main() returns ExitCode
	var n = Named.named("hello")
	match n 'update'
		named(name) then name = "world"
		anonymous then return 0
	end 'update'
	match n 'read'
		named(name) then return name.byteLength()
		anonymous then return 0
	end 'read'
end 'main'
---
ExitCode: 5

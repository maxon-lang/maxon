// Test: error.assign-to-let-enum-binding
typealias Integer = int(i64.min to i64.max)

union Box
	empty
	full(value Integer)
end 'Box'

function main() returns ExitCode
	let b = Box.full(10)
	match b 'bad'
		full(value) then value = 42
		empty then return 0
	end 'bad'
	return 0
end 'main'
---

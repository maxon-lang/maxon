// Test: basic-mutable
typealias Integer = int(i64.min to i64.max)

enum Box
	empty
	full(value Integer)
end 'Box'

function main() returns ExitCode
	var b = Box.full(10)
	match b 'update'
		full(value) then value = 42
		empty then return 0
	end 'update'
	match b 'read'
		full(value) then return value
		empty then return 0
	end 'read'
end 'main'

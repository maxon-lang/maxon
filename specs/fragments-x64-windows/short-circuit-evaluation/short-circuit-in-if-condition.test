// Test: short-circuit-in-if-condition
typealias Integer = int(0 to u64.max)

var trace = 0 as Integer

function setFlag(bit Integer) returns bool
	trace = trace or bit
	return false
end 'setFlag'

function main() returns ExitCode
	if setFlag(1) and setFlag(2) 'never'
		return 99
	end 'never'
	return trace as ExitCode
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @setFlag(bit: i64) -> i1 {
  entry:
    x64.mov rax, qword [rip+trace]
    x64.or rax, rcx
    x64.mov qword [rip+trace], rax
    x64.xor eax, eax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.call setFlag
    x64.xor ecx, ecx
    x64.mov [rbp-1], rcx
    x64.test rax, rax
    x64.je main.shortAnd_0.merge
  shortAnd_0.rhs:
    x64.mov rcx, 2
    x64.call setFlag
    x64.mov [rbp-1], rax
    x64.jmp main.shortAnd_0.merge
  shortAnd_0.merge:
    x64.mov rax, [rbp-1]
    x64.test rax, rax
    x64.je main.never_0.after
  never_0:
    x64.mov rax, 99
    x64.epilogue
    x64.ret
  never_0.after:
    x64.mov rax, qword [rip+trace]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg main.__range_panic_1
    x64.cmp rax, rbx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

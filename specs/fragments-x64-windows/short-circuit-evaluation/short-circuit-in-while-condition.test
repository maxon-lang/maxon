// Test: short-circuit-in-while-condition
var trace = 0

function check() returns bool
	trace = trace + 1
	return trace < 3
end 'check'

function alwaysFalse() returns bool
	trace = trace + 100
	return false
end 'alwaysFalse'

function main() returns ExitCode
	while check() and alwaysFalse() 'loop'
		return 99
	end 'loop'
	return trace
end 'main'

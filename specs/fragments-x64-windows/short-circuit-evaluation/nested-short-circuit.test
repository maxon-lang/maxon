	calls = calls + 1
	return true
end 'a'

function b() returns bool
	calls = calls + 10
	return false
end 'b'

function c() returns bool
	calls = calls + 100
	return true
end 'c'

function main() returns ExitCode
	let inner = b() or c()
	let result = a() and inner
	if result 'r'
		return calls as ExitCode
	end 'r'
	return 99
end 'main'

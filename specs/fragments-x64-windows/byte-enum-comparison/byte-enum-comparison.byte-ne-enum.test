// Test: byte-enum-comparison.byte-ne-enum

typealias Byte = byte(0 to u8.max)

enum Ascii
	underscore = 95
	space = 32
	zero = 48
end 'Ascii'

function main() returns ExitCode
	let b = 95 as Byte
	if b == Ascii.space 'noMatch'
		return 1
	end 'noMatch'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 95
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rdx, 32
    x64.cmp rax, rdx
    x64.jne main.noMatch_0.after
  noMatch_0:
    x64.mov rax, 1
    x64.ret
  noMatch_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

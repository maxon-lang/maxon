// Test: byte-enum-comparison.byte-eq-enum

typealias Byte = int(0 to u8.max)

enum Ascii
	underscore = 95
	space = 32
	zero = 48
end 'Ascii'

function main() returns ExitCode
	let b = 95 as Byte
	if b == Ascii.underscore 'match'
		return 0
	end 'match'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

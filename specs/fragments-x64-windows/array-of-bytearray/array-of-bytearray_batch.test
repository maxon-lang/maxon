// Batch: array-of-bytearray
// Tests: array-of-bytebuffer-push-get-count
---
// Test: array-of-bytebuffer-push-get-count
typealias Byte = byte(0 to u8.max)
typealias ByteArray = Array with Byte
typealias ByteArrayArray = Array with ByteArray

function main() returns ExitCode
	var outer = ByteArrayArray.create()
	var inner = ByteArray.create()
	inner.push(10)
	inner.push(20)
	inner.push(30)
	outer.push(inner)
	var retrieved = try outer.get(0) otherwise ByteArray.create()
	print("{retrieved.count()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
```

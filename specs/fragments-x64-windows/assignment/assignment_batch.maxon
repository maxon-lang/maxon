// --- batched test: basic-assignment ---
function _b_basic_assignment_main() returns ExitCode
	var x = 3
	x = x + 2
	return x
end '_b_basic_assignment_main'

// --- batched test: multiple-assignments ---
function _b_multiple_assignments_main() returns ExitCode
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end '_b_multiple_assignments_main'

// --- batched test: assignment-in-loop ---
function _b_assignment_in_loop_main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end '_b_assignment_in_loop_main'

// --- batched test: docs-example-1 ---
function _b_docs_example_1_main() returns ExitCode
	var x = 10
	x = 20          // Update x
	x = x + 5       // x is now 25
	return x
end '_b_docs_example_1_main'

// --- batch dispatcher for assignment ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:basic-assignment>>>\n")
	let ec_basic_assignment = _b_basic_assignment_main()
	print("\n<<<MAXON_BATCH_TEST_END:basic-assignment:{ec_basic_assignment}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multiple-assignments>>>\n")
	let ec_multiple_assignments = _b_multiple_assignments_main()
	print("\n<<<MAXON_BATCH_TEST_END:multiple-assignments:{ec_multiple_assignments}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:assignment-in-loop>>>\n")
	let ec_assignment_in_loop = _b_assignment_in_loop_main()
	print("\n<<<MAXON_BATCH_TEST_END:assignment-in-loop:{ec_assignment_in_loop}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:docs-example-1>>>\n")
	let ec_docs_example_1 = _b_docs_example_1_main()
	print("\n<<<MAXON_BATCH_TEST_END:docs-example-1:{ec_docs_example_1}>>>\n")
	return 0 as ExitCode
end 'main'

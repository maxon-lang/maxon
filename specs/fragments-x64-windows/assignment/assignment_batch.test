// Batch: assignment
// Tests: basic-assignment, multiple-assignments, assignment-in-loop, docs-example-1
---
// Test: basic-assignment
function main() returns ExitCode
	var x = 3
	x = x + 2
	return x
end 'main'
---
ExitCode: 5
---
// Test: multiple-assignments
function main() returns ExitCode
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end 'main'
---
ExitCode: 50
---
// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
// Test: docs-example-1
function main() returns ExitCode
	var x = 10
	x = 20          // Update x
	x = x + 5       // x is now 25
	return x
end 'main'

---
ExitCode: 25

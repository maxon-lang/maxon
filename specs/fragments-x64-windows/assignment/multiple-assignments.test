// Test: multiple-assignments
function main() returns ExitCode
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 50
    x64.mov r9d, 30
    x64.mov r9d, 20
    x64.mov r9d, 10
    x64.ret
  }
}
---

// Test: multiple-assignments
function main() returns ExitCode
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 50
    x64.mov ebx, 30
    x64.mov ebx, 20
    x64.mov ebx, 10
    x64.epilogue
    x64.ret
  }
}
---

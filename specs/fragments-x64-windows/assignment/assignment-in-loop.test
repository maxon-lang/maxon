// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor rbx, rbx
    x64.mov [rbp-8], rbx
    x64.mov rsi, 1
    x64.mov [rbp-16], rsi
  loop_1.header:
    x64.mov rbx, [rbp-8]
    x64.mov rsi, [rbp-16]
  loop_1.header.body:
    x64.cmp rsi, 5
    x64.jg loop_1.exit
  loop_1:
    x64.mov rdi, rsi
    x64.add rdi, 1
    x64.mov r8, rbx
    x64.add r8, rsi
    x64.mov [rbp-8], r8
    x64.mov [rbp-16], rdi
    x64.mov rbx, r8
    x64.mov rsi, rdi
    x64.jmp loop_1.header.body
  loop_1.exit:
    x64.cmp rbx, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
}
---

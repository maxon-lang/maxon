// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @assignment.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 1
    x64.xor r9d, r9d
    x64.xchg r8, r9
  loop_1.header:
    x64.cmp r9, 5
    x64.jg loop_1.exit
  loop_1:
    x64.mov rax, r9
    x64.add rax, 1
    x64.add r8, r9
    x64.mov r9, rax
    x64.jmp loop_1.header
  loop_1.exit:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

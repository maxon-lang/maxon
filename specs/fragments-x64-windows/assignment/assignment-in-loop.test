// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.mov rcx, 1
    x64.mov [rbp-16], rcx
  loop_1.header:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.cmp rcx, 5
    x64.jg loop_1.exit
  loop_1:
    x64.mov rax, [rbp+-16]
    x64.mov rcx, rax
    x64.add rcx, 1
    x64.mov rdx, [rbp+-8]
    x64.mov rbx, rdx
    x64.add rbx, rax
    x64.mov [rbp-8], rbx
    x64.mov [rbp-16], rcx
    x64.jmp loop_1.header
  loop_1.exit:
    x64.mov rax, [rbp+-8]
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

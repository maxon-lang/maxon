// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ebx, 1
    x64.mov r8d, 0
  loop_1.header:
    x64.cmp rbx, 5
    x64.jg loop_1.exit
  loop_1:
    x64.mov rsi, rbx
    x64.add rsi, 1
    x64.add r8, rbx
    x64.mov rbx, rsi
    x64.jmp loop_1.header
  loop_1.exit:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

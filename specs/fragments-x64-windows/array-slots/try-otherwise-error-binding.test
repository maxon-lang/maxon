// Test: try-otherwise-error-binding
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.resize(2)
	try arr.get(0) otherwise (e) 'handler'
		match e 'check'
			emptySlot then return 42
			indexOutOfBounds then return 99
		end 'check'
	end 'handler'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @Slot.clone(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov [rbp-24], rdx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.mov rdx, [rbp-24]
    x64.mov [rcx+0], rdx
    x64.mov rbx, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }

    x64.mov rcx, [rbp-24]
    x64.call mm_decref
    x64.label __nonnull_skip_4
    x64.mov rcx, [rbp-8]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_5
    x64.call mm_decref
    x64.label __nonnull_skip_5
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
  func @__destruct_Slot(ptr: i64) {
  entry:
    x64.jmp __destruct_Slot.done
  done:
    x64.ret
  }
  func @__destruct___ManagedMemory_Slot(ptr: i64) {

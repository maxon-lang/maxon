    x64.call SlotArray.resize
    x64.mov rcx, [rbp-8]
    x64.xor rdx, rdx
    x64.call SlotArray.get
    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rax
    x64.xor rax, rax
    x64.cmp rdx, rax
    x64.je main.otherwise_continue_1
  otherwise_error_0:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 1
    x64.sub rax, rcx
    x64.mov [rbp-32], rax
    x64.jmp main.check_4.cmp0
  check_4.cmp0:
    x64.mov rax, [rbp-32]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_4.cmp1
  check_4.case0:
    x64.mov rax, [rbp-24]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-24]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 42
    x64.epilogue
    x64.ret
  check_4.cmp1:
    x64.mov rax, [rbp-32]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.check_4.merge
  check_4.case1:
    x64.mov rax, [rbp-24]
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-24]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_3
    x64.call mm_decref
    x64.label __nonnull_skip_3
    x64.mov rax, 99
    x64.epilogue

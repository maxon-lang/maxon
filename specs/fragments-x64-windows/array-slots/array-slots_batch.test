// Batch: array-slots
// Tests: get-empty-slot-basic, get-valid-slot-not-empty, int-array-zero-not-empty, get-empty-slot-try-otherwise-value, first-empty-slot, last-empty-slot, try-otherwise-error-binding
---
// Test: get-empty-slot-basic
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.push(Slot.create(value: 10))
	arr.resize(3)
	let result = try arr.get(1) otherwise Slot.create(value: -1)
	return result.value + 1
end 'main'
---
ExitCode: 0
---
// Test: get-valid-slot-not-empty
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.push(Slot.create(value: 42))
	let result = try arr.get(0) otherwise Slot.create(value: 0)
	return result.value
end 'main'
---
ExitCode: 42
---
// Test: int-array-zero-not-empty
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(0)
	arr.push(5)
	arr.resize(4)
	let val = try arr.get(0) otherwise -1
	let val2 = try arr.get(2) otherwise -1
	return val + val2
end 'main'
---
ExitCode: 0
---
// Test: get-empty-slot-try-otherwise-value
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.resize(3)
	let result = try arr.get(0) otherwise Slot.create(value: 99)
	return result.value
end 'main'
---
ExitCode: 99
---
// Test: first-empty-slot
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.push(Slot.create(value: 1))
	arr.resize(3)
	try arr.remove(0) otherwise ignore
	let result = try arr.first() otherwise Slot.create(value: 77)
	return result.value
end 'main'
---
ExitCode: 77
---
// Test: last-empty-slot
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.push(Slot.create(value: 1))
	arr.resize(3)
	let result = try arr.last() otherwise Slot.create(value: 55)
	return result.value
end 'main'
---
ExitCode: 55
---
// Test: try-otherwise-error-binding
typealias Integer = int(i64.min to i64.max)

type Slot
	export var value Integer
end 'Slot'

typealias SlotArray = Array with Slot

function main() returns ExitCode
	var arr = SlotArray.create()
	arr.resize(2)
	try arr.get(0) otherwise (e) 'handler'
		match e 'check'
			emptySlot then return 42
			indexOutOfBounds then return 99
		end 'check'
	end 'handler'
	return 0
end 'main'
---
ExitCode: 99
---

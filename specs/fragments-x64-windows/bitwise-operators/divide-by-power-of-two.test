    x64.shr rdx, cl
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rdx, rsi
    x64.jg bitwise-operators.main.__range_panic_0
    x64.cmp rdx, rbx
    x64.jl bitwise-operators.main.__range_panic_0
    x64.jmp bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_11]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}

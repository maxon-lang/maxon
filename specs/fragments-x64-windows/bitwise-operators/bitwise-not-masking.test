// Test: bitwise-not-masking
function main() returns ExitCode
	let value = 125    // 0x7D
	// Clear lower 4 bits: 125 and not 15 = 112
	return value and not 15
end 'main'
---
ExitCode: 112
---
// CompiledIR
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 125
    x64.mov rcx, 15
    x64.mov rdx, -1
    x64.xor rcx, rdx
    x64.and rax, rcx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg bitwise-operators.main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl bitwise-operators.main.__range_panic_0
    x64.jmp bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_14]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

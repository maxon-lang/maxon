// Test: bitwise-not-masking
function main() returns ExitCode
	var value = 255    // 0xFF
	// Clear lower 4 bits: 255 and not 15 = 240
	return value and not 15
end 'main'
---
ExitCode: 240
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 255
    x64.mov rcx, 15
    x64.mov rdx, -1
    x64.xor rcx, rdx
    x64.and rax, rcx
    x64.xor rbx, rbx
    x64.mov rsi, 4294967295
    x64.cmp rax, rsi
    x64.jg main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: bit-clear
function main() returns ExitCode
	var flags = 7        // binary 111
	// Clear bit 1 using xor
	flags = flags xor 2
	return flags         // 5 (binary 101)
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 5
    x64.mov r8, r9
    x64.ret
  }
}
---

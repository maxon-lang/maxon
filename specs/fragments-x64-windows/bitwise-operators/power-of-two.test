// Test: power-of-two
function main() returns ExitCode
	// Calculate 2^n using shift
	let n = 5
	return 1 shl n        // 32
end 'main'
---
ExitCode: 32
---
// CompiledIR
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 5
    x64.mov rcx, 1
    x64.mov rdx, rcx
    x64.mov rcx, rax
    x64.shl rdx, cl
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rdx, rsi
    x64.jg bitwise-operators.main.__range_panic_0
    x64.cmp rdx, rbx
    x64.jl bitwise-operators.main.__range_panic_0
    x64.jmp bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

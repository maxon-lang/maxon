// Test: bit-masking
function main() returns ExitCode
	let flags = 5         // binary 101 (bit 0 and bit 2 set)
	return flags and 4    // returns 4 (bit 2 is set)
end 'main'
---
ExitCode: 4
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 4
    x64.mov r8, r9
    x64.ret
  }
}
---

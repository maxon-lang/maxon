// Test: bitwise-and-or-precedence
function main() returns ExitCode
	// and has higher precedence than or
	// 12 and 10 = 8, then 8 or 1 = 9
	return 12 and 10 or 1
end 'main'
---
ExitCode: 9
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 9
    x64.mov r8, r9
    x64.ret
  }
}
---

// Test: bitwise-xor-precedence
function main() returns ExitCode
	// and has higher precedence than xor
	// 12 and 10 = 8, then 8 xor 3 = 11
	return 12 and 10 xor 3
end 'main'
---
ExitCode: 11
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 11
    x64.mov r8, r9
    x64.ret
  }
}
---

// Test: bitwise-xor-precedence
function main() returns ExitCode
	// and has higher precedence than xor
	// 12 and 10 = 8, then 8 xor 3 = 11
	return 12 and 10 xor 3
end 'main'
---
ExitCode: 11
---
// CompiledIR
module {
  func @bitwise-operators.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 12
    x64.mov rcx, 10
    x64.and rax, rcx
    x64.mov rdx, 3
    x64.xor rax, rdx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg bitwise-operators.main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl bitwise-operators.main.__range_panic_0
    x64.jmp bitwise-operators.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_7]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

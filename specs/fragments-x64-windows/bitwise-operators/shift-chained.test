// Test: shift-chained
function main() returns ExitCode
	var a = 1
	return a shl 4 shr 2
end 'main'
---
ExitCode: 4
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.mov rcx, 4
    x64.mov rdx, rax
    x64.shl rdx, cl
    x64.mov rbx, 2
    x64.mov rcx, rbx
    x64.mov rsi, rdx
    x64.shr rsi, cl
    x64.xor rdi, rdi
    x64.mov r8, 4294967295
    x64.cmp rsi, r8
    x64.jg main.__range_panic_0
    x64.cmp rsi, rdi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rsi
    x64.epilogue
    x64.ret
  }
}
---

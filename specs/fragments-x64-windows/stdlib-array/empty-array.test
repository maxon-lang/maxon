// Test: empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	if arr.count() != 0 'check'
		return 1
	end 'check'
	if arr.isEmpty() == false 'empty'
		return 2
	end 'empty'
	return 0
end 'main'
---
ExitCode: 0
---

  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call IntArray.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntArray.count
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.je main.check_0.after
  check_0:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntArray.isEmpty
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.empty_1.after
  empty_1:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 2
    x64.epilogue
    x64.ret
  empty_1.after:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
  func @__destruct___ManagedMemory_Int(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+16]
    x64.xor rdx, rdx
    x64.cmp rcx, rdx
    x64.je __destruct___ManagedMemory_Int.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct___ManagedMemory_Int.skip_buf_0
  skip_buf_0:

    x64.mov ecx, 40
    x64.call mrt_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+16], r9 (8b)
    x64.mov r9d, 8
    x64.mov [r8+24], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+32], r9 (8b)
    x64.mov [r12+0], r8 (8b)
    x64.lea rdx, [rip+__layout_Array_Int]
    x64.mov rcx, r12
    x64.call Array.count
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8, [r12+0] (8b)
    x64.mov r9, [r8+8] (8b)
    x64.test r9, r9
    x64.sete r8
    x64.test r8, r8
    x64.jne empty_0.after
  empty_0:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  empty_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

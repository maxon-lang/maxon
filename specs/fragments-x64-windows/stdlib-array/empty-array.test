// Test: empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	if arr.count() != 0 'check'
		return 1
	end 'check'
	if arr.isEmpty() == false 'empty'
		return 2
	end 'empty'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea rcx, [rip+__layout_Array_Int]
    x64.call Array.create
    x64.mov r12, r8
    x64.lea rdx, [rip+__layout_Array_Int]
    x64.mov rcx, r12
    x64.call Array.count
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8, [r12+0] (8b)
    x64.mov r13, [r8+8] (8b)
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r13, r13
    x64.sete r8
    x64.test r8, r8
    x64.jne empty_0.after
  empty_0:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  empty_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: insert-multiple-positions
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	arr.push(10)
	arr.push(30)
	arr.push(50)

	arr.insert(1, value: 20)
	arr.insert(3, value: 40)

	if arr.count() != 5 'cnt'
		return 1
	end 'cnt'

	let v0 = try arr.get(0) otherwise -1
	let v1 = try arr.get(1) otherwise -1
	let v2 = try arr.get(2) otherwise -1
	let v3 = try arr.get(3) otherwise -1
	let v4 = try arr.get(4) otherwise -1

	if v0 != 10 'c0'
		return 2
	end 'c0'
	if v1 != 20 'c1'
		return 3
	end 'c1'
	if v2 != 30 'c2'
		return 4
	end 'c2'
	if v3 != 40 'c3'
		return 5
	end 'c3'
	if v4 != 50 'c4'
		return 6
	end 'c4'

	return 0
end 'main'

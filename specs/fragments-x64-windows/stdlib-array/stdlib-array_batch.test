// Batch: stdlib-array
// Tests: empty-array, push-single, push-multiple, get-all-elements, set-element, first-last, pop-element, array-literal, for-in-iteration, for-in-double-iteration, for-in-nested, isEmpty-transitions, clear-array, get-out-of-bounds, get-empty-array, get-empty-module-level-array, reserve-capacity, push-string-literals, push-string-literals-long, push-string-variables, string-array-iteration, string-array-get, string-array-memory, push-self-assignment, insert-at-beginning, insert-at-middle, insert-at-end, insert-into-empty, insert-index-clamps-high, insert-multiple-positions, remove-from-beginning, remove-from-middle, remove-from-end, remove-all-one-by-one, remove-out-of-bounds, remove-from-empty-array, insert-then-remove-same-position, build-sorted-with-inserts, insert-strings, remove-strings, insert-remove-structs
---
// Test: empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	if arr.count() != 0 'check'
		return 1
	end 'check'
	if arr.isEmpty() == false 'empty'
		return 2
	end 'empty'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: push-single
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(42)
	let val = try arr.get(0) otherwise -1
	if val != 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---

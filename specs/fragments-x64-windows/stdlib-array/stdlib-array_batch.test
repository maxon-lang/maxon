		return 1
	end 'e1'

	arr.push(42)

	if arr.isEmpty() == true 'e2'
		return 2
	end 'e2'

	_ = try arr.pop() otherwise 0

	if arr.isEmpty() == false 'e3'
		return 3
	end 'e3'

	return 0
end 'main'

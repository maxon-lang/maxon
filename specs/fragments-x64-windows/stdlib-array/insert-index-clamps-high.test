    x64.mov rdx, 10
    x64.call IntArray.push
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 20
    x64.call IntArray.push
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 100
    x64.mov r8, 30
    x64.call IntArray.insert
    x64.mov rbx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntArray.count
    x64.mov rsi, 3
    x64.cmp rax, rsi
    x64.je main.cnt_0.after
  cnt_0:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  cnt_0.after:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 2
    x64.call IntArray.get
    x64.mov rcx, -1
    x64.mov [rbp-16], rcx
    x64.mov [rbp-24], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_4
  otherwise_default_error_3:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-24], rax
    x64.jmp main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 30
    x64.cmp rax, rcx
    x64.je main.c2_5.after
  c2_5:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 2
    x64.epilogue
    x64.ret
  c2_5.after:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }

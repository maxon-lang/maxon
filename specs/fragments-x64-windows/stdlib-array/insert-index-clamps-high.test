// Test: insert-index-clamps-high
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	arr.push(10)
	arr.push(20)

	arr.insert(100, value: 30)

	if arr.count() != 3 'cnt'
		return 1
	end 'cnt'

	let v2 = try arr.get(2) otherwise -1
	if v2 != 30 'c2'
		return 2
	end 'c2'

	return 0
end 'main'
---
ExitCode: 0
---

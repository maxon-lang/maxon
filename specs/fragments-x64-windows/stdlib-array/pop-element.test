// Test: pop-element
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)

	let val = try arr.pop() otherwise -1
	if val != 30 'check'
		return 1
	end 'check'

	if arr.count() != 2 'cnt'
		return 3
	end 'cnt'

	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.call IntArray.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 10
    x64.call IntArray.push
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 20
    x64.call IntArray.push
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 30
    x64.call IntArray.push
    x64.mov rbx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntArray.pop
    x64.mov rsi, -1
    x64.mov [rbp-16], rsi
    x64.mov [rbp-24], rax
    x64.xor rdi, rdi
    x64.cmp rdx, rdi
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-24], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 30
    x64.cmp rax, rcx
    x64.je main.check_4.after
  check_4:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_4.after:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntArray.count
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.je main.cnt_5.after
  cnt_5:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 3
    x64.epilogue
    x64.ret
  cnt_5.after:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
  func @__destruct___ManagedMemory_Int(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+16]
    x64.xor rdx, rdx
    x64.cmp rcx, rdx
    x64.je __destruct___ManagedMemory_Int.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct___ManagedMemory_Int.skip_buf_0
  skip_buf_0:
    x64.jmp __destruct___ManagedMemory_Int.done
  done:
    x64.epilogue
    x64.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+8]
    x64.mov [rbp-16], rcx
    x64.test rcx, rcx
    x64.jz __nonnull_skip_3
    x64.call mm_decref
    x64.label __nonnull_skip_3
    x64.jmp __destruct_IntArray.done
  done:
    x64.epilogue
    x64.ret
  }
}
---

// Test: remove-from-empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()

	let removed = try arr.remove(0) otherwise -1
	if removed == -1 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.lea rcx, [rip+__layout_Array_Int]
    x64.call Array.create
    x64.mov r12, r8
    x64.lea rax, [rip+__layout_Array_Int]
    x64.xor edx, edx
    x64.mov rcx, r12
    x64.call Array.remove
    x64.mov r13, r8
    x64.mov r14, rdx
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r14, r14
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 1
    x64.neg r8
    x64.mov r13, r8
  try_0.merge:
    x64.mov r8d, 1
    x64.neg r8
    x64.cmp r13, r8
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

// Test: push-string-literals
typealias StringArray = Array with String

function main() returns ExitCode
	var arr = StringArray.create()
	arr.push("hello")
	arr.push("world")

	if arr.count() != 2 'cnt'
		return 1
	end 'cnt'

	let s0 = try arr.get(0) otherwise ""
	let s1 = try arr.get(1) otherwise ""
	print(s0)
	print(s1)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
helloworld
```

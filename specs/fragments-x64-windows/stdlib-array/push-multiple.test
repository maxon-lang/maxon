// Test: push-multiple
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)
	if arr.count() != 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov ecx, 40
    x64.call mrt_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+16], r9 (8b)
    x64.mov r9d, 8
    x64.mov [r8+24], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+32], r9 (8b)
    x64.mov [r12+0], r8 (8b)
    x64.lea rax, [rip+__layout_Array_Int]
    x64.mov edx, 10
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_Int]
    x64.mov edx, 20
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_Int]
    x64.mov edx, 30
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rdx, [rip+__layout_Array_Int]
    x64.mov rcx, r12
    x64.call Array.count
    x64.cmp r8, 3
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

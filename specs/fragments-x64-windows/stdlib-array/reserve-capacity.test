// Test: reserve-capacity
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.reserve(100)

	if arr.capacity() < 100 'cap'
		return 1
	end 'cap'

	if arr.count() != 0 'cnt'
		return 2
	end 'cnt'

	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov ecx, 40
    x64.call mrt_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+16], r9 (8b)
    x64.mov r9d, 8
    x64.mov [r8+24], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+32], r9 (8b)
    x64.mov [r12+0], r8 (8b)
    x64.lea rax, [rip+__layout_Array_Int]
    x64.mov edx, 100
    x64.mov rcx, r12
    x64.call Array.reserve
    x64.lea rdx, [rip+__layout_Array_Int]
    x64.mov rcx, r12
    x64.call Array.capacity
    x64.cmp r8, 100
    x64.jge cap_0.after
  cap_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  cap_0.after:
    x64.lea rdx, [rip+__layout_Array_Int]
    x64.mov rcx, r12
    x64.call Array.count
    x64.test r8, r8
    x64.je cnt_0.after
  cnt_0:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  cnt_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: get-empty-module-level-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int
var arr = IntArray.create()

function main() returns ExitCode
	let val = try arr.get(0) otherwise -1
	if val == -1 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_arr]
    x64.mov r9, [r8+0] (8b)
    x64.xor edx, edx
  inlined_Array.get_0_0:
    x64.mov rcx, [r9+0] (8b)
    x64.call stdlib.__managed_mem_get
    x64.test rdx, rdx
    x64.je inlined_Array.get_3_0
  inlined_Array.get_1_0:
    x64.mov edx, 1
    x64.xor r8d, r8d
    x64.jmp inline_cont_main_0
  inlined_Array.get_3_0:
    x64.xor edx, edx
  inline_cont_main_0:
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 1
    x64.neg r8
  try_0.merge:
    x64.mov r9d, 1
    x64.neg r9
    x64.cmp r8, r9
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

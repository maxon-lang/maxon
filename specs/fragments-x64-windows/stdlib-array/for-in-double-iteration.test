    x64.mov rcx, [rbp-24]
    x64.call __IntArray_Iter.next
    x64.mov [rbp-32], rax
    x64.xor rcx, rcx
    x64.cmp rdx, rcx
    x64.jne main.loop1_0.exit
  loop1_0:
    x64.mov rax, [rbp-32]
    x64.mov rcx, [rbp-16]
    x64.add rcx, rax
    x64.mov [rbp-16], rcx
    x64.jmp main.loop1_0.header
  loop1_0.exit:
    x64.xor rax, rax
    x64.mov [rbp-40], rax
    x64.mov rcx, [rbp-8]
    x64.call IntArray.__createIter
    x64.mov [rbp-48], rax
    x64.jmp main.loop2_3.header
  loop2_3.header:
    x64.mov rax, [rbp-48]
    x64.mov rcx, [rbp-48]
    x64.call __IntArray_Iter.next
    x64.mov [rbp-56], rax
    x64.xor rcx, rcx
    x64.cmp rdx, rcx
    x64.jne main.loop2_3.exit
  loop2_3:
    x64.mov rax, [rbp-56]
    x64.mov rcx, [rbp-40]
    x64.add rcx, rax
    x64.mov [rbp-40], rcx
    x64.jmp main.loop2_3.header
  loop2_3.exit:
    x64.mov rax, 60
    x64.mov rcx, [rbp-16]
    x64.cmp rcx, rax
    x64.sete rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, 60
    x64.mov rsi, [rbp-40]
    x64.cmp rsi, rbx
    x64.sete rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.check_6.after
  check_6:
    x64.mov rax, [rbp-48]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-48]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-24]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rdx, [rbp-8]
    x64.test rdx, rdx
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  check_6.after:
    x64.mov rax, [rbp-48]
    x64.test rax, rax
    x64.jz __nonnull_skip_3
    x64.mov rcx, [rbp-48]

    x64.mov rcx, [rbp-8]
    x64.mov rdx, 10
    x64.call IntArray.push
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 20
    x64.call IntArray.push
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 30

// Test: for-in-double-iteration
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)

	var sum1 = 0
	for item in arr 'loop1'
		sum1 = sum1 + item
	end 'loop1'

	var sum2 = 0
	for item in arr 'loop2'
		sum2 = sum2 + item
	end 'loop2'

	if sum1 == 60 and sum2 == 60 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=64
    x64.call IntArray.create
    x64.mov [rbp-8], rax

// Test: enum-match-range.basic
typealias Integer = int(i64.min to i64.max)

union Action
	noop
	skip
	run(code Integer)
end 'Action'

function main() returns ExitCode
	let a = Action.skip
	let result = match a 'check'
		noop to skip gives 1
		run(code) gives code
	end 'check'
	return result
end 'main'

// Test: error.enum-match-range.overlap
typealias Integer = int(i64.min to i64.max)

enum Op
	add
	sub
	mul
	exec(code Integer)
end 'Op'

function main() returns ExitCode
	let op = Op.add
	match op 'check'
		add to sub then return 1
		sub to mul then return 2
		exec(code) then return code
	end 'check'
end 'main'
---

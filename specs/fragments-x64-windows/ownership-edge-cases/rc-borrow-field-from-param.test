    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.mov [rdx+0], rcx
    x64.call mm_incref
    x64.mov rbx, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }

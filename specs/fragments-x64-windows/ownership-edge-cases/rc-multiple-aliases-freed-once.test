// Test: rc-multiple-aliases-freed-once
typealias Integer = int(i64.min to i64.max)

type Data
	export var n as Integer

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Data'

function main() returns ExitCode
	@heap let a = Data.create(7)
	let b = a
	let c = a
	return a.n + b.n + c.n
end 'main'
---
ExitCode: 21

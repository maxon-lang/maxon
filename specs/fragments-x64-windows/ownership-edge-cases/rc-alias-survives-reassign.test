// Test: rc-alias-survives-reassign
typealias Integer = int(i64.min to i64.max)

type Num
	export var v Integer

	static function create(v Integer) returns Self
		return Self{v: v}
	end 'create'
end 'Num'

function main() returns ExitCode
	var a = Num.create(10)
	let b = a
	a = Num.create(20)
	return b.v + a.v
end 'main'

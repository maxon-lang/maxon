// Batch: ownership-edge-cases
// Tests: rc-struct-literal-as-function-arg, rc-tuple-return-destructure-no-crash, rc-enum-char-rawvalue-from-function, rc-enum-name-from-function, rc-enum-string-rawvalue-from-function, rc-discarded-self-return, rc-borrow-field-from-param, rc-char-to-string-interpolation, rc-match-char-range-cleanup, rc-string-backed-enum-compare, rc-char-backed-enum-compare, rc-nested-struct-clone-no-leak, rc-string-clone-no-leak, rc-string-replace-no-leak, rc-string-replacefirst-no-leak, rc-string-concat-loop-no-leak, rc-string-slice-no-leak, rc-enum-name-no-leak, rc-enum-name-reassign-no-leak, rc-array-of-structs-get-no-leak, rc-array-of-structs-literal-no-leak, rc-global-array-push-local-no-leak, rc-global-array-push-remove-loop-no-leak, rc-struct-field-overwrite-in-if-no-leak, rc-map-string-keys-no-leak, rc-map-string-keys-multiple-no-leak, rc-closure-capture-string-no-crash, rc-managed-list-remove-single-no-leak, rc-module-level-struct-nested-field-assign, rc-top-level-array-literal-no-leak, rc-array-append-no-leak, rc-struct-with-string-enum-in-array, rc-custom-hashable-map-key-no-leak
---
// Test: rc-struct-literal-as-function-arg
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function acceptPoint(p Point) returns Integer
	return p.x + p.y
end 'acceptPoint'

function main() returns ExitCode
	return acceptPoint(Point.create(x: 3, y: 4))
end 'main'
---
ExitCode: 7
---
// Test: rc-tuple-return-destructure-no-crash
typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
	return (a, b)
end 'makePair'

function main() returns ExitCode
	let (x, y) = makePair(10, b: 32)
	return x + y
end 'main'
---
ExitCode: 42
---
// Test: rc-enum-char-rawvalue-from-function
enum Grade
	excellent = 'A'
	good = 'B'
	average = 'C'
end 'Grade'

function getLetter(g Grade) returns Character
	return g.rawValue
end 'getLetter'

function main() returns ExitCode
	let grade = Grade.good
	let letter = getLetter(grade)
	if letter == 'B' 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: rc-enum-name-from-function
enum Direction
	north
	south
	east
	west
end 'Direction'

function getName(d Direction) returns String
	return d.name
end 'getName'

function main() returns ExitCode
	let d = Direction.west
	let n = getName(d)
	if n == "west" 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: rc-enum-string-rawvalue-from-function
enum Planet
	earth = "Earth"
	mars = "Mars"
	venus = "Venus"
end 'Planet'

function getName(p Planet) returns String
	return p.rawValue
end 'getName'

function main() returns ExitCode
	let p = Planet.mars
	let n = getName(p)
	if n == "Mars" 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: rc-discarded-self-return
typealias Count = int(i64.min to i64.max)

type Counter
	export var value Count

	function increment() returns Counter
		value = value + 1
		return self
	end 'increment'

	static function create(value Count) returns Self
		return Self{value: value}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(value: 0)
	c.increment()
	return c.value
end 'main'
---
ExitCode: 1
---
// Test: rc-borrow-field-from-param
typealias Integer = int(i64.min to i64.max)

type Data
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Data'

type Wrapper
	export var data Data

	static function create(data Data) returns Self
		return Self{data: data}
	end 'create'
end 'Wrapper'

function extractData(w Wrapper) returns Data
	return w.data
end 'extractData'

function main() returns ExitCode
	let d = Data.create(value: 42)
	let w = Wrapper.create(data: d)
	let result = extractData(w)
	return result.value
end 'main'
---
ExitCode: 42
---
// Test: rc-char-to-string-interpolation

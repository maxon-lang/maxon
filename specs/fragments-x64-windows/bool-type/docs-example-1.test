// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function isPositive(x Score) returns bool
	if x > 0 'check'
		return true
	end 'check'
	return false
end 'isPositive'

function main() returns ExitCode
	if isPositive(5) 'test'
		return 1
	end 'test'
	return 0
end 'main'

---
ExitCode: 1
---
// CompiledIR
module {
  func @bool-type.isPositive(x: i64) -> i1 {
  entry:
    x64.xor eax, eax
    x64.cmp rcx, rax
    x64.jle bool-type.isPositive.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call bool-type.isPositive
    x64.test rax, rax
    x64.je main.test_0.after
  test_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  test_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

function isPositive(x Score) returns bool
	if x > 0 'check'
		return true
	end 'check'
	return false
end 'isPositive'

function main() returns ExitCode
	if isPositive(5) 'test'
		return 1
	end 'test'
	return 0
end 'main'

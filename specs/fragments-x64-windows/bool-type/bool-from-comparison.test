// Test: bool-from-comparison
function main() returns ExitCode
	let result = 5 > 3
	if result 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @bool-type.main() -> u32 {
  entry:
    x64.mov rax, 5
    x64.mov rcx, 3
    x64.cmp rax, rcx
    x64.jle bool-type.main.check_0.after
  check_0:
    x64.mov rax, 42
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

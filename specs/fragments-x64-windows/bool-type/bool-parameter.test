// Test: bool-parameter

typealias Integer = int(i64.min to i64.max)

function test_bool_param(flag bool) returns Integer
	if flag 'check'
		return 1
	end 'check' else 'else_check'
		return 0
	end 'else_check'
end 'test_bool_param'

function main() returns ExitCode
	return test_bool_param(true)
end 'main'
---
ExitCode: 1
---
module {
  func @bool-type.test_bool_param(flag: i1) -> i64 {
  entry:
    x64.test rcx, rcx
    x64.je bool-type.test_bool_param.else_check_1
  check_0:
    x64.mov rax, 1
    x64.ret
  else_check_1:
    x64.xor eax, eax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.call bool-type.test_bool_param
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

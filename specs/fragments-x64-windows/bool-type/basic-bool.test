// Test: basic-bool
function main() returns ExitCode
	let x = true

	if x 'check'
		return 1
	end 'check' else 'else_check'
		return 0
	end 'else_check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 1
    x64.test rax, rax
    x64.je main.else_check_1
  check_0:
    x64.mov rax, 1
    x64.ret
  else_check_1:
    x64.xor eax, eax
    x64.ret
  }
}
---

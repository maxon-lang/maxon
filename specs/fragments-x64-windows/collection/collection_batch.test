// Test: map-single-element
typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let arr = [42]
	let result = arr.map((x Integer) gives x + 8)
	let val = try result.get(0) otherwise 0
	print("{val}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
50

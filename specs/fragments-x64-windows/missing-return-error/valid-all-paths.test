// Test: valid-all-paths

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x > 0 'check'
		return 1
	end 'check'
	return 0
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'

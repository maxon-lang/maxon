// Test: valid-all-paths

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x > 0 'check'
		return 1
	end 'check'
	return 0
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 1
---
module {
  func @missing-return-error.test(x: i64) -> i64 {
  entry:
    x64.xor eax, eax
    x64.cmp rcx, rax
    x64.jle missing-return-error.test.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call missing-return-error.test
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// --- batched test: valid-all-paths ---

typealias _b_valid_all_paths_Integer = int(i64.min to i64.max)

function _b_valid_all_paths_test(x _b_valid_all_paths_Integer) returns _b_valid_all_paths_Integer
	if x > 0 'check'
		return 1
	end 'check'
	return 0
end '_b_valid_all_paths_test'

function _b_valid_all_paths_main() returns ExitCode
	return _b_valid_all_paths_test(5)
end '_b_valid_all_paths_main'

// --- batch dispatcher for missing-return-error ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:valid-all-paths>>>\n")
	let ec_valid_all_paths = _b_valid_all_paths_main()
	print("\n<<<MAXON_BATCH_TEST_END:valid-all-paths:{ec_valid_all_paths}>>>\n")
	return 0 as ExitCode
end 'main'

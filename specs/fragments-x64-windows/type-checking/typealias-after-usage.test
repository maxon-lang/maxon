// Test: typealias-after-usage

typealias Integer = int(i64.min to i64.max)

type Container
	export var items ItemArray

	static function create(items ItemArray) returns Self
		return Self{items: items}
	end 'create'
end 'Container'

typealias ItemArray = Array with Item

type Item
	export let value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Item'

function main() returns ExitCode
	var c = Container.create(items: ItemArray.create())
	c.items.push(Item.create(value: 7))
	return c.items.count()
end 'main'

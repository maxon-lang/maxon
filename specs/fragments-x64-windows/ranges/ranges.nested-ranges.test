// Test: ranges.nested-ranges
function main() returns ExitCode
		var sum = 0
		for i in 1 to 3 'outer'
				for j in 1 to 3 'inner'
						sum = sum + i * j
				end 'inner'
		end 'outer'
		return sum
end 'main'

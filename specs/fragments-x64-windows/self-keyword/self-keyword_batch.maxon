// --- batched test: self-explicit-access ---

typealias _b_self_explicit_access_Integer = int(i64.min to i64.max)

type _b_self_explicit_access_Counter
	var count _b_self_explicit_access_Integer

	function increment()
		self.count = self.count + 1
	end 'increment'

	function get() returns _b_self_explicit_access_Integer
		return self.count
	end 'get'

	static function create(count _b_self_explicit_access_Integer) returns Self
		return Self{count: count}
	end 'create'
end '_b_self_explicit_access_Counter'

function _b_self_explicit_access_main() returns ExitCode
	var c = _b_self_explicit_access_Counter.create(count: 0)
	c.increment()
	c.increment()
	return c.get()
end '_b_self_explicit_access_main'


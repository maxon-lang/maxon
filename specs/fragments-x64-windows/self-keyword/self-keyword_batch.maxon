// --- batched test: self-with-params ---

typealias _b_self_with_params_Integer = int(i64.min to i64.max)

type _b_self_with_params_Accumulator
	var total _b_self_with_params_Integer

	function add(value _b_self_with_params_Integer)
		self.total = self.total + value
	end 'add'

	function getTotal() returns _b_self_with_params_Integer
		return self.total
	end 'getTotal'

	static function create(total _b_self_with_params_Integer) returns Self
		return Self{total: total}
	end 'create'
end '_b_self_with_params_Accumulator'

function _b_self_with_params_main() returns ExitCode
	let acc = _b_self_with_params_Accumulator.create(total: 0)
	acc.add(10)
	acc.add(20)
	acc.add(12)
	return acc.getTotal()
end '_b_self_with_params_main'


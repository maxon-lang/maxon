    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r8, [rip+__panic_msg_0]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

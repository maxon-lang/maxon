// Test: mixed-default-and-literal

typealias Integer = int(i64.min to i64.max)

type Mixed
	export var a = 10
	export var b as Integer

	export static function make(b Integer) returns Self
		return Self{b: b}
	end 'make'
end 'Mixed'

function main() returns ExitCode
	let m = Mixed.make(32)
	return m.a + m.b
end 'main'

  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.je other_0
  br_0:
    x64.xor eax, eax
    x64.xor edx, edx
    x64.mov ecx, 8
    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov rcx, r12
    x64.call stdlib.__mm_incref
    x64.mov r8d, 42
    x64.mov [r12+0], r8 (8b)
    x64.mov r8, r12
    x64.epilogue
    x64.ret
  other_0:
    x64.xor eax, eax
    x64.xor edx, edx
    x64.mov ecx, 8
    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov rcx, r12
    x64.call stdlib.__mm_incref
    x64.mov r8d, 42
    x64.neg r8
    x64.mov [r12+0], r8 (8b)
    x64.mov r8, r12
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 1
    x64.call TwoReturns.make
    x64.mov r12, [r8+0] (8b)
    x64.mov rcx, r8
    x64.call __mm_decref_maybenull_helper
    x64.mov r8d, 4294967295
    x64.cmp r12, r8
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_85b1005d287f841b]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r12
    x64.epilogue
    x64.ret
  }
}

// Test: factory-multiple-returns

typealias Integer = int(i64.min to i64.max)

type TwoReturns
	export var value Integer

	export static function make(sign bool) returns Self
		if sign 'br'
			self.value = 42
			return Self{}
		end 'br' else 'other'
			self.value = -42
			return Self{}
		end 'other'
	end 'make'
end 'TwoReturns'

function main() returns ExitCode
	let t = TwoReturns.make(true)
	return t.value
end 'main'

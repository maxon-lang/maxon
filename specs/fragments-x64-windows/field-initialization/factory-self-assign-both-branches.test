// Test: factory-self-assign-both-branches

typealias Integer = int(i64.min to i64.max)

type Branched
	export var value as Integer

	export static function make(sign bool) returns Self
		if sign 'br'
			self.value = 42
		end 'br' else 'other'
			self.value = -42
		end 'other'
		return Self{}
	end 'make'
end 'Branched'

function main() returns ExitCode
	let b = Branched.make(true)
	return b.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Branched.make(rcx: i1) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.je other_0
  br_0:
    x64.mov r8d, 42
    x64.mov r12, r8
    x64.jmp br_0.merge
  other_0:
    x64.mov r8d, 42
    x64.neg r8
    x64.mov r12, r8
  br_0.merge:
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 1
    x64.call Branched.make
    x64.mov r9, [r8+0] (8b)
    x64.mov r8d, 4294967295
    x64.cmp r9, r8
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_aeef911bfaa0ccd9]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

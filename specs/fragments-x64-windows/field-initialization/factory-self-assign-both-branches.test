// Test: factory-self-assign-both-branches

typealias Integer = int(i64.min to i64.max)

type Branched
	export var value Integer

	export static function make(sign bool) returns Self
		if sign 'br'
			self.value = 42
		end 'br' else 'other'
			self.value = -42
		end 'other'
		return Self{}
	end 'make'
end 'Branched'

function main() returns ExitCode
	let b = Branched.make(true)
	return b.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Branched.make(sign: i1) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.test rcx, rcx
    x64.je Branched.make.other_1
  br_0:
    x64.mov rax, 42
    x64.mov [rbp-8], rax
    x64.jmp Branched.make.br_0.merge
  other_1:
    x64.mov rax, -42
    x64.mov [rbp-8], rax
    x64.jmp Branched.make.br_0.merge
  br_0.merge:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 8
    x64.xor edx, edx
    x64.mov r8, 6
    x64.call mm_alloc
    x64.mov [rbp-16], rax
    x64.mov rcx, [rbp-16]
    x64.mov rdx, [rbp-8]
    x64.mov [rcx+0], rdx
    x64.mov rbx, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @field-initialization.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.call Branched.make
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg field-initialization.main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl field-initialization.main.__range_panic_0
    x64.jmp field-initialization.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_5]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rcx
    x64.test rax, rax
    x64.jz __nonnull_skip_5
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_5
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Branched(ptr: i64) {
  entry:
    x64.jmp __destruct_Branched.done
  done:
    x64.ret
  }
}

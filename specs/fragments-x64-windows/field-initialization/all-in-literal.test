// Test: all-in-literal

typealias Integer = int(i64.min to i64.max)

type Point
	export var x as Integer
	export var y as Integer

	export static function make(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'make'
end 'Point'

function main() returns ExitCode
	let p = Point.make(1, y: 41)
	return p.x + p.y
end 'main'

    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg field-initialization.main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl field-initialization.main.__range_panic_0
    x64.jmp field-initialization.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_2]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rcx
    x64.test rax, rax
    x64.jz __nonnull_skip_2

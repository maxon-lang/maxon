// Test: missing-field-errors

typealias Integer = int(i64.min to i64.max)

type P
	export var x as Integer
	export var y as Integer

	export static function make(x Integer) returns Self
		return Self{x: x}
	end 'make'
end 'P'

function main() returns ExitCode
	_ = P.make(0)
	return 0
end 'main'

// Test: basic-interface-dispatch

typealias Integer = int(i64.min to i64.max)

interface Greeter
	function greet() returns Integer
end 'Greeter'

type Hello implements Greeter
	let value Integer

	function greet() returns Integer
		return value + 1
	end 'greet'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Hello'

function callGreet(g Greeter) returns Integer
	return g.greet()
end 'callGreet'

function main() returns ExitCode
	let h = Hello.create(value: 41)
	return callGreet(h)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Hello.greet(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.add r8, 1
    x64.ret
  }
  func @callGreet(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rdx
    x64.mov r8, [rbp-16]
    x64.mov rcx, [rbp-8]
    x64.mov r10, [r8+24] (8b)
    x64.call r10
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 41
    x64.mov [r8+0], r9 (8b)
    x64.lea rdx, [rip+__witness_Hello_Greeter]
    x64.mov rcx, r8
    x64.call callGreet
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

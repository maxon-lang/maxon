// Test: dispatch-multiple-types

typealias Integer = int(i64.min to i64.max)

interface Scorer
	function score() returns Integer
end 'Scorer'

type Alpha implements Scorer
	let n Integer

	function score() returns Integer
		return n * 2
	end 'score'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Alpha'

type Beta implements Scorer
	let n Integer

	function score() returns Integer
		return n * 3
	end 'score'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Beta'

function getScore(s Scorer) returns Integer
	return s.score()
end 'getScore'

function main() returns ExitCode
	let a = Alpha.create(10)
	let b = Beta.create(10)
	return getScore(a) + getScore(b)
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @Alpha.score(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.mov r9d, 2
    x64.imul r8, r9
    x64.ret
  }
  func @Beta.score(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.mov r9d, 3
    x64.imul r8, r9
    x64.ret
  }
  func @getScore(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rdx
    x64.mov r8, [rbp-16]
    x64.mov rcx, [rbp-8]
    x64.mov r10, [r8+24] (8b)
    x64.call r10
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 10
    x64.mov [r12+0], r8 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r13, r8
    x64.mov r8d, 10
    x64.mov [r13+0], r8 (8b)
    x64.lea rdx, [rip+__witness_Alpha_Scorer]
    x64.mov rcx, r12
    x64.call getScore
    x64.mov r12, r8
    x64.lea rdx, [rip+__witness_Beta_Scorer]
    x64.mov rcx, r13
    x64.call getScore
    x64.mov r9d, 4294967295
    x64.mov rsi, r12
    x64.add rsi, r8
    x64.cmp rsi, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, rsi
    x64.epilogue
    x64.ret
  }

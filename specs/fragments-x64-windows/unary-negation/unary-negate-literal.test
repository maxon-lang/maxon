// Test: unary-negate-literal
function main() returns ExitCode
	var x = -5
	return 47 + x
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 5
    x64.mov rcx, rax
    x64.neg rcx
    x64.mov rdx, 47
    x64.mov rax, rdx
    x64.add rax, rcx
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

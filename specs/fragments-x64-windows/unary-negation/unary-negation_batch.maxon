// --- batched test: unary-negate-variable ---
function _b_unary_negate_variable_main() returns ExitCode
	let x = 47
	let y = -x
	print("{42 + y}\n")
	return 0
end '_b_unary_negate_variable_main'

// --- batched test: unary-negate-literal ---
function _b_unary_negate_literal_main() returns ExitCode
	let x = -5
	return 47 + x
end '_b_unary_negate_literal_main'

// --- batched test: unary-negate-expression ---
function _b_unary_negate_expression_main() returns ExitCode
	let x = 10
	let y = 5
	let z = -(x + y)
	return 57 + z
end '_b_unary_negate_expression_main'

// --- batched test: unary-negate-float ---
function _b_unary_negate_float_main() returns ExitCode
	let f = 3.5
	let g = -f
	return trunc(g + 45.5)
end '_b_unary_negate_float_main'

// --- batch dispatcher for unary-negation ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:unary-negate-variable>>>\n")
	let ec_unary_negate_variable = _b_unary_negate_variable_main()
	print("\n<<<MAXON_BATCH_TEST_END:unary-negate-variable:{ec_unary_negate_variable}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:unary-negate-literal>>>\n")
	let ec_unary_negate_literal = _b_unary_negate_literal_main()
	print("\n<<<MAXON_BATCH_TEST_END:unary-negate-literal:{ec_unary_negate_literal}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:unary-negate-expression>>>\n")
	let ec_unary_negate_expression = _b_unary_negate_expression_main()
	print("\n<<<MAXON_BATCH_TEST_END:unary-negate-expression:{ec_unary_negate_expression}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:unary-negate-float>>>\n")
	let ec_unary_negate_float = _b_unary_negate_float_main()
	print("\n<<<MAXON_BATCH_TEST_END:unary-negate-float:{ec_unary_negate_float}>>>\n")
	return 0 as ExitCode
end 'main'

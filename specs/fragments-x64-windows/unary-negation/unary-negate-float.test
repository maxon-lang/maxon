// Test: unary-negate-float
function main() returns ExitCode
	let f = 3.5
	let g = -f
	return trunc(g + 45.5)
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.5]
    x64.movsd xmm1, [rip+__float_0]
    x64.movsd xmm2, xmm1
    x64.subsd xmm2, xmm0
    x64.movsd xmm3, [rip+__float_45.5]
    x64.movsd xmm4, xmm2
    x64.addsd xmm4, xmm3
    x64.cvttsd2si rax, xmm4
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

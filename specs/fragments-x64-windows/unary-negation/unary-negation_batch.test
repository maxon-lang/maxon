// Batch: unary-negation
// Tests: unary-negate-variable, unary-negate-literal, unary-negate-expression, unary-negate-float
---
// Test: unary-negate-variable
function main() returns ExitCode
	let x = 47
	let y = -x
	print("{42 + y}\n")
	return 0
end 'main'
---
Stdout: ```
-5
```
---
// Test: unary-negate-literal
function main() returns ExitCode
	let x = -5
	return 47 + x
end 'main'
---
ExitCode: 42
---
// Test: unary-negate-expression
function main() returns ExitCode
	let x = 10
	let y = 5
	let z = -(x + y)
	return 57 + z
end 'main'
---
ExitCode: 42
---
// Test: unary-negate-float
function main() returns ExitCode
	let f = 3.5
	let g = -f
	return trunc(g + 45.5)
end 'main'
---
ExitCode: 42
---

    x64.prologue stack_size=48
    x64.lea rax, [rip+__str_0]
    x64.mov rcx, 47
    x64.mov rdx, rcx
    x64.neg rdx
    x64.mov rbx, 42
    x64.mov rsi, rbx
    x64.add rsi, rdx
    x64.mov rcx, rsi
    x64.mov [rbp+-16], rax
    x64.mov [rbp+-24], rcx
    x64.call mrt_printInt
    x64.mov rdi, [rbp+-16]
    x64.mov rcx, rdi
    x64.mov rdx, 1

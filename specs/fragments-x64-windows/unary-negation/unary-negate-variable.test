// Test: unary-negate-variable
function main() returns ExitCode
	let x = 47
	let y = -x
	print("{42 + y}\n")
	return 0
end 'main'
---
Stdout: ```
-5
```
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=64
    x64.lea rcx, [rip+__str_0]
    x64.mov rbx, 47
    x64.mov rsi, rbx
    x64.neg rsi
    x64.mov rdi, 42
    x64.mov r8, rdi
    x64.add r8, rsi
    x64.mov [rbp+-16], rcx
    x64.mov rcx, r8
    x64.mov r12, rcx
    x64.call mrt_printInt
    x64.mov r9, [rbp+-16]
    x64.mov rcx, r9
    x64.mov rdx, 1
    x64.mov r13, rax
    x64.mov r14, rcx
    x64.call mrt_write_stdout
    x64.mov [rbp+-24], rax
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}

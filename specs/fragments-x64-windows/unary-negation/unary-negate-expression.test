// Test: unary-negate-expression
function main() returns ExitCode
	let x = 10
	let y = 5
	let z = -(x + y)
	return 57 + z
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rbx, 15
    x64.mov rsi, rbx
    x64.neg rsi
    x64.mov rdi, 57
    x64.mov r8, rdi
    x64.add r8, rsi
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, r8
    x64.epilogue
    x64.ret
  }
}
---

// Test: unary-negate-expression
function main() returns ExitCode
	let x = 10
	let y = 5
	let z = -(x + y)
	return 57 + z
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ebx, 15
    x64.mov r8d, 57
    x64.neg rbx
    x64.add r8, rbx
    x64.cmp r8, 125
    x64.mov ebx, 5
    x64.mov ebx, 10
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

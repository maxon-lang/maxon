  entry:
    x64.prologue stack_size=16
    x64.mov rax, 20
    x64.mov rcx, 22
    x64.add rax, rcx
    x64.mov rcx, rax
    x64.call pass-by-reference.readVal
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg pass-by-reference.main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl pass-by-reference.main.__range_panic_0
    x64.jmp pass-by-reference.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

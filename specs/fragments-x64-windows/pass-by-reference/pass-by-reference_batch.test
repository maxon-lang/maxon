// Batch: pass-by-reference
// Tests: pass-by-reference.basic-primitive-ref, pass-by-reference.mutate-primitive-ref, pass-by-reference.immutable-primitive-ref, pass-by-reference.literal-creates-temporary, pass-by-reference.expression-creates-temporary, pass-by-reference.struct-ref-field-mutation, pass-by-reference.struct-ref-reassignment, pass-by-reference.nested-calls, pass-by-reference.multiple-params-mixed, pass-by-reference.enum-ref, pass-by-reference.default-param-value, pass-by-reference.closure-capture-by-ref, pass-by-reference.closure-capture-after-mutation
---
// Test: pass-by-reference.basic-primitive-ref

typealias Integer = int(i64.min to i64.max)

function readVal(x Integer) returns Integer
	return x
end 'readVal'

function main() returns ExitCode
	let n = 42
	return readVal(x: n)
end 'main'
---
ExitCode: 42
---
// Test: pass-by-reference.mutate-primitive-ref

typealias Integer = int(i64.min to i64.max)

function setTo99(x Integer)
	x = 99
end 'setTo99'

function main() returns ExitCode
	var n = 0
	setTo99(x: n)
	print("{n}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
99
```
---

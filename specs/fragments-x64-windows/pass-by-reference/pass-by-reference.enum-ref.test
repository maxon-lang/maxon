// Test: pass-by-reference.enum-ref

enum Color
	red
	blue
	green
end 'Color'

function switchColor(c Color)
	c = Color.green
end 'switchColor'

function main() returns ExitCode
	var c = Color.red
	switchColor(c: c)
	return c.rawValue
end 'main'
---
ExitCode: 2
---
module {
  func @pass-by-reference.switchColor(c: i64) {

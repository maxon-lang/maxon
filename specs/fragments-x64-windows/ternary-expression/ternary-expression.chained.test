    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg ternary-expression.main.__range_panic_2
    x64.cmp rax, rcx
    x64.jl ternary-expression.main.__range_panic_2
    x64.jmp ternary-expression.main.__range_ok_2
  __range_panic_2:
    x64.lea_symdata rax, [__panic_msg_5]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_2:

// Test: ternary-expression.chained
function main() returns ExitCode
	let a = false
	let b = true
	let x = 1 if a else 2 if b else 3
	return x
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov r9d, 1
    x64.xor esi, esi
  ternary.merge:
    x64.test rsi, rsi
    x64.je ternary.else
    x64.mov r8, r9
    x64.jmp ternary.merge
  ternary.else:
  ternary.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0fb08625d74c3e87]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

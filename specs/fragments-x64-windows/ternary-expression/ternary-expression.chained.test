    x64.jmp ternary-expression.main.ternary_1.merge
  ternary_1.false:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp ternary-expression.main.ternary_1.merge
  ternary_1.merge:

    x64.mov [rbp-8], rax
    x64.jmp main.ternary_0.merge
  ternary_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1

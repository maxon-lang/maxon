// Batch: ternary-expression
// Tests: ternary-expression.basic-true, ternary-expression.basic-false, ternary-expression.with-variable-condition, ternary-expression.with-comparison, ternary-expression.with-strings, ternary-expression.string-interp-expression, ternary-expression.string-interp-nested-strings, ternary-expression.complex-expressions, ternary-expression.chained, ternary-expression.in-return, ternary-expression.with-floats, ternary-expression.with-bools, ternary-expression.false-path-strings, docs-example-1, docs-example-2, docs-example-3
---
// Test: ternary-expression.basic-true
function main() returns ExitCode
	let x = 10 if true else 20
	return x
end 'main'
---
ExitCode: 10
---
// Test: ternary-expression.basic-false
function main() returns ExitCode
	let x = 10 if false else 20
	return x
end 'main'
---
ExitCode: 20
---
// Test: ternary-expression.with-variable-condition
function main() returns ExitCode
	let flag = true
	let x = 1 if flag else 0
	return x
end 'main'
---
ExitCode: 1
---
// Test: ternary-expression.with-comparison
function main() returns ExitCode
	let a = 5
	let b = 3
	let x = 1 if a > b else 0
	return x
end 'main'
---
ExitCode: 1
---
// Test: ternary-expression.with-strings
function main() returns ExitCode
	let flag = true
	let s = "yes" if flag else "no"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
yes
```
---
// Test: ternary-expression.string-interp-expression
function main() returns ExitCode
	let x = 5
	let msg = "value: {x if x > 0 else 0}"
	print(msg)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
value: 5
```
---
// Test: ternary-expression.string-interp-nested-strings
function main() returns ExitCode
	let flag = true
	let msg = "status: {"on" if flag else "off"}"
	print(msg)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
status: on
```
---
// Test: ternary-expression.complex-expressions
function main() returns ExitCode
	let a = 3
	let b = 2
	let cond = true
	let x = a + b if cond else a * b
	return x
end 'main'
---
ExitCode: 5
---
// Test: ternary-expression.chained
function main() returns ExitCode
	let a = false
	let b = true
	let x = 1 if a else 2 if b else 3
	return x
end 'main'
---
ExitCode: 2
---
// Test: ternary-expression.in-return
function main() returns ExitCode
	let done = true
	return 1 if done else 0
end 'main'
---
ExitCode: 1
---
// Test: ternary-expression.with-floats
function main() returns ExitCode
	let x = 1.5 if true else 2.5
	return trunc(x)
end 'main'
---
ExitCode: 1
---
// Test: ternary-expression.with-bools
function main() returns ExitCode
	let x = true if true else false
	let result = 1 if x else 0
	return result
end 'main'
---
ExitCode: 1
---
// Test: ternary-expression.false-path-strings
function main() returns ExitCode
	let flag = false
	let s = "yes" if flag else "no"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
no
```
---
// Test: docs-example-1
function main() returns ExitCode
	let x = 10 if true else 20
	return x
end 'main'

---
ExitCode: 10
---
// Test: docs-example-2
function main() returns ExitCode
	let a = 5
	let b = 3
	let max = a if a > b else b
	return max
end 'main'

---
ExitCode: 5
---
// Test: docs-example-3
function main() returns ExitCode
	let flag = true
	let status = "Active" if flag else "Offline"
	print(status)
	return 0
end 'main'

---
ExitCode: 0
---

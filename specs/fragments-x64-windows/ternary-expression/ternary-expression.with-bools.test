// Test: ternary-expression.with-bools
function main() returns ExitCode
	let x = true if true else false
	let result = 1 if x else 0
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 1
  ternary.merge:
    x64.xor r9d, r9d
    x64.mov esi, 1
    x64.test r8, r8
    x64.je ternary.else
    x64.mov r8, rsi
    x64.jmp ternary.merge
  ternary.else:
    x64.mov r8, r9
  ternary.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_09f9f848750ca52e]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

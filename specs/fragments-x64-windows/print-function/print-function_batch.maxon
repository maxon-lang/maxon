// --- batched test: basic ---
function _b_basic_main() returns ExitCode
	let x = 42
	print("{x}\n")
	return 0
end '_b_basic_main'

// --- batched test: expression ---
function _b_expression_main() returns ExitCode
	print("{10 + 5}\n")
	return 0
end '_b_expression_main'

// --- batched test: multiple-calls ---
function _b_multiple_calls_main() returns ExitCode
	let x = 42
	print("{x}\n")
	print("{10 + 5}\n")
	print("{100}\n")
	return 0
end '_b_multiple_calls_main'

// --- batched test: composite-interp ---
function _b_composite_interp_main() returns ExitCode
	let x = 42
	print("value is {x} and doubled is {x + x}\n")
	return 0
end '_b_composite_interp_main'

// --- batched test: docs-example-1 ---
function _b_docs_example_1_main() returns ExitCode
	let x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end '_b_docs_example_1_main'

// --- batch dispatcher for print-function ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:basic>>>\n")
	let ec_basic = _b_basic_main()
	print("\n<<<MAXON_BATCH_TEST_END:basic:{ec_basic}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:expression>>>\n")
	let ec_expression = _b_expression_main()
	print("\n<<<MAXON_BATCH_TEST_END:expression:{ec_expression}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multiple-calls>>>\n")
	let ec_multiple_calls = _b_multiple_calls_main()
	print("\n<<<MAXON_BATCH_TEST_END:multiple-calls:{ec_multiple_calls}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:composite-interp>>>\n")
	let ec_composite_interp = _b_composite_interp_main()
	print("\n<<<MAXON_BATCH_TEST_END:composite-interp:{ec_composite_interp}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:docs-example-1>>>\n")
	let ec_docs_example_1 = _b_docs_example_1_main()
	print("\n<<<MAXON_BATCH_TEST_END:docs-example-1:{ec_docs_example_1}>>>\n")
	return 0 as ExitCode
end 'main'

// Batch: print-function
// Tests: basic, expression, multiple-calls, composite-interp, docs-example-1
---
// Test: basic
function main() returns ExitCode
	let x = 42
	print("{x}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
42
```
---
// Test: expression
function main() returns ExitCode
	print("{10 + 5}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
15
```
---
// Test: multiple-calls
function main() returns ExitCode
	let x = 42
	print("{x}\n")
	print("{10 + 5}\n")
	print("{100}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
42
15
100
```
---
// Test: composite-interp
function main() returns ExitCode
	let x = 42
	print("value is {x} and doubled is {x + x}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
value is 42 and doubled is 84
```
---
// Test: docs-example-1
function main() returns ExitCode
	let x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end 'main'

---
ExitCode: 0
---

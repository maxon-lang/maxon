// Test: docs-example-1
function main() returns ExitCode
	let x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=112
    x64.lea rcx, [rip+__str_0]
    x64.lea rbx, [rip+__str_0]
    x64.lea rsi, [rip+__str_0]
    x64.mov [rbp+-32], rcx
    x64.mov rcx, 42
    x64.mov r12, rbx
    x64.mov r13, rsi
    x64.call mrt_printInt
    x64.mov rcx, r13
    x64.mov rdx, 1
    x64.mov r13, rax
    x64.mov r14, rcx
    x64.call mrt_write_stdout
    x64.mov rcx, 15
    x64.mov r15, rax
    x64.call mrt_printInt
    x64.mov rcx, r12
    x64.mov rdx, 1
    x64.mov r12, rax
    x64.mov [rbp+-40], rcx
    x64.call mrt_write_stdout
    x64.mov rcx, 100
    x64.mov [rbp+-48], rax
    x64.call mrt_printInt
    x64.mov rdi, [rbp+-32]
    x64.mov rcx, rdi
    x64.mov rdx, 1
    x64.mov [rbp+-56], rax
    x64.call mrt_write_stdout
    x64.mov [rbp+-64], rax
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}

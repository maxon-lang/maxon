// Test: docs-example-1
function main() returns ExitCode
	var x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=112
    x64.lea rax, [rip+__str_0]
    x64.lea rcx, [rip+__str_0]
    x64.lea rdx, [rip+__str_0]
    x64.mov [rbp+-32], rcx
    x64.mov rcx, 42
    x64.mov [rbp+-40], rax
    x64.mov [rbp+-48], rdx
    x64.call mrt_printInt
    x64.mov rbx, [rbp+-48]
    x64.mov rcx, rbx
    x64.mov rdx, 1
    x64.mov [rbp+-56], rax
    x64.call mrt_write_stdout
    x64.mov rcx, 15
    x64.mov [rbp+-64], rax
    x64.call mrt_printInt
    x64.mov rsi, [rbp+-32]
    x64.mov rcx, rsi
    x64.mov rdx, 1
    x64.mov [rbp+-72], rax
    x64.call mrt_write_stdout
    x64.mov rcx, 100
    x64.mov [rbp+-80], rax
    x64.call mrt_printInt
    x64.mov rdi, [rbp+-40]
    x64.mov rcx, rdi
    x64.mov rdx, 1
    x64.mov [rbp+-88], rax
    x64.call mrt_write_stdout
    x64.mov [rbp+-96], rax
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}

// Test: docs-example-1
function main() returns ExitCode
	let x = 42
	print("{x}\n")        // Prints: 42
	print("{10 + 5}\n")   // Prints: 15
	print("{100}\n")      // Prints: 100
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 42
    x64.call mrt_printInt
    x64.mov edx, 1
    x64.lea rcx, [rip+__str_0]
    x64.call mrt_write_stdout
    x64.mov ecx, 15
    x64.call mrt_printInt
    x64.mov edx, 1
    x64.lea rcx, [rip+__str_0]
    x64.call mrt_write_stdout
    x64.mov ecx, 100
    x64.call mrt_printInt
    x64.mov edx, 1
    x64.lea rcx, [rip+__str_0]
    x64.call mrt_write_stdout
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

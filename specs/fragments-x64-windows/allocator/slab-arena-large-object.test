// Test: slab-arena-large-object
function main() returns ExitCode
	let p = __mm_raw_alloc(40000)
	__mm_raw_free(p)
	let count = __mm_raw_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 40000
    x64.mov rcx, r8
    x64.call mm_raw_alloc
    x64.mov rcx, r8
    x64.call mm_raw_free
    x64.lea r8, [rip+__mm_raw_alloc_count]
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.jne ok_1.after
  ok_1:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  ok_1.after:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

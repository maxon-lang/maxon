    x64.call mm_decref
    x64.xor r8d, r8d
    x64.xor r9d, r9d
    x64.mov esi, 40
    x64.mov rcx, rsi
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call mm_alloc
    x64.mov rcx, r8
    x64.call mm_decref
    x64.lea r8, [rip+__mm_alloc_count]
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.jne ok_1.after
  ok_1:
    x64.xor r9d, r9d

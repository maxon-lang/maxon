// Test: slab-free-reuses-slot-no-os-alloc
function main() returns ExitCode
	let a = __mm_alloc(40, destructor: 0, tag: 0)
	__mm_decref(a)
	let b = __mm_alloc(40, destructor: 0, tag: 0)
	__mm_decref(b)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---

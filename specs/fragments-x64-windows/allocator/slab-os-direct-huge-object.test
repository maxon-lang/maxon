// Test: slab-os-direct-huge-object
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = IntArray.create()
	arr.reserve(10485760)
	return arr.count()
end 'main'

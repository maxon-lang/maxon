// Test: raw-alloc-basic
function main() returns ExitCode
	let p = __mm_alloc(64, destructor: 0, tag: 0)
	__mm_decref(p)
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.xor r9d, r9d
    x64.mov esi, 64
    x64.mov rcx, rsi
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call mm_alloc
    x64.mov rcx, r8
    x64.call mm_decref
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

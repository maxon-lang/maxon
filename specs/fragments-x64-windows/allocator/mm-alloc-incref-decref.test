// Test: mm-alloc-incref-decref
function main() returns ExitCode
	let p = __mm_alloc(64, destructor: 0, tag: 0)
	__mm_incref(p)
	__mm_incref(p)
	__mm_incref(p)
	__mm_decref(p)
	__mm_decref(p)
	__mm_decref(p)
	let after3 = __mm_alloc_count()
	__mm_decref(p)
	let after4 = __mm_alloc_count()
	var fail = 0
	if after3 != 1 'a'
		fail = 1
	end 'a'
	if after4 != 0 'b'
		fail = fail + 2
	end 'b'
	if fail == 0 'ok'
		return 0
	end 'ok'
	if fail == 1 'f1'
		return 1
	end 'f1'
	if fail == 2 'f2'
		return 2
	end 'f2'
	return 3
end 'main'

	__mm_raw_free(f)
	__mm_raw_free(g)
	__mm_raw_free(h)
	__mm_raw_free(i)
	__mm_raw_free(j)
	let count = __mm_raw_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'

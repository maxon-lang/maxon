// Test: i32-unsigned-cmp
typealias SmallInt = int(0 to 1000)

function main() returns ExitCode
	let a = 10 as SmallInt
	let b = 3 as SmallInt
	if a > b 'check'
		return 1
	end 'check'
	return 0
end 'main'

    %1 = maxon.literal {value = 5 : f64}
    maxon.assign %1 {var = b} {kind = f64} {decl = 1 : i1} {mut = 1 : i1}
    %2 = maxon.binop %0, %1 {op = lt} {kind = f64}
    maxon.cond_br %2 [then: less_0, else: less_0.after]
  less_0:

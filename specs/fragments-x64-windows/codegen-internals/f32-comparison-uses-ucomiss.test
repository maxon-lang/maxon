// Test: f32-comparison-uses-ucomiss
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	var a = F{3.0}
	var b = F{5.0}
	if a < b 'less'
		return 1
	end 'less'
	return 0
end 'main'

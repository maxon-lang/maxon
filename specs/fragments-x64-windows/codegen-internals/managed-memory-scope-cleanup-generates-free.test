// Test: managed-memory-scope-cleanup-generates-free
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	if true 'outer'
		let outer_arr = IntArray.create()
		outer_arr.push(100)
		if true 'inner'
			let inner_arr = IntArray.create()
			inner_arr.push(200)
		end 'inner'
	end 'outer'
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.test rax, rax
    x64.je main.outer_0.merge
  outer_0:
    x64.call IntArray.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 100
    x64.call IntArray.push
    x64.mov rcx, 1
    x64.test rcx, rcx
    x64.je main.inner_1.merge
  inner_1:
    x64.call IntArray.create
    x64.mov [rbp-16], rax
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rbp-16]
    x64.mov rdx, 200
    x64.call IntArray.push
    x64.mov rcx, [rbp-16]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.jmp main.inner_1.merge
  inner_1.merge:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.jmp main.outer_0.merge
  outer_0.merge:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+16]
    x64.xor edx, edx
    x64.cmp rcx, rdx
    x64.je __destruct___ManagedMemory_Integer.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct___ManagedMemory_Integer.skip_buf_0
  skip_buf_0:
    x64.jmp __destruct___ManagedMemory_Integer.done
  done:
    x64.epilogue
    x64.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+8]
    x64.mov [rbp-16], rcx
    x64.test rcx, rcx
    x64.jz __nonnull_skip_2
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.jmp __destruct_IntArray.done
  done:
    x64.epilogue
    x64.ret
  }
}
---

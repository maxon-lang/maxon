// Test: error.unexported-field-read

typealias Integer = int(i64.min to i64.max)

type Value
	var private Integer

	static function create() returns Self
		return Value{private: 42}
	end 'create'
end 'Value'

function main() returns ExitCode
	let v = Value.create()
	return v.private
end 'main'

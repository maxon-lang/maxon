// Test: export-let-readonly

typealias Integer = int(i64.min to i64.max)

type Config
	export let version as Integer

	static function create() returns Self
		return Config{version: 42}
	end 'create'
end 'Config'

function main() returns ExitCode
	let c = Config.create()
	return c.version
end 'main'

// Test: export-var-write

typealias Integer = int(i64.min to i64.max)

type Value
	export var n Integer

	static function create() returns Self
		return Value{n: 10}
	end 'create'
end 'Value'

function main() returns ExitCode
	var v = Value.create()
	v.n = 42
	return v.n
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 10
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8d, 4294967295
    x64.cmp r9, r8
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

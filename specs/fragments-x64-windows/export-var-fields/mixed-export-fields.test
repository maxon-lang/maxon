// Test: mixed-export-fields

typealias Integer = int(i64.min to i64.max)

type Box
	export var value Integer
	var secret Integer

	static function create(v Integer, s Integer) returns Self
		return Box{value: v, secret: s}
	end 'create'

	function getSecret() returns Integer
		return secret
	end 'getSecret'
end 'Box'

function main() returns ExitCode
	let b = Box.create(20, s: 22)
	return b.value + b.getSecret()
end 'main'
---
ExitCode: 42
---
module {
  func @Box.create(v: i64, s: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-16], rcx
    x64.mov [rbp-24], rdx
    x64.mov rcx, 16
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @Box.getSecret(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+8]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 20
    x64.mov rdx, 22
    x64.call Box.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.mov rdx, [rbp-8]
    x64.mov [rbp-16], rcx
    x64.mov rcx, [rbp-8]
    x64.call Box.getSecret
    x64.mov rbx, [rbp-16]
    x64.add rbx, rax
    x64.xor rsi, rsi
    x64.mov edi, 4294967295
    x64.cmp rbx, rdi
    x64.jg main.__range_panic_0
    x64.cmp rbx, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rbx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Box(ptr: i64) {
  entry:
    x64.jmp __destruct_Box.done
  done:

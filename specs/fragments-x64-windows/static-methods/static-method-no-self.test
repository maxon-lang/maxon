// Test: static-method-no-self

typealias Integer = int(i64.min to i64.max)

type Math
	var unused Integer

	static function add(a Integer, b Integer) returns Integer
		return a + b
	end 'add'
end 'Math'

function main() returns ExitCode
	return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Math.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r9, rcx
    x64.add r9, rdx
    x64.mov r8, r9
    x64.ret
  }
  func @static-methods.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 22
    x64.mov r9d, 20
    x64.mov rcx, r9
    x64.mov rdx, r8
    x64.call Math.add
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

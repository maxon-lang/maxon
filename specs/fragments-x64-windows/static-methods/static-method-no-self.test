// Test: static-method-no-self

typealias Integer = int(i64.min to i64.max)

type Math
	var unused Integer

	static function add(a Integer, b Integer) returns Integer
		return a + b
	end 'add'
end 'Math'

function main() returns ExitCode
	return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Math.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r9, rcx
    x64.mov r8, r9
    x64.add r8, rdx
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 22
    x64.mov ecx, 20
    x64.call Math.add
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

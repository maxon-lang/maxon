// Test: static-method-basic

typealias Integer = int(i64.min to i64.max)

type Box
	export var value Integer

	static function make(v Integer) returns Box
		return Box{value: v}
	end 'make'
end 'Box'

function main() returns ExitCode
	let b = Box.make(42)
	return b.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Box.make(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @static-methods.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 42
    x64.call Box.make
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

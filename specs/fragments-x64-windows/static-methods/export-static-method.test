// Test: export-static-method

typealias Integer = int(i64.min to i64.max)

type Factory
	export var id Integer

	export static function create(val Integer) returns Factory
		return Factory{id: val}
	end 'create'

	export static function zero() returns Factory
		return Factory.create(0)
	end 'zero'
end 'Factory'

function main() returns ExitCode
	let f1 = Factory.create(100)
	let f2 = Factory.zero()
	return f1.id + f2.id
end 'main'
---
ExitCode: 100
---
// CompiledIR
module {
  func @Factory.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @Factory.zero() -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 0
    x64.call Factory.create
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.mov ecx, 100
    x64.call Factory.create
    x64.mov r12, r8
    x64.call Factory.zero
    x64.mov rbx, [r8+0] (8b)
    x64.mov r8, [r12+0] (8b)
    x64.add r8, rbx
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

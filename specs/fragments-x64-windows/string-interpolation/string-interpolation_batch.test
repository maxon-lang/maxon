// Batch: string-interpolation
// Tests: basic-variable, multiple-variables, integer-interpolation, integer-literal, negative-integer, negative-unary, float-interpolation, float-literal, negative-float, bool-true, bool-false, bool-literal, expression-interpolation, complex-expression, parenthesized-expression, empty-parts, adjacent-interpolations, three-adjacent, string-variable, escaped-braces, mixed-escaped, interpolation-loop, function-call, method-call, comparison-interpolation, logical-expression, float-arithmetic, mixed-types, large-integer, zero-values, newline-interpolation, tab-interpolation, custom-stringable, stringable-format-spec, multiple-stringable, int-enum-interpolation, simple-enum-interpolation, string-enum-interpolation, multiple-enum-interpolation, int-format-zero-pad, int-format-hex, int-format-width, int-format-neg-zero-pad, float-format-precision, float-format-width-precision, enum-rawvalue-format
---
// Test: basic-variable
function main() returns ExitCode
	let name = "World"
	print("Hello, {name}!")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
Hello, World!
```
---
// Test: multiple-variables
function main() returns ExitCode
	let first = "Hello"
	let second = "World"
	print("{first}, {second}!")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
Hello, World!
```

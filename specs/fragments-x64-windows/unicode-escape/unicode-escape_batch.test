// Batch: unicode-escape
// Tests: unicode-escape.char-basic, unicode-escape.char-multibyte, unicode-escape.string-basic, unicode-escape.string-interp, unicode-escape.whitespace-chars
---
// Test: unicode-escape.char-basic
function main() returns ExitCode
	let excl = '\u0021'
	if excl == '!' 'check'
		print("PASS")
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
PASS
```
---
// Test: unicode-escape.char-multibyte
function main() returns ExitCode
	let sigma = '\u03A3'
	print("{sigma}")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
Σ
```
---
// Test: unicode-escape.string-basic
function main() returns ExitCode
	let s = "hello\u0021"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello!
```
---
// Test: unicode-escape.string-interp
function main() returns ExitCode
	let name = "world"
	let s = "hello\u0021 {name}"
	print(s)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello! world
```
---
// Test: unicode-escape.whitespace-chars
function main() returns ExitCode
	let ws = CharacterSet.whitespacesAndNewlines()
	let nbsp = '\u00A0'
	let enSpace = '\u2002'
	let ideoSpace = '\u3000'
	if ws.contains(nbsp) 'c1'
		print("nbsp ")
	end 'c1'
	if ws.contains(enSpace) 'c2'
		print("enSpace ")
	end 'c2'
	if ws.contains(ideoSpace) 'c3'
		print("ideoSpace")
	end 'c3'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
nbsp enSpace ideoSpace
```

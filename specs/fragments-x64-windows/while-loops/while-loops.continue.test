// Test: while-loops.continue
function main() returns ExitCode
	var sum = 0
	var i = 0
	while i < 5 'loop'
		i = i + 1
		if i == 3 'skip'
			continue
		end 'skip'
		sum = sum + i
	end 'loop'
	return sum
end 'main'

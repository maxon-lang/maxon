// Batch: while-loops
// Tests: while-loops.basic, while-loops.break, while-loops.zero-iterations, nested-control, while-loops.continue
---
// Test: while-loops.basic
function main() returns ExitCode
var x = 5
var i = 3
while i > 0 'loop'
x = x + 2
i = i - 1
if i == 0 'check'
break
end 'check'
end 'loop'
return x
end 'main'
---
ExitCode: 11
---
// Test: while-loops.break
function main() returns ExitCode
	var x = 5
	while true 'loop'
		x = x + 2
		if x == 11 'check'
			break
		end 'check'
	end 'loop'
	return x
end 'main'
---
ExitCode: 11
---
// Test: while-loops.zero-iterations
function main() returns ExitCode
	var x = 10
	while x < 5 'loop'
		x = x + 1
	end 'loop'
	return x
end 'main'
---
ExitCode: 10
---
// Test: nested-control
function main() returns ExitCode
	var result = 0
	var i = 0
	while i < 3 'outer'
		var j = 0
		while j < 3 'inner'
			if (i + j) mod 2 == 0 'even'
				result = result + 1
			end 'even'
			j = j + 1
		end 'inner'
		i = i + 1
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---
// Test: while-loops.continue
function main() returns ExitCode
	var sum = 0
	var i = 0
	while i < 5 'loop'
		i = i + 1
		if i == 3 'skip'
			continue
		end 'skip'
		sum = sum + i
	end 'loop'
	return sum
end 'main'
---
ExitCode: 12
---

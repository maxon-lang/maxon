// Test: while-loops.zero-iterations
function main() returns ExitCode
	var x = 10
	while x < 5 'loop'
		x = x + 1
	end 'loop'
	return x
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 10
  loop_0.header:
    x64.cmp r8, 5
    x64.jge loop_0.exit
  loop_0:
    x64.add r8, 1
    x64.jmp loop_0.header
  loop_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

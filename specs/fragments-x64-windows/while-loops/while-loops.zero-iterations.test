// Test: while-loops.zero-iterations
function main() returns ExitCode
	var x = 10
	while x < 5 'loop'
		x = x + 1
	end 'loop'
	return x
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @while-loops.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov [rbp-8], rax
    x64.jmp while-loops.main.loop_0.header
  loop_0.header:
    x64.mov rax, 5
    x64.mov rcx, [rbp-8]
    x64.cmp rcx, rax
    x64.jge while-loops.main.loop_0.exit
  loop_0:
    x64.mov rax, 1
    x64.mov rcx, [rbp-8]
    x64.add rcx, rax
    x64.mov [rbp-8], rcx
    x64.jmp while-loops.main.loop_0.header
  loop_0.exit:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg while-loops.main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl while-loops.main.__range_panic_1
    x64.jmp while-loops.main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_2]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

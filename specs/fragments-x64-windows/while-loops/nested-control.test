// Test: nested-control
function main() returns ExitCode
	var result = 0
	var i = 0
	while i < 3 'outer'
		var j = 0
		while j < 3 'inner'
			if (i + j) mod 2 == 0 'even'
				result = result + 1
			end 'even'
			j = j + 1
		end 'inner'
		i = i + 1
	end 'outer'
	return result
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.xor r9d, r9d
    x64.xchg r8, r9
  outer_0.header:
    x64.cmp r9, 3
    x64.jge outer_0.exit
  outer_0:
    x64.xor esi, esi
    x64.jmp inner_0.header
  outer_0.exit:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  inner_0.header:
    x64.cmp rsi, 3
    x64.jge inner_0.exit
  inner_0:
    x64.mov edi, 2
    x64.mov rax, r9
    x64.add rax, rsi
    x64.cqo
    x64.idiv rdi
    x64.test rdx, rdx
    x64.jne even_0.after
    x64.jmp even_0
  inner_0.exit:
    x64.add r9, 1
    x64.jmp outer_0.header
  even_0:
    x64.add r8, 1
  even_0.after:
    x64.add rsi, 1
    x64.jmp inner_0.header
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

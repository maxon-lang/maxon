// Test: void-return-type
function doNothing()
end 'doNothing'

function main() returns ExitCode
	doNothing()
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @void-return-type.doNothing() {
  entry:
    x64.xor rax, rax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call void-return-type.doNothing
    x64.mov [rbp+-8], rax
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

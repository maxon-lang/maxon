// Test: void-return-type
function doNothing()
end 'doNothing'

function main() returns ExitCode
	doNothing()
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @function-declaration.doNothing() {
  entry:
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call function-declaration.doNothing
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

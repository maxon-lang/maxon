// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function quadruple(x Integer) returns Integer
	return double(double(x))
end 'quadruple'

function main() returns ExitCode
	return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @nested-calls.double(ptr: i64) -> i64 {
  entry:
    x64.mov rbx, 2
    x64.imul rcx, rbx
    x64.mov rax, rcx
    x64.ret
  }
  func @nested-calls.quadruple(ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov r12, rcx
    x64.call nested-calls.double
    x64.mov rcx, rax
    x64.mov r13, rcx
    x64.call nested-calls.double
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 3
    x64.call nested-calls.quadruple
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

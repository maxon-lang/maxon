// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function quadruple(x Integer) returns Integer
	return double(double(x))
end 'quadruple'

function main() returns ExitCode
	return quadruple(3)
end 'main'
---
ExitCode: 12
---

// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function quadruple(x Integer) returns Integer
	return double(double(x))
end 'quadruple'

function main() returns ExitCode
	return quadruple(3)
end 'main'
---
ExitCode: 12
---
// CompiledIR
module {
  func @function-declaration.double(rcx: i64) -> i64 {
  entry:
    x64.mov r9d, 2
    x64.mov r8, rcx
    x64.imul r8, r9
    x64.ret
  }
  func @function-declaration.quadruple(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.call function-declaration.double
    x64.mov rcx, r8
    x64.call function-declaration.double
    x64.epilogue
    x64.ret
  }
  func @function-declaration.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 3
    x64.call function-declaration.quadruple
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea rcx, [rip+__panic_msg_2]
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

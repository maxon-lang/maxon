// Test: with-parameters

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(10, b: 20)
end 'main'
---
ExitCode: 30
---
module {
  func @with-parameters.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.add rcx, rdx
    x64.mov rax, -9223372036854775807
    x64.cmp rcx, rax
    x64.jge __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 20
    x64.call with-parameters.add
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

// Test: with-parameters

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(10, b: 20)
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @function-declaration.main() -> u8 {
  entry:
    x64.mov r9d, 30
    x64.mov r8, r9
    x64.ret
  }
}

// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
	return 3 + 4
end 'add'

function main() returns ExitCode
	return add()
end 'main'
---
ExitCode: 7
---
module {
  func @function-declaration.add() -> i64 {
  entry:
    x64.mov rax, 3
    x64.mov rcx, 4
    x64.add rax, rcx
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call function-declaration.add
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

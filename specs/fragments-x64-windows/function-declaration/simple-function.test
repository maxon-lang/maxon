// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
	return 3 + 4
end 'add'

function main() returns ExitCode
	return add()
end 'main'
---
ExitCode: 7
---
module {
  func @simple-function.add() -> i64 {
  entry:
    x64.mov rax, 7
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.call simple-function.add
    x64.cmp rax, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
	return 3 + 4
end 'add'

function main() returns ExitCode
	return add()
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 7
    x64.ret
  }
}
---

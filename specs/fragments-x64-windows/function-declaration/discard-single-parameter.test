// Test: discard-single-parameter

typealias Integer = int(i64.min to i64.max)

function useSecond(_ Integer, b Integer) returns Integer
	return b
end 'useSecond'

function main() returns ExitCode
	return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
module {
  func @discard-single-parameter.useSecond(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, -9223372036854775807
    x64.cmp rdx, rax
    x64.jge __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 42
    x64.call discard-single-parameter.useSecond
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea rax, [rip+__panic_msg_1]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

// Test: discard-single-parameter

typealias Integer = int(i64.min to i64.max)

function useSecond(_ Integer, b Integer) returns Integer
	return b
end 'useSecond'

function main() returns ExitCode
	return useSecond(10, b: 42)
end 'main'
---
ExitCode: 42
---
module {
  func @discard-single-parameter.useSecond(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.mov r8, rdx
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 42
    x64.mov ecx, 10
    x64.call discard-single-parameter.useSecond
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

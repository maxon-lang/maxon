// Test: docs-example-1

typealias Score = int(i64.min to i64.max)

function add(a Score, b Score) returns Score
	return a + b
end 'add'

function main() returns ExitCode
	return add(3, b: 4)
end 'main'
---
ExitCode: 7
---
module {
  func @docs-example-1.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rbx, rcx
    x64.mov rcx, rbx
    x64.add rcx, rdx
    x64.mov r8, rcx
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 4
    x64.mov ecx, 3
    x64.call docs-example-1.add
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: docs-example-2
function main() returns ExitCode
	let p = FilePath from "C:\\Users\\docs\\readme.md"
	print("{p.filename()}\n")
	print("{p.fileExtension()}\n")
	print("{p.stem()}\n")
	let parent = try p.parent() otherwise panic("no parent")
	print("{parent}\n")
	return 0
end 'main'

---
ExitCode: 0
---

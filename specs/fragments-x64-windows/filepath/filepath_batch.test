---
// Test: filepath-from-string
function main() returns ExitCode
	let p = FilePath from "C:\\test.txt"
	print("{p.toString()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
C:\test.txt
```
---
// Test: filepath-from-method
function main() returns ExitCode
	let p = try FilePath.from("hello.maxon") otherwise panic("bad path")
	print("{p}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello.maxon
```
---

---
module {
  func @main() -> u32 {
  entry:
    x64.movzx rax, byte [rip+a]
    x64.movzx rcx, byte [rip+c]
    x64.and rax, rcx
    x64.movzx rdx, byte [rip+b]
    x64.xor ebx, ebx
    x64.cmp rdx, rbx
    x64.sete rsi
    x64.movzx rsi, rsib
    x64.and rax, rsi
    x64.test rax, rax
    x64.je main.read_0.after
  read_0:
    x64.xor eax, eax
    x64.ret
  read_0.after:
    x64.mov rax, 1
    x64.ret
  }
}

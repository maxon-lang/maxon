module {
  func @top-level-var-increment.add(rcx: i64) {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_total]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_total]
    x64.add r9, rcx
    x64.mov [r8+0], r9 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5
    x64.call top-level-var-increment.add
    x64.mov ecx, 27
    x64.call top-level-var-increment.add
    x64.lea r9, [rip+__data_total]
    x64.mov r8, [r9+0] (8b)
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

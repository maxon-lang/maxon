// Test: top-level-var-increment

typealias Integer = int(i64.min to i64.max)

var total = 10

function add(n Integer)
	total = total + n
end 'add'

function main() returns ExitCode
	add(5)
	add(27)
	return total
end 'main'
---
ExitCode: 42
---

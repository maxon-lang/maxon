// Test: top-level-var-with-let
let BASE = 40
var offset = 0

function main() returns ExitCode
	offset = 2
	return BASE + offset
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_offset]
    x64.mov r9d, 2
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_offset]
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, r9
    x64.add r8, 40
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_6]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}
---

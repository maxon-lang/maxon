// Test: top-level-var-with-let
let BASE = 40
var offset = 0

function main() returns ExitCode
	offset = 2
	return BASE + offset
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 2
    x64.mov qword [rip+offset], rax
    x64.mov rcx, 40
    x64.mov rdx, qword [rip+offset]
    x64.add rcx, rdx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rcx, rsi
    x64.jg main.__range_panic_0
    x64.cmp rcx, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

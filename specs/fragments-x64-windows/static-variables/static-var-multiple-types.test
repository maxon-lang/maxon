// Test: static-var-multiple-types
type TypeA
	static var value = 10
end 'TypeA'

type TypeB
	static var value = 20
end 'TypeB'

function main() returns ExitCode
	TypeA.value = TypeA.value + 2
	TypeB.value = TypeB.value + 10
	return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_TypeA.value]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_TypeA.value]
    x64.add r9, 2
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_TypeB.value]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_TypeB.value]
    x64.add r9, 10
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_TypeB.value]
    x64.lea r9, [rip+__data_TypeA.value]
    x64.mov rsi, [r8+0] (8b)
    x64.mov r8, [r9+0] (8b)
    x64.add r8, rsi
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: static-var-multiple-types
type TypeA
	static var value = 10
end 'TypeA'

type TypeB
	static var value = 20
end 'TypeB'

function main() returns ExitCode
	TypeA.value = TypeA.value + 2
	TypeB.value = TypeB.value + 10
	return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, qword [rip+TypeA.value]
    x64.mov rcx, 2
    x64.add rax, rcx
    x64.mov qword [rip+TypeA.value], rax
    x64.mov rdx, qword [rip+TypeB.value]
    x64.mov rbx, 10
    x64.add rdx, rbx
    x64.mov qword [rip+TypeB.value], rdx
    x64.mov rsi, qword [rip+TypeA.value]
    x64.mov rdi, qword [rip+TypeB.value]
    x64.add rsi, rdi
    x64.xor r8d, r8d
    x64.mov r9, 4294967295
    x64.cmp rsi, r9
    x64.jg main.__range_panic_0
    x64.cmp rsi, r8
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rsi
    x64.epilogue
    x64.ret
  }
}
---

// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
	static var created = 0
	export var id Integer

	static function make(n Integer) returns Thing
		Thing.created = Thing.created + 1
		return Thing{id: n}
	end 'make'
end 'Thing'

function main() returns ExitCode
	let a = Thing.make(10)
	let b = Thing.make(20)
	return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
// CompiledIR
module {
  func @Thing.make(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.lea r8, [rip+__data_Thing.created]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_Thing.created]
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 10
    x64.call Thing.make
    x64.mov r12, r8
    x64.mov ecx, 20
    x64.call Thing.make
    x64.lea r9, [rip+__data_Thing.created]
    x64.mov rsi, [r12+0] (8b)
    x64.mov rdi, [r9+0] (8b)
    x64.mov r9, [r8+0] (8b)
    x64.add rdi, rsi
    x64.mov r8, rdi
    x64.add r8, r9
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

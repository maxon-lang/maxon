// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
	static var created = 0
	export var id Integer

	static function make(n Integer) returns Thing
		Thing.created = Thing.created + 1
		return Thing{id: n}
	end 'make'
end 'Thing'

function main() returns ExitCode
	let a = Thing.make(10)
	let b = Thing.make(20)
	return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
// CompiledIR
module {
  func @Thing.make(n: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, qword [rip+Thing.created]
    x64.mov rdx, 1
    x64.add rax, rdx
    x64.mov qword [rip+Thing.created], rax
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.mov [rcx+0], rdx
    x64.mov rbx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 10
    x64.call Thing.make
    x64.mov [rbp-8], rax
    x64.mov rcx, 20
    x64.call Thing.make
    x64.mov [rbp-16], rax
    x64.mov rax, qword [rip+Thing.created]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rcx+0]
    x64.add rax, rdx
    x64.mov rbx, [rbp-16]
    x64.mov rsi, [rbx+0]
    x64.add rax, rsi
    x64.xor edi, edi
    x64.mov r8, 4294967295
    x64.cmp rax, r8
    x64.jg static-variables.main.__range_panic_0
    x64.cmp rax, rdi
    x64.jl static-variables.main.__range_panic_0
    x64.jmp static-variables.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rcx, [rbp-16]
    x64.mov [rbp-24], rax
    x64.test rcx, rcx
    x64.jz __nonnull_skip_0
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Thing(ptr: i64) {
  entry:
    x64.jmp __destruct_Thing.done
  done:

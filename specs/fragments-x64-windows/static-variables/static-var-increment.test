// Test: static-var-increment
type Counter
	static var count = 0

	static function increment()
		Counter.count = Counter.count + 1
	end 'increment'
end 'Counter'

function main() returns ExitCode
	Counter.increment()
	Counter.increment()
	Counter.increment()
	return Counter.count
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @Counter.increment() {
  entry:
    x64.mov rax, qword [rip+Counter.count]
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov qword [rip+Counter.count], rax
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call Counter.increment
    x64.call Counter.increment
    x64.call Counter.increment
    x64.mov rax, qword [rip+Counter.count]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: static-var-bool
var initialized = false

function init()
	initialized = true
end 'init'

function main() returns ExitCode
	if initialized 'check1'
		return 1
	end 'check1'
	init()
	if initialized 'check2'
		return 42
	end 'check2'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @static-variables.init() {
  entry:
    x64.mov rax, 1
    x64.mov byte [rip+initialized], rax
    x64.ret
  }
  func @static-variables.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movzx rax, byte [rip+initialized]
    x64.test rax, rax
    x64.je static-variables.main.check1_0.after
  check1_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check1_0.after:
    x64.call static-variables.init
    x64.movzx rax, byte [rip+initialized]
    x64.test rax, rax
    x64.je static-variables.main.check2_1.after
  check2_1:
    x64.mov rax, 42
    x64.epilogue
    x64.ret
  check2_1.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

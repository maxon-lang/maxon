// Test: static-var-bool
var initialized = false

function init()
	initialized = true
end 'init'

function main() returns ExitCode
	if initialized 'check1'
		return 1
	end 'check1'
	init()
	if initialized 'check2'
		return 42
	end 'check2'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=32
    x64.lea r8, [rip+__data_initialized]
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.je check1_1.after
  check1_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check1_1.after:
    x64.lea r8, [rip+__data_initialized]
    x64.mov r9d, 1
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_initialized]
    x64.mov r9, [r8+0] (8b)
    x64.test r9, r9
    x64.je check2_3.after
  check2_3:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  check2_3.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: data-section-bool-then-i64-sorted
var flag = false
var counter = 42

function main() returns ExitCode
	if flag 'read'
		return 1
	end 'read'
	return counter - 42
end 'main'
---
ExitCode: 0
RequiredData: ```
i64 42
i8 0
```
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movzx rax, byte [rip+flag]
    x64.test rax, rax
    x64.je main.read_0.after
  read_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  read_0.after:
    x64.mov rax, qword [rip+counter]
    x64.mov rcx, 42
    x64.sub rax, rcx
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_1
    x64.cmp rax, rdx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

// Test: top-level-var-enum-initializer
enum Color
		Red
		Green
		Blue
end 'Color'

var current = Color.Green

function main() returns ExitCode
	let isGreen = match current 'check'
		Green gives true
		Red gives false
		Blue gives false
	end 'check'
	if isGreen 'check'
		current = Color.Blue
		let isBlue = match current 'check2'
			Blue gives true
			Red gives false
			Green gives false
		end 'check2'
		if isBlue 'check2'
			return 42
		end 'check2'
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.lea r8, [rip+__data_current]
    x64.mov r9, [r8+0] (8b)
    x64.xor esi, esi
    x64.cmp r9, 1
    x64.jne check_0.next0
    x64.jmp check_0.case0
  check_0.merge:
    x64.test r8, r8
    x64.je check_1.after
    x64.jmp check_1
  check_0.case0:
    x64.mov r8d, 1
    x64.jmp check_0.merge
  check_0.next0:
    x64.test r9, r9
    x64.jne check_0.next1
    x64.mov r8, rsi
    x64.jmp check_0.merge
  check_0.next1:
    x64.mov r9d, 2
    x64.mov r8, rsi
    x64.jmp check_0.merge
  check_1:
    x64.lea r8, [rip+__data_current]
    x64.mov r9d, 2
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_current]
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 2
    x64.jne check2_0.next0
    x64.jmp check2_0.case0
  check2_0.merge:
    x64.test r8, r8
    x64.je check_1.after
    x64.jmp check2_1
  check2_0.case0:
    x64.mov r8d, 1
    x64.jmp check2_0.merge
  check2_0.next0:
    x64.test r9, r9
    x64.jne check2_0.next1
    x64.mov r8, rsi
    x64.jmp check2_0.merge
  check2_0.next1:
    x64.mov r9d, 1
    x64.mov r8, rsi
    x64.jmp check2_0.merge
  check2_1:
    x64.mov r8d, 42
    x64.ret
  check_1.after:
    x64.mov r8, rsi
    x64.ret
  }
}

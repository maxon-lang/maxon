// Test: top-level-var-enum-initializer
enum Color
		Red
		Green
		Blue
end 'Color'

var current = Color.Green

function main() returns ExitCode
	let isGreen = match current 'check'
		Green gives true
		Red gives false
		Blue gives false
	end 'check'
	if isGreen 'check'
		current = Color.Blue
		let isBlue = match current 'check2'
			Blue gives true
			Red gives false
			Green gives false
		end 'check2'
		if isBlue 'check2'
			return 42
		end 'check2'
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---

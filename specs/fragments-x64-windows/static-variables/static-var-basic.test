// Test: static-var-basic
type Counter
	static var count = 0
end 'Counter'

function main() returns ExitCode
	Counter.count = 42
	return Counter.count
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_Counter.count]
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.lea r9, [rip+__data_Counter.count]
    x64.mov r8, [r9+0] (8b)
    x64.cmp r8, 125
    x64.jbe __range_ok_4
  __range_panic_4:
    x64.lea r8, [rip+__panic_msg_7]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_4:
    x64.epilogue
    x64.ret
  }
}
---

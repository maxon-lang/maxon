// Test: top-level-var-basic
var counter = 0

function main() returns ExitCode
	counter = 42
	return counter
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.lea r8, [rip+__data_counter]
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.lea r9, [rip+__data_counter]
    x64.mov r8, [r9+0] (8b)
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rcx
    x64.jmp enum-nested-struct-backing.main.dispatch_0.cmp0
  dispatch_0.cmp0:
    x64.mov rax, [rbp-24]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne enum-nested-struct-backing.main.dispatch_0.cmp1
  dispatch_0.case0:
    x64.mov rax, 10
    x64.mov [rbp-16], rax
    x64.jmp enum-nested-struct-backing.main.dispatch_0.merge
  dispatch_0.cmp1:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne enum-nested-struct-backing.main.dispatch_0.merge
  dispatch_0.case1:
    x64.mov rax, 20
    x64.mov [rbp-16], rax
    x64.jmp enum-nested-struct-backing.main.dispatch_0.merge
  dispatch_0.merge:
    x64.mov rax, [rbp-16]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg enum-nested-struct-backing.main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl enum-nested-struct-backing.main.__range_panic_0
    x64.jmp enum-nested-struct-backing.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue

// Test: nested-struct-backing-match
typealias Latency = int(0 to 50)

type Inner
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'Inner'

type Outer
	export let inner Inner
	export let fast bool

	static function create(inner Inner, fast bool) returns Self
		return Self{inner: inner, fast: fast}
	end 'create'
end 'Outer'

enum Op
	add = Outer.create(inner: Inner.create(latency: 1), fast: true)
	div = Outer.create(inner: Inner.create(latency: 40), fast: false)
end 'Op'

function main() returns ExitCode
	let op = Op.div
	return match op 'dispatch'
		add gives 10
		div gives 20
	end 'dispatch'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 1
    x64.jmp dispatch_0.next0
  dispatch_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  dispatch_0.next0:
    x64.cmp r9, 1
    x64.jne dispatch_0.merge
  dispatch_0.case1:
    x64.mov r8d, 20
    x64.jmp dispatch_0.merge
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 3
    x64.mov [r12+0], r8 (8b)
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 5
    x64.mov [r8+0], r9 (8b)
    x64.mov rdx, [r8+0] (8b)
    x64.mov rcx, [r12+0] (8b)
    x64.call int.compare
    x64.mov r9, r8
    x64.test r9, r9
    x64.jne check_0.next0
  check_0.case0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.next0:
    x64.cmp r9, 1
    x64.jne check_0.next1
  check_0.case1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.next1:
    x64.cmp r9, 2
    x64.jne check_0.next2
  check_0.case2:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  check_0.next2:
    x64.lea r12, [rip+__panic_msg_96c7daeb3f9a871f]
    x64.mov rcx, r12
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

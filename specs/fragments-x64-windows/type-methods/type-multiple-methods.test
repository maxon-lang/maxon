// Test: type-multiple-methods

typealias Integer = int(i64.min to i64.max)

type Counter
	var count Integer

	function increment()
		count = count + 1
	end 'increment'

	function decrement()
		count = count - 1
	end 'decrement'

	function reset()
		count = 0
	end 'reset'

	function get() returns Integer
		return count
	end 'get'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(count: 10)
	c.increment()
	c.increment()
	c.decrement()
	return c.get()
end 'main'
---
ExitCode: 11

// Test: type-multiple-methods

typealias Integer = int(i64.min to i64.max)

type Counter
	var count Integer

	function increment()
		count = count + 1
	end 'increment'

	function decrement()
		count = count - 1
	end 'decrement'

	function reset()
		count = 0
	end 'reset'

	function get() returns Integer
		return count
	end 'get'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(count: 10)
	c.increment()
	c.increment()
	c.decrement()
	return c.get()
end 'main'
---
ExitCode: 11
---
// CompiledIR
module {
  func @Counter.increment(rcx: i64) {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.add r8, 1
    x64.mov [rcx+0], r8 (8b)
    x64.ret
  }
  func @Counter.decrement(rcx: i64) {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.sub r8, 1
    x64.mov [rcx+0], r8 (8b)
    x64.ret
  }
  func @Counter.get(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @Counter.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.epilogue
    x64.ret
  }
  func @type-methods.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 10
    x64.call Counter.create
    x64.mov r12, r8
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.increment
    x64.mov rcx, r12
    x64.call Counter.decrement
    x64.mov rcx, r12
    x64.call Counter.get
    x64.cmp r8, 125
    x64.jbe __range_ok_3
  __range_panic_3:
    x64.lea rcx, [rip+__panic_msg_3]
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}
---

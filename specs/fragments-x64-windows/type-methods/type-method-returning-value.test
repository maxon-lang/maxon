// Test: type-method-returning-value

typealias Integer = int(i64.min to i64.max)

type Calculator
	var value Integer

	function double() returns Integer
		return value * 2
	end 'double'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	let c = Calculator.create(value: 21)
	return c.double()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Calculator.double(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.mov r9d, 2
    x64.mov rsi, r8
    x64.imul rsi, r9
    x64.mov r8, rsi
    x64.ret
  }
  func @Calculator.create(rcx: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r12, rcx
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r9, r8
    x64.mov [r9+0], r12 (8b)
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @type-methods.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 21
    x64.mov rcx, r8
    x64.call Calculator.create
    x64.mov rcx, r8
    x64.call Calculator.double
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea r8, [rip+__panic_msg_2]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}

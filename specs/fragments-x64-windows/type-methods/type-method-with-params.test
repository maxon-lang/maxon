    x64.mov [r9+0], r12 (8b)
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @type-methods.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov rcx, r8
    x64.call Adder.create
    x64.mov r12, r8
    x64.mov r8d, 10
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Adder.add
    x64.mov r8d, 32
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Adder.add
    x64.mov rcx, r12
    x64.call Adder.getTotal
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic

  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.add r8, rdx
    x64.mov [rcx+0], r8 (8b)
    x64.ret
  }
  func @Adder.getTotal(rcx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, r9
    x64.ret
  }
  func @Adder.create(rcx: i64) -> i64 {

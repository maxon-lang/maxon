// Batch: match-simple
// Tests: match-statements.simple, match-statements.default, match-statements.first-case, match-statements.or-patterns, match-statements.or-patterns-first, match-statements.or-patterns-second, match-expression.basic, match-expression.or-patterns, match-expression.default, match-statements.fallthrough, match-statements.fallthrough-chain, match-statements.fallthrough-to-default, match-statements.nested-in-function, match-statements.assignment, match-statements.function-call, match-enum.exhaustive, match-enum.expression, match-expression.used-in-expression, docs-example-1, docs-example-2, docs-example-3, docs-example-4, docs-example-5
---
// Test: match-statements.simple
function main() returns ExitCode
	let x = 2
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// Test: match-statements.default
function main() returns ExitCode
	let x = 99
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
// Test: match-statements.first-case
function main() returns ExitCode
	let x = 1
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 10
---
// Test: match-statements.or-patterns
function main() returns ExitCode
	let x = 3
	match x 'check'
		1 or 2 then return 10
		3 or 4 or 5 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---

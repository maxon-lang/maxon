// Test: match-expression.basic
function main() returns ExitCode
	let x = 2
	let result = match x 'eval'
		1 gives 10
		2 gives 20
		default gives 0
	end 'eval'
	return result
end 'main'
---
ExitCode: 20
---
// Test: match-expression.or-patterns

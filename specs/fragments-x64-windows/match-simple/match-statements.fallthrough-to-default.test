// Test: match-statements.fallthrough-to-default
function main() returns ExitCode
	let x = 3
	var result = 0
	match x 'check'
		1 then result = 10
		2 then result = 20
		3 then result = result + 20 and fallthrough
		default then result = result + 100
	end 'check'
	return result
end 'main'
---
ExitCode: 120
---

// Test: match-statements.fallthrough-to-default
function main() returns ExitCode
	let x = 3
	var result = 0
	match x 'check'
		1 then result = 10
		2 then result = 20
		3 then result = result + 20 and fallthrough
		default then result = result + 100
	end 'check'
	return result
end 'main'
---
ExitCode: 120
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 3
    x64.jmp check_0.next0
  check_0.merge:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  check_0.next0:
    x64.cmp r9, 2
    x64.jne check_0.next1
  check_0.case1:
    x64.mov r8d, 20
    x64.jmp check_0.merge
  check_0.next1:
    x64.cmp r9, 3
    x64.jne check_0.case3
  check_0.case2:
    x64.add r8, 20
  check_0.case3:
    x64.add r8, 100
    x64.jmp check_0.merge
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

    x64.jmp match-simple.main.check_0.merge
  check_0.cmp2:
    x64.mov rax, [rbp-16]
    x64.mov rcx, 3
    x64.cmp rax, rcx
    x64.jne match-simple.main.check_0.case3
  check_0.case2:
    x64.mov rax, 20
    x64.mov rcx, [rbp-8]
    x64.add rcx, rax
    x64.mov [rbp-8], rcx
    x64.jmp match-simple.main.check_0.case3
  check_0.case3:
    x64.mov rax, 100
    x64.mov rcx, [rbp-8]
    x64.add rcx, rax
    x64.mov [rbp-8], rcx
    x64.jmp match-simple.main.check_0.merge
  check_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg match-simple.main.__range_panic_0

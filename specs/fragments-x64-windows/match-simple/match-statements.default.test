// Test: match-statements.default
function main() returns ExitCode
	let x = 99
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.mov r8d, 99
  check_1.next0:
    x64.cmp r8, 2
    x64.jne check_1.case2
  check_1.case1:
    x64.mov r8d, 20
    x64.ret
  check_1.case2:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

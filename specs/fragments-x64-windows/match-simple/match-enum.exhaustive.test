// Test: match-enum.exhaustive
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	match c 'check'
		red then return 1
		green then return 2
		blue then return 3
	end 'check'
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r9d, 1
  check_1.next0:
    x64.cmp r9, 1
    x64.jne check_1.next1
  check_1.case1:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  check_1.next1:
    x64.cmp r9, 2
    x64.jne check_1.next2
  check_1.case2:
    x64.mov r8d, 3
    x64.epilogue
    x64.ret
  check_1.next2:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

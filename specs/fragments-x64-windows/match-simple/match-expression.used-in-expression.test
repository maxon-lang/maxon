// Test: match-expression.used-in-expression
function main() returns ExitCode
	let x = 2
	let doubled = match x 'eval'
		1 gives 10
		2 gives 20
		default gives 0
	end 'eval' * 2
	return doubled
end 'main'
---
ExitCode: 40
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.jmp eval_1.next0
  eval_1.merge:
    x64.mov r9d, 2
    x64.imul r8, r9
    x64.cmp r8, 125
    x64.jbe __range_ok_10
    x64.jmp __range_panic_10
  eval_1.next0:
    x64.cmp r8, 2
    x64.jne eval_1.case2
  eval_1.case1:
    x64.mov r8d, 20
    x64.jmp eval_1.merge
  eval_1.case2:
    x64.xor r8d, r8d
    x64.jmp eval_1.merge
  __range_panic_10:
    x64.lea rcx, [rip+__panic_msg_12]
    x64.call mrt_panic
  __range_ok_10:
    x64.epilogue
    x64.ret
  }
}
---

// Test: match-statements.assignment
function main() returns ExitCode
	let x = 2
	var result = 0
	match x 'process'
		1 then result = 100
		2 then result = 120
		default then result = 0
	end 'process'
	return result
end 'main'
---
ExitCode: 120
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.jmp process_0.next0
  process_0.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  process_0.next0:
    x64.cmp r8, 2
    x64.jne process_0.case2
  process_0.case1:
    x64.mov r8d, 120
    x64.jmp process_0.merge
  process_0.case2:
    x64.xor r8d, r8d
    x64.jmp process_0.merge
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

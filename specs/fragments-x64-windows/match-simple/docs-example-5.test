// Test: docs-example-5
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	let dir = Direction.north
	match dir 'navigate'
		north then return 1
		south then return 2
		east then return 3
		west then return 4
	end 'navigate'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

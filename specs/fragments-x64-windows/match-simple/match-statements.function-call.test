// Test: match-statements.function-call

typealias Integer = int(i64.min to i64.max)

function double(n Integer) returns Integer
	return n * 2
end 'double'

function main() returns ExitCode
	let x = 2
	var result = 0
	match x 'process'
		1 then result = double(10)
		2 then result = double(20)
		default then result = 0
	end 'process'
	return result
end 'main'
---
ExitCode: 40
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.jmp process_1.next0
  process_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_8
    x64.jmp __range_panic_8
  process_1.next0:
    x64.cmp r8, 2
    x64.jne process_1.case2
  process_1.case1:
    x64.mov r8d, 40
    x64.jmp process_1.merge
  process_1.case2:
    x64.xor r8d, r8d
    x64.jmp process_1.merge
  __range_panic_8:
    x64.lea r8, [rip+__panic_msg_10]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_8:
    x64.epilogue
    x64.ret
  }
}

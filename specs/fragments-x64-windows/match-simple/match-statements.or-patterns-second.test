// Test: match-statements.or-patterns-second
function main() returns ExitCode
	let x = 2
	match x 'check'
		1 or 2 then return 10
		3 or 4 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.mov r8d, 2
  check_1.case0:
    x64.mov r8d, 10
    x64.ret
  }
}
---

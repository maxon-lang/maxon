// Test: match-expression.default
function main() returns ExitCode
	let x = 99
	let result = match x 'eval'
		1 gives 10
		2 gives 20
		default gives 0
	end 'eval'
	return result
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 99
    x64.jmp eval_1.next0
  eval_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_2
    x64.jmp __range_panic_2
  eval_1.next0:
    x64.cmp r8, 2
    x64.jne eval_1.case2
  eval_1.case1:
    x64.mov r8d, 20
    x64.jmp eval_1.merge
  eval_1.case2:
    x64.xor r8d, r8d
    x64.jmp eval_1.merge
  __range_panic_2:
    x64.lea rcx, [rip+__panic_msg_4]
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

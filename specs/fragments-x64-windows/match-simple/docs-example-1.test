// Test: docs-example-1
function main() returns ExitCode
	let x = 2
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.mov r8d, 2
  check_1.next0:
    x64.cmp r8, 2
    x64.jne check_1.case2
  check_1.case1:
    x64.mov r9d, 20
    x64.mov r8, r9
    x64.ret
  check_1.case2:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}
---

// Test: match-statements.first-case
function main() returns ExitCode
	let x = 1
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.mov r9d, 10
    x64.mov r8, r9
    x64.ret
  }
}
---

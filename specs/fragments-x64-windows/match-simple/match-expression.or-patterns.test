// Test: match-expression.or-patterns
function main() returns ExitCode
	let x = 4
	let result = match x 'eval'
		1 or 2 gives 10
		3 or 4 gives 20
		default gives 0
	end 'eval'
	return result
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 4
    x64.jmp eval_1.next0
  eval_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_1
    x64.jmp __range_panic_1
  eval_1.next0:
    x64.cmp r8, 4
    x64.sete r9
    x64.cmp r8, 3
    x64.sete r8
    x64.or r8, r9
    x64.je eval_1.case2
  eval_1.case1:
    x64.mov r8d, 20
    x64.jmp eval_1.merge
  eval_1.case2:
    x64.xor r8d, r8d
    x64.jmp eval_1.merge
  __range_panic_1:
    x64.lea rcx, [rip+__panic_msg_3]
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

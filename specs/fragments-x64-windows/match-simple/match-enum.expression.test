    x64.cmp r9, 1
    x64.jne eval_1.next1
  eval_1.case1:
    x64.mov r8d, 1
    x64.jmp eval_1.merge
  eval_1.next1:
    x64.cmp r9, 2
    x64.jne eval_1.merge
  eval_1.case2:
    x64.mov r8d, 2
    x64.jmp eval_1.merge
  __range_panic_9:

    x64.or rsi, r9
    x64.or rsi, r8
    x64.je eval_1.case2
  eval_1.case1:
    x64.mov r9d, 20
    x64.mov r8, r9
    x64.ret
  eval_1.case2:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}

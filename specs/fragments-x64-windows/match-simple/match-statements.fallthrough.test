// Test: match-statements.fallthrough
function main() returns ExitCode
	let x = 1
	var result = 0
	match x 'check'
		1 then result = result + 10 and fallthrough
		2 then result = result + 20
		default then result = result + 100
	end 'check'
	return result
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.jmp check_1.case0
  check_1.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_3
    x64.jmp __range_panic_3
  check_1.case0:
    x64.add r8, 10
  check_1.case1:
    x64.add r8, 20
    x64.jmp check_1.merge
  __range_panic_3:
    x64.lea r8, [rip+__panic_msg_5]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_3:
    x64.epilogue
    x64.ret
  }
}
---

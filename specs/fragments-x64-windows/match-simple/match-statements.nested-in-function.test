// Test: match-statements.nested-in-function

typealias Integer = int(i64.min to i64.max)

function categorize(n Integer) returns Integer
	match n 'cat'
		1 or 2 or 3 then return 1
		4 or 5 or 6 then return 2
		default then return 0
	end 'cat'
end 'categorize'

function main() returns ExitCode
	return categorize(5)
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @match-simple.categorize(rcx: i64) -> i64 {
  entry:
    x64.cmp rcx, 2
    x64.sete r8
    x64.cmp rcx, 1
    x64.sete r9
    x64.cmp rcx, 3
    x64.sete rsi
    x64.or r9, r8
    x64.or r9, rsi
    x64.je cat_1.next0
  cat_1.case0:
    x64.mov r8d, 1
    x64.ret
  cat_1.next0:
    x64.cmp rcx, 5
    x64.sete r8
    x64.cmp rcx, 4
    x64.sete r9
    x64.cmp rcx, 6
    x64.sete rsi
    x64.or r9, r8
    x64.or r9, rsi
    x64.je cat_1.case2
  cat_1.case1:
    x64.mov r8d, 2
    x64.ret
  cat_1.case2:
    x64.xor r8d, r8d
    x64.ret
  }
  func @match-simple.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5
    x64.call match-simple.categorize
    x64.cmp r8, 125
    x64.jbe __range_ok_6
  __range_panic_6:
    x64.lea rcx, [rip+__panic_msg_8]
    x64.call mrt_panic
  __range_ok_6:
    x64.epilogue
    x64.ret
  }
}

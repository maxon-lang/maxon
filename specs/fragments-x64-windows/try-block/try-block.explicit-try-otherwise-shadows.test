// Test: try-block.explicit-try-otherwise-shadows
typealias Score = int(0 to 100)

enum ErrA implements Error
    kaboom
end 'ErrA'

enum ErrB implements Error
    splat
end 'ErrB'

function callA(x bool) returns Score throws ErrA
    if x 'c'
        throw ErrA.kaboom
    end 'c'
    return 5
end 'callA'

function callB(x bool) returns Score throws ErrB
    if x 'c'
        throw ErrB.splat
    end 'c'
    return 6
end 'callB'

function main() returns ExitCode
    var sum = 0
    try 'work'
        let a = try callA(true) otherwise 0
        let b = callB(false)
        sum = a + b
    end 'work'
    otherwise (e) 'h'
        match e 'k'
            splat then sum = 99
        end 'k'
    end 'h'
    return sum
end 'main'
---

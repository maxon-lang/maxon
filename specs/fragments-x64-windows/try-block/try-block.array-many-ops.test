// Test: try-block.array-many-ops
typealias Score = int(0 to 100)
typealias ScoreArray = Array with Score

function main() returns ExitCode
    var arr = ScoreArray.create()
    arr.push(0)
    arr.push(0)
    arr.push(0)

    var sum = 0
    try 'work'
        arr.set(0, value: 10)
        arr.set(1, value: 20)
        arr.set(2, value: 30)
        let a = arr.get(0)
        let b = arr.get(1)
        let c = arr.get(2)
        sum = a + b + c
    end 'work'
    otherwise (e) 'h'
        match e 'k'
            indexOutOfBounds then sum = 99
            emptySlot then sum = 99
        end 'k'
    end 'h'
    return sum
end 'main'

    end 'check'
    return 7
end 'maybeFail'

function main() returns ExitCode
    var sum = 0
    try 'work'
        let a = maybeFail(false)
        let b = maybeFail(true)
        sum = a + b
    end 'work'
    otherwise (e) 'h'
        match e 'k'
            failed then sum = 42
        end 'k'
    end 'h'
    return sum
end 'main'

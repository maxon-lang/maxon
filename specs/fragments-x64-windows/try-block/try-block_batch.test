    if x 'c'
        throw ErrA.bad(code: 50, msg: 7)
    end 'c'
    return 5
end 'callA'

function callB(x bool) returns Score throws ErrB
    if x 'c'
        throw ErrB.splat
    end 'c'
    return 6
end 'callB'

function main() returns ExitCode
    var sum = 0
    try 'work'
        let a = callA(true)
        let b = callB(false)
        sum = a + b
    end 'work'
    otherwise (e) 'h'
        match e 'k'
            ErrA.bad(code, msg) then sum = code + msg
            ErrB.splat then sum = 99
        end 'k'
    end 'h'
    return sum
end 'main'

// Test: async-filesystem.try-await-success-path
typealias Integer = int(i64.min to i64.max)

enum ComputeError implements Error
		overflow
end 'ComputeError'

function safeDivide(a Integer, b Integer) returns Integer throws ComputeError
		_ = File.exists(FilePath from "noyield.txt")
		if b == 0 'check'
				throw ComputeError.overflow
		end 'check'
		return a / b
end 'safeDivide'

function main() returns ExitCode
		let p = async safeDivide(100, b: 5)
		let r = try await p otherwise 0
		return r
end 'main'

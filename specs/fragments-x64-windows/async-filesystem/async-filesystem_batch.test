// Batch: async-filesystem
// Tests: async-filesystem.try-await-success-path, async-filesystem.try-await-error-path, async-filesystem.try-await-string-success, async-filesystem.try-await-string-error, async-filesystem.try-await-parallel-throws, async-filesystem.try-await-cross-block, async-filesystem.async-read-nonexistent, async-filesystem.async-write-read, async-filesystem.async-parallel-reads, async-filesystem.async-exists, async-filesystem.async-write-read-parallel
---
// Test: async-filesystem.try-await-success-path
typealias Integer = int(i64.min to i64.max)

enum ComputeError implements Error
		overflow
end 'ComputeError'

function safeDivide(a Integer, b Integer) returns Integer throws ComputeError
		_ = File.exists(FilePath from "noyield.txt")
		if b == 0 'check'
				throw ComputeError.overflow
		end 'check'
		return a / b
end 'safeDivide'

function main() returns ExitCode
		let p = async safeDivide(100, b: 5)
		let r = try await p otherwise 0
		return r
end 'main'
---
ExitCode: 20
---
// Test: async-filesystem.try-await-error-path
typealias Integer = int(i64.min to i64.max)

enum ComputeError implements Error
		overflow
end 'ComputeError'

function safeDivide(a Integer, b Integer) returns Integer throws ComputeError
		_ = File.exists(FilePath from "noyield.txt")
		if b == 0 'check'
				throw ComputeError.overflow
		end 'check'
		return a / b
end 'safeDivide'

function main() returns ExitCode
		let p = async safeDivide(100, b: 0)
		let r = try await p otherwise 99
		return r
end 'main'
---
ExitCode: 99
---
// Test: async-filesystem.try-await-string-success
enum TestError implements Error
		failed
end 'TestError'

function getName(ok bool) returns String throws TestError
		_ = File.exists(FilePath from "noyield.txt")
		if ok 'check'
				return "Alice"
		end 'check'
		throw TestError.failed
end 'getName'

function main() returns ExitCode
		let p = async getName(true)
		let name = try await p otherwise "unknown"
		print("{name}")
		return 42
end 'main'
---
ExitCode: 42
Stdout: ```
Alice
```
---

// Test: extension-multiple-types

typealias Integer = int(i64.min to i64.max)

interface Valued
	function val() returns Integer
end 'Valued'

extension Valued
	function valPlusTen() returns Integer
		return self.val() + 10
	end 'valPlusTen'
end 'Valued'

type TypeA implements Valued
	let a Integer
	function val() returns Integer
		return a
	end 'val'

	static function create(a Integer) returns Self
		return Self{a: a}
	end 'create'
end 'TypeA'

type TypeB implements Valued
	var b Integer
	function val() returns Integer
		return b * 2
	end 'val'

	static function create(b Integer) returns Self
		return Self{b: b}
	end 'create'
end 'TypeB'

function main() returns ExitCode
	let ta = TypeA.create(a: 5)
	let tb = TypeB.create(b: 10)
	return ta.valPlusTen() + tb.valPlusTen()
end 'main'
---
ExitCode: 45
---

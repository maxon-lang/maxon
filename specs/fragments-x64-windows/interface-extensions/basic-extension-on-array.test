// Test: basic-extension-on-array

typealias Integer = int(i64.min to i64.max)

interface Countable
	function value() returns Integer
end 'Countable'

extension Countable
	function count() returns Integer
		return 42
	end 'count'
end 'Countable'

type IntList implements Countable
	let data Integer

	function value() returns Integer
		return data
	end 'value'

	static function create(data Integer) returns Self
		return Self{data: data}
	end 'create'
end 'IntList'

function main() returns ExitCode
	let list = IntList.create(data: 5)
	return list.count()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @IntList.value(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 5
    x64.mov [r8+0], r9 (8b)
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  }
}
---

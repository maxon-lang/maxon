// Test: basic-extension-on-array

typealias Integer = int(i64.min to i64.max)

interface Countable
	function value() returns Integer
end 'Countable'

extension Countable
	function count() returns Integer
		return 42
	end 'count'
end 'Countable'

type IntList implements Countable
	var data Integer

	function value() returns Integer
		return data
	end 'value'

	static function create(data Integer) returns Self
		return Self{data: data}
	end 'create'
end 'IntList'

function main() returns ExitCode
	var list = IntList.create(data: 5)
	return list.count()
end 'main'
---
ExitCode: 42
---
module {
  func @IntList.count(__self_ptr: i64) -> i64 {
  entry:
    x64.mov rax, 42
    x64.ret
  }
  func @IntList.create(data: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call IntList.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntList.count
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rbx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_IntList(ptr: i64) {
  entry:
    x64.jmp __destruct_IntList.done
  done:
    x64.ret
  }
}
---

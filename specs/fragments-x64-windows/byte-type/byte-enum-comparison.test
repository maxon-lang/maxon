// Test: byte-enum-comparison

typealias Byte = byte(0 to u8.max)

enum Ascii
	underscore = 95
	space = 32
	zero = 48
end 'Ascii'

function main() returns ExitCode
	let b = 95 as Byte
	if b == Ascii.underscore 'match'
		let s = 32 as Byte
		if Ascii.space == s 'reverse'
			return 0
		end 'reverse'
	end 'match'
	return 1
end 'main'
---
ExitCode: 0
---
---

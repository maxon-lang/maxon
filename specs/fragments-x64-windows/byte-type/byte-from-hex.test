// Test: byte-from-hex

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0xff as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @byte-type.main() -> u8 {
  entry:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}
---

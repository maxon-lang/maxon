// Test: byte-from-hex

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0xff as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 255
    x64.cmp r8, 255
    x64.jne fail_2
  ok_1:
    x64.xor r8d, r8d
    x64.ret
  fail_2:
    x64.mov r8d, 1
    x64.ret
  }
}
---

// Test: byte-max

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 255 as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
  ok_1:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

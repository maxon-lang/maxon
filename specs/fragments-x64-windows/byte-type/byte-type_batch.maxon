// --- batched test: byte-cast ---

typealias _b_byte_cast_Integer = int(i64.min to i64.max)
typealias _b_byte_cast_Byte = byte(0 to u8.max)

function _b_byte_cast_main() returns ExitCode
	let b = 42 as _b_byte_cast_Byte
	return b as _b_byte_cast_Integer
end '_b_byte_cast_main'

// --- batched test: byte-max ---

typealias _b_byte_max_Byte = byte(0 to u8.max)

function _b_byte_max_main() returns ExitCode
	let b = 255 as _b_byte_max_Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end '_b_byte_max_main'

// --- batched test: byte-zero ---

typealias _b_byte_zero_Byte = byte(0 to u8.max)

function _b_byte_zero_main() returns ExitCode
	let b = 0 as _b_byte_zero_Byte
	return b
end '_b_byte_zero_main'

// --- batched test: byte-from-hex ---

typealias _b_byte_from_hex_Byte = byte(0 to u8.max)

function _b_byte_from_hex_main() returns ExitCode
	let b = 0xff as _b_byte_from_hex_Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end '_b_byte_from_hex_main'

// --- batch dispatcher for byte-type ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:byte-cast>>>\n")
	let ec_byte_cast = _b_byte_cast_main()
	print("\n<<<MAXON_BATCH_TEST_END:byte-cast:{ec_byte_cast}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:byte-max>>>\n")
	let ec_byte_max = _b_byte_max_main()
	print("\n<<<MAXON_BATCH_TEST_END:byte-max:{ec_byte_max}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:byte-zero>>>\n")
	let ec_byte_zero = _b_byte_zero_main()
	print("\n<<<MAXON_BATCH_TEST_END:byte-zero:{ec_byte_zero}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:byte-from-hex>>>\n")
	let ec_byte_from_hex = _b_byte_from_hex_main()
	print("\n<<<MAXON_BATCH_TEST_END:byte-from-hex:{ec_byte_from_hex}>>>\n")
	return 0 as ExitCode
end 'main'

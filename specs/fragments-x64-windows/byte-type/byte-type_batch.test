// Batch: byte-type
// Tests: byte-cast, byte-max, byte-zero, byte-from-hex
---
// Test: byte-cast

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	return b as Integer
end 'main'
---
ExitCode: 42
---
// Test: byte-max

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 255 as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---
// Test: byte-zero

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0 as Byte
	return b
end 'main'
---
ExitCode: 0
---
// Test: byte-from-hex

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0xff as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---

// Test: byte-cast

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	return b as Integer
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @byte-type.main() -> u8 {
  entry:
    x64.mov r9d, 42
    x64.mov r8, r9
    x64.ret
  }
}
---

// Test: negate-int
function main() returns ExitCode
	let x = -42
	let y = -x
	if y == 42 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, -42
    x64.xor ecx, ecx
    x64.sub rcx, rax
    x64.mov rdx, 42
    x64.cmp rcx, rdx
    x64.jne main.check_0.after
  check_0:
    x64.xor eax, eax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

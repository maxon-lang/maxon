// Test: negate-int
function main() returns ExitCode
	let x = -42
	let y = -x
	if y == 42 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 42
    x64.neg r8
    x64.neg r8
    x64.cmp r8, 42
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

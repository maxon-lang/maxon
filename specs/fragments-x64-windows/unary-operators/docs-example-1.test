// Test: docs-example-1
function main() returns ExitCode
	var x = 42
	var y = -x      // y is -42
	var z = -y      // z is 42
	return z
end 'main'

---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 42
    x64.xor rcx, rcx
    x64.sub rcx, rax
    x64.xor rdx, rdx
    x64.sub rdx, rcx
    x64.xor rbx, rbx
    x64.mov esi, 4294967295
    x64.cmp rdx, rsi
    x64.jg main.__range_panic_0
    x64.cmp rdx, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

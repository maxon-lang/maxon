  entry:
    x64.test rcx, rcx
    x64.jne zero_1.else
  zero_1:
    x64.xor r8d, r8d
    x64.ret
  zero_1.else:
    x64.cmp rcx, 10
    x64.jge small_3.else
  small_3:
    x64.mov r8d, 1
    x64.ret
  small_3.else:
    x64.cmp rcx, 100
    x64.jge large_6
  medium_5:
    x64.mov r8d, 2
    x64.ret
  large_6:
    x64.mov r8d, 3
    x64.ret
  }
  func @if-statements.main() -> u8 {
  entry:
    x64.prologue stack_size=48
    x64.xor ecx, ecx
    x64.call if-statements.classify
    x64.mov r12, r8
    x64.mov ecx, 5
    x64.call if-statements.classify
    x64.mov r13, r8
    x64.mov ecx, 50
    x64.call if-statements.classify
    x64.mov r14, r8
    x64.mov ecx, 200
    x64.call if-statements.classify
    x64.mov r9d, 3
    x64.imul r13, r9
    x64.mov r9d, 9
    x64.imul r14, r9
    x64.mov r9d, 27
    x64.imul r8, r9
    x64.add r13, r12
    x64.add r13, r14
    x64.mov r9, r13
    x64.add r9, r8
    x64.cmp r9, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }

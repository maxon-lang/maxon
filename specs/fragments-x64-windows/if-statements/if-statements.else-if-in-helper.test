// Test: if-statements.else-if-in-helper

typealias Integer = int(i64.min to i64.max)

function classify(x Integer) returns Integer
	if x == 0 'zero'
		return 0
	end 'zero' else if x < 10 'small'
		return 1
	end 'small' else if x < 100 'medium'
		return 2
	end 'medium' else 'large'
		return 3
	end 'large'
end 'classify'

function main() returns ExitCode
	let a = classify(0)
	let b = classify(5)
	let c = classify(50)
	let d = classify(200)
	return a + b * 3 + c * 9 + d * 27
end 'main'
---
ExitCode: 102
---
module {
  func @if-statements.classify(ptr: i64) -> i64 {
  entry:
    x64.test rcx, rcx
    x64.jne zero_1.else
  zero_1:
    x64.mov r8d, 0
    x64.ret
  zero_1.else:
    x64.cmp rcx, 10
    x64.jge small_3.else
  small_3:
    x64.mov r8d, 1
    x64.ret
  small_3.else:
    x64.cmp rcx, 100
    x64.jge large_6
  medium_5:
    x64.mov r8d, 2
    x64.ret
  large_6:
    x64.mov r8d, 3
    x64.ret
  small_3.merge:
  zero_1.merge:
    x64.mov r8d, 0
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=64
    x64.mov ecx, 0
    x64.call if-statements.classify
    x64.mov r12, r8
    x64.mov ecx, 5
    x64.call if-statements.classify
    x64.mov r13, r8
    x64.mov ecx, 50
    x64.call if-statements.classify
    x64.mov r14, r8
    x64.mov ecx, 200
    x64.call if-statements.classify
    x64.mov ebx, 3
    x64.mov rsi, r13
    x64.imul rsi, rbx
    x64.mov ebx, 9
    x64.mov rdi, r14
    x64.imul rdi, rbx
    x64.mov ebx, 27
    x64.mov r9, r8
    x64.imul r9, rbx
    x64.mov r8, r12
    x64.add r8, rsi
    x64.mov rbx, r8
    x64.add rbx, rdi
    x64.mov r8, rbx
    x64.add r8, r9
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

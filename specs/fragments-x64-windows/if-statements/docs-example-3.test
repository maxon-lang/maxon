// Test: docs-example-3
function main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 2
  case1_1.else:
    x64.cmp r8, 2
    x64.jne default_4
  case2_3:
    x64.mov r9d, 2
    x64.mov r8, r9
    x64.ret
  default_4:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.ret
  }
}
---

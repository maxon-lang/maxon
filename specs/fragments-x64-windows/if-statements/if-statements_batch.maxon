function _b_docs_example_3_main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end '_b_docs_example_3_main'


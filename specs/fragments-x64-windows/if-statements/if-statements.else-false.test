// Test: if-statements.else-false
function main() returns ExitCode
	let x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ebx, 3
    x64.cmp rbx, 5
    x64.jle not_gt5_2
  gt5_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  not_gt5_2:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

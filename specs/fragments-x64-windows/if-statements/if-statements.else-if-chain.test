// Test: if-statements.else-if-chain
function main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ebx, 2
    x64.cmp rbx, 1
    x64.jne case1_1.else
  case1_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  case1_1.else:
    x64.cmp rbx, 2
    x64.jne default_4
  case2_3:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  default_4:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  case1_1.merge:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

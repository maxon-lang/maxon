// Test: if-statements.else-if-chain
function main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 2
  case1_0.else:
    x64.cmp r8, 2
    x64.jne default_0
  case2_0:
    x64.mov r8d, 2
    x64.ret
  default_0:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

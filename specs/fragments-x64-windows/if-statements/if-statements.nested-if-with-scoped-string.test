// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(ptr: i64) -> i64 {
  entry:
    x64.test rcx, rcx
    x64.jne outer_1.after
  outer_1:
    x64.mov rax, 1
    x64.cmp rax, 1
    x64.jne checkInner_2.after
  checkInner_2:
    x64.mov rax, 1
    x64.ret
  checkInner_2.after:
  outer_1.after:
    x64.mov rax, 42
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 5
    x64.call if-statements.test
    x64.mov rcx, 4294967295
    x64.cmp rax, rcx
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rax, [rip+__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

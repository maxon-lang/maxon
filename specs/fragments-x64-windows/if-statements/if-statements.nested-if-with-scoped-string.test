// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 5
  inlined_if-statements.test_0:
    x64.test r8, r8
    x64.jne inlined_if-statements.test_4
  inlined_if-statements.test_2:
    x64.mov r8d, 1
    x64.jmp inline_cont_if-statements.main_0
  inlined_if-statements.test_4:
    x64.mov r8d, 42
  inline_cont_if-statements.main_0:
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

    x64.mov r8, -2
    x64.mov [r13+16], r8 (8b)
    x64.mov [r13+24], r12 (8b)
    x64.xor r8d, r8d
    x64.mov [r13+32], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov [r8+0], r13 (8b)
    x64.mov [r8+8], r12 (8b)
  checkInner_0:
    x64.mov r8, r12
    x64.epilogue
    x64.ret
  outer_0.after:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 5

// Test: if-statements.else
function main() returns ExitCode
	let x = 5
	if x == 5 'is5'
		return 1
	end 'is5' else 'not5'
		return 0
	end 'not5'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ebx, 5
    x64.cmp rbx, 5
    x64.jne not5_2
  is5_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  not5_2:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

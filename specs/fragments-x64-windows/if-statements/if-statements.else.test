// Test: if-statements.else
function main() returns ExitCode
	var x = 5
	if x == 5 'is5'
		return 1
	end 'is5' else 'not5'
		return 0
	end 'not5'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rax, 5
    x64.cmp rax, 5
    x64.jne not5_2
  is5_1:
    x64.mov rax, 1
    x64.ret
  not5_2:
    x64.xor rax, rax
    x64.ret
  }
}
---

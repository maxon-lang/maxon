// Test: if-statements.else
function main() returns ExitCode
	let x = 5
	if x == 5 'is5'
		return 1
	end 'is5' else 'not5'
		return 0
	end 'not5'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 5
    x64.mov rcx, 5
    x64.cmp rax, rcx
    x64.jne main.not5_1
  is5_0:
    x64.mov rax, 1
    x64.ret
  not5_1:
    x64.xor eax, eax
    x64.ret
  }
}
---

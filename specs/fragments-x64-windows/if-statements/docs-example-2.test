// Test: docs-example-2
function main() returns ExitCode
	let x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rbx, 3
    x64.cmp rbx, 5
    x64.jle not_gt5_2
  gt5_1:
    x64.mov rax, 1
    x64.ret
  not_gt5_2:
    x64.xor rax, rax
    x64.ret
  }
}
---

// Test: docs-example-2
function main() returns ExitCode
	let x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 3
    x64.cmp r8, 5
    x64.jle not_gt5_2
  gt5_1:
    x64.mov r8d, 1
    x64.ret
  not_gt5_2:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

// Batch: if-statements
// Tests: if-statements.simple, if-statements.else, if-statements.else-false, if-statements.else-if-chain, if-statements.else-if-in-helper, if-statements.nested, if-statements.nested-if-with-scoped-string, if-statements.nested-if-with-multiple-returns, docs-example-1, docs-example-2, docs-example-3
---
// Test: if-statements.simple
function main() returns ExitCode
	let x = 10
	if x > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: if-statements.else
function main() returns ExitCode
	let x = 5
	if x == 5 'is5'
		return 1
	end 'is5' else 'not5'
		return 0
	end 'not5'
end 'main'
---
ExitCode: 1
---
// Test: if-statements.else-false
function main() returns ExitCode
	let x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'
---
ExitCode: 0
---
// Test: if-statements.else-if-chain
function main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'
---
ExitCode: 2
---
// Test: if-statements.else-if-in-helper

typealias Integer = int(i64.min to i64.max)

function classify(x Integer) returns Integer
	if x == 0 'zero'
		return 0
	end 'zero' else if x < 10 'small'
		return 1
	end 'small' else if x < 100 'medium'
		return 2
	end 'medium' else 'large'
		return 3
	end 'large'
end 'classify'

function main() returns ExitCode
	let a = classify(0)
	let b = classify(5)
	let c = classify(50)
	let d = classify(200)
	return a + b * 3 + c * 9 + d * 27
end 'main'
---
ExitCode: 102
---
// Test: if-statements.nested
function main() returns ExitCode
	let x = 3
	if x == 1 'outer'
		return 1
	end 'outer' else 'else_outer'
		if x == 2 'inner'
			return 2
		end 'inner' else 'else_inner'
			return 3
		end 'else_inner'
	end 'else_outer'
end 'main'
---
ExitCode: 3
---
// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
// Test: docs-example-1
function main() returns ExitCode
	let x = 10
	if x > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'

---
ExitCode: 1
---
// Test: docs-example-2
function main() returns ExitCode
	let x = 3
	if x > 5 'gt5'
		return 1
	end 'gt5' else 'not_gt5'
		return 0
	end 'not_gt5'
end 'main'

---
ExitCode: 0
---
// Test: docs-example-3
function main() returns ExitCode
	let x = 2
	if x == 1 'case1'
		return 1
	end 'case1' else if x == 2 'case2'
		return 2
	end 'case2' else 'default'
		return 0
	end 'default'
end 'main'

---
ExitCode: 2
---

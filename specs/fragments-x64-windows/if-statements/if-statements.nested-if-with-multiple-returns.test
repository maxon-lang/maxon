// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(ptr: i64, ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov rbx, rcx
    x64.test rbx, rbx
    x64.jne maybePrefix_1.after
  maybePrefix_1:
    x64.cmp rdx, 1
    x64.jne isHex_2.after
  isHex_2:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  isHex_2.after:
    x64.cmp rdx, 2
    x64.jne isBinary_4.after
  isBinary_4:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  isBinary_4.after:
  maybePrefix_1.after:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 0
    x64.mov ecx, 5
    x64.call if-statements.test
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.test(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.test rcx, rcx
    x64.jne maybePrefix_1.after
  maybePrefix_1:
    x64.cmp rdx, 1
    x64.jne isHex_2.after
  isHex_2:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.ret
  isHex_2.after:
    x64.cmp rdx, 2
    x64.jne maybePrefix_1.after
  isBinary_4:
    x64.mov r9d, 2
    x64.mov r8, r9
    x64.ret
  maybePrefix_1.after:
    x64.mov r9d, 42
    x64.mov r8, r9
    x64.ret
  }
  func @if-statements.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov r9d, 5
    x64.mov rcx, r9
    x64.mov rdx, r8
    x64.call if-statements.test
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea r8, [rip+__panic_msg_2]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

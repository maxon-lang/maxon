  inlined_test_1:
    x64.cmp r8, 1
    x64.jne inlined_test_3
  inlined_test_2:
    x64.mov r8d, 1
    x64.jmp inline_cont_main_0
  inlined_test_3:
    x64.cmp r8, 2
    x64.jne inlined_test_5
  inlined_test_4:
    x64.mov r8d, 2
    x64.jmp inline_cont_main_0
  inlined_test_5:
    x64.mov r8d, 42
  inline_cont_main_0:
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_fec2254da66d3742]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }

// Test: if-statements.nested
function main() returns ExitCode
	let x = 3
	if x == 1 'outer'
		return 1
	end 'outer' else 'else_outer'
		if x == 2 'inner'
			return 2
		end 'inner' else 'else_inner'
			return 3
		end 'else_inner'
	end 'else_outer'
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r9d, 3
    x64.cmp r9, 1
    x64.jne else_outer_2
  outer_1:
    x64.mov r8d, 1
    x64.ret
  else_outer_2:
    x64.cmp r9, 2
    x64.jne else_inner_4
  inner_3:
    x64.mov r8d, 2
    x64.ret
  else_inner_4:
    x64.mov r8d, 3
    x64.ret
  }
}
---

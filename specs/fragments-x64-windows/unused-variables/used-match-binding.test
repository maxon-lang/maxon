// Test: used-match-binding

typealias Integer = int(i64.min to i64.max)

union Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let c = Container.value(42)
	match c 'check'
		empty then return 1
		value(n) then return n
	end 'check'
end 'main'

// Test: docs-example-2
typealias Integer = int(i64.min to i64.max)

function sideEffect() returns Integer
	print("hello\n")
	return 42
end 'sideEffect'

function main() returns ExitCode
	_ = sideEffect()  // OK: underscore discards return value
	return 0
end 'main'
---
ExitCode: 0
---

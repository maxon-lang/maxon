// Test: array-get-set
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	let arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)
	arr.set(1, value: 99)
	let v = try arr.get(1) otherwise 'err'
		return 0
	end 'err'
	return v
end 'main'
---
ExitCode: 99
---

// Test: bounds-setlength-exceeds-capacity
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(1)
	try arr.managed.setLength(100) otherwise 'overlen'
		return 7
	end 'overlen'
	return 0
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea rcx, [rip+__layout_Array_Int]
    x64.call Array.create
    x64.mov r12, r8
    x64.lea rax, [rip+__layout_Array_Int]
    x64.mov edx, 1
    x64.mov rcx, r12
    x64.call Array.push
    x64.mov rcx, [r12+0] (8b)
    x64.mov edx, 100
    x64.call stdlib.__managed_mem_set_length
    x64.mov r13, rdx
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r13, r13
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 7
    x64.epilogue
    x64.ret
  try_0.merge:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

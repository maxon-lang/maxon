// Test: byte-element-type

typealias Byte = int(0 to u8.max)

interface ByteSource uses Element
	function getByte() returns Element
end 'ByteSource'

type SingleByte implements ByteSource with Byte
	let b as Byte

	function getByte() returns Byte
		return b
	end 'getByte'

	static function create(b Byte) returns Self
		return Self{b: b}
	end 'create'
end 'SingleByte'

function main() returns ExitCode
	let s = SingleByte.create(42 as Byte)
	let b = s.getByte()
	return b
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @SingleByte.getByte(rcx: i64) -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.movzx r8, [rcx+0] (1b)
    x64.cmp r8, 255
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (1b)
    x64.mov rcx, r8
    x64.call SingleByte.getByte
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_1]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

    x64.mov r13, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r9d, 4294967295
    x64.mov r8, r13
    x64.add r8, 1
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:

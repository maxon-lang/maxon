// Test: basic-associated-type

typealias Integer = int(i64.min to i64.max)

interface Wrapper uses Inner
	function unwrap() returns Inner
end 'Wrapper'

type IntBox implements Wrapper with Integer
	let value as Integer

	function unwrap() returns Integer
		return value
	end 'unwrap'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'IntBox'

function main() returns ExitCode
	let box = IntBox.create(42)
	return box.unwrap()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.xor edx, edx
    x64.mov ecx, 8
    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov r8d, 42
    x64.mov [r12+0], r8 (8b)
    x64.mov r13, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r8d, 4294967295
    x64.cmp r13, r8
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_1afe48c1b37102ea]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  }
}

// Test: multiple-associated-types

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

interface Pair uses First, Second
	function getFirst() returns First
	function getSecond() returns Second
end 'Pair'

type IntFloat implements Pair with Integer, Float
	var a Integer
	var b Float

	function getFirst() returns Integer
		return a
	end 'getFirst'

	function getSecond() returns Float
		return b
	end 'getSecond'

	static function create(a Integer, b Float) returns Self
		return Self{a: a, b: b}
	end 'create'
end 'IntFloat'

function main() returns ExitCode
	var p = IntFloat.create(a: 40, b: 2.5)
	var x = p.getFirst()
	var y = trunc(p.getSecond())
	return x + y
end 'main'
---
ExitCode: 42
---
module {
  func @IntFloat.getFirst(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @IntFloat.getSecond(__self_ptr: i64) -> f64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.movsd xmm0, [rax+8]
    x64.epilogue
    x64.ret
  }
  func @IntFloat.create(a: i64, b: f64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-16], rcx
    x64.movsd [rbp-24], xmm1
    x64.mov rcx, 16
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.movsd xmm1, [rbp-24]
    x64.movsd [rdx+8], xmm1
    x64.mov rbx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.movsd xmm0, [rip+__float_2.5]
    x64.movsd xmm1, xmm0
    x64.mov rcx, 40
    x64.call IntFloat.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call IntFloat.getFirst
    x64.mov rcx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.call IntFloat.getSecond
    x64.cvttsd2si rdx, xmm0
    x64.mov rbx, [rbp-16]
    x64.add rbx, rdx
    x64.xor rsi, rsi
    x64.mov rdi, 4294967295
    x64.cmp rbx, rdi
    x64.jg main.__range_panic_0
    x64.cmp rbx, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rbx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret

// Test: managed-directory.exists
function main() returns ExitCode
	let cwd = try __ManagedDirectory.currentPath() otherwise return 1
	let cwdStr = String.init(cwd)
	let exists = __ManagedDirectory.exists(cwdStr.managed)
	if exists 'check'
		return 42
	end 'check'
	return 1
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call mrt_directory_current_path
    x64.mov r9, r8
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  try_0.merge:
    x64.mov rcx, r9
    x64.call String.init
    x64.mov rcx, [r8+0] (8b)
    x64.call mrt_directory_exists
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

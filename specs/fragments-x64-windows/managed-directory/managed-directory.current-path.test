// Test: managed-directory.current-path
function main() returns ExitCode
	let cwd = try __ManagedDirectory.currentPath() otherwise return 1
	let cwdStr = String.init(cwd)
	if cwdStr.count() > 0 'hasPath'
		return 42
	end 'hasPath'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call mrt_directory_current_path
    x64.mov r9, r8
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  try_0.merge:
    x64.mov rcx, r9
    x64.call String.init
    x64.mov rcx, r8
    x64.call String.count
    x64.test r8, r8
    x64.jle hasPath_0.after
  hasPath_0:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  hasPath_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: list-directory-count
function main() returns ExitCode
	let files = try Directory.list(FilePath from "../bin") otherwise 'err'
		return 99
	end 'err'
	// bin directory has at least maxon.exe
	if files.count() >= 1 'ok'
		return 42
	end 'ok'
	return files.count()
end 'main'

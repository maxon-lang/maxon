// Test: current-directory-is-directory
function main() returns ExitCode
	let cwd = Directory.currentPath()
	if Directory.exists(cwd) 'ok'
		return 42
	end 'ok'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call Directory.currentPath
    x64.mov r12, r8
    x64.mov r8, [r12+0] (8b)
    x64.mov rcx, [r8+0] (8b)
    x64.call mrt_directory_exists
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r13, r13
    x64.je ok_0.after
  ok_0:
    x64.mov r8d, 42
    x64.epilogue
    x64.ret
  ok_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: rung-09-int-array-push-get
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var xs = IntArray.create()
	xs.push(10)
	xs.push(20)
	return try xs.get(1) otherwise 0
end 'main'

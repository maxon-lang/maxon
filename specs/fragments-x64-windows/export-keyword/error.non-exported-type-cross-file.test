typealias Integer = int(i64.min to i64.max)

type InternalPoint
	export var x as Integer

	static function create(x Integer) returns Self
		return Self{x: x}
	end 'create'
end 'InternalPoint'

// --- file: main.maxon
function main() returns ExitCode
	let p = InternalPoint.create(42)
	return p.x
end 'main'

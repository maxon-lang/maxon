// Test: exported-enum-cross-file
// --- file: api/color.maxon
export enum Color
	red
	green
	blue
end 'Color'

// --- file: app/main.maxon
function main() returns ExitCode
	let c = Color.blue
	match c 'check'
		blue then return 42
		red then return 0
		green then return 0
	end 'check'
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
}

// Test: non-exported-enum-same-file
enum Direction
	up
	down
end 'Direction'

function main() returns ExitCode
	let d = Direction.up
	match d 'check'
		up then return 42
		down then return 0
	end 'check'
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp1
  check_0.case0:
    x64.mov rax, 42
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0.case1:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

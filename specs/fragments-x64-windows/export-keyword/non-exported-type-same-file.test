// Test: non-exported-type-same-file

typealias Integer = int(i64.min to i64.max)

type InternalPoint
	export var x Integer
	export var y Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'InternalPoint'

function main() returns ExitCode
	let p = InternalPoint.create(x: 20, y: 22)
	return p.x + p.y
end 'main'
---
ExitCode: 42
---
module {
  func @InternalPoint.create(x: i64, y: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-16], rcx
    x64.mov [rbp-24], rdx
    x64.mov rcx, 16
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 20
    x64.mov rdx, 22
    x64.call InternalPoint.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rdx+8]
    x64.add rcx, rbx
    x64.xor esi, esi
    x64.mov edi, 4294967295
    x64.cmp rcx, rdi
    x64.jg main.__range_panic_0
    x64.cmp rcx, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rcx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_InternalPoint(ptr: i64) {
  entry:
    x64.jmp __destruct_InternalPoint.done
  done:
    x64.ret
  }
}

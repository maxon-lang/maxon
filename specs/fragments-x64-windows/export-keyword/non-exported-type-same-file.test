    x64.mov [r8+8], r9 (8b)
    x64.mov r9, [r8+8] (8b)
    x64.mov rsi, [r8+0] (8b)
    x64.mov r8, rsi
    x64.add r8, r9
    x64.cmp r8, 125
    x64.jbe __range_ok_5
  __range_panic_5:
    x64.lea rcx, [rip+__panic_msg_6]

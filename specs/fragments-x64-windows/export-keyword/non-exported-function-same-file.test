// Test: non-exported-function-same-file

typealias Integer = int(i64.min to i64.max)

function privateHelper() returns Integer
	return 99
end 'privateHelper'

function main() returns ExitCode
	return privateHelper()
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 99
    x64.ret
  }
}
---

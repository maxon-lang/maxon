// Batch: collection-contains
// Tests: array-int-found, array-int-not-found, array-string-found, array-string-not-found, string-char-found, string-char-not-found, array-empty, array-first-element, array-last-element, set-contains, array-subsequence-found, array-subsequence-not-found, array-subsequence-at-start, array-subsequence-at-end, array-subsequence-empty, string-substring-found, string-substring-not-found, array-predicate-found, array-predicate-not-found, map-predicate-key, map-predicate-value, map-predicate-not-found
---
// Test: array-int-found
function main() returns ExitCode
	let arr = [10, 20, 30, 40, 50]
	if arr.contains(30) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-int-not-found
function main() returns ExitCode
	let arr = [10, 20, 30]
	if arr.contains(99) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: array-string-found
function main() returns ExitCode
	let arr = ["apple", "banana", "cherry"]
	if arr.contains("banana") 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-string-not-found
function main() returns ExitCode
	let arr = ["apple", "banana", "cherry"]
	if arr.contains("grape") 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: string-char-found
function main() returns ExitCode
	let s = "hello world"
	if s.contains('o') 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: string-char-not-found
function main() returns ExitCode
	let s = "hello world"
	if s.contains('z') 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: array-empty
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	if arr.contains(1) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: array-first-element
function main() returns ExitCode
	let arr = [5, 10, 15]
	if arr.contains(5) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-last-element
function main() returns ExitCode
	let arr = [5, 10, 15]
	if arr.contains(15) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: set-contains
function main() returns ExitCode
	let s = Set from [1, 2, 3, 4, 5]
	if s.contains(3) 'check'
		print("found\n")
	end 'check'
	if s.contains(99) 'check2'
		print("not found\n")
	end 'check2'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
found
```
---
// Test: array-subsequence-found
function main() returns ExitCode
	let arr = [1, 2, 3, 4, 5]
	if arr.contains(sequence: [2, 3, 4]) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-subsequence-not-found
function main() returns ExitCode
	let arr = [1, 2, 3, 4, 5]
	if arr.contains(sequence: [1, 3]) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---

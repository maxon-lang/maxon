// Test: split-delimiter-at-start
function main() returns ExitCode
	let s = ",hello"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'

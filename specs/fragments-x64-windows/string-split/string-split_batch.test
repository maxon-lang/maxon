// Batch: string-split
// Tests: split-by-space, split-by-comma, split-no-match, split-empty-string, split-consecutive-delimiters, split-delimiter-at-start, split-delimiter-at-end, split-empty-delimiter, split-multi-char-delimiter, split-only-delimiters
---
// Test: split-by-space
function main() returns ExitCode
	let s = "hello world foo"
	let parts = s.split(" ")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
hello
world
foo
```
---
// Test: split-by-comma
function main() returns ExitCode
	let s = "a,b,c"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
a
b
c
```
---
// Test: split-no-match
function main() returns ExitCode
	let s = "hello"
	let parts = s.split("xyz")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
hello
```
---
// Test: split-empty-string
function main() returns ExitCode
	let s = ""
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
[]
```
---
// Test: split-consecutive-delimiters
function main() returns ExitCode
	let s = "a,,b"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
[a]
[]
[b]
```
---
// Test: split-delimiter-at-start
function main() returns ExitCode
	let s = ",hello"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
[]
[hello]
```
---
// Test: split-delimiter-at-end
function main() returns ExitCode
	let s = "hello,"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
2
[hello]
[]
```
---
// Test: split-empty-delimiter
function main() returns ExitCode
	let s = "hello"
	let parts = s.split("")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
hello
```
---
// Test: split-multi-char-delimiter
function main() returns ExitCode
	let s = "one::two::three"
	let parts = s.split("::")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
one
two
three
```
---
// Test: split-only-delimiters
function main() returns ExitCode
	let s = ",,"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
[]
[]
[]
```

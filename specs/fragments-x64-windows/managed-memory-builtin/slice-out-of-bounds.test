// Test: slice-out-of-bounds
function main() returns ExitCode
	let mm = try __ManagedMemory.create(4, elementSize: 8) otherwise return 1
	try mm.setLength(2) otherwise return 2
	let _ = try mm.slice(0, endIndex: 99) otherwise return 0
	return 5
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 8
    x64.mov ecx, 4
    x64.call stdlib.__managed_mem_create
    x64.mov r12, r8
    x64.xor r13d, r13d
  try_0.merge:
    x64.mov edx, 2
    x64.mov rcx, r12
    x64.call stdlib.__managed_mem_set_length
    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  try_1.merge:
    x64.mov eax, 99
    x64.mov rcx, r12
    x64.mov rdx, r13
    x64.call stdlib.__managed_mem_slice
    x64.test rdx, rdx
    x64.je try_2.merge
  try_2.otherwise:
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  try_2.merge:
    x64.mov r8d, 5
    x64.epilogue
    x64.ret
  }
}

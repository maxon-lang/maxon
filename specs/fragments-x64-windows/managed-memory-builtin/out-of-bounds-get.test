// Test: out-of-bounds-get
function main() returns ExitCode
	let mm = try __ManagedMemory.create(2, elementSize: 8) otherwise return 1
	try mm.setLength(1) otherwise return 2
	try mm.set(0, value: 7) otherwise return 3
	let _ = try mm.get(99) otherwise return 0
	return 5
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 8
    x64.mov ecx, 2
    x64.call __managed_mem_create
    x64.mov rbx, r8
  try_1.merge:
    x64.mov edx, 1
    x64.mov rcx, rbx
    x64.call __managed_mem_set_length
    x64.test rdx, rdx
    x64.je try_4.merge
  try_4.otherwise:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  try_4.merge:
    x64.mov eax, 7
    x64.xor edx, edx
    x64.mov rcx, rbx
    x64.call __managed_mem_set
    x64.test rdx, rdx
    x64.je try_7.merge
  try_7.otherwise:
    x64.mov r8d, 3
    x64.epilogue
    x64.ret
  try_7.merge:
    x64.mov edx, 99
    x64.mov rcx, rbx
    x64.call __managed_mem_get
    x64.test rdx, rdx
    x64.je try_10.merge
  try_10.otherwise:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  try_10.merge:
    x64.mov r8d, 5
    x64.epilogue
    x64.ret
  }
}

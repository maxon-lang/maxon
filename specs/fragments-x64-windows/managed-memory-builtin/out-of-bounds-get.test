module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov edx, 8
    x64.mov ecx, 2
    x64.call __managed_mem_create
    x64.mov r12, r8
    x64.xor r13d, r13d
  try_0.merge:
    x64.mov edx, 1
    x64.mov rcx, r12
    x64.call __managed_mem_set_length
    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  try_1.merge:
    x64.mov eax, 7
    x64.mov rcx, r12
    x64.mov rdx, r13
    x64.call __managed_mem_set
    x64.test rdx, rdx
    x64.je try_2.merge
  try_2.otherwise:
    x64.mov r8d, 3
    x64.epilogue
    x64.ret
  try_2.merge:
    x64.mov edx, 99
    x64.mov rcx, r12
    x64.call __managed_mem_get
    x64.test rdx, rdx
    x64.je try_3.merge
  try_3.otherwise:
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  try_3.merge:
    x64.mov r8d, 5
    x64.epilogue
    x64.ret
  }
}

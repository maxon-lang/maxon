    x64.test rdx, rdx
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  try_1.merge:
    x64.mov eax, 42
    x64.mov edx, 99
    x64.mov rcx, r12
    x64.call stdlib.__managed_mem_set
    x64.mov r14, rdx
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r14, r14
    x64.je try_2.merge
  try_2.otherwise:
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  try_2.merge:

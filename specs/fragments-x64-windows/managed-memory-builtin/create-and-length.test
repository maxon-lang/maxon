// Test: create-and-length
function main() returns ExitCode
	let mm = try __ManagedMemory.create(4, elementSize: 8) otherwise return 1
	if mm.length() != 0 'badLen'
		return 2
	end 'badLen'
	if mm.capacity() != 4 'badCap'
		return 3
	end 'badCap'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @managed-memory-builtin.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 8
    x64.mov r9d, 4
    x64.mov rcx, r9
    x64.mov rdx, r8
    x64.call __managed_mem_create
    x64.mov r12, r8
    x64.call mrt_get_error_and_clear
    x64.test r8, r8
    x64.je try_1.merge
  try_1.otherwise:
    x64.mov r9d, 1
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  try_1.merge:
    x64.mov r8, [r12+8] (8b)
    x64.test r8, r8
    x64.je badLen_4.after
  badLen_4:
    x64.mov r9d, 2
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  badLen_4.after:
    x64.mov r8, [r12+16] (8b)
    x64.cmp r8, 4
    x64.je badCap_6.after
  badCap_6:
    x64.mov r9d, 3
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  badCap_6.after:
    x64.xor r9d, r9d
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

    x64.mov rbx, 2
    x64.mov rsi, 255
    x64.and rbx, rsi
    x64.mov rdi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, rbx
    x64.call ByteArray.push
    x64.mov r8, 3
    x64.mov r9, 255
    x64.and r8, r9
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, r8
    x64.call ByteArray.push
    x64.mov rax, 4
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rcx, [rbp-8]
    x64.mov rdx, rax
    x64.call ByteArray.push
    x64.mov rax, 5
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rcx, [rbp-8]
    x64.mov rdx, rax
    x64.call ByteArray.push
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call ByteArray.count
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rbx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_ByteMemory(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+16]
    x64.xor edx, edx
    x64.cmp rcx, rdx
    x64.je __destruct_ByteMemory.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct_ByteMemory.skip_buf_0
  skip_buf_0:
    x64.jmp __destruct_ByteMemory.done
  done:

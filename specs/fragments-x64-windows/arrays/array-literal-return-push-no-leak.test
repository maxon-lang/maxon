    x64.prologue stack_size=32
    x64.mov rcx, 10
    x64.mov rdx, 20
    x64.call arrays.makeNumbers
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 2
    x64.call IntArray.get
    x64.xor rcx, rcx
    x64.mov [rbp-16], rcx
    x64.mov [rbp-24], rax
    x64.xor rax, rax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-24], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-24]
    x64.xor rcx, rcx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_4
    x64.cmp rax, rcx
    x64.jl main.__range_panic_4
    x64.jmp main.__range_ok_4
  __range_panic_4:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_4:
    x64.mov rbx, [rbp-8]
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx

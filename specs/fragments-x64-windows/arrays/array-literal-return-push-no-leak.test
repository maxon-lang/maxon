    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.call IntArray.push
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-24]
    x64.call IntArray.push
    x64.mov rdx, [rbp-24]
    x64.mov rbx, [rbp-16]
    x64.add rbx, rdx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, rbx
    x64.call IntArray.push
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {

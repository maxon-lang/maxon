    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call Array.get
    x64.mov r13, r8
    x64.call mrt_get_error_and_clear
    x64.test r8, r8
    x64.je try_1.merge
  try_1.otherwise:
    x64.xor r8d, r8d

// Batch: arrays
// Tests: literal-first, literal-middle, literal-last, five-elements, index-assignment, assignment-middle, assignment-last, multiple-access, assignment-preserves-others, multiple-assignments, let-array-first, let-array-middle, let-array-last, let-array-multiple-access, array-with-reserve, array-with-resize, array-growth-realloc, byte-array-push-get, byte-array-initialized, byte-array-set, byte-array-max-values, byte-array-count, array-literal-constant, array-literal-with-dependency, string-array-literal-basic, string-array-literal-iterate, string-array-literal-top-level, string-array-literal-top-level-pass-to-function, slice-basic, slice-from-start, slice-to-end, slice-empty, slice-full, slice-throws-invalid-end, slice-throws-inverted-range, slice-throws-invalid-start, append-basic, append-empty-to-nonempty, append-nonempty-to-empty, append-preserves-originals, slice-cow-modify-slice, slice-cow-modify-original, array-literal-return-from-function, array-literal-return-push-no-leak, array-literal-struct-return-from-function
---
// Test: literal-first
function main() returns ExitCode
	return try [10, 20, 30].get(0) otherwise 0
end 'main'
---
ExitCode: 10
---
// Test: literal-middle
function main() returns ExitCode
	let arr = [10, 20, 30]
	return try arr.get(1) otherwise 0
end 'main'
---
ExitCode: 20
---
// Test: literal-last
function main() returns ExitCode
	let arr = [10, 20, 30]
	return try arr.get(2) otherwise 0
end 'main'
---
ExitCode: 30
---
// Test: five-elements
function main() returns ExitCode
	let arr = [5, 10, 15, 20, 25]
	return try arr.get(4) otherwise 0
end 'main'
---
ExitCode: 25
---
// Test: index-assignment
function main() returns ExitCode
	var arr = [10, 20, 30]
	try arr.set(0, value: 100) otherwise panic("test invariant: set OOB")
	return try arr.get(0) otherwise 0
end 'main'
---
ExitCode: 100
---
// Test: assignment-middle
function main() returns ExitCode
	var arr = [1, 2, 3]
	try arr.set(1, value: 42) otherwise panic("test invariant: set OOB")
	return try arr.get(1) otherwise 0
end 'main'
---
ExitCode: 42
---
// Test: assignment-last
function main() returns ExitCode
	var arr = [1, 2, 3, 4, 5]
	try arr.set(4, value: 99) otherwise panic("test invariant: set OOB")
	return try arr.get(4) otherwise 0
end 'main'
---
ExitCode: 99
---
// Test: multiple-access
function main() returns ExitCode
	let arr = [5, 10, 15, 20, 25]
	let a = try arr.get(2) otherwise 0
	let b = try arr.get(4) otherwise 0
	return a + b
end 'main'

// Test: array-growth-realloc
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
		let arr = IntArray.create()
		var i = 0
		while i < 100 'loop'
				arr.push(i)
				i = i + 1
		end 'loop'
		return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.call IntArray.create
    x64.mov [rbp-8], rax
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp main.loop_0.header
  loop_0.header:
    x64.mov rax, 100
    x64.mov rcx, [rbp-16]
    x64.cmp rcx, rax
    x64.jge main.loop_0.exit
  loop_0:
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-16]
    x64.call IntArray.push
    x64.mov rdx, 1
    x64.mov rbx, [rbp-16]
    x64.add rbx, rdx
    x64.mov [rbp-16], rbx
    x64.jmp main.loop_0.header
  loop_0.exit:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 99
    x64.call IntArray.get
    x64.mov rcx, -1
    x64.mov [rbp-24], rcx
    x64.mov [rbp-32], rax
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_4
  otherwise_default_error_3:
    x64.mov rax, [rbp-24]
    x64.mov [rbp-32], rax
    x64.jmp main.otherwise_default_continue_4
  otherwise_default_continue_4:
    x64.mov rax, [rbp-32]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_5
    x64.cmp rax, rcx
    x64.jl main.__range_panic_5
    x64.jmp main.__range_ok_5
  __range_panic_5:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_5:
    x64.mov rbx, [rbp-8]
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-32]
    x64.epilogue
    x64.ret
  }
  func @__destruct___ManagedMemory_Integer(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+16]
    x64.xor edx, edx
    x64.cmp rcx, rdx
    x64.je __destruct___ManagedMemory_Integer.skip_buf_0
  free_buf_0:
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+0]
    x64.call mm_raw_free
    x64.jmp __destruct___ManagedMemory_Integer.skip_buf_0
  skip_buf_0:
    x64.jmp __destruct___ManagedMemory_Integer.done
  done:
    x64.epilogue
    x64.ret
  }
  func @__destruct_IntArray(ptr: i64) {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+8]
    x64.mov [rbp-16], rcx
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.jmp __destruct_IntArray.done
  done:
    x64.epilogue
    x64.ret
  }
}
---

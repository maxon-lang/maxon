// Test: array-growth-realloc
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
		var arr = IntArray.create()
		var i = 0
		while i < 100 'loop'
				arr.push(i)
				i = i + 1
		end 'loop'
		return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.mov rcx, r8
    x64.call Array.create
    x64.mov rbx, r8
    x64.xor edx, edx
    x64.mov r12, rdx
  loop_1.header:
    x64.cmp r12, 100
    x64.jge loop_1.exit
  loop_1:
    x64.xor r8d, r8d
    x64.mov rcx, rbx
    x64.mov rdx, r12
    x64.mov rax, r8
    x64.call Array.push
    x64.add r12, 1
    x64.jmp loop_1.header
  loop_1.exit:
    x64.xor r8d, r8d
    x64.mov r9d, 99
    x64.mov rcx, rbx
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call Array.get
    x64.mov r12, r8
    x64.call mrt_get_error_and_clear
    x64.test r8, r8
    x64.je __phi_trampoline_3_6
  try_4.otherwise:
    x64.mov r8d, 1
    x64.neg r8
  try_4.merge:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r8, [rip+__panic_msg_0]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  __phi_trampoline_3_6:
    x64.mov r8, r12
    x64.jmp try_4.merge
  }
}
---

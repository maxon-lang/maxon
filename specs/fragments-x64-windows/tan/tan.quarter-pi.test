// Test: tan.quarter-pi
function main() returns ExitCode
	let quarterPi = 0.785398163
	let result = Math.tan(quarterPi)
	// Should be approximately 1.0
	let diff = abs(result - 1.0)
	if diff < 0.01 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_4605249457293724960]
    x64.call Math.tan
    x64.movsd xmm1, [rip+__float_4607182418800017408]
    x64.subsd xmm0, xmm1
    x64.movsd xmm1, [rip+__float_4576918229304087675]
    x64.andpd xmm0, [rip+__xmmmask_9223372036854775807_9223372036854775807]
    x64.ucomisd xmm0, xmm1
    x64.jae check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}

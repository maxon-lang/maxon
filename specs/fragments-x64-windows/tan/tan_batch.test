// Batch: tan
// Tests: tan.zero, tan.multiple-values, tan.quarter-pi, tan.with-int-promotion
---
// Test: tan.zero
function main() returns ExitCode
	let result = Math.tan(0.0)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: tan.multiple-values
function main() returns ExitCode
	let x1 = Math.tan(0.0)
	let x2 = Math.tan(0.5)
	let x3 = Math.tan(1.0)
	let x4 = Math.tan(0.7854)
	print("{x1}\n")
	print("{x2}\n")
	print("{x3}\n")
	print("{x4}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
0.0
0.546302
1.557408
1.000004
```
---
// Test: tan.quarter-pi
function main() returns ExitCode
	let quarterPi = 0.785398163
	let result = Math.tan(quarterPi)
	// Should be approximately 1.0
	let diff = abs(result - 1.0)
	if diff < 0.01 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: tan.with-int-promotion
function main() returns ExitCode
	let x = 0  // int
	let result = Math.tan(x)  // x promoted to 0.0
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---

// Test: tan.with-int-promotion
function main() returns ExitCode
	let x = 0  // int
	let result = Math.tan(x)  // x promoted to 0.0
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor r8d, r8d
    x64.cvtsi2sd xmm0, r8
    x64.call Math.tan
    x64.movsd xmm1, [rip+__float_0]
    x64.ucomisd xmm0, xmm1
    x64.jp check_0.after
    x64.jne check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  }
}
---

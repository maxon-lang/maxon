// Test: var-field-assign

typealias Integer = int(i64.min to i64.max)

type Config
	export let version Integer
	export var count Integer

	static function create(version Integer, count Integer) returns Self
		return Self{version: version, count: count}
	end 'create'
end 'Config'

function main() returns ExitCode
	var c = Config.create(version: 1, count: 0)
	c.count = 5
	return c.count
end 'main'
---
ExitCode: 5
---
module {
  func @Config.create(version: i64, count: i64) -> i64 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-16], rcx
    x64.mov [rbp-24], rdx
    x64.mov rcx, 16
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rbp-24]
    x64.mov [rdx+8], rbx
    x64.mov rsi, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 1
    x64.xor edx, edx
    x64.call Config.create
    x64.mov [rbp-8], rax
    x64.mov rax, 5
    x64.mov rcx, [rbp-8]
    x64.mov [rcx+8], rax
    x64.mov rdx, [rbp-8]
    x64.mov rbx, [rdx+8]
    x64.xor esi, esi
    x64.mov edi, 4294967295
    x64.cmp rbx, rdi
    x64.jg main.__range_panic_0
    x64.cmp rbx, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rbx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Config(ptr: i64) {
  entry:
    x64.jmp __destruct_Config.done

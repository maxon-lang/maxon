    x64.mov rsi, [rbp-8]
    x64.mov rdi, 1
    x64.mov [rsi+8], rdi
    x64.mov r8, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]

// Test: multiple-variables
function main() returns ExitCode
	let a = 10
	let b = 20
	return a + b
end 'main'
---
ExitCode: 30
---
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 30
    x64.mov ebx, 20
    x64.mov ebx, 10
    x64.epilogue
    x64.ret
  }
}
---

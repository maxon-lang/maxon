// --- batched test: let-declaration ---
function _b_let_declaration_main() returns ExitCode
	let x = 42
	return x
end '_b_let_declaration_main'

// --- batched test: var-declaration ---
function _b_var_declaration_main() returns ExitCode
	let x = 10
	return x
end '_b_var_declaration_main'

// --- batched test: multiple-variables ---
function _b_multiple_variables_main() returns ExitCode
	let a = 10
	let b = 20
	return a + b
end '_b_multiple_variables_main'

// --- batched test: top-level-string-constant ---
let _b_top_level_string_constant_GREETING = "hello"

function _b_top_level_string_constant_main() returns ExitCode
	if _b_top_level_string_constant_GREETING == "hello" 'check'
		return 1
	end 'check'
	return 0
end '_b_top_level_string_constant_main'

// --- batch dispatcher for variables ---
function main() returns ExitCode
	print("\n<<<MAXON_BATCH_TEST_BEGIN:let-declaration>>>\n")
	let ec_let_declaration = _b_let_declaration_main()
	print("\n<<<MAXON_BATCH_TEST_END:let-declaration:{ec_let_declaration}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:var-declaration>>>\n")
	let ec_var_declaration = _b_var_declaration_main()
	print("\n<<<MAXON_BATCH_TEST_END:var-declaration:{ec_var_declaration}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:multiple-variables>>>\n")
	let ec_multiple_variables = _b_multiple_variables_main()
	print("\n<<<MAXON_BATCH_TEST_END:multiple-variables:{ec_multiple_variables}>>>\n")
	print("\n<<<MAXON_BATCH_TEST_BEGIN:top-level-string-constant>>>\n")
	let ec_top_level_string_constant = _b_top_level_string_constant_main()
	print("\n<<<MAXON_BATCH_TEST_END:top-level-string-constant:{ec_top_level_string_constant}>>>\n")
	return 0 as ExitCode
end 'main'

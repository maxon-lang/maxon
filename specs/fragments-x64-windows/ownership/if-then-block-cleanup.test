typealias Integer = int(i64.min to i64.max)

type Widget
	export var id as Integer

	static function create(id Integer) returns Self
		return Self{id: id}
	end 'create'
end 'Widget'

function main() returns ExitCode
	var result = 0
	if true 'check'
		@heap let w = Widget.create(5)
		result = w.id
	end 'check'
	print("{result}\n")
	return 0
end 'main'

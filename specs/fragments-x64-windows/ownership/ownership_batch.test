// Test: break-cleanup
typealias Integer = int(i64.min to i64.max)

type Counter
	export var val Integer

	static function create(val Integer) returns Self
		return Self{val: val}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var total = 0
	var i = 0
	while i < 5 'loop'
		let c = Counter.create(val: i)
		if i == 3 'brk'
			total = total + c.val
			break
		end 'brk'
		total = total + c.val
		i = i + 1
	end 'loop'
	print("{total}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
6
```
---
// Test: continue-cleanup
typealias Integer = int(i64.min to i64.max)

type Item
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Item'

function main() returns ExitCode
	var total = 0
	var i = 0
	while i < 5 'loop'
		let item = Item.create(value: i)
		i = i + 1
		if item.value == 2 'skip'
			continue
		end 'skip'
		total = total + item.value
	end 'loop'
	// 0+1+3+4 = 8
	print("{total}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
8
```

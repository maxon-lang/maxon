// Batch: ownership
// Tests: local-struct-freed, local-alias, reassignment-frees-old, nested-block-frees, return-local-struct, return-container-element-get, return-container-element-remove, return-struct-with-field-ref, return-param-borrow, container-push-incref, container-remove-decref, container-push-remove-cycle, container-overwrite-decrefs-old, container-freed-decrefs-elements, struct-field-assign-incref, struct-field-overwrite, managed-list-insert-incref, managed-list-remove-decref, managed-list-clear-decrefs-all, global-container-push-local, global-container-remove-frees, global-container-many-push-remove, if-then-block-cleanup, if-else-both-assign, while-loop-iteration-cleanup, for-loop-elem-borrow, match-case-cleanup, break-cleanup, continue-cleanup, closure-env-freed, closure-captures-borrow, no-leak-nested-structs, no-leak-nested-containers, no-leak-returned-managed-list
---
// Test: local-struct-freed
typealias Integer = int(i64.min to i64.max)

type Point
	export var x Integer
	export var y Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function testLocal()
	@heap let p = Point.create(x: 1, y: 2)
	print("{p.x}\n")
end 'testLocal'

function main() returns ExitCode
	testLocal()
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1
```
---

// Test: type-qualified-u64-max
typealias BigId = int(0 to u64.max)

function getValue() returns BigId
	return u64.max
end 'getValue'

function main() returns ExitCode
	let v = getValue()
	if v == u64.max 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @ranged-typealias.getValue() -> u64 {
  entry:
    x64.mov rax, -1
    x64.ret
  }
  func @ranged-typealias.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call ranged-typealias.getValue
    x64.mov rcx, -1
    x64.cmp rax, rcx
    x64.jne ranged-typealias.main.check_0.after
  check_0:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  }
}
---

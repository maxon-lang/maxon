// Batch: ranged-typealias
// Tests: basic-declaration, literal-in-range, negative-range, min-max-bounds, float-range, upto-exclusive, same-type-arithmetic, function-param-return, runtime-check-pass, byte-range, int-division-truncates, struct-field, return-literal-in-range, return-runtime-check-pass, return-float-range-check, type-qualified-u32-max, type-qualified-u64-max, type-qualified-i8-range, type-qualified-u16-max, u32-range, i8-range, f32-range, f32-arithmetic, f32-comparison, f32-function-param-return, f32-to-int, hex-range-bound, range-id-assign, range-id-comparison, range-id-i8-min, range-id-arithmetic
---
// Test: basic-declaration
typealias Score = int(0 to 100)

function main() returns ExitCode
	let s = Score{42}
	return s
end 'main'
---
ExitCode: 42
---
// Test: literal-in-range
typealias SmallInt = int(0 to 10)

function main() returns ExitCode
	let x = SmallInt{7}
	return x
end 'main'
---
ExitCode: 7
---
// Test: negative-range
typealias Temp = int(-50 to 50)

function main() returns ExitCode
	let t = Temp{-10}
	return t + 60
end 'main'
---
ExitCode: 50
---
// Test: min-max-bounds
typealias FullInt = int(i64.min to i64.max)

function main() returns ExitCode
	let x = FullInt{42}
	return x
end 'main'
---
ExitCode: 42
---
// Test: float-range
typealias Pct = float(0.0 to 100.0)

function main() returns ExitCode
	let p = Pct{75.5}
	return trunc(p)
end 'main'
---
ExitCode: 75
---
// Test: upto-exclusive
typealias Idx = int(0 upto 10)

function main() returns ExitCode
	let i = Idx{9}
	return i
end 'main'
---
ExitCode: 9
---
// Test: same-type-arithmetic
typealias Score = int(0 to 100)

function main() returns ExitCode
	let a = Score{30}
	let b = Score{12}
	return a + b
end 'main'
---
ExitCode: 42
---
// Test: function-param-return
typealias Score = int(0 to 100)

function double(s Score) returns Score
	return s * 2
end 'double'

function main() returns ExitCode
	let s = Score{21}
	return double(s)
end 'main'
---
ExitCode: 42
---
// Test: runtime-check-pass
typealias Integer = int(i64.min to i64.max)
typealias Age = int(0 to 150)

function makeAge(n Integer) returns Integer
	let a = Age{n}
	return a
end 'makeAge'

function main() returns ExitCode
	return makeAge(50)
end 'main'
---
ExitCode: 50
---
// Test: byte-range
typealias Integer = int(i64.min to i64.max)
typealias AsciiCode = byte(0 to 127)

function main() returns ExitCode
	let c = AsciiCode{65}
	return c as Integer
end 'main'
---
ExitCode: 65
---
// Test: int-division-truncates
function main() returns ExitCode
	let a = 7
	let b = 2
	return a / b
end 'main'
---
ExitCode: 3
---
// Test: struct-field
typealias Score = int(0 to 100)

type Player
	export var name String
	export var score Score

	static function create(name String, score Score) returns Self
		return Self{name: name, score: score}
	end 'create'
end 'Player'

function main() returns ExitCode
	let p = Player.create(name: "Alice", score: Score{42})
	return p.score
end 'main'
---
ExitCode: 42
---
// Test: return-literal-in-range
typealias Score = int(0 to 100)

function getScore() returns Score
	return 42
end 'getScore'

function main() returns ExitCode
	return getScore()
end 'main'
---
ExitCode: 42
---
// Test: return-runtime-check-pass
typealias Score = int(0 to 100)

function half(s Score) returns Score
	return s / 2
end 'half'

function main() returns ExitCode
	let s = Score{84}
	return half(s)
end 'main'
---
ExitCode: 42
---
// Test: return-float-range-check

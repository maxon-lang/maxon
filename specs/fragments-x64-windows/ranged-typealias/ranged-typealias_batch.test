// Test: f32-arithmetic
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	let a = F{10.0}
	let b = F{3.0}
	let sum = a + b
	let diff = a - b
	let prod = a * b
	let quot = a / b
	return trunc(sum + diff + prod + quot)
end 'main'
---
ExitCode: 53
---
// Test: f32-comparison
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	let a = F{3.0}
	let b = F{5.0}
	if a < b 'less'
		return 1
	end 'less'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: f32-function-param-return

// Test: return-literal-in-range
typealias Score = int(0 to 100)

function getScore() returns Score
	return 42
end 'getScore'

function main() returns ExitCode
	return getScore()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @getScore() -> u8 {
  entry:
    x64.mov r8d, 42
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.call getScore
    x64.cmp r8, 125
    x64.jbe __range_ok_7
  __range_panic_7:
    x64.lea rcx, [rip+__panic_msg_8]
    x64.call mrt_panic
  __range_ok_7:
    x64.epilogue
    x64.ret
  }
}

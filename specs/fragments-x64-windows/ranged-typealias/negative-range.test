// Test: negative-range
typealias Temp = int(-50 to 50)

function main() returns ExitCode
	let t = Temp{-10}
	return t + 60
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, -10
    x64.mov rcx, 60
    x64.mov edx, eax
    x64.mov ebx, ecx
    x64.add rdx, rbx
    x64.xor esi, esi
    x64.movsxd rdi, rdx
    x64.mov r8, 4294967295
    x64.movsxd r9, rdx
    x64.cmp r9, r8
    x64.jg main.__range_panic_0
    x64.cmp rdi, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

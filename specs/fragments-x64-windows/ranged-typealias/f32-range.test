// Test: f32-range
typealias SmallFloat = float(f32.min to f32.max)

function main() returns ExitCode
	var x = SmallFloat{3.5}
	var y = SmallFloat{1.5}
	return trunc(x + y)
end 'main'
---
ExitCode: 5
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_3.5]
    x64.movsd xmm1, [rip+__float_1.5]
    x64.movsd xmm2, xmm0
    x64.addsd xmm2, xmm1
    x64.cvttsd2si rax, xmm2
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

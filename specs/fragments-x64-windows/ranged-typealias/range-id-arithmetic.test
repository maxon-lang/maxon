// Test: range-id-arithmetic
function main() returns ExitCode
	let x = u8.max + 1
	return x - 206
end 'main'
---
ExitCode: 50
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 255
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov rdx, 206
    x64.sub rax, rdx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

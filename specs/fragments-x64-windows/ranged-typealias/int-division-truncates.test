// Test: int-division-truncates
function main() returns ExitCode
	let a = 7
	let b = 2
	return a / b
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov eax, 7
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rax
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

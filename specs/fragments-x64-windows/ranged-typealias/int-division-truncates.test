// Test: int-division-truncates
function main() returns ExitCode
	var a = 7
	var b = 2
	return a / b
end 'main'
---
ExitCode: 3
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 7
    x64.mov rcx, 2
    x64.cqo
    x64.idiv rcx
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: range-id-assign
function main() returns ExitCode
	var x = u16.max
	return x - 65500
end 'main'
---
ExitCode: 35
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 65535
    x64.mov rcx, 65500
    x64.sub rax, rcx
    x64.xor rdx, rdx
    x64.mov rbx, 4294967295
    x64.cmp rax, rbx
    x64.jg main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

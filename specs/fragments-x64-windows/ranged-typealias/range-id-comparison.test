// Test: range-id-comparison
function main() returns ExitCode
	let x = i32.max
	if x == 2147483647 'isMax'
		return 1
	end 'isMax'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 2147483647
    x64.mov rcx, 2147483647
    x64.cmp rax, rcx
    x64.jne main.isMax_0.after
  isMax_0:
    x64.mov rax, 1
    x64.ret
  isMax_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

// Test: byte-range
typealias Integer = int(i64.min to i64.max)
typealias AsciiCode = byte(0 to 127)

function main() returns ExitCode
	let c = 65 as AsciiCode
	return c as Integer
end 'main'
---
ExitCode: 65
---
// CompiledIR
module {
  func @ranged-typealias.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 65
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg ranged-typealias.main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl ranged-typealias.main.__range_panic_0
    x64.jmp ranged-typealias.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_7]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Test: byte-range
typealias Integer = int(i64.min to i64.max)
typealias AsciiCode = int(0 to 127)

function main() returns ExitCode
	let c = 65 as AsciiCode
	return c as Integer
end 'main'
---
ExitCode: 65
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 65
    x64.ret
  }
}
---

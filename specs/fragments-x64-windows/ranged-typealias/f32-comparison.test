// Test: f32-comparison
typealias F = float(f32.min to f32.max)

function main() returns ExitCode
	let a = 3.0 as F
	let b = 5.0 as F
	if a < b 'less'
		return 1
	end 'less'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.movsd xmm0, [rip+__float_4617315517961601024]
    x64.movsd xmm1, [rip+__float_4613937818241073152]
    x64.ucomisd xmm1, xmm0
    x64.jae less_0.after
  less_0:
    x64.mov r8d, 1
    x64.ret
  less_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

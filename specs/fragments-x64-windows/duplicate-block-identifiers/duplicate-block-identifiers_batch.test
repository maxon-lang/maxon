// Batch: duplicate-block-identifiers
// Tests: duplicate-block-identifiers.different-blocks, duplicate-block-identifiers.nested-same-id, duplicate-block-identifiers.multiple-nested, duplicate-block-identifiers.else-nested, docs-example-1, docs-example-2
---
// Test: duplicate-block-identifiers.different-blocks
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
	end 'outer'
	
	if true 'inner'
		x = 2
	end 'inner'
	
	return x
end 'main'
---
ExitCode: 2
---
// Test: duplicate-block-identifiers.nested-same-id
function main() returns ExitCode
	var x = 0
	if true 'check'
		x = 1
		if true 'check'
			x = 2
		end 'check'
	end 'check'
	return x
end 'main'
---
ExitCode: 2
---
// Test: duplicate-block-identifiers.multiple-nested
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
		while true 'inner'
			x = 2
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 2
---
// Test: duplicate-block-identifiers.else-nested
function main() returns ExitCode
	var x = 0
	if false 'check'
		x = 1
	end 'check' else 'else_check'
		if true 'nested'
			x = 2
		end 'nested'
	end 'else_check'
	return x
end 'main'
---
ExitCode: 2
---
// Test: docs-example-1
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
	end 'outer'

	if true 'inner'
		x = 2
	end 'inner'

	return x
end 'main'

---
ExitCode: 2
---
// Test: docs-example-2
function main() returns ExitCode
	var x = 0
	if true 'check'
		x = 1
		if true 'check'
			x = 2
		end 'check'
	end 'check'
	return x
end 'main'

---
ExitCode: 2

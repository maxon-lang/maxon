module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 1
    x64.xor r9d, r9d
    x64.test r8, r8
    x64.je outer_1.after
  outer_1:
    x64.mov r8d, 1
  outer_1.after:
    x64.mov r9d, 1
    x64.test r9, r9
    x64.je inner_3.after
  inner_3:
    x64.mov r8d, 2
  inner_3.after:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

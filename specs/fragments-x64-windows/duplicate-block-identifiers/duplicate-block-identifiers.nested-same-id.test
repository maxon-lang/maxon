// Test: duplicate-block-identifiers.nested-same-id
function main() returns ExitCode
	var x = 0
	if true 'check'
		x = 1
		if true 'check'
			x = 2
		end 'check'
	end 'check'
	return x
end 'main'
---
ExitCode: 2
---

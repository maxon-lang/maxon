// Test: duplicate-block-identifiers.multiple-nested
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
		while true 'inner'
			x = 2
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 1
    x64.xor r9d, r9d
    x64.test r8, r8
    x64.je outer_1.after
  outer_1:
    x64.mov r8d, 1
  inner_2.header:
    x64.mov r9d, 1
    x64.test r9, r9
    x64.je inner_2.exit
  inner_2:
    x64.mov r8d, 2
  inner_2.exit:
  outer_1.after:
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

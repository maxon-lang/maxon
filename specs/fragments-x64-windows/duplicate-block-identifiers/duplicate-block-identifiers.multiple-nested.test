// Test: duplicate-block-identifiers.multiple-nested
function main() returns ExitCode
	var x = 0
	if true 'outer'
		x = 1
		while true 'inner'
			x = 2
			break
		end 'inner'
	end 'outer'
	return x
end 'main'
---
ExitCode: 2
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor rax, rax
    x64.mov [rbp-8], rax
    x64.mov rcx, 1
    x64.test rcx, rcx
    x64.je main.outer_0.merge
  outer_0:
    x64.mov rax, 1
    x64.mov [rbp-8], rax
    x64.jmp main.inner_1.header
  inner_1.header:
    x64.mov rax, 1
    x64.test rax, rax
    x64.je main.inner_1.exit
  inner_1:
    x64.mov rax, 2
    x64.mov [rbp-8], rax
    x64.jmp main.inner_1.exit
  inner_1.exit:
    x64.jmp main.outer_0.merge
  outer_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_2
    x64.cmp rax, rcx
    x64.jl main.__range_panic_2
    x64.jmp main.__range_ok_2
  __range_panic_2:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

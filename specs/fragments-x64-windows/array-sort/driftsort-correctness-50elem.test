	a.push(2)
	a.push(49)
	a.push(39)
	a.push(29)
	a.push(19)
	a.push(9)
	a.push(47)
	a.push(37)
	a.push(27)
	a.push(17)
	a.push(7)
	a.push(43)
	a.push(33)
	a.push(23)
	a.push(13)
	a.push(3)
	a.push(41)
	a.push(31)
	a.push(21)
	a.push(11)
	a.push(1)
	a.sort(ascending)
	for x in a 'p'
		print("{x} ")
	end 'p'
	print("\n")
	return 0
end 'main'

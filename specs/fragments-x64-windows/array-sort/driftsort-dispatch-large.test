    x64.mov rdx, [r8+8] (8b)
    x64.mov r12, [r8+0] (8b)
    x64.mov rcx, r12
    x64.call mrt_write_stdout
    x64.mov rcx, r14
    x64.call mm_drop
    x64.mov r8, r13
    x64.epilogue
    x64.ret
  }
}

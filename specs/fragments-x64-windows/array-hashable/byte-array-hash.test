// Test: byte-array-hash
typealias ByteVal = int(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var arr = ByteArr.create()
	arr.push(65)
	arr.push(66)
	arr.push(67)
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.lea rcx, [rip+__layout_Array_ByteVal]
    x64.call Array.create
    x64.mov r12, r8
    x64.lea rax, [rip+__layout_Array_ByteVal]
    x64.mov edx, 65
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_ByteVal]
    x64.mov edx, 66
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_ByteVal]
    x64.mov edx, 67
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea r9, [rip+__witness_int_Equatable]
    x64.lea rax, [rip+__witness_int_Hashable]
    x64.lea rdx, [rip+__layout_Array_ByteVal]
    x64.mov rcx, r12
    x64.call Array.hash
    x64.mov r13, r8
    x64.mov rcx, r12
    x64.call __mm_decref_maybenull_helper
    x64.test r13, r13
    x64.je nonzero_0.after
  nonzero_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  nonzero_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

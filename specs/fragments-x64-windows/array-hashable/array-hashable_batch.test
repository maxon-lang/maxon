// Batch: array-hashable
// Tests: array-hash-basic, array-equals-same, array-equals-different, array-equals-different-length, int-array-map-key, byte-array-hash, byte-array-equals
---
// Test: array-hash-basic
function main() returns ExitCode
	let arr = [10, 20, 30]
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-equals-same
function main() returns ExitCode
	let a = [1, 2, 3]
	let b = [1, 2, 3]
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: array-equals-different
function main() returns ExitCode
	let a = [1, 2, 3]
	let b = [1, 2, 4]
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: array-equals-different-length
function main() returns ExitCode
	let a = [1, 2, 3]
	let b = [1, 2]
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 0
---
// Test: int-array-map-key
typealias Val = int(i64.min to i64.max)
typealias IntArr = Array with Val
typealias IntArrMap = Map with (IntArr, Val)

function main() returns ExitCode
	var m = IntArrMap.create()
	var key = IntArr.create()
	key.push(1)
	key.push(2)
	key.push(3)
	try m.insert(key: key, value: 42) otherwise ignore
	var lookup = IntArr.create()
	lookup.push(1)
	lookup.push(2)
	lookup.push(3)
	let val = try m.get(key: lookup) otherwise 'notFound'
		return 0
	end 'notFound'
	return val
end 'main'
---
ExitCode: 42
---
// Test: byte-array-hash
typealias ByteVal = byte(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var arr = ByteArr.create()
	arr.push(65)
	arr.push(66)
	arr.push(67)
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: byte-array-equals
typealias ByteVal = byte(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var a = ByteArr.create()
	a.push(65)
	a.push(66)
	var b = ByteArr.create()
	b.push(65)
	b.push(66)
	if a.equals(b) 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---

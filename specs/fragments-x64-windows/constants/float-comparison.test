    x64.movsd xmm1, [rip+__float_0.1]
    x64.ucomisd xmm0, xmm1
    x64.seta rax
    x64.movzx rax, raxb
    x64.xor ecx, ecx
    x64.mov [rbp-9], rcx
    x64.test rax, rax
    x64.je constants.main.shortAnd_0.merge
  shortAnd_0.rhs:
    x64.movsd xmm0, [rip+__float_0.9]
    x64.movsd xmm1, [rbp-8]
    x64.ucomisd xmm1, xmm0
    x64.setb rax
    x64.movzx rax, raxb
    x64.mov [rbp-9], rax
    x64.jmp constants.main.shortAnd_0.merge
  shortAnd_0.merge:
    x64.mov rax, [rbp-9]
    x64.test rax, rax
    x64.je constants.main.inRange_1.after
  inRange_1:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  inRange_1.after:

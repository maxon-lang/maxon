// Test: float-comparison
enum Threshold
	low = 0.1
	high = 0.9
end 'Threshold'

function main() returns ExitCode
	let val = 0.5
	if val > Threshold.low and val < Threshold.high 'inRange'
		return 1
	end 'inRange'
	return 0
end 'main'
---
ExitCode: 1
---

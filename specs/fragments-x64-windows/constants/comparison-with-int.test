// Test: comparison-with-int
enum State
	idle
	running
	done
end 'State'

function main() returns ExitCode
	let s = State.running
	if s >= State.idle and s <= State.done 'inRange'
		return 1
	end 'inRange'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
  shortAnd.rhs:
    x64.cmp r8, 2
    x64.setle r8
  shortAnd.merge:
    x64.test r8, r8
    x64.je inRange_0.after
  inRange_0:
    x64.mov r8d, 1
    x64.ret
  inRange_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

// Test: comparison-with-int
enum State
	idle
	running
	done
end 'State'

function main() returns ExitCode
	let s = State.running
	if s >= State.idle and s <= State.done 'inRange'
		return 1
	end 'inRange'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.mov [rbp-8], rax
    x64.xor rcx, rcx
    x64.mov rdx, [rbp-8]
    x64.cmp rdx, rcx
    x64.setge rbx
    x64.movzx rbx, rbxb
    x64.mov rsi, 2
    x64.mov rdi, [rbp-8]
    x64.cmp rdi, rsi
    x64.setle r8
    x64.movzx r8, r8b
    x64.and rbx, r8
    x64.test rbx, rbx
    x64.je main.inRange_0.after
  inRange_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  inRange_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

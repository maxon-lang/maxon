// Test: comparison-with-int
enum State
	idle
	running
	done
end 'State'

function main() returns ExitCode
	let s = State.running
	if s >= State.idle and s <= State.done 'inRange'
		return 1
	end 'inRange'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 1
    x64.mov [rbp-8], rax
    x64.xor ecx, ecx
    x64.mov rdx, [rbp-8]
    x64.cmp rdx, rcx
    x64.setge rbx
    x64.movzx rbx, rbxb
    x64.xor esi, esi
    x64.mov [rbp-9], rsi
    x64.test rbx, rbx
    x64.je main.shortAnd_0.merge
  shortAnd_0.rhs:
    x64.mov rax, 2
    x64.mov rcx, [rbp-8]
    x64.cmp rcx, rax
    x64.setle rdx
    x64.movzx rdx, rdxb
    x64.mov [rbp-9], rdx
    x64.jmp main.shortAnd_0.merge
  shortAnd_0.merge:
    x64.mov rax, [rbp-9]
    x64.test rax, rax
    x64.je main.inRange_0.after
  inRange_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  inRange_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

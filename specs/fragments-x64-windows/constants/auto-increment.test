// Test: auto-increment
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.blue
	let result = match c 'check'
		red gives 10
		green gives 20
		blue gives 30
	end 'check'
	return result
end 'main'
---
ExitCode: 30
---

	off
end 'Status'

function isOn(s Status) returns bool
	if s == Status.on 'check'
		return true
	end 'check'
	return false
end 'isOn'

function main() returns ExitCode
	let status = Status.on
	if isOn(status) 'test'
		return 1
	end 'test'
	return 0
end 'main'

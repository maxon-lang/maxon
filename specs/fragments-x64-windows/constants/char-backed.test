// Test: char-backed
enum Escape
	newline = '\n'
	tab = '\t'
end 'Escape'

function main() returns ExitCode
	let e = Escape.newline
	if e == Escape.newline 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---

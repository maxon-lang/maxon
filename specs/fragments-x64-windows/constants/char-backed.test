    x64.mov r12, r8
    x64.xor ecx, ecx
    x64.call __enum_Escape_rawString
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Character.equals
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1

    x64.movsd xmm1, [rip+__float_4602678819172646912]
    x64.ucomisd xmm1, xmm0
    x64.jp check_0.after
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.ret
  }

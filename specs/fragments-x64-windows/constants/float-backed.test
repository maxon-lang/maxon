// Test: float-backed
enum Threshold
	low = 0.1
	medium = 0.5
	high = 0.9
end 'Threshold'

function main() returns ExitCode
	let t = Threshold.medium
	if t == Threshold.medium 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

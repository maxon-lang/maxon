// Test: fromRawValue-simple
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = try Color.fromRawValue(1) otherwise Color.red
	if c == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 1
    x64.call __enum_Color_fromRawValue
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.xor r8d, r8d
  try_0.merge:
    x64.cmp r8, 1
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

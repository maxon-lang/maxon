// Test: fromRawValue-simple
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = try Color.fromRawValue(1) otherwise Color.red
	if c == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rax, 1
    x64.mov rcx, 1
    x64.xor edx, edx
    x64.xor ebx, ebx
    x64.cmp rax, rbx
    x64.sete rsi
    x64.movzx rsi, rsib
    x64.xor edi, edi
    x64.test rsi, rsi
    x64.mov r8, rcx
    x64.cmovne r8, rdi
    x64.xor r9d, r9d
    x64.test rsi, rsi
    x64.mov rcx, rdx
    x64.cmovne rcx, r9
    x64.mov rdx, 1
    x64.cmp rax, rdx
    x64.sete rdx
    x64.movzx rdx, rdxb
    x64.xor ebx, ebx
    x64.test rdx, rdx
    x64.mov rsi, r8
    x64.cmovne rsi, rbx
    x64.mov rbx, 1
    x64.test rdx, rdx
    x64.mov rdi, rcx
    x64.cmovne rdi, rbx
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.sete rax
    x64.movzx rax, raxb
    x64.xor ecx, ecx
    x64.test rax, rax
    x64.mov rdx, rsi
    x64.cmovne rdx, rcx
    x64.mov rcx, 2
    x64.test rax, rax
    x64.mov rbx, rdi
    x64.cmovne rbx, rcx
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov [rbp-16], rbx
    x64.xor eax, eax
    x64.cmp rdx, rax
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-24], rax
    x64.mov rcx, 1
    x64.mov rdx, [rbp-24]
    x64.cmp rdx, rcx
    x64.jne main.check_4.after
  check_4:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_4.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

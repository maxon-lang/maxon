// Test: top-level-constant
enum Color
	red
	green
	blue
end 'Color'

let DEFAULT_COLOR = Color.green

function main() returns ExitCode
	if DEFAULT_COLOR == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 1
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

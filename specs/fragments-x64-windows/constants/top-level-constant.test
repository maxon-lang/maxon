// Test: top-level-constant
enum Color
	red
	green
	blue
end 'Color'

let DEFAULT_COLOR = Color.green

function main() returns ExitCode
	if DEFAULT_COLOR == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

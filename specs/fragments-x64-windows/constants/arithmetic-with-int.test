// Test: arithmetic-with-int
enum Step
	first
	second
	third
end 'Step'

function main() returns ExitCode
	let stride = 10
	let offset = Step.second * stride
	return offset
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 10
    x64.ret
  }
}
---

// Test: fromRawValue-int-backed
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	let status = try HttpStatus.fromRawValue(404) otherwise HttpStatus.ok
	if status == HttpStatus.notFound 'check'
		return 1
	end 'check'
	return 0
end 'main'

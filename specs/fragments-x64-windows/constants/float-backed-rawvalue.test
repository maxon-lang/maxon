// Test: float-backed-rawvalue
enum Weights
	light = 1.5
	medium = 2.5
	heavy = 3.5
end 'Weights'

function main() returns ExitCode
	let w = Weights.medium
	let rawVal = w.rawValue
	if rawVal > 2.0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_4611686018427387904]
    x64.movsd xmm1, [rip+__float_4612811918334230528]
    x64.ucomisd xmm1, xmm0
    x64.jbe check_0.after
  check_0:
    x64.mov r8d, 1
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.ret
  }
}

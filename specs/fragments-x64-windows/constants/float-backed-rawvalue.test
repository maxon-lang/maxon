// Test: float-backed-rawvalue
enum Weights
	light = 1.5
	medium = 2.5
	heavy = 3.5
end 'Weights'

function main() returns ExitCode
	let w = Weights.medium
	let rawVal = w.rawValue
	if rawVal > 2.0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_2.5]
    x64.movsd [rbp-8], xmm0
    x64.movsd xmm1, [rbp-8]
    x64.movsd xmm2, [rip+__float_2]
    x64.ucomisd xmm1, xmm2
    x64.jbe main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

// Test: string-rawvalue-dynamic-comparison
enum Planet
	earth = "Earth"
	mars = "Mars"
end 'Planet'

function getName() returns String
	return "Mars"
end 'getName'

function main() returns ExitCode
	let p = Planet.mars
	let name = p.rawValue
	let expected = getName()
	if name == expected 'check'
		return 1
	end 'check'
	return 0
end 'main'

    x64.xor edx, edx
    x64.add rax, rdx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg constants.main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl constants.main.__range_panic_0
    x64.jmp constants.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_5]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue

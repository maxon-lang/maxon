// Test: arithmetic-as-array-index
enum Slot
	a
	b
	c
end 'Slot'

let NUM_SLOTS = 3

function main() returns ExitCode
	let idx = Slot.b * NUM_SLOTS + Slot.a
	return idx
end 'main'
---
ExitCode: 3
---

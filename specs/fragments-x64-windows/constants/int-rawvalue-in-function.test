// Test: int-rawvalue-in-function

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
	ok = 200
	notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns Integer
	return s.rawValue
end 'getCode'

function main() returns ExitCode
	let status = HttpStatus.notFound
	let code = getCode(status)
	if code == 404 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @constants.getCode(s: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 404
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.call constants.getCode
    x64.mov rdx, 404
    x64.cmp rax, rdx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

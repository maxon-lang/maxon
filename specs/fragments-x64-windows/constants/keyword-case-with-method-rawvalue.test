// Test: keyword-case-with-method-rawvalue
enum TokenType
	function
	return
	end
	if
end 'TokenType'

function main() returns ExitCode
	let t = TokenType.function
	return t.rawValue
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

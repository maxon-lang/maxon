// Test: raw-value-int-comparison
enum Priority
	low = 1
	medium = 5
	high = 10
end 'Priority'

function main() returns ExitCode
	let p = Priority.high
	if p.rawValue > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 5
    x64.cmp rcx, rdx
    x64.jle main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

// Test: fromRawValue-failure

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
	ok = 200
	notFound = 404
end 'HttpStatus'

function getCode() returns Integer
	return 999
end 'getCode'

function main() returns ExitCode
	let code = getCode()
	let status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
	if status == HttpStatus.ok 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @constants.getCode() -> i64 {
  entry:
    x64.mov rax, 999
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.call constants.getCode
    x64.mov rcx, 1
    x64.xor edx, edx
    x64.mov rbx, 200
    x64.cmp rax, rbx
    x64.sete rbx
    x64.movzx rbx, rbxb
    x64.xor esi, esi
    x64.test rbx, rbx
    x64.mov rdi, rcx
    x64.cmovne rdi, rsi
    x64.mov rcx, 200
    x64.test rbx, rbx
    x64.mov rsi, rdx
    x64.cmovne rsi, rcx
    x64.mov rcx, 404
    x64.cmp rax, rcx
    x64.sete rax
    x64.movzx rax, raxb
    x64.xor ecx, ecx
    x64.test rax, rax
    x64.mov rdx, rdi
    x64.cmovne rdx, rcx
    x64.mov rbx, 404
    x64.test rax, rax
    x64.mov rcx, rsi
    x64.cmovne rcx, rbx
    x64.mov rsi, 200
    x64.mov [rbp-8], rsi
    x64.mov [rbp-16], rcx
    x64.xor edi, edi
    x64.cmp rdx, rdi
    x64.je main.otherwise_default_continue_3
  otherwise_default_error_2:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-16], rax
    x64.jmp main.otherwise_default_continue_3
  otherwise_default_continue_3:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-24], rax
    x64.mov rcx, 200
    x64.mov rdx, [rbp-24]
    x64.cmp rdx, rcx
    x64.jne main.check_4.after
  check_4:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_4.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }

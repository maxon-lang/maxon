// Test: raw-value-int
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	let status = HttpStatus.ok
	if status.rawValue == 200 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

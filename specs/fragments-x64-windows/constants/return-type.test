// Test: return-type
enum Result
	success
	failure
end 'Result'

function getResult(succeed bool) returns Result
	if succeed 'check'
		return Result.success
	end 'check'
	return Result.failure
end 'getResult'

function main() returns ExitCode
	let r = getResult(true)
	if r == Result.success 'test'
		return 1
	end 'test'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @getResult(rcx: i1) -> u8 {
  entry:
    x64.test rcx, rcx
    x64.je check_0.after
  check_0:
    x64.xor r8d, r8d
    x64.ret
  check_0.after:
    x64.mov r8d, 1
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 1
    x64.call getResult
    x64.test r8, r8
    x64.jne test_0.after
  test_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  test_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

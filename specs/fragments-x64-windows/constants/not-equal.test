// Test: not-equal
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	if c != Color.blue 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov rcx, 2
    x64.mov rdx, [rbp-8]
    x64.cmp rdx, rcx
    x64.je main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

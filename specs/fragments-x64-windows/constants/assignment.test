// Test: assignment
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	var d = Direction.north
	d = Direction.west
	if d == Direction.west 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 3
    x64.mov [rbp-8], rax
    x64.mov rcx, 3
    x64.mov rdx, [rbp-8]
    x64.cmp rdx, rcx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

// Test: assignment
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	var d = Direction.north
	d = Direction.west
	if d == Direction.west 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

// Test: name-char-backed
enum CardSuit
	Hearts = 'H'
	Diamonds = 'D'
	Spades = 'S'
end 'CardSuit'

function main() returns ExitCode
	let s = CardSuit.Diamonds
	if s.name == "Diamonds" 'check'
		return 1
	end 'check'
	return 0
end 'main'

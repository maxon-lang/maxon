module {
  func @constants.isOn(s: i64) -> i1 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.xor eax, eax
    x64.mov rdx, [rbp-8]
    x64.cmp rdx, rax
    x64.jne constants.isOn.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.call constants.isOn
    x64.test rax, rax
    x64.je main.test_0.after
  test_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  test_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

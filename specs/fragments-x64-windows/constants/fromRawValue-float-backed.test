// Test: fromRawValue-float-backed
enum Weights
	light = 1.5
	medium = 2.5
	heavy = 3.5
end 'Weights'

function main() returns ExitCode
	let w = try Weights.fromRawValue(2.5) otherwise Weights.light
	if w == Weights.medium 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

    x64.mov [r12+8], r8 (8b)
    x64.mov r8, -2
    x64.mov [r12+16], r8 (8b)
    x64.mov r8d, 1
    x64.mov [r12+24], r8 (8b)
    x64.xor r8d, r8d
    x64.mov [r12+32], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.mov r9d, 1
    x64.mov [r8+8], r9 (8b)
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call getInvalidName
    x64.mov rcx, r8
    x64.call __enum_Direction_fromName
    x64.test rdx, rdx
    x64.je try_0.merge
  try_0.otherwise:
    x64.xor r8d, r8d
  try_0.merge:
    x64.test r8, r8
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

// Test: fromRawValue-string-backed
enum Planet
	earth = "Earth"
	mars = "Mars"
end 'Planet'

function main() returns ExitCode
	let p = try Planet.fromRawValue("Mars") otherwise Planet.earth
	if p == Planet.mars 'check'
		return 1
	end 'check'
	return 0
end 'main'

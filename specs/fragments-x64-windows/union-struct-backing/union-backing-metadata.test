// Test: union-backing-metadata
typealias Latency = int(0 to 50)
typealias ID = int(i64.min to i64.max)

type OpMeta
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'OpMeta'

union TestOp
	add(dest ID, src ID) = OpMeta.create(latency: 1)
	mul(dest ID, src ID) = OpMeta.create(latency: 3)
	nop = OpMeta.create(latency: 0)
end 'TestOp'

function main() returns ExitCode
	return TestOp.mul.latency
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 3
    x64.ret
  }
}
---

// Batch: union-struct-backing
// Tests: union-backing-basic, union-backing-metadata, union-backing-mixed-cases, union-backing-multi-field
---
// Test: union-backing-basic
typealias Latency = int(0 to 50)
typealias ID = int(i64.min to i64.max)

type OpMeta
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'OpMeta'

union TestOp
	add(dest ID, src ID) = OpMeta.create(latency: 1)
	mul(dest ID, src ID) = OpMeta.create(latency: 3)
	nop = OpMeta.create(latency: 0)
end 'TestOp'

function main() returns ExitCode
	let op = TestOp.add(10, src: 20)
	match op 'handle'
		add(d, s) then return d + s
		mul(d, s) then return d * s
		nop then return 0
	end 'handle'
end 'main'
---
ExitCode: 30
---
// Test: union-backing-metadata
typealias Latency = int(0 to 50)
typealias ID = int(i64.min to i64.max)

type OpMeta
	export let latency Latency

	static function create(latency Latency) returns Self
		return Self{latency: latency}
	end 'create'
end 'OpMeta'

union TestOp
	add(dest ID, src ID) = OpMeta.create(latency: 1)
	mul(dest ID, src ID) = OpMeta.create(latency: 3)
	nop = OpMeta.create(latency: 0)
end 'TestOp'

function main() returns ExitCode
	return TestOp.mul.latency
end 'main'
---
ExitCode: 3
---
// Test: union-backing-mixed-cases
typealias Cost = int(0 to 100)
typealias ID = int(i64.min to i64.max)

type CostMeta
	export let cost Cost

	static function create(cost Cost) returns Self
		return Self{cost: cost}
	end 'create'
end 'CostMeta'

union Action
	load(dest ID) = CostMeta.create(cost: 4)
	store(src ID) = CostMeta.create(cost: 3)
	nop = CostMeta.create(cost: 0)
end 'Action'

function main() returns ExitCode
	let op = Action.nop
	match op 'handle'
		load(d) then return d
		store(s) then return s
		nop then return 1
	end 'handle'
end 'main'
---
ExitCode: 1
---
// Test: union-backing-multi-field
typealias Flag = int(0 to 1)
typealias Latency = int(0 to 50)
typealias ID = int(i64.min to i64.max)

type DetailMeta
	export let latency Latency
	export let isMemory Flag

	static function create(latency Latency, isMemory Flag) returns Self
		return Self{latency: latency, isMemory: isMemory}
	end 'create'
end 'DetailMeta'

union MemOp
	load(dest ID, offset ID) = DetailMeta.create(latency: 4, isMemory: 1)
	store(src ID, offset ID) = DetailMeta.create(latency: 3, isMemory: 1)
	add(dest ID, src ID) = DetailMeta.create(latency: 1, isMemory: 0)
end 'MemOp'

function main() returns ExitCode
	let memFlag = MemOp.load.isMemory
	let aluFlag = MemOp.add.isMemory
	return memFlag + aluFlag
end 'main'
---
ExitCode: 1
---

    x64.add r8, 1
    x64.mov [r12+0], r8 (8b)
    x64.mov r13, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r8d, 4294967295
    x64.cmp r13, r8

// Test: void-function-ok

function doNothing()
end 'doNothing'

function main() returns ExitCode
	doNothing()
	return 0
end 'main'
---
ExitCode: 0
---
module {
  func @discarded-results.doNothing() {
  entry:
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call discarded-results.doNothing
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}

// Test: impure-function-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

function incrementAndGet() returns Integer
	counter = counter + 1
	return counter
end 'incrementAndGet'

function main() returns ExitCode
	_ = incrementAndGet()
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.lea r8, [rip+__data_counter]
    x64.mov r9, [r8+0] (8b)
    x64.lea r8, [rip+__data_counter]
    x64.add r9, 1
    x64.mov [r8+0], r9 (8b)
    x64.lea r8, [rip+__data_counter]
    x64.mov r9, [r8+0] (8b)
    x64.xor r8d, r8d
    x64.ret
  }
}
---

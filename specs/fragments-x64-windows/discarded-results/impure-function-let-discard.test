// Test: impure-function-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

function incrementAndGet() returns Integer
	counter = counter + 1
	return counter
end 'incrementAndGet'

function main() returns ExitCode
	_ = incrementAndGet()
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @discarded-results.incrementAndGet() -> i64 {
  entry:
    x64.mov rax, qword [rip+counter]
    x64.mov rcx, 1
    x64.add rax, rcx
    x64.mov qword [rip+counter], rax
    x64.mov rax, qword [rip+counter]
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.call discarded-results.incrementAndGet
    x64.xor ecx, ecx
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

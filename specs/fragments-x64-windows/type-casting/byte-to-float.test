// Test: byte-to-float

typealias Float = float(f64.min to f64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 50 as Byte
	let f = b as Float
	return trunc(f)
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @type-casting.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 50
    x64.cvtsi2sd xmm0, rax
    x64.cvttsd2si rcx, xmm0
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg type-casting.main.__range_panic_0
    x64.cmp rcx, rdx
    x64.jl type-casting.main.__range_panic_0
    x64.jmp type-casting.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue
    x64.ret
  }
}
---

// Test: byte-to-float

typealias Float = float(f64.min to f64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 50 as Byte
	let f = b as Float
	return trunc(f)
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 50
    x64.cvtsi2sd xmm0, r8
    x64.mov r9d, 4294967295
    x64.cvttsd2si r8, xmm0
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

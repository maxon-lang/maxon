// Test: chained-byte-int-float

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 25 as Byte
	let i = b as Integer
	let f = i as Float
	return trunc(f)
end 'main'
---
ExitCode: 25
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 25
    x64.cvtsi2sd xmm0, r8
    x64.cvttsd2si r8, xmm0
    x64.cmp r8, 125
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

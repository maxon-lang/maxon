// Test: byte-to-int

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 100 as Byte
	return b as Integer
end 'main'
---
ExitCode: 100
---
// CompiledIR
module {
  func @type-casting.main() -> u8 {
  entry:
    x64.mov r8d, 100
    x64.ret
  }
}
---

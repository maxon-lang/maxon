// Test: int-literal-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	return b as Integer
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-casting.main() -> u32 {
  entry:
    x64.mov rax, 42
    x64.ret
  }
}
---

// Test: int-literal-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	return b as Integer
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-casting.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 42
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg type-casting.main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl type-casting.main.__range_panic_0
    x64.jmp type-casting.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

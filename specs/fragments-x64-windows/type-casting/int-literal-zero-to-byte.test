// Test: int-literal-zero-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0 as Byte
	return b as Integer
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

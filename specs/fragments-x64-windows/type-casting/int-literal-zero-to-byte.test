// Test: int-literal-zero-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 0 as Byte
	return b as Integer
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @type-casting.main() -> u32 {
  entry:
    x64.xor eax, eax
    x64.ret
  }
}
---

// Test: cast-in-expression

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 10 as Byte
	let result = b as Integer + 32
	return result
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-casting.main() -> u8 {
  entry:
    x64.mov r9d, 42
    x64.mov r8, r9
    x64.ret
  }
}
---

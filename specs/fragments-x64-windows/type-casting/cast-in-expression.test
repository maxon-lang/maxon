// Test: cast-in-expression

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 10 as Byte
	let result = b as Integer + 32
	return result
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov rcx, 255
    x64.and rax, rcx
    x64.mov rdx, 32
    x64.add rax, rdx
    x64.xor ebx, ebx
    x64.mov esi, 4294967295
    x64.cmp rax, rsi
    x64.jg main.__range_panic_0
    x64.cmp rax, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

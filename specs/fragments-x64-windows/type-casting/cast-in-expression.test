// Test: cast-in-expression

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 10 as Byte
	let result = b as Integer + 32
	return result
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-casting.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov rcx, 32
    x64.mov edx, eax
    x64.mov ebx, ecx
    x64.add rdx, rbx
    x64.xor esi, esi
    x64.mov edi, rdx
    x64.mov r8, 4294967295
    x64.mov r9, rdx
    x64.cmp r9, r8
    x64.jg type-casting.main.__range_panic_0
    x64.cmp rdi, rsi
    x64.jl type-casting.main.__range_panic_0
    x64.jmp type-casting.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

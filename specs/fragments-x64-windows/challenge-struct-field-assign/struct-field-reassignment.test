// Test: struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Counter
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(10)
	c.value = 42
	return c.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 10
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8d, 4294967295
    x64.cmp r9, r8
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}
---

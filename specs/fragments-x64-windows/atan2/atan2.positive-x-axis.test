// Test: atan2.positive-x-axis
function main() returns ExitCode
	var angle = Math.atan2(0.0, x: 1.0)
	if angle == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0]
    x64.movsd xmm1, [rip+__float_1]
    x64.call stdlib.Math.atan2
    x64.movsd xmm2, [rip+__float_0]
    x64.ucomisd xmm0, xmm2
    x64.jne main.check_0.after
    x64.jp main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  }
}
---

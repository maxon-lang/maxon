// Batch: sin
// Tests: sin.basic, sin.zero, sin.with-int-promotion
---
// Test: sin.basic
function main() returns ExitCode
	let x1 = Math.sin(0.0)
	let x2 = Math.sin(0.5)
	let x3 = Math.sin(1.0)
	let x4 = Math.sin(1.5708)
	print("{x1}\n")
	print("{x2}\n")
	print("{x3}\n")
	print("{x4}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
0.0
0.479426
0.841471
0.999999
```
---
// Test: sin.zero
function main() returns ExitCode
	let result = Math.sin(0.0)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: sin.with-int-promotion
function main() returns ExitCode
	let x = 0  // int
	let result = Math.sin(x)  // x promoted to 0.0
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0

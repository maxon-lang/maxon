// Batch: enum-full
// Tests: simple-enum, enum-assignment, enum-not-equal, enum-comparison, enum-function-param, enum-return-type, associated-value-construction, associated-value-function-param, associated-value-function-param-empty, associated-value-function-return, associated-value-function-param-multi, associated-value-named-second-arg, associated-value-all-named-reordered, associated-value-array-push, associated-value-for-iterator, associated-value-for-iterator-mixed, associated-value-for-iterator-single, enum-method, enum-method-returns-enum, enum-method-export-same-file, enum-method-private-helper, union-method-no-assoc-values, union-method-with-assoc-values, match-enum-binding-simple, match-enum-binding-multiple, match-expr-enum-binding, match-enum-no-binding, implicit-string-backed, implicit-char-backed, explicit-char-backed, float-backed, fromName-associated-compile-time, fromName-associated-empty-case, fromName-associated-runtime-empty, enum-member-constant, match-enum-binding-string, match-enum-binding-struct
---
// Test: simple-enum
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	let dir = Direction.north
	let result = match dir 'check'
		north gives 1
		south gives 0
		east gives 0
		west gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// Test: enum-assignment
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	var c = Color.red
	c = Color.blue
	let result = match c 'check'
		red gives 0
		green gives 0
		blue gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// Test: enum-not-equal
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s = Status.pending
	let result = match s 'check'
		active gives 0
		pending gives 1
		done gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// Test: enum-comparison
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s1 = Status.pending
	match s1 'check'
		pending then return 1
		active then return 0
		done then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
// Test: enum-function-param
enum Status
	on
	off
end 'Status'

function isOn(s Status) returns bool
	let result = match s 'check'
		on gives true
		off gives false
	end 'check'
	return result
end 'isOn'

function main() returns ExitCode
	let status = Status.on
	if isOn(status) 'test'
		return 1
	end 'test'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: enum-return-type
enum Result
	success
	failure
end 'Result'

function getResult(succeed bool) returns Result
	if succeed 'check'
		return Result.success
	end 'check'
	return Result.failure
end 'getResult'

function main() returns ExitCode
	let r = getResult(true)
	let result = match r 'handle'
		success gives 1
		failure gives 0
	end 'handle'
	return result
end 'main'
---
ExitCode: 1

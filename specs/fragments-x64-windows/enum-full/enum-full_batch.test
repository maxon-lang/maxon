// Test: associated-value-function-param

typealias Integer = int(i64.min to i64.max)

union Container
		empty
		value(n Integer)
end 'Container'

function process(c Container) returns Integer
		match c 'handle'
				empty then return 0
				value(n) then return n
		end 'handle'
end 'process'

function main() returns ExitCode
		let c = Container.value(42)
		return process(c)
end 'main'

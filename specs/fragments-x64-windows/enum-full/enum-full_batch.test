// Test: union-method-with-assoc-values

typealias Code = int(0 to 1000)

union Outcome
	ok
	failure(code Code)

	function statusCode() returns Code
		return match self 'check'
			ok gives 0
			failure(code) gives code
		end 'check'
	end 'statusCode'
end 'Outcome'

function main() returns ExitCode
	let o = Outcome.failure(42)
	return o.statusCode()
end 'main'

typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	var c = try Container.fromName("value", 42) otherwise Container.empty
	match c 'check'
		value(n) then return n
		empty then return 0
	end 'check'
end 'main'

// Test: enum-method-export-same-file
enum Toggle
	on
	off

	export function isOn() returns bool
		return match self 'check'
			on gives true
			off gives false
		end 'check'
	end 'isOn'
end 'Toggle'

function main() returns ExitCode
	let t = Toggle.on
	if t.isOn() 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @Toggle.isOn(self: i64) -> i1 {
  entry:
    x64.prologue stack_size=32
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.xor edx, edx
    x64.mov [rbp-16], rdx
    x64.mov [rbp-24], rax
    x64.jmp Toggle.isOn.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-24]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne Toggle.isOn.check_0.cmp1
  check_0.case0:
    x64.mov rax, 1
    x64.mov [rbp-16], rax
    x64.jmp Toggle.isOn.check_0.merge
  check_0.cmp1:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne Toggle.isOn.check_0.merge
  check_0.case1:
    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp Toggle.isOn.check_0.merge
  check_0.merge:
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @enum-full.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.call Toggle.isOn
    x64.test rax, rax
    x64.je enum-full.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}

// Test: enum-comparison
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s1 = Status.pending
	match s1 'check'
		pending then return 1
		active then return 0
		done then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enum-full.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.jmp enum-full.main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne enum-full.main.check_0.cmp1
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne enum-full.main.check_0.cmp2
  check_0.case1:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.cmp2:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne enum-full.main.check_0.merge
  check_0.case2:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}

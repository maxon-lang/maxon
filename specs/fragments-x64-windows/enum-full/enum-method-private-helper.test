// Test: enum-method-private-helper
enum Signal
	red
	green
	yellow

	function isStop() returns bool
		return match self 'check'
			red gives true
			green gives false
			yellow gives false
		end 'check'
	end 'isStop'

	export function action() returns bool
		return self.isStop()
	end 'action'
end 'Signal'

function main() returns ExitCode
	let s = Signal.red
	if s.action() 'isRed'
		return 1
	end 'isRed'
	return 0
end 'main'

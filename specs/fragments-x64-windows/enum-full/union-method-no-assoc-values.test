// Test: union-method-no-assoc-values
union Status
	pending
	active
	closed

	function isActive() returns bool
		return match self 'check'
			pending gives false
			active gives true
			closed gives false
		end 'check'
	end 'isActive'
end 'Status'

function main() returns ExitCode
	let s = Status.active
	if s.isActive() 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

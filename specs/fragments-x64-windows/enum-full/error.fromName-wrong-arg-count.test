// Test: error.fromName-wrong-arg-count

typealias Integer = int(i64.min to i64.max)

union Container
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let _c = try Container.fromName("value") otherwise Container.value(0)
	return 0
end 'main'

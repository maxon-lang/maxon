// Test: enum-method-export-cross-file
// --- file: signal.maxon
export enum Signal
	on
	off

	export function isOn() returns bool
		return match self 'check'
			on gives true
			off gives false
		end 'check'
	end 'isOn'
end 'Signal'

// --- file: main.maxon
function main() returns ExitCode
	let s = Signal.on
	if s.isOn() 'check'
		return 1
	end 'check'
	return 0
end 'main'

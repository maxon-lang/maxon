    x64.mov rcx, [rax+0]
    x64.mov rdx, [rbp-8]
    x64.mov [rbp-16], rdx
    x64.mov rbx, [rbp-16]
    x64.mov [rbp-32], rcx
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.mov rsi, [rbp-32]
    x64.mov [rbp-24], rsi
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-24]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.check_0.cmp1
  check_0.case0:
    x64.mov rax, [rbp-16]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_1
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-24]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0.case1:
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rax+8]
    x64.xor rdx, rdx
    x64.mov ebx, 4294967295
    x64.cmp rcx, rbx
    x64.jg main.__range_panic_1
    x64.cmp rcx, rdx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.mov rax, [rbp-16]
    x64.mov [rbp-32], rcx
    x64.test rax, rax
    x64.jz __nonnull_skip_2
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_2
    x64.mov rcx, [rbp-8]
    x64.test rcx, rcx
    x64.jz __nonnull_skip_3
    x64.call mm_decref
    x64.label __nonnull_skip_3

// Test: match-enum-no-binding

typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	var c = Container.empty
	match c 'check'
		empty then return 1
		value(n) then return n
	end 'check'
end 'main'
---
ExitCode: 1
---

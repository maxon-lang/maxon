// Test: match-expr-enum-binding

typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	var c = Container.value(10)
	var result = match c 'get'
		empty gives 0
		value(n) gives n * 2
	end 'get'
	return result
end 'main'
---
ExitCode: 20
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=48
    x64.mov rax, 10
    x64.mov rcx, 16
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rcx, 1
    x64.mov [rax+0], rcx
    x64.mov rdx, 10
    x64.mov [rax+8], rdx
    x64.mov rbx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rsi, [rbp-8]
    x64.mov rdi, [rsi+0]
    x64.mov r8, [rbp-8]
    x64.mov [rbp-16], r8
    x64.mov r9, [rbp-16]
    x64.mov [rbp-40], rdi
    x64.mov rcx, [rbp-16]
    x64.call mm_incref
    x64.xor rax, rax
    x64.mov [rbp-24], rax
    x64.mov rax, [rbp-40]
    x64.mov [rbp-32], rax
    x64.jmp main.get_0.cmp0
  get_0.cmp0:
    x64.mov rax, [rbp-32]
    x64.xor rcx, rcx
    x64.cmp rax, rcx
    x64.jne main.get_0.cmp1
  get_0.case0:
    x64.xor rax, rax
    x64.mov [rbp-24], rax
    x64.jmp main.get_0.merge
  get_0.cmp1:
    x64.mov rax, [rbp-32]
    x64.mov rcx, 1
    x64.cmp rax, rcx
    x64.jne main.get_0.merge
  get_0.case1:
    x64.mov rax, [rbp-16]
    x64.mov rcx, [rax+8]
    x64.mov rdx, 2
    x64.imul rcx, rdx
    x64.mov [rbp-24], rcx
    x64.jmp main.get_0.merge
  get_0.merge:
    x64.mov rax, [rbp-24]
    x64.xor rcx, rcx
    x64.mov rdx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.mov rbx, [rbp-16]
    x64.test rbx, rbx
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-16]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_Container(ptr: i64) {
  entry:
    x64.jmp __destruct_Container.done
  done:

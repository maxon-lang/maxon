    x64.xor eax, eax
    x64.mov [rbp-16], rax
    x64.jmp isOn.check_0.merge
  check_0.merge:
    x64.mov rax, [rbp-16]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {

// Test: error.match-enum-unknown-case

typealias Integer = int(i64.min to i64.max)

enum Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let c = Container.value(42)
	match c 'extract'
		unknown(x) then return x
	end 'extract'
end 'main'

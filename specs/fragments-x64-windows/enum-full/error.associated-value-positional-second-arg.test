// Test: error.associated-value-positional-second-arg

typealias Integer = int(i64.min to i64.max)

enum TwoParts
	none
	values(a Integer, b Integer)
end 'TwoParts'

function main() returns ExitCode
	let _p = TwoParts.values(10, 20)
	return 0
end 'main'

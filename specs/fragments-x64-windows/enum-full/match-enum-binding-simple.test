// Test: match-enum-binding-simple

typealias Integer = int(i64.min to i64.max)

union Container
	empty
	value(n Integer)
end 'Container'

function main() returns ExitCode
	let c = Container.value(42)
	match c 'extract'
		empty then return 0
		value(n) then return n
	end 'extract'
end 'main'

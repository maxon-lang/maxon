// Test: error.associated-value-wrong-count

typealias Integer = int(i64.min to i64.max)

enum Result
	success(value Integer)
	failure
end 'Result'

function main() returns ExitCode
	let _r = Result.success(1, 2)
	return 0
end 'main'

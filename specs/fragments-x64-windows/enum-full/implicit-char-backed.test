// Test: implicit-char-backed
enum CharBacked
	'N'
	'S'
	'E'
end 'CharBacked'

function main() returns ExitCode
	let dir = CharBacked.N
	let result = match dir 'check'
		N gives 1
		S gives 0
		E gives 0
	end 'check'
	return result
end 'main'
---
ExitCode: 1

// Test: enum-ordinal.float-backed
enum Threshold
	low = 0.1
	medium = 0.5
	high = 0.9
end 'Threshold'

function main() returns ExitCode
	let t = Threshold.high
	if t.ordinal == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0.9]
    x64.movsd [rbp-8], xmm0
    x64.movsd xmm1, [rbp-8]
    x64.xor rax, rax
    x64.movsd xmm2, [rip+__float_0.1]
    x64.ucomisd xmm1, xmm2
    x64.sete rcx
    x64.movzx rcx, rcxb
    x64.setnp rdx
    x64.movzx rdx, rdxb
    x64.and rcx, rdx
    x64.xor rbx, rbx
    x64.test rcx, rcx
    x64.mov rsi, rax
    x64.cmovne rsi, rbx
    x64.movsd xmm3, [rip+__float_0.5]
    x64.ucomisd xmm1, xmm3
    x64.sete rdi
    x64.movzx rdi, rdib
    x64.setnp r8
    x64.movzx r8, r8b
    x64.and rdi, r8
    x64.mov r9, 1
    x64.test rdi, rdi
    x64.mov rax, rsi
    x64.cmovne rax, r9
    x64.movsd xmm4, [rip+__float_0.9]
    x64.ucomisd xmm1, xmm4
    x64.sete rcx
    x64.movzx rcx, rcxb
    x64.setnp rdx
    x64.movzx rdx, rdxb
    x64.and rcx, rdx
    x64.mov rdx, 2
    x64.test rcx, rcx
    x64.mov rbx, rax
    x64.cmovne rbx, rdx
    x64.mov rax, 2
    x64.cmp rbx, rax
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

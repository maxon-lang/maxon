// Test: enum-ordinal.from-function
enum Priority
	low
	medium
	high
end 'Priority'

typealias OrdinalValue = int(0 to 100)

function getOrdinal(p Priority) returns OrdinalValue
	return p.ordinal
end 'getOrdinal'

function main() returns ExitCode
	let p = Priority.high
	if getOrdinal(p) == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @getOrdinal(rcx: u8) -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8, rcx
    x64.cmp r8, 100
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 2
    x64.call getOrdinal
    x64.cmp r8, 2
    x64.jne check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}

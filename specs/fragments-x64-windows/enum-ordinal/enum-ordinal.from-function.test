// Test: enum-ordinal.from-function
enum Priority
	low
	medium
	high
end 'Priority'

typealias OrdinalValue = int(0 to 100)

function getOrdinal(p Priority) returns OrdinalValue
	return p.ordinal
end 'getOrdinal'

function main() returns ExitCode
	let p = Priority.high
	if getOrdinal(p) == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

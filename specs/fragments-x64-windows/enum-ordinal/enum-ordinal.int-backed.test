// Test: enum-ordinal.int-backed
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	let s = HttpStatus.serverError
	// ordinal is 2 (third case), not 500 (the raw value)
	if s.ordinal == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 500
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.xor rdx, rdx
    x64.mov rbx, 200
    x64.cmp rcx, rbx
    x64.sete rsi
    x64.movzx rsi, rsib
    x64.xor rdi, rdi
    x64.test rsi, rsi
    x64.mov r8, rdx
    x64.cmovne r8, rdi
    x64.mov r9, 404
    x64.cmp rcx, r9
    x64.sete rax
    x64.movzx rax, raxb
    x64.mov rdx, 1
    x64.test rax, rax
    x64.mov rbx, r8
    x64.cmovne rbx, rdx
    x64.mov rax, 500
    x64.cmp rcx, rax
    x64.sete rax
    x64.movzx rax, raxb
    x64.mov rcx, 2
    x64.test rax, rax
    x64.mov rdx, rbx
    x64.cmovne rdx, rcx
    x64.mov rax, 2
    x64.cmp rdx, rax
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor rax, rax
    x64.epilogue
    x64.ret
  }
}
---

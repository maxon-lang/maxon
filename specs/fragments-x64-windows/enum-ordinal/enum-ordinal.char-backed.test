// Test: enum-ordinal.char-backed
enum Grade
	a = 'A'
	b = 'B'
	c = 'C'
end 'Grade'

function main() returns ExitCode
	let g = Grade.c
	if g.ordinal == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

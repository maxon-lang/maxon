// Test: enum-ordinal.char-backed
enum Grade
	a = 'A'
	b = 'B'
	c = 'C'
end 'Grade'

function main() returns ExitCode
	let g = Grade.c
	if g.ordinal == 2 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @enum-ordinal.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 2
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.mov rdx, 2
    x64.cmp rcx, rdx
    x64.jne enum-ordinal.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

// Test: enum-ordinal.arithmetic
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.blue
	let result = c.ordinal + 10
	if result == 12 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 2
    x64.mov [rbp-8], rax
    x64.mov rcx, [rbp-8]
    x64.xor edx, edx
    x64.xor ebx, ebx
    x64.cmp rcx, rbx
    x64.sete rsi
    x64.movzx rsi, rsib
    x64.xor edi, edi
    x64.test rsi, rsi
    x64.mov r8, rdx
    x64.cmovne r8, rdi
    x64.mov r9, 1
    x64.cmp rcx, r9
    x64.sete rax
    x64.movzx rax, raxb
    x64.mov rdx, 1
    x64.test rax, rax
    x64.mov rbx, r8
    x64.cmovne rbx, rdx
    x64.mov rax, 2
    x64.cmp rcx, rax
    x64.sete rax
    x64.movzx rax, raxb
    x64.mov rcx, 2
    x64.test rax, rax
    x64.mov rdx, rbx
    x64.cmovne rdx, rcx
    x64.mov rax, 10
    x64.add rdx, rax
    x64.mov rax, 12
    x64.cmp rdx, rax
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  }
}
---

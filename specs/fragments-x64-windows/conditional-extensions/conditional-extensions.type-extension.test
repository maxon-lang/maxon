// Test: conditional-extensions.type-extension
type Box uses Item
	export var item Item

	static function create(item Item) returns Self
		return Self{item: item}
	end 'create'
end 'Box'

extension Box where Item is Equatable
	function matches(other Item) returns bool
		return item == other
	end 'matches'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
	let b = IntBox.create(item: 42)
	if b.matches(42) 'yes'
		return 1
	end 'yes'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 42
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.cmp r9, 42
    x64.jne yes_0.after
  yes_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  yes_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

// Test: builtins-type.float-to-bits
function main() returns ExitCode
	let bits = __Builtins.floatToBits(1.0)
	// IEEE 754: 1.0 = 0x3FF0000000000000 = 4607182418800017408
	if bits == 4607182418800017408 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_1]
    x64.movq rax, xmm0
    x64.mov rcx, 4607182418800017408
    x64.cmp rax, rcx
    x64.jne main.check_0.after
  check_0:
    x64.xor rax, rax
    x64.ret
  check_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

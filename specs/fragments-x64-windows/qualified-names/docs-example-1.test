// Test: docs-example-1
typealias Score = int(i64.min to i64.max)

export function add(a Score, b Score) returns Score
	return a + b
end 'add'

function main() returns ExitCode
	return add(10, b: 20)  // Unqualified call within same namespace
end 'main'

---
ExitCode: 30
---
module {
  func @qualified-names.add(a: i64, b: i64) -> i64 {
  entry:
    x64.lea rax, [rcx + rdx]
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 10
    x64.mov rdx, 20
    x64.call qualified-names.add
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_0
    x64.cmp rax, rcx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

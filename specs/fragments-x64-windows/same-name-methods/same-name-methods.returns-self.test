// Test: same-name-methods.returns-self
typealias Integer = int(i64.min to i64.max)

type Counter
	export var count Integer

	static function create(count Integer) returns Counter
		return Counter{count: count}
	end 'create'

	static function reset() returns Counter
		return Counter{count: 0}
	end 'reset'

	function reset()
		count = 0
	end 'reset'
end 'Counter'

function main() returns ExitCode
	let c = Counter.reset()
	var c2 = Counter.create(count: 42)
	c2.reset()
	return c.count + c2.count
end 'main'
---
ExitCode: 0

// Test: async-await.parallel
typealias Integer = int(i64.min to i64.max)

function taskA() returns Integer
		if File.exists(FilePath from "noyield.txt") 'io'
		end 'io'
		return 10
end 'taskA'

function taskB() returns Integer
		if File.exists(FilePath from "noyield.txt") 'io'
		end 'io'
		return 20
end 'taskB'

function main() returns ExitCode
		var p1 = async taskA()
		var p2 = async taskB()
		var r1 = await p1
		var r2 = await p2
		return r1 + r2
end 'main'

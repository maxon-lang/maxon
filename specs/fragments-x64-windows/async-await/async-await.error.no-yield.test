// Test: async-await.error.no-yield
typealias Integer = int(i64.min to i64.max)

function heavyCompute(n Integer) returns Integer
		return n * n
end 'heavyCompute'

function main() returns ExitCode
		var p = async heavyCompute(5)
		var result = await p
		return result
end 'main'

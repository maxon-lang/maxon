    x64.mov r8d, 1
    x64.mov [r12+24], r8 (8b)
    x64.xor r8d, r8d
    x64.mov [r12+32], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov [r8+0], r12 (8b)
    x64.mov r9d, 1
    x64.mov [r8+8], r9 (8b)
    x64.mov rcx, r8
    x64.call FilePath.init
    x64.mov r9, [r8+0] (8b)
    x64.mov rcx, [r9+0] (8b)
    x64.call mrt_file_exists
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_0.after:
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 24
    x64.call __slab_alloc
    x64.xor r9d, r9d
    x64.mov [r8+0], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+8], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+16], r9 (8b)
    x64.xor edx, edx
    x64.lea rcx, [rip+yieldingTask]
    x64.mov rax, r8
    x64.call __gt_spawn
    x64.mov r8d, 42

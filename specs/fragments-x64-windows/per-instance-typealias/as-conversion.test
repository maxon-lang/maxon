    x64.mov rdx, 7
    x64.call IntWrapper.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rax+8]
    x64.call per-instance-typealias.takeStrTag
    x64.mov rdx, 7
    x64.cmp rax, rdx
    x64.jne main.check_0.after
  check_0:
    x64.mov rax, [rbp-8]

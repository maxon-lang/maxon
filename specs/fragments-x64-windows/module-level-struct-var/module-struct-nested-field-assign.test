		end 'create'
end 'Inner'

type Outer
		export var inner Inner

		static function create(inner Inner) returns Self
			return Self{inner: inner}
		end 'create'
end 'Outer'

var state = Outer.create(inner: Inner.create(x: 0))

function main() returns ExitCode
		state.inner.x = 99
		return state.inner.x
end 'main'

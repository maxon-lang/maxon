    x64.mov r9d, 99
    x64.mov [r8+0], r9 (1b)
    x64.lea r8, [rip+__data_state]
    x64.mov r9, [r8+0] (8b)
    x64.mov rsi, [r9+0] (8b)
    x64.movzx r8, [rsi+0] (1b)
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_03273e62f3feaf85]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

// Test: basic-tuple
function main() returns ExitCode
	var t = (10, 32)
	return t.0 + t.1
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov rcx, 32
    x64.mov [rbp-16], rax
    x64.mov [rbp-8], rcx
    x64.mov rdx, [rbp-16]
    x64.mov rbx, [rbp-8]
    x64.add rdx, rbx
    x64.xor rsi, rsi
    x64.mov edi, 4294967295
    x64.cmp rdx, rdi
    x64.jg main.__range_panic_0
    x64.cmp rdx, rsi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
}
---

// Batch: tuples
// Tests: basic-tuple, mixed-type-tuple, tuple-as-param, tuple-as-return, tuple-destructuring, three-element-tuple, tuple-field-write, tuple-with-string, let-destructuring, for-destructuring-map
---
// Test: basic-tuple
function main() returns ExitCode
	let t = (10, 32)
	return t.0 + t.1
end 'main'
---
ExitCode: 42
---
// Test: mixed-type-tuple
function main() returns ExitCode
	let t = (40, 2.5)
	return t.0 + trunc(t.1)
end 'main'
---
ExitCode: 42
---
// Test: tuple-as-param

typealias Integer = int(i64.min to i64.max)

function sum(t (Integer, Integer)) returns Integer
	return t.0 + t.1
end 'sum'

function main() returns ExitCode
	let t = (10, 32)
	return sum(t)
end 'main'
---
ExitCode: 42
---
// Test: tuple-as-return

typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
	return (a, b)
end 'makePair'

function main() returns ExitCode
	let t = makePair(10, b: 32)
	return t.0 + t.1
end 'main'
---
ExitCode: 42
---
// Test: tuple-destructuring

typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
	return (a, b)
end 'makePair'

function main() returns ExitCode
	let (x, y) = makePair(10, b: 32)
	return x + y
end 'main'
---
ExitCode: 42
---
// Test: three-element-tuple
function main() returns ExitCode
	let t = (1, 2, 39)
	return t.0 + t.1 + t.2
end 'main'
---
ExitCode: 42
---
// Test: tuple-field-write
function main() returns ExitCode
	var t = (0, 0)
	t.0 = 20
	t.1 = 22
	return t.0 + t.1
end 'main'
---
ExitCode: 42
---
// Test: tuple-with-string
function main() returns ExitCode
	let t = (42, "hello")
	return t.0
end 'main'
---
ExitCode: 42
---
// Test: let-destructuring
function main() returns ExitCode
	let (x, y) = (10, 32)
	return x + y
end 'main'
---
ExitCode: 42
---
// Test: for-destructuring-map
function main() returns ExitCode
	let m = ["a": 10, "b": 32]
	var sum = 0
	for (_, value) in m 'loop'
		sum = sum + value
	end 'loop'
	return sum
end 'main'
---
ExitCode: 42
---

ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 40
    x64.movsd xmm0, [rip+__float_2.5]
    x64.mov [rbp-16], rax
    x64.movsd [rbp-8], xmm0

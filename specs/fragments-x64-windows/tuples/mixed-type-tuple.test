    x64.movsd xmm1, [rbp-8]
    x64.cvttsd2si rdx, xmm1
    x64.add rcx, rdx
    x64.xor rbx, rbx
    x64.mov esi, 4294967295
    x64.cmp rcx, rsi
    x64.jg main.__range_panic_0
    x64.cmp rcx, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rcx
    x64.epilogue

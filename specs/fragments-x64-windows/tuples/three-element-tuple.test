// Test: three-element-tuple
function main() returns ExitCode
	let t = (1, 2, 39)
	return t.0 + t.1 + t.2
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rax, 1
    x64.mov rcx, 2
    x64.mov rdx, 39
    x64.mov [rbp-24], rax
    x64.mov [rbp-16], rcx
    x64.mov [rbp-8], rdx
    x64.mov rbx, [rbp-24]
    x64.mov rsi, [rbp-16]
    x64.add rbx, rsi
    x64.mov rdi, [rbp-8]
    x64.add rbx, rdi
    x64.xor r8, r8
    x64.mov r9, 4294967295
    x64.cmp rbx, r9
    x64.jg main.__range_panic_0
    x64.cmp rbx, r8
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rbx
    x64.epilogue
    x64.ret
  }
}
---

// Test: negative-division
function main() returns ExitCode
	let neg = -7
	let a = neg / 2           // -7/2 = -3 (truncating toward zero)
	if a == -3 'pass'
			return 0
	end 'pass'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov eax, 7
    x64.mov r8d, 2
    x64.neg rax
    x64.cqo
    x64.idiv r8
    x64.mov r8d, 3
    x64.neg r8
    x64.cmp rax, r8
    x64.jne pass_0.after
  pass_0:
    x64.xor r8d, r8d
    x64.ret
  pass_0.after:
    x64.mov r8d, 1
    x64.ret
  }
}
---

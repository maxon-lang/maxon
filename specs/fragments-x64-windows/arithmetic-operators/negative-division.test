// Test: negative-division
function main() returns ExitCode
	let neg = -7
	let a = neg / 2           // -7/2 = -3 (truncating toward zero)
	if a == -3 'pass'
			return 0
	end 'pass'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, -7
    x64.mov rcx, 2
    x64.cqo
    x64.idiv rcx
    x64.mov rdx, -3
    x64.cmp rax, rdx
    x64.jne main.pass_0.after
  pass_0:
    x64.xor rax, rax
    x64.ret
  pass_0.after:
    x64.mov rax, 1
    x64.ret
  }
}
---

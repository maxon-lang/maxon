// Test: variable-division-optimizes
function main() returns ExitCode
	let a = 7
	let b = 2
	return a / b              // int/int = truncating int, returns 3
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
    x64.mov eax, 7
    x64.xor edx, edx
    x64.idiv r8
    x64.mov r8, rax
    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_0]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

// Batch: arithmetic-operators
// Tests: addition, multiplication, precedence, division-truncating-int, trunc-division-optimizes, variable-division-optimizes, negative-division, modulo, complex-expression, docs-example-1
---
// Test: addition
function main() returns ExitCode
	return 5 + 3
end 'main'
---
ExitCode: 8
---
// Test: multiplication
function main() returns ExitCode
	return 6 * 7
end 'main'
---
ExitCode: 42
---
// Test: precedence
function main() returns ExitCode
	return 2 + 3 * 4
end 'main'
---
ExitCode: 14
---
// Test: division-truncating-int
function main() returns ExitCode
	return 20 / 3
end 'main'
---
ExitCode: 6
---
// Test: trunc-division-optimizes
function main() returns ExitCode
	return 20 / 3             // int/int = truncating int, returns 6
end 'main'
---
ExitCode: 6
---
// Test: variable-division-optimizes
function main() returns ExitCode
	let a = 7
	let b = 2
	return a / b              // int/int = truncating int, returns 3
end 'main'
---
ExitCode: 3
---
// Test: negative-division
function main() returns ExitCode
	let neg = -7
	let a = neg / 2           // -7/2 = -3 (truncating toward zero)
	if a == -3 'pass'
			return 0
	end 'pass'
	return 1
end 'main'
---
ExitCode: 0
---
// Test: modulo
function main() returns ExitCode
	return 17 mod 5
end 'main'
---
ExitCode: 2
---
// Test: complex-expression
function main() returns ExitCode
	let a = 10
	let b = 3
	let result = (a + b) * 2 - a / b
	return result
end 'main'
---
ExitCode: 23
---
// Test: docs-example-1
function main() returns ExitCode
	let a = 10
	let b = 3
	let sum = a + b          // 13
	let diff = a - b         // 7
	let prod = a * b         // 30
	let div = a / b          // 3 (truncating integer division)
	let rem = a mod b        // 1

	// Use the values
	print("{sum}\n")
	print("{diff}\n")
	print("{prod}\n")
	print("{div}\n")
	print("{rem}\n")

	return 0
end 'main'

---
ExitCode: 0
---

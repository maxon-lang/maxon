// Test: trunc-division-optimizes
function main() returns ExitCode
	return 20 / 3             // int/int = truncating int, returns 6
end 'main'
---
ExitCode: 6
---
// CompiledIR
module {
  func @arithmetic-operators.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 20
    x64.mov rcx, 3
    x64.cqo
    x64.idiv rcx
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg arithmetic-operators.main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl arithmetic-operators.main.__range_panic_0
    x64.jmp arithmetic-operators.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}
---

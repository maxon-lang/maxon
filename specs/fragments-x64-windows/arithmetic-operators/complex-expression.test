// Test: complex-expression
function main() returns ExitCode
	var a = 10
	var b = 3
	var result = (a + b) * 2 - a / b
	return result
end 'main'
---
ExitCode: 23
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rax, 10
    x64.mov rcx, 3
    x64.lea rdx, [rax + rcx]
    x64.mov rbx, 2
    x64.imul rdx, rbx
    x64.mov [rbp-8], rdx
    x64.cqo
    x64.idiv rcx
    x64.mov rsi, [rbp-8]
    x64.sub rsi, rax
    x64.xor rdi, rdi
    x64.mov r8, 4294967295
    x64.cmp rsi, r8
    x64.jg main.__range_panic_0
    x64.cmp rsi, rdi
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, rsi
    x64.epilogue
    x64.ret
  }
}

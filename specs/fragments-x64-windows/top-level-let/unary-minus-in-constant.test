// Test: unary-minus-in-constant
let NEGATIVE = -42

function main() returns ExitCode
	return 0 - NEGATIVE
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @top-level-let.main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov rcx, -42
    x64.sub rax, rcx
    x64.xor edx, edx
    x64.mov ebx, 4294967295
    x64.cmp rax, rbx
    x64.jg top-level-let.main.__range_panic_0
    x64.cmp rax, rdx
    x64.jl top-level-let.main.__range_panic_0
    x64.jmp top-level-let.main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_Integer]
    x64.mov edx, 20
    x64.mov rcx, r12
    x64.call Array.push
    x64.lea rax, [rip+__layout_Array_Integer]
    x64.mov edx, 30

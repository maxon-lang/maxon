    x64.mov [r8+16], r9 (8b)
    x64.mov r9d, 8
    x64.mov [r8+24], r9 (8b)
    x64.xor r9d, r9d
    x64.mov [r8+32], r9 (8b)
    x64.mov [r12+0], r8 (8b)
    x64.lea rax, [rip+__layout_Array_Integer]
    x64.mov edx, 10

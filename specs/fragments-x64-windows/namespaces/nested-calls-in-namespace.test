// Test: nested-calls-in-namespace

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function sum_three(a Integer, b Integer, c Integer) returns Integer
	return add(add(a, b: b), b: c)
end 'sum_three'

function main() returns ExitCode
	return sum_three(1, b: 2, c: 3)
end 'main'
---
ExitCode: 6
---
// CompiledIR
module {
  func @namespaces.add(rcx: i64, rdx: i64) -> i64 {
  entry:
    x64.mov r9, rcx
    x64.add r9, rdx
    x64.mov r8, r9
    x64.ret
  }
  func @namespaces.sum_three(rcx: i64, rdx: i64, rax: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8, rcx
    x64.mov r9, rdx
    x64.mov r12, rax
    x64.mov rcx, r8
    x64.mov rdx, r9
    x64.call namespaces.add
    x64.mov rcx, r8
    x64.mov rdx, r12
    x64.call namespaces.add
    x64.mov r9, r8
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
  func @namespaces.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 3
    x64.mov r9d, 2
    x64.mov esi, 1
    x64.mov rcx, rsi
    x64.mov rdx, r9
    x64.mov rax, r8
    x64.call namespaces.sum_three
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea r8, [rip+__panic_msg_2]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}
---

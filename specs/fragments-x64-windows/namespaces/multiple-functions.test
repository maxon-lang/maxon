// Test: multiple-functions

typealias Integer = int(i64.min to i64.max)

export function double(x Integer) returns Integer
	return x * 2
end 'double'

export function triple(x Integer) returns Integer
	return x * 3
end 'triple'

function main() returns ExitCode
	return double(5) + triple(4)
end 'main'
---
ExitCode: 22
---
// CompiledIR
module {
  func @namespaces.double(rcx: i64) -> i64 {
  entry:
    x64.mov r9d, 2
    x64.mov rsi, rcx
    x64.imul rsi, r9
    x64.mov r8, rsi
    x64.ret
  }
  func @namespaces.triple(rcx: i64) -> i64 {
  entry:
    x64.mov r9d, 3
    x64.mov rsi, rcx
    x64.imul rsi, r9
    x64.mov r8, rsi
    x64.ret
  }
  func @namespaces.main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 5
    x64.mov rcx, r8
    x64.call namespaces.double
    x64.mov r12, r8
    x64.mov r8d, 4
    x64.mov rcx, r8
    x64.call namespaces.triple
    x64.mov r9, r12
    x64.add r9, r8
    x64.cmp r9, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.mov r8, r9
    x64.epilogue
    x64.ret
  }
}

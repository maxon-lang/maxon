// Test: var-reassigned-in-if

function main() returns ExitCode
	var x = 0
	if x == 0 'check'
		x = 42
	end 'check'
	return x
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0:
    x64.mov rax, 42
    x64.mov [rbp-8], rax
    x64.jmp main.check_0.merge
  check_0.merge:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.mov edx, 4294967295
    x64.cmp rax, rdx
    x64.jg main.__range_panic_1
    x64.cmp rax, rcx
    x64.jl main.__range_panic_1
    x64.jmp main.__range_ok_1
  __range_panic_1:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

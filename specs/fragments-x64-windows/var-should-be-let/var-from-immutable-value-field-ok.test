// Test: var-from-immutable-value-field-ok

typealias Integer = int(i64.min to i64.max)

type Point
	export var x as Integer
	export var y as Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function main() returns ExitCode
	let p = Point.create(1, y: 2)
	var x = p.x
	x = 99
	return x
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor edx, edx
    x64.mov ecx, 16
    x64.call stdlib.__mm_alloc
    x64.mov r12, r8
    x64.mov r8d, 1
    x64.mov [r12+0], r8 (8b)
    x64.mov r8d, 2
    x64.mov [r12+8], r8 (8b)
    x64.mov r8, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r8d, 99
    x64.epilogue
    x64.ret
  }
}
---

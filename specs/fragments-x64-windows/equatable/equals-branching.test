    x64.mov r9, [r13+0] (8b)
    x64.mov rsi, [r12+0] (8b)
    x64.xor edi, edi
    x64.cmp rsi, r9
    x64.jne first_0.after
  first_0:
    x64.add rdi, 1
  first_0.after:
    x64.mov r9, [r8+0] (8b)
    x64.mov rsi, [r12+0] (8b)
    x64.cmp rsi, r9
    x64.jne second_0.after
  second_0:
    x64.add rdi, 10
  second_0.after:

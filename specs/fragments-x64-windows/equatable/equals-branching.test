    x64.mov r8, [r13+0] (8b)
    x64.cmp r8, r9
    x64.jne __phi_trampoline_4_0
  third_0:
    x64.add rdi, 100
    x64.mov r8, rdi
  third_0.after:
    x64.mov r9d, 4294967295

    x64.mov r8d, 2
    x64.mov [r12+8], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov r9d, 1
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 2
    x64.mov [r8+8], r9 (8b)
    x64.mov rcx, r12
    x64.mov rdx, r8
    x64.call Point.equals
    x64.test r8, r8
    x64.je check_0.after
  check_0:
    x64.xor r8d, r8d

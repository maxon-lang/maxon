// Test: self-equality

typealias Integer = int(i64.min to i64.max)

type Box implements Equatable
	export var value Integer

	function equals(other Box) returns bool
		return value == other.value
	end 'equals'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function main() returns ExitCode
	let a = Box.create(value: 7)
	if a.equals(a) 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
module {
  func @Box.equals(__self_ptr: i64, other: i64) -> i1 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov [rbp-16], rdx
    x64.mov rax, [rbp-8]
    x64.mov rbx, [rax+0]
    x64.mov rax, [rbp-16]
    x64.mov rsi, [rax+0]
    x64.cmp rbx, rsi
    x64.sete rax
    x64.movzx rax, raxb
    x64.epilogue
    x64.ret
  }
  func @Box.create(value: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor edx, edx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov rcx, 7
    x64.call Box.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.mov rdx, [rbp-8]
    x64.call Box.equals
    x64.test rax, rax
    x64.je main.check_0.after
  check_0:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.xor eax, eax
    x64.epilogue
    x64.ret
  check_0.after:
    x64.mov rax, [rbp-8]
    x64.test rax, rax
    x64.jz __nonnull_skip_1
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_1
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  }
  func @__destruct_Box(ptr: i64) {
  entry:
    x64.jmp __destruct_Box.done
  done:
    x64.ret
  }
}
---

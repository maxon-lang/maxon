    x64.mov rsi, [rdx+0] (8b)
    x64.mov rdi, [rcx+0] (8b)
    x64.cmp r9, r8
    x64.sete r9
    x64.cmp rdi, rsi
    x64.sete r8
    x64.and r8, r9
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov r12, r8
    x64.mov r8d, 1
    x64.mov [r12+0], r8 (8b)
    x64.mov r8d, 2
    x64.mov [r12+8], r8 (8b)
    x64.mov ecx, 16
    x64.call mrt_alloc
    x64.mov r9d, 1
    x64.mov [r8+0], r9 (8b)
    x64.mov r9d, 99
    x64.mov [r8+8], r9 (8b)
    x64.mov r9, [r8+8] (8b)
    x64.mov rsi, [r12+8] (8b)
    x64.mov rdi, [r8+0] (8b)
    x64.mov r8, [r12+0] (8b)
    x64.cmp rsi, r9
    x64.sete r9
    x64.cmp r8, rdi
    x64.sete r8
    x64.and r8, r9
    x64.je check_1.after
  check_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.epilogue

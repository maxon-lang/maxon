    x64.mov r12, r8
    x64.mov r8d, 41
    x64.mov [r12+0], r8 (8b)
    x64.mov r13, [r12+0] (8b)
    x64.mov rcx, r12
    x64.call mm_drop
    x64.mov r9d, 4294967295
    x64.mov r8, r13
    x64.add r8, 1
    x64.cmp r8, r9
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea r12, [rip+__panic_msg_a9b7a3f66d355a3f]
    x64.mov rcx, r12
    x64.call mrt_panic
  __range_ok_0:
    x64.epilogue
    x64.ret
  }
}

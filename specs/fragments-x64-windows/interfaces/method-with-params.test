    x64.mov r8, [rcx+0] (8b)
    x64.add r8, rdx
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ecx, 8
    x64.call mrt_alloc
    x64.mov r9d, 10
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov r8, r9
    x64.add r8, 5
    x64.cmp r8, 125
    x64.jbe __range_ok_2
  __range_panic_2:
    x64.lea rcx, [rip+__panic_msg_2]
    x64.call mrt_panic
  __range_ok_2:
    x64.epilogue
    x64.ret
  }
}

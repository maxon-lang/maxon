// Test: transitive-interface-complete

typealias Integer = int(i64.min to i64.max)

interface BaseInterface
	function baseMethod() returns Integer
end 'BaseInterface'

interface DerivedInterface extends BaseInterface
	function derivedMethod() returns Integer
end 'DerivedInterface'

// CompleteType implements all methods from both interfaces
type CompleteType implements DerivedInterface
	var value Integer

	function baseMethod() returns Integer
		return value
	end 'baseMethod'

	function derivedMethod() returns Integer
		return value * 2
	end 'derivedMethod'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'CompleteType'

function main() returns ExitCode
	var t = CompleteType.create(value: 21)
	return t.baseMethod() + t.derivedMethod()
end 'main'
---
ExitCode: 63
---
module {
  func @CompleteType.baseMethod(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @CompleteType.derivedMethod(__self_ptr: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-8], rcx
    x64.mov rax, [rbp-8]
    x64.mov rdx, [rax+0]
    x64.mov rax, 2
    x64.imul rdx, rax
    x64.mov rax, rdx
    x64.epilogue
    x64.ret
  }
  func @CompleteType.create(value: i64) -> i64 {
  entry:
    x64.prologue stack_size=16
    x64.mov [rbp-16], rcx
    x64.mov rcx, 8
    x64.xor rdx, rdx
    x64.mov r8, 1
    x64.call mm_alloc
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-16]
    x64.mov [rax+0], rcx
    x64.mov rdx, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call mm_incref
    x64.mov rax, [rbp-8]
    x64.epilogue
    x64.ret
  }
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=32
    x64.mov rcx, 21
    x64.call CompleteType.create
    x64.mov [rbp-8], rax
    x64.mov rax, [rbp-8]
    x64.mov rcx, [rbp-8]
    x64.call CompleteType.baseMethod
    x64.mov rcx, [rbp-8]
    x64.mov [rbp-16], rax
    x64.call CompleteType.derivedMethod
    x64.mov rdx, [rbp-16]
    x64.add rdx, rax
    x64.xor rbx, rbx
    x64.mov esi, 4294967295
    x64.cmp rdx, rsi
    x64.jg main.__range_panic_0
    x64.cmp rdx, rbx
    x64.jl main.__range_panic_0
    x64.jmp main.__range_ok_0
  __range_panic_0:
    x64.lea_symdata rax, [__panic_msg_0]
    x64.mov rcx, rax
    x64.call mrt_panic
  __range_ok_0:
    x64.mov rax, [rbp-8]
    x64.mov [rbp-24], rdx
    x64.test rax, rax
    x64.jz __nonnull_skip_0
    x64.mov rcx, [rbp-8]
    x64.call mm_decref
    x64.label __nonnull_skip_0
    x64.mov rax, [rbp-24]
    x64.epilogue
    x64.ret
  }
  func @__destruct_CompleteType(ptr: i64) {
  entry:
    x64.jmp __destruct_CompleteType.done
  done:
    x64.ret
  }
}

    x64.mov rsi, [r8+0] (8b)
    x64.mov r8d, 2
    x64.imul r9, r8
    x64.mov edi, 4294967295
    x64.mov r8, rsi
    x64.add r8, r9
    x64.cmp r8, rdi
    x64.jbe __range_ok_0
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]
    x64.call mrt_panic
  __range_ok_0:

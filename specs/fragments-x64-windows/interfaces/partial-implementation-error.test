	function two() returns Integer
	function three() returns Integer
end 'ThreeMethods'

type Incomplete implements ThreeMethods
	let value as Integer

	function one() returns Integer
		return 1
	end 'one'
end 'Incomplete'

function main() returns ExitCode
	return 0
end 'main'

// Test: multiple-methods

typealias Integer = int(i64.min to i64.max)

interface Describable
	function describe() returns Integer
	function value() returns Integer
end 'Describable'

type Counter implements Describable
	let count Integer

	function describe() returns Integer
		return 50 + count
	end 'describe'

	function value() returns Integer
		return count
	end 'value'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	let c = Counter.create(count: 12)
	return c.describe() + c.value()
end 'main'
---
ExitCode: 74
---
// CompiledIR
module {
  func @Counter.describe(rcx: i64) -> i64 {
  entry:
    x64.mov r8, [rcx+0] (8b)
    x64.mov r9, r8
    x64.add r9, 50
    x64.mov r8, r9
    x64.ret
  }
  func @Counter.value(rcx: i64) -> i64 {
  entry:
    x64.mov r9, [rcx+0] (8b)
    x64.mov r8, r9
    x64.ret
  }
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 8
    x64.mov rcx, r8
    x64.call mrt_alloc
    x64.mov r9d, 12
    x64.mov [r8+0], r9 (8b)
    x64.mov r9, [r8+0] (8b)
    x64.mov rsi, [r8+0] (8b)
    x64.add r9, 50
    x64.mov r8, r9
    x64.add r8, rsi
    x64.cmp r8, 125
    x64.jbe __range_ok_1
  __range_panic_1:
    x64.lea r8, [rip+__panic_msg_1]
    x64.mov rcx, r8
    x64.call mrt_panic
  __range_ok_1:
    x64.epilogue
    x64.ret
  }
}
---

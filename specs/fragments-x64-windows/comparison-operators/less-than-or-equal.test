// Test: less-than-or-equal
function main() returns ExitCode
	let a = 5
	let b = 10
	if a <= b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 5
    x64.mov rcx, 10
    x64.cmp rax, rcx
    x64.jg main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

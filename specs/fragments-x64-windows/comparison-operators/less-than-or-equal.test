// Test: less-than-or-equal
function main() returns ExitCode
	let a = 5
	let b = 10
	if a <= b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 5
    x64.cmp r8, 10
    x64.jg check_1.after
  check_1:
    x64.mov r8d, 1
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

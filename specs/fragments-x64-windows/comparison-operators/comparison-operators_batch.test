// Batch: comparison-operators
// Tests: equality, not-equal, greater-than, less-than-or-equal, float-comparison, docs-example-1
---
// Test: equality
function main() returns ExitCode
	let x = 42
	if x == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: not-equal
function main() returns ExitCode
	let x = 10
	if x != 20 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: greater-than
function main() returns ExitCode
	if 5 > 3 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// Test: less-than-or-equal
function main() returns ExitCode
	let a = 5
	let b = 10
	if a <= b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: float-comparison
function main() returns ExitCode
	let x = 3.5
	let y = 2.1
	if x > y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// Test: docs-example-1
function main() returns ExitCode
	let x = 10
	let y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'

---
ExitCode: 1

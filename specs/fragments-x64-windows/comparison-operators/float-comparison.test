// Test: float-comparison
function main() returns ExitCode
	let x = 3.5
	let y = 2.1
	if x > y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.movsd xmm0, [rip+__float_3.5]
    x64.movsd xmm1, [rip+__float_2.1]
    x64.ucomisd xmm0, xmm1
    x64.jbe main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

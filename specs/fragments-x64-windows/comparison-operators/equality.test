// Test: equality
function main() returns ExitCode
	let x = 42
	if x == 42 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rbx, 42
    x64.cmp rbx, 42
    x64.jne check_1.after
  check_1:
    x64.mov rax, 1
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

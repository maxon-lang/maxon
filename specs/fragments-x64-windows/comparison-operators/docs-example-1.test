// Test: docs-example-1
function main() returns ExitCode
	var x = 10
	var y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rax, 10
    x64.cmp rax, 20
    x64.jge check_1.after
  check_1:
    x64.mov rax, 1
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

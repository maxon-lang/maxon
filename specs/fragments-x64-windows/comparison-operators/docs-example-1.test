// Test: docs-example-1
function main() returns ExitCode
	let x = 10
	let y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'

---
ExitCode: 1
---
// CompiledIR
module {
  func @comparison-operators.main() -> u32 {
  entry:
    x64.mov rax, 10
    x64.mov rcx, 20
    x64.cmp rax, rcx
    x64.jge comparison-operators.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

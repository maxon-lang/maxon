// Test: docs-example-1
function main() returns ExitCode
	let x = 10
	let y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.prologue stack_size=16
    x64.mov ebx, 10
    x64.cmp rbx, 20
    x64.jge check_1.after
  check_1:
    x64.mov r8d, 1
    x64.epilogue
    x64.ret
  check_1.after:
    x64.mov r8d, 0
    x64.epilogue
    x64.ret
  }
}
---

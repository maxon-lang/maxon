// Test: not-equal
function main() returns ExitCode
	var x = 10
	if x != 20 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.mov rax, 10
    x64.cmp rax, 20
    x64.je check_1.after
  check_1:
    x64.mov rax, 1
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

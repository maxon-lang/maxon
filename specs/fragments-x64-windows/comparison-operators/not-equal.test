// Test: not-equal
function main() returns ExitCode
	let x = 10
	if x != 20 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @comparison-operators.main() -> u32 {
  entry:
    x64.mov rax, 10
    x64.mov rcx, 20
    x64.cmp rax, rcx
    x64.je comparison-operators.main.check_0.after
  check_0:
    x64.mov rax, 1
    x64.ret
  check_0.after:
    x64.xor eax, eax
    x64.ret
  }
}
---

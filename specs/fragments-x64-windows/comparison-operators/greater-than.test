// Test: greater-than
function main() returns ExitCode
	if 5 > 3 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    x64.mov r8d, 5
    x64.cmp r8, 3
    x64.jle check_1.after
  check_1:
    x64.mov r8d, 42
    x64.ret
  check_1.after:
    x64.xor r8d, r8d
    x64.ret
  }
}
---

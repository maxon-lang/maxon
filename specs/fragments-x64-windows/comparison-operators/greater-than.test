// Test: greater-than
function main() returns ExitCode
	if 5 > 3 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
module {
  func @main() -> u8 {
  entry:
    x64.mov rbx, 5
    x64.cmp rbx, 3
    x64.jle check_1.after
  check_1:
    x64.mov rax, 42
    x64.ret
  check_1.after:
    x64.xor rax, rax
    x64.ret
  }
}
---

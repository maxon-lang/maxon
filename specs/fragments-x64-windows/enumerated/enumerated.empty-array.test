// Test: enumerated.empty-array
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = IntArray.create()
	var count = 0
	for (i, v) in arr.enumerated() 'loop'
		print("{i}:{v}\n")
		count = count + 1
	end 'loop'
	print("{count}\n")
	return 0
end 'main'

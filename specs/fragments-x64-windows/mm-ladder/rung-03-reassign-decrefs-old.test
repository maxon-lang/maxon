mm_move Box #1 -> return [Box.create]
mm_drop Box #1 [Box.create]
    mm_free Box #1
mm_alloc Box #2 size=8 [Box.create]
mm_move Box #2 -> return [Box.create]
mm_drop Box #2 [main]
    mm_free Box #2

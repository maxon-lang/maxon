// Test: enum-exhaustive.float-backed-range
enum Threshold
		low = 0.1
		medium = 0.5
		high = 0.9
end 'Threshold'

function main() returns ExitCode
	let t = Threshold.medium
	match t 'check'
		low to high then return 1
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.movsd xmm0, [rip+__float_0.5]
    x64.movsd [rbp-8], xmm0
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.movsd xmm0, [rbp-8]
    x64.movsd xmm1, [rip+__float_0.1]
    x64.ucomisd xmm0, xmm1
    x64.setae rax
    x64.movzx rax, raxb
    x64.movsd xmm2, [rbp-8]
    x64.movsd xmm3, [rip+__float_0.9]
    x64.ucomisd xmm2, xmm3
    x64.setbe rcx
    x64.movzx rcx, rcxb
    x64.and rax, rcx
    x64.test rax, rax
    x64.je main.check_0.merge
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

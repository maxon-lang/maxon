// Test: enum-exhaustive.float-backed-range
enum Threshold
		low = 0.1
		medium = 0.5
		high = 0.9
end 'Threshold'

function main() returns ExitCode
	let t = Threshold.medium
	match t 'check'
		low to high then return 1
	end 'check'
end 'main'
---
ExitCode: 1

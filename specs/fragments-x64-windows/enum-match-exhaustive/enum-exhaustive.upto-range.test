// Test: enum-exhaustive.upto-range
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	match c 'check'
		red upto blue then return 1
		blue then return 2
	end 'check'
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.xor eax, eax
    x64.mov [rbp-8], rax
    x64.jmp main.check_0.cmp0
  check_0.cmp0:
    x64.mov rax, [rbp-8]
    x64.xor ecx, ecx
    x64.cmp rax, rcx
    x64.setge rdx
    x64.movzx rdx, rdxb
    x64.mov rbx, [rbp-8]
    x64.mov rsi, 2
    x64.cmp rbx, rsi
    x64.setl rdi
    x64.movzx rdi, rdib
    x64.and rdx, rdi
    x64.test rdx, rdx
    x64.je main.check_0.cmp1
  check_0.case0:
    x64.mov rax, 1
    x64.epilogue
    x64.ret
  check_0.cmp1:
    x64.mov rax, [rbp-8]
    x64.mov rcx, 2
    x64.cmp rax, rcx
    x64.jne main.check_0.merge
  check_0.case1:
    x64.mov rax, 2
    x64.epilogue
    x64.ret
  check_0.merge:
  }
}
---

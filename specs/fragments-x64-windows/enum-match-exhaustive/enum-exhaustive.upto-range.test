// Test: enum-exhaustive.upto-range
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	match c 'check'
		red upto blue then return 1
		blue then return 2
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

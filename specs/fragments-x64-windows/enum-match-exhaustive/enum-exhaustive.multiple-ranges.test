// Test: enum-exhaustive.multiple-ranges
enum Priority
		low
		medium
		high
		critical
end 'Priority'

function main() returns ExitCode
	let p = Priority.high
	match p 'check'
		low to medium then return 1
		high to critical then return 2
	end 'check'
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.prologue stack_size=16
    x64.mov r8d, 2
  check_0.next0:
    x64.cmp r8, 3
    x64.setle r9
    x64.cmp r8, 2
    x64.setge r8
    x64.and r8, r9
    x64.je check_0.next1
  check_0.case1:
    x64.mov r8d, 2
    x64.epilogue
    x64.ret
  check_0.next1:
    x64.lea r12, [rip+__panic_msg_1097c97d71f9fc43]
    x64.mov rcx, r12
    x64.call mrt_panic
    x64.xor r8d, r8d
    x64.epilogue
    x64.ret
  }
}
---

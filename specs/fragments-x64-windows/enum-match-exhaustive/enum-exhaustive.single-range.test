// Test: enum-exhaustive.single-range
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	match c 'check'
		red to blue then return 1
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

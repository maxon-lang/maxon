// Test: enum-exhaustive.mix-explicit-and-range
enum Priority
		low
		medium
		high
		critical
end 'Priority'

function main() returns ExitCode
	let p = Priority.low
	match p 'check'
		low then return 1
		medium to critical then return 2
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u32 {
  entry:
    x64.mov r8d, 1
    x64.ret
  }
}
---

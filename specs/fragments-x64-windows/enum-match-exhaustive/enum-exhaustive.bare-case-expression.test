    x64.mov r9d, 4294967295
    x64.cmp r8, r9
    x64.jbe __range_ok_0
    x64.jmp __range_panic_0
  eval_0.next0:
    x64.cmp r9, 1
    x64.jne eval_0.next1
  eval_0.case1:
    x64.mov r8d, 1
    x64.jmp eval_0.merge
  eval_0.next1:
    x64.cmp r9, 2
    x64.jne eval_0.merge
  eval_0.case2:
    x64.mov r8d, 2
    x64.jmp eval_0.merge
  __range_panic_0:
    x64.lea rcx, [rip+__panic_msg_0]

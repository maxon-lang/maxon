// Test: split-consecutive-delimiters
function main() returns ExitCode
	let s = "a,,b"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("[{p}]\n")
	end 'loop'
	return 0
end 'main'

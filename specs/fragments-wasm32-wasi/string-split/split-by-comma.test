// Test: split-by-comma
function main() returns ExitCode
	let s = "a,b,c"
	let parts = s.split(",")
	print("{parts.count()}\n")
	for p in parts 'loop'
		print("{p}\n")
	end 'loop'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
3
a
b
c

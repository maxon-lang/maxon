// Test: named-args

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(3, b: 4)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3 = mir.mov_imm 7 : i64
    mir.ret %3
  }
}
---

// Test: default-param-omitted

typealias Integer = int(i64.min to i64.max)

function repeat(value Integer, times Integer = 2) returns Integer
	return value * times
end 'repeat'

function main() returns ExitCode
	return repeat(value: 21)
end 'main'
---
ExitCode: 42

// Test: named-args-multiply

typealias Integer = int(i64.min to i64.max)

function multiply(x Integer, y Integer) returns Integer
	return x * y
end 'multiply'

function main() returns ExitCode
	return multiply(x: 6, y: 7)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3 = mir.mov_imm 42 : i64
    mir.ret %3
  }
}
---

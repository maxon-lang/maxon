// Test: error-unknown-param-name

typealias Integer = int(i64.min to i64.max)

function greet(name Integer, suffix Integer) returns Integer
	return name + suffix
end 'greet'

function main() returns ExitCode
	return greet(42, person: 1)
end 'main'

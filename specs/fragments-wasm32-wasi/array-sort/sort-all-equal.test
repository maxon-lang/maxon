// Test: sort-all-equal
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var a = IntArray.create()
	a.push(7)
	a.push(7)
	a.push(7)
	a.push(7)
	a.sort()
	for x in a 'p'
		print("{x} ")
	end 'p'
	print("\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
7 7 7 7 

// Test: sort-single
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var a = IntArray.create()
	a.push(42)
	a.sort()
	let x = try a.get(0) otherwise return 99
	print("{x}\n")
	return 0
end 'main'

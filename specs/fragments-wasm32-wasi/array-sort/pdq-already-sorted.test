// Test: pdq-already-sorted
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function ascending(x Integer, y Integer) returns Ordering
	return x.compare(y)
end 'ascending'

function main() returns ExitCode
	var a = IntArray.create()
	a.push(1)
	a.push(2)
	a.push(3)
	a.push(4)
	a.push(5)
	a.push(6)
	a.push(7)
	a.push(8)
	a.push(9)
	a.push(10)
	a.push(11)
	a.push(12)
	a.push(13)
	a.push(14)
	a.push(15)
	a.push(16)
	a.push(17)
	a.push(18)
	a.push(19)
	a.push(20)
	a.push(21)
	a.push(22)
	a.push(23)
	a.push(24)
	a.push(25)
	a.push(26)
	a.push(27)
	a.push(28)
	a.push(29)
	a.push(30)
	a.push(31)
	a.push(32)
	a.push(33)
	a.push(34)
	a.push(35)
	a.sortUnstable(ascending)
	for x in a 'p'
		print("{x} ")
	end 'p'
	print("\n")
	return 0
end 'main'

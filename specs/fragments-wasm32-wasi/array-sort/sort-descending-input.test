// Test: sort-descending-input
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var a = IntArray.create()
	a.push(5)
	a.push(4)
	a.push(3)
	a.push(2)
	a.push(1)
	a.sort()
	for x in a 'p'
		print("{x} ")
	end 'p'
	print("\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
1 2 3 4 5 

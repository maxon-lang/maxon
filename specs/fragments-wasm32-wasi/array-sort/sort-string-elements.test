// Test: sort-string-elements
typealias StringArray = Array with String

function byLength(a String, b String) returns Ordering
	let la = a.count()
	let lb = b.count()
	return la.compare(lb)
end 'byLength'

function main() returns ExitCode
	var a = StringArray.create()
	a.push("banana")
	a.push("fig")
	a.push("apple")
	a.push("kiwi")
	a.push("a")
	a.sort(byLength)
	for s in a 'p'
		print("{s}\n")
	end 'p'
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
a
fig
kiwi
apple
banana
```

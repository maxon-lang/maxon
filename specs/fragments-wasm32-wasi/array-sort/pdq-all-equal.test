	Log.startCapture()
	a.sortUnstable(ascending)
	let keys = Log.stopCapture()
	if Log.fired(keys, key: "pdq.equalElements") 'e'
		print("equal-path-fired\n")
	end 'e'
	return 0
end 'main'

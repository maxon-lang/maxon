// Test: driftsort-logical-run-dispatch
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function ascending(x Integer, y Integer) returns Ordering
	return x.compare(y)
end 'ascending'

function main() returns ExitCode
	var a = IntArray.create()
	var base = 0
	var blk = 0
	while blk < 25 'blocks'
		a.push(base + 4)
		a.push(base + 3)
		a.push(base + 2)
		a.push(base + 1)
		base = base + 10
		blk = blk + 1
	end 'blocks'
	Log.startCapture()
	a.sort(ascending)
	let keys = Log.stopCapture()
	if Log.fired(keys, key: "driftsort.logicalRun") 'lr'
		print("logicalRun ")
	end 'lr'
	if not Log.fired(keys, key: "driftsort.eagerRun") 'ne'
		print("no-eager ")
	end 'ne'
	var ok = true
	for i in 1 upto 100 'c'
		let p = try a.get(i - 1) otherwise return 90
		let cv = try a.get(i) otherwise return 91
		if p > cv 'bad'
			ok = false
		end 'bad'
	end 'c'
	if ok 'o'
		print("sorted")
	end 'o'
	print("\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
logicalRun no-eager sorted
```

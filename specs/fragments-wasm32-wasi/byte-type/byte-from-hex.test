// Test: byte-from-hex

typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 0xff as Byte
	if b == 255 'ok'
		return 0
	end 'ok' else 'fail'
		return 1
	end 'fail'
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  }
}
---

module {
  func @main() -> u8 {
  entry:
    %2 = mir.global_addr @__layout_Array_ByteVal
    %3 = mir.call @Array.create(%2)
    %5 = mir.mov_imm 65 : i64
    %6 = mir.global_addr @__layout_Array_ByteVal
    %7 = mir.call @Array.push(%3, %5, %6)
    %9 = mir.mov_imm 66 : i64
    %10 = mir.global_addr @__layout_Array_ByteVal
    %11 = mir.call @Array.push(%3, %9, %10)
    %12 = mir.global_addr @__layout_Array_ByteVal
    %13 = mir.call @Array.create(%12)
    %15 = mir.mov_imm 65 : i64
    %16 = mir.global_addr @__layout_Array_ByteVal
    %17 = mir.call @Array.push(%13, %15, %16)
    %19 = mir.mov_imm 66 : i64
    %20 = mir.global_addr @__layout_Array_ByteVal
    %21 = mir.call @Array.push(%13, %19, %20)
    %24 = mir.global_addr @__layout_Array_ByteVal
    %25 = mir.global_addr @__witness_int_Hashable
    %26 = mir.global_addr @__witness_int_Equatable
    %27 = mir.call @Array.equals(%3, %13, %24, %25, %26)
    %31 = mir.call @__mm_decref_maybenull_helper(%3)
    %30 = mir.call @__mm_decref_maybenull_helper(%13)
    mir.cond_br %27 [then: eq_0(), else: eq_0.after()]
  eq_0:
    %28 = mir.mov_imm 1 : i64
    mir.ret %28
  eq_0.after:
    %29 = mir.mov_imm 0 : i64
    mir.ret %29
  }
}

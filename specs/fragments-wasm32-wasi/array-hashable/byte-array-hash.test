// Test: byte-array-hash
typealias ByteVal = int(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var arr = ByteArr.create()
	arr.push(65)
	arr.push(66)
	arr.push(67)
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %22 = mir.mov_imm 8 : i64
    %23 = mir.call @mrt_alloc(%22)
    %24 = mir.mov_imm 40 : i64
    %25 = mir.call @mrt_alloc(%24)
    %26 = mir.mov_imm 0 : i64
    mir.store %26, %25, 0 width: qword
    %27 = mir.mov_imm 0 : i64
    mir.store %27, %25, 8 width: qword
    %28 = mir.mov_imm 0 : i64
    mir.store %28, %25, 16 width: qword
    %29 = mir.mov_imm 8 : i64
    mir.store %29, %25, 24 width: qword
    %30 = mir.mov_imm 0 : i64
    mir.store %30, %25, 32 width: qword
    mir.store %25, %23, 0 width: qword
    %3 = mir.mov_imm 65 : i64
    %4 = mir.global_addr @__layout_Array_ByteVal
    %5 = mir.call @Array.push(%23, %3, %4)
    %7 = mir.mov_imm 66 : i64
    %8 = mir.global_addr @__layout_Array_ByteVal
    %9 = mir.call @Array.push(%23, %7, %8)
    %11 = mir.mov_imm 67 : i64
    %12 = mir.global_addr @__layout_Array_ByteVal
    %13 = mir.call @Array.push(%23, %11, %12)
    %15 = mir.global_addr @__layout_Array_ByteVal
    %16 = mir.call @Array.hash(%23, %15)
    %18 = mir.mov_imm 0 : i64
    %19 = mir.cmp ne, %16, %18
    mir.cond_br %19 [then: nonzero_0(), else: nonzero_0.after()]
  nonzero_0:
    %20 = mir.mov_imm 1 : i64
    mir.ret %20
  nonzero_0.after:
    %21 = mir.mov_imm 0 : i64
    mir.ret %21
  }
}
---

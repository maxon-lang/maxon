// Test: byte-array-hash
typealias ByteVal = int(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var arr = ByteArr.create()
	arr.push(65)
	arr.push(66)
	arr.push(67)
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_ByteVal
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 65 : i64
    %5 = mir.global_addr @__layout_Array_ByteVal
    %6 = mir.call @Array.push(%2, %4, %5)
    %8 = mir.mov_imm 66 : i64
    %9 = mir.global_addr @__layout_Array_ByteVal
    %10 = mir.call @Array.push(%2, %8, %9)
    %12 = mir.mov_imm 67 : i64
    %13 = mir.global_addr @__layout_Array_ByteVal
    %14 = mir.call @Array.push(%2, %12, %13)
    %16 = mir.global_addr @__layout_Array_ByteVal
    %17 = mir.global_addr @__witness_int_Hashable
    %18 = mir.global_addr @__witness_int_Equatable
    %19 = mir.call @Array.hash(%2, %16, %17, %18)
    %21 = mir.mov_imm 0 : i64
    %22 = mir.cmp ne, %19, %21
    %25 = mir.call @__mm_decref_maybenull_helper(%2)
    mir.cond_br %22 [then: nonzero_0(), else: nonzero_0.after()]
  nonzero_0:
    %23 = mir.mov_imm 1 : i64
    mir.ret %23
  nonzero_0.after:
    %24 = mir.mov_imm 0 : i64
    mir.ret %24
  }
}
---

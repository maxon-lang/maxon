// Test: byte-array-hash
typealias ByteVal = int(0 to u8.max)
typealias ByteArr = Array with ByteVal

function main() returns ExitCode
	var arr = ByteArr.create()
	arr.push(65)
	arr.push(66)
	arr.push(67)
	let h = arr.hash()
	if h != 0 'nonzero'
		return 1
	end 'nonzero'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %24 = mir.mov_imm 8 : i64
    %25 = mir.call @mrt_alloc(%24)
    %26 = mir.mov_imm 40 : i64
    %27 = mir.call @mrt_alloc(%26)
    %28 = mir.mov_imm 0 : i64
    mir.store %28, %27, 0 width: qword
    %29 = mir.mov_imm 0 : i64
    mir.store %29, %27, 8 width: qword
    %30 = mir.mov_imm 0 : i64
    mir.store %30, %27, 16 width: qword
    %31 = mir.mov_imm 8 : i64
    mir.store %31, %27, 24 width: qword
    %32 = mir.mov_imm 0 : i64
    mir.store %32, %27, 32 width: qword
    mir.store %27, %25, 0 width: qword
    %3 = mir.mov_imm 65 : i64
    %4 = mir.global_addr @__layout_Array_ByteVal
    %5 = mir.call @Array.push(%25, %3, %4)
    %7 = mir.mov_imm 66 : i64
    %8 = mir.global_addr @__layout_Array_ByteVal
    %9 = mir.call @Array.push(%25, %7, %8)
    %11 = mir.mov_imm 67 : i64
    %12 = mir.global_addr @__layout_Array_ByteVal
    %13 = mir.call @Array.push(%25, %11, %12)
    %15 = mir.global_addr @__layout_Array_ByteVal
    %16 = mir.global_addr @__witness_int_Hashable
    %17 = mir.global_addr @__witness_int_Equatable
    %18 = mir.call @Array.hash(%25, %15, %16, %17)
    %20 = mir.mov_imm 0 : i64
    %21 = mir.cmp ne, %18, %20
    mir.cond_br %21 [then: nonzero_0(), else: nonzero_0.after()]
  nonzero_0:
    %22 = mir.mov_imm 1 : i64
    mir.ret %22
  nonzero_0.after:
    %23 = mir.mov_imm 0 : i64
    mir.ret %23
  }
}

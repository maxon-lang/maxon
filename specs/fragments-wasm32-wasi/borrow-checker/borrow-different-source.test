// Test: borrow-different-source
typealias StringArray = Array with String

function main() returns ExitCode
	let arr1 = ["hello"]
	var arr2 = StringArray.create()
	let s = try arr1.get(0) otherwise ""
	arr2.push("world")
	print("{s}\n")
	return 0
end 'main'
---

// Test: multiple-calls
function main() returns ExitCode
	let x = 42
	print("{x}\n")
	print("{10 + 5}\n")
	print("{100}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
42
15
100
```

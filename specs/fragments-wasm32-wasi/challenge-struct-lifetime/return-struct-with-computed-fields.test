  func @main() -> u8 {
  entry:
    %8 = mir.mov_imm 7 : i64
    %9 = mir.mov_imm 12 : i64
    %10 = mir.mov_imm 16 : i64
    %11 = mir.call @mrt_alloc(%10)
    mir.store %8, %11, 0 width: qword
    mir.store %9, %11, 8 width: qword
    %4 = mir.load %11, 0 width: qword
    %6 = mir.load %11, 8 width: qword
    %7 = mir.add.i64 %4, %6
    %12 = mir.mov_imm 125 : i64
    %13 = mir.cmp ugt, %7, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %14 = mir.global_addr @__panic_msg_0
    %15 = mir.call @mrt_panic(%14)
  __range_ok_0:
    mir.ret %7
  }
}

    %4 = mir.mov_imm 42 : i64
    mir.store %4, %11, 0 width: qword
    %12 = mir.load %11, 0 width: qword
    %13 = mir.call @mm_drop(%11)
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %12, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:

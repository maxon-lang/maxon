// Test: conformance-no-interface

typealias Integer = int(i64.min to i64.max)

type Standalone
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Standalone'

function main() returns ExitCode
	let s = Standalone.create(value: 42)
	return s.get()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0
    %6 = mir.load %5, 0
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %6, %7
    mir.cond_br %8 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %9 = mir.global_addr @__panic_msg_0
    %10 = mir.call @mrt_panic(%9)
  __range_ok_0:
    mir.ret %6
  }
}
---

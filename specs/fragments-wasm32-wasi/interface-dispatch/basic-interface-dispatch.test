    %1 = mir.load %5, 0 width: qword
    %3 = mir.mov_imm 1 : i64
    %4 = mir.add.i64 %1, %3
    mir.ret %4
  }
  func @callGreet(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    mir.store_slot slot_0, %5
    %6 = mir.param local1 : i64
    mir.store_slot slot_1, %6
    %2 = mir.load_slot slot_0
    %3 = mir.load_slot slot_1
    %4 = mir.witness_call %3, [0](%2)
    mir.ret %4
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 41 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.call @mrt_alloc(%5)
    mir.store %0, %6, 0 width: qword
    %3 = mir.global_addr @__witness_Hello_Greeter
    %4 = mir.call @callGreet(%6, %3)
    %7 = mir.mov_imm 255 : i64
    %8 = mir.cmp ugt, %4, %7
    mir.cond_br %8 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %9 = mir.global_addr @__panic_msg_0
    %10 = mir.call @mrt_panic(%9)
  __range_ok_0:
    mir.ret %4
  }
}

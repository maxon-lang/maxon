  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0 width: qword
    mir.ret %1
  }
  func @getCount(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    mir.store_slot slot_0, %5
    %6 = mir.param local1 : i64
    mir.store_slot slot_1, %6
    %2 = mir.load_slot slot_0
    %3 = mir.load_slot slot_1
    %4 = mir.witness_call %3, [0](%2)
    mir.ret %4
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 17 : i64
    %11 = mir.mov_imm 8 : i64
    %12 = mir.call @mrt_alloc(%11)
    mir.store %0, %12, 0 width: qword
    %2 = mir.mov_imm 25 : i64
    %13 = mir.mov_imm 8 : i64
    %14 = mir.call @mrt_alloc(%13)
    mir.store %2, %14, 0 width: qword
    %5 = mir.global_addr @__witness_SimpleCounter_Counter
    %6 = mir.call @getCount(%12, %5)
    %8 = mir.global_addr @__witness_SimpleCounter_Counter
    %9 = mir.call @getCount(%14, %8)
    %10 = mir.add.i64 %6, %9
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %10, %15
    mir.cond_br %16 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_0
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %10
  }

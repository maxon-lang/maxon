// Test: assignment-in-loop
function main() returns ExitCode
	var sum = 0
	var i = 1
	while i <= 5 'loop'
		sum = sum + i
		i = i + 1
	end 'loop'
	return sum
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 1 : i64
    mir.br loop_0.header(%0, %1)
  loop_0.header:
    %3 = mir.mov_imm 5 : i64
    %4 = mir.cmp le, %13, %3
    mir.cond_br %4 [then: loop_0(), else: loop_0.exit()]
  loop_0:
    %7 = mir.add.i64 %12, %13
    %9 = mir.mov_imm 1 : i64
    %10 = mir.add.i64 %13, %9
    mir.br loop_0.header(%7, %10)
  loop_0.exit:
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %12, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %12
  }
}
---

// Test: multiple-assignments
function main() returns ExitCode
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 20 : i64
    %3 = mir.mov_imm 30 : i64
    %6 = mir.mov_imm 50 : i64
    mir.ret %6
  }
}
---

// Test: tuple-assign-error-assign-to-let-decl
typealias Integer = int(i64.min to i64.max)

function makePair(a Integer, b Integer) returns (Integer, Integer)
	return (a, b)
end 'makePair'

function main() returns ExitCode
	var x = 0
	(x, let y) = makePair(10, b: 32)
	(x, y) = makePair(1, b: 2)
	return x + y
end 'main'

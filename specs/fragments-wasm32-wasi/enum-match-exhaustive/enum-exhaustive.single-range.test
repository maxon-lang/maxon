// Test: enum-exhaustive.single-range
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	match c 'check'
		red to blue then return 1
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  }
}
---

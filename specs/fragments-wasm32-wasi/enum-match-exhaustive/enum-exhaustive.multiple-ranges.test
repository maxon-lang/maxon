module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    mir.br check_0.next0()
  check_0.next0:
    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp ge, %0, %8
    %10 = mir.mov_imm 3 : i64
    %11 = mir.cmp le, %0, %10
    %12 = mir.and.i64 %9, %11
    mir.cond_br %12 [then: check_0.case1(), else: check_0.next1()]
  check_0.case1:
    %13 = mir.mov_imm 2 : i64
    mir.ret %13
  check_0.next1:
    %14 = mir.global_addr @__panic_msg_96c7daeb3f9a871f
    %15 = mir.call @mrt_panic(%14)
    %16 = mir.mov_imm 0 : i64
    mir.ret %16
  }
}

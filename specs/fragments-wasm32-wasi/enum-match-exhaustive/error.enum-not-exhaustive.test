// Test: error.enum-not-exhaustive
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	match c 'check'
		red then return 1
		green then return 2
	end 'check'
end 'main'
---
MaxoncStderr: ```
error E2026: specs/fragments/enum-match-exhaustive/error.enum-not-exhaustive.test:13:2: match on enum 'Color' is not exhaustive, missing: blue
```

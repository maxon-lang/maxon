// Test: enum-exhaustive.expression
enum Status
		pending
		approved
		rejected
end 'Status'

function main() returns ExitCode
	let s = Status.approved
	let code = match s 'eval'
		pending gives 0
		approved to rejected gives 1
	end 'eval'
	return code
end 'main'

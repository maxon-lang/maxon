// Test: enum-exhaustive.mix-explicit-and-range
enum Priority
		low
		medium
		high
		critical
end 'Priority'

function main() returns ExitCode
	let p = Priority.low
	match p 'check'
		low then return 1
		medium to critical then return 2
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

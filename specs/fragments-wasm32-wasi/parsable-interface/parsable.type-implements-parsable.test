// Test: parsable.type-implements-parsable

typealias Integer = int(i64.min to i64.max)

// Type can implement Parsable with throwing static method
enum ParseError implements Error
	Invalid = 1
end 'ParseError'

type Value implements Parsable
	var n Integer

	static function fromString(input String) returns Self throws ParseError
		return Value{n: input.byteLength()}
	end 'fromString'
end 'Value'

function main() returns ExitCode
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @Value.fromString(local0: i64) -> i64 {
  entry:
    %6 = mir.param local0 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @mrt_alloc(%1)
    %4 = mir.call @String.byteLength(%6)
    mir.store %4, %2, 0 width: qword
    %5 = mir.mov_imm 0 : i64
    mir.error_return %2, %5
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    mir.ret %0
  }
}
---

    %3 = mir.mov_imm 0 : i64
    mir.store %3, %2, 8 width: qword
    %4 = mir.mov_imm -2 : i64
    mir.store %4, %2, 16 width: qword
    %5 = mir.mov_imm 1 : i64
    mir.store %5, %2, 24 width: qword
    %6 = mir.mov_imm 0 : i64
    mir.store %6, %2, 32 width: qword
    %7 = mir.mov_imm 16 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %2, %8, 0 width: qword
    %9 = mir.mov_imm 1 : i64
    mir.store %9, %8, 8 width: qword
    %10, %11 = mir.try_call @Value.fromString(%8)
    %12 = mir.mov_imm 0 : i64
    %13 = mir.cmp ne, %11, %12
    mir.cond_br %13 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:

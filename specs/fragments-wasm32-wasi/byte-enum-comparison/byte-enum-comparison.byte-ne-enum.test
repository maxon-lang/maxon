// Test: byte-enum-comparison.byte-ne-enum

typealias Byte = int(0 to u8.max)

enum Ascii
	underscore = 95
	space = 32
	zero = 48
end 'Ascii'

function main() returns ExitCode
	let b = 95 as Byte
	if b == Ascii.space 'noMatch'
		return 1
	end 'noMatch'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 0 : i64
    mir.ret %5
  }
}
---

// Test: byte-enum-comparison.enum-eq-byte

typealias Byte = int(0 to u8.max)

enum Ascii
	underscore = 95
	space = 32
	zero = 48
end 'Ascii'

function main() returns ExitCode
	let s = 32 as Byte
	if Ascii.space == s 'match'
		return 0
	end 'match'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  }
}
---

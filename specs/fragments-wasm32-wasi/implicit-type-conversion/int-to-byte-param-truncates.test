  entry:
    %2 = mir.mov_imm 44 : i64
    %3 = mir.call @implicit-type-conversion.takeByte(%2)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_3(), else: __range_ok_3()]
  __range_panic_3:
    %6 = mir.global_addr @__panic_msg_3
    %7 = mir.call @mrt_panic(%6)
  __range_ok_3:
    mir.ret %3
  }
}

    %1 = mir.mov_imm 255 : i64
    %2 = mir.and.i64 %0, %1
    %3 = mir.call @implicit-type-conversion.takeByte(%2)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_7(), else: __range_ok_7()]
  __range_panic_7:
    %6 = mir.global_addr @__panic_msg_7

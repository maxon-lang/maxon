// Test: math-intrinsic-int-promotion
function main() returns ExitCode
	let result = sqrt(16)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
// CompiledIR
module {
  func @implicit-type-conversion.main() -> u8 {
  entry:
    %0 = mir.mov_imm 16 : i64
    %1 = mir.sitofp.f64 %0
    %2 = mir.sqrt.f64 %1
    %4 = mir.fptosi.i64 %2
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_9(), else: __range_ok_9()]
  __range_panic_9:
    %7 = mir.global_addr @__panic_msg_9
    %8 = mir.call @mrt_panic(%7)
  __range_ok_9:
    mir.ret %4
  }
}
---

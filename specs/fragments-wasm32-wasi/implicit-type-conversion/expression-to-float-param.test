// Test: expression-to-float-param

typealias Integer = int(i64.min to i64.max)
typealias Float = float(f64.min to f64.max)

function takeFloat(x Float) returns Integer
	return trunc(x)
end 'takeFloat'

function main() returns ExitCode
	let a = 20
	let b = 22
	return takeFloat(a + b)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 42 : i64
    %5 = mir.sitofp.f64 %4
    %7 = mir.fptosi.i64 %5
    %8 = mir.mov_imm 125 : i64
    %9 = mir.cmp ugt, %7, %8
    mir.cond_br %9 [then: __range_panic_4(), else: __range_ok_4()]
  __range_panic_4:
    %10 = mir.global_addr @__panic_msg_4
    %11 = mir.call @mrt_panic(%10)
  __range_ok_4:
    mir.ret %7
  }
}
---

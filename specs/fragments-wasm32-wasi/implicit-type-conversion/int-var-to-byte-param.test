// Test: int-var-to-byte-param

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function takeByte(x Byte) returns Integer
	return x as Integer
end 'takeByte'

function main() returns ExitCode
	let i = 300
	return takeByte(i)
end 'main'
---
ExitCode: 44
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3 = mir.mov_imm 44 : i64
    mir.ret %3
  }
}
---

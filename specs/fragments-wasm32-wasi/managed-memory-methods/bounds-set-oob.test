    %18 = mir.call @Array.push(%2, %16, %17)
    %20 = mir.load %2, 0 width: qword
    %21 = mir.mov_imm 10 : i64
    %22 = mir.mov_imm 99 : i64
    %23, %24 = mir.try_call @stdlib.__managed_mem_set(%20, %21, %22)
    %31 = mir.call @__mm_decref_maybenull_helper(%2)
    %25 = mir.mov_imm 0 : i64
    %26 = mir.cmp ne, %24, %25
    mir.cond_br %26 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:

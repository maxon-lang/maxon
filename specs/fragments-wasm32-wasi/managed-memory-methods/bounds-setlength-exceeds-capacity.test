// Test: bounds-setlength-exceeds-capacity
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(1)
	try arr.managed.setLength(100) otherwise 'overlen'
		return 7
	end 'overlen'
	return 0
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %17 = mir.mov_imm 8 : i64
    %18 = mir.call @mrt_alloc(%17)
    %19 = mir.mov_imm 40 : i64
    %20 = mir.call @mrt_alloc(%19)
    %21 = mir.mov_imm 0 : i64
    mir.store %21, %20, 0 width: qword
    %22 = mir.mov_imm 0 : i64
    mir.store %22, %20, 8 width: qword
    %23 = mir.mov_imm 0 : i64
    mir.store %23, %20, 16 width: qword
    %24 = mir.mov_imm 8 : i64
    mir.store %24, %20, 24 width: qword
    %25 = mir.mov_imm 0 : i64
    mir.store %25, %20, 32 width: qword
    mir.store %20, %18, 0 width: qword
    %3 = mir.mov_imm 1 : i64
    %4 = mir.global_addr @__layout_Array_Int
    %5 = mir.call @Array.push(%18, %3, %4)
    %7 = mir.load %18, 0 width: qword
    %8 = mir.mov_imm 100 : i64
    %9, %10 = mir.try_call @stdlib.__managed_mem_set_length(%7, %8)
    %11 = mir.mov_imm 0 : i64
    %12 = mir.cmp ne, %10, %11
    mir.cond_br %12 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:
    %14 = mir.mov_imm 7 : i64
    mir.ret %14
  try_0.merge:
    %16 = mir.mov_imm 0 : i64
    mir.ret %16
  }
}
---

// Test: bounds-setlength-exceeds-capacity
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(1)
	try arr.managed.setLength(100) otherwise 'overlen'
		return 7
	end 'overlen'
	return 0
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 1 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6 = mir.call @Array.push(%2, %4, %5)
    %8 = mir.load %2, 0 width: qword
    %9 = mir.mov_imm 100 : i64
    %10, %11 = mir.try_call @stdlib.__managed_mem_set_length(%8, %9)
    %18 = mir.call @__mm_decref_maybenull_helper(%2)
    %12 = mir.mov_imm 0 : i64
    %13 = mir.cmp ne, %11, %12
    mir.cond_br %13 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:
    %15 = mir.mov_imm 7 : i64
    mir.ret %15
  try_0.merge:
    %17 = mir.mov_imm 0 : i64
    mir.ret %17
  }
}
---

// Test: float-comparison
function main() returns ExitCode
	var x = 3.5
	var y = 2.1
	if x > y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4615063718147915776 : f64
    %1 = mir.mov_imm 4611911198408756428 : f64
    %4 = mir.cmp fgt, %0, %1
    mir.cond_br %4 [then: check_1(), else: check_1.after()]
  check_1:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  check_1.after:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}
---

// Test: docs-example-1
function main() returns ExitCode
	let x = 10
	let y = 20
	
	if x < y 'check'
		return 1
	end 'check'
	
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 20 : i64
    %4 = mir.cmp lt, %0, %1
    mir.cond_br %4 [then: check_1(), else: check_1.after()]
  check_1:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  check_1.after:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}
---

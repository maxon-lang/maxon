// Test: set-from-character-literals-membership
typealias CharSet = Set with Character

function main() returns ExitCode
	let cs = CharSet from ['\t', '\n', '\r', ' ', '\x0B']
	if cs.contains('\n') 'nlIn'
		if not cs.contains('h') 'hOut'
			return 42
		end 'hOut'
	end 'nlIn'
	return 0
end 'main'
---

// Test: multiple-variables
function main() returns ExitCode
	let x = 42
	let y = 10
	let result = x + y
	return result
end 'main'
---
ExitCode: 52
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %1 = mir.mov_imm 10 : i64
    %4 = mir.mov_imm 52 : i64
    mir.ret %4
  }
}
---

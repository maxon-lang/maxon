// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
// CompiledIR
module {
  func @expressions.main() -> u8 {
  entry:
    %5 = mir.mov_imm 12 : i64
    mir.ret %5
  }
}
---

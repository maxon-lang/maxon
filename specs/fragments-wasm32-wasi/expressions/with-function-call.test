// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    %1 = mir.mov_imm 5 : i64
    %3 = mir.mov_imm 4 : i64
    %4 = mir.call @with-function-call.add(%0, %3)
    %5 = mir.add.i64 %1, %4
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
  func @with-function-call.add(local0: i64, local1: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %4 = mir.param local1 : i64
    %2 = mir.add.i64 %3, %4
    mir.ret %2
  }
}
---

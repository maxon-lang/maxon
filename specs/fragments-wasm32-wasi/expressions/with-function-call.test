// Test: with-function-call

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	var x = 3
	return 5 + add(x, b: 4)
end 'main'

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'
---
ExitCode: 12
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    %1 = mir.mov_imm 5 : i64
    %3 = mir.mov_imm 4 : i64
    %4 = mir.call @with-function-call.add(%0, %3)
    %5 = mir.add.i64 %1, %4
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %10 = mir.global_addr @__panic_msg_0
    %11 = mir.call @mrt_panic(%10)
  __range_ok_0:
    mir.ret %5
  }
  func @with-function-call.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    %3 = mir.param 0 : StdI64
    %4 = mir.param 1 : StdI64
    %2 = mir.add.i64 %3, %4
    %8 = mir.mov_imm -9223372036854775807 : i64
    %9 = mir.cmp lt, %2, %8
    mir.cond_br %9 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %12 = mir.global_addr @__panic_msg_1
    %13 = mir.call @mrt_panic(%12)
  __range_ok_1:
    mir.ret %2
  }
}
---

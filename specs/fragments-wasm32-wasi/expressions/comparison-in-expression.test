// Test: comparison-in-expression
function main() returns ExitCode
	let isGreater = 10 > 5
	if isGreater 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 5 : i64
    %2 = mir.cmp gt, %0, %1
    mir.cond_br %2 [then: check_1(), else: check_1.after()]
  check_1:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  check_1.after:
    %5 = mir.mov_imm 0 : i64
    mir.ret %5
  }
}
---

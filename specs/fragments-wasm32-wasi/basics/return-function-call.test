// Test: return-function-call

typealias Integer = int(i64.min to i64.max)

function getValue() returns Integer
	return 42
end 'getValue'

function main() returns ExitCode
	return getValue()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @basics.main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    mir.ret %1
  }
}
---

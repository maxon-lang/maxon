// Test: string-rawvalue-after-reassign
enum Planet
	earth = "Earth"
	mars = "Mars"
end 'Planet'

function main() returns ExitCode
	var p = Planet.earth
	p = Planet.mars
	let name = p.rawValue
	if name == "Mars" 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

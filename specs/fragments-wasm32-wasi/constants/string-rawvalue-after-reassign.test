    mir.store %11, %7, 32 width: qword
    %12 = mir.mov_imm 16 : i64
    %13 = mir.call @mrt_alloc(%12)
    mir.store %7, %13, 0 width: qword
    %14 = mir.mov_imm 1 : i64
    mir.store %14, %13, 8 width: qword
    %15 = mir.call @String.equals(%3, %13)
    mir.cond_br %15 [then: check_0(), else: check_0.after()]

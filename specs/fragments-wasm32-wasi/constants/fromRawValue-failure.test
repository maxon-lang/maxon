// Test: fromRawValue-failure

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
	ok = 200
	notFound = 404
end 'HttpStatus'

function getCode() returns Integer
	return 999
end 'getCode'

function main() returns ExitCode
	let code = getCode()
	let status = try HttpStatus.fromRawValue(code) otherwise HttpStatus.ok
	if status == HttpStatus.ok 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %15 = mir.mov_imm 999 : i64
    %2, %3 = mir.try_call @__enum_HttpStatus_fromRawValue(%15)
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp ne, %3, %4
    mir.cond_br %5 [then: try_0.otherwise(), else: try_0.merge(%2)]
  try_0.otherwise:
    %7 = mir.mov_imm 200 : i64
    mir.br try_0.merge(%7)
  try_0.merge:
    %10 = mir.mov_imm 200 : i64
    %11 = mir.cmp eq, %14, %10
    mir.cond_br %11 [then: check_0(), else: check_0.after()]
  check_0:
    %12 = mir.mov_imm 1 : i64
    mir.ret %12
  check_0.after:
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  }
}
---

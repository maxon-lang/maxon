// Test: name-string-backed
enum Planet
	earth = "Earth"
	mars = "Mars"
end 'Planet'

function main() returns ExitCode
	let p = Planet.mars
	// rawValue is "Mars", name is "mars"
	if p.name == "mars" 'check'
		return 1
	end 'check'
	return 0
end 'main'

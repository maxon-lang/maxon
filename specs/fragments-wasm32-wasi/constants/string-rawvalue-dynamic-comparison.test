    %5 = mir.mov_imm 4 : i64
    mir.store %5, %3, 8 width: qword
    %6 = mir.mov_imm -2 : i64
    mir.store %6, %3, 16 width: qword
    %7 = mir.mov_imm 1 : i64
    mir.store %7, %3, 24 width: qword
    %8 = mir.mov_imm 0 : i64

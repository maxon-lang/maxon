    %10 = mir.mov_imm 16 : i64
    %11 = mir.func_addr @__destruct_String
    %9 = mir.call @stdlib.__mm_alloc(%10, %11)
    %13 = mir.call @stdlib.__mm_incref(%9)
    mir.store %3, %9, 0 width: qword
    %12 = mir.mov_imm 1 : i64
    mir.store %12, %9, 8 width: qword
    mir.ret %9
  }
  func @main() -> u8 {
  entry:
    %2 = mir.mov_imm 1 : i64
    %4 = mir.call @__enum_Planet_rawString(%2)
    %5 = mir.call @getName()
    %8 = mir.call @String.equals(%4, %5)
    %12 = mir.call @__mm_decref_maybenull_helper(%4)
    %11 = mir.call @__mm_decref_maybenull_helper(%5)
    mir.cond_br %8 [then: check_0(), else: check_0.after()]
  check_0:
    %9 = mir.mov_imm 1 : i64

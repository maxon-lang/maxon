// Test: string-rawvalue-dynamic-comparison
enum Planet
	earth = "Earth"
	mars = "Mars"
end 'Planet'

function getName() returns String
	return "Mars"
end 'getName'

function main() returns ExitCode
	let p = Planet.mars
	let name = p.rawValue
	let expected = getName()
	if name == expected 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @getName() -> i64 {
  entry:
    %0 = mir.global_addr @__istr_0
    %1 = mir.mov_imm 40 : i64
    %2 = mir.call @mrt_alloc(%1)
    mir.store %0, %2, 0 width: qword
    %3 = mir.mov_imm 4 : i64
    mir.store %3, %2, 8 width: qword
    %4 = mir.mov_imm -2 : i64
    mir.store %4, %2, 16 width: qword
    %5 = mir.mov_imm 1 : i64
    mir.store %5, %2, 24 width: qword
    %6 = mir.mov_imm 0 : i64
    mir.store %6, %2, 32 width: qword
    %7 = mir.mov_imm 16 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %2, %8, 0 width: qword
    %9 = mir.mov_imm 1 : i64
    mir.store %9, %8, 8 width: qword
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %2 = mir.call @__enum_Planet_rawString(%0)
    %3 = mir.call @getName()
    %6 = mir.call @String.equals(%2, %3)
    mir.cond_br %6 [then: check_0(), else: check_0.after()]
  check_0:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  check_0.after:
    %8 = mir.mov_imm 0 : i64
    mir.ret %8
  }
}
---

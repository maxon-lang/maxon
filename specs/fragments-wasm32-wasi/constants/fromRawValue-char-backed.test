// Test: fromRawValue-char-backed
enum Grade
	excellent = 'A'
	good = 'B'
	average = 'C'
end 'Grade'

function main() returns ExitCode
	let g = try Grade.fromRawValue('B') otherwise Grade.average
	if g == Grade.good 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

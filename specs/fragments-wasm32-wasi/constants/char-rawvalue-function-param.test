    mir.store %0, %8, 8 width: qword
    mir.store %0, %8, 16 width: qword
    mir.store %0, %8, 24 width: qword
    %12 = mir.mov_imm 0 : i64
    mir.store %12, %8, 32 width: qword
    %13 = mir.mov_imm 8 : i64
    %14 = mir.call @mrt_alloc(%13)
    mir.store %8, %14, 0 width: qword
    %15 = mir.call @Character.equals(%18, %14)

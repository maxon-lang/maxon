// Test: char-rawvalue-function-param
enum Grade
	excellent = 'A'
	good = 'B'
	average = 'C'
end 'Grade'

function getLetter(g Grade) returns Character
	return g.rawValue
end 'getLetter'

function main() returns ExitCode
	let grade = Grade.good
	let letter = getLetter(grade)
	if letter == 'B' 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---

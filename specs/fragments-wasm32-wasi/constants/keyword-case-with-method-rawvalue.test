// Test: keyword-case-with-method-rawvalue
enum TokenType
	function
	return
	end
	if
end 'TokenType'

function main() returns ExitCode
	let t = TokenType.function
	return t.rawValue
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    mir.ret %0
  }
}
---

// Test: float-rawvalue-in-function

typealias Float = float(f64.min to f64.max)

enum Weights
	light = 1.5
	medium = 2.5
end 'Weights'

function getRaw(w Weights) returns Float
	return w.rawValue
end 'getRaw'

function main() returns ExitCode
	let w = Weights.medium
	let raw = getRaw(w)
	if raw > 2.0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---

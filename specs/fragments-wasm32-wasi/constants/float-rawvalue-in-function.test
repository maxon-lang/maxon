module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4612811918334230528 : f64
    %4 = mir.mov_imm 4611686018427387904 : f64
    %5 = mir.cmp fgt, %0, %4
    mir.cond_br %5 [then: check_0(), else: check_0.after()]
  check_0:
    %6 = mir.mov_imm 1 : i64
    mir.ret %6
  check_0.after:
    %7 = mir.mov_imm 0 : i64
    mir.ret %7
  }
}

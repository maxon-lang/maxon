// Test: int-backed-rawvalue
enum HttpStatus
	ok = 200
	notFound = 404
	serverError = 500
end 'HttpStatus'

function main() returns ExitCode
	let status = HttpStatus.notFound
	let code = status.rawValue
	if code == 404 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

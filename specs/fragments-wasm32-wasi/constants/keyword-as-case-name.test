// Test: keyword-as-case-name
enum TokenKind
	function
	return
	end
	if
end 'TokenKind'

function main() returns ExitCode
	let t = TokenKind.function
	if t == TokenKind.function 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

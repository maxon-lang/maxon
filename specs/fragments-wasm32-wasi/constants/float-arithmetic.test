module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4616189618054758400 : f64
    %1 = mir.mov_imm 4602678819172646912 : f64
    %3 = mir.mul.f64 %1, %0
    %5 = mir.mov_imm 4611686018427387904 : f64
    %6 = mir.cmp feq, %3, %5
    mir.cond_br %6 [then: check_0(), else: check_0.after()]
  check_0:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  check_0.after:
    %8 = mir.mov_imm 0 : i64
    mir.ret %8
  }
}

// Test: float-arithmetic
enum Weight
	light = 0.5
	heavy = 2.0
end 'Weight'

function main() returns ExitCode
	let scale = 4.0
	let result = Weight.light * scale
	if result == 2.0 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---

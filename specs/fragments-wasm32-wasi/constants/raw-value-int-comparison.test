// Test: raw-value-int-comparison
enum Priority
	low = 1
	medium = 5
	high = 10
end 'Priority'

function main() returns ExitCode
	let p = Priority.high
	if p.rawValue > 5 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

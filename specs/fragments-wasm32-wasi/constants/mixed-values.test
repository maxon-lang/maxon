// Test: mixed-values
enum Priority
	low
	medium
	high = 10
	critical
end 'Priority'

function main() returns ExitCode
	let result = match Priority.critical 'check'
		low gives 0
		medium gives 1
		high gives 10
		critical gives 11
	end 'check'
	return result
end 'main'

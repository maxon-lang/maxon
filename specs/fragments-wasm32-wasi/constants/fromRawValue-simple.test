// Test: fromRawValue-simple
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = try Color.fromRawValue(1) otherwise Color.red
	if c == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1, %2 = mir.try_call @__enum_Color_fromRawValue(%0)
    %3 = mir.mov_imm 0 : i64
    %4 = mir.cmp ne, %2, %3
    mir.cond_br %4 [then: try_0.otherwise(), else: try_0.merge(%1)]
  try_0.otherwise:
    %6 = mir.mov_imm 0 : i64
    mir.br try_0.merge(%6)
  try_0.merge:
    %9 = mir.mov_imm 1 : i64
    %10 = mir.cmp eq, %13, %9
    mir.cond_br %10 [then: check_0(), else: check_0.after()]
  check_0:
    %11 = mir.mov_imm 1 : i64
    mir.ret %11
  check_0.after:
    %12 = mir.mov_imm 0 : i64
    mir.ret %12
  }
}
---

// Test: string-backed
enum ContentType
	json = "application/json"
	html = "text/html"
	plain = "text/plain"
end 'ContentType'

function main() returns ExitCode
	let ct = ContentType.json
	if ct == ContentType.json 'check'
		return 1
	end 'check'
	return 0
end 'main'

// Test: int-rawvalue-in-function

typealias Integer = int(i64.min to i64.max)

enum HttpStatus
	ok = 200
	notFound = 404
end 'HttpStatus'

function getCode(s HttpStatus) returns Integer
	return s.rawValue
end 'getCode'

function main() returns ExitCode
	let status = HttpStatus.notFound
	let code = getCode(status)
	if code == 404 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %6 = mir.mov_imm 1 : i64
    mir.ret %6
  }
}
---

// Test: return-type
enum Result
	success
	failure
end 'Result'

function getResult(succeed bool) returns Result
	if succeed 'check'
		return Result.success
	end 'check'
	return Result.failure
end 'getResult'

function main() returns ExitCode
	let r = getResult(true)
	if r == Result.success 'test'
		return 1
	end 'test'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @getResult(local0: i1) -> u8 {
  entry:
    %4 = mir.param local0 : i1
    mir.cond_br %4 [then: check_0(), else: check_0.after()]
  check_0:
    %2 = mir.mov_imm 0 : i64
    mir.ret %2
  check_0.after:
    %3 = mir.mov_imm 1 : i64
    mir.ret %3
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.call @getResult(%0)
    %3 = mir.mov_imm 0 : i64
    %4 = mir.cmp eq, %1, %3
    mir.cond_br %4 [then: test_0(), else: test_0.after()]
  test_0:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  test_0.after:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}

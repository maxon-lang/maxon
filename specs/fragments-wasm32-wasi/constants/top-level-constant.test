// Test: top-level-constant
enum Color
	red
	green
	blue
end 'Color'

let DEFAULT_COLOR = Color.green

function main() returns ExitCode
	if DEFAULT_COLOR == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1

// Test: arithmetic-with-int
enum Step
	first
	second
	third
end 'Step'

function main() returns ExitCode
	let stride = 10
	let offset = Step.second * stride
	return offset
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3 = mir.mov_imm 10 : i64
    mir.ret %3
  }
}
---

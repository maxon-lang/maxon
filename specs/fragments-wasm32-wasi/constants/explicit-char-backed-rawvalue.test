// Test: explicit-char-backed-rawvalue
enum CardSuit
	Hearts = 'H'
	Diamonds = 'D'
	Spades = 'S'
end 'CardSuit'

function main() returns ExitCode
	let suit = CardSuit.Diamonds
	let ch = suit.rawValue
	if ch == 'D' 'check'
		return 1
	end 'check'
	return 0
end 'main'

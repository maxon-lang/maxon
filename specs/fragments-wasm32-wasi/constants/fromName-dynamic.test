// Test: fromName-dynamic
enum Color
	red
	green
	blue
end 'Color'

function getName() returns String
	return "green"
end 'getName'

function main() returns ExitCode
	let name = getName()
	let color = try Color.fromName(name) otherwise Color.red
	if color == Color.green 'check'
		return 1
	end 'check'
	return 0
end 'main'

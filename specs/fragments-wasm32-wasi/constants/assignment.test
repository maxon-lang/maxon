// Test: assignment
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	var d = Direction.north
	d = Direction.west
	if d == Direction.west 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

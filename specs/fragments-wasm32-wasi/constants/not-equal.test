// Test: not-equal
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	if c != Color.blue 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

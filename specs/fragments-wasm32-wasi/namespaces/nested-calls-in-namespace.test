// Test: nested-calls-in-namespace

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function sum_three(a Integer, b Integer, c Integer) returns Integer
	return add(add(a, b: b), b: c)
end 'sum_three'

function main() returns ExitCode
	return sum_three(1, b: 2, c: 3)
end 'main'
---
ExitCode: 6
---
// CompiledIR
module {
  func @namespaces.add(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    %6 = mir.param local1 : i64
    %4 = mir.add.i64 %5, %6
    mir.ret %4
  }
  func @namespaces.sum_three(local0: i64, local1: i64, local2: i64) -> i64 {
  entry:
    %8 = mir.param local0 : i64
    %9 = mir.param local1 : i64
    %10 = mir.param local2 : i64
    %5 = mir.call @namespaces.add(%8, %9)
    %7 = mir.call @namespaces.add(%5, %10)
    mir.ret %7
  }
  func @namespaces.main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mov_imm 3 : i64
    %3 = mir.call @namespaces.sum_three(%0, %1, %2)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %6 = mir.global_addr @__panic_msg_2
    %7 = mir.call @mrt_panic(%6)
  __range_ok_2:
    mir.ret %3
  }
}
---

// Test: url.parse-scheme-chars
function main() returns ExitCode
	let url = try URL.parse("custom+scheme.v2://host/path") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("{host}\n")
	return 0
end 'main'

// Test: url.parse-port
function main() returns ExitCode
	let url = try URL.parse("https://example.com:443/") otherwise 'err'
		return 1
	end 'err'
	let port = try url.port() otherwise 'np'
		return 2
	end 'np'
	print("{port}\n")
	print("{url.path()}\n")
	return 0
end 'main'

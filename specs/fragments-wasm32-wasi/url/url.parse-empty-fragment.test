// Test: url.parse-empty-fragment
function main() returns ExitCode
	let url = try URL.parse("https://example.com/path#") otherwise 'err'
		return 1
	end 'err'
	let frag = try url.fragment() otherwise 'nf'
		return 2
	end 'nf'
	print("fragment='{frag}'\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
fragment=''
/path
```

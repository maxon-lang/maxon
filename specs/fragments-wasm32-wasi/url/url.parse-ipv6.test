// Test: url.parse-ipv6
function main() returns ExitCode
	let url = try URL.parse("http://[::1]:8080/path") otherwise 'err'
		return 1
	end 'err'
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("{host}\n")
	let port = try url.port() otherwise 'np'
		return 3
	end 'np'
	print("{port}\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
[::1]
8080
/path
```

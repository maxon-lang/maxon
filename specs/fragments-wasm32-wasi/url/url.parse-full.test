// Test: url.parse-full
function main() returns ExitCode
	let url = try URL.parse("https://example.com:8080/path?query=value#frag") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("{host}\n")
	let port = try url.port() otherwise 'np'
		return 3
	end 'np'
	print("{port}\n")
	print("{url.path()}\n")
	let query = try url.query() otherwise 'nq'
		return 4
	end 'nq'
	print("{query}\n")
	let frag = try url.fragment() otherwise 'nf'
		return 5
	end 'nf'
	print("{frag}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
https
example.com
8080
/path
query=value
frag
```

// Test: url.resolve-dotdot
function main() returns ExitCode
	let base = try URL.parse("http://a/b/c/d?q") otherwise 'err'
		return 1
	end 'err'
	let resolved = try URL.resolve(base, reference: "../g") otherwise 'err2'
		return 2
	end 'err2'
	print("{resolved.toString()}\n")
	return 0
end 'main'

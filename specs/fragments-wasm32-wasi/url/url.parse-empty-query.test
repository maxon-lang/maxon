// Test: url.parse-empty-query
function main() returns ExitCode
	let url = try URL.parse("https://example.com/path?") otherwise 'err'
		return 1
	end 'err'
	let query = try url.query() otherwise 'nq'
		return 2
	end 'nq'
	print("query='{query}'\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
query=''
/path

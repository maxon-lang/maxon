// Test: url.parse-file-uri
function main() returns ExitCode
	let url = try URL.parse("file:///home/user/file.txt") otherwise 'err'
		return 1
	end 'err'
	print("{url.scheme()}\n")
	let host = try url.host() otherwise 'nh'
		return 2
	end 'nh'
	print("host='{host}'\n")
	print("{url.path()}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
file
host=''
/home/user/file.txt
```

    %2 = mir.mov_imm 0 : i64
    %3 = mir.cmp ne, %17, %2
    mir.cond_br %3 [then: try_0.otherwise(), else: try_0.merge(%16)]
  try_0.otherwise:
    %5 = mir.mov_imm 77 : i64
    mir.br try_0.merge(%5)
  try_0.merge:
    %18 = mir.mov_imm 255 : i64
    %19 = mir.cmp ugt, %8, %18
    mir.cond_br %19 [then: __range_panic_0(), else: __range_ok_0()]

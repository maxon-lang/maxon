// Test: error.binding-match-multi-case

typealias Integer = int(i64.min to i64.max)

// Test matching on error binding with multiple cases
enum MyError implements Error
	failed
	timeout
	notFound
end 'MyError'

var counter = 0 as Integer

function mayFail(code Integer) returns Integer throws MyError
	counter = counter + 1
	if code == 1 'c1'
		throw MyError.failed
	end 'c1'
	if code == 2 'c2'
		throw MyError.timeout
	end 'c2'
	throw MyError.notFound
end 'mayFail'

function main() returns ExitCode
	var result = 0
	try mayFail(2) otherwise (e) 'handler'
		match e 'check'
			failed then result = 10
			timeout then result = 20
			notFound then result = 30
		end 'check'
	end 'handler'
	return result
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @error-handling.mayFail(local0: i64) -> i64 {
  entry:
    %18 = mir.param local0 : i64
    %1 = mir.global_addr @__data_counter
    %2 = mir.load %1, 0 width: qword
    %3 = mir.mov_imm 1 : i64
    %4 = mir.add.i64 %2, %3
    %5 = mir.global_addr @__data_counter
    mir.store %4, %5, 0 width: qword
    %7 = mir.mov_imm 1 : i64
    %8 = mir.cmp eq, %18, %7
    mir.cond_br %8 [then: c1_0(), else: c1_0.after()]
  c1_0:
    %9 = mir.mov_imm 0 : i64
    %10 = mir.mov_imm 1 : i64
    mir.error_return %9, %10
  c1_0.after:
    %12 = mir.mov_imm 2 : i64
    %13 = mir.cmp eq, %18, %12
    mir.cond_br %13 [then: c2_0(), else: c2_0.after()]
  c2_0:
    %14 = mir.mov_imm 0 : i64
    %15 = mir.mov_imm 2 : i64
    mir.error_return %14, %15
  c2_0.after:
    %16 = mir.mov_imm 0 : i64
    %17 = mir.mov_imm 3 : i64
    mir.error_return %16, %17
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 2 : i64
    %2, %3 = mir.try_call @error-handling.mayFail(%1)
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp ne, %3, %4
    mir.cond_br %5 [then: try_0.otherwise(), else: try_0.merge(%0, %2)]
  try_0.otherwise:
    %7 = mir.mov_imm 1 : i64
    %8 = mir.sub.i64 %3, %7
    %10 = mir.mov_imm 0 : i64
    %11 = mir.cmp eq, %8, %10
    mir.cond_br %11 [then: check_0.case0(), else: check_0.next0()]
  check_0.merge:
    %12 = mir.mov_imm 0 : i64
    mir.br try_0.merge(%22, %12)
  check_0.case0:
    %13 = mir.mov_imm 10 : i64
    mir.br check_0.merge(%13)
  check_0.next0:
    %14 = mir.mov_imm 1 : i64
    %15 = mir.cmp eq, %8, %14
    mir.cond_br %15 [then: check_0.case1(), else: check_0.next1()]
  check_0.case1:
    %16 = mir.mov_imm 20 : i64
    mir.br check_0.merge(%16)
  check_0.next1:
    %17 = mir.mov_imm 2 : i64
    %18 = mir.cmp eq, %8, %17
    mir.cond_br %18 [then: check_0.case2(), else: check_0.merge(%0)]
  check_0.case2:
    %19 = mir.mov_imm 30 : i64
    mir.br check_0.merge(%19)
  try_0.merge:
    %25 = mir.mov_imm 125 : i64
    %26 = mir.cmp ugt, %23, %25
    mir.cond_br %26 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %27 = mir.global_addr @__panic_msg_0
    %28 = mir.call @mrt_panic(%27)
  __range_ok_0:
    mir.ret %23
  }
}
---

    %21 = mir.add.i64 %19, %20
    %22 = mir.global_addr @__data_counter
    mir.store %21, %22, 0 width: qword
    %24 = mir.mov_imm 1 : i64
    mir.br try_0.otherwise()
  try_0.otherwise:
    %6 = mir.mov_imm 1 : i64

    mir.cond_br %16 [then: inlined_error-handling.getBoxValue_1(), else: inlined_error-handling.getBoxValue_2()]
  inlined_error-handling.getBoxValue_1:
    %17 = mir.mov_imm 1 : i64
    %18 = mir.neg.i64 %17
    mir.br inline_cont_main_0(%18)
  inlined_error-handling.getBoxValue_2:
    %19 = mir.load %13, 0 width: qword
    mir.br inline_cont_main_0(%19)
  inline_cont_main_0:
    %3 = mir.mov_imm 7 : i64
    %4 = mir.cmp eq, %20, %3
    mir.cond_br %4 [then: g_0(), else: g_0.after()]
  g_0:
    %5 = mir.mov_imm 1 : i64
    mir.br inlined_error-handling.getBoxValue_0()
  inlined_error-handling.getBoxValue_0:
    %21, %22 = mir.try_call @error-handling.makeBox(%5)
    %23 = mir.mov_imm 0 : i64

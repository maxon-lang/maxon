    mir.cond_br %24 [then: inlined_error-handling.getBoxValue_1(), else: inlined_error-handling.getBoxValue_2()]
  inlined_error-handling.getBoxValue_1:
    %25 = mir.mov_imm 1 : i64
    %26 = mir.neg.i64 %25
    mir.br inline_cont_main_1(%26)
  inlined_error-handling.getBoxValue_2:
    %27 = mir.load %21, 0 width: qword
    mir.br inline_cont_main_1(%27)
  inline_cont_main_1:

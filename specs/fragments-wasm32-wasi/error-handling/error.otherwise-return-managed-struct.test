    %8 = mir.mov_imm 8 : i64
    %9 = mir.call @mrt_alloc(%8)
    mir.store %4, %9, 0 width: qword
    %6 = mir.mov_imm 0 : i64
    mir.error_return %9, %6
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    mir.br inlined_error-handling.getBoxValue_0()
  inlined_error-handling.getBoxValue_0:
    %13, %14 = mir.try_call @error-handling.makeBox(%0)
    %15 = mir.mov_imm 0 : i64

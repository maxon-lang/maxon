// Test: current-directory-is-directory
function main() returns ExitCode
	let cwd = Directory.currentPath()
	if Directory.exists(cwd) 'ok'
		return 42
	end 'ok'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.call @Directory.currentPath()
    %6 = mir.load %1, 0 width: qword
    %7 = mir.load %6, 0 width: qword
    %8 = mir.call @mrt_directory_exists(%7)
    %9 = mir.call @__mm_decref_maybenull_helper(%1)
    mir.cond_br %8 [then: ok_0(), else: ok_0.after()]
  ok_0:
    %4 = mir.mov_imm 42 : i64
    mir.ret %4
  ok_0.after:
    %5 = mir.mov_imm 0 : i64
    mir.ret %5
  }
}
---

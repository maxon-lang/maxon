// Test: current-directory-not-empty
function main() returns ExitCode
	let cwd = Directory.currentPath()
	if cwd.toString().count() > 0 'ok'
		return 42
	end 'ok'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.call @Directory.currentPath()
    %8 = mir.load %0, 0 width: qword
    %3 = mir.call @String.count(%8)
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp gt, %3, %4
    mir.cond_br %5 [then: ok_0(), else: ok_0.after()]
  ok_0:
    %6 = mir.mov_imm 42 : i64
    mir.ret %6
  ok_0.after:
    %7 = mir.mov_imm 0 : i64
    mir.ret %7
  }
}
---

// Test: string-append-implicit-loop
function main() returns ExitCode
	var s = ""
	var i = 0
	while i < 5 'loop'
		s = "{s}{i},"
		i = i + 1
	end 'loop'
	print("{s}\n")
	return 0
end 'main'

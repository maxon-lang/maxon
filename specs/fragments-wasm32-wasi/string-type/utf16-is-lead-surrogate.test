// Test: utf16-is-lead-surrogate
function main() returns ExitCode
	// 0xD83D = 55357 (high surrogate for 😀)
	if utf16IsLeadSurrogate(55357) 'c1'
		print("1\n")
	end 'c1'
	if utf16IsLeadSurrogate(56832) 'c2'
		print("0\n")
	end 'c2'
	if utf16IsLeadSurrogate(65) 'c3'
		print("0\n")
	end 'c3'
	return 0
end 'main'

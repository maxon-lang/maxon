// Test: clone-preserves-original
function main() returns ExitCode
	let a = "TEST STRING"
	var b = a.clone()
	let c = a.clone()
	b = b.toLower()
	print("{a}\n")
	print("{b}\n")
	print("{c}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
TEST STRING
test string
TEST STRING
```

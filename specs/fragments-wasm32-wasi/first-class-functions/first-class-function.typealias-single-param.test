// Test: first-class-function.typealias-single-param

typealias Integer = int(i64.min to i64.max)
typealias UnaryOp = function(Integer) returns Integer

function double(x Integer) returns Integer
	return x * 2
end 'double'

function apply(f UnaryOp, x Integer) returns Integer
	return f(x)
end 'apply'

function main() returns ExitCode
	return apply(double, x: 21)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.func_addr @__fnref_double
    %1 = mir.mov_imm 0 : i64
    %2 = mir.mov_imm 21 : i64
    %5 = mir.indirect_call %0(%2, %1)
    %6 = mir.mov_imm 255 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
}
---

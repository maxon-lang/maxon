// Test: first-class-function.reassign

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function triple(x Integer) returns Integer
	return x * 3
end 'triple'

function main() returns ExitCode
	var f = double
	let a = f(10)
	f = triple
	let b = f(10)
	return a + b
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.func_addr @__fnref_double
    %4 = mir.mov_imm 10 : i64
    %5 = mir.indirect_call %0(%4, %0)
    %6 = mir.func_addr @__fnref_triple
    %10 = mir.mov_imm 10 : i64
    %11 = mir.indirect_call %6(%10, %5)
    %14 = mir.add.i64 %5, %11
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %14, %15
    mir.cond_br %16 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_0
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %14
  }
}
---

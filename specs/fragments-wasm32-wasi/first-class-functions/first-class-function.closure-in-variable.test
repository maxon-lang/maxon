// Test: first-class-function.closure-in-variable

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let f = function(x Integer) gives x * 5
	return f(8)
end 'main'
---
ExitCode: 40
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.func_addr @_$closure_2
    %1 = mir.mov_imm 0 : i64
    %3 = mir.mov_imm 8 : i64
    %4 = mir.indirect_call %0(%3, %1)
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %7 = mir.global_addr @__panic_msg_0
    %8 = mir.call @mrt_panic(%7)
  __range_ok_0:
    mir.ret %4
  }
}
---

// Test: first-class-function.closure-in-variable

typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let f = function(x Integer) gives x * 5
	return f(8)
end 'main'
---
ExitCode: 40
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.func_addr @_$closure_0
    %4 = mir.mov_imm 8 : i64
    %5 = mir.indirect_call %0(%4, %0)
    %6 = mir.mov_imm 255 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
}
---

// Test: first-class-function.let-from-call-returning-fn

typealias Integer = int(i64.min to i64.max)
typealias UnaryOp = function(Integer) returns Integer

function double(x Integer) returns Integer
	return x * 2
end 'double'

function pickDouble() returns UnaryOp
	return double
end 'pickDouble'

function main() returns ExitCode
	let f = pickDouble()
	return f(21)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.func_addr @__fnref_double
    %1 = mir.mov_imm 0 : i64
    %3 = mir.mov_imm 21 : i64
    %4 = mir.indirect_call %5(%3, %1)
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %4, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %4
  }
}

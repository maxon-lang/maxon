// Test: docs-example-1
function main() returns ExitCode
	let x = 42
	let y = -x      // y is -42
	let z = -y      // z is 42
	return z
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @unary-operators.main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %2 = mir.neg.i64 %0
    %4 = mir.neg.i64 %2
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %7 = mir.global_addr @__panic_msg_0
    %8 = mir.call @mrt_panic(%7)
  __range_ok_0:
    mir.ret %4
  }
}
---

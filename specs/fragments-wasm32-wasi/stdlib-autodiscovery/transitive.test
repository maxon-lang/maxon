    %2 = mir.call @Math.pow(%0, %1)
    %4 = mir.mov_imm 4620130267728707584 : f64
    %5 = mir.cmp fgt, %2, %4
    mir.cond_br %5 [then: check_1(), else: check_1.after()]
  check_1:
    %6 = mir.mov_imm 8 : i64
    mir.ret %6
  check_1.after:
    %7 = mir.mov_imm 0 : i64
    mir.ret %7
  }
}

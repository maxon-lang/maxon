// Test: docs-example-4
typealias Score = int(i64.min to i64.max)

function double(x Score) returns Score
	return x * 2
end 'double'

function main() returns ExitCode
	let numbers = [1, 2, 3, 4, 5]
	let doubled = numbers.map(double)
	let val = try doubled.get(2) otherwise 0
	print("{val}\n")
	return 0
end 'main'

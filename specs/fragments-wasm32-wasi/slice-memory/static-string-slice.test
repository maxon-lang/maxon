// Test: static-string-slice
function main() returns ExitCode
	let s = "hello world"
	let start = s.startIndex()
	let idx = try s.findFirst(" ") otherwise s.endIndex()
	let sub = s.slice(start, endIndex: idx)
	print("{sub}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello
```

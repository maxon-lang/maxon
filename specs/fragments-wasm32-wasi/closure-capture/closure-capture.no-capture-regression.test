// Test: closure-capture.no-capture-regression

typealias Integer = int(i64.min to i64.max)

function apply(f (Integer) returns Integer, x Integer) returns Integer
	return f(x)
end 'apply'

function main() returns ExitCode
	let result = apply(f: (n Integer) gives n * 3, x: 10)
	return result
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.func_addr @_$closure_5
    %1 = mir.mov_imm 10 : i64
    %3 = mir.indirect_call %0(%1, %0)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

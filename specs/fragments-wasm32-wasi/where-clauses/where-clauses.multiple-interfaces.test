    %15 = mir.mov_imm 8 : i64
    %16 = mir.load %5, 40 width: qword
    %17 = mir.call @stdlib.__mm_alloc(%15, %16)
    mir.store %14, %17, 0 width: qword
    %10 = mir.load %17, 0 width: qword
    %18 = mir.load %10, 0 width: qword
    %20 = mir.call @mm_drop(%17)
    %21 = mir.mov_imm 125 : i64
    %22 = mir.cmp ugt, %18, %21
    mir.cond_br %22 [then: __range_panic_0(), else: __range_ok_0()]

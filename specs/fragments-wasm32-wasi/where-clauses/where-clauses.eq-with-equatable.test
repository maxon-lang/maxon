// Test: where-clauses.eq-with-equatable
type Box uses T where T is Equatable
		var item T

		static function create(item T) returns Self
			return Self{item: item}
		end 'create'

		export function eq(other T) returns bool
				return item == other
		end 'eq'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
		let b = IntBox.create(item: 42)
		if b.eq(other: 42) 'yes'
				return 1
		end 'yes'
		return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %11 = mir.mov_imm 8 : i64
    %12 = mir.call @mrt_alloc(%11)
    mir.store %0, %12, 0 width: qword
    %5 = mir.mov_imm 42 : i64
    %7 = mir.global_addr @__witness_int_Equatable
    %13 = mir.load %12, 0 width: qword
    %14 = mir.witness_call %7, [0](%13, %5)
    mir.cond_br %14 [then: yes_0(), else: yes_0.after()]
  yes_0:
    %9 = mir.mov_imm 1 : i64
    mir.ret %9
  yes_0.after:
    %10 = mir.mov_imm 0 : i64
    mir.ret %10
  }
}
---

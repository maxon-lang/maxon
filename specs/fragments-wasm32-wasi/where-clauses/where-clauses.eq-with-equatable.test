// Test: where-clauses.eq-with-equatable
type Box uses T where T is Equatable
		var item as T

		static function create(item T) returns Self
			return Self{item: item}
		end 'create'

		export function eq(other T) returns bool
				return item == other
		end 'eq'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
		let b = IntBox.create(42)
		if b.eq(42) 'yes'
				return 1
		end 'yes'
		return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    %2 = mir.global_addr @__layout_Box_Int
    %12 = mir.mov_imm 8 : i64
    %13 = mir.load %2, 40 width: qword
    %14 = mir.call @stdlib.__mm_alloc(%12, %13)
    mir.store %1, %14, 0 width: qword
    %6 = mir.mov_imm 42 : i64
    %8 = mir.global_addr @__witness_int_Equatable
    %15 = mir.load %14, 0 width: qword
    %16 = mir.witness_call %8, [0](%15, %6)
    %17 = mir.call @mm_drop(%14)
    mir.cond_br %16 [then: yes_0(), else: yes_0.after()]
  yes_0:
    %10 = mir.mov_imm 1 : i64
    mir.ret %10
  yes_0.after:
    %11 = mir.mov_imm 0 : i64
    mir.ret %11
  }
}
---

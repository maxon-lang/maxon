// Test: tan.quarter-pi
function main() returns ExitCode
	let quarterPi = 0.785398163
	let result = Math.tan(quarterPi)
	// Should be approximately 1.0
	let diff = abs(result - 1.0)
	if diff < 0.01 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4605249457293724960 : f64
    %2 = mir.call @Math.tan(%0)
    %4 = mir.mov_imm 4607182418800017408 : f64
    %5 = mir.sub.f64 %2, %4
    %6 = mir.abs.f64 %5
    %8 = mir.mov_imm 4576918229304087675 : f64
    %9 = mir.cmp flt, %6, %8
    mir.cond_br %9 [then: check_0(), else: check_0.after()]
  check_0:
    %10 = mir.mov_imm 0 : i64
    mir.ret %10
  check_0.after:
    %11 = mir.mov_imm 1 : i64
    mir.ret %11
  }
}
---

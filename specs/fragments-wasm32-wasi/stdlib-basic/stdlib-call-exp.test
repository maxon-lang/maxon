// Test: stdlib-call-exp
function main() returns ExitCode
	let result = Math.exp(0.0)
	if result == 1.0 'check'
		return 42
	end 'check'
	return 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @stdlib-basic.main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : f64
    %1 = mir.call @Math.exp(%0)
    %3 = mir.mov_imm 4607182418800017408 : f64
    %4 = mir.cmp feq, %1, %3
    mir.cond_br %4 [then: check_1(), else: check_1.after()]
  check_1:
    %5 = mir.mov_imm 42 : i64
    mir.ret %5
  check_1.after:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}
---

// Test: local-alias
typealias Integer = int(i64.min to i64.max)

type Point
	export var x as Integer
	export var y as Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function testAlias()
	let p = Point.create(3, y: 4)
	let q = p
	print("{q.x}\n")
	print("{p.y}\n")
end 'testAlias'

function main() returns ExitCode
	testAlias()
	return 0
end 'main'

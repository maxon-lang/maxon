// Test: directives.not-doubles-back
function main() returns ExitCode
	#if not os(Wasi)
		#if os(Wasi)
			return 99
		#else
			return 10
		#endif
	#else
		#if not os(Wasi)
			return 99
		#else
			return 10
		#endif
	#endif
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    mir.ret %0
  }
}
---

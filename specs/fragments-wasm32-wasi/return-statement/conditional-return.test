// Test: conditional-return
function main() returns ExitCode
	var x = 5
	if x > 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %2 = mir.mov_imm 3 : i64
    %3 = mir.cmp gt, %0, %2
    mir.cond_br %3 [then: check_1(), else: check_1.after()]
  check_1:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  check_1.after:
    %5 = mir.mov_imm 0 : i64
    mir.ret %5
  }
}
---

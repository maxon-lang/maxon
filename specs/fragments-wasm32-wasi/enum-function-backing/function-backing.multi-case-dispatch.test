end 'doubleFn'

function tripleFn(x Integer) returns Integer
	return x * 3
end 'tripleFn'

enum Op
	doubleOp = doubleFn
	tripleOp = tripleFn
end 'Op'

function main() returns ExitCode
	let dFn = Op.doubleOp.rawValue

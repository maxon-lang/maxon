// Test: non-exported-enum-same-file
enum Direction
	up
	down
end 'Direction'

function main() returns ExitCode
	let d = Direction.up
	match d 'check'
		up then return 42
		down then return 0
	end 'check'
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 42 : i64
    mir.ret %4
  }
}
---

    mir.store %0, %9, 0
    mir.store %1, %9, 8
    %4 = mir.load %9, 0
    %6 = mir.load %9, 8
    %7 = mir.add.i64 %4, %6
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %7, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %12 = mir.global_addr @__panic_msg_6
    %13 = mir.call @mrt_panic(%12)
  __range_ok_0:

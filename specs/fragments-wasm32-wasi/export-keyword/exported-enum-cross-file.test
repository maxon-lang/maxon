// Test: exported-enum-cross-file
// --- file: color.maxon
export enum Color
	red
	green
	blue
end 'Color'

// --- file: main.maxon
function main() returns ExitCode
	let c = Color.blue
	match c 'check'
		blue then return 42
		red then return 0
		green then return 0
	end 'check'
end 'main'
---
ExitCode: 42

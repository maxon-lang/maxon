// Test: non-exported-function-same-file

typealias Integer = int(i64.min to i64.max)

function privateHelper() returns Integer
	return 99
end 'privateHelper'

function main() returns ExitCode
	return privateHelper()
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 99 : i64
    mir.ret %1
  }
}
---

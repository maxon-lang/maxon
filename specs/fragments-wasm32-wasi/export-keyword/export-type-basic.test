typealias Integer = int(i64.min to i64.max)

export type Point
	var x as Integer
	var y as Integer

	export function sum() returns Integer
		return x + y
	end 'sum'

	export static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

// --- file: app/main.maxon
function main() returns ExitCode
	let p = Point.create(20, y: 22)
	return p.sum()
end 'main'

// Test: self-method-call-in-closure

typealias Integer = int(i64.min to i64.max)

function apply(f (Integer) returns Integer, x Integer) returns Integer
	return f(x)
end 'apply'

type Doubler
	export var base Integer

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'

	function doubled() returns Integer
		return self.base + self.base
	end 'doubled'

	export function run() returns Integer
		return apply(f: (_ Integer) gives self.doubled(), x: 0)
	end 'run'
end 'Doubler'

function main() returns ExitCode
	let d = Doubler.create(base: 5)
	return d.run()
end 'main'
---
ExitCode: 10
---

// Test: self-method-call-in-closure

typealias Integer = int(i64.min to i64.max)

function apply(f (Integer) returns Integer, x Integer) returns Integer
	return f(x)
end 'apply'

type Doubler
	export var base Integer

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'

	function doubled() returns Integer
		return self.base + self.base
	end 'doubled'

	export function run() returns Integer
		return apply(f: (_ Integer) gives self.doubled(), x: 0)
	end 'run'
end 'Doubler'

function main() returns ExitCode
	let d = Doubler.create(base: 5)
	return d.run()
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @Doubler.run(local0: i64) -> i64 {
  entry:
    %7 = mir.param local0 : i64
    mir.store_slot slot_0, %7
    %1 = mir.func_addr @_$closure_1
    %2 = mir.stack_slot_addr slot_0
    %3 = mir.mov_imm 8 : i64
    %4 = mir.call @mrt_alloc(%3)
    mir.store %2, %4, 0
    %5 = mir.mov_imm 0 : i64
    %8 = mir.indirect_call %1(%5, %4)
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0
    %3 = mir.call @Doubler.run(%5)
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %3, %6
    mir.cond_br %7 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %8 = mir.global_addr @__panic_msg_1
    %9 = mir.call @mrt_panic(%8)
  __range_ok_1:
    mir.ret %3
  }
}
---

    %1 = mir.func_addr @__closure_1
    %2 = mir.stack_slot_addr slot_0
    %3 = mir.mov_imm 8 : i64
    %4 = mir.call @mrt_alloc(%3)
    mir.store %2, %4, 0
    %5 = mir.mov_imm 0 : i64
    %6 = mir.call @closure-self.apply(%1, %4, %5)
    mir.ret %6
  }
  func @closure-self.main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @Doubler.create(%0)

// Test: bare-self-field

typealias Integer = int(i64.min to i64.max)

function apply(f (Integer) returns Integer, x Integer) returns Integer
	return f(x)
end 'apply'

type Holder
	export var value Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'

	export function readViaClosure() returns Integer
		return apply(f: (_ Integer) gives self.value, x: 0)
	end 'readViaClosure'
end 'Holder'

function main() returns ExitCode
	let h = Holder.create(value: 7)
	return h.readViaClosure()
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @Holder.readViaClosure(local0: i64) -> i64 {
  entry:

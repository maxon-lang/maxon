    mir.store_slot slot_0, %7
    %1 = mir.func_addr @_$closure_0
    %2 = mir.stack_slot_addr slot_0
    %3 = mir.mov_imm 8 : i64
    %4 = mir.call @mrt_alloc(%3)
    mir.store %2, %4, 0 width: qword
    %5 = mir.mov_imm 0 : i64
    %8 = mir.indirect_call %1(%5, %4)
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 7 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0 width: qword
    %3 = mir.call @Holder.readViaClosure(%5)
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %3, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %3
  }
}

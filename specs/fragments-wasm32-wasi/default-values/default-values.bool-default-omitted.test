  inlined_choose_1:
    %4 = mir.mov_imm 2 : i64
    %5 = mir.add.i64 %1, %4
    mir.br inline_cont_main_0(%5)
  inline_cont_main_0:
    %7 = mir.mov_imm 255 : i64
    %8 = mir.cmp ugt, %6, %7
    mir.cond_br %8 [then: __range_panic_0(), else: __range_ok_0()]

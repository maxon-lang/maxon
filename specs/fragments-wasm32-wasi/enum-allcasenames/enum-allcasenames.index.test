// Test: enum-allcasenames.index
enum Direction
	north
	south
	east
	west
end 'Direction'

function main() returns ExitCode
	let names = Direction.allCaseNames
	let first = try names.get(0) otherwise "?"
	print("{first}\n")
	return 0
end 'main'

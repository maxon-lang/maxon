// Test: empty-literal-no-defaults-errors

typealias Integer = int(i64.min to i64.max)

type P
	export var x Integer
	export var y Integer

	export static function make() returns Self
		return Self{}
	end 'make'
end 'P'

function main() returns ExitCode
	_ = P.make()
	return 0
end 'main'

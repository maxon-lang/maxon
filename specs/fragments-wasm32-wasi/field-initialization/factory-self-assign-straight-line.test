    mir.store %7, %9, 8 width: qword
    %3 = mir.load %9, 0 width: qword
    %5 = mir.load %9, 8 width: qword
    %6 = mir.add.i64 %3, %5
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %6, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]

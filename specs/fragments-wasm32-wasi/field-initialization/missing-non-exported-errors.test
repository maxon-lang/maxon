// Test: missing-non-exported-errors

typealias Integer = int(i64.min to i64.max)

type Q
	var hidden Integer
	export var shown Integer

	export static function make(s Integer) returns Self
		return Self{shown: s}
	end 'make'
end 'Q'

function main() returns ExitCode
	_ = Q.make(0)
	return 0
end 'main'

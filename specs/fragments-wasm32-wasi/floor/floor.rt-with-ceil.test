// Test: floor.rt-with-ceil
function main() returns ExitCode
	let args = CommandLine.args()
	let x = try float.fromString(try args.get(1) otherwise "") otherwise 0.0
	let a = trunc(floor(x))
	let b = trunc(ceil(x))
	return a + b
end 'main'

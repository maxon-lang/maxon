// Test: var-from-immutable-value-field-ok

typealias Integer = int(i64.min to i64.max)

type Point
	export var x as Integer
	export var y as Integer

	static function create(x Integer, y Integer) returns Self
		return Self{x: x, y: y}
	end 'create'
end 'Point'

function main() returns ExitCode
	let p = Point.create(1, y: 2)
	var x = p.x
	x = 99
	return x
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 1 : i64
    %2 = mir.mov_imm 2 : i64
    %7 = mir.mov_imm 16 : i64
    %8 = mir.mov_imm 0 : i64
    %9 = mir.mov_imm 0 : i64
    %10 = mir.call @stdlib.__mm_alloc(%7, %8, %9)
    mir.store %1, %10, 0 width: qword
    mir.store %2, %10, 8 width: qword
    %5 = mir.load %10, 0 width: qword
    %11 = mir.call @mm_drop(%10)
    %6 = mir.mov_imm 99 : i64
    mir.ret %6
  }
}
---

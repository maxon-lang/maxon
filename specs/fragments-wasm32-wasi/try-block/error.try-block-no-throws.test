// Test: error.try-block-no-throws
function main() returns ExitCode
    try 'work'
        print("hi")
    end 'work'
    otherwise (e) 'h'
        match e 'k'
            default panic("unreachable")
        end 'k'
    end 'h'
    return 0
end 'main'

// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
	var n as Integer
	
	function get() returns Integer
		return n
	end 'get'
	
	function add(other Value) returns Integer
		return n + other.get()
	end 'add'
	
	function multiply(other Value) returns Integer
		return n * other.get()
	end 'multiply'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let a = Value.create(5)
	let b = Value.create(3)
	let c = Value.create(2)
	// a.add(b) = 5 + 3 = 8
	// a.multiply(c) = 5 * 2 = 10
	// total = 8 + 10 = 18
	return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %13 = mir.mov_imm 8 : i64
    %14 = mir.call @mrt_alloc(%13)
    mir.store %0, %14, 0 width: qword
    %2 = mir.mov_imm 3 : i64
    %15 = mir.mov_imm 8 : i64
    %16 = mir.call @mrt_alloc(%15)
    mir.store %2, %16, 0 width: qword
    %4 = mir.mov_imm 2 : i64
    %17 = mir.mov_imm 8 : i64
    %18 = mir.call @mrt_alloc(%17)
    mir.store %4, %18, 0 width: qword
    %19 = mir.load %14, 0 width: qword
    %20 = mir.load %16, 0 width: qword
    %21 = mir.add.i64 %19, %20
    %22 = mir.load %14, 0 width: qword
    %23 = mir.load %18, 0 width: qword
    %24 = mir.mul.i64 %22, %23
    %12 = mir.add.i64 %21, %24
    %25 = mir.mov_imm 125 : i64
    %26 = mir.cmp ugt, %12, %25
    mir.cond_br %26 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %27 = mir.global_addr @__panic_msg_0
    %28 = mir.call @mrt_panic(%27)
  __range_ok_0:
    mir.ret %12
  }
}
---

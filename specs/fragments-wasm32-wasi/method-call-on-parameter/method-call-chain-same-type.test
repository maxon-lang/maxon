// Test: method-call-chain-same-type

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer
	
	function get() returns Integer
		return n
	end 'get'
	
	function add(other Value) returns Integer
		return n + other.get()
	end 'add'
	
	function multiply(other Value) returns Integer
		return n * other.get()
	end 'multiply'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let a = Value.create(n: 5)
	let b = Value.create(n: 3)
	let c = Value.create(n: 2)
	// a.add(b) = 5 + 3 = 8
	// a.multiply(c) = 5 * 2 = 10
	// total = 8 + 10 = 18
	return a.add(b) + a.multiply(c)
end 'main'
---
ExitCode: 18
---
// CompiledIR
module {
  func @Value.get(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0
    mir.ret %1
  }
  func @Value.add(local0: i64, local1: i64) -> i64 {
  entry:
    %7 = mir.param local0 : i64
    %8 = mir.param local1 : i64
    %2 = mir.load %7, 0
    %5 = mir.call @Value.get(%8)
    %6 = mir.add.i64 %2, %5
    mir.ret %6
  }
  func @Value.multiply(local0: i64, local1: i64) -> i64 {
  entry:
    %7 = mir.param local0 : i64
    %8 = mir.param local1 : i64
    %2 = mir.load %7, 0
    %5 = mir.call @Value.get(%8)
    %6 = mir.mul.i64 %2, %5
    mir.ret %6
  }
  func @Value.create(local0: i64) -> i64 {
  entry:
    %4 = mir.param local0 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @mrt_alloc(%1)
    mir.store %4, %2, 0
    mir.ret %2
  }
  func @method-call-on-parameter.main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @Value.create(%0)
    %2 = mir.mov_imm 3 : i64
    %3 = mir.call @Value.create(%2)
    %4 = mir.mov_imm 2 : i64
    %5 = mir.call @Value.create(%4)
    %8 = mir.call @Value.add(%1, %3)
    %11 = mir.call @Value.multiply(%1, %5)
    %12 = mir.add.i64 %8, %11
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %12, %13
    mir.cond_br %14 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %15 = mir.global_addr @__panic_msg_1
    %16 = mir.call @mrt_panic(%15)
  __range_ok_1:
    mir.ret %12
  }
}

  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 5 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @stdlib.__mm_alloc(%5, %6, %7)
    mir.store %1, %8, 0 width: qword
    %9 = mir.load %8, 0 width: qword
    %10 = mir.mov_imm 2 : i64
    %11 = mir.mul.i64 %9, %10
    %14 = mir.call @mm_drop(%8)
    %12 = mir.mov_imm 2 : i64
    %13 = mir.mul.i64 %11, %12
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %13, %15
    mir.cond_br %16 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_89afa683f1ac0a51
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %13
  }
}

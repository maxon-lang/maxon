// Test: sibling-method-call-still-works

typealias Integer = int(i64.min to i64.max)

type Calculator
	var base as Integer
	
	function double() returns Integer
		return base * 2
	end 'double'
	
	function quadruple() returns Integer
		// Sibling call - calls self.double()
		return double() * 2
	end 'quadruple'

	static function create(base Integer) returns Self
		return Self{base: base}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	let calc = Calculator.create(5)
	return calc.quadruple()
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 5 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @stdlib.__mm_alloc(%5, %6)
    mir.store %1, %7, 0 width: qword
    %8 = mir.load %7, 0 width: qword
    %9 = mir.mov_imm 2 : i64
    %10 = mir.mul.i64 %8, %9
    %13 = mir.call @mm_drop(%7)
    %11 = mir.mov_imm 2 : i64
    %12 = mir.mul.i64 %10, %11
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %12, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_89afa683f1ac0a51
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %12
  }
}

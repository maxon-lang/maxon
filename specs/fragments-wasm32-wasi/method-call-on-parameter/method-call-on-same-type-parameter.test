// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
	var x Integer
	
	function bar() returns Integer
		return x
	end 'bar'
	
	function callBarOn(other Foo) returns Integer
		return other.bar()
	end 'callBarOn'

	static function create(x Integer) returns Self
		return Self{x: x}
	end 'create'
end 'Foo'

function main() returns ExitCode
	let f1 = Foo.create(x: 10)
	let f2 = Foo.create(x: 42)
	return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Foo.bar(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0
    mir.ret %1
  }
  func @Foo.callBarOn(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local1 : i64
    %3 = mir.call @Foo.bar(%5)
    mir.ret %3
  }
  func @Foo.create(local0: i64) -> i64 {
  entry:
    %4 = mir.param local0 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @mrt_alloc(%1)
    mir.store %4, %2, 0
    mir.ret %2
  }
  func @method-call-on-parameter.main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.call @Foo.create(%0)
    %2 = mir.mov_imm 42 : i64
    %3 = mir.call @Foo.create(%2)
    %6 = mir.call @Foo.callBarOn(%1, %3)
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %6, %7
    mir.cond_br %8 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %9 = mir.global_addr @__panic_msg_0
    %10 = mir.call @mrt_panic(%9)
  __range_ok_0:
    mir.ret %6
  }
}
---

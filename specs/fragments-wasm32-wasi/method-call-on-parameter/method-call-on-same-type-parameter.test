    %14 = mir.mov_imm 0 : i64
    %15 = mir.mov_imm 0 : i64
    %16 = mir.call @stdlib.__mm_alloc(%13, %14, %15)
    mir.store %4, %16, 0 width: qword
    %17 = mir.load %16, 0 width: qword
    %19 = mir.call @mm_drop(%16)
    %20 = mir.mov_imm 125 : i64
    %21 = mir.cmp ugt, %17, %20
    mir.cond_br %21 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:

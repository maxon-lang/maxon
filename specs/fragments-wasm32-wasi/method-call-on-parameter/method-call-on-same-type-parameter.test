// Test: method-call-on-same-type-parameter

typealias Integer = int(i64.min to i64.max)

type Foo
	var x as Integer
	
	function bar() returns Integer
		return x
	end 'bar'
	
	function callBarOn(other Foo) returns Integer
		return other.bar()
	end 'callBarOn'

	static function create(x Integer) returns Self
		return Self{x: x}
	end 'create'
end 'Foo'

function main() returns ExitCode
	let f1 = Foo.create(10)
	let f2 = Foo.create(42)
	return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %7 = mir.mov_imm 8 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %0, %8, 0 width: qword
    %2 = mir.mov_imm 42 : i64
    %9 = mir.mov_imm 8 : i64
    %10 = mir.call @mrt_alloc(%9)
    mir.store %2, %10, 0 width: qword
    %11 = mir.load %10, 0 width: qword
    %12 = mir.mov_imm 255 : i64
    %13 = mir.cmp ugt, %11, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %14 = mir.global_addr @__panic_msg_0
    %15 = mir.call @mrt_panic(%14)
  __range_ok_0:
    mir.ret %11
  }
}
---

// Test: async-await.trace-yield
typealias Integer = int(i64.min to i64.max)

function ioTask() returns Integer
		_ = File.exists(FilePath from "noyield.txt")
		return 42
end 'ioTask'

function main() returns ExitCode
		let p = async ioTask()
		let r = await p
		return r
end 'main'

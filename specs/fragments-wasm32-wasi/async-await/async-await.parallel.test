		return 10
end 'taskA'

function taskB() returns Integer
		_ = File.exists(FilePath from "noyield.txt")
		return 20
end 'taskB'

function main() returns ExitCode
		let p1 = async taskA()
		let p2 = async taskB()
		let r1 = await p1
		let r2 = await p2
		return r1 + r2
end 'main'

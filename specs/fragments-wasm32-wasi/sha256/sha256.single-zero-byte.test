// Test: sha256.single-zero-byte
function main() returns ExitCode
	var data = ByteArray.create()
	data.push(0)
	let hash = sha256(data)
	// SHA-256(0x00) = 6e340b9c...
	// first byte = 0x6e = 110
	let b0 = try hash.get(0) otherwise 0
	print("{b0}\n")
	return 0
end 'main'

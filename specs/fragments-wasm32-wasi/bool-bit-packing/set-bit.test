// Test: set-bit
typealias BoolArray = Array with bool

function main() returns ExitCode
	var arr = BoolArray.create()
	arr.push(false)
	arr.push(false)
	arr.push(false)
	try arr.set(1, value: true) otherwise panic("test invariant: set OOB")
	let v = try arr.get(1) otherwise false
	if v 'check'
		return 1
	end 'check'
	return 0
end 'main'

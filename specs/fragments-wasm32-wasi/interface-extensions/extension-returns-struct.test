    %17 = mir.mov_imm 16 : i64
    %18 = mir.call @mrt_alloc(%17)
    mir.store %15, %18, 0 width: qword
    mir.store %16, %18, 8 width: qword
    %6 = mir.load %18, 0 width: qword
    %8 = mir.load %18, 8 width: qword
    %9 = mir.add.i64 %6, %8
    %19 = mir.mov_imm 125 : i64
    %20 = mir.cmp ugt, %9, %19

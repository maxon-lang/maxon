    %9 = mir.mov_imm 2 : i64
    %10 = mir.mul.i64 %11, %9
    %12 = mir.call @mm_drop(%7)
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %10, %13

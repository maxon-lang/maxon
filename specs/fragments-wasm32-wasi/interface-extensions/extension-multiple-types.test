    mir.store %2, %12, 0 width: qword
    %19 = mir.load %10, 0 width: qword
    %14 = mir.mov_imm 10 : i64
    %15 = mir.add.i64 %19, %14
    %20 = mir.load %12, 0 width: qword
    %21 = mir.mov_imm 2 : i64
    %22 = mir.mul.i64 %20, %21
    %17 = mir.mov_imm 10 : i64
    %18 = mir.add.i64 %22, %17
    %8 = mir.add.i64 %15, %18
    %23 = mir.mov_imm 125 : i64
    %24 = mir.cmp ugt, %8, %23
    mir.cond_br %24 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %25 = mir.global_addr @__panic_msg_0
    %26 = mir.call @mrt_panic(%25)

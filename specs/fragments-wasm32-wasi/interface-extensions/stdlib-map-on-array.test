// Test: stdlib-map-on-array
typealias Integer = int(i64.min to i64.max)

function main() returns ExitCode
	let nums = [1, 2, 3, 4, 5]
	let doubled = nums.map(function(x Integer) gives x * 2)

	var sum = 0
	for n in doubled 'loop'
		sum = sum + n
	end 'loop'

	// 2 + 4 + 6 + 8 + 10 = 30
	return sum
end 'main'

    %3 = mir.mov_imm 6 : i64
    %9 = mir.load %6, 0 width: qword
    %8 = mir.mul.i64 %9, %3
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %8, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]

// Test: basic-extension-on-array

typealias Integer = int(i64.min to i64.max)

interface Countable
	function value() returns Integer
end 'Countable'

extension Countable
	function count() returns Integer
		return 42
	end 'count'
end 'Countable'

type IntList implements Countable
	let data as Integer

	function value() returns Integer
		return data
	end 'value'

	static function create(data Integer) returns Self
		return Self{data: data}
	end 'create'
end 'IntList'

function main() returns ExitCode
	let list = IntList.create(5)
	return list.count()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 5 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @stdlib.__mm_alloc(%5, %6)
    mir.store %1, %7, 0 width: qword
    %9 = mir.call @mm_drop(%7)
    %8 = mir.mov_imm 42 : i64
    mir.ret %8
  }
}
---

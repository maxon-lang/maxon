// Test: try-otherwise-value-flow.propagation-success
enum E
	bad
end 'E'

function double(x ExitCode) returns ExitCode throws E
	return x * 2
end 'double'

function wrap() returns ExitCode throws E
	let v = try double(5)
	return v
end 'wrap'

function main() returns ExitCode
	let v = try wrap() otherwise 99
	return v
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @double(local0: u8) -> u8 {
  entry:
    %5 = mir.param local0 : u8
    %2 = mir.mov_imm 2 : i64
    %3 = mir.mul.i64 %5, %2
    %4 = mir.mov_imm 0 : i64
    mir.error_return %3, %4
  }
  func @wrap() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1, %2 = mir.try_call @double(%0)
    %3 = mir.mov_imm 0 : i64
    %4 = mir.cmp ne, %2, %3
    mir.cond_br %4 [then: try_1.err(), else: try_1.cont()]
  try_1.err:
    %5 = mir.mov_imm 0 : i64
    mir.error_return %5, %2
  try_1.cont:
    %7 = mir.mov_imm 0 : i64
    mir.error_return %1, %7
  }
  func @main() -> u8 {
  entry:
    %0, %1 = mir.try_call @wrap()
    %2 = mir.mov_imm 0 : i64
    %3 = mir.cmp ne, %1, %2
    mir.cond_br %3 [then: try_1.otherwise(), else: try_1.merge(%0)]
  try_1.otherwise:
    %5 = mir.mov_imm 99 : i64
    mir.br try_1.merge(%5)
  try_1.merge:
    %9 = mir.mov_imm 125 : i64
    %10 = mir.cmp ugt, %8, %9
    mir.cond_br %10 [then: __range_panic_3(), else: __range_ok_3()]
  __range_panic_3:
    %11 = mir.global_addr @__panic_msg_3
    %12 = mir.call @mrt_panic(%11)
  __range_ok_3:
    mir.ret %8
  }
}
---

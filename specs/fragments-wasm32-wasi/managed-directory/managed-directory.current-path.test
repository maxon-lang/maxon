  try_0.otherwise:
    %8 = mir.mov_imm 1 : i64
    mir.ret %8
  try_0.merge:
    %11 = mir.call @String.init(%3)
    %13 = mir.call @String.count(%11)
    %17 = mir.call @__mm_decref_maybenull_helper(%11)
    %15 = mir.cmp gt, %13, %0
    mir.cond_br %15 [then: hasPath_0(), else: hasPath_0.after()]
  hasPath_0:
    %16 = mir.mov_imm 42 : i64
    mir.ret %16
  hasPath_0.after:
    mir.ret %0
  }
}

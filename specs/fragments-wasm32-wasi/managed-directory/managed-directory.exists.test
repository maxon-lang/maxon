// Test: managed-directory.exists
function main() returns ExitCode
	let cwd = try __ManagedDirectory.currentPath() otherwise return 1
	let cwdStr = String.init(cwd)
	let exists = __ManagedDirectory.exists(cwdStr.managed)
	if exists 'check'
		return 42
	end 'check'
	return 1
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3, %4 = mir.try_call @mrt_directory_current_path()
    %5 = mir.mov_imm 0 : i64
    %6 = mir.cmp ne, %4, %5
    mir.cond_br %6 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:
    %8 = mir.mov_imm 1 : i64
    mir.ret %8
  try_0.merge:
    %11 = mir.call @String.init(%3)
    %13 = mir.load %11, 0 width: qword
    %14 = mir.call @mrt_directory_exists(%13)
    %18 = mir.call @__mm_decref_maybenull_helper(%11)
    mir.cond_br %14 [then: check_0(), else: check_0.after()]
  check_0:
    %16 = mir.mov_imm 42 : i64
    mir.ret %16
  check_0.after:
    %17 = mir.mov_imm 1 : i64
    mir.ret %17
  }
}
---

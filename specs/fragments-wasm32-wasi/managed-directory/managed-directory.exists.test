// Test: managed-directory.exists
function main() returns ExitCode
	let cwd = try __ManagedDirectory.currentPath() otherwise return 1
	let cwdStr = String.init(cwd)
	let exists = __ManagedDirectory.exists(cwdStr.managed)
	if exists 'check'
		return 42
	end 'check'
	return 1
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0, %1 = mir.try_call @mrt_directory_current_path()
    %2 = mir.mov_imm 0 : i64
    %3 = mir.cmp ne, %1, %2
    mir.cond_br %3 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  try_0.merge:
    %8 = mir.call @String.init(%0)
    %10 = mir.load %8, 0 width: qword
    %11 = mir.call @mrt_directory_exists(%10)
    mir.cond_br %11 [then: check_0(), else: check_0.after()]
  check_0:
    %13 = mir.mov_imm 42 : i64
    mir.ret %13
  check_0.after:
    %14 = mir.mov_imm 1 : i64
    mir.ret %14
  }
}
---

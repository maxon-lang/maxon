// Test: self-implicit-multiple-fields

typealias Integer = int(i64.min to i64.max)

type Rectangle
	var width Integer
	var height Integer

	function area() returns Integer
		return width * height
	end 'area'

	static function create(width Integer, height Integer) returns Self
		return Self{width: width, height: height}
	end 'create'
end 'Rectangle'

function main() returns ExitCode
	let r = Rectangle.create(width: 6, height: 7)
	return r.area()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 6 : i64
    %1 = mir.mov_imm 7 : i64
    %5 = mir.mov_imm 16 : i64
    %6 = mir.call @mrt_alloc(%5)
    mir.store %0, %6, 0 width: qword
    mir.store %1, %6, 8 width: qword
    %7 = mir.load %6, 0 width: qword
    %8 = mir.load %6, 8 width: qword
    %9 = mir.mul.i64 %7, %8
    %10 = mir.mov_imm 255 : i64
    %11 = mir.cmp ugt, %9, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %12 = mir.global_addr @__panic_msg_0
    %13 = mir.call @mrt_panic(%12)
  __range_ok_0:
    mir.ret %9
  }
}
---

// Test: self-explicit-access

typealias Integer = int(i64.min to i64.max)

type Counter
	var count Integer

	function increment()
		self.count = self.count + 1
	end 'increment'

	function get() returns Integer
		return self.count
	end 'get'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(0)
	c.increment()
	c.increment()
	return c.get()
end 'main'
---
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %8 = mir.mov_imm 8 : i64
    %9 = mir.call @mrt_alloc(%8)
    mir.store %0, %9, 0 width: qword
    %10 = mir.load %9, 0 width: qword
    %11 = mir.mov_imm 1 : i64
    %12 = mir.add.i64 %10, %11
    mir.store %12, %9, 0 width: qword
    %13 = mir.load %9, 0 width: qword
    %14 = mir.mov_imm 1 : i64
    %15 = mir.add.i64 %13, %14
    mir.store %15, %9, 0 width: qword
    %16 = mir.load %9, 0 width: qword
    %17 = mir.mov_imm 255 : i64
    %18 = mir.cmp ugt, %16, %17
    mir.cond_br %18 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %19 = mir.global_addr @__panic_msg_0
    %20 = mir.call @mrt_panic(%19)
  __range_ok_0:
    mir.ret %16
  }
}
---

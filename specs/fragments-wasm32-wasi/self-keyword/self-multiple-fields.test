  func @self-keyword.main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 32 : i64
    %5 = mir.mov_imm 16 : i64
    %6 = mir.call @mrt_alloc(%5)
    mir.store %0, %6, 0
    mir.store %1, %6, 8
    %7 = mir.load %6, 0
    %8 = mir.load %6, 8
    %9 = mir.add.i64 %7, %8
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %9, %10
    mir.cond_br %11 [then: __range_panic_3(), else: __range_ok_3()]
  __range_panic_3:
    %12 = mir.global_addr @__panic_msg_3
    %13 = mir.call @mrt_panic(%12)
  __range_ok_3:
    mir.ret %9
  }
}

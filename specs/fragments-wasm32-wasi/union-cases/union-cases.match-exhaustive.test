    %12 = mir.call @mrt_panic(%11)
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 1 : i64
    %2 = mir.mov_imm 2 : i64
    %4 = mir.call @describe(%0)
    %6 = mir.call @describe(%1)
    %7 = mir.add.i64 %4, %6
    %9 = mir.call @describe(%2)
    %10 = mir.add.i64 %7, %9
    %12 = mir.mov_imm 600 : i64
    %13 = mir.cmp eq, %10, %12
    mir.cond_br %13 [then: check_0(), else: check_0.after()]

    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp eq, %14, %8
    mir.cond_br %9 [then: tag_0.case2(), else: tag_0.next2()]
  tag_0.case2:
    %10 = mir.mov_imm 300 : i64
    mir.ret %10

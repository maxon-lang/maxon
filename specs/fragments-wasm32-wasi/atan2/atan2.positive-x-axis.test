// Test: atan2.positive-x-axis
function main() returns ExitCode
	let angle = Math.atan2(0.0, x: 1.0)
	if angle == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : f64
    %1 = mir.mov_imm 4607182418800017408 : f64
    %2 = mir.call @Math.atan2(%0, %1)
    %4 = mir.mov_imm 0 : f64
    %5 = mir.cmp feq, %2, %4
    mir.cond_br %5 [then: check_0(), else: check_0.after()]
  check_0:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  check_0.after:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  }
}

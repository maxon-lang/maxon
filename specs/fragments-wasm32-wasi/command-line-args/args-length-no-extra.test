// Test: args-length-no-extra
function main() returns ExitCode
	// Without extra args, count should be 1 (just argv[0])
	let args = CommandLine.args()
	return args.count()
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.call @CommandLine.args()
    %2 = mir.global_addr @__layout_Array_String
    %3 = mir.call @Array.count(%0, %2)
    %4 = mir.mov_imm 255 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

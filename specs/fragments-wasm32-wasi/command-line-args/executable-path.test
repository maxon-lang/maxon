// Test: executable-path
function main() returns ExitCode
	let exe = try Process.executablePath() otherwise return 2
	// Just verify it returns something (the actual path varies)
	if exe.path.byteLength() > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %14 = mir.call @mrt_executable_path()
    %15 = mir.mov_imm 8 : i64
    %16 = mir.call @mrt_alloc(%15)
    %17 = mir.call @String.init(%14)
    mir.store %17, %16, 0 width: qword
    mir.br try_0.merge()
  try_0.merge:
    %8 = mir.load %16, 0 width: qword
    %9 = mir.call @String.byteLength(%8)
    %10 = mir.mov_imm 0 : i64
    %11 = mir.cmp gt, %9, %10
    mir.cond_br %11 [then: check_0(), else: check_0.after()]
  check_0:
    %12 = mir.mov_imm 0 : i64
    mir.ret %12
  check_0.after:
    %13 = mir.mov_imm 1 : i64
    mir.ret %13
  }
}
---

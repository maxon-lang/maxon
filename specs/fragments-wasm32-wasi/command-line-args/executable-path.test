// Test: executable-path
function main() returns ExitCode
	let exe = try Process.executablePath() otherwise return 2
	// Just verify it returns something (the actual path varies)
	if exe.path.byteLength() > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0, %1 = mir.try_call @Process.executablePath()
    %2 = mir.mov_imm 0 : i64
    %3 = mir.cmp ne, %1, %2
    mir.cond_br %3 [then: try_0.otherwise(), else: try_0.merge()]
  try_0.otherwise:
    %5 = mir.mov_imm 2 : i64
    mir.ret %5
  try_0.merge:
    %8 = mir.load %0, 0 width: qword
    %9 = mir.call @String.byteLength(%8)
    %10 = mir.mov_imm 0 : i64
    %11 = mir.cmp gt, %9, %10
    mir.cond_br %11 [then: check_0(), else: check_0.after()]
  check_0:
    %12 = mir.mov_imm 0 : i64
    mir.ret %12
  check_0.after:
    %13 = mir.mov_imm 1 : i64
    mir.ret %13
  }
}
---

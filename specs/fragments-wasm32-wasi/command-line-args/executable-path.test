// Test: executable-path
function main() returns ExitCode
	let exe = Process.executablePath()
	// Just verify it returns something (the actual path varies)
	if exe.path.byteLength() > 0 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %8 = mir.call @mrt_executable_path()
    %9 = mir.mov_imm 8 : i64
    %10 = mir.call @mrt_alloc(%9)
    %11 = mir.call @String.init(%8)
    mir.store %11, %10, 0 width: qword
    %2 = mir.load %10, 0 width: qword
    %3 = mir.call @String.byteLength(%2)
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp gt, %3, %4
    mir.cond_br %5 [then: check_0(), else: check_0.after()]
  check_0:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  check_0.after:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  }
}
---

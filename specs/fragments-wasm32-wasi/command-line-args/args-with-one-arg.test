// Test: args-with-one-arg
function main() returns ExitCode
	let args = CommandLine.args()
	return args.count()
end 'main'
---
Args: hello
ExitCode: 2
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.call @CommandLine.args()
    %2 = mir.global_addr @__layout_Set_Character
    %3 = mir.call @Array.count(%0, %2)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

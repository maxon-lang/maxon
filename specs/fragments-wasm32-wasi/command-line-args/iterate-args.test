// Test: iterate-args
function main() returns ExitCode
	// Skip argv[0] and print the rest
	let args = CommandLine.args()
	var i = 1
	while i < args.count() 'loop'
		let arg = try args.get(i) otherwise ""
		print(arg)
		print("\n")
		i = i + 1
	end 'loop'
	return 0
end 'main'

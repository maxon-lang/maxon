// Test: numeric-args
function main() returns ExitCode
	let args = CommandLine.args()
	// Args include argv[0], so count == 2 with one user arg
	if args.count() == 2 'check'
		let arg = try args.get(1) otherwise ""
		print(arg)
		return 0
	end 'check'
	return 1
end 'main'

    mir.cond_br %5 [then: loop_0(), else: loop_0.exit()]
  loop_0:
    %7 = mir.mov_imm 2 : i64
    %8 = mir.rem.i64 %20, %7
    %9 = mir.mov_imm 0 : i64
    %10 = mir.cmp eq, %8, %9
    mir.cond_br %10 [then: loop_0.step(%19), else: skip_0.after()]
  loop_0.step:
    %12 = mir.mov_imm 1 : i64
    %13 = mir.add.i64 %20, %12
    mir.br loop_0.header(%18, %13)
  loop_0.exit:
    %21 = mir.mov_imm 125 : i64
    %22 = mir.cmp ugt, %19, %21
    mir.cond_br %22 [then: __range_panic_0(), else: __range_ok_0()]
  skip_0.after:
    %17 = mir.add.i64 %19, %20
    mir.br loop_0.step(%17)
  __range_panic_0:

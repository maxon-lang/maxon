// Test: impure-function-let-discard

typealias Integer = int(i64.min to i64.max)

var counter = 0 as Integer

function incrementAndGet() returns Integer
	counter = counter + 1
	return counter
end 'incrementAndGet'

function main() returns ExitCode
	_ = incrementAndGet()
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %2 = mir.global_addr @__data_counter
    %3 = mir.load %2, 0 width: qword
    %4 = mir.mov_imm 1 : i64
    %5 = mir.add.i64 %3, %4
    %6 = mir.global_addr @__data_counter
    mir.store %5, %6, 0 width: qword
    %7 = mir.global_addr @__data_counter
    %8 = mir.load %7, 0 width: qword
    %1 = mir.mov_imm 0 : i64
    mir.ret %1
  }
}
---

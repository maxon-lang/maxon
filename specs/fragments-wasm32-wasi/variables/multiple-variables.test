// Test: multiple-variables
function main() returns ExitCode
	let a = 10
	let b = 20
	return a + b
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @variables.main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 20 : i64
    %4 = mir.mov_imm 30 : i64
    mir.ret %4
  }
}
---

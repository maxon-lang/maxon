// Test: clone-isolates-string-mutation
function main() returns ExitCode
	let original = "HELLO"
	var copy = original.clone()
	copy = copy.toLower()
	print("{original}\n")
	print("{copy}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
HELLO
hello
```

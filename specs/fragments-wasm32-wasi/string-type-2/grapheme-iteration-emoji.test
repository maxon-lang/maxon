// Test: grapheme-iteration-emoji
function main() returns ExitCode
	let s = "a🎉b"
	var count = 0
	for c in s 'loop'
		print("{c}")  // Use c to avoid unused warning
		count = count + 1
	end 'loop'
	print("\n{count}\n")
	return 0
end 'main'

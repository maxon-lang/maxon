// Test: string-double-iteration
function main() returns ExitCode
	let s = "Hello"
	var count1 = 0
	for _ in s 'loop1'
		count1 = count1 + 1
	end 'loop1'
	var count2 = 0
	for _ in s 'loop2'
		count2 = count2 + 1
	end 'loop2'
	if count1 == 5 and count2 == 5 'ok'
		return 0
	end 'ok'
	return 1
end 'main'

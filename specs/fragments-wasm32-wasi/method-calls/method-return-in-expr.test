// Test: method-return-in-expr

typealias Integer = int(i64.min to i64.max)

type Box
	var value Integer

	function getValue() returns Integer
		return value
	end 'getValue'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Box'

function main() returns ExitCode
	let b = Box.create(value: 40)
	return b.getValue() + 2
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Box.getValue(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0
    mir.ret %1
  }
  func @Box.create(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %0 = mir.mov_imm 8 : i64
    %1 = mir.call @mrt_alloc(%0)
    mir.store %3, %1, 0
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 40 : i64
    %1 = mir.call @Box.create(%0)
    %3 = mir.call @Box.getValue(%1)
    %4 = mir.mov_imm 2 : i64
    %5 = mir.add.i64 %3, %4
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
}
---

    mir.store %14, %10, 8
    %15 = mir.load %10, 0
    %16 = mir.load %10, 8
    %17 = mir.add.i64 %15, %16
    %18 = mir.mov_imm 125 : i64
    %19 = mir.cmp ugt, %17, %18

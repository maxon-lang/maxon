// Test: static-method-named-args

typealias Integer = int(i64.min to i64.max)

type Factory
	static function create(x Integer, y Integer) returns Integer
		return x * 10 + y
	end 'create'
end 'Factory'

function main() returns ExitCode
	return Factory.create(4, y: 2)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Factory.create(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    %6 = mir.param local1 : i64
    %1 = mir.mov_imm 10 : i64
    %2 = mir.mul.i64 %5, %1
    %4 = mir.add.i64 %2, %6
    mir.ret %4
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.call @Factory.create(%0, %1)
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %2, %7
    mir.cond_br %8 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %9 = mir.global_addr @__panic_msg_0
    %10 = mir.call @mrt_panic(%9)
  __range_ok_0:
    mir.ret %2
  }
}
---

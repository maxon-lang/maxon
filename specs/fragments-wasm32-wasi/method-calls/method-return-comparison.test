// Test: method-return-comparison

typealias Integer = int(i64.min to i64.max)

type Value
	var n Integer

	function isPositive() returns Integer
		if n > 0 'positive'
			return 1
		end 'positive'
		return 0
	end 'isPositive'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Value'

function main() returns ExitCode
	let v = Value.create(n: 42)
	return v.isPositive()
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0 width: qword
    mir.br inlined_Value.isPositive_0()
  inlined_Value.isPositive_0:
    %6 = mir.load %5, 0 width: qword
    %7 = mir.mov_imm 0 : i64
    %8 = mir.cmp gt, %6, %7
    mir.cond_br %8 [then: inlined_Value.isPositive_1(), else: inlined_Value.isPositive_2()]
  inlined_Value.isPositive_1:
    %9 = mir.mov_imm 1 : i64
    mir.br inline_cont_main_0(%9)
  inlined_Value.isPositive_2:
    %10 = mir.mov_imm 0 : i64
    mir.br inline_cont_main_0(%10)
  inline_cont_main_0:
    %12 = mir.mov_imm 125 : i64
    %13 = mir.cmp ugt, %11, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %14 = mir.global_addr @__panic_msg_0
    %15 = mir.call @mrt_panic(%14)
  __range_ok_0:
    mir.ret %11
  }
}
---

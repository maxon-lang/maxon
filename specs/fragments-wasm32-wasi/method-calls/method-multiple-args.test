// Test: method-multiple-args

typealias Integer = int(i64.min to i64.max)

type Calculator
	var result Integer

	function addTwo(a Integer, b Integer)
		result = result + a + b
	end 'addTwo'

	function get() returns Integer
		return result
	end 'get'

	static function create(result Integer) returns Self
		return Self{result: result}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	var calc = Calculator.create(0)
	calc.addTwo(20, b: 22)
	return calc.get()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %8 = mir.mov_imm 8 : i64
    %9 = mir.call @mrt_alloc(%8)
    mir.store %0, %9, 0 width: qword
    %3 = mir.mov_imm 20 : i64
    %4 = mir.mov_imm 22 : i64
    %10 = mir.load %9, 0 width: qword
    %11 = mir.add.i64 %10, %3
    %12 = mir.add.i64 %11, %4
    mir.store %12, %9, 0 width: qword
    %13 = mir.load %9, 0 width: qword
    %14 = mir.mov_imm 255 : i64
    %15 = mir.cmp ugt, %13, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %13
  }
}
---

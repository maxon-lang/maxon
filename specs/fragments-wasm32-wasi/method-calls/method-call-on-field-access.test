  entry:
    %3 = mir.param local0 : i64
    %0 = mir.mov_imm 8 : i64
    %1 = mir.call @mrt_alloc(%0)
    mir.store %3, %1, 0
    mir.ret %1
  }
  func @Outer.getInnerValue(local0: i64) -> i64 {
  entry:
    %4 = mir.param local0 : i64
    %1 = mir.load %4, 0
    %3 = mir.call @Inner.get(%1)
    mir.ret %3
  }
  func @Outer.create(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %0 = mir.mov_imm 8 : i64
    %1 = mir.call @mrt_alloc(%0)
    mir.store %3, %1, 0
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %1 = mir.call @Inner.create(%0)
    %2 = mir.call @Outer.create(%1)
    %4 = mir.call @Outer.getInnerValue(%2)
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %7 = mir.global_addr @__panic_msg_0
    %8 = mir.call @mrt_panic(%7)
  __range_ok_0:

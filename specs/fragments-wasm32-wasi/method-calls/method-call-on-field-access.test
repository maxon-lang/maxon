module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    %6 = mir.mov_imm 8 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @stdlib.__mm_alloc(%6, %7)
    %14 = mir.call @stdlib.__mm_incref(%8)
    mir.store %1, %8, 0 width: qword
    %9 = mir.mov_imm 8 : i64
    %10 = mir.func_addr @__destruct_Outer
    %11 = mir.call @stdlib.__mm_alloc(%9, %10)
    mir.store %8, %11, 0 width: qword
    %12 = mir.load %11, 0 width: qword
    %13 = mir.load %12, 0 width: qword
    %15 = mir.call @mm_drop(%11)
    %16 = mir.mov_imm 125 : i64
    %17 = mir.cmp ugt, %13, %16
    mir.cond_br %17 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %18 = mir.global_addr @__panic_msg_6eab3ac88269eb79
    %19 = mir.call @mrt_panic(%18)
  __range_ok_0:
    mir.ret %13
  }
}

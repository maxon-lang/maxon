// Test: method-call-on-field-access

typealias Integer = int(i64.min to i64.max)

type Inner
	var value Integer

	function get() returns Integer
		return value
	end 'get'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Inner'

type Outer
	var inner Inner

	function getInnerValue() returns Integer
		return inner.get()
	end 'getInnerValue'

	static function create(inner Inner) returns Self
		return Self{inner: inner}
	end 'create'
end 'Outer'

function main() returns ExitCode
	let o = Outer.create(inner: Inner.create(value: 42))
	return o.getInnerValue()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.call @mrt_alloc(%5)
    mir.store %0, %6, 0
    %7 = mir.mov_imm 8 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %6, %8, 0
    %9 = mir.load %8, 0
    %10 = mir.load %9, 0
    %11 = mir.mov_imm 125 : i64
    %12 = mir.cmp ugt, %10, %11
    mir.cond_br %12 [then: __range_panic_4(), else: __range_ok_4()]
  __range_panic_4:
    %13 = mir.global_addr @__panic_msg_4
    %14 = mir.call @mrt_panic(%13)
  __range_ok_4:
    mir.ret %10
  }
}
---

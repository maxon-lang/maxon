    %18 = mir.mov_imm 125 : i64
    %19 = mir.cmp ugt, %4, %18
    mir.cond_br %19 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %20 = mir.global_addr @__panic_msg_5b074d262f8db1ca

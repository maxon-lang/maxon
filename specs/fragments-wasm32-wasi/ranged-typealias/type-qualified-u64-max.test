// Test: type-qualified-u64-max
typealias BigId = int(0 to u64.max)

function getValue() returns BigId
	return u64.max
end 'getValue'

function main() returns ExitCode
	let v = getValue()
	if v == u64.max 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @getValue() -> u64 {
  entry:
    %0 = mir.mov_imm -1 : i64
    mir.ret %0
  }
  func @main() -> u8 {
  entry:
    %0 = mir.call @getValue()
    %2 = mir.mov_imm -1 : i64
    %3 = mir.cmp eq, %0, %2
    mir.cond_br %3 [then: check_0(), else: check_0.after()]
  check_0:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  check_0.after:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

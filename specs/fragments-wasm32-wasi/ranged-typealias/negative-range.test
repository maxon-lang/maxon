// Test: negative-range
typealias Temp = int(-50 to 50)

function main() returns ExitCode
	let t = -10 as Temp
	return t + 60
end 'main'
---
ExitCode: 50
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.neg.i64 %0
    %3 = mir.mov_imm 60 : i64
    %4 = mir.add.i64 %1, %3
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %7 = mir.global_addr @__panic_msg_1
    %8 = mir.call @mrt_panic(%7)
  __range_ok_0:
    mir.ret %4
  }
}
---

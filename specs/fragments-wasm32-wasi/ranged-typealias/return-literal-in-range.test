// Test: return-literal-in-range
typealias Score = int(0 to 100)

function getScore() returns Score
	return 42
end 'getScore'

function main() returns ExitCode
	return getScore()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @getScore() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    mir.ret %0
  }
  func @main() -> u8 {
  entry:
    %0 = mir.call @getScore()
    %1 = mir.mov_imm 125 : i64
    %2 = mir.cmp ugt, %0, %1
    mir.cond_br %2 [then: __range_panic_7(), else: __range_ok_7()]
  __range_panic_7:
    %3 = mir.global_addr @__panic_msg_8
    %4 = mir.call @mrt_panic(%3)
  __range_ok_7:
    mir.ret %0
  }
}
---

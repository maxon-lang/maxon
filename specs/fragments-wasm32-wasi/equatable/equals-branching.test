    %0 = mir.mov_imm 10 : i64
    %29 = mir.mov_imm 8 : i64
    %30 = mir.call @mrt_alloc(%29)
    mir.store %0, %30, 0 width: qword
    %2 = mir.mov_imm 10 : i64
    %31 = mir.mov_imm 8 : i64
    %32 = mir.call @mrt_alloc(%31)
    mir.store %2, %32, 0 width: qword
    %4 = mir.mov_imm 20 : i64
    %33 = mir.mov_imm 8 : i64
    %34 = mir.call @mrt_alloc(%33)
    mir.store %4, %34, 0 width: qword
    %6 = mir.mov_imm 0 : i64
    %35 = mir.load %30, 0 width: qword
    %36 = mir.load %32, 0 width: qword
    %37 = mir.cmp eq, %35, %36
    mir.cond_br %37 [then: first_0(), else: first_0.after(%6)]
  first_0:
    %11 = mir.mov_imm 1 : i64
    %12 = mir.add.i64 %6, %11
    mir.br first_0.after(%12)
  first_0.after:
    %38 = mir.load %30, 0 width: qword
    %39 = mir.load %34, 0 width: qword
    %40 = mir.cmp eq, %38, %39
    mir.cond_br %40 [then: second_0(), else: second_0.after(%28)]
  second_0:
    %17 = mir.mov_imm 10 : i64
    %18 = mir.add.i64 %28, %17
    mir.br second_0.after(%18)
  second_0.after:
    %41 = mir.load %32, 0 width: qword
    %42 = mir.load %34, 0 width: qword
    %43 = mir.cmp eq, %41, %42
    mir.cond_br %43 [then: third_0(), else: third_0.after(%27)]
  third_0:
    %23 = mir.mov_imm 100 : i64
    %24 = mir.add.i64 %27, %23
    mir.br third_0.after(%24)
  third_0.after:
    %44 = mir.mov_imm 255 : i64
    %45 = mir.cmp ugt, %26, %44
    mir.cond_br %45 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %46 = mir.global_addr @__panic_msg_0
    %47 = mir.call @mrt_panic(%46)
  __range_ok_0:
    mir.ret %26
  }
}

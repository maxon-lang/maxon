    mir.store %3, %20, 0 width: qword
    %5 = mir.mov_imm 5 : i64
    %21 = mir.mov_imm 8 : i64
    %22 = mir.mov_imm 0 : i64
    %23 = mir.call @stdlib.__mm_alloc(%21, %22)
    mir.store %5, %23, 0 width: qword
    %7 = mir.mov_imm 6 : i64
    %24 = mir.mov_imm 8 : i64
    %25 = mir.mov_imm 0 : i64
    %26 = mir.call @stdlib.__mm_alloc(%24, %25)
    mir.store %7, %26, 0 width: qword
    %27 = mir.load %20, 0 width: qword
    %28 = mir.load %23, 0 width: qword
    %29 = mir.cmp eq, %27, %28
    %33 = mir.call @mm_drop(%23)
    mir.cond_br %29 [then: eq_0(), else: eq_0.after()]
  eq_0:
    %30 = mir.load %20, 0 width: qword
    %31 = mir.load %26, 0 width: qword
    %32 = mir.cmp eq, %30, %31
    %35 = mir.call @mm_drop(%26)
    %34 = mir.call @mm_drop(%20)
    mir.cond_br %32 [then: neq_0(), else: neq_0.after()]
  neq_0:
    %15 = mir.mov_imm 1 : i64
    mir.ret %15
  neq_0.after:
    %16 = mir.mov_imm 0 : i64
    mir.ret %16
  eq_0.after:

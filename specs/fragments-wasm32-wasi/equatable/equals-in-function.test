// Test: equals-in-function

typealias Integer = int(i64.min to i64.max)

type Id implements Equatable
	export var n Integer

	function equals(other Id) returns bool
		return n == other.n
	end 'equals'

	static function create(n Integer) returns Self
		return Self{n: n}
	end 'create'
end 'Id'

function areEqual(a Id, b Id) returns bool
	return a.equals(b)
end 'areEqual'

function main() returns ExitCode
	let x = Id.create(n: 5)
	let y = Id.create(n: 5)
	let z = Id.create(n: 6)
	if areEqual(x, b: y) 'eq'
		if areEqual(x, b: z) 'neq'
			return 1
		end 'neq'
		return 0
	end 'eq'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %15 = mir.mov_imm 8 : i64
    %16 = mir.call @mrt_alloc(%15)
    mir.store %0, %16, 0 width: qword
    %2 = mir.mov_imm 5 : i64
    %17 = mir.mov_imm 8 : i64
    %18 = mir.call @mrt_alloc(%17)
    mir.store %2, %18, 0 width: qword
    %4 = mir.mov_imm 6 : i64
    %19 = mir.mov_imm 8 : i64
    %20 = mir.call @mrt_alloc(%19)
    mir.store %4, %20, 0 width: qword
    %21 = mir.load %16, 0 width: qword
    %22 = mir.load %18, 0 width: qword
    %23 = mir.cmp eq, %21, %22
    mir.cond_br %23 [then: eq_0(), else: eq_0.after()]
  eq_0:
    %24 = mir.load %16, 0 width: qword
    %25 = mir.load %20, 0 width: qword
    %26 = mir.cmp eq, %24, %25
    mir.cond_br %26 [then: neq_0(), else: neq_0.after()]
  neq_0:
    %12 = mir.mov_imm 1 : i64
    mir.ret %12
  neq_0.after:
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  eq_0.after:
    %14 = mir.mov_imm 1 : i64
    mir.ret %14
  }
}
---

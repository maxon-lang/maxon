  entry:
    %7 = mir.param local0 : i64
    %8 = mir.param local1 : i64
    %2 = mir.load %7, 0
    %5 = mir.load %8, 0
    %6 = mir.cmp eq, %2, %5
    mir.ret %6
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %15 = mir.mov_imm 8 : i64
    %16 = mir.call @mrt_alloc(%15)
    mir.store %0, %16, 0
    %2 = mir.mov_imm 42 : i64
    %17 = mir.mov_imm 8 : i64
    %18 = mir.call @mrt_alloc(%17)
    mir.store %2, %18, 0
    %4 = mir.mov_imm 99 : i64
    %19 = mir.mov_imm 8 : i64
    %20 = mir.call @mrt_alloc(%19)
    mir.store %4, %20, 0
    %21 = mir.load %16, 0
    %22 = mir.load %18, 0
    %23 = mir.cmp eq, %21, %22
    mir.cond_br %23 [then: eq_1(), else: eq_1.after()]
  eq_1:
    %24 = mir.load %16, 0
    %25 = mir.load %20, 0
    %26 = mir.cmp eq, %24, %25
    mir.cond_br %26 [then: neq_2(), else: neq_2.after()]
  neq_2:
    %12 = mir.mov_imm 1 : i64
    mir.ret %12
  neq_2.after:
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  eq_1.after:
    %14 = mir.mov_imm 1 : i64
    mir.ret %14
  }
}

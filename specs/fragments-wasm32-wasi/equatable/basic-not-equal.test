    %5 = mir.load %16, 0 width: qword
    %6 = mir.cmp eq, %2, %5
    %7 = mir.mov_imm 0 : i64
    mir.cond_br %6 [then: shortAnd.rhs(), else: shortAnd.merge(%7)]
  shortAnd.rhs:
    %8 = mir.load %15, 8 width: qword
    %11 = mir.load %16, 8 width: qword
    %12 = mir.cmp eq, %8, %11
    mir.br shortAnd.merge(%12)
  shortAnd.merge:
    mir.ret %14
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.mov_imm 2 : i64
    %11 = mir.mov_imm 16 : i64
    %12 = mir.call @mrt_alloc(%11)
    mir.store %0, %12, 0 width: qword
    mir.store %1, %12, 8 width: qword
    %3 = mir.mov_imm 3 : i64
    %4 = mir.mov_imm 4 : i64
    %13 = mir.mov_imm 16 : i64
    %14 = mir.call @mrt_alloc(%13)
    mir.store %3, %14, 0 width: qword
    mir.store %4, %14, 8 width: qword
    %8 = mir.call @Point.equals(%12, %14)
    mir.cond_br %8 [then: check_0(), else: check_0.after()]
  check_0:
    %9 = mir.mov_imm 1 : i64
    mir.ret %9
  check_0.after:

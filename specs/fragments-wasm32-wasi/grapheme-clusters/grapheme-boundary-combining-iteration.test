// Test: grapheme-boundary-combining-iteration
function main() returns ExitCode
	let s = "caf\u0065\u0301"  // c, a, f, e+combining accent = 4 graphemes
	var count = 0
	for _ in s 'loop'
		count = count + 1
	end 'loop'
	print("{count}\n")
	return 0
end 'main'

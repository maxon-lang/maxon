// Test: pass-by-reference.let-to-mutating-param-error

typealias Integer = int(i64.min to i64.max)

function setTo99(x Integer)
	x = 99
end 'setTo99'

function main() returns ExitCode
	let n = 5
	setTo99(x: n)
	return 0
end 'main'

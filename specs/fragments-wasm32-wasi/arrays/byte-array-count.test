// Test: byte-array-count

typealias Byte = byte(0 to u8.max)

typealias ByteArray = Array with Byte

function main() returns ExitCode
	var arr = ByteArray.create()
	arr.push(1 as Byte)
	arr.push(2 as Byte)
	arr.push(3 as Byte)
	arr.push(4 as Byte)
	arr.push(5 as Byte)

	return arr.count()
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.call @Array.create(%0)
    %3 = mir.mov_imm 1 : i64
    %4 = mir.mov_imm 0 : i64
    %5 = mir.call @Array.push(%1, %3, %4)
    %7 = mir.mov_imm 2 : i64
    %8 = mir.mov_imm 0 : i64
    %9 = mir.call @Array.push(%1, %7, %8)
    %11 = mir.mov_imm 3 : i64
    %12 = mir.mov_imm 0 : i64
    %13 = mir.call @Array.push(%1, %11, %12)
    %15 = mir.mov_imm 4 : i64
    %16 = mir.mov_imm 0 : i64
    %17 = mir.call @Array.push(%1, %15, %16)
    %19 = mir.mov_imm 5 : i64
    %20 = mir.mov_imm 0 : i64
    %21 = mir.call @Array.push(%1, %19, %20)
    %23 = mir.mov_imm 0 : i64
    %24 = mir.call @Array.count(%1, %23)
    %25 = mir.mov_imm 125 : i64
    %26 = mir.cmp ugt, %24, %25
    mir.cond_br %26 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %27 = mir.global_addr @__panic_msg_0
    %28 = mir.call @mrt_panic(%27)
  __range_ok_0:
    mir.ret %24
  }
}

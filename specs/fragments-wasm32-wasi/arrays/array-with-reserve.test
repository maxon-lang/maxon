// Test: array-with-reserve
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
	var arr = IntArray.create()
	arr.reserve(5)
	arr.push(42)
	return try arr.get(0) otherwise 0
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.call @Array.create(%0)
    %3 = mir.mov_imm 5 : i64
    %4 = mir.mov_imm 0 : i64
    %5 = mir.call @Array.reserve(%1, %3, %4)
    %7 = mir.mov_imm 42 : i64
    %8 = mir.mov_imm 0 : i64
    %9 = mir.call @Array.push(%1, %7, %8)
    %11 = mir.mov_imm 0 : i64
    %12 = mir.mov_imm 0 : i64
    %13 = mir.call @Array.get(%1, %11, %12)
    %14 = mir.call @mrt_get_error_and_clear()
    %15 = mir.mov_imm 0 : i64
    %16 = mir.cmp ne, %14, %15
    mir.cond_br %16 [then: try_1.otherwise(), else: try_1.merge(%13)]
  try_1.otherwise:
    %18 = mir.mov_imm 0 : i64
    mir.br try_1.merge(%18)
  try_1.merge:
    %21 = mir.mov_imm 125 : i64
    %22 = mir.cmp ugt, %20, %21
    mir.cond_br %22 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %23 = mir.global_addr @__panic_msg_0
    %24 = mir.call @mrt_panic(%23)
  __range_ok_0:
    mir.ret %20
  }
}
---

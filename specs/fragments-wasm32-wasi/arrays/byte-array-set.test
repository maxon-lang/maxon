    %4 = mir.mov_imm 0 : i64
    %5 = mir.call @Array.push(%1, %3, %4)
    %7 = mir.mov_imm 20 : i64
    %8 = mir.mov_imm 0 : i64
    %9 = mir.call @Array.push(%1, %7, %8)
    %11 = mir.mov_imm 30 : i64
    %12 = mir.mov_imm 0 : i64
    %13 = mir.call @Array.push(%1, %11, %12)
    %15 = mir.mov_imm 1 : i64
    %16 = mir.mov_imm 99 : i64
    %17 = mir.mov_imm 0 : i64
    %18 = mir.call @Array.set(%1, %15, %16, %17)
    %19 = mir.call @mrt_get_error_and_clear()
    %20 = mir.mov_imm 0 : i64
    %21 = mir.cmp ne, %19, %20
    mir.cond_br %21 [then: try_1.otherwise(), else: try_1.merge()]
  try_1.otherwise:
    %23 = mir.global_addr @__panic_msg_0
    %24 = mir.call @mrt_panic(%23)
    %25 = mir.mov_imm 0 : i64
    mir.ret %25
  try_1.merge:
    %28 = mir.mov_imm 1 : i64
    %29 = mir.mov_imm 0 : i64
    %30 = mir.call @Array.get(%1, %28, %29)
    %31 = mir.call @mrt_get_error_and_clear()
    %32 = mir.mov_imm 0 : i64
    %33 = mir.cmp ne, %31, %32
    mir.cond_br %33 [then: try_4.otherwise(), else: try_4.merge(%30)]
  try_4.otherwise:
    %35 = mir.mov_imm 0 : i64
    mir.br try_4.merge(%35)
  try_4.merge:
    %39 = mir.mov_imm 125 : i64
    %40 = mir.cmp ugt, %38, %39
    mir.cond_br %40 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %41 = mir.global_addr @__panic_msg_1
    %42 = mir.call @mrt_panic(%41)
  __range_ok_0:

// Test: array-growth-realloc
typealias Integer = int(i64.min to i64.max)
typealias IntArray = Array with Integer

function main() returns ExitCode
		var arr = IntArray.create()
		var i = 0
		while i < 100 'loop'
				arr.push(i)
				i = i + 1
		end 'loop'
		return try arr.get(99) otherwise -1
end 'main'
---
ExitCode: 99
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.call @Array.create(%0)
    %2 = mir.mov_imm 0 : i64
    mir.br loop_1.header(%2)
  loop_1.header:
    %4 = mir.mov_imm 100 : i64
    %5 = mir.cmp lt, %24, %4
    mir.cond_br %5 [then: loop_1(), else: loop_1.exit()]
  loop_1:
    %8 = mir.mov_imm 0 : i64
    %9 = mir.call @Array.push(%1, %24, %8)
    %11 = mir.mov_imm 1 : i64
    %12 = mir.add.i64 %24, %11
    mir.br loop_1.header(%12)
  loop_1.exit:
    %14 = mir.mov_imm 99 : i64
    %15 = mir.mov_imm 0 : i64
    %16 = mir.call @Array.get(%1, %14, %15)
    %17 = mir.call @mrt_get_error_and_clear()
    %18 = mir.mov_imm 0 : i64
    %19 = mir.cmp ne, %17, %18
    mir.cond_br %19 [then: try_4.otherwise(), else: try_4.merge(%16)]
  try_4.otherwise:
    %21 = mir.mov_imm 1 : i64
    %22 = mir.neg.i64 %21
    mir.br try_4.merge(%22)
  try_4.merge:
    %26 = mir.mov_imm 125 : i64
    %27 = mir.cmp ugt, %25, %26
    mir.cond_br %27 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %28 = mir.global_addr @__panic_msg_0
    %29 = mir.call @mrt_panic(%28)
  __range_ok_0:
    mir.ret %25
  }
}
---

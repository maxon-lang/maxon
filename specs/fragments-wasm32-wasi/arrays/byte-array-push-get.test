    %4 = mir.mov_imm 0 : i64
    %5 = mir.call @Array.push(%1, %3, %4)
    %7 = mir.mov_imm 20 : i64
    %8 = mir.mov_imm 0 : i64
    %9 = mir.call @Array.push(%1, %7, %8)
    %11 = mir.mov_imm 30 : i64
    %12 = mir.mov_imm 0 : i64
    %13 = mir.call @Array.push(%1, %11, %12)
    %15 = mir.mov_imm 0 : i64
    %16 = mir.mov_imm 0 : i64
    %17 = mir.call @Array.get(%1, %15, %16)
    %18 = mir.call @mrt_get_error_and_clear()
    %19 = mir.mov_imm 0 : i64
    %20 = mir.cmp ne, %18, %19
    mir.cond_br %20 [then: try_1.otherwise(), else: try_1.merge(%17)]
  try_1.otherwise:
    %22 = mir.mov_imm 0 : i64
    mir.br try_1.merge(%22)
  try_1.merge:
    %25 = mir.mov_imm 1 : i64
    %26 = mir.mov_imm 0 : i64
    %27 = mir.call @Array.get(%1, %25, %26)
    %28 = mir.call @mrt_get_error_and_clear()
    %29 = mir.mov_imm 0 : i64
    %30 = mir.cmp ne, %28, %29
    mir.cond_br %30 [then: try_4.otherwise(), else: try_4.merge(%27)]
  try_4.otherwise:
    %32 = mir.mov_imm 0 : i64
    mir.br try_4.merge(%32)
  try_4.merge:
    %35 = mir.mov_imm 2 : i64
    %36 = mir.mov_imm 0 : i64
    %37 = mir.call @Array.get(%1, %35, %36)
    %38 = mir.call @mrt_get_error_and_clear()
    %39 = mir.mov_imm 0 : i64
    %40 = mir.cmp ne, %38, %39
    mir.cond_br %40 [then: try_7.otherwise(), else: try_7.merge(%37)]
  try_7.otherwise:
    %42 = mir.mov_imm 0 : i64
    mir.br try_7.merge(%42)
  try_7.merge:
    %46 = mir.add.i64 %49, %50
    %48 = mir.add.i64 %46, %51
    %52 = mir.mov_imm 125 : i64
    %53 = mir.cmp ugt, %48, %52
    mir.cond_br %53 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %54 = mir.global_addr @__panic_msg_0

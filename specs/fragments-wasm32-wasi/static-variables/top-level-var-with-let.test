// Test: top-level-var-with-let
let BASE = 40
var offset = 0

function main() returns ExitCode
	offset = 2
	return BASE + offset
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    %1 = mir.global_addr @__data_offset
    mir.store %0, %1, 0 width: qword
    %2 = mir.mov_imm 40 : i64
    %3 = mir.global_addr @__data_offset
    %4 = mir.load %3, 0 width: qword
    %5 = mir.add.i64 %2, %4
    %6 = mir.mov_imm 255 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
}
---

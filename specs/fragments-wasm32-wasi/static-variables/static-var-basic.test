// Test: static-var-basic
type Counter
	static var count = 0
end 'Counter'

function main() returns ExitCode
	Counter.count = 42
	return Counter.count
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %1 = mir.global_addr @__data_Counter.count
    mir.store %0, %1, 0
    %2 = mir.global_addr @__data_Counter.count
    %3 = mir.load %2, 0
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

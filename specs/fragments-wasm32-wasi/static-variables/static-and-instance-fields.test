// Test: static-and-instance-fields

typealias Integer = int(i64.min to i64.max)

type Thing
	static var created = 0
	export var id Integer

	static function make(n Integer) returns Thing
		Thing.created = Thing.created + 1
		return Thing{id: n}
	end 'make'
end 'Thing'

function main() returns ExitCode
	let a = Thing.make(10)
	let b = Thing.make(20)
	return Thing.created + a.id + b.id
end 'main'
---
ExitCode: 32
---
// CompiledIR
module {
  func @Thing.make(local0: i64) -> i64 {
  entry:
    %9 = mir.param local0 : i64
    %1 = mir.global_addr @__data_Thing.created
    %2 = mir.load %1, 0 width: qword
    %3 = mir.mov_imm 1 : i64
    %4 = mir.add.i64 %2, %3
    %5 = mir.global_addr @__data_Thing.created
    mir.store %4, %5, 0 width: qword
    %6 = mir.mov_imm 8 : i64
    %7 = mir.call @mrt_alloc(%6)
    mir.store %9, %7, 0 width: qword
    mir.ret %7
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.call @Thing.make(%0)
    %2 = mir.mov_imm 20 : i64
    %3 = mir.call @Thing.make(%2)
    %4 = mir.global_addr @__data_Thing.created
    %5 = mir.load %4, 0 width: qword
    %7 = mir.load %1, 0 width: qword
    %8 = mir.add.i64 %5, %7
    %10 = mir.load %3, 0 width: qword
    %11 = mir.add.i64 %8, %10
    %12 = mir.mov_imm 125 : i64
    %13 = mir.cmp ugt, %11, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %14 = mir.global_addr @__panic_msg_0
    %15 = mir.call @mrt_panic(%14)
  __range_ok_0:
    mir.ret %11
  }
}
---

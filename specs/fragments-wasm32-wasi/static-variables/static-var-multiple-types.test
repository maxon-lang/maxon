    %3 = mir.add.i64 %1, %2
    %4 = mir.global_addr @__data_TypeA.value
    mir.store %3, %4, 0 width: qword
    %5 = mir.global_addr @__data_TypeB.value
    %6 = mir.load %5, 0 width: qword
    %7 = mir.mov_imm 10 : i64
    %8 = mir.add.i64 %6, %7
    %9 = mir.global_addr @__data_TypeB.value
    mir.store %8, %9, 0 width: qword
    %10 = mir.global_addr @__data_TypeA.value
    %11 = mir.load %10, 0 width: qword
    %12 = mir.global_addr @__data_TypeB.value
    %13 = mir.load %12, 0 width: qword
    %14 = mir.add.i64 %11, %13
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %14, %15
    mir.cond_br %16 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_0
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %14
  }
}
---

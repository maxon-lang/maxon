// Test: static-var-multiple-types
type TypeA
	static var value = 10
end 'TypeA'

type TypeB
	static var value = 20
end 'TypeB'

function main() returns ExitCode
	TypeA.value = TypeA.value + 2
	TypeB.value = TypeB.value + 10
	return TypeA.value + TypeB.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.global_addr @__data_TypeA.value
    %1 = mir.load %0, 0 width: qword

    %0 = mir.global_addr @__data_flag
    %1 = mir.load %0, 0
    mir.cond_br %1 [then: checkFalse_1(), else: checkFalse_1.after()]
  checkFalse_1:
    %2 = mir.global_addr @__istr_0
    %3 = mir.mov_imm 40 : i64

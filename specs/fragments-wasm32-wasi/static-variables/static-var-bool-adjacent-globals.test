    %10 = mir.call @mrt_alloc(%9)
    mir.store %4, %10, 0
    %11 = mir.mov_imm 1 : i64
    mir.store %11, %10, 8
    %31 = mir.load %10, 0
    %32 = mir.load %31, 0
    %33 = mir.load %31, 8
    %34 = mir.call @mrt_write_stdout(%32, %33)
    %13 = mir.mov_imm 1 : i64
    mir.ret %13
  checkFalse_1.after:
    %14 = mir.global_addr @__data_counter
    %15 = mir.load %14, 0
    %16 = mir.mov_imm 42 : i64
    %17 = mir.cmp eq, %15, %16
    mir.cond_br %17 [then: checkCounter_3(), else: checkCounter_3.after()]
  checkCounter_3:
    %18 = mir.mov_imm 0 : i64
    mir.ret %18
  checkCounter_3.after:
    %19 = mir.global_addr @__istr_1
    %20 = mir.mov_imm 40 : i64
    %21 = mir.call @mrt_alloc(%20)
    mir.store %19, %21, 0
    %22 = mir.mov_imm 14 : i64
    mir.store %22, %21, 8
    %23 = mir.mov_imm -2 : i64
    mir.store %23, %21, 16
    %24 = mir.mov_imm 1 : i64
    mir.store %24, %21, 24
    %25 = mir.mov_imm 0 : i64
    mir.store %25, %21, 32
    %26 = mir.mov_imm 16 : i64
    %27 = mir.call @mrt_alloc(%26)
    mir.store %21, %27, 0

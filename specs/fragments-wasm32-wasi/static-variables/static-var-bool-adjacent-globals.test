    %32 = mir.load %10, 0
    %33 = mir.load %32, 0
    %34 = mir.load %32, 8
    %35 = mir.call @mrt_write_stdout(%33, %34)
    mir.ret %31
  checkFalse_0.after:
    %14 = mir.global_addr @__data_counter
    %15 = mir.load %14, 0
    %16 = mir.mov_imm 42 : i64
    %17 = mir.cmp eq, %15, %16
    mir.cond_br %17 [then: checkCounter_0(), else: checkCounter_0.after()]
  checkCounter_0:
    %18 = mir.mov_imm 0 : i64
    mir.ret %18
  checkCounter_0.after:
    %19 = mir.global_addr @__istr_1
    %20 = mir.mov_imm 40 : i64
    %21 = mir.call @mrt_alloc(%20)
    mir.store %19, %21, 0
    %22 = mir.mov_imm 14 : i64
    mir.store %22, %21, 8
    %23 = mir.mov_imm -2 : i64
    mir.store %23, %21, 16
    mir.store %31, %21, 24
    %25 = mir.mov_imm 0 : i64
    mir.store %25, %21, 32
    %26 = mir.mov_imm 16 : i64
    %27 = mir.call @mrt_alloc(%26)

  func @main() -> u8 {
  entry:
    %0 = mir.global_addr @__data_current
    %1 = mir.load %0, 0
    %2 = mir.mov_imm 0 : i64
    %3 = mir.mov_imm 1 : i64
    %4 = mir.cmp eq, %1, %3
    mir.cond_br %4 [then: check_0.case0(), else: check_0.next0()]
  check_0.merge:
    mir.cond_br %32 [then: check_1(), else: check_1.after()]
  check_0.case0:
    %7 = mir.mov_imm 1 : i64
    mir.br check_0.merge(%7)
  check_0.next0:
    %9 = mir.cmp eq, %1, %2
    mir.cond_br %9 [then: check_0.merge(%2), else: check_0.next1()]
  check_0.next1:
    %11 = mir.mov_imm 2 : i64
    mir.br check_0.merge(%2)
  check_1:
    %14 = mir.mov_imm 2 : i64
    %15 = mir.global_addr @__data_current
    mir.store %14, %15, 0
    %16 = mir.global_addr @__data_current
    %17 = mir.load %16, 0
    %19 = mir.mov_imm 2 : i64
    %20 = mir.cmp eq, %17, %19
    mir.cond_br %20 [then: check2_0.case0(), else: check2_0.next0()]
  check2_0.merge:
    mir.cond_br %33 [then: check2_1(), else: check_1.after()]
  check2_0.case0:
    %23 = mir.mov_imm 1 : i64
    mir.br check2_0.merge(%23)
  check2_0.next0:
    %25 = mir.cmp eq, %17, %2
    mir.cond_br %25 [then: check2_0.merge(%2), else: check2_0.next1()]
  check2_0.next1:
    %27 = mir.mov_imm 1 : i64
    mir.br check2_0.merge(%2)
  check2_1:
    %30 = mir.mov_imm 42 : i64
    mir.ret %30
  check_1.after:
    mir.ret %2
  }
}

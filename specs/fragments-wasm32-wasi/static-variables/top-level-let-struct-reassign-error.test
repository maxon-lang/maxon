// Test: top-level-let-struct-reassign-error
typealias SmallInt = int(0 to u8.max)

type Point
		export var x SmallInt
		export var y SmallInt

		static function create(x SmallInt, y SmallInt) returns Self
			return Self{x: x, y: y}
		end 'create'
end 'Point'

let origin = Point.create(x: 0, y: 0)

function main() returns ExitCode
		origin = Point.create(x: 1, y: 1)
		return 0
end 'main'

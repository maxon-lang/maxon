// Test: memory.clear-frees-strings
typealias StringList = List with String

function testClear()
	var list = StringList.create()
	list.append("alpha string!!!!!!!!!!!!!!!")
	list.append("beta string!!!!!!!!!!!!!!!!")
	list.append("gamma string!!!!!!!!!!!!!!!")
	list.clear()
	print("{list.count()}\n")
end 'testClear'

function main() returns ExitCode
	testClear()
	return 0
end 'main'

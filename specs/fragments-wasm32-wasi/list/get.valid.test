// Test: get.valid
function main() returns ExitCode
	let list = List from [10, 20, 30, 40]
	let v0 = try list.get(0) otherwise 0
	let v1 = try list.get(1) otherwise 0
	let v2 = try list.get(2) otherwise 0
	let v3 = try list.get(3) otherwise 0
	print("{v0}\n")
	print("{v1}\n")
	print("{v2}\n")
	print("{v3}\n")
	return 0
end 'main'

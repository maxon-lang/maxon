// Test: remove-first
function main() returns ExitCode
	var list = List from [10, 20, 30]
	let removed = try list.removeFirst() otherwise 0
	print("{removed}\n")
	print("{list.count()}\n")
	let f = try list.first() otherwise 0
	print("{f}\n")
	return 0
end 'main'
---
ExitCode: 0

// Test: strings
typealias StringList = List with String

function main() returns ExitCode
	var list = StringList.create()
	list.append("hello")
	list.append("world")
	let f = try list.first() otherwise "none"
	let l = try list.last() otherwise "none"
	print("{f}\n")
	print("{l}\n")
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
hello
world
```

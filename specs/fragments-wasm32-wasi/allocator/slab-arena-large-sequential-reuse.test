// Test: slab-arena-large-sequential-reuse
function main() returns ExitCode
	let a = __mm_raw_alloc(40000)
	__mm_raw_free(a)
	let b = __mm_raw_alloc(40000)
	__mm_raw_free(b)
	let c = __mm_raw_alloc(40000)
	__mm_raw_free(c)
	let count = __mm_raw_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 40000 : i64
    %1 = mir.call @mm_raw_alloc(%0)
    %3 = mir.call @mm_raw_free(%1)
    %4 = mir.mov_imm 40000 : i64
    %5 = mir.call @mm_raw_alloc(%4)
    %7 = mir.call @mm_raw_free(%5)
    %8 = mir.mov_imm 40000 : i64
    %9 = mir.call @mm_raw_alloc(%8)
    %11 = mir.call @mm_raw_free(%9)
    %12 = mir.global_addr @__mm_raw_alloc_count
    %13 = mir.load %12, 0
    %15 = mir.mov_imm 0 : i64
    %16 = mir.cmp eq, %13, %15
    mir.cond_br %16 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %17 = mir.mov_imm 0 : i64
    mir.ret %17
  ok_1.after:
    %18 = mir.mov_imm 1 : i64
    mir.ret %18
  }
}
---

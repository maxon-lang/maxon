    %15 = mir.call @mm_alloc(%12, %13, %14)
    %17 = mir.call @mm_decref(%15)
    %18 = mir.global_addr @__mm_alloc_count
    %19 = mir.load %18, 0
    %21 = mir.mov_imm 0 : i64
    %22 = mir.cmp eq, %19, %21
    mir.cond_br %22 [then: ok_0(), else: ok_0.after()]
  ok_0:

// Test: raw-alloc-free-reuse
function main() returns ExitCode
	let p1 = __mm_raw_alloc(64)
	__mm_raw_free(p1)
	let p2 = __mm_raw_alloc(64)
	__mm_raw_free(p2)
	let count = __mm_raw_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 64 : i64
    %1 = mir.call @mm_raw_alloc(%0)
    %3 = mir.call @mm_raw_free(%1)
    %4 = mir.mov_imm 64 : i64
    %5 = mir.call @mm_raw_alloc(%4)
    %7 = mir.call @mm_raw_free(%5)
    %8 = mir.global_addr @__mm_raw_alloc_count
    %9 = mir.load %8, 0
    %11 = mir.mov_imm 0 : i64
    %12 = mir.cmp eq, %9, %11
    mir.cond_br %12 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  ok_1.after:
    %14 = mir.mov_imm 1 : i64
    mir.ret %14
  }
}
---

// Test: mixed-raw-and-tracked
function main() returns ExitCode
	let p = __mm_alloc(64, destructor: 0, tag: 0)
	let q = __mm_alloc(64, destructor: 0, tag: 0)
	let r = __mm_alloc(128, destructor: 0, tag: 0)
	let s = __mm_alloc(128, destructor: 0, tag: 0)
	__mm_decref(p)
	__mm_decref(q)
	__mm_decref(r)
	__mm_decref(s)
	let count = __mm_alloc_count()
	if count != 0 'fail'
		return 1
	end 'fail'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 64 : i64
    %1 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %1)
    %4 = mir.mov_imm 64 : i64
    %7 = mir.call @mm_alloc(%4, %1, %1)
    %8 = mir.mov_imm 128 : i64
    %11 = mir.call @mm_alloc(%8, %1, %1)
    %12 = mir.mov_imm 128 : i64
    %15 = mir.call @mm_alloc(%12, %1, %1)
    %17 = mir.call @mm_decref(%3)
    %19 = mir.call @mm_decref(%7)
    %21 = mir.call @mm_decref(%11)
    %23 = mir.call @mm_decref(%15)
    %24 = mir.global_addr @__mm_alloc_count
    %25 = mir.load %24, 0
    %28 = mir.cmp ne, %25, %1
    mir.cond_br %28 [then: fail_0(), else: fail_0.after()]
  fail_0:
    %29 = mir.mov_imm 1 : i64
    mir.ret %29
  fail_0.after:
    mir.ret %1
  }
}

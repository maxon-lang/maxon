    %3 = mir.call @mm_alloc(%0, %1, %2)
    %4 = mir.mov_imm 64 : i64
    %5 = mir.mov_imm 0 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @mm_alloc(%4, %5, %6)
    %8 = mir.mov_imm 128 : i64
    %9 = mir.mov_imm 0 : i64
    %10 = mir.mov_imm 0 : i64
    %11 = mir.call @mm_alloc(%8, %9, %10)
    %12 = mir.mov_imm 128 : i64
    %13 = mir.mov_imm 0 : i64
    %14 = mir.mov_imm 0 : i64
    %15 = mir.call @mm_alloc(%12, %13, %14)
    %17 = mir.call @mm_decref(%3)
    %19 = mir.call @mm_decref(%7)
    %21 = mir.call @mm_decref(%11)
    %23 = mir.call @mm_decref(%15)
    %24 = mir.global_addr @__mm_alloc_count
    %25 = mir.load %24, 0
    %27 = mir.mov_imm 0 : i64
    %28 = mir.cmp ne, %25, %27
    mir.cond_br %28 [then: fail_1(), else: fail_1.after()]
  fail_1:
    %29 = mir.mov_imm 1 : i64
    mir.ret %29
  fail_1.after:
    %30 = mir.mov_imm 0 : i64
    mir.ret %30

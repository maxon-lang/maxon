// Test: slab-mixed-allocation-tiers
function main() returns ExitCode
	let small = __mm_alloc(16, destructor: 0, tag: 0)
	let medium = __mm_alloc(40000, destructor: 0, tag: 0)
	let huge = __mm_alloc(83886080, destructor: 0, tag: 0)
	__mm_decref(huge)
	__mm_decref(medium)
	__mm_decref(small)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 16 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %2)
    %4 = mir.mov_imm 40000 : i64
    %5 = mir.mov_imm 0 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @mm_alloc(%4, %5, %6)
    %8 = mir.mov_imm 83886080 : i64
    %9 = mir.mov_imm 0 : i64
    %10 = mir.mov_imm 0 : i64
    %11 = mir.call @mm_alloc(%8, %9, %10)
    %13 = mir.call @mm_decref(%11)
    %15 = mir.call @mm_decref(%7)
    %17 = mir.call @mm_decref(%3)
    %18 = mir.global_addr @__mm_alloc_count
    %19 = mir.load %18, 0
    %21 = mir.mov_imm 0 : i64
    %22 = mir.cmp eq, %19, %21
    mir.cond_br %22 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %23 = mir.mov_imm 0 : i64
    mir.ret %23
  ok_1.after:
    %24 = mir.mov_imm 1 : i64
    mir.ret %24
  }
}
---

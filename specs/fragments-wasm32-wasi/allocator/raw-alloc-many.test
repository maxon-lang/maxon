// Test: raw-alloc-many
function main() returns ExitCode
	for i in 1 upto 100 'loop'
		let p = __mm_alloc(i * 8, destructor: 0, tag: 0)
		__mm_decref(p)
	end 'loop'
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.mov_imm 100 : i64
    mir.br loop_1.header(%0)
  loop_1.header:
    %4 = mir.cmp lt, %23, %1
    mir.cond_br %4 [then: loop_1(), else: loop_1.exit()]
  loop_1:
    %6 = mir.mov_imm 8 : i64
    %7 = mir.mul.i64 %23, %6
    %8 = mir.mov_imm 0 : i64
    %9 = mir.mov_imm 0 : i64
    %10 = mir.call @mm_alloc(%7, %8, %9)
    %12 = mir.call @mm_decref(%10)
    mir.br loop_1.step()
  loop_1.step:
    %14 = mir.mov_imm 1 : i64
    %15 = mir.add.i64 %23, %14
    mir.br loop_1.header(%15)
  loop_1.exit:
    %16 = mir.global_addr @__mm_alloc_count
    %17 = mir.load %16, 0
    %19 = mir.mov_imm 0 : i64
    %20 = mir.cmp eq, %17, %19
    mir.cond_br %20 [then: ok_5(), else: ok_5.after()]
  ok_5:
    %21 = mir.mov_imm 0 : i64
    mir.ret %21
  ok_5.after:
    %22 = mir.mov_imm 1 : i64
    mir.ret %22
  }
}
---

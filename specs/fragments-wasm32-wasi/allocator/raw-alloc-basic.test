// Test: raw-alloc-basic
function main() returns ExitCode
	let p = __mm_alloc(64, destructor: 0, tag: 0)
	__mm_decref(p)
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 64 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %2)
    %5 = mir.call @mm_decref(%3)
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}

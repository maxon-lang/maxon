// Test: raw-alloc-large
function main() returns ExitCode
	let big = 100 * 1024 * 1024
	let p = __mm_alloc(big, destructor: 0, tag: 0)
	__mm_decref(p)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %4 = mir.mov_imm 104857600 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @mm_alloc(%4, %6, %7)
    %10 = mir.call @mm_decref(%8)
    %11 = mir.global_addr @__mm_alloc_count
    %12 = mir.load %11, 0
    %14 = mir.mov_imm 0 : i64
    %15 = mir.cmp eq, %12, %14
    mir.cond_br %15 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %16 = mir.mov_imm 0 : i64
    mir.ret %16
  ok_1.after:
    %17 = mir.mov_imm 1 : i64
    mir.ret %17
  }
}
---

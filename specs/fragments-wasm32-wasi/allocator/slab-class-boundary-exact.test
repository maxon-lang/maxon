// Test: slab-class-boundary-exact
function main() returns ExitCode
	let p16 = __mm_alloc(16, destructor: 0, tag: 0)
	let p24 = __mm_alloc(24, destructor: 0, tag: 0)
	__mm_decref(p24)
	__mm_decref(p16)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 16 : i64
    %1 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %1)
    %4 = mir.mov_imm 24 : i64
    %7 = mir.call @mm_alloc(%4, %1, %1)
    %9 = mir.call @mm_decref(%7)
    %11 = mir.call @mm_decref(%3)
    %12 = mir.global_addr @__mm_alloc_count
    %13 = mir.load %12, 0
    %16 = mir.cmp eq, %13, %1
    mir.cond_br %16 [then: ok_0(), else: ok_0.after()]
  ok_0:
    mir.ret %1
  ok_0.after:
    %18 = mir.mov_imm 1 : i64
    mir.ret %18
  }
}
---

// Test: mm-alloc-tracked-count
function main() returns ExitCode
	for i in 1 upto 100 'loop'
		let p = __mm_alloc(64, destructor: 0, tag: 0)
		__mm_decref(p)
	end 'loop'
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.mov_imm 100 : i64
    mir.br loop_0.header(%0)
  loop_0.header:
    %4 = mir.cmp lt, %21, %1
    mir.cond_br %4 [then: loop_0(), else: loop_0.exit()]
  loop_0:
    %5 = mir.mov_imm 64 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @mm_alloc(%5, %6, %7)
    %10 = mir.call @mm_decref(%8)
    mir.br loop_0.step()
  loop_0.step:
    %12 = mir.mov_imm 1 : i64
    %13 = mir.add.i64 %21, %12
    mir.br loop_0.header(%13)
  loop_0.exit:
    %14 = mir.global_addr @__mm_alloc_count
    %15 = mir.load %14, 0
    %17 = mir.mov_imm 0 : i64
    %18 = mir.cmp eq, %15, %17
    mir.cond_br %18 [then: ok_0(), else: ok_0.after()]
  ok_0:
    %19 = mir.mov_imm 0 : i64
    mir.ret %19
  ok_0.after:
    %20 = mir.mov_imm 1 : i64
    mir.ret %20
  }
}
---

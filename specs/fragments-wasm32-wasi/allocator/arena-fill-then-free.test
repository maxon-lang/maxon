// Test: arena-fill-then-free
function main() returns ExitCode
	var i = 0
	while i < 1000 'loop'
		let p = __mm_alloc(8, destructor: 0, tag: 0)
		__mm_decref(p)
		i = i + 1
	end 'loop'
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    mir.br loop_1.header(%0)
  loop_1.header:
    %2 = mir.mov_imm 1000 : i64
    %3 = mir.cmp lt, %20, %2
    mir.cond_br %3 [then: loop_1(), else: loop_1.exit()]
  loop_1:
    %4 = mir.mov_imm 8 : i64
    %5 = mir.mov_imm 0 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @mm_alloc(%4, %5, %6)
    %9 = mir.call @mm_decref(%7)
    %11 = mir.mov_imm 1 : i64
    %12 = mir.add.i64 %20, %11
    mir.br loop_1.header(%12)
  loop_1.exit:
    %13 = mir.global_addr @__mm_alloc_count
    %14 = mir.load %13, 0
    %16 = mir.mov_imm 0 : i64
    %17 = mir.cmp eq, %14, %16
    mir.cond_br %17 [then: ok_4(), else: ok_4.after()]
  ok_4:
    %18 = mir.mov_imm 0 : i64
    mir.ret %18
  ok_4.after:
    %19 = mir.mov_imm 1 : i64
    mir.ret %19
  }
}
---

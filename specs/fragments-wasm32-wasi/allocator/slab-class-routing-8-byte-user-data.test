// Test: slab-class-routing-8-byte-user-data
function main() returns ExitCode
	let p = __mm_alloc(8, destructor: 0, tag: 0)
	__mm_decref(p)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 8 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %2)
    %5 = mir.call @mm_decref(%3)
    %6 = mir.global_addr @__mm_alloc_count
    %7 = mir.load %6, 0
    %9 = mir.mov_imm 0 : i64
    %10 = mir.cmp eq, %7, %9
    mir.cond_br %10 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %11 = mir.mov_imm 0 : i64
    mir.ret %11
  ok_1.after:
    %12 = mir.mov_imm 1 : i64
    mir.ret %12
  }
}
---

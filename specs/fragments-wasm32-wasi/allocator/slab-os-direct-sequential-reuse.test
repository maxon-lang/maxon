// Test: slab-os-direct-sequential-reuse
function main() returns ExitCode
	let a = __mm_alloc(83886080, destructor: 0, tag: 0)
	__mm_decref(a)
	let b = __mm_alloc(83886080, destructor: 0, tag: 0)
	__mm_decref(b)
	let count = __mm_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 83886080 : i64
    %1 = mir.mov_imm 0 : i64
    %3 = mir.call @mm_alloc(%0, %1, %1)
    %5 = mir.call @mm_decref(%3)
    %6 = mir.mov_imm 83886080 : i64
    %9 = mir.call @mm_alloc(%6, %1, %1)
    %11 = mir.call @mm_decref(%9)
    %12 = mir.global_addr @__mm_alloc_count
    %13 = mir.load %12, 0
    %16 = mir.cmp eq, %13, %1
    mir.cond_br %16 [then: ok_0(), else: ok_0.after()]
  ok_0:
    mir.ret %1
  ok_0.after:
    %18 = mir.mov_imm 1 : i64
    mir.ret %18
  }
}

// Test: interleaved-alloc-free
function main() returns ExitCode
	let a = __mm_raw_alloc(16)
	let b = __mm_raw_alloc(16)
	let c = __mm_raw_alloc(16)
	let d = __mm_raw_alloc(16)
	let e = __mm_raw_alloc(16)
	__mm_raw_free(a)
	__mm_raw_free(b)
	__mm_raw_free(c)
	let f = __mm_raw_alloc(16)
	let g = __mm_raw_alloc(16)
	let h = __mm_raw_alloc(16)
	let i = __mm_raw_alloc(16)
	let j = __mm_raw_alloc(16)
	__mm_raw_free(d)
	__mm_raw_free(e)
	__mm_raw_free(f)
	__mm_raw_free(g)
	__mm_raw_free(h)
	__mm_raw_free(i)
	__mm_raw_free(j)
	let count = __mm_raw_alloc_count()
	if count == 0 'ok'
		return 0
	end 'ok'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @allocator.main() -> u8 {
  entry:
    %0 = mir.mov_imm 16 : i64
    %1 = mir.call @mm_raw_alloc(%0)
    %2 = mir.mov_imm 16 : i64
    %3 = mir.call @mm_raw_alloc(%2)
    %4 = mir.mov_imm 16 : i64
    %5 = mir.call @mm_raw_alloc(%4)
    %6 = mir.mov_imm 16 : i64
    %7 = mir.call @mm_raw_alloc(%6)
    %8 = mir.mov_imm 16 : i64
    %9 = mir.call @mm_raw_alloc(%8)
    %11 = mir.call @mm_raw_free(%1)
    %13 = mir.call @mm_raw_free(%3)
    %15 = mir.call @mm_raw_free(%5)
    %16 = mir.mov_imm 16 : i64
    %17 = mir.call @mm_raw_alloc(%16)
    %18 = mir.mov_imm 16 : i64
    %19 = mir.call @mm_raw_alloc(%18)
    %20 = mir.mov_imm 16 : i64
    %21 = mir.call @mm_raw_alloc(%20)
    %22 = mir.mov_imm 16 : i64
    %23 = mir.call @mm_raw_alloc(%22)
    %24 = mir.mov_imm 16 : i64
    %25 = mir.call @mm_raw_alloc(%24)
    %27 = mir.call @mm_raw_free(%7)
    %29 = mir.call @mm_raw_free(%9)
    %31 = mir.call @mm_raw_free(%17)
    %33 = mir.call @mm_raw_free(%19)
    %35 = mir.call @mm_raw_free(%21)
    %37 = mir.call @mm_raw_free(%23)
    %39 = mir.call @mm_raw_free(%25)
    %40 = mir.global_addr @__mm_raw_alloc_count
    %41 = mir.load %40, 0
    %43 = mir.mov_imm 0 : i64
    %44 = mir.cmp eq, %41, %43
    mir.cond_br %44 [then: ok_1(), else: ok_1.after()]
  ok_1:
    %45 = mir.mov_imm 0 : i64
    mir.ret %45
  ok_1.after:
    %46 = mir.mov_imm 1 : i64
    mir.ret %46
  }
}

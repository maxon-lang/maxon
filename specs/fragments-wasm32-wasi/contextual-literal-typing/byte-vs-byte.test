// Test: byte-vs-byte

typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let a = 50 as Byte
	let b = 50 as Byte
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

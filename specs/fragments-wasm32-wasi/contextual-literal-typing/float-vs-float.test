// Test: float-vs-float
function main() returns ExitCode
	let a = 3.14
	let b = 3.14
	if a == b 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4614253070214989086 : f64
    %1 = mir.mov_imm 4614253070214989086 : f64
    %4 = mir.cmp feq, %0, %1
    mir.cond_br %4 [then: check_1(), else: check_1.after()]
  check_1:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  check_1.after:
    %6 = mir.mov_imm 0 : i64
    mir.ret %6
  }
}
---

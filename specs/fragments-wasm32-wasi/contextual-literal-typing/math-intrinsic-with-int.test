// Test: math-intrinsic-with-int
function main() returns ExitCode
	let x = 16
	let result = sqrt(x)
	return trunc(result)
end 'main'
---
ExitCode: 4
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 16 : i64
    %2 = mir.sitofp.f64 %0
    %3 = mir.sqrt.f64 %2
    %5 = mir.fptosi.i64 %3
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %5, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_0
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %5
  }
}
---

// Test: explicit-cast-float-to-int
function main() returns ExitCode
	let x = 5
	let y = 5.0
	if x == trunc(y) 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.mov_imm 4617315517961601024 : f64
    %4 = mir.fptosi.i64 %1
    %5 = mir.cmp eq, %0, %4
    mir.cond_br %5 [then: check_0(), else: check_0.after()]
  check_0:
    %6 = mir.mov_imm 1 : i64
    mir.ret %6
  check_0.after:
    %7 = mir.mov_imm 0 : i64
    mir.ret %7
  }
}
---

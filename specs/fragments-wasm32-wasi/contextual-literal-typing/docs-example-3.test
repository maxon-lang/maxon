// Test: docs-example-3
typealias Decimal = float(f64.min to f64.max)

function main() returns ExitCode
	let x = 5
	let y = 5.0
	if (x as Decimal) == y 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.mov_imm 4617315517961601024 : f64
    %3 = mir.sitofp.f64 %0
    %5 = mir.cmp feq, %3, %1
    mir.cond_br %5 [then: check_1(), else: check_1.after()]
  check_1:
    %6 = mir.mov_imm 1 : i64
    mir.ret %6
  check_1.after:
    %7 = mir.mov_imm 0 : i64
    mir.ret %7
  }
}
---

    %5 = mir.mov_imm 0 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @stdlib.__mm_alloc(%5, %6, %7)
    %11 = mir.call @mm_drop(%8)
    %10 = mir.mov_imm 42 : i64
    mir.ret %10
  }
}

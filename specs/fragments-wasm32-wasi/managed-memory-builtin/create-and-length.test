    mir.br try_0.merge()
  try_0.merge:
    %12 = mir.load %22, 8 width: qword
    %14 = mir.cmp ne, %12, %0
    mir.cond_br %14 [then: badLen_0(), else: badLen_0.after()]
  badLen_0:

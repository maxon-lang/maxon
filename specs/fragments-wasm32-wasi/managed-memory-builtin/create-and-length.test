// Test: create-and-length
function main() returns ExitCode
	let mm = try __ManagedMemory.create(4, elementSize: 8) otherwise return 1
	if mm.length() != 0 'badLen'
		return 2
	end 'badLen'
	if mm.capacity() != 4 'badCap'
		return 3
	end 'badCap'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @managed-memory-builtin.main() -> u8 {
  entry:
    %0 = mir.mov_imm 4 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @__managed_mem_create(%0, %1)
    %3 = mir.call @mrt_get_error_and_clear()
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp ne, %3, %4
    mir.cond_br %5 [then: try_1.otherwise(), else: try_1.merge()]
  try_1.otherwise:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  try_1.merge:
    %10 = mir.load %2, 8
    %11 = mir.mov_imm 0 : i64
    %12 = mir.cmp ne, %10, %11
    mir.cond_br %12 [then: badLen_4(), else: badLen_4.after()]
  badLen_4:
    %13 = mir.mov_imm 2 : i64
    mir.ret %13
  badLen_4.after:
    %15 = mir.load %2, 16
    %16 = mir.mov_imm 4 : i64
    %17 = mir.cmp ne, %15, %16
    mir.cond_br %17 [then: badCap_6(), else: badCap_6.after()]
  badCap_6:
    %18 = mir.mov_imm 3 : i64
    mir.ret %18
  badCap_6.after:
    %19 = mir.mov_imm 0 : i64
    mir.ret %19
  }
}

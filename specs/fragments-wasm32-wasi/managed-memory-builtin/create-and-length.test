// Test: create-and-length
function main() returns ExitCode
	let mm = try __ManagedMemory.create(4, elementSize: 8) otherwise return 1
	if mm.length() != 0 'badLen'
		return 2
	end 'badLen'
	if mm.capacity() != 4 'badCap'
		return 3
	end 'badCap'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @stdlib.__managed_mem_create(%0, %1)
    %3 = mir.mov_imm 0 : i64
    mir.br try_0.merge()
  try_0.merge:
    %10 = mir.load %2, 8 width: qword
    %12 = mir.cmp ne, %10, %3
    mir.cond_br %12 [then: badLen_0(), else: badLen_0.after()]
  badLen_0:
    %13 = mir.mov_imm 2 : i64
    mir.ret %13
  badLen_0.after:
    %15 = mir.load %2, 16 width: qword
    %16 = mir.mov_imm 4 : i64
    %17 = mir.cmp ne, %15, %16
    mir.cond_br %17 [then: badCap_0(), else: badCap_0.after()]
  badCap_0:
    %18 = mir.mov_imm 3 : i64
    mir.ret %18
  badCap_0.after:
    mir.ret %3
  }
}
---

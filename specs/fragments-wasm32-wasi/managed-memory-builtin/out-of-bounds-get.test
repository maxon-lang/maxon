// Test: out-of-bounds-get
function main() returns ExitCode
	let mm = try __ManagedMemory.create(2, elementSize: 8) otherwise return 1
	try mm.setLength(1) otherwise return 2
	try mm.set(0, value: 7) otherwise return 3
	let _ = try mm.get(99) otherwise return 0
	return 5
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @__managed_mem_create(%0, %1)
    %3 = mir.mov_imm 0 : i64
    mir.br try_0.merge()
  try_0.merge:
    %10 = mir.mov_imm 1 : i64
    %11, %12 = mir.try_call @__managed_mem_set_length(%2, %10)
    %14 = mir.cmp ne, %12, %3
    mir.cond_br %14 [then: try_1.otherwise(), else: try_1.merge()]
  try_1.otherwise:
    %16 = mir.mov_imm 2 : i64
    mir.ret %16
  try_1.merge:
    %20 = mir.mov_imm 7 : i64
    %21, %22 = mir.try_call @__managed_mem_set(%2, %3, %20)
    %24 = mir.cmp ne, %22, %3
    mir.cond_br %24 [then: try_2.otherwise(), else: try_2.merge()]
  try_2.otherwise:
    %26 = mir.mov_imm 3 : i64
    mir.ret %26
  try_2.merge:
    %29 = mir.mov_imm 99 : i64
    %30, %31 = mir.try_call @__managed_mem_get(%2, %29)
    %33 = mir.cmp ne, %31, %3
    mir.cond_br %33 [then: try_3.otherwise(), else: try_3.merge()]
  try_3.otherwise:
    mir.ret %3
  try_3.merge:
    %37 = mir.mov_imm 5 : i64
    mir.ret %37
  }
}
---

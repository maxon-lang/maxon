    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 0 : i64
    mir.br outer_0.header(%0, %1)
  outer_0.header:
    %3 = mir.mov_imm 3 : i64
    %4 = mir.cmp lt, %29, %3
    mir.cond_br %4 [then: outer_0(), else: outer_0.exit()]
  outer_0:
    %5 = mir.mov_imm 0 : i64
    mir.br inner_0.header(%28, %5)
  outer_0.exit:
    %31 = mir.mov_imm 255 : i64
    %32 = mir.cmp ugt, %28, %31
    mir.cond_br %32 [then: __range_panic_0(), else: __range_ok_0()]
  inner_0.header:
    %8 = mir.mov_imm 3 : i64
    %9 = mir.cmp lt, %30, %8
    mir.cond_br %9 [then: inner_0(), else: inner_0.exit()]
  inner_0:
    %12 = mir.add.i64 %29, %30
    %13 = mir.mov_imm 2 : i64
    %14 = mir.rem.i64 %12, %13
    %15 = mir.mov_imm 0 : i64
    %16 = mir.cmp eq, %14, %15
    mir.cond_br %16 [then: even_0(), else: even_0.after(%27)]
  inner_0.exit:
    %18 = mir.mov_imm 1 : i64
    %19 = mir.add.i64 %29, %18
    mir.br outer_0.header(%27, %19)
  even_0:
    %21 = mir.mov_imm 1 : i64
    %22 = mir.add.i64 %27, %21
    mir.br even_0.after(%22)
  even_0.after:
    %24 = mir.mov_imm 1 : i64
    %25 = mir.add.i64 %30, %24
    mir.br inner_0.header(%26, %25)
  __range_panic_0:
    %33 = mir.global_addr @__panic_msg_0
    %34 = mir.call @mrt_panic(%33)
  __range_ok_0:

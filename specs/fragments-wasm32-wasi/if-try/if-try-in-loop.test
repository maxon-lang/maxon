  inlined_mayFail_2:
    %24 = mir.mov_imm 0 : i64
    mir.br inline_cont_main_0(%19, %24)
  inline_cont_main_0:
    %8 = mir.mov_imm 0 : i64
    %9 = mir.cmp eq, %26, %8
    mir.cond_br %9 [then: check_0(), else: check_0.after(%18)]
  loop_0.exit:
    %27 = mir.mov_imm 255 : i64
    %28 = mir.cmp ugt, %18, %27
    mir.cond_br %28 [then: __range_panic_0(), else: __range_ok_0()]
  check_0:
    %13 = mir.add.i64 %18, %25
    mir.br check_0.after(%13)
  check_0.after:
    %15 = mir.mov_imm 1 : i64
    %16 = mir.add.i64 %19, %15
    mir.br loop_0.header(%17, %16)
  __range_panic_0:
    %29 = mir.global_addr @__panic_msg_0

		return 10
	end 'case1' else if x == 2 'case2'
		let r = try mayFail()
		return r
	end 'case2' else 'default'
		return 30
	end 'default'
end 'helper'

function main() returns ExitCode
	return try helper(3) otherwise 99
end 'main'

// Test: if-try-else-if-plain-after-binding

typealias Integer = int(i64.min to i64.max)

enum MyError implements Error
	failed
end 'MyError'

function mayFail() returns Integer throws MyError
	throw MyError.failed
end 'mayFail'

function main() returns ExitCode
	let x = 2
	var result = 0
	if let v = try mayFail() 'check'
		result = v
	end 'check' else if x == 2 'two'
		result = 22
	end 'two' else 'fallback'
		result = 99
	end 'fallback'
	return result
end 'main'
---
ExitCode: 22
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    mir.br check_0.else()
  check_0.else:
    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp eq, %0, %8
    mir.cond_br %9 [then: two_0(), else: fallback_0()]
  two_0:
    %10 = mir.mov_imm 22 : i64
    mir.br two_0.merge(%10)
  fallback_0:
    %11 = mir.mov_imm 99 : i64
    mir.br two_0.merge(%11)
  two_0.merge:
    mir.br check_0.merge(%13)
  check_0.merge:
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %14, %15
    mir.cond_br %16 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_52ac43ba6b16b531
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %14
  }
}
---

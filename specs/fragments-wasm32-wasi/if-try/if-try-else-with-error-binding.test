    %26 = mir.mov_imm 2 : i64
    mir.br inline_cont_main_0(%25, %26)
  inlined_mayFail_4:
    %27 = mir.mov_imm 42 : i64
    %28 = mir.mov_imm 0 : i64
    mir.br inline_cont_main_0(%27, %28)
  inline_cont_main_0:
    %4 = mir.mov_imm 0 : i64
    %5 = mir.cmp eq, %30, %4
    mir.cond_br %5 [then: check_0(), else: err_0()]
  check_0:
    %6 = mir.mov_imm 100 : i64
    mir.br check_0.merge(%6)
  err_0:
    %7 = mir.mov_imm 1 : i64
    %8 = mir.sub.i64 %30, %7
    %10 = mir.mov_imm 0 : i64
    %11 = mir.cmp eq, %8, %10
    mir.cond_br %11 [then: kind_0.case0(), else: kind_0.next0()]
  kind_0.merge:
    mir.br check_0.merge(%17)
  kind_0.case0:
    %12 = mir.mov_imm 50 : i64
    mir.br kind_0.merge(%12)
  kind_0.next0:
    %13 = mir.mov_imm 1 : i64
    %14 = mir.cmp eq, %8, %13
    mir.cond_br %14 [then: kind_0.case1(), else: kind_0.merge(%0)]
  kind_0.case1:
    %15 = mir.mov_imm 60 : i64
    mir.br kind_0.merge(%15)
  check_0.merge:
    %31 = mir.mov_imm 125 : i64
    %32 = mir.cmp ugt, %18, %31
    mir.cond_br %32 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %33 = mir.global_addr @__panic_msg_0
    %34 = mir.call @mrt_panic(%33)
  __range_ok_0:
    mir.ret %18
  }
}

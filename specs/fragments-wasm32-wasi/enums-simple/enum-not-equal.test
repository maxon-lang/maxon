// Test: enum-not-equal
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s = Status.pending
	let result = match s 'check'
		active gives 0
		pending gives 1
		done gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1

// Test: enum-assignment
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	var c = Color.red
	c = Color.blue
	let result = match c 'check'
		red gives 0
		green gives 0
		blue gives 1
	end 'check'
	return result
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 2 : i64
    mir.br check_0.next0()
  check_0.merge:
    %16 = mir.mov_imm 255 : i64
    %17 = mir.cmp ugt, %15, %16
    mir.cond_br %17 [then: __range_panic_0(), else: __range_ok_0()]
  check_0.next0:
    %9 = mir.mov_imm 1 : i64
    %10 = mir.cmp eq, %1, %9
    mir.cond_br %10 [then: check_0.merge(%0), else: check_0.next1()]
  check_0.next1:
    %12 = mir.mov_imm 2 : i64
    %13 = mir.cmp eq, %1, %12
    mir.cond_br %13 [then: check_0.case2(), else: check_0.merge(%0)]
  check_0.case2:
    %14 = mir.mov_imm 1 : i64
    mir.br check_0.merge(%14)
  __range_panic_0:
    %18 = mir.global_addr @__panic_msg_0
    %19 = mir.call @mrt_panic(%18)
  __range_ok_0:
    mir.ret %15
  }
}
---

// Test: enum-function-param
enum Status
	on
	off
end 'Status'

function isOn(s Status) returns bool
	let result = match s 'check'
		on gives true
		off gives false
	end 'check'
	return result
end 'isOn'

function main() returns ExitCode
	let status = Status.on
	if isOn(status) 'test'
		return 1
	end 'test'
	return 0
end 'main'

// Test: enum-comparison
enum Status
	pending
	active
	done
end 'Status'

function main() returns ExitCode
	let s1 = Status.pending
	match s1 'check'
		pending then return 1
		active then return 0
		done then return 0
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    mir.br check_1.case0()
  check_1.case0:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

// Test: mixed-export-fields

typealias Integer = int(i64.min to i64.max)

type Box
	export var value as Integer
	var secret as Integer

	static function create(v Integer, s Integer) returns Self
		return Box{value: v, secret: s}
	end 'create'

	function getSecret() returns Integer
		return secret
	end 'getSecret'
end 'Box'

function main() returns ExitCode
	let b = Box.create(20, s: 22)
	return b.value + b.getSecret()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 20 : i64
    %1 = mir.mov_imm 22 : i64
    %8 = mir.mov_imm 16 : i64
    %9 = mir.call @mrt_alloc(%8)
    mir.store %0, %9, 0 width: qword
    mir.store %1, %9, 8 width: qword
    %4 = mir.load %9, 0 width: qword
    %10 = mir.load %9, 8 width: qword
    %7 = mir.add.i64 %4, %10
    %11 = mir.mov_imm 125 : i64
    %12 = mir.cmp ugt, %7, %11
    mir.cond_br %12 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %13 = mir.global_addr @__panic_msg_0
    %14 = mir.call @mrt_panic(%13)
  __range_ok_0:
    mir.ret %7
  }
}

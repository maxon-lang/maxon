module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 5 : i64
    %7 = mir.mov_imm 16 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %0, %8, 0 width: qword
    mir.store %1, %8, 8 width: qword
    %9 = mir.load %8, 0 width: qword
    %10 = mir.mov_imm 1 : i64
    %11 = mir.add.i64 %9, %10
    mir.store %11, %8, 0 width: qword
    %12 = mir.load %8, 0 width: qword
    %13 = mir.mov_imm 255 : i64
    %14 = mir.cmp ugt, %12, %13
    mir.cond_br %14 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %15 = mir.global_addr @__panic_msg_0
    %16 = mir.call @mrt_panic(%15)
  __range_ok_0:
    mir.ret %12
  }
}

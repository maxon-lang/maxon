// Test: with-parameters

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(10, b: 20)
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @with-parameters.add(local0: i64, local1: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %4 = mir.param local1 : i64
    %2 = mir.add.i64 %3, %4
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 20 : i64
    %2 = mir.call @with-parameters.add(%0, %1)
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %2, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %7 = mir.global_addr @__panic_msg_0
    %8 = mir.call @mrt_panic(%7)
  __range_ok_0:
    mir.ret %2
  }
}
---

// Test: with-parameters

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	return add(10, b: 20)
end 'main'
---
ExitCode: 30
---
module {
  func @with-parameters.add(ptr: i64, ptr: i64) -> i64 {
  entry:
    %3 = mir.param 0 : StdI64
    %4 = mir.param 1 : StdI64
    %2 = mir.add.i64 %3, %4
    %5 = mir.mov_imm -9223372036854775807 : i64
    %6 = mir.cmp lt, %2, %5
    mir.cond_br %6 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %9 = mir.global_addr @__panic_msg_0
    %10 = mir.call @mrt_panic(%9)
  __range_ok_0:
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 20 : i64
    %2 = mir.call @with-parameters.add(%0, %1)
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %2, %7
    mir.cond_br %8 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %11 = mir.global_addr @__panic_msg_1
    %12 = mir.call @mrt_panic(%11)
  __range_ok_1:
    mir.ret %2
  }
}
---

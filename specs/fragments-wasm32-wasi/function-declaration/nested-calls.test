// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function quadruple(x Integer) returns Integer
	return double(double(x))
end 'quadruple'

function main() returns ExitCode
	return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @nested-calls.double(ptr: i64) -> i64 {
  entry:
    %3 = mir.param 0 : StdI64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mul.i64 %3, %1
    %4 = mir.mov_imm -9223372036854775807 : i64
    %5 = mir.cmp lt, %2, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %10 = mir.global_addr @__panic_msg_0
    %11 = mir.call @mrt_panic(%10)
  __range_ok_0:
    mir.ret %2
  }
  func @nested-calls.quadruple(ptr: i64) -> i64 {
  entry:
    %3 = mir.param 0 : StdI64
    %1 = mir.call @nested-calls.double(%3)
    %2 = mir.call @nested-calls.double(%1)
    %6 = mir.mov_imm -9223372036854775807 : i64
    %7 = mir.cmp lt, %2, %6
    mir.cond_br %7 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %12 = mir.global_addr @__panic_msg_1
    %13 = mir.call @mrt_panic(%12)
  __range_ok_1:
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    %1 = mir.call @nested-calls.quadruple(%0)
    %8 = mir.mov_imm 125 : i64
    %9 = mir.cmp ugt, %1, %8
    mir.cond_br %9 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %14 = mir.global_addr @__panic_msg_2
    %15 = mir.call @mrt_panic(%14)
  __range_ok_2:
    mir.ret %1
  }
}
---

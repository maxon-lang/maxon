// Test: nested-calls

typealias Integer = int(i64.min to i64.max)

function double(x Integer) returns Integer
	return x * 2
end 'double'

function quadruple(x Integer) returns Integer
	return double(double(x))
end 'quadruple'

function main() returns ExitCode
	return quadruple(3)
end 'main'
---
ExitCode: 12
---
module {
  func @nested-calls.double(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : StdI64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mul.i64 %3, %1
    mir.ret %2
  }
  func @nested-calls.quadruple(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : StdI64
    %1 = mir.call @nested-calls.double(%3)
    %2 = mir.call @nested-calls.double(%1)
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    %1 = mir.call @nested-calls.quadruple(%0)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %1, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %1
  }
}
---

// Test: simple-function

typealias Integer = int(i64.min to i64.max)

function add() returns Integer
	return 3 + 4
end 'add'

function main() returns ExitCode
	return add()
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @function-declaration.main() -> u8 {
  entry:
    %1 = mir.mov_imm 7 : i64
    mir.ret %1
  }
}
---

// Test: match-statements.simple
function main() returns ExitCode
	let x = 2
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    mir.br check_0.next0()
  check_0.next0:
    %5 = mir.mov_imm 2 : i64
    %6 = mir.cmp eq, %0, %5
    mir.cond_br %6 [then: check_0.case1(), else: check_0.case2()]
  check_0.case1:
    %7 = mir.mov_imm 20 : i64
    mir.ret %7
  check_0.case2:
    %8 = mir.mov_imm 0 : i64
    mir.ret %8
  }
}
---

// Test: match-statements.or-patterns-first
function main() returns ExitCode
	let x = 1
	match x 'check'
		1 or 2 then return 10
		3 or 4 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    %7 = mir.mov_imm 10 : i64
    mir.ret %7
  }
}
---

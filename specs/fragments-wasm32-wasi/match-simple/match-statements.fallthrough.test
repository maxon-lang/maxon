// Test: match-statements.fallthrough
function main() returns ExitCode
	let x = 1
	var result = 0
	match x 'check'
		1 then result = result + 10 and fallthrough
		2 then result = result + 20
		default then result = result + 100
	end 'check'
	return result
end 'main'
---
ExitCode: 30
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    %1 = mir.mov_imm 0 : i64
    mir.br check_1.case0()
  check_1.merge:
    %19 = mir.mov_imm 125 : i64
    %20 = mir.cmp ugt, %17, %19
    mir.cond_br %20 [then: __range_panic_3(), else: __range_ok_3()]
  check_1.case0:
    %7 = mir.mov_imm 10 : i64
    %8 = mir.add.i64 %1, %7
    mir.br check_1.case1(%8)
  check_1.case1:
    %12 = mir.mov_imm 20 : i64
    %13 = mir.add.i64 %18, %12
    mir.br check_1.merge(%13)
  __range_panic_3:
    %21 = mir.global_addr @__panic_msg_5
    %22 = mir.call @mrt_panic(%21)
  __range_ok_3:
    mir.ret %17
  }
}
---

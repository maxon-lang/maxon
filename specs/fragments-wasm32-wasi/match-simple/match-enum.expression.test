// Test: match-enum.expression
enum Status
	pending
	approved
	rejected
end 'Status'

function main() returns ExitCode
	let s = Status.approved
	let code = match s 'eval'
		pending gives 0
		approved gives 1
		rejected gives 2
	end 'eval'
	return code
end 'main'

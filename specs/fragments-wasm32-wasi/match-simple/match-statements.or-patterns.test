// Test: match-statements.or-patterns
function main() returns ExitCode
	let x = 3
	match x 'check'
		1 or 2 then return 10
		3 or 4 or 5 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    mir.br check_1.next0()
  check_1.next0:
    %8 = mir.mov_imm 3 : i64
    %9 = mir.cmp eq, %0, %8
    %10 = mir.mov_imm 4 : i64
    %11 = mir.cmp eq, %0, %10
    %12 = mir.or.i64 %9, %11
    %13 = mir.mov_imm 5 : i64
    %14 = mir.cmp eq, %0, %13
    %15 = mir.or.i64 %12, %14
    mir.cond_br %15 [then: check_1.case1(), else: check_1.case2()]
  check_1.case1:
    %16 = mir.mov_imm 20 : i64
    mir.ret %16
  check_1.case2:
    %17 = mir.mov_imm 0 : i64
    mir.ret %17
  }
}
---

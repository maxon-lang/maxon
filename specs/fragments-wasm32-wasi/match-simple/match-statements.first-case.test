// Test: match-statements.first-case
function main() returns ExitCode
	let x = 1
	match x 'check'
		1 then return 10
		2 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 10
---
// CompiledIR
module {
  func @match-simple.main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    mir.br check_1.case0()
  check_1.case0:
    %4 = mir.mov_imm 10 : i64
    mir.ret %4
  }
}
---

// Test: match-expression.default
function main() returns ExitCode
	let x = 99
	let result = match x 'eval'
		1 gives 10
		2 gives 20
		default gives 0
	end 'eval'
	return result
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 99 : i64
    mir.br eval_0.next0()
  eval_0.merge:
    %13 = mir.mov_imm 255 : i64
    %14 = mir.cmp ugt, %12, %13
    mir.cond_br %14 [then: __range_panic_0(), else: __range_ok_0()]
  eval_0.next0:
    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp eq, %0, %8
    mir.cond_br %9 [then: eval_0.case1(), else: eval_0.case2()]
  eval_0.case1:
    %10 = mir.mov_imm 20 : i64
    mir.br eval_0.merge(%10)
  eval_0.case2:
    %11 = mir.mov_imm 0 : i64
    mir.br eval_0.merge(%11)
  __range_panic_0:
    %15 = mir.global_addr @__panic_msg_0
    %16 = mir.call @mrt_panic(%15)
  __range_ok_0:
    mir.ret %12
  }
}
---

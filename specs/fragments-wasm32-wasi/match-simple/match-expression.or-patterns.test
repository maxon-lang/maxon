// Test: match-expression.or-patterns
function main() returns ExitCode
	let x = 4
	let result = match x 'eval'
		1 or 2 gives 10
		3 or 4 gives 20
		default gives 0
	end 'eval'
	return result
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 4 : i64
    mir.br eval_1.next0()
  eval_1.merge:
    %19 = mir.mov_imm 125 : i64
    %20 = mir.cmp ugt, %18, %19
    mir.cond_br %20 [then: __range_panic_1(), else: __range_ok_1()]
  eval_1.next0:
    %11 = mir.mov_imm 3 : i64
    %12 = mir.cmp eq, %0, %11
    %13 = mir.mov_imm 4 : i64
    %14 = mir.cmp eq, %0, %13
    %15 = mir.or.i64 %12, %14
    mir.cond_br %15 [then: eval_1.case1(), else: eval_1.case2()]
  eval_1.case1:
    %16 = mir.mov_imm 20 : i64
    mir.br eval_1.merge(%16)
  eval_1.case2:
    %17 = mir.mov_imm 0 : i64
    mir.br eval_1.merge(%17)
  __range_panic_1:
    %21 = mir.global_addr @__panic_msg_3
    %22 = mir.call @mrt_panic(%21)
  __range_ok_1:
    mir.ret %18
  }
}
---

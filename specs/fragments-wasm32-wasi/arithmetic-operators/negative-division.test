// Test: negative-division
function main() returns ExitCode
	let neg = -7
	let a = neg / 2           // -7/2 = -3 (truncating toward zero)
	if a == -3 'pass'
			return 0
	end 'pass'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 7 : i64
    %1 = mir.neg.i64 %0
    %3 = mir.mov_imm 2 : i64
    %4 = mir.div.i64 %1, %3
    %6 = mir.mov_imm 3 : i64
    %7 = mir.neg.i64 %6
    %8 = mir.cmp eq, %4, %7
    mir.cond_br %8 [then: pass_0(), else: pass_0.after()]
  pass_0:
    %9 = mir.mov_imm 0 : i64
    mir.ret %9
  pass_0.after:
    %10 = mir.mov_imm 1 : i64
    mir.ret %10
  }
}
---

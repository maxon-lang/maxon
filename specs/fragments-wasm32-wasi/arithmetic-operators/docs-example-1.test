// Test: docs-example-1
function main() returns ExitCode
	let a = 10
	let b = 3
	let sum = a + b          // 13
	let diff = a - b         // 7
	let prod = a * b         // 30
	let div = a / b          // 3 (truncating integer division)
	let rem = a mod b        // 1

	// Use the values
	print("{sum}\n")
	print("{diff}\n")
	print("{prod}\n")
	print("{div}\n")
	print("{rem}\n")

	return 0
end 'main'

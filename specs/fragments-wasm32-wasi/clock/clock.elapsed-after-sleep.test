// Test: clock.elapsed-after-sleep
function main() returns ExitCode
		let start = Clock.nowMs()
		sleep(30)
		let elapsed = Clock.elapsedMs(start)
		var score = 0
		if elapsed > 0 'advanced'
				score = score + 1
		end 'advanced'
		if elapsed < 10000 'bounded'
				score = score + 1
		end 'bounded'
		print("score={score}\n")
		return 0
end 'main'
---
Stdout: ```
score=2
```

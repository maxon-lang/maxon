// Test: clock.elapsed-clamps-on-equal
function main() returns ExitCode
		let start = Clock.nowMs()
		let elapsed = Clock.elapsedMs(start)
		var ok = 0
		if elapsed < 10000 'bounded'
				ok = 1
		end 'bounded'
		print("ok={ok}\n")
		return 0
end 'main'
---
Stdout: ```
ok=1
```

// Test: clock.now-monotonic
function main() returns ExitCode
		let a = Clock.nowMs()
		let b = Clock.nowMs()
		var score = 0
		if a > 0 'positive'
				score = score + 1
		end 'positive'
		if b >= a 'nondecreasing'
				score = score + 1
		end 'nondecreasing'
		print("score={score}\n")
		return 0
end 'main'
---
Stdout: ```
score=2
```

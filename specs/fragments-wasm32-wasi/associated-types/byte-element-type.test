// Test: byte-element-type

typealias Byte = int(0 to u8.max)

interface ByteSource uses Element
	function getByte() returns Element
end 'ByteSource'

type SingleByte implements ByteSource with Byte
	let b as Byte

	function getByte() returns Byte
		return b
	end 'getByte'

	static function create(b Byte) returns Self
		return Self{b: b}
	end 'create'
end 'SingleByte'

function main() returns ExitCode
	let s = SingleByte.create(42 as Byte)
	let b = s.getByte()
	return b
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @SingleByte.getByte(local0: i64) -> u8 {
  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0 width: byte
    %4 = mir.mov_imm 255 : i64
    %5 = mir.cmp ugt, %1, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0 width: byte
    %3 = mir.call @SingleByte.getByte(%5)
    %6 = mir.mov_imm 125 : i64
    %7 = mir.cmp ugt, %3, %6
    mir.cond_br %7 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %8 = mir.global_addr @__panic_msg_1
    %9 = mir.call @mrt_panic(%8)
  __range_ok_0:
    mir.ret %3
  }
}
---

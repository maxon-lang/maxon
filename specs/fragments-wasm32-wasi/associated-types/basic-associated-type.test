  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.mov_imm 0 : i64
    %8 = mir.call @stdlib.__mm_alloc(%5, %6, %7)
    mir.store %1, %8, 0 width: qword
    %9 = mir.load %8, 0 width: qword
    %10 = mir.call @mm_drop(%8)
    %11 = mir.mov_imm 125 : i64
    %12 = mir.cmp ugt, %9, %11
    mir.cond_br %12 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %13 = mir.global_addr @__panic_msg_1afe48c1b37102ea
    %14 = mir.call @mrt_panic(%13)
  __range_ok_0:
    mir.ret %9
  }
}

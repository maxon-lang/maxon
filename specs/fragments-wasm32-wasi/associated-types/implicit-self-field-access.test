// Test: implicit-self-field-access

typealias Integer = int(i64.min to i64.max)

interface Countable
	function getCount() returns Integer
end 'Countable'

type Counter implements Countable
	let count as Integer

	function getCount() returns Integer
		return count
	end 'getCount'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	let c = Counter.create(42)
	return c.getCount()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    %5 = mir.mov_imm 8 : i64
    %6 = mir.mov_imm 0 : i64
    %7 = mir.call @stdlib.__mm_alloc(%5, %6)
    mir.store %1, %7, 0 width: qword
    %8 = mir.load %7, 0 width: qword
    %9 = mir.call @mm_drop(%7)
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %8, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %12 = mir.global_addr @__panic_msg_ca8f68beb01289bc
    %13 = mir.call @mrt_panic(%12)
  __range_ok_0:
    mir.ret %8
  }
}

// Test: alias-of-alias-forward
typealias Counter = Tally
typealias Tally = int(0 to 1000)

function main() returns ExitCode
	let c = 7 as Counter
	return c
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @type-alias-resolution.main() -> u8 {
  entry:
    %0 = mir.mov_imm 7 : i64
    mir.ret %0
  }
}
---

// Test: bitwise-not-masking
function main() returns ExitCode
	let value = 125    // 0x7D
	// Clear lower 4 bits: 125 and not 15 = 112
	return value and not 15
end 'main'
---
ExitCode: 112
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 112 : i64
    mir.ret %5
  }
}
---

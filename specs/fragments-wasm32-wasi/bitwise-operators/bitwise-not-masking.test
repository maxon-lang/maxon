// Test: bitwise-not-masking
function main() returns ExitCode
	let value = 125    // 0x7D
	// Clear lower 4 bits: 125 and not 15 = 112
	return value and not 15
end 'main'
---
ExitCode: 112
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 125 : i64
    %2 = mir.mov_imm 15 : i64
    %3 = mir.not.i64 %2
    %4 = mir.and.i64 %0, %3
    %5 = mir.mov_imm 125 : i64
    %6 = mir.cmp ugt, %4, %5
    mir.cond_br %6 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %7 = mir.global_addr @__panic_msg_1
    %8 = mir.call @mrt_panic(%7)
  __range_ok_1:
    mir.ret %4
  }
}
---

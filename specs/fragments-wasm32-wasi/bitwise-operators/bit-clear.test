// Test: bit-clear
function main() returns ExitCode
	var flags = 7        // binary 111
	// Clear bit 1 using xor
	flags = flags xor 2
	return flags         // 5 (binary 101)
end 'main'
---
ExitCode: 5
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %3 = mir.mov_imm 5 : i64
    mir.ret %3
  }
}
---

    mir.cond_br %4 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %5 = mir.global_addr @__panic_msg_0
    %6 = mir.call @mrt_panic(%5)
  __range_ok_0:
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @check(%0)
    %2 = mir.mov_imm 125 : i64
    %3 = mir.cmp ugt, %1, %2
    mir.cond_br %3 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %4 = mir.global_addr @__panic_msg_1
    %5 = mir.call @mrt_panic(%4)
  __range_ok_1:

// Test: range-check-panic.in-range
typealias SmallInt = int(0 to 10)

function check(x SmallInt) returns SmallInt
  return x
end 'check'

function main() returns ExitCode
  return check(5)
end 'main'
---
ExitCode: 5
---
module {
  func @range-check-panic.check(local0: i64) -> u8 {
  entry:
    %1 = mir.param local0 : StdI64
    %2 = mir.mov_imm 10 : i64
    %3 = mir.cmp ugt, %1, %2
    mir.cond_br %3 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @range-check-panic.check(%0)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %1, %4
    mir.cond_br %5 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %8 = mir.global_addr @__panic_msg_1
    %9 = mir.call @mrt_panic(%8)
  __range_ok_1:
    mir.ret %1
  }
}
---

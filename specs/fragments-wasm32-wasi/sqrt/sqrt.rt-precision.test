// Test: sqrt.rt-precision
function main() returns ExitCode
	let args = CommandLine.args()
	let x = try float.fromString(try args.get(1) otherwise "") otherwise 0.0
	let check = sqrt(x) * sqrt(x)
	return trunc(check)
end 'main'

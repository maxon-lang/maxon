// Test: boolean
function main() returns ExitCode
	let flag = true
	if flag 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 1 : i64
    mir.cond_br %0 [then: check_1(), else: check_1.after()]
  check_1:
    %2 = mir.mov_imm 1 : i64
    mir.ret %2
  check_1.after:
    %3 = mir.mov_imm 0 : i64
    mir.ret %3
  }
}
---

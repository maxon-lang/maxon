// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
	let x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5368709120 : i64
    %2 = mir.mov_imm 5368709120 : i64
    %3 = mir.cmp eq, %0, %2
    mir.cond_br %3 [then: check_1(), else: check_1.after()]
  check_1:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  check_1.after:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

// Test: large-hex-literal-underscore
// Test large hex literal with underscore separators
function main() returns ExitCode
	let x = 0x0000_0001_4000_0000
	if x == 5368709120 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @literals.main() -> u8 {
  entry:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  }
}

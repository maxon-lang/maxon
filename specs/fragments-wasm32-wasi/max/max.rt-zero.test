// Test: max.rt-zero
function main() returns ExitCode
	let args = CommandLine.args()
	let a = try float.fromString(try args.get(1) otherwise "") otherwise 0.0
	let b = try float.fromString(try args.get(2) otherwise "") otherwise 0.0
	let result = max(a, b)
	if result == 0.0 'check'
		return 0
	end 'check'
	return 1
end 'main'

// Test: implicit-method-call-wrong-type
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

type Container
	var items as IntArray

	function addWrong(s String)
	items.push(s)
	end 'addWrong'
end 'Container'

function main() returns ExitCode
	return 0
end 'main'

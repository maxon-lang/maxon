// Test: typealias-forward-reference

typealias Integer = int(i64.min to i64.max)

typealias FooArray = Array with Foo

type Foo
	let value as Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Foo'

function main() returns ExitCode
	var arr = FooArray.create()
	arr.push(Foo.create(42))
	return arr.count() - 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Foo
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 42 : i64
    %13 = mir.mov_imm 8 : i64
    %14 = mir.mov_imm 0 : i64
    %15 = mir.call @stdlib.__mm_alloc(%13, %14)
    %16 = mir.call @stdlib.__mm_incref(%15)
    mir.store %4, %15, 0 width: qword
    %6 = mir.global_addr @__layout_Array_Foo
    %7 = mir.call @Array.push(%2, %15, %6)
    %9 = mir.global_addr @__layout_Array_Foo
    %10 = mir.call @Array.count(%2, %9)
    %11 = mir.mov_imm 1 : i64
    %12 = mir.sub.i64 %10, %11
    %17 = mir.call @__mm_decref_maybenull_helper(%2)
    %18 = mir.mov_imm 125 : i64
    %19 = mir.cmp ugt, %12, %18
    mir.cond_br %19 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %20 = mir.global_addr @__panic_msg_bfd2adf851a5ca74
    %21 = mir.call @mrt_panic(%20)
  __range_ok_0:
    mir.ret %12
  }
}

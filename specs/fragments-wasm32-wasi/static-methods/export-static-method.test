// Test: export-static-method

typealias Integer = int(i64.min to i64.max)

type Factory
	export var id Integer

	export static function create(val Integer) returns Factory
		return Factory{id: val}
	end 'create'

	export static function zero() returns Factory
		return Factory.create(0)
	end 'zero'
end 'Factory'

function main() returns ExitCode
	let f1 = Factory.create(100)
	let f2 = Factory.zero()
	return f1.id + f2.id
end 'main'
---
ExitCode: 100
---
// CompiledIR
module {
  func @static-methods.main() -> u8 {
  entry:
    %0 = mir.mov_imm 100 : i64
    %8 = mir.mov_imm 8 : i64
    %9 = mir.call @mrt_alloc(%8)
    mir.store %0, %9, 0
    %10 = mir.mov_imm 0 : i64
    %11 = mir.mov_imm 8 : i64
    %12 = mir.call @mrt_alloc(%11)
    mir.store %10, %12, 0
    %4 = mir.load %9, 0
    %6 = mir.load %12, 0
    %7 = mir.add.i64 %4, %6
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %7, %13
    mir.cond_br %14 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %15 = mir.global_addr @__panic_msg_1
    %16 = mir.call @mrt_panic(%15)
  __range_ok_1:
    mir.ret %7
  }
}
---

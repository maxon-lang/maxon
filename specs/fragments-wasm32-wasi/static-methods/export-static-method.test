    %13 = mir.mov_imm 0 : i64
    %14 = mir.mov_imm 8 : i64
    %15 = mir.mov_imm 0 : i64
    %16 = mir.call @stdlib.__mm_alloc(%14, %15)
    mir.store %13, %16, 0 width: qword
    %6 = mir.load %12, 0 width: qword
    %8 = mir.load %16, 0 width: qword
    %9 = mir.add.i64 %6, %8
    %18 = mir.call @mm_drop(%12)
    %17 = mir.call @mm_drop(%16)
    %19 = mir.mov_imm 125 : i64

// Test: export-static-method

typealias Integer = int(i64.min to i64.max)

type Factory
	export var id Integer

	export static function create(val Integer) returns Factory
		return Factory{id: val}
	end 'create'

	export static function zero() returns Factory
		return Factory.create(0)
	end 'zero'
end 'Factory'

function main() returns ExitCode
	let f1 = Factory.create(100)
	let f2 = Factory.zero()
	return f1.id + f2.id
end 'main'
---
ExitCode: 100
---
// CompiledIR
module {
  func @Factory.create(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %0 = mir.mov_imm 8 : i64
    %1 = mir.call @mrt_alloc(%0)
    mir.store %3, %1, 0
    mir.ret %1
  }
  func @Factory.zero() -> i64 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.call @Factory.create(%0)
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 100 : i64
    %1 = mir.call @Factory.create(%0)
    %2 = mir.call @Factory.zero()
    %4 = mir.load %1, 0
    %6 = mir.load %2, 0
    %7 = mir.add.i64 %4, %6
    %8 = mir.mov_imm 125 : i64
    %9 = mir.cmp ugt, %7, %8
    mir.cond_br %9 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %10 = mir.global_addr @__panic_msg_0
    %11 = mir.call @mrt_panic(%10)
  __range_ok_0:
    mir.ret %7
  }
}
---

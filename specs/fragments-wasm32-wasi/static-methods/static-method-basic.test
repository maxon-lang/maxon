// Test: static-method-basic

typealias Integer = int(i64.min to i64.max)

type Box
	export var value Integer

	static function make(v Integer) returns Box
		return Box{value: v}
	end 'make'
end 'Box'

function main() returns ExitCode
	let b = Box.make(42)
	return b.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Box.make(local0: i64) -> i64 {
  entry:
    %4 = mir.param local0 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @mrt_alloc(%1)
    mir.store %4, %2, 0
    mir.ret %2
  }
  func @static-methods.main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    %1 = mir.call @Box.make(%0)
    %3 = mir.load %1, 0
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

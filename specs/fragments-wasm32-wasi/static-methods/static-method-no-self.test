// Test: static-method-no-self

typealias Integer = int(i64.min to i64.max)

type Math
	var unused Integer

	static function add(a Integer, b Integer) returns Integer
		return a + b
	end 'add'
end 'Math'

function main() returns ExitCode
	return Math.add(20, b: 22)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Math.add(local0: i64, local1: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    %6 = mir.param local1 : i64
    %4 = mir.add.i64 %5, %6
    mir.ret %4
  }
  func @static-methods.main() -> u8 {
  entry:
    %0 = mir.mov_imm 20 : i64
    %1 = mir.mov_imm 22 : i64
    %2 = mir.call @Math.add(%0, %1)
    %3 = mir.mov_imm 125 : i64
    %4 = mir.cmp ugt, %2, %3
    mir.cond_br %4 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %5 = mir.global_addr @__panic_msg_1
    %6 = mir.call @mrt_panic(%5)
  __range_ok_1:
    mir.ret %2
  }
}
---

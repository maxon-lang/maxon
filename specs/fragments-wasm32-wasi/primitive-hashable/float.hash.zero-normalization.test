// Test: float.hash.zero-normalization
function main() returns ExitCode
	let pos = 0.0
	let neg = -0.0
	let h1 = pos.hash()
	let h2 = neg.hash()
	if h1 == h2 'eq'
		return 1
	end 'eq'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : f64
    %1 = mir.mov_imm 0 : f64
    %2 = mir.mov_imm 0 : f64
    %3 = mir.sub.f64 %2, %1
    %5 = mir.call @float.hash(%0)
    %7 = mir.call @float.hash(%3)
    %10 = mir.cmp eq, %5, %7
    mir.cond_br %10 [then: eq_0(), else: eq_0.after()]
  eq_0:
    %11 = mir.mov_imm 1 : i64
    mir.ret %11
  eq_0.after:
    %12 = mir.mov_imm 0 : i64
    mir.ret %12
  }
}
---

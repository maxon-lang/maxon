	end 'create'
end 'Bag'

function main() returns ExitCode
	var a = Bag.create()
	var b = Bag.create()
	a.items.push(1)
	a.items.push(2)
	b.items.push(9)
	return a.items.count() * 10 + b.items.count()
end 'main'

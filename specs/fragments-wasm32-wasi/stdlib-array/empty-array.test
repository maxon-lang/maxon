// Test: empty-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	if arr.count() != 0 'check'
		return 1
	end 'check'
	if arr.isEmpty() == false 'empty'
		return 2
	end 'empty'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.global_addr @__layout_Array_Int
    %5 = mir.call @Array.count(%2, %4)
    %6 = mir.mov_imm 0 : i64
    %7 = mir.cmp ne, %5, %6
    mir.cond_br %7 [then: check_0(), else: check_0.after()]
  check_0:
    %21 = mir.call @__mm_decref_maybenull_helper(%2)
    %8 = mir.mov_imm 1 : i64
    mir.ret %8
  check_0.after:
    %16 = mir.load %2, 0 width: qword
    %17 = mir.load %16, 8 width: qword
    %18 = mir.mov_imm 0 : i64
    %19 = mir.cmp eq, %17, %18
    %20 = mir.call @__mm_decref_maybenull_helper(%2)
    %12 = mir.mov_imm 0 : i64
    %13 = mir.cmp eq, %19, %12
    mir.cond_br %13 [then: empty_0(), else: empty_0.after()]
  empty_0:
    %14 = mir.mov_imm 2 : i64
    mir.ret %14
  empty_0.after:
    %15 = mir.mov_imm 0 : i64
    mir.ret %15
  }
}
---

// Test: push-multiple
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)
	if arr.count() != 3 'check'
		return 1
	end 'check'
	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 10 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6 = mir.call @Array.push(%2, %4, %5)
    %8 = mir.mov_imm 20 : i64
    %9 = mir.global_addr @__layout_Array_Int
    %10 = mir.call @Array.push(%2, %8, %9)
    %12 = mir.mov_imm 30 : i64
    %13 = mir.global_addr @__layout_Array_Int
    %14 = mir.call @Array.push(%2, %12, %13)
    %16 = mir.global_addr @__layout_Array_Int
    %17 = mir.call @Array.count(%2, %16)
    %18 = mir.mov_imm 3 : i64
    %19 = mir.cmp ne, %17, %18
    %22 = mir.call @__mm_decref_maybenull_helper(%2)
    mir.cond_br %19 [then: check_0(), else: check_0.after()]
  check_0:
    %20 = mir.mov_imm 1 : i64
    mir.ret %20
  check_0.after:
    %21 = mir.mov_imm 0 : i64
    mir.ret %21
  }
}
---

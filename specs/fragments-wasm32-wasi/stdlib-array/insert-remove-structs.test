// Test: insert-remove-structs
typealias Int = int(i64.min to i64.max)

type Item
	export var id Int

	static function create(id Int) returns Self
		return Self{id: id}
	end 'create'
end 'Item'

typealias ItemArray = Array with Item

function main() returns ExitCode
	var arr = ItemArray.create()
	arr.push(Item.create(1))
	arr.push(Item.create(3))

	arr.insert(1, value: Item.create(2))

	let removed = try arr.remove(0) otherwise 'err'
		return 99
	end 'err'

	// removed.id==1, arr is now [Item{id:2}, Item{id:3}]
	return removed.id + arr.count()
end 'main'
---
ExitCode: 3
---

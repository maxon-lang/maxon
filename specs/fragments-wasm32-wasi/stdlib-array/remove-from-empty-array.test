module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 0 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6, %7 = mir.try_call @Array.remove(%2, %4, %5)
    %21 = mir.call @__mm_decref_maybenull_helper(%2)
    %8 = mir.mov_imm 0 : i64
    %9 = mir.cmp ne, %7, %8
    mir.cond_br %9 [then: try_0.otherwise(), else: try_0.merge(%6)]
  try_0.otherwise:
    %11 = mir.mov_imm 1 : i64
    %12 = mir.neg.i64 %11
    mir.br try_0.merge(%12)
  try_0.merge(%20: i64):
    %15 = mir.mov_imm 1 : i64
    %16 = mir.neg.i64 %15
    %17 = mir.cmp eq, %20, %16
    mir.cond_br %17 [then: check_0(), else: check_0.after()]
  check_0:
    %18 = mir.mov_imm 0 : i64
    mir.ret %18
  check_0.after:
    %19 = mir.mov_imm 1 : i64
    mir.ret %19
  }
}
---

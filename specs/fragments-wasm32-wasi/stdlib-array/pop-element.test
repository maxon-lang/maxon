// Test: pop-element
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)
	arr.push(30)

	let val = try arr.pop() otherwise -1
	if val != 30 'check'
		return 1
	end 'check'

	if arr.count() != 2 'cnt'
		return 3
	end 'cnt'

	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 10 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6 = mir.call @Array.push(%2, %4, %5)
    %8 = mir.mov_imm 20 : i64
    %9 = mir.global_addr @__layout_Array_Int
    %10 = mir.call @Array.push(%2, %8, %9)
    %12 = mir.mov_imm 30 : i64
    %13 = mir.global_addr @__layout_Array_Int
    %14 = mir.call @Array.push(%2, %12, %13)
    %16 = mir.global_addr @__layout_Array_Int
    %17, %18 = mir.try_call @Array.pop(%2, %16)
    %19 = mir.mov_imm 0 : i64
    %20 = mir.cmp ne, %18, %19
    mir.cond_br %20 [then: try_0.otherwise(), else: try_0.merge(%17)]
  try_0.otherwise:
    %22 = mir.mov_imm 1 : i64
    %23 = mir.neg.i64 %22
    mir.br try_0.merge(%23)
  try_0.merge(%36: i64):
    %26 = mir.mov_imm 30 : i64
    %27 = mir.cmp ne, %36, %26
    mir.cond_br %27 [then: check_0(), else: check_0.after()]
  check_0:
    %38 = mir.call @__mm_decref_maybenull_helper(%2)
    %28 = mir.mov_imm 1 : i64
    mir.ret %28
  check_0.after:
    %30 = mir.global_addr @__layout_Array_Int
    %31 = mir.call @Array.count(%2, %30)
    %32 = mir.mov_imm 2 : i64
    %33 = mir.cmp ne, %31, %32
    %37 = mir.call @__mm_decref_maybenull_helper(%2)
    mir.cond_br %33 [then: cnt_0(), else: cnt_0.after()]
  cnt_0:
    %34 = mir.mov_imm 3 : i64
    mir.ret %34
  cnt_0.after:
    %35 = mir.mov_imm 0 : i64
    mir.ret %35
  }
}

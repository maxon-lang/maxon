// Test: get-empty-module-level-array
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int
var arr = IntArray.create()

function main() returns ExitCode
	let val = try arr.get(0) otherwise -1
	if val == -1 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---

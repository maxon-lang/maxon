    %22 = mir.mov_imm 0 : i64
    %23 = mir.cmp ne, %21, %22
    mir.cond_br %23 [then: inlined_Array.get_1(), else: inlined_Array.get_2()]
  inlined_Array.get_1:
    %24 = mir.mov_imm 0 : i64
    %25 = mir.mov_imm 1 : i64
    mir.br inline_cont_main_0(%24, %25)
  inlined_Array.get_2:
    %26 = mir.mov_imm 0 : i64
    mir.br inline_cont_main_0(%20, %26)
  inline_cont_main_0:
    %6 = mir.mov_imm 0 : i64
    %7 = mir.cmp ne, %28, %6
    mir.cond_br %7 [then: try_0.otherwise(), else: try_0.merge(%27)]
  try_0.otherwise:
    %9 = mir.mov_imm 1 : i64
    %10 = mir.neg.i64 %9
    mir.br try_0.merge(%10)
  try_0.merge:
    %13 = mir.mov_imm 1 : i64
    %14 = mir.neg.i64 %13
    %15 = mir.cmp eq, %18, %14
    mir.cond_br %15 [then: check_0(), else: check_0.after()]
  check_0:
    %16 = mir.mov_imm 0 : i64
    mir.ret %16
  check_0.after:
    %17 = mir.mov_imm 1 : i64
    mir.ret %17
  }
}
---

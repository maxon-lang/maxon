// Test: remove-strings
typealias StringArray = Array with String

function main() returns ExitCode
	var arr = StringArray.create()
	arr.push("x")
	arr.push("y")
	arr.push("z")

	let removed = try arr.remove(1) otherwise ""
	print(removed)

	if arr.count() != 2 'cnt'
		return 1
	end 'cnt'

	let v0 = try arr.get(0) otherwise ""
	let v1 = try arr.get(1) otherwise ""
	print(v0)
	print(v1)
	return 0
end 'main'
---
ExitCode: 0
Stdout: ```
yxz
```

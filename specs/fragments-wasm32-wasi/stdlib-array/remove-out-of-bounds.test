// Test: remove-out-of-bounds
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)

	let removed = try arr.remove(5) otherwise -1
	if removed == -1 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 10 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6 = mir.call @Array.push(%2, %4, %5)
    %8 = mir.mov_imm 20 : i64
    %9 = mir.global_addr @__layout_Array_Int
    %10 = mir.call @Array.push(%2, %8, %9)
    %12 = mir.mov_imm 5 : i64
    %13 = mir.global_addr @__layout_Array_Int
    %14, %15 = mir.try_call @Array.remove(%2, %12, %13)
    %29 = mir.call @__mm_decref_maybenull_helper(%2)
    %16 = mir.mov_imm 0 : i64
    %17 = mir.cmp ne, %15, %16
    mir.cond_br %17 [then: try_0.otherwise(), else: try_0.merge(%14)]
  try_0.otherwise:
    %19 = mir.mov_imm 1 : i64
    %20 = mir.neg.i64 %19
    mir.br try_0.merge(%20)
  try_0.merge(%28: i64):
    %23 = mir.mov_imm 1 : i64
    %24 = mir.neg.i64 %23
    %25 = mir.cmp eq, %28, %24
    mir.cond_br %25 [then: check_0(), else: check_0.after()]
  check_0:
    %26 = mir.mov_imm 0 : i64
    mir.ret %26
  check_0.after:
    %27 = mir.mov_imm 1 : i64
    mir.ret %27
  }
}
---

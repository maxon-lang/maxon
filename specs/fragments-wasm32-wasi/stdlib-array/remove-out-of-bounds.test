// Test: remove-out-of-bounds
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.push(10)
	arr.push(20)

	let removed = try arr.remove(5) otherwise -1
	if removed == -1 'check'
		return 0
	end 'check'
	return 1
end 'main'

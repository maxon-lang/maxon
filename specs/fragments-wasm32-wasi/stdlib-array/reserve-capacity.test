// Test: reserve-capacity
typealias Int = int(i64.min to i64.max)
typealias IntArray = Array with Int

function main() returns ExitCode
	var arr = IntArray.create()
	arr.reserve(100)

	if arr.capacity() < 100 'cap'
		return 1
	end 'cap'

	if arr.count() != 0 'cnt'
		return 2
	end 'cnt'

	return 0
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.global_addr @__layout_Array_Int
    %2 = mir.call @Array.create(%1)
    %4 = mir.mov_imm 100 : i64
    %5 = mir.global_addr @__layout_Array_Int
    %6 = mir.call @Array.reserve(%2, %4, %5)
    %8 = mir.global_addr @__layout_Array_Int
    %9 = mir.call @Array.capacity(%2, %8)
    %10 = mir.mov_imm 100 : i64
    %11 = mir.cmp lt, %9, %10
    mir.cond_br %11 [then: cap_0(), else: cap_0.after()]
  cap_0:
    %21 = mir.call @__mm_decref_maybenull_helper(%2)
    %12 = mir.mov_imm 1 : i64
    mir.ret %12
  cap_0.after:
    %14 = mir.global_addr @__layout_Array_Int
    %15 = mir.call @Array.count(%2, %14)
    %16 = mir.mov_imm 0 : i64
    %17 = mir.cmp ne, %15, %16
    %20 = mir.call @__mm_decref_maybenull_helper(%2)
    mir.cond_br %17 [then: cnt_0(), else: cnt_0.after()]
  cnt_0:
    %18 = mir.mov_imm 2 : i64
    mir.ret %18
  cnt_0.after:
    %19 = mir.mov_imm 0 : i64
    mir.ret %19
  }
}
---

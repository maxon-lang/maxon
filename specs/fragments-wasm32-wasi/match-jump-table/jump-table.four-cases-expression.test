// Test: jump-table.four-cases-expression
enum Direction
		north
		south
		east
		west
end 'Direction'

function main() returns ExitCode
		let d = Direction.east
		let code = match d 'dir'
				north gives 10
				south gives 20
				east gives 30
				west gives 40
		end 'dir'
		return code
end 'main'

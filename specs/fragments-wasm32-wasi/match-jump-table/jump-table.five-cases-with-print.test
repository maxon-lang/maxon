// Test: jump-table.five-cases-with-print
enum Suit
		hearts
		diamonds
		clubs
		spades
		joker
end 'Suit'

function main() returns ExitCode
		let s = Suit.clubs
		match s 'check'
				hearts then print("hearts")
				diamonds then print("diamonds")
				clubs then print("clubs")
				spades then print("spades")
				joker then print("joker")
		end 'check'
		return 0
end 'main'
---
Stdout: ```
clubs
```

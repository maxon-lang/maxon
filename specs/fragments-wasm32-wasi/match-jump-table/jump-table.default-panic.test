// Test: jump-table.default-panic
enum Color
		red
		green
		blue
		yellow
end 'Color'

function main() returns ExitCode
		let c = Color.blue
		match c 'check'
				red then print("red")
				green then print("green")
				blue then print("blue")
				yellow then print("yellow")
				default panic("unknown")
		end 'check'
		return 0
end 'main'
---

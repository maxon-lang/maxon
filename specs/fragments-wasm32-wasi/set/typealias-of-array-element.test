// Test: typealias-of-array-element
typealias ByteArraySet = Set with ByteArray

function main() returns ExitCode
	var s = ByteArraySet.create()
	let key = ByteArray.create()
	s.insert(key)
	if s.count() != 1 'count'
		return 1
	end 'count'
	if not s.contains(key) 'present'
		return 2
	end 'present'
	return 0
end 'main'
---
ExitCode: 0

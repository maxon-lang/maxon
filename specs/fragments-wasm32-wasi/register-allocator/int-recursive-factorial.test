// Test: int-recursive-factorial

typealias Integer = int(i64.min to i64.max)

function factorial(n Integer) returns Integer
	if n <= 1 'base'
		return 1
	end 'base'
	return n * factorial(n - 1)
end 'factorial'

function main() returns ExitCode
	return factorial(5) mod 256
end 'main'
---
ExitCode: 120
---
// CompiledIR
module {
  func @factorial(local0: i64) -> i64 {
  entry:
    %11 = mir.param local0 : i64
    %2 = mir.mov_imm 1 : i64
    %3 = mir.cmp le, %11, %2
    mir.cond_br %3 [then: base_0(), else: base_0.after()]
  base_0:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  base_0.after:
    %7 = mir.mov_imm 1 : i64
    %8 = mir.sub.i64 %11, %7
    %9 = mir.call @factorial(%8)
    %10 = mir.mul.i64 %11, %9
    mir.ret %10
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @factorial(%0)
    %2 = mir.mov_imm 256 : i64
    %3 = mir.rem.i64 %1, %2
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %6 = mir.global_addr @__panic_msg_0
    %7 = mir.call @mrt_panic(%6)
  __range_ok_0:
    mir.ret %3
  }
}
---

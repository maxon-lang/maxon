// Test: int-value-live-across-nested-control
function main() returns ExitCode
	let sentinel = 100
	var total = 0
	var i = 0
	while i < 3 'outer'
		var j = 0
		while j < 3 'inner'
			if i == j 'diag'
				total = total + 1
			end 'diag'
			j = j + 1
		end 'inner'
		i = i + 1
	end 'outer'
	return sentinel + total
end 'main'
---
ExitCode: 103
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 100 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.mov_imm 0 : i64
    mir.br outer_0.header(%1, %2)
  outer_0.header:
    %4 = mir.mov_imm 3 : i64
    %5 = mir.cmp lt, %28, %4
    mir.cond_br %5 [then: outer_0(), else: outer_0.exit()]
  outer_0:
    %6 = mir.mov_imm 0 : i64
    mir.br inner_0.header(%27, %6)
  outer_0.exit:
    %9 = mir.add.i64 %0, %27
    %30 = mir.mov_imm 125 : i64
    %31 = mir.cmp ugt, %9, %30
    mir.cond_br %31 [then: __range_panic_0(), else: __range_ok_0()]
  inner_0.header:
    %11 = mir.mov_imm 3 : i64
    %12 = mir.cmp lt, %29, %11
    mir.cond_br %12 [then: inner_0(), else: inner_0.exit()]
  inner_0:
    %15 = mir.cmp eq, %28, %29
    mir.cond_br %15 [then: diag_0(), else: diag_0.after(%26)]
  inner_0.exit:
    %17 = mir.mov_imm 1 : i64
    %18 = mir.add.i64 %28, %17
    mir.br outer_0.header(%26, %18)
  diag_0:
    %20 = mir.mov_imm 1 : i64
    %21 = mir.add.i64 %26, %20
    mir.br diag_0.after(%21)
  diag_0.after:
    %23 = mir.mov_imm 1 : i64
    %24 = mir.add.i64 %29, %23
    mir.br inner_0.header(%25, %24)
  __range_panic_0:
    %32 = mir.global_addr @__panic_msg_0
    %33 = mir.call @mrt_panic(%32)
  __range_ok_0:
    mir.ret %9
  }
}

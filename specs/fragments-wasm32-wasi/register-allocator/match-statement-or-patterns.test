// Test: match-statement-or-patterns
function main() returns ExitCode
	let x = 3
	match x 'check'
		1 or 2 then return 10
		3 or 4 then return 20
		default then return 0
	end 'check'
end 'main'
---
ExitCode: 20
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    mir.br check_0.next0()
  check_0.next0:
    %8 = mir.mov_imm 3 : i64
    %9 = mir.cmp eq, %0, %8
    %10 = mir.mov_imm 4 : i64
    %11 = mir.cmp eq, %0, %10
    %12 = mir.or.i64 %9, %11
    mir.cond_br %12 [then: check_0.case1(), else: check_0.case2()]
  check_0.case1:
    %13 = mir.mov_imm 20 : i64
    mir.ret %13
  check_0.case2:
    %14 = mir.mov_imm 0 : i64
    mir.ret %14
  }
}
---

// Test: match-statement-assignment
function main() returns ExitCode
	let x = 2
	var result = 0
	match x 'process'
		1 then result = 100
		2 then result = 200
		default then result = 0
	end 'process'
	return result and 125
end 'main'
---
ExitCode: 72
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    mir.br process_0.next0()
  process_0.merge:
    %6 = mir.mov_imm 125 : i64
    %7 = mir.and.i64 %13, %6
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %7, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  process_0.next0:
    %9 = mir.mov_imm 2 : i64
    %10 = mir.cmp eq, %0, %9
    mir.cond_br %10 [then: process_0.case1(), else: process_0.case2()]
  process_0.case1:
    %11 = mir.mov_imm 200 : i64
    mir.br process_0.merge(%11)
  process_0.case2:
    %12 = mir.mov_imm 0 : i64
    mir.br process_0.merge(%12)
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %7
  }
}
---

// Test: int-subtraction-high-pressure
function main() returns ExitCode
	let a = 100
	let b = 1
	let c = 2
	let d = 3
	let e = 4
	let f = 5
	let g = 6
	let h = 7
	return a - b - c - d - e - f - g - h
end 'main'

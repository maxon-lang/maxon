// Test: int-division-high-pressure
function main() returns ExitCode
	let a = 10
	let b = 20
	let c = 30
	let d = 40
	let e = 50
	let f = 60
	let g = 70
	let h = 2
	return ((a + b + c + d + e + f + g) / h) and 125
end 'main'
---
ExitCode: 12
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %7 = mir.mov_imm 2 : i64
    %20 = mir.mov_imm 280 : i64
    %22 = mir.div.i64 %20, %7
    %23 = mir.mov_imm 125 : i64
    %24 = mir.and.i64 %22, %23
    %25 = mir.mov_imm 125 : i64
    %26 = mir.cmp ugt, %24, %25
    mir.cond_br %26 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %27 = mir.global_addr @__panic_msg_0
    %28 = mir.call @mrt_panic(%27)
  __range_ok_0:
    mir.ret %24
  }
}
---

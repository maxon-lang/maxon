// Test: int-division-high-pressure
function main() returns ExitCode
	let a = 10
	let b = 20
	let c = 30
	let d = 40
	let e = 50
	let f = 60
	let g = 70
	let h = 2
	return (a + b + c + d + e + f + g) / h
end 'main'
---
ExitCode: 140
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %7 = mir.mov_imm 2 : i64
    %20 = mir.mov_imm 280 : i64
    %22 = mir.div.i64 %20, %7
    %23 = mir.mov_imm 255 : i64
    %24 = mir.cmp ugt, %22, %23
    mir.cond_br %24 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %25 = mir.global_addr @__panic_msg_0
    %26 = mir.call @mrt_panic(%25)
  __range_ok_0:
    mir.ret %22
  }
}
---

// Test: int-mov-reg-reg-32bit

typealias Integer = int(i64.min to i64.max)

function add(a Integer, b Integer) returns Integer
	return a + b
end 'add'

function main() returns ExitCode
	let x = 20
	let y = 22
	return add(y, b: x)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %5 = mir.mov_imm 42 : i64
    mir.ret %5
  }
}
---

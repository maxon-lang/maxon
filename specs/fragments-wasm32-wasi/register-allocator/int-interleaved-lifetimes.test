// Test: int-interleaved-lifetimes
function main() returns ExitCode
	let a = 10
	let b = 20
	let ab = a + b
	let c = 30
	let d = 40
	let cd = c + d
	let e = 50
	let f = 60
	let ef = e + f
	let result = ab + cd + ef
	return result mod 256
end 'main'
---
ExitCode: 210
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %19 = mir.mov_imm 210 : i64
    %21 = mir.mov_imm 256 : i64
    %22 = mir.rem.i64 %19, %21
    %23 = mir.mov_imm 255 : i64
    %24 = mir.cmp ugt, %22, %23
    mir.cond_br %24 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %25 = mir.global_addr @__panic_msg_0
    %26 = mir.call @mrt_panic(%25)
  __range_ok_0:
    mir.ret %22
  }
}
---

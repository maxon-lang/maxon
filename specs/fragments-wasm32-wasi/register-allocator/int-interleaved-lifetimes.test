// Test: int-interleaved-lifetimes
function main() returns ExitCode
	let a = 10
	let b = 20
	let ab = a + b
	let c = 30
	let d = 40
	let cd = c + d
	let e = 50
	let f = 60
	let ef = e + f
	let result = ab + cd + ef
	return result and 125
end 'main'
---
ExitCode: 80
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %22 = mir.mov_imm 80 : i64
    mir.ret %22
  }
}
---

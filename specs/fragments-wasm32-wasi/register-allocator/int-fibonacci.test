// Test: int-fibonacci
function main() returns ExitCode
	var a = 0
	var b = 1
	var i = 0
	while i < 13 'loop'
		let temp = a + b
		a = b
		b = temp
		i = i + 1
	end 'loop'
	return a
end 'main'
---
ExitCode: 233
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.mov_imm 1 : i64
    %2 = mir.mov_imm 0 : i64
    mir.br loop_0.header(%0, %1, %2)
  loop_0.header:
    %4 = mir.mov_imm 13 : i64
    %5 = mir.cmp lt, %17, %4
    mir.cond_br %5 [then: loop_0(), else: loop_0.exit()]
  loop_0:
    %8 = mir.add.i64 %15, %16
    %12 = mir.mov_imm 1 : i64
    %13 = mir.add.i64 %17, %12
    mir.br loop_0.header(%16, %8, %13)
  loop_0.exit:
    %18 = mir.mov_imm 255 : i64
    %19 = mir.cmp ugt, %15, %18
    mir.cond_br %19 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %20 = mir.global_addr @__panic_msg_0
    %21 = mir.call @mrt_panic(%20)
  __range_ok_0:
    mir.ret %15
  }
}

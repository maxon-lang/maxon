// Test: int-call-result-used-later

typealias Integer = int(i64.min to i64.max)

function compute() returns Integer
	return 100
end 'compute'

function main() returns ExitCode
	let a = compute()
	let b = compute()
	return (a + b) and 125
end 'main'
---
ExitCode: 72
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %6 = mir.mov_imm 72 : i64
    mir.ret %6
  }
}
---

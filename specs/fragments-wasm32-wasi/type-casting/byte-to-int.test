// Test: byte-to-int

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 100 as Byte
	return b as Integer
end 'main'
---
ExitCode: 100
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 100 : i64
    mir.ret %0
  }
}
---

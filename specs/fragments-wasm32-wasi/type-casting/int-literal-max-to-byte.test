// Test: int-literal-max-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = int(0 to u8.max)

function main() returns ExitCode
	let b = 255 as Byte
	return b as Integer
end 'main'
---
ExitCode: 255
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 255 : i64
    mir.ret %0
  }
}
---

// Test: same-type-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	let c = b as Byte
	return c as Integer
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    mir.ret %0
  }
}
---

// Test: int-literal-to-byte

typealias Integer = int(i64.min to i64.max)
typealias Byte = byte(0 to u8.max)

function main() returns ExitCode
	let b = 42 as Byte
	return b as Integer
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @type-casting.main() -> u8 {
  entry:
    %0 = mir.mov_imm 42 : i64
    mir.ret %0
  }
}
---

// Test: enum-array-push-get-last
typealias Integer = int(i64.min to i64.max)

export union Op
		add(value Integer)
		sub(value Integer)
		nop
end 'Op'

typealias OpArray = Array with Op

function main() returns ExitCode
		var ops = OpArray.create()
		ops.push(Op.add(10))
		ops.push(Op.sub(20))
		ops.push(Op.add(42))

		let last = try ops.get(2) otherwise Op.nop
		match last 'check'
				add(v) then return v
				sub then return 99
				nop then return 98
		end 'check'
end 'main'
---
ExitCode: 42
---

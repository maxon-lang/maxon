// Test: multiple-enum-interpolation
enum Priority
	low = 1
	medium = 2
	high = 3
end 'Priority'

function main() returns ExitCode
	let p1 = Priority.low
	let p2 = Priority.high
	print("Priorities: {p1} and {p2}\n")
	return 0
end 'main'

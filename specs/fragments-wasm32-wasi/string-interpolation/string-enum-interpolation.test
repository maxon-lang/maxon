// Test: string-enum-interpolation
enum Status
	active = "Active"
	inactive = "Inactive"
	pending = "Pending"
end 'Status'

function main() returns ExitCode
	let s = Status.active
	print("Status: {s}\n")
	return 0
end 'main'

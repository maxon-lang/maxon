// Test: builtins-type.directory-exists
function main() returns ExitCode
	let cwd = Directory.currentPath()
	if Directory.exists(cwd) 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.call @Directory.currentPath()
    %5 = mir.load %0, 0 width: qword
    %6 = mir.load %5, 0 width: qword
    %7 = mir.call @mrt_directory_exists(%6)
    mir.cond_br %7 [then: check_0(), else: check_0.after()]
  check_0:
    %3 = mir.mov_imm 0 : i64
    mir.ret %3
  check_0.after:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

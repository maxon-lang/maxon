// Test: builtins-type.directory-exists
function main() returns ExitCode
	let cwd = Directory.currentPath()
	if Directory.exists(cwd) 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
ExitCode: 0
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.call @Directory.currentPath()
    %6 = mir.load %1, 0 width: qword
    %7 = mir.load %6, 0 width: qword
    %8 = mir.call @mrt_directory_exists(%7)
    %9 = mir.call @__mm_decref_maybenull_helper(%1)
    mir.cond_br %8 [then: check_0(), else: check_0.after()]
  check_0:
    %4 = mir.mov_imm 0 : i64
    mir.ret %4
  check_0.after:
    %5 = mir.mov_imm 1 : i64
    mir.ret %5
  }
}
---

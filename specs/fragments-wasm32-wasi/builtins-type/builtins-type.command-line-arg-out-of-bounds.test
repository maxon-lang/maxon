// Test: builtins-type.command-line-arg-out-of-bounds
function main() returns ExitCode
	let managed = __Builtins.commandLineArg(9999)
	let s = String.init(managed)
	if s == "" 'check'
		return 0
	end 'check'
	return 1
end 'main'
---
Args: one
ExitCode: 0
---

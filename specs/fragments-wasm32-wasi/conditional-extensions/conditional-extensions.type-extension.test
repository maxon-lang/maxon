// Test: conditional-extensions.type-extension
type Box uses Item
	export var item as Item

	static function create(item Item) returns Self
		return Self{item: item}
	end 'create'
end 'Box'

extension Box where Item is Equatable
	function matches(other Item) returns bool
		return item == other
	end 'matches'
end 'Box'

typealias Int = int(i64.min to i64.max)
typealias IntBox = Box with Int

function main() returns ExitCode
	let b = IntBox.create(42)
	if b.matches(42) 'yes'
		return 1
	end 'yes'
	return 0
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    %2 = mir.global_addr @__layout_Box_Int
    %11 = mir.mov_imm 8 : i64
    %12 = mir.load %2, 40 width: qword
    %13 = mir.mov_imm 0 : i64
    %14 = mir.call @stdlib.__mm_alloc(%11, %12, %13)
    mir.store %1, %14, 0 width: qword
    %5 = mir.mov_imm 42 : i64
    %7 = mir.global_addr @__witness_int_Equatable
    %15 = mir.load %14, 0 width: qword
    %16 = mir.witness_call %7, [0](%15, %5)
    %17 = mir.call @mm_drop(%14)
    mir.cond_br %16 [then: yes_0(), else: yes_0.after()]
  yes_0:
    %9 = mir.mov_imm 1 : i64
    mir.ret %9
  yes_0.after:
    %10 = mir.mov_imm 0 : i64
    mir.ret %10
  }
}
---

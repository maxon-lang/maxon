// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
	var r1 = a / b
	var r2 = c / d
	return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
	return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---
module {
  func @multi-div.multiDiv(ptr: i64, ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    %9 = mir.param 0 : StdI64
    %10 = mir.param 1 : StdI64
    %11 = mir.param 2 : StdI64
    %12 = mir.param 3 : StdI64
    %2 = mir.div.i64 %9, %10
    %5 = mir.div.i64 %11, %12
    %8 = mir.add.i64 %2, %5
    %13 = mir.mov_imm -9223372036854775807 : i64
    %14 = mir.cmp lt, %8, %13
    mir.cond_br %14 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %17 = mir.global_addr @__panic_msg_0
    %18 = mir.call @mrt_panic(%17)
  __range_ok_0:
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mov_imm 20 : i64
    %3 = mir.mov_imm 4 : i64
    %4 = mir.call @multi-div.multiDiv(%0, %1, %2, %3)
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %4, %15
    mir.cond_br %16 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %19 = mir.global_addr @__panic_msg_1
    %20 = mir.call @mrt_panic(%19)
  __range_ok_1:
    mir.ret %4
  }
}
---

// Test: multi-div

typealias Integer = int(i64.min to i64.max)

function multiDiv(a Integer, b Integer, c Integer, d Integer) returns Integer
	let r1 = a / b
	let r2 = c / d
	return trunc(r1 + r2)
end 'multiDiv'

function main() returns ExitCode
	return multiDiv(10, b: 2, c: 20, d: 4)
end 'main'
---
ExitCode: 10
---

	let v2 = b + 2
	let v3 = c + 3
	let v4 = d + 4
	let v5 = e + 5
	let v6 = f + 6
	let v7 = v1 + v2
	let v8 = v3 + v4
	let v9 = v5 + v6
	let v10 = v7 + v8
	let v11 = v9 + v10
	let v12 = v11 + v1 + v2 + v3 + v4 + v5 + v6
	return v12
end 'manyVars'

function main() returns ExitCode
	return manyVars(1, b: 2, c: 3, d: 4, e: 5, f: 6)
end 'main'

// Test: mod-live-values

typealias Integer = int(i64.min to i64.max)

function modLive(a Integer, b Integer, x Integer) returns Integer
	let preserved = x + 1
	let result = a mod b
	return result + preserved
end 'modLive'

function main() returns ExitCode
	return modLive(10, b: 3, x: 5)
end 'main'
---
ExitCode: 7
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 3 : i64
    %5 = mir.mov_imm 6 : i64
    %6 = mir.rem.i64 %0, %1
    %7 = mir.add.i64 %6, %5
    %8 = mir.mov_imm 125 : i64
    %9 = mir.cmp ugt, %7, %8
    mir.cond_br %9 [then: __range_panic_3(), else: __range_ok_3()]
  __range_panic_3:
    %10 = mir.global_addr @__panic_msg_3
    %11 = mir.call @mrt_panic(%10)
  __range_ok_3:
    mir.ret %7
  }
}
---

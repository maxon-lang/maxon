  func @div-with-call.divCall(local0: i64, local1: i64) -> i64 {
  entry:
    %8 = mir.param local0 : i64
    %9 = mir.param local1 : i64
    %2 = mir.div.i64 %8, %9
    %4 = mir.call @div-with-call.helper(%2)
    %7 = mir.add.i64 %4, %2
    mir.ret %7
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.call @div-with-call.divCall(%0, %1)
    %10 = mir.mov_imm 125 : i64
    %11 = mir.cmp ugt, %2, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %12 = mir.global_addr @__panic_msg_0
    %13 = mir.call @mrt_panic(%12)
  __range_ok_0:
    mir.ret %2
  }
}

    %4 = mir.param local0 : i64
    %2 = mir.mov_imm 2 : i64
    %3 = mir.mul.i64 %4, %2
    mir.ret %3
  }
  func @arithmetic.divCall(local0: i64, local1: i64) -> i64 {
  entry:
    %10 = mir.param local0 : i64
    %11 = mir.param local1 : i64
    %4 = mir.div.i64 %10, %11
    %6 = mir.call @arithmetic.helper(%4)
    %9 = mir.add.i64 %6, %4
    mir.ret %9
  }
  func @arithmetic.main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.call @arithmetic.divCall(%0, %1)
    %3 = mir.mov_imm 125 : i64
    %4 = mir.cmp ugt, %2, %3
    mir.cond_br %4 [then: __range_panic_5(), else: __range_ok_5()]
  __range_panic_5:
    %5 = mir.global_addr @__panic_msg_5
    %6 = mir.call @mrt_panic(%5)
  __range_ok_5:
    mir.ret %2
  }
}

// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	let temp = trunc(a / b)
	let result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %3 = mir.div.i64 %0, %1
    %4 = mir.mov_imm 2 : i64
    %5 = mir.mul.i64 %3, %4
    %6 = mir.add.i64 %5, %3
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %6, %7
    mir.cond_br %8 [then: __range_panic_5(), else: __range_ok_5()]
  __range_panic_5:
    %9 = mir.global_addr @__panic_msg_5
    %10 = mir.call @mrt_panic(%9)
  __range_ok_5:
    mir.ret %6
  }
}
---

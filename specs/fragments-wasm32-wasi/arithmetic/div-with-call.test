// Test: div-with-call

typealias Integer = int(i64.min to i64.max)

function helper(x Integer) returns Integer
	return x * 2
end 'helper'

function divCall(a Integer, b Integer) returns Integer
	var temp = trunc(a / b)
	var result = helper(temp)
	return result + temp
end 'divCall'

function main() returns ExitCode
	return divCall(10, b: 2)
end 'main'
---
ExitCode: 15
---
module {
  func @div-with-call.helper(ptr: i64) -> i64 {
  entry:
    %3 = mir.param 0 : StdI64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mul.i64 %3, %1
    %10 = mir.mov_imm -9223372036854775807 : i64
    %11 = mir.cmp lt, %2, %10
    mir.cond_br %11 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %2
  }
  func @div-with-call.divCall(ptr: i64, ptr: i64) -> i64 {
  entry:
    %8 = mir.param 0 : StdI64
    %9 = mir.param 1 : StdI64
    %2 = mir.div.i64 %8, %9
    %4 = mir.call @div-with-call.helper(%2)
    %7 = mir.add.i64 %4, %2
    %12 = mir.mov_imm -9223372036854775807 : i64
    %13 = mir.cmp lt, %7, %12
    mir.cond_br %13 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %18 = mir.global_addr @__panic_msg_1
    %19 = mir.call @mrt_panic(%18)
  __range_ok_1:
    mir.ret %7
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.call @div-with-call.divCall(%0, %1)
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %2, %14
    mir.cond_br %15 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %20 = mir.global_addr @__panic_msg_2
    %21 = mir.call @mrt_panic(%20)
  __range_ok_2:
    mir.ret %2
  }
}

// Test: div-live-values

typealias Integer = int(i64.min to i64.max)

function divLive(a Integer, b Integer, x Integer) returns Integer
	var preserved = x + 1
	var result = a / b
	return trunc(result + preserved)
end 'divLive'

function main() returns ExitCode
	return divLive(10, b: 2, x: 5)
end 'main'
---
ExitCode: 11
---
module {
  func @div-live-values.divLive(ptr: i64, ptr: i64, ptr: i64) -> i64 {
  entry:
    %9 = mir.param 0 : StdI64
    %10 = mir.param 1 : StdI64
    %11 = mir.param 2 : StdI64
    %1 = mir.mov_imm 1 : i64
    %2 = mir.add.i64 %11, %1
    %5 = mir.div.i64 %9, %10
    %8 = mir.add.i64 %5, %2
    %12 = mir.mov_imm -9223372036854775807 : i64
    %13 = mir.cmp lt, %8, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mov_imm 5 : i64
    %3 = mir.call @div-live-values.divLive(%0, %1, %2)
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %3, %14
    mir.cond_br %15 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %18 = mir.global_addr @__panic_msg_1
    %19 = mir.call @mrt_panic(%18)
  __range_ok_1:
    mir.ret %3
  }
}
---

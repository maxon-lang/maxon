    %5 = mir.div.i64 %9, %10
    %8 = mir.add.i64 %5, %2
    mir.ret %8
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %1 = mir.mov_imm 2 : i64
    %2 = mir.mov_imm 5 : i64
    %3 = mir.call @div-live-values.divLive(%0, %1, %2)
    %12 = mir.mov_imm 125 : i64

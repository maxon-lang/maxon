// Test: closure-parameter
typealias Integer = int(i64.min to i64.max)

function apply(f Integer, n Integer) returns Integer
	return f + n
end 'apply'

function main() returns ExitCode
	let f = (__n Integer) gives __n + 1
	_ = f(0)
	return 0
end 'main'

// Test: type-multiple-methods

typealias Integer = int(i64.min to i64.max)

type Counter
	var count Integer

	function increment()
		count = count + 1
	end 'increment'

	function decrement()
		count = count - 1
	end 'decrement'

	function reset()
		count = 0
	end 'reset'

	function get() returns Integer
		return count
	end 'get'

	static function create(count Integer) returns Self
		return Self{count: count}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(count: 10)
	c.increment()
	c.increment()
	c.decrement()
	return c.get()
end 'main'
---
ExitCode: 11
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %10 = mir.mov_imm 8 : i64
    %11 = mir.call @mrt_alloc(%10)
    mir.store %0, %11, 0 width: qword
    %12 = mir.load %11, 0 width: qword
    %13 = mir.mov_imm 1 : i64
    %14 = mir.add.i64 %12, %13
    mir.store %14, %11, 0 width: qword
    %15 = mir.load %11, 0 width: qword
    %16 = mir.mov_imm 1 : i64
    %17 = mir.add.i64 %15, %16
    mir.store %17, %11, 0 width: qword
    %18 = mir.load %11, 0 width: qword
    %19 = mir.mov_imm 1 : i64
    %20 = mir.sub.i64 %18, %19
    mir.store %20, %11, 0 width: qword
    %21 = mir.load %11, 0 width: qword
    %22 = mir.mov_imm 255 : i64
    %23 = mir.cmp ugt, %21, %22
    mir.cond_br %23 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %24 = mir.global_addr @__panic_msg_0
    %25 = mir.call @mrt_panic(%24)
  __range_ok_0:
    mir.ret %21
  }
}

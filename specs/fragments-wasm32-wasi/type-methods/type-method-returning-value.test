// Test: type-method-returning-value

typealias Integer = int(i64.min to i64.max)

type Calculator
	var value Integer

	function double() returns Integer
		return value * 2
	end 'double'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	let c = Calculator.create(value: 21)
	return c.double()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @Calculator.double(local0: i64) -> i64 {
  entry:
    %5 = mir.param local0 : i64
    %1 = mir.load %5, 0
    %3 = mir.mov_imm 2 : i64
    %4 = mir.mul.i64 %1, %3
    mir.ret %4
  }
  func @Calculator.create(local0: i64) -> i64 {
  entry:
    %4 = mir.param local0 : i64
    %1 = mir.mov_imm 8 : i64
    %2 = mir.call @mrt_alloc(%1)
    mir.store %4, %2, 0
    mir.ret %2
  }
  func @type-methods.main() -> u8 {
  entry:
    %0 = mir.mov_imm 21 : i64
    %1 = mir.call @Calculator.create(%0)
    %3 = mir.call @Calculator.double(%1)
    %4 = mir.mov_imm 125 : i64
    %5 = mir.cmp ugt, %3, %4
    mir.cond_br %5 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %6 = mir.global_addr @__panic_msg_2
    %7 = mir.call @mrt_panic(%6)
  __range_ok_2:
    mir.ret %3
  }
}

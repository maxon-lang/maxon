// Test: type-method-returning-value

typealias Integer = int(i64.min to i64.max)

type Calculator
	var value as Integer

	function double() returns Integer
		return value * 2
	end 'double'

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Calculator'

function main() returns ExitCode
	let c = Calculator.create(21)
	return c.double()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 21 : i64
    %4 = mir.mov_imm 8 : i64
    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0 width: qword
    %6 = mir.load %5, 0 width: qword
    %7 = mir.mov_imm 2 : i64
    %8 = mir.mul.i64 %6, %7
    %9 = mir.mov_imm 255 : i64
    %10 = mir.cmp ugt, %8, %9
    mir.cond_br %10 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %11 = mir.global_addr @__panic_msg_0
    %12 = mir.call @mrt_panic(%11)
  __range_ok_0:
    mir.ret %8
  }
}
---

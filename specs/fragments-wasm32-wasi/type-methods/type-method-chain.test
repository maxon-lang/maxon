    %6 = mir.mov_imm 20 : i64
    %7 = mir.call @Value.add(%1, %6)
    %9 = mir.mov_imm 12 : i64
    %10 = mir.call @Value.add(%1, %9)
    %12 = mir.call @Value.get(%1)
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %12, %13
    mir.cond_br %14 [then: __range_panic_4(), else: __range_ok_4()]
  __range_panic_4:
    %15 = mir.global_addr @__panic_msg_4
    %16 = mir.call @mrt_panic(%15)

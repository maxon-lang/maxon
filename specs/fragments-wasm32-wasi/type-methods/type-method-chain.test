    mir.store %18, %14, 0 width: qword
    %9 = mir.mov_imm 12 : i64
    %19 = mir.load %14, 0 width: qword
    %20 = mir.add.i64 %19, %9
    mir.store %20, %14, 0 width: qword
    %21 = mir.load %14, 0 width: qword
    %22 = mir.mov_imm 125 : i64

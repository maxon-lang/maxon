    %3 = mir.mov_imm 10 : i64
    %12 = mir.load %11, 0 width: qword
    %13 = mir.add.i64 %12, %3
    mir.store %13, %11, 0 width: qword
    %6 = mir.mov_imm 32 : i64
    %14 = mir.load %11, 0 width: qword
    %15 = mir.add.i64 %14, %6
    mir.store %15, %11, 0 width: qword
    %16 = mir.load %11, 0 width: qword
    %17 = mir.mov_imm 255 : i64
    %18 = mir.cmp ugt, %16, %17
    mir.cond_br %18 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %19 = mir.global_addr @__panic_msg_0
    %20 = mir.call @mrt_panic(%19)
  __range_ok_0:
    mir.ret %16
  }
}

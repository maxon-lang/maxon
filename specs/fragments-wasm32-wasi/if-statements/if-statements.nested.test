// Test: if-statements.nested
function main() returns ExitCode
	let x = 3
	if x == 1 'outer'
		return 1
	end 'outer' else 'else_outer'
		if x == 2 'inner'
			return 2
		end 'inner' else 'else_inner'
			return 3
		end 'else_inner'
	end 'else_outer'
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    %2 = mir.mov_imm 1 : i64
    %3 = mir.cmp eq, %0, %2
    mir.cond_br %3 [then: outer_1(), else: else_outer_2()]
  outer_1:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  else_outer_2:
    %6 = mir.mov_imm 2 : i64
    %7 = mir.cmp eq, %0, %6
    mir.cond_br %7 [then: inner_3(), else: else_inner_4()]
  inner_3:
    %8 = mir.mov_imm 2 : i64
    mir.ret %8
  else_inner_4:
    %9 = mir.mov_imm 3 : i64
    mir.ret %9
  outer_1.merge:
    %10 = mir.mov_imm 0 : i64
    mir.ret %10
  }
}
---

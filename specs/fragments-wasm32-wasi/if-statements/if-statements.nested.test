// Test: if-statements.nested
function main() returns ExitCode
	let x = 3
	if x == 1 'outer'
		return 1
	end 'outer' else 'else_outer'
		if x == 2 'inner'
			return 2
		end 'inner' else 'else_inner'
			return 3
		end 'else_inner'
	end 'else_outer'
end 'main'
---
ExitCode: 3
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 3 : i64
    mir.br else_outer_0()
  else_outer_0:
    %6 = mir.mov_imm 2 : i64
    %7 = mir.cmp eq, %0, %6
    mir.cond_br %7 [then: inner_0(), else: else_inner_0()]
  inner_0:
    %8 = mir.mov_imm 2 : i64
    mir.ret %8
  else_inner_0:
    %9 = mir.mov_imm 3 : i64
    mir.ret %9
  }
}
---

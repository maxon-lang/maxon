// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
module {
  func @if-statements.test(local0: i64, local1: i64) -> i64 {
  entry:
    %12 = mir.param local0 : StdI64
    %13 = mir.param local1 : StdI64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.cmp eq, %12, %1
    mir.cond_br %2 [then: maybePrefix_1(), else: maybePrefix_1.after()]
  maybePrefix_1:
    %4 = mir.mov_imm 1 : i64
    %5 = mir.cmp eq, %13, %4
    mir.cond_br %5 [then: isHex_2(), else: isHex_2.after()]
  isHex_2:
    %6 = mir.mov_imm 1 : i64
    mir.ret %6
  isHex_2.after:
    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp eq, %13, %8
    mir.cond_br %9 [then: isBinary_4(), else: isBinary_4.after()]
  isBinary_4:
    %10 = mir.mov_imm 2 : i64
    mir.ret %10
  isBinary_4.after:
    mir.br maybePrefix_1.after()
  maybePrefix_1.after:
    %11 = mir.mov_imm 42 : i64
    mir.ret %11
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.call @if-statements.test(%0, %1)
    %14 = mir.mov_imm 125 : i64
    %15 = mir.cmp ugt, %2, %14
    mir.cond_br %15 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %16 = mir.global_addr @__panic_msg_0
    %17 = mir.call @mrt_panic(%16)
  __range_ok_0:
    mir.ret %2
  }
}
---

// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.mov_imm 0 : i64
    mir.br inlined_if-statements.test_0()
  inlined_if-statements.test_0:
    %3 = mir.mov_imm 0 : i64
    %4 = mir.cmp eq, %0, %3
    mir.cond_br %4 [then: inlined_if-statements.test_1(), else: inlined_if-statements.test_6()]
  inlined_if-statements.test_1:
    %5 = mir.mov_imm 1 : i64
    %6 = mir.cmp eq, %1, %5
    mir.cond_br %6 [then: inlined_if-statements.test_2(), else: inlined_if-statements.test_3()]
  inlined_if-statements.test_2:
    %7 = mir.mov_imm 1 : i64
    mir.br inline_cont_if-statements.main_0(%7)
  inlined_if-statements.test_3:
    %8 = mir.mov_imm 2 : i64
    %9 = mir.cmp eq, %1, %8
    mir.cond_br %9 [then: inlined_if-statements.test_4(), else: inlined_if-statements.test_6()]
  inlined_if-statements.test_4:
    %10 = mir.mov_imm 2 : i64
    mir.br inline_cont_if-statements.main_0(%10)
  inlined_if-statements.test_6:
    %11 = mir.mov_imm 42 : i64
    mir.br inline_cont_if-statements.main_0(%11)
  inline_cont_if-statements.main_0:
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %12, %13
    mir.cond_br %14 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %15 = mir.global_addr @__panic_msg_2
    %16 = mir.call @mrt_panic(%15)
  __range_ok_2:
    mir.ret %12
  }
}
---

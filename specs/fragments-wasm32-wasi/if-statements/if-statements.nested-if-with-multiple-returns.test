// Test: if-statements.nested-if-with-multiple-returns

typealias Integer = int(i64.min to i64.max)

function test(c Integer, next Integer) returns Integer
	if c == 0 'maybePrefix'
		if next == 1 'isHex'
			return 1
		end 'isHex'
		if next == 2 'isBinary'
			return 2
		end 'isBinary'
	end 'maybePrefix'
	return 42
end 'test'

function main() returns ExitCode
	return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.test(local0: i64, local1: i64) -> i64 {
  entry:
    %14 = mir.param local0 : i64
    %15 = mir.param local1 : i64
    %3 = mir.mov_imm 0 : i64
    %4 = mir.cmp eq, %14, %3
    mir.cond_br %4 [then: maybePrefix_1(), else: maybePrefix_1.after()]
  maybePrefix_1:
    %6 = mir.mov_imm 1 : i64
    %7 = mir.cmp eq, %15, %6
    mir.cond_br %7 [then: isHex_2(), else: isHex_2.after()]
  isHex_2:
    %8 = mir.mov_imm 1 : i64
    mir.ret %8
  isHex_2.after:
    %10 = mir.mov_imm 2 : i64
    %11 = mir.cmp eq, %15, %10
    mir.cond_br %11 [then: isBinary_4(), else: maybePrefix_1.after()]
  isBinary_4:
    %12 = mir.mov_imm 2 : i64
    mir.ret %12
  maybePrefix_1.after:
    %13 = mir.mov_imm 42 : i64
    mir.ret %13
  }
  func @if-statements.main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.call @if-statements.test(%0, %1)
    %3 = mir.mov_imm 125 : i64
    %4 = mir.cmp ugt, %2, %3
    mir.cond_br %4 [then: __range_panic_2(), else: __range_ok_2()]
  __range_panic_2:
    %5 = mir.global_addr @__panic_msg_2
    %6 = mir.call @mrt_panic(%5)
  __range_ok_2:
    mir.ret %2
  }
}
---

// Test: if-statements.else-if-in-helper

typealias Integer = int(i64.min to i64.max)

function classify(x Integer) returns Integer
	if x == 0 'zero'
		return 0
	end 'zero' else if x < 10 'small'
		return 1
	end 'small' else if x < 100 'medium'
		return 2
	end 'medium' else 'large'
		return 3
	end 'large'
end 'classify'

function main() returns ExitCode
	let a = classify(0)
	let b = classify(5)
	let c = classify(50)
	let d = classify(200)
	return a + b * 3 + c * 9 + d * 27
end 'main'
---
ExitCode: 102
---
module {
  func @if-statements.classify(local0: i64) -> i64 {
  entry:
    %14 = mir.param local0 : StdI64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.cmp eq, %14, %1
    mir.cond_br %2 [then: zero_1(), else: zero_1.else()]
  zero_1:
    %3 = mir.mov_imm 0 : i64
    mir.ret %3
  zero_1.else:
    %5 = mir.mov_imm 10 : i64
    %6 = mir.cmp lt, %14, %5
    mir.cond_br %6 [then: small_3(), else: small_3.else()]
  small_3:
    %7 = mir.mov_imm 1 : i64
    mir.ret %7
  small_3.else:
    %9 = mir.mov_imm 100 : i64
    %10 = mir.cmp lt, %14, %9
    mir.cond_br %10 [then: medium_5(), else: large_6()]
  medium_5:
    %11 = mir.mov_imm 2 : i64
    mir.ret %11
  large_6:
    %12 = mir.mov_imm 3 : i64
    mir.ret %12
  small_3.merge:
    mir.br zero_1.merge()
  zero_1.merge:
    %13 = mir.mov_imm 0 : i64
    mir.ret %13
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 0 : i64
    %1 = mir.call @if-statements.classify(%0)
    %2 = mir.mov_imm 5 : i64
    %3 = mir.call @if-statements.classify(%2)
    %4 = mir.mov_imm 50 : i64
    %5 = mir.call @if-statements.classify(%4)
    %6 = mir.mov_imm 200 : i64
    %7 = mir.call @if-statements.classify(%6)
    %10 = mir.mov_imm 3 : i64
    %11 = mir.mul.i64 %3, %10
    %12 = mir.add.i64 %1, %11
    %14 = mir.mov_imm 9 : i64
    %15 = mir.mul.i64 %5, %14
    %16 = mir.add.i64 %12, %15
    %18 = mir.mov_imm 27 : i64
    %19 = mir.mul.i64 %7, %18
    %20 = mir.add.i64 %16, %19
    %21 = mir.mov_imm 125 : i64
    %22 = mir.cmp ugt, %20, %21
    mir.cond_br %22 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %23 = mir.global_addr @__panic_msg_0
    %24 = mir.call @mrt_panic(%23)
  __range_ok_0:
    mir.ret %20
  }
}
---

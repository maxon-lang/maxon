// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    mir.br inlined_if-statements.test_0()
  inlined_if-statements.test_0:
    %2 = mir.mov_imm 0 : i64
    %3 = mir.cmp eq, %0, %2
    mir.cond_br %3 [then: inlined_if-statements.test_2(), else: inlined_if-statements.test_4()]
  inlined_if-statements.test_2:
    %4 = mir.mov_imm 1 : i64
    mir.br inline_cont_if-statements.main_0(%4)
  inlined_if-statements.test_4:
    %5 = mir.mov_imm 42 : i64
    mir.br inline_cont_if-statements.main_0(%5)
  inline_cont_if-statements.main_0:
    %7 = mir.mov_imm 125 : i64
    %8 = mir.cmp ugt, %6, %7
    mir.cond_br %8 [then: __range_panic_1(), else: __range_ok_1()]
  __range_panic_1:
    %9 = mir.global_addr @__panic_msg_1
    %10 = mir.call @mrt_panic(%9)
  __range_ok_1:
    mir.ret %6
  }
}
---

// Test: if-statements.nested-if-with-scoped-string

typealias Integer = int(i64.min to i64.max)

function test(x Integer) returns Integer
	if x == 0 'outer'
		let inner = "hello"
		if inner == "hello" 'checkInner'
			return 1
		end 'checkInner'
	end 'outer'
	return 42
end 'test'

function main() returns ExitCode
	return test(5)
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @if-statements.test(local0: i64) -> i64 {
  entry:
    %11 = mir.param local0 : i64
    %1 = mir.mov_imm 0 : i64
    %2 = mir.cmp eq, %11, %1
    mir.cond_br %2 [then: outer_1(), else: outer_1.after()]
  outer_1:
    %6 = mir.mov_imm 1 : i64
    %7 = mir.mov_imm 1 : i64
    %8 = mir.cmp eq, %6, %7
    mir.cond_br %8 [then: checkInner_2(), else: checkInner_2.after()]
  checkInner_2:
    %9 = mir.mov_imm 1 : i64
    mir.ret %9
  checkInner_2.after:
    mir.br outer_1.after()
  outer_1.after:
    %10 = mir.mov_imm 42 : i64
    mir.ret %10
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 5 : i64
    %1 = mir.call @if-statements.test(%0)
    %12 = mir.mov_imm 125 : i64
    %13 = mir.cmp ugt, %1, %12
    mir.cond_br %13 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %14 = mir.global_addr @__panic_msg_0
    %15 = mir.call @mrt_panic(%14)
  __range_ok_0:
    mir.ret %1
  }
}
---

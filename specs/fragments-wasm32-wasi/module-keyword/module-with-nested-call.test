    %1 = mir.mov_imm 20 : i64
    %2 = mir.add.i64 %0, %1
    mir.ret %2
  }
  func @main() -> u8 {
  entry:
    %0 = mir.call @outer.outer()
    %1 = mir.mov_imm 125 : i64
    %2 = mir.cmp ugt, %0, %1
    mir.cond_br %2 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %3 = mir.global_addr @__panic_msg_0
    %4 = mir.call @mrt_panic(%3)
  __range_ok_0:
    mir.ret %0
  }
}

// Test: module-function-same-file
typealias Integer = int(i64.min to i64.max)

module function helper() returns Integer
	return 42
end 'helper'

function main() returns ExitCode
	return helper()
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @module-keyword.main() -> u8 {
  entry:
    %1 = mir.mov_imm 42 : i64
    mir.ret %1
  }
}
---

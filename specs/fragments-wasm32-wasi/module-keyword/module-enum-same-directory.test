// Test: module-enum-same-directory
// --- file: feature/color.maxon
module enum Color
	red
	green
	blue
end 'Color'

// --- file: feature/main.maxon
function main() returns ExitCode
	let c = Color.blue
	match c 'check'
		blue then return 42
		red then return 0
		green then return 0
	end 'check'
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 2 : i64
    mir.br check_1.case0()
  check_1.case0:
    %4 = mir.mov_imm 42 : i64
    mir.ret %4
  }
}
---

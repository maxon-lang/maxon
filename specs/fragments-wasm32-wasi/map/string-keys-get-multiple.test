// Test: string-keys-get-multiple
function main() returns ExitCode
	let m = ["hello": 10, "world": 20, "foo": 30]
	let a = try m.get("hello") otherwise 0
	let b = try m.get("world") otherwise 0
	return a + b
end 'main'

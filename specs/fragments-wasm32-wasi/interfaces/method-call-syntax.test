    %5 = mir.call @mrt_alloc(%4)
    mir.store %0, %5, 0
    %6 = mir.load %5, 0
    %7 = mir.mov_imm 1 : i64
    %8 = mir.add.i64 %6, %7
    %9 = mir.mov_imm 125 : i64
    %10 = mir.cmp ugt, %8, %9

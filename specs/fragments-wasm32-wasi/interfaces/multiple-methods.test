  entry:
    %5 = mir.param local0 : i64
    %1 = mir.mov_imm 50 : i64
    %2 = mir.load %5, 0 width: qword
    %4 = mir.add.i64 %1, %2
    mir.ret %4
  }
  func @Counter.value(local0: i64) -> i64 {
  entry:
    %3 = mir.param local0 : i64
    %1 = mir.load %3, 0 width: qword
    mir.ret %1
  }
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 12 : i64
    %7 = mir.mov_imm 8 : i64
    %8 = mir.call @mrt_alloc(%7)
    mir.store %0, %8, 0 width: qword
    %9 = mir.mov_imm 50 : i64
    %10 = mir.load %8, 0 width: qword
    %11 = mir.add.i64 %9, %10
    %12 = mir.load %8, 0 width: qword
    %6 = mir.add.i64 %11, %12
    %13 = mir.mov_imm 125 : i64
    %14 = mir.cmp ugt, %6, %13
    mir.cond_br %14 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %15 = mir.global_addr @__panic_msg_0
    %16 = mir.call @mrt_panic(%15)
  __range_ok_0:
    mir.ret %6
  }
}

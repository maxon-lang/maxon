    %12 = mir.load %8, 0
    %13 = mir.mov_imm 3 : i64
    %14 = mir.mul.i64 %12, %13
    %6 = mir.add.i64 %11, %14
    %15 = mir.mov_imm 125 : i64
    %16 = mir.cmp ugt, %6, %15

// Test: error.enum-upto-adjacent
enum Color
	red
	green
	blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	match c 'eval'
		red upto green then return 0
		green then return 1
		blue then return 2
	end 'eval'
end 'main'
---

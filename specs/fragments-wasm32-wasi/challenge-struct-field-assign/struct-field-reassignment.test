// Test: struct-field-reassignment

typealias Integer = int(i64.min to i64.max)

type Counter
	export var value as Integer

	static function create(value Integer) returns Self
		return Self{value: value}
	end 'create'
end 'Counter'

function main() returns ExitCode
	var c = Counter.create(10)
	c.value = 42
	return c.value
end 'main'
---
ExitCode: 42
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %0 = mir.mov_imm 10 : i64
    %6 = mir.mov_imm 8 : i64
    %7 = mir.call @mrt_alloc(%6)
    mir.store %0, %7, 0 width: qword
    %3 = mir.mov_imm 42 : i64
    mir.store %3, %7, 0 width: qword
    %5 = mir.load %7, 0 width: qword
    %8 = mir.mov_imm 125 : i64
    %9 = mir.cmp ugt, %5, %8
    mir.cond_br %9 [then: __range_panic_0(), else: __range_ok_0()]
  __range_panic_0:
    %10 = mir.global_addr @__panic_msg_0
    %11 = mir.call @mrt_panic(%10)
  __range_ok_0:
    mir.ret %5
  }
}
---

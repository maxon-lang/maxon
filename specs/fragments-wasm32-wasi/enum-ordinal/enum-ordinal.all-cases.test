  shortAnd.rhs:
    %9 = mir.mov_imm 1 : i64
    %10 = mir.cmp eq, %1, %9
    mir.br shortAnd.merge(%10)
  shortAnd.merge(%24: i64):
    mir.cond_br %24 [then: shortAnd.rhs(), else: shortAnd.merge(%0)]
  shortAnd.rhs:
    %14 = mir.mov_imm 2 : i64
    %15 = mir.cmp eq, %2, %14
    mir.br shortAnd.merge(%15)
  shortAnd.merge(%25: i64):
    mir.cond_br %25 [then: shortAnd.rhs(), else: shortAnd.merge(%0)]
  shortAnd.rhs:
    %19 = mir.mov_imm 3 : i64
    %20 = mir.cmp eq, %3, %19
    mir.br shortAnd.merge(%20)
  shortAnd.merge(%26: i64):
    mir.cond_br %26 [then: check_0(), else: check_0.after()]
  check_0:
    %22 = mir.mov_imm 1 : i64
    mir.ret %22
  check_0.after:
    mir.ret %0
  }
}

// Test: default-panic.enum-range-statement
typealias Integer = int(i64.min to i64.max)

union Op
	add
	sub
	mul
	exec(code Integer)
end 'Op'

function main() returns ExitCode
	let op = Op.sub
	match op 'check'
		add to mul then return 1
		default panic("unexpected op")
	end 'check'
end 'main'

// Test: default-panic.enum-statement
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.red
	match c 'check'
		red then return 1
		default panic("unhandled color")
	end 'check'
end 'main'
---
ExitCode: 1
---
// CompiledIR
module {
  func @main() -> u8 {
  entry:
    %4 = mir.mov_imm 1 : i64
    mir.ret %4
  }
}
---

// Test: default-panic.enum-expression
enum Color
		red
		green
		blue
end 'Color'

function main() returns ExitCode
	let c = Color.green
	let result = match c 'eval'
		red gives 1
		green gives 2
		default panic("unhandled color")
	end 'eval'
	return result
end 'main'

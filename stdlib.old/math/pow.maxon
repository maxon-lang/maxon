// stdlib/math/pow.maxon
// Power function implementation
// Namespace: stdlib.math (automatically inferred from file path)

/// Calculate base^exponent for float values
/// Uses simple multiplication for small positive integers, exp/log otherwise
export function pow(base float, exponent float) returns float
	// Handle special cases
	if exponent == 0.0 'exp_zero'
		return 1.0
	end 'exp_zero'

	if base == 0.0 'base_zero'
		if exponent > 0.0 'exp_positive'
			return 0.0
		end 'exp_positive'
		return 0.0
	end 'base_zero'

	if base == 1.0 'base_one'
		return 1.0
	end 'base_one'

	// Handle negative base (only works for integer exponents in real domain)
	if base < 0.0 'negative_base'
		return 0.0  // Simplified: return 0 for negative base
	end 'negative_base'

	// Check if exponent is a small positive integer (optimize common case)
	// Use floor to check if it's an integer
	var exp_floor = floor(exponent)
	if (exponent - exp_floor) == 0.0 'is_int'
		if exponent > 0.0 'positive_int'
			if exponent <= 20.0 'small_int'
				// Simple multiplication for small positive integers
				var result = 1.0
				var i = 0.0
				while i < exponent 'mult_loop'
					result = result * base
					i = i + 1.0
				end 'mult_loop'
				return result
			end 'small_int'
		end 'positive_int'

		// Handle small negative integer exponents: base^(-n) = 1 / base^n
		if exponent < 0.0 'negative_int'
			var neg_exp = -exponent
			if neg_exp <= 20.0 'small_neg'
				var result = 1.0
				var i = 0.0
				while i < neg_exp 'div_loop'
					result = result / base
					i = i + 1.0
				end 'div_loop'
				return result
			end 'small_neg'
		end 'negative_int'
	end 'is_int'

	// For other cases, use formula: base^exp = exp(exp * log(base))
	var log_base = log(base)
	var exp_times_log = exponent * log_base
	return exp(exp_times_log)
end 'pow'


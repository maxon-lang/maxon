export typealias ExitCode = int(0 to 125)

function stdlibTestAdd() returns ExitCode
	let a = 40
	let b = 2
	return a + b
end 'stdlibTestAdd'

function stdlibTestMul() returns ExitCode
	let a = 6
	let b = 7
	return a * b
end 'stdlibTestMul'

// Calls stdlibTestAdd — tests transitive linking
function stdlibTestAddPlusOne() returns ExitCode
	let base = stdlibTestAdd()
	return base + 1
end 'stdlibTestAddPlusOne'

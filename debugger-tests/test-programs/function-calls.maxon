// Test function calls and stepping
function add(a int, b int) returns int
	let result = a + b
	return result
end 'add'

function multiply(x int, y int) returns int
	let product = x * y
	return product
end 'multiply'

function main() returns int
	let a = 5
	let b = 10
	let sum = add(a, b)
	let product = multiply(a, b)

	printInt(sum)
	printInt(product)

	return 0
end 'main'

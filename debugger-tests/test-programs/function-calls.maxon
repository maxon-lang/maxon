// Test function calls and stepping
function add(a int, b int) int
	let result = a + b
	return result
end 'add'

function multiply(x int, y int) int
	let product = x * y
	return product
end 'multiply'

function main() int
	let a = 5
	let b = 10
	let sum = add(a, b)
	let product = multiply(a, b)

	print_int(sum)
	print_int(product)

	return 0
end 'main'

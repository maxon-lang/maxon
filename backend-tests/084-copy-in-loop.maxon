// ExitCode: 55
// Phase: Optimization correctness test
// Test copy semantics within a loop
// Each iteration: save current y to x, then increment y
// After loop: x should be the value y had BEFORE last increment
function main() returns int
	var x = 0
	var y = 1
	var i = 0
	while i < 10 'loop'
		x = y
		y = y + i
		i = i + 1
	end 'loop'
	// Trace: i=0: x=1, y=1+0=1; i=1: x=1, y=1+1=2; i=2: x=2, y=2+2=4
	// i=3: x=4, y=4+3=7; i=4: x=7, y=7+4=11; i=5: x=11, y=11+5=16
	// i=6: x=16, y=16+6=22; i=7: x=22, y=22+7=29; i=8: x=29, y=29+8=37
	// i=9: x=37, y=37+9=46; loop ends
	// Result: x(37) + y(46) - 28 = 55
	return x + y - 28
end 'main'

// ExitCode: 15
// Phase 10: Break/continue inside if/else inside while
// Tests that break and continue work correctly in all if/else variants nested in while loops
function main() int
	var result = 0

	// Test 1: break in block if (adds 1)
	var x = 0
	while true 't1'
		x = 1
		if true 't1'
			break
		end 't1'
		x = 99
	end 't1'
	result = result + x

	// Test 2: break in block else (adds 2)
	x = 0
	while true 't2'
		x = 2
		if false 't2'
			x = 99
		else 't2'
			break
		end 't2'
		x = 99
	end 't2'
	result = result + x

	// Test 3: break in block if (adds 3)
	x = 0
	while true 't3'
		x = 3
		if true 't3'
			break
		end 't3'
		x = 99
	end 't3'
	result = result + x

	// Test 4: break in another block if (adds 4)
	x = 0
	while true 't4'
		x = 4
		if true 't4'
			break
		end 't4'
		x = 99
	end 't4'
	result = result + x

	// Test 5: continue in block if (adds 5)
	x = 0
	var count = 0
	while count < 5 't5'
		count = count + 1
		if true 't5'
			continue
		end 't5'
		x = 99
	end 't5'
	result = result + count

	return result
end 'main'

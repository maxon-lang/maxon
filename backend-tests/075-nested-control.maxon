// ExitCode: 5
// Phase 10: Nested control flow
// Count cells where (i + j) is even in a 3x3 grid
// (0,0), (0,2), (1,1), (2,0), (2,2) = 5 cells
function main() int
    var result = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            if (i + j) mod 2 == 0 'even'
                result = result + 1
            end 'even'
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return result
end 'main'

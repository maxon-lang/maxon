; EXPECT: fail
; Test: PHI node missing predecessor
; The PHI node is missing an entry for one of its predecessor blocks

define i32 @test_phi_missing_pred() {
entry:
    %cond = icmp eq i32 1, 1
    br i1 %cond, label %left, label %right

left:
    br label %merge

right:
    br label %merge

merge:
    ; ERROR: PHI is missing entry for 'right' predecessor
    %val = phi i32 [10, %left]
    ret i32 %val
}

; EXPECT: fail
; Test: cross-block value use without dominance
; %val is defined in block 'define_val' but used in 'use_val' which is NOT dominated by 'define_val'

define i32 @test_cross_block_invalid() {
entry:
    %cond = icmp eq i32 1, 1
    br i1 %cond, label %define_val, label %use_val

define_val:
    %val = add i32 10, 20
    br label %exit

use_val:
    ; ERROR: %val is not dominated here - control can reach use_val without going through define_val
    %result = add i32 %val, 5
    br label %exit

exit:
    ret i32 0
}

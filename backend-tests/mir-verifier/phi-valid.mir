; EXPECT: pass
; Test: PHI node with correct predecessors

define i32 @test_phi_valid() {
entry:
    %cond = icmp eq i32 1, 1
    br i1 %cond, label %left, label %right

left:
    br label %merge

right:
    br label %merge

merge:
    ; OK: PHI has entries for both predecessors
    %val = phi i32 [10, %left], [20, %right]
    ret i32 %val
}

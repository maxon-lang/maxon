// ExitCode: 42
// Test: struct fields with default values

struct Counter
	var value int = 0
	var step int = 1
end 'Counter'

function main() int
	// Use default values - omit all fields
	var c1 = Counter{}

	// Override one default
	var c2 = Counter{value: 40}

	// Override both
	var c3 = Counter{value: 10, step: 2}

	// c1: value=0, step=1
	// c2: value=40, step=1
	// c3: value=10, step=2
	// Total: 0 + 40 + 10/2 = 0 + 40 + 2 (step ignored for division)
	// Let's just sum: 0 + 40 + 2 = 42
	return c1.value + c2.value + c3.step
end 'main'

// Test string reassignment (struct copy fix)
// This test verifies that reassigning a string variable correctly copies the struct contents

function main() int
    // Test basic string initialization
    var s = "hello"
    print_int(s.count())  // Should print 5

    // Test reassignment - this was previously broken (struct pointer stored instead of copied)
    var u = "abc"
    u = "testing"
    print_int(u.count())  // Should print 7 (not 3)

    // Test empty string to non-empty
    var v = ""
    v = "world"
    print_int(v.count())  // Should print 5 (not 0)

    return 0
end 'main'

// ExitCode: 104
// Phase: Optimization correctness test
// Test chained variable copies with modifications
// a = b copies 2 to a, b = c copies 3 to b, c = 99 changes c only
// Result: a(2) + b(3) + c(99) = 104
function main() returns int
	var a = 1
	var b = 2
	var c = 3
	a = b
	b = c
	c = 99
	return a + b + c
end 'main'

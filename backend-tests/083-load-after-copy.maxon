// ExitCode: 45
// Phase: Optimization correctness test
// Test multiple loads from copied variable after source changes
// x = y (x gets 10), then y changes multiple times
// x should still be 10 for all subsequent loads
function main() returns int
	var x = 0
	var y = 10
	x = y
	y = 20
	var a = x
	y = 30
	var b = x
	y = 40
	var c = x
	// a=10, b=10, c=10, x=10, so need to adjust return
	// Let's return a + b + c + x + y/10 = 10+10+10+10+4 = 44?
	// Actually: a(10) + b(10) + c(10) + x(10) = 40, plus y/8 = 5, total 45
	return a + b + c + x + trunc(y / 8)
end 'main'

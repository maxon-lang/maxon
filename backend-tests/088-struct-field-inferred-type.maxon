// ExitCode: 55
// Test: struct fields with type inference from default value

struct Settings
	let maxRetries = 5    // inferred int
	var timeout = 50.0    // inferred float
end 'Settings'

function main() int
	var s = Settings{}
	// maxRetries = 5, timeout = 50.0
	// Return 5 + trunc(50.0) = 55
	return s.maxRetries + trunc(s.timeout)
end 'main'

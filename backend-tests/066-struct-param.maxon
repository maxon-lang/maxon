// ExitCode: 10
// Phase 9: Struct as function parameter
// dot(v1, v2) = 3*2 + 4*1 = 6 + 4 = 10
struct Vec2
    x int
    y int
end 'Vec2'

function dot(a Vec2, b Vec2) int
    return a.x * b.x + a.y * b.y
end 'dot'

function main() int
    var v1 = Vec2 { x: 3, y: 4 }
    var v2 = Vec2 { x: 2, y: 1 }
    return dot(v1, v2)
end 'main'

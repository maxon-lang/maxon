; ExitCode: 15
; Test: Critical edge - phi block has multiple preds, one pred has multiple succs
; This tests that phi elimination correctly handles critical edges by splitting them
; 
; In this test, the 'entry' block branches to either 'left' or 'merge'.
; The 'merge' block has phi from both 'left' and 'entry'.
; The edge from 'entry' to 'merge' is a critical edge because:
;   - entry has multiple successors (left, merge)
;   - merge has multiple predecessors (left, entry)
;
; Without critical edge splitting, the copy for phi would be placed incorrectly.
; Expected: n=5, cond (5 > 3) is true, so we go to 'left', add 10 -> 15

define i32 @main() {
entry:
    %n = add i32 0, 5
    %cond = icmp sgt i32 %n, 3
    br i1 %cond, label %left, label %merge

left:
    %left_val = add i32 %n, 10
    br label %merge

merge:
    ; Critical edge: entry->merge when left is not taken
    ; %n comes from entry (via critical edge), %left_val comes from left
    %result = phi i32 [%left_val, %left], [%n, %entry]
    ret i32 %result
}

; ExitCode: 10
; Test: Simple phi node - if/else with phi returning constant values
; This tests basic phi elimination with two predecessors
; The condition (1 == 1) is always true, so we should take the "left" branch
; and return 10.

define i32 @main() {
entry:
    %cond = icmp eq i32 1, 1
    br i1 %cond, label %left, label %right

left:
    br label %merge

right:
    br label %merge

merge:
    %val = phi i32 [10, %left], [20, %right]
    ret i32 %val
}

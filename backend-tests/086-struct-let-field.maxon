// ExitCode: 1
// Test: struct with let (immutable) field
// Verify let fields are immutable - cannot be modified after init

struct Config
	let version int
	var count int
end 'Config'

function main() returns int
	var cfg = Config{version: 1, count: 0}
	cfg.count = 5
	// cfg.version = 2  // This would cause a compile error
	if cfg.version == 1 and cfg.count == 5 'check'
		return 1
	end 'check'
	return 0
end 'main'

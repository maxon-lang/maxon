// ExitCode: 30
// Phase 5: Continue statement - sum even numbers 1-10
// 2 + 4 + 6 + 8 + 10 = 30
function main() int
    var sum = 0
    var i = 0
    while i < 10
        i = i + 1
        if i % 2 == 1
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'

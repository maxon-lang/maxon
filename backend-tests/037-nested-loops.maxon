// ExitCode: 9
// Phase 5: Nested loops - 3x3 iterations
function main() int
    var count = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            count = count + 1
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return count
end 'main'

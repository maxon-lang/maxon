// ExitCode: 12
// Labeled continue in nested loops - skip when y==3
// Each outer iteration: 5 inner iterations, but skip 1 (y==3), so add 4 to sum
// 3 outer iterations * 4 = 12
function main() int
    var sum = 0
    var x = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            if y == 3 'check'
                continue 'inner'
            end 'check'
            sum = sum + 1
        end 'inner'
    end 'outer'
    return sum
end 'main'

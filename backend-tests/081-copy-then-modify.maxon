// ExitCode: 50
// Phase: Optimization correctness test
// Test that copying a variable then modifying the source preserves semantics
// x = y copies value 20 to x, then y = 30 changes y but NOT x
// Result: x(20) + y(30) = 50
function main() int
	var x = 10
	var y = 20
	x = y
	y = 30
	return x + y
end 'main'

// ExitCode: 8
// Phase 11: Safe FFI memset regression test
// This test ensures extern function calls work correctly.
// Previously, calling @memset from ffi_spawn_worker caused a crash.
// The FFI worker subprocess must be spawned and execute correctly.
extern function add_numbers(a int, b int) int "ffi_test_lib"

function main() int
	var result = add_numbers(5, 3)
	return result
end 'main'

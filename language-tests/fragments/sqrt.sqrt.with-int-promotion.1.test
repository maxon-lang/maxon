// Test: sqrt.sqrt.with-int-promotion.1
function main() int
    var x = 16  // int
    var result = sqrt(x)  // x promoted to 16.0
    return trunc(result)
end 'main'
---
; Module: test.maxon
; Instructions: 14

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 16, ptr %0
  %1 = load i32, ptr %0
  %2 = sitofp i32 %1 to f64
  %3 = call f64 @sqrt(f64 %2)
  %4 = alloca f64
  store f64 %3, ptr %4
  %5 = load f64, ptr %4
  %6 = call f64 @trunc(f64 %5)
  %7 = fptosi f64 %6 to i32
  ret i32 %7
}

declare f64 @sqrt(f64 %arg0)

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


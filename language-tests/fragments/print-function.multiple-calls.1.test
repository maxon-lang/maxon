// Test: print-function.multiple-calls.1
function main() int
    var x = 42
    print(x)
    print(10 + 5)
    print(100)
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  tail call fastcc void @sys.print(i32 42)
  tail call fastcc void @sys.print(i32 15)
  tail call fastcc void @sys.print(i32 100)
  ret i32 0
}


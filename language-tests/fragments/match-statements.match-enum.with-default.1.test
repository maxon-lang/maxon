; Instructions: 7

define i32 @main() {
entry0:
  br label %match.check.04
match.case.02:
  ret i32 1
match.case.13:
  ret i32 0
match.check.04:
  br i1 0, label %match.case.02, label %match.case.13
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


// Test: sin.sin.with-int-promotion.1
function main() int
    var x = 0  // int
    var result = sin(x)  // x promoted to 0.0
    if result = 0.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 0
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 0)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %result = alloca double, align 8
  %x = alloca i32, align 4
  store i32 0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  %x1 = load i32, ptr %x, align 4, !dbg !11
  %inttofp = sitofp i32 %x1 to double, !dbg !11
  %sin_result = call double @sin(double %inttofp), !dbg !11
  store double %sin_result, ptr %result, align 8, !dbg !11
    #dbg_declare(ptr %result, !12, !DIExpression(), !11)
  %result2 = load double, ptr %result, align 8, !dbg !13
  %fcmptmp = fcmp oeq double %result2, 0.000000e+00, !dbg !13
  br i1 %fcmptmp, label %then, label %ifcont, !dbg !13

then:                                             ; preds = %entry
  ret i32 0, !dbg !14

ifcont:                                           ; preds = %entry
  ret i32 1, !dbg !15
}

declare double @sin(double)

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)

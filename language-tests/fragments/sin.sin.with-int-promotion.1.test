; Module: test.maxon
; Instructions: 9

define i32 @main() {
entry0:
  %2 = sitofp i32 0 to f64
  %3 = call f64 @sin(f64 %2)
  %6 = fcmp oeq f64 %3, 0
  br i1 %6, label %then1, label %ifcont2
then1:
  ret i32 0
ifcont2:
  ret i32 1
}

declare f64 @sin(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


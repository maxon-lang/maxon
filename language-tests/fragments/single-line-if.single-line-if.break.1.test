// Test: single-line-if.single-line-if.break.1
function main() int
	var x = 11
	var i = 5
	while i > 0 'loop'
		if x == 11 then break
		i = i - 1
	end 'loop'
	return i
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 11, ptr %0
  %1 = alloca i32
  store i32 5, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %1
  %3 = icmp sgt i32 %2, 0
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %0
  %5 = icmp eq i32 %4, 11
  br i1 %5, label %then4, label %ifcont5
afterloop3:
  %8 = load i32, ptr %1
  ret i32 %8
then4:
  br label %afterloop3
ifcont5:
  %6 = load i32, ptr %1
  %7 = sub i32 %6, 1
  store i32 %7, ptr %1
  br label %whilecond1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


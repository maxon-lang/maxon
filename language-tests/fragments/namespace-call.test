namespace math 'math'
    function add(a int, b int) int
        return a + b
    end 'add'
end 'math'

function main() int
    return math.add(10, 20)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %0 = call i32 @"math::add"(i32 10, i32 20)
  ret i32 %0
}

define i32 @"math::add"(i32 %0, i32 %1) {
entry:
  %addtmp = add i32 %1, %0
  ret i32 %addtmp
}
---
ExitCode: 30

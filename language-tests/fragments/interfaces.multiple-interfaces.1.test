// Test: interfaces.multiple-interfaces.1
interface Hashable
    function hash() int
end 'Hashable'

interface Equatable
    function equals(other Self) int
end 'Equatable'

struct Point is Hashable, Equatable
    x int
    y int

    function Hashable.hash() int
        return x + y
    end 'hash'

    function Equatable.equals(other Point) int
        if x == other.x and y == other.y then return 1
        return 0
    end 'equals'
end 'Point'

function main() int
    var p1 = Point{x: 3, y: 4}
    var p2 = Point{x: 3, y: 4}
    return p1.hash() + p1.equals(p2)
end 'main'

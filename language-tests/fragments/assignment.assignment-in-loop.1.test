// Test: assignment.assignment-in-loop.1
function main() int
    var sum = 0
    var i = 1
    while i <= 5 'loop'
        sum = sum + i
        i = i + 1
    end 'loop'
    return sum
end 'main'
---
; Module: test.maxon
; Instructions: 21

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 1, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %1
  %3 = icmp sle i32 %2, 5
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %0
  %5 = load i32, ptr %1
  %6 = add i32 %4, %5
  store i32 %6, ptr %0
  %7 = load i32, ptr %1
  %8 = add i32 %7, 1
  store i32 %8, ptr %1
  br label %whilecond1
afterloop3:
  %9 = load i32, ptr %0
  ret i32 %9
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


// Test: method-call-on-parameter.sibling-method-call-still-works.1
type Calculator
    var base int
    
    function double() returns int
        return base * 2
    end 'double'
    
    function quadruple() returns int
        // Sibling call - calls self.double()
        return double() * 2
    end 'quadruple'
end 'Calculator'

function main() returns int
    var calc = Calculator{base: 5}
    return calc.quadruple()
end 'main'
---
; Module: test.maxon
; Instructions: 11

%Calculator = type { i32 }

define i32 @main() {
entry0:
  %0 = alloca %Calculator
  %1 = getelementptr %Calculator, ptr %0, i32 0, i32 0
  store i32 5, ptr %1
  %3 = getelementptr %Calculator, ptr %0, i32 0, i32 0
  %4 = load i32, ptr %3
  %5 = shl i32 %4, 1
  %6 = shl i32 %5, 1
  ret i32 %6
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


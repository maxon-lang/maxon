%Calculator = type { i32 }

define i32 @Calculator.double(ptr %self) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = load ptr, ptr %0
  %2 = getelementptr %Calculator, ptr %1, i32 0, i32 0
  %3 = load i32, ptr %2
  %4 = mul i32 %3, 2
  ret i32 %4
}

define i32 @Calculator.quadruple(ptr %self) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = load ptr, ptr %0
  %2 = call i32 @Calculator.double(ptr %1)
  %3 = mul i32 %2, 2
  ret i32 %3
}

define i32 @main() {
entry0:
  %0 = alloca %Calculator
  %1 = getelementptr %Calculator, ptr %0, i32 0, i32 0
  store i32 5, ptr %1
  %2 = call i32 @Calculator.quadruple(ptr %0)
  ret i32 %2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


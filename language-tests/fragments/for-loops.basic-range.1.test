forcond1:
  %13 = phi i32 [ 0, %entry0 ], [ %10, %forincrement3 ]
  %12 = phi i32 [ 0, %entry0 ], [ %8, %forincrement3 ]
  %5 = icmp slt i32 %13, 5
  br i1 %5, label %forloop2, label %afterfor4
forloop2:
  %8 = add i32 %12, %13
  br label %forincrement3
forincrement3:
  %10 = add i32 %13, 1
  br label %forcond1
afterfor4:
  ret i32 %12
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


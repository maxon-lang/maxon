// Test: for-loops.basic-range.1
function main() int
    var sum = 0
    for i in range(0, 5) 'loop'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
; Module: test.maxon
; Instructions: 25

%__unsized_array_byte = type { ptr, i32 }
%string = type { %__unsized_array_byte, i32, i32 }
%ByteView = type { %string, i32 }
%UTF16View = type { %string, i32, i32 }
%Iterator = type { i32, i32, i32 }

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  %2 = alloca i32
  store i32 5, ptr %2
  br label %forcond1
forcond1:
  %3 = load i32, ptr %1
  %4 = load i32, ptr %2
  %5 = icmp slt i32 %3, %4
  br i1 %5, label %forloop2, label %afterfor4
forloop2:
  %6 = load i32, ptr %0
  %7 = load i32, ptr %1
  %8 = add i32 %6, %7
  store i32 %8, ptr %0
  br label %forincrement3
forincrement3:
  %9 = load i32, ptr %1
  %10 = add i32 %9, 1
  store i32 %10, ptr %1
  br label %forcond1
afterfor4:
  %11 = load i32, ptr %0
  ret i32 %11
}

declare ptr @malloc(i64 %arg0)

declare void @free(ptr %arg0)

declare ptr @memset(ptr %arg0, i32 %arg1, i64 %arg2)

declare ptr @memcpy(ptr %arg0, ptr %arg1, i64 %arg2)


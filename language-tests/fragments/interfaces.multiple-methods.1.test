  %6 = load i32, ptr %5
  %7 = add i32 100, %6
  %8 = getelementptr %Counter, ptr %0, i32 0, i32 0
  %9 = load i32, ptr %8
  %4 = add i32 %7, %9
  ret i32 %4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()

// Test: interfaces.multiple-methods.1
interface Describable
    function describe(self Self) int
    function value(self Self) int
end 'Describable'

struct Counter is Describable
    count int
end 'Counter'

function Counter.describe(self Counter) int
    return 100 + self.count
end 'describe'

function Counter.value(self Counter) int
    return self.count
end 'value'

function main() int
    var c = Counter{count: 42}
    return Counter.describe(c) + Counter.value(c)
end 'main'

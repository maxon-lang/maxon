// Test: mem2reg-phi-placement.doc-example-2.1
function main() returns int
    var x = 0
    if 1 > 0 'branch'
        x = 10
    end 'branch' else 'else_branch'
        x = 20
    end 'else_branch'
    return x
end 'main'
---
OptimizedInstructions: 0
UnoptimizedInstructions: 0
ExitCode: 10
---
; Module: test.maxon

define i64 @main() {
entry0:
  br i1 1, label %then1, label %else3
then1:
  br label %ifcont2
ifcont2:
  %3 = phi i64 [ 10, %then1 ], [ 20, %else3 ]
  ret i64 %3
else3:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}

---
; Module: test.maxon

define i64 @main() {
entry0:
  %0 = alloca i64
  store i64 0, ptr %0
  %1 = icmp sgt i64 1, 0
  br i1 %1, label %then1, label %else3
then1:
  store i64 10, ptr %0
  br label %ifcont2
ifcont2:
  %2 = load i64, ptr %0
  ret i64 %2
else3:
  store i64 20, ptr %0
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)

// Test: return-statement.conditional-return.1
function main() int
    var x = 5
    if x > 3 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 5, ptr %0
  %1 = load i32, ptr %0
  %2 = icmp sgt i32 %1, 3
  br i1 %2, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


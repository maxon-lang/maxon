define i32 @main() !dbg !4 {
entry:
  %y = alloca i32, align 4
  %count = alloca i32, align 4
  %x = alloca i32, align 4
  store i32 0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  store i32 0, ptr %count, align 4, !dbg !11
    #dbg_declare(ptr %count, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %afterloop, %then, %entry
  %x1 = load i32, ptr %x, align 4, !dbg !13
  %cmptmp = icmp slt i32 %x1, 3, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop13, !dbg !13

loop:                                             ; preds = %whilecond
  %x2 = load i32, ptr %x, align 4, !dbg !14
  %addtmp = add i32 %x2, 1, !dbg !14
  store i32 %addtmp, ptr %x, align 4, !dbg !14
  store i32 0, ptr %y, align 4, !dbg !15
    #dbg_declare(ptr %y, !16, !DIExpression(), !15)
  br label %whilecond3, !dbg !17

whilecond3:                                       ; preds = %ifcont, %loop
  %y4 = load i32, ptr %y, align 4, !dbg !17
  %cmptmp5 = icmp slt i32 %y4, 5, !dbg !17
  br i1 %cmptmp5, label %loop6, label %afterloop, !dbg !17

loop6:                                            ; preds = %whilecond3
  %y7 = load i32, ptr %y, align 4, !dbg !18
  %addtmp8 = add i32 %y7, 1, !dbg !18
  store i32 %addtmp8, ptr %y, align 4, !dbg !18
  %count9 = load i32, ptr %count, align 4, !dbg !19
  %addtmp10 = add i32 %count9, 1, !dbg !19
  store i32 %addtmp10, ptr %count, align 4, !dbg !19
  %y11 = load i32, ptr %y, align 4, !dbg !20
  %cmptmp12 = icmp eq i32 %y11, 2, !dbg !20
  br i1 %cmptmp12, label %then, label %ifcont, !dbg !20

then:                                             ; preds = %loop6
  br label %whilecond, !dbg !21

aftercontinue:                                    ; No predecessors!
  br label %ifcont, !dbg !21

ifcont:                                           ; preds = %aftercontinue, %loop6
  br label %whilecond3, !dbg !21

afterloop:                                        ; preds = %whilecond3
  br label %whilecond, !dbg !21

afterloop13:                                      ; preds = %whilecond
  %count14 = load i32, ptr %count, align 4, !dbg !22
  ret i32 %count14, !dbg !22
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



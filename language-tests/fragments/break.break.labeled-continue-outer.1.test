// Test: break.break.labeled-continue-outer.1
function main() int
    var x = 0
    var count = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            count = count + 1
            if y = 2 'check'
                continue 'outer'
            end 'check'
        end 'inner'
    end 'outer'
    return count
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 6
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 6)
  unreachable
}


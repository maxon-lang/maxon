  %0 = ptrtoint ptr %x to i64
  %ptr2inttmp = trunc i64 %0 to i32
  %cmptmp = icmp slt i32 %ptr2inttmp, 1
  %. = zext i1 %cmptmp to i32
  ret i32 %.
}


// Test: arrays.dynamic.push-pop.1
function main() returns int
    var arr = [1, 2, 3]
    arr.push(4)
    arr.push(5)
    var count_after_push = arr.count()
    var popped = arr.pop() else 'unwrap'
        popped = 0
    end 'unwrap'
    var count_after_pop = arr.count()
    return count_after_push * 100 + popped * 10 + count_after_pop
end 'main'

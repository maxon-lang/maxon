function main() int
    var x = 5
    if x == 5 'check'
        return 1
    else 'check'
        return 0
    end 'check'
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4
  %x1 = load i32, ptr %x, align 4
  %cmptmp = icmp eq i32 %x1, 5
  br i1 %cmptmp, label %then, label %else

then:                                             ; preds = %entry
  ret i32 1

else:                                             ; preds = %entry
  ret i32 0
}
---
ExitCode: 1

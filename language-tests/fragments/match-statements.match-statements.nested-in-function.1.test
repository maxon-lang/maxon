// Test: match-statements.match-statements.nested-in-function.1
function categorize(n int) returns int
    match n 'cat'
        1 or 2 or 3 then return 1
        4 or 5 or 6 then return 2
        default then return 0
    end 'cat'
end 'categorize'

function main() returns int
    return categorize(5)
end 'main'

  br label %match.check.17
match.check.16:
match.check.17:
  %10 = icmp eq i32 %n, 4
  %11 = icmp eq i32 %n, 5
  %12 = or i1 %10, %11
  %13 = icmp eq i32 %n, 6
  %14 = or i1 %12, %13
  br i1 %14, label %match.case.13, label %match.case.24

// Test: namespaces.nested-calls-in-namespace.1
function add(a int, b int) int
    return a + b
end 'add'

function sum_three(a int, b int, c int) int
    return add(add(a, b), c)
end 'sum_three'

function main() int
    return sum_three(1, 2, 3)
end 'main'

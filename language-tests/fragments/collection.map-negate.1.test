// Test: collection.map-negate.1
function negate(x int) returns int
    return 0 - x
end 'negate'

function main() returns int
    var arr = [1, 2, 3]
    var result = arr.map(negate)
    print("{result[0]}")
    print("{result[1]}")
    print("{result[2]}")
    return 0
end 'main'

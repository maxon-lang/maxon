// Test: arithmetic-operators.negative-division.1
function main() int
    var neg = 0 - 7
    return trunc(neg / 2)    // -7/2 = -3.5, trunc = -3 (toward zero)
end 'main'
---
; Module: test.maxon
; Instructions: 13

define i32 @main() {
entry0:
  %0 = sub i32 0, 7
  %1 = alloca i32
  store i32 %0, ptr %1
  %2 = load i32, ptr %1
  %3 = sitofp i32 %2 to f64
  %4 = sitofp i32 2 to f64
  %5 = fdiv f64 %3, %4
  %6 = call f64 @trunc(f64 %5)
  %7 = fptosi f64 %6 to i32
  ret i32 %7
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


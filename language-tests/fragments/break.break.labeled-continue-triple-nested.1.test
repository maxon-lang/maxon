// Test: break.break.labeled-continue-triple-nested.1
function main() int
    var count = 0
    var a = 0
    while a < 2 'outer'
        a = a + 1
        var b = 0
        while b < 3 'middle'
            b = b + 1
            var c = 0
            while c < 4 'inner'
                c = c + 1
                count = count + 1
                if c == 2 'check'
                    continue 'middle'
                end 'check'
            end 'inner'
        end 'middle'
    end 'outer'
    return count
end 'main'
---

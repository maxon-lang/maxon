define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %1
  %3 = icmp slt i32 %2, 2
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %1
  %5 = add i32 %4, 1
  store i32 %5, ptr %1
  %6 = alloca i32
  store i32 0, ptr %6
  br label %whilecond4
afterloop3:
  %20 = load i32, ptr %0
  ret i32 %20
whilecond4:
  %7 = load i32, ptr %6
  %8 = icmp slt i32 %7, 3
  br i1 %8, label %loop5, label %afterloop6
loop5:
  %9 = load i32, ptr %6
  %10 = add i32 %9, 1
  store i32 %10, ptr %6
  %11 = alloca i32
  store i32 0, ptr %11
  br label %whilecond7
afterloop6:
  br label %whilecond1
whilecond7:
  %12 = load i32, ptr %11
  %13 = icmp slt i32 %12, 4
  br i1 %13, label %loop8, label %afterloop9
loop8:
  %14 = load i32, ptr %11
  %15 = add i32 %14, 1
  store i32 %15, ptr %11
  %16 = load i32, ptr %0
  %17 = add i32 %16, 1
  store i32 %17, ptr %0
  %18 = load i32, ptr %11
  %19 = icmp eq i32 %18, 2
  br i1 %19, label %then10, label %ifcont11
afterloop9:
  br label %whilecond4
then10:
  br label %whilecond4
ifcont11:
  br label %whilecond7
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


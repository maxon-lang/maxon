// Test value-initialized array
function main() int
    var arr = [10, 20, 30, 40]
    return arr[2]
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %arr.malloc = call ptr @malloc(i64 16)
  store i32 10, ptr %arr.malloc, align 4
  %arrayidx1 = getelementptr i8, ptr %arr.malloc, i64 4
  store i32 20, ptr %arrayidx1, align 4
  %arrayidx2 = getelementptr i8, ptr %arr.malloc, i64 8
  store i32 30, ptr %arrayidx2, align 4
  %arrayidx3 = getelementptr i8, ptr %arr.malloc, i64 12
  store i32 40, ptr %arrayidx3, align 4
  call void @free(ptr nonnull %arr.malloc)
  ret i32 30
}

declare ptr @GetProcessHeap()

declare ptr @HeapAlloc(ptr, i32, i64)

declare i32 @HeapFree(ptr, i32, ptr)

define ptr @malloc(i64 %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call ptr @HeapAlloc(ptr %1, i32 0, i64 %0)
  ret ptr %2
}

define void @free(ptr %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}
---
ExitCode: 30

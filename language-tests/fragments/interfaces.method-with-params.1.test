// Test: interfaces.method-with-params.1
interface Calculator
    function add(n int) returns int
end 'Calculator'

type Accumulator is Calculator
    var total int

    function Calculator.add(n int) returns int
        return total + n
    end 'add'
end 'Accumulator'

function main() returns int
    var acc = Accumulator{total: 10}
    return acc.add(5)
end 'main'
---
; Module: test.maxon
; Instructions: 10

%Accumulator = type { i64 }

define i64 @main() {
entry0:
  %0 = alloca %Accumulator
  %1 = getelementptr %Accumulator, ptr %0, i32 0, i32 0
  store i64 10, ptr %1
  %3 = getelementptr %Accumulator, ptr %0, i32 0, i32 0
  %4 = load i64, ptr %3
  %5 = add i64 %4, 5
  ret i64 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}

---
; Module: test.maxon
; Instructions: 18

%Accumulator = type { i64 }

define i64 @Accumulator.add(ptr %self, i64 %n) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = alloca i64
  store i64 %n, ptr %1
  %2 = load ptr, ptr %0
  %3 = getelementptr %Accumulator, ptr %2, i32 0, i32 0
  %4 = load i64, ptr %3
  %5 = load i64, ptr %1
  %6 = add i64 %4, %5
  ret i64 %6
}

define i64 @main() {
entry0:
  %0 = alloca %Accumulator
  %1 = getelementptr %Accumulator, ptr %0, i32 0, i32 0
  store i64 10, ptr %1
  %2 = call i64 @Accumulator.add(ptr %0, i64 5)
  ret i64 %2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


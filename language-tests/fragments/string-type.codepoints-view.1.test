// Test: string-type.codepoints-view.1
function main() int
    var s = "Aé"  // A (1 codepoint) + é (1 codepoint if precomposed)
    for cp in s.codepoints() 'loop'
        print_int(cp)
    end 'loop'
    return 0
end 'main'

  %12 = load i64, ptr %11
  %13 = add i64 %10, %12
  %14 = getelementptr %Value, ptr %0, i32 0, i32 0
  %15 = load i64, ptr %14
  %16 = getelementptr %Value, ptr %4, i32 0, i32 0
  %17 = load i64, ptr %16

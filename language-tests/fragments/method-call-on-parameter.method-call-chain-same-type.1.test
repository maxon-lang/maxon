// Test: method-call-on-parameter.method-call-chain-same-type.1
type Value
    var n int
    
    function get() returns int
        return n
    end 'get'
    
    function add(other Value) returns int
        return n + other.get()
    end 'add'
    
    function multiply(other Value) returns int
        return n * other.get()
    end 'multiply'
end 'Value'

function main() returns int
    var a = Value{n: 5}
    var b = Value{n: 3}
    var c = Value{n: 2}
    // a.add(b) = 5 + 3 = 8
    // a.multiply(c) = 5 * 2 = 10
    // total = 8 + 10 = 18
    return a.add(b) + a.multiply(c)
end 'main'

; Instructions: 11

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 7, ptr %0
  %1 = alloca i32
  store i32 2, ptr %1
  %2 = load i32, ptr %0
  %3 = load i32, ptr %1
  %8 = sdiv i32 %2, %3
  ret i32 %8
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


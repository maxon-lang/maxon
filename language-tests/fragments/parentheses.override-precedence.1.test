// Test: parentheses.override-precedence.1
function main() int
    return (2 + 3) * 4
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  ret i32 20
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


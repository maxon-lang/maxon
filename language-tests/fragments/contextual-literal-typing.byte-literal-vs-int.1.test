define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 100, ptr %0
  %1 = load i32, ptr %0
  %2 = zext i8 100 to i32
  %3 = icmp eq i32 %1, %2
  br i1 %3, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:

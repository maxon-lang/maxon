// Test: character-type.escape-sequences.1
function main() returns int
    var newline = '\n'
    var tab = '\t'
    var backslash = '\\'
    var quote = '\''
    print("{newline.bytes().count()}")
    print("{tab.bytes().count()}")
    print("{backslash.bytes().count()}")
    print("{quote.bytes().count()}")
    return 0
end 'main'

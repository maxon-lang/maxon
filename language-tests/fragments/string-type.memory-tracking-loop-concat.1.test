// Test: string-type.memory-tracking-loop-concat.1
// Note: Loop reassignment currently leaks intermediate strings.
// This will be fixed when we implement release-before-reassign.
function main() int
    var s = ""
    var i = 0
    while i < 3 'loop'
        s = s + "x"
        i = i + 1
    end 'loop'
    print(s.count())
    return 0
end 'main'

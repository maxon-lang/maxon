// Test: string-type.memory-tracking-loop-concat.1
function main() int
    var s = ""
    var i = 0
    while i < 3 'loop'
        s = s + "x"
        i = i + 1
    end 'loop'
    print_int(s.count())
    return 0
end 'main'

// Test: match-statements.match-enum.exhaustive.1
enum Color
    case red
    case green
    case blue
end 'Color'

function main() int
    var c = Color.green
    match c 'check'
        Color.red then return 1
        Color.green then return 2
        Color.blue then return 3
    end 'check'
end 'main'
---
; Module: test.maxon
; Instructions: 22

define i32 @main() {
entry0:
  %0 = alloca i8
  store i8 1, ptr %0
  %1 = load i8, ptr %0
  %2 = alloca i8
  store i8 %1, ptr %2
  br label %match.check.05
match.merge1:
  ret i32 0
match.case.02:
  ret i32 1
match.case.13:
  ret i32 2
match.case.24:
  ret i32 3
match.check.05:
  %3 = load i8, ptr %2
  %4 = icmp eq i8 %3, 0
  br i1 %4, label %match.case.02, label %match.check.16
match.check.16:
  %5 = load i8, ptr %2
  %6 = icmp eq i8 %5, 1
  br i1 %6, label %match.case.13, label %match.check.27
match.check.27:
  %7 = load i8, ptr %2
  %8 = icmp eq i8 %7, 2
  br i1 %8, label %match.case.24, label %match.merge1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


  br i1 %cmptmp, label %loop28, label %afterloop42, !dbg !56

loop28:                                           ; preds = %whilecond26
  %term29 = load double, ptr %term, align 8, !dbg !57
  %z_squared30 = load double, ptr %z_squared, align 8, !dbg !57
  %fmultmp31 = fmul double %term29, %z_squared30, !dbg !57
  store double %fmultmp31, ptr %term, align 8, !dbg !57
  %k32 = load i32, ptr %k, align 4, !dbg !58

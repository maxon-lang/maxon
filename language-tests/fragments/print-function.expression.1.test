; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@.str.newline = private constant [1 x i8] c"\0A"

define i32 @main() !dbg !4 {
entry:
  %0 = call i32 @print(i32 15), !dbg !8
  ret i32 0, !dbg !9
}

declare ptr @memset(ptr, i32, i64)

declare ptr @GetStdHandle(i32)

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr)

define i32 @print(i32 %0) #0 {
entry:
  %buffer = alloca [12 x i8], align 1, !dbg !8
  %temp = alloca [12 x i8], align 1, !dbg !8
  %bytesWritten = alloca i32, align 4, !dbg !8
  %1 = call ptr @memset(ptr %buffer, i32 0, i64 12), !dbg !8
  %2 = call ptr @memset(ptr %temp, i32 0, i64 12), !dbg !8
  %3 = icmp eq i32 %0, 0, !dbg !8
  br i1 %3, label %zero_case, label %non_zero, !dbg !8

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !8
  store i8 48, ptr %4, align 1, !dbg !8
  br label %format_done, !dbg !8

non_zero:                                         ; preds = %entry
  %5 = icmp slt i32 %0, 0, !dbg !8
  br i1 %5, label %negative, label %positive, !dbg !8

format_done:                                      ; preds = %reverse_loop, %zero_case
  %final_offset = phi i32 [ 0, %zero_case ], [ %offset_in_reverse, %reverse_loop ], !dbg !8
  %final_digit_count = phi i32 [ 1, %zero_case ], [ %digit_count_in_reverse, %reverse_loop ], !dbg !8
  %6 = add i32 %final_offset, %final_digit_count, !dbg !8
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !8
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %6, ptr %bytesWritten, ptr null), !dbg !8
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !8
  ret i32 0, !dbg !8

negative:                                         ; preds = %non_zero
  %10 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !8
  store i8 45, ptr %10, align 1, !dbg !8
  %11 = sub i32 0, %0, !dbg !8
  br label %extract_digits, !dbg !8

positive:                                         ; preds = %non_zero
  br label %extract_digits, !dbg !8

extract_digits:                                   ; preds = %positive, %negative
  %value_abs = phi i32 [ %11, %negative ], [ %0, %positive ], !dbg !8
  %start_offset = phi i32 [ 1, %negative ], [ 0, %positive ], !dbg !8
  br label %digit_loop, !dbg !8

digit_loop:                                       ; preds = %digit_loop_body, %extract_digits
  %remaining = phi i32 [ %value_abs, %extract_digits ], [ %17, %digit_loop_body ], !dbg !8
  %temp_idx = phi i32 [ 0, %extract_digits ], [ %18, %digit_loop_body ], !dbg !8
  %12 = icmp ne i32 %remaining, 0, !dbg !8
  br i1 %12, label %digit_loop_body, label %reverse_loop, !dbg !8

digit_loop_body:                                  ; preds = %digit_loop
  %13 = srem i32 %remaining, 10, !dbg !8
  %14 = add i32 %13, 48, !dbg !8
  %15 = trunc i32 %14 to i8, !dbg !8
  %16 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %temp_idx, !dbg !8
  store i8 %15, ptr %16, align 1, !dbg !8
  %17 = sdiv i32 %remaining, 10, !dbg !8
  %18 = add i32 %temp_idx, 1, !dbg !8
  br label %digit_loop, !dbg !8

reverse_loop:                                     ; preds = %reverse_body, %digit_loop
  %reverse_idx = phi i32 [ 0, %digit_loop ], [ %26, %reverse_body ], !dbg !8
  %offset_in_reverse = phi i32 [ %start_offset, %digit_loop ], [ %offset_in_reverse, %reverse_body ], !dbg !8
  %digit_count_in_reverse = phi i32 [ %temp_idx, %digit_loop ], [ %digit_count_in_reverse, %reverse_body ], !dbg !8
  %19 = icmp slt i32 %reverse_idx, %digit_count_in_reverse, !dbg !8
  br i1 %19, label %reverse_body, label %format_done, !dbg !8

reverse_body:                                     ; preds = %reverse_loop
  %20 = sub i32 %digit_count_in_reverse, %reverse_idx, !dbg !8
  %21 = sub i32 %20, 1, !dbg !8
  %22 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %21, !dbg !8
  %23 = load i8, ptr %22, align 1, !dbg !8
  %24 = add i32 %offset_in_reverse, %reverse_idx, !dbg !8
  %25 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 %24, !dbg !8
  store i8 %23, ptr %25, align 1, !dbg !8
  %26 = add i32 %reverse_idx, 1, !dbg !8
  br label %reverse_loop, !dbg !8
}

define i32 @print_float(double %0, i32 %1) #0 {
entry:
  %float_value_local = alloca double, align 8, !dbg !8
  store double %0, ptr %float_value_local, align 8, !dbg !8
  %float_value = load double, ptr %float_value_local, align 8, !dbg !8
  %buffer = alloca [32 x i8], align 1, !dbg !8
  %bytesWritten = alloca i32, align 4, !dbg !8
  %2 = call ptr @memset(ptr %buffer, i32 0, i64 32), !dbg !8
  %3 = fcmp oeq double %float_value, 0.000000e+00, !dbg !8
  br i1 %3, label %zero_case, label %non_zero, !dbg !8

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !8
  store i8 48, ptr %4, align 1, !dbg !8
  %5 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 1, !dbg !8
  store i8 46, ptr %5, align 1, !dbg !8
  br label %zero_fill_loop, !dbg !8

non_zero:                                         ; preds = %entry
  %pos = alloca i32, align 4, !dbg !8
  store i32 0, ptr %pos, align 4, !dbg !8
  %6 = fcmp olt double %float_value, 0.000000e+00, !dbg !8
  br i1 %6, label %negative, label %positive, !dbg !8

format_done:                                      ; preds = %frac_digits_done, %zero_fill_done
  %final_float_length = phi i32 [ %14, %zero_fill_done ], [ %81, %frac_digits_done ], !dbg !8
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !8
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %final_float_length, ptr %bytesWritten, ptr null), !dbg !8
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !8
  ret i32 0, !dbg !8

zero_fill_loop:                                   ; preds = %zero_fill_body, %zero_case
  %zero_fill_idx = phi i32 [ 0, %zero_case ], [ %13, %zero_fill_body ], !dbg !8
  %10 = icmp slt i32 %zero_fill_idx, %1, !dbg !8
  br i1 %10, label %zero_fill_body, label %zero_fill_done, !dbg !8

zero_fill_body:                                   ; preds = %zero_fill_loop
  %11 = add i32 2, %zero_fill_idx, !dbg !8
  %12 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %11, !dbg !8
  store i8 48, ptr %12, align 1, !dbg !8
  %13 = add i32 %zero_fill_idx, 1, !dbg !8
  br label %zero_fill_loop, !dbg !8

zero_fill_done:                                   ; preds = %zero_fill_loop
  %14 = add i32 2, %1, !dbg !8
  br label %format_done, !dbg !8

negative:                                         ; preds = %non_zero
  %15 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !8
  store i8 45, ptr %15, align 1, !dbg !8
  store i32 1, ptr %pos, align 4, !dbg !8
  %16 = call double @llvm.fabs.f64(double %float_value), !dbg !8
  br label %extract_int, !dbg !8

positive:                                         ; preds = %non_zero
  br label %extract_int, !dbg !8

extract_int:                                      ; preds = %positive, %negative
  %work_value = phi double [ %16, %negative ], [ %float_value, %positive ], !dbg !8
  %int_part_trunc = fptosi double %work_value to i32, !dbg !8
  %int_part_trunc_float = sitofp i32 %int_part_trunc to double, !dbg !8
  %frac_part_initial = fsub double %work_value, %int_part_trunc_float, !dbg !8
  %17 = fcmp ogt double %frac_part_initial, 9.999000e-01, !dbg !8
  %int_part_rounded = add i32 %int_part_trunc, 1, !dbg !8
  %int_part = select i1 %17, i32 %int_part_rounded, i32 %int_part_trunc, !dbg !8
  %int_part_float = sitofp i32 %int_part to double, !dbg !8
  %frac_part = fsub double %work_value, %int_part_float, !dbg !8
  %float_temp = alloca [20 x i8], align 1, !dbg !8
  %18 = call ptr @memset(ptr %float_temp, i32 0, i64 20), !dbg !8
  %float_temp_idx = alloca i32, align 4, !dbg !8
  store i32 19, ptr %float_temp_idx, align 4, !dbg !8
  %19 = icmp eq i32 %int_part, 0, !dbg !8
  br i1 %19, label %int_zero, label %int_nonzero, !dbg !8

int_zero:                                         ; preds = %extract_int
  %20 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 19, !dbg !8
  store i8 48, ptr %20, align 1, !dbg !8
  store i32 18, ptr %float_temp_idx, align 4, !dbg !8
  br label %int_digits_done, !dbg !8

int_nonzero:                                      ; preds = %extract_int
  br label %int_digit_loop, !dbg !8

int_digits_done:                                  ; preds = %int_digit_loop, %int_zero
  %final_temp_idx = phi i32 [ %current_temp_idx, %int_digit_loop ], [ 18, %int_zero ], !dbg !8
  %21 = add i32 %final_temp_idx, 1, !dbg !8
  %22 = sub i32 20, %21, !dbg !8
  br label %copy_int_loop, !dbg !8

int_digit_loop:                                   ; preds = %int_digit_body, %int_nonzero
  %remaining_int = phi i32 [ %int_part, %int_nonzero ], [ %28, %int_digit_body ], !dbg !8
  %current_temp_idx = phi i32 [ 19, %int_nonzero ], [ %29, %int_digit_body ], !dbg !8
  %23 = icmp ne i32 %remaining_int, 0, !dbg !8
  br i1 %23, label %int_digit_body, label %int_digits_done, !dbg !8

int_digit_body:                                   ; preds = %int_digit_loop
  %24 = srem i32 %remaining_int, 10, !dbg !8
  %25 = add i32 %24, 48, !dbg !8
  %26 = trunc i32 %25 to i8, !dbg !8
  %27 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %current_temp_idx, !dbg !8
  store i8 %26, ptr %27, align 1, !dbg !8
  %28 = sdiv i32 %remaining_int, 10, !dbg !8
  %29 = sub i32 %current_temp_idx, 1, !dbg !8
  br label %int_digit_loop, !dbg !8

copy_int_loop:                                    ; preds = %copy_int_body, %int_digits_done
  %copy_idx = phi i32 [ 0, %int_digits_done ], [ %36, %copy_int_body ], !dbg !8
  %30 = icmp slt i32 %copy_idx, %22, !dbg !8
  br i1 %30, label %copy_int_body, label %copy_int_done, !dbg !8

copy_int_body:                                    ; preds = %copy_int_loop
  %current_pos = load i32, ptr %pos, align 4, !dbg !8
  %31 = add i32 %21, %copy_idx, !dbg !8
  %32 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %31, !dbg !8
  %33 = load i8, ptr %32, align 1, !dbg !8
  %34 = add i32 %current_pos, %copy_idx, !dbg !8
  %35 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %34, !dbg !8
  store i8 %33, ptr %35, align 1, !dbg !8
  %36 = add i32 %copy_idx, 1, !dbg !8
  br label %copy_int_loop, !dbg !8

copy_int_done:                                    ; preds = %copy_int_loop
  %pos_after_int = load i32, ptr %pos, align 4, !dbg !8
  %37 = add i32 %pos_after_int, %22, !dbg !8
  store i32 %37, ptr %pos, align 4, !dbg !8
  %38 = load i32, ptr %pos, align 4, !dbg !8
  %39 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %38, !dbg !8
  store i8 46, ptr %39, align 1, !dbg !8
  %40 = add i32 %38, 1, !dbg !8
  store i32 %40, ptr %pos, align 4, !dbg !8
  br label %scale_loop, !dbg !8

scale_loop:                                       ; preds = %scale_body, %copy_int_done
  %scale_idx = phi i32 [ 0, %copy_int_done ], [ %42, %scale_body ], !dbg !8
  %scale_accum = phi double [ 1.000000e+00, %copy_int_done ], [ %next_scale, %scale_body ], !dbg !8
  %41 = icmp slt i32 %scale_idx, %1, !dbg !8
  br i1 %41, label %scale_body, label %scale_done, !dbg !8

scale_body:                                       ; preds = %scale_loop
  %next_scale = fmul double %scale_accum, 1.000000e+01, !dbg !8
  %42 = add i32 %scale_idx, 1, !dbg !8
  br label %scale_loop, !dbg !8

scale_done:                                       ; preds = %scale_loop
  %frac_scaled = fmul double %frac_part, %scale_accum, !dbg !8
  %frac_rounded = fadd double %frac_scaled, 5.000000e-01, !dbg !8
  %frac_int = fptosi double %frac_rounded to i64, !dbg !8
  br label %frac_overflow_check, !dbg !8

frac_overflow_check:                              ; preds = %scale_done
  %43 = fptosi double %scale_accum to i64, !dbg !8
  %44 = icmp sge i64 %frac_int, %43, !dbg !8
  br i1 %44, label %frac_overflow, label %frac_no_overflow, !dbg !8

frac_overflow:                                    ; preds = %frac_overflow_check
  %45 = add i32 %int_part, 1, !dbg !8
  %46 = load i32, ptr %pos, align 4, !dbg !8
  %47 = icmp eq i32 %46, 1, !dbg !8
  %48 = select i1 %47, i32 1, i32 0, !dbg !8
  %49 = call ptr @memset(ptr %float_temp, i32 0, i64 20), !dbg !8
  store i32 19, ptr %float_temp_idx, align 4, !dbg !8
  br label %overflow_int_loop, !dbg !8

frac_no_overflow:                                 ; preds = %overflow_copy_done, %frac_overflow_check
  %final_frac_int = phi i64 [ 0, %overflow_copy_done ], [ %frac_int, %frac_overflow_check ], !dbg !8
  %50 = sub i32 %1, 1, !dbg !8
  br label %frac_digit_loop, !dbg !8

overflow_int_loop:                                ; preds = %overflow_int_body, %frac_overflow
  %overflow_remaining = phi i32 [ %45, %frac_overflow ], [ %56, %overflow_int_body ], !dbg !8
  %overflow_temp_idx = phi i32 [ 19, %frac_overflow ], [ %57, %overflow_int_body ], !dbg !8
  %51 = icmp ne i32 %overflow_remaining, 0, !dbg !8
  br i1 %51, label %overflow_int_body, label %overflow_int_done, !dbg !8

overflow_int_body:                                ; preds = %overflow_int_loop
  %52 = srem i32 %overflow_remaining, 10, !dbg !8
  %53 = add i32 %52, 48, !dbg !8
  %54 = trunc i32 %53 to i8, !dbg !8
  %55 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %overflow_temp_idx, !dbg !8
  store i8 %54, ptr %55, align 1, !dbg !8
  %56 = sdiv i32 %overflow_remaining, 10, !dbg !8
  %57 = sub i32 %overflow_temp_idx, 1, !dbg !8
  br label %overflow_int_loop, !dbg !8

overflow_int_done:                                ; preds = %overflow_int_loop
  %58 = add i32 %overflow_temp_idx, 1, !dbg !8
  %59 = sub i32 20, %58, !dbg !8
  br label %overflow_copy_loop, !dbg !8

overflow_copy_loop:                               ; preds = %overflow_copy_body, %overflow_int_done
  %overflow_copy_idx = phi i32 [ 0, %overflow_int_done ], [ %66, %overflow_copy_body ], !dbg !8
  %60 = icmp slt i32 %overflow_copy_idx, %59, !dbg !8
  br i1 %60, label %overflow_copy_body, label %overflow_copy_done, !dbg !8

overflow_copy_body:                               ; preds = %overflow_copy_loop
  %61 = add i32 %58, %overflow_copy_idx, !dbg !8
  %62 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %61, !dbg !8
  %63 = load i8, ptr %62, align 1, !dbg !8
  %64 = add i32 %48, %overflow_copy_idx, !dbg !8
  %65 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %64, !dbg !8
  store i8 %63, ptr %65, align 1, !dbg !8
  %66 = add i32 %overflow_copy_idx, 1, !dbg !8
  br label %overflow_copy_loop, !dbg !8

overflow_copy_done:                               ; preds = %overflow_copy_loop
  %67 = add i32 %48, %59, !dbg !8
  store i32 %67, ptr %pos, align 4, !dbg !8
  %68 = load i32, ptr %pos, align 4, !dbg !8
  %69 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %68, !dbg !8
  store i8 46, ptr %69, align 1, !dbg !8
  %70 = add i32 %68, 1, !dbg !8
  store i32 %70, ptr %pos, align 4, !dbg !8
  br label %frac_no_overflow, !dbg !8

frac_digit_loop:                                  ; preds = %frac_digit_body, %frac_no_overflow
  %frac_idx = phi i32 [ %50, %frac_no_overflow ], [ %79, %frac_digit_body ], !dbg !8
  %frac_remaining = phi i64 [ %final_frac_int, %frac_no_overflow ], [ %78, %frac_digit_body ], !dbg !8
  %71 = icmp sge i32 %frac_idx, 0, !dbg !8
  br i1 %71, label %frac_digit_body, label %frac_digits_done, !dbg !8

frac_digit_body:                                  ; preds = %frac_digit_loop
  %72 = srem i64 %frac_remaining, 10, !dbg !8
  %73 = add i64 %72, 48, !dbg !8
  %74 = trunc i64 %73 to i8, !dbg !8
  %75 = load i32, ptr %pos, align 4, !dbg !8
  %76 = add i32 %75, %frac_idx, !dbg !8
  %77 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %76, !dbg !8

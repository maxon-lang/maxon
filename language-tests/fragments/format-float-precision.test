function format_float_array(value float, buffer []char, precision int) int
    if value = 0.0 'zero_case'
        buffer[0] = '0' as char
        buffer[1] = '.' as char
        var i = 0
        while i < precision 'zero_decimals'
            buffer[2 + i] = '0' as char
            i = i + 1
        end 'zero_decimals'
        return 2 + precision
    end 'zero_case'
    
    var pos = 0
    
    var work_value = value
    if value < 0.0 'negative_check'
        buffer[pos] = '-' as char
        pos = pos + 1
        work_value = 0.0 - value
    end 'negative_check'
    
    var int_part = trunc(work_value)
    
    var temp = [20]char
    var temp_pos = 19
    var abs_int = int_part
    
    if int_part = 0 'int_zero'
        temp[temp_pos] = '0' as char
        temp_pos = temp_pos - 1
    end 'int_zero'
    
    while abs_int > 0 'convert_int'
        var digit = abs_int % 10
        var digit_char = ('0' as int) + digit
        temp[temp_pos] = digit_char as char
        temp_pos = temp_pos - 1
        abs_int = abs_int / 10
    end 'convert_int'
    
    var start = temp_pos + 1
    var length = 20 - start
    var i = 0
    while i < length 'copy_int'
        buffer[pos + i] = temp[start + i]
        i = i + 1
    end 'copy_int'
    pos = pos + length
    
    buffer[pos] = '.' as char
    pos = pos + 1
    
    var frac_part = work_value - int_part
    var scale = pow(10.0, precision as float)
    var frac_scaled = trunc(frac_part * scale + 0.5)
    
    var j = precision - 1
    while j >= 0 'convert_frac'
        var digit = frac_scaled % 10
        var digit_char = ('0' as int) + digit
        buffer[pos + j] = digit_char as char
        frac_scaled = frac_scaled / 10
        j = j - 1
    end 'convert_frac'
    
    pos = pos + precision
    return pos
end 'format_float_array'

function main() int
    var buffer = [32]char
    var len = format_float_array(1.23456789, buffer, 6)
    
    if len != 8 return 1
    if buffer[0] as int != '1' as int return 2
    if buffer[1] as int != '.' as int return 3
    if buffer[2] as int != '2' as int return 4
    if buffer[3] as int != '3' as int return 5
    if buffer[4] as int != '4' as int return 6
    if buffer[5] as int != '5' as int return 7
    if buffer[6] as int != '6' as int return 8
    if buffer[7] as int != '8' as int return 9
    
    return 0
end 'main'

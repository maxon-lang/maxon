// Test: array-struct-element-member-access.field-access-in-loop.1
struct Item
    var value int
end 'Item'

function sumValues(items array of Item, n int) returns int
    var total = 0
    for i in range(0, n) 'loop'
        total = total + items[i].value
    end 'loop'
    return total
end 'sumValues'

function main() returns int
    var arr = array of 3 Item
    arr[0] = Item{value: 10}
    arr[1] = Item{value: 20}
    arr[2] = Item{value: 30}
    return sumValues(arr, 3)
end 'main'

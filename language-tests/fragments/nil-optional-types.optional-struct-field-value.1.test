// Test: nil-optional-types.optional-struct-field-value.1
struct Person
	var name string
	var age int or nil
end 'Person'

function main() int
	var p = Person{name: "Alice", age: 30}
	if let a = p.age 'check'
		return a
	else 'check'
		return 0
	end 'check'
end 'main'

// Test: mem2reg-phi-placement.phi-with-computation.1
function main() returns int
    var x = 5
    if x > 3 'check'
        x = x * 2
    end 'check' else 'else_check'
        x = x + 10
    end 'else_check'
    return x
end 'main'
---
OptimizedInstructions: 0
UnoptimizedInstructions: 0
ExitCode: 10

entry0:
  br i1 1, label %then1, label %else3
then1:
  br label %ifcont2
ifcont2:
  %8 = phi i64 [ 10, %then1 ], [ 15, %else3 ]
  ret i64 %8
else3:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


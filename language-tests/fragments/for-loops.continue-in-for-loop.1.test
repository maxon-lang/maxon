// Test: for-loops.continue-in-for-loop.1
function main() int
    var sum = 0
    for i in range(0, 10) 'loop'
        if i == 5 'skip'
            continue
        end 'skip'
        sum = sum + i
    end 'loop'
    return sum
end 'main'

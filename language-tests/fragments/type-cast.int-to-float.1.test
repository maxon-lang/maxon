// Test: type-cast.int-to-float.1
function main() int
    var x = 5
    var y = x as float
    var z = y + 2.5
    return trunc(z)
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 5, ptr %0
  %1 = load i32, ptr %0
  %2 = sitofp i32 %1 to f64
  %3 = alloca f64
  store f64 %2, ptr %3
  %5 = fadd f64 %2, 2.5
  %6 = alloca f64
  store f64 %5, ptr %6
  %8 = call f64 @trunc(f64 %5)
  %9 = fptosi f64 %8 to i32
  ret i32 %9
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


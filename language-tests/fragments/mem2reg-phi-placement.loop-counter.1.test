// Test: mem2reg-phi-placement.loop-counter.1
function main() int
    var count = 0
    var i = 0
    while i < 10 'loop'
        if i mod 2 == 0 'even'
            count = count + 1
        end 'even'
        i = i + 1
    end 'loop'
    return count
end 'main'
---
; Module: test.maxon
; Instructions: 25

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %1
  %3 = icmp slt i32 %2, 10
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %1
  %5 = srem i32 %4, 2
  %6 = icmp eq i32 %5, 0
  br i1 %6, label %then4, label %ifcont5
afterloop3:
  %11 = load i32, ptr %0
  ret i32 %11
then4:
  %7 = load i32, ptr %0
  %8 = add i32 %7, 1
  store i32 %8, ptr %0
  br label %ifcont5
ifcont5:
  %9 = load i32, ptr %1
  %10 = add i32 %9, 1
  store i32 %10, ptr %1
  br label %whilecond1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


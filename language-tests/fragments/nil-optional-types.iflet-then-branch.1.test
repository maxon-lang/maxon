// Test: nil-optional-types.iflet-then-branch.1
function safeDivide(a int, b int) int or nil
	if b == 0 'check'
		return nil
	end 'check'
	return trunc(a / b)
end 'safeDivide'

function main() int
	var opt = safeDivide(10, 2)
	if let result = opt 'unwrap'
		return result
	else 'unwrap'
		return 999
	end 'unwrap'
end 'main'

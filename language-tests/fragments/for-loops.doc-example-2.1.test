forloop:                                          ; preds = %forcond
  %i = call i32 @iter.getCurrent(ptr %__iter), !dbg !11
  %i2 = alloca i32, align 4, !dbg !11
  store i32 %i, ptr %i2, align 4, !dbg !11
  %i3 = load i32, ptr %i2, align 4, !dbg !12
  %cmptmp = icmp eq i32 %i3, 5, !dbg !12
  br i1 %cmptmp, label %then, label %ifcont, !dbg !12

then:                                             ; preds = %forloop
  br label %forincrement, !dbg !13

aftercontinue:                                    ; No predecessors!
  br label %ifcont, !dbg !13

ifcont:                                           ; preds = %aftercontinue, %forloop
  %i4 = load i32, ptr %i2, align 4, !dbg !14
  %cmptmp5 = icmp eq i32 %i4, 8, !dbg !14
  br i1 %cmptmp5, label %then6, label %ifcont7, !dbg !14

then6:                                            ; preds = %ifcont
  br label %afterfor, !dbg !15

afterbreak:                                       ; No predecessors!
  br label %ifcont7, !dbg !15

ifcont7:                                          ; preds = %afterbreak, %ifcont
  %sum8 = load i32, ptr %sum, align 4, !dbg !16
  %i9 = load i32, ptr %i2, align 4, !dbg !16
  %addtmp = add i32 %sum8, %i9, !dbg !16
  store i32 %addtmp, ptr %sum, align 4, !dbg !16
  br label %forincrement, !dbg !16

forincrement:                                     ; preds = %ifcont7, %then
  %__iter.next = call %Iterator @iter.next(ptr %__iter), !dbg !16

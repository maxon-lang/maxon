// Test: for-loops.doc-example-2.1
function main() int
    var sum = 0
    for i in range(0, 10) 'loop'
        if i = 5 'skip'
            continue  // Skip 5
        end 'skip'
        if i = 8 'stop'
            break  // Stop at 8
        end 'stop'
        sum = sum + i
    end 'loop'
    return sum  // Returns 23 (0+1+2+3+4+6+7)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"


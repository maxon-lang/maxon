// Test: if-statements.if-statements.elseif.1
function main() int
    var x = 3
    if x = 1 'check'
        return 1
    else 'check'
        if x = 2 'inner'
            return 2
        else 'inner'
            return 3
        end 'inner'
    end 'check'
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 3
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 3)
  unreachable
}

---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4
  store i32 3, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  %x1 = load i32, ptr %x, align 4, !dbg !11
  %cmptmp = icmp eq i32 %x1, 1, !dbg !11
  br i1 %cmptmp, label %then, label %else, !dbg !11

then:                                             ; preds = %entry
  ret i32 1, !dbg !12

else:                                             ; preds = %entry
  %x2 = load i32, ptr %x, align 4, !dbg !13
  %cmptmp3 = icmp eq i32 %x2, 2, !dbg !13
  br i1 %cmptmp3, label %then4, label %else5, !dbg !13

then4:                                            ; preds = %else
  ret i32 2, !dbg !14

else5:                                            ; preds = %else
  ret i32 3, !dbg !15
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}


!llvm.dbg.cu = !{!0}

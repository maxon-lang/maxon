  %3 = getelementptr i8, ptr %2, i64 0
  store i32 42, ptr %3
  %4 = alloca %__enum_Container
  %5 = load %__enum_Container, ptr %0
  store %__enum_Container %5, ptr %4
  %6 = load %__enum_Container, ptr %4
  %7 = alloca %__enum_Container
  store %__enum_Container %6, ptr %7
  br label %match.check.04
match.merge1:

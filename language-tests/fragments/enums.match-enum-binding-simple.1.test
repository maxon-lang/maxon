// Test: enums.match-enum-binding-simple.1
enum Container
    empty
    value(n int)
end 'Container'

function main() returns int
    var c = Container.value(42)
    match c 'extract'
        empty then return 0
        value(n) then return n
    end 'extract'
end 'main'

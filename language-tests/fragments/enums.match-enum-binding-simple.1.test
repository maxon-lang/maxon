match.check.04:
  %8 = getelementptr %__enum_Container, ptr %7, i32 0, i32 0
  %9 = load i8, ptr %8
  %10 = icmp eq i8 %9, 0
  br i1 %10, label %match.case.02, label %match.check.15
match.check.15:
  %11 = getelementptr %__enum_Container, ptr %7, i32 0, i32 0
  %12 = load i8, ptr %11
  %13 = icmp eq i8 %12, 1
  br i1 %13, label %match.case.13, label %match.merge1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:

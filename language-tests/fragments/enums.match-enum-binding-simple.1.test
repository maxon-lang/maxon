// Test: enums.match-enum-binding-simple.1
enum Container
    case empty
    case value(n int)
end 'Container'

function main() int
    var c = Container.value(42)
    match c 'extract'
        case empty then return 0
        case value(n) then return n
    end 'extract'
end 'main'

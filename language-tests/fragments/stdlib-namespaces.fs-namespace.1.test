// Test: stdlib-namespaces.fs-namespace.1
export extern function GetStdHandle(nStdHandle int) ptr
export extern function WriteFile(hFile ptr, lpBuffer ptr, nNumberOfBytesToWrite int, lpNumberOfBytesWritten ptr, lpOverlapped ptr) int

export function STD_OUTPUT_HANDLE() int
    return 0 - 11
end 'STD_OUTPUT_HANDLE'

export function stdout() ptr
    var handle = STD_OUTPUT_HANDLE()
    let h = GetStdHandle(handle)
    return h
end 'stdout'

export function write(handle ptr, buffer ptr, length int) int
    var bytesWritten = 0
    let pBytesWritten = &bytesWritten
    let overlapped = 0 as ptr
    
    var result = WriteFile(handle, buffer, length, pBytesWritten, overlapped)
    
    if result = 0 'check_result'
        return 0
    end 'check_result'
    
    return bytesWritten
end 'write'

function main() int
    let out = stdout()
    var text = "OK"
    write(out, text, 2)
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@.str = private constant [2 x i8] c"OK"

declare ptr @GetStdHandle(i32) local_unnamed_addr

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr) local_unnamed_addr

define noundef i32 @main() local_unnamed_addr {
entry:
  %bytesWritten.i = alloca i32, align 4
  %0 = tail call ptr @GetStdHandle(i32 -11)
  call void @llvm.lifetime.start.p0(i64 4, ptr nonnull %bytesWritten.i)
  store i32 0, ptr %bytesWritten.i, align 4
  %1 = call i32 @WriteFile(ptr %0, ptr nonnull @.str, i32 2, ptr nonnull %bytesWritten.i, ptr null)
  call void @llvm.lifetime.end.p0(i64 4, ptr nonnull %bytesWritten.i)
  ret i32 0
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #0 {
entry:
  %0 = tail call i32 @main()
  tail call void @ExitProcess(i32 0)
  unreachable
}

; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: readwrite)
declare void @llvm.lifetime.start.p0(i64 immarg, ptr captures(none)) #1

; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: readwrite)
declare void @llvm.lifetime.end.p0(i64 immarg, ptr captures(none)) #1

attributes #0 = { noreturn }
attributes #1 = { nocallback nofree nosync nounwind willreturn memory(argmem: readwrite) }

// Test: match-statements.match-statements.function-call.1
function double(n int) int
    return n * 2
end 'double'

function main() int
    var x = 2
    var result = 0
    match x 'process'
        1 then result = double(10)
        2 then result = double(20)
        default then result = 0
    end 'process'
    return result
end 'main'

match.case.35:
  store i32 100, ptr %1
  br label %match.merge1
match.check.06:
  %4 = load i32, ptr %3
  %5 = icmp eq i32 %4, 1
  br i1 %5, label %match.case.02, label %match.check.17
  br label %match.check.18
match.check.17:
match.check.18:
  %6 = load i32, ptr %3
  %7 = icmp eq i32 %6, 2
  br i1 %7, label %match.case.13, label %match.check.29
  br label %match.check.210
match.check.29:
match.check.210:
  %8 = load i32, ptr %3
  %9 = icmp eq i32 %8, 3
  br i1 %9, label %match.case.24, label %match.case.35
}

declare void @exit(i32 %arg0)

define void @_start() {

// Test: tan.tan.quarter-pi.1
function main() int
    var quarterPi = 0.785398163
    var result = tan(quarterPi)
    // Should be approximately 1.0
    var diff = abs(result - 1.0)
    if diff < 0.01 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca f64
  store f64 0.785398, ptr %0
  %2 = call f64 @tan(f64 0.785398)
  %3 = alloca f64
  store f64 %2, ptr %3
  %5 = fsub f64 %2, 1
  %6 = call f64 @abs(f64 %5)
  %7 = alloca f64
  store f64 %6, ptr %7
  %9 = fcmp olt f64 %6, 0.01
  br i1 %9, label %then1, label %ifcont2
then1:
  ret i32 0
ifcont2:
  ret i32 1
}

declare f64 @tan(f64 %arg0)

declare f64 @abs(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

  store double 0x3FE921FB540D8D20, ptr %quarterPi, align 8, !dbg !9
    #dbg_declare(ptr %quarterPi, !10, !DIExpression(), !9)
  %quarterPi1 = load double, ptr %quarterPi, align 8, !dbg !11
  %tan_result = call double @tan(double %quarterPi1), !dbg !11
  store double %tan_result, ptr %result, align 8, !dbg !11
    #dbg_declare(ptr %result, !12, !DIExpression(), !11)
  %result2 = load double, ptr %result, align 8, !dbg !13
  %fsubtmp = fsub double %result2, 1.000000e+00, !dbg !13
  %abs.result = call double @llvm.fabs.f64(double %fsubtmp), !dbg !13
  store double %abs.result, ptr %diff, align 8, !dbg !13
    #dbg_declare(ptr %diff, !14, !DIExpression(), !13)
  %diff3 = load double, ptr %diff, align 8, !dbg !15
  %fcmptmp = fcmp olt double %diff3, 1.000000e-02, !dbg !15
  br i1 %fcmptmp, label %then, label %ifcont, !dbg !15

then:                                             ; preds = %entry
  ret i32 0, !dbg !16

ifcont:                                           ; preds = %entry
  ret i32 1, !dbg !17
}

declare double @tan(double)

declare double @llvm.fabs.f64(double)

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



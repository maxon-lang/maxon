// Test: tan.tan.quarter-pi.1
function main() int
    var quarterPi = 0.785398163
    var result = tan(quarterPi)
    // Should be approximately 1.0
    var diff = abs(result - 1.0)
    if diff < 0.01 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 0
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 0)
  unreachable
}


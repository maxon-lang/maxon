// Test: interfaces.basic-interface.1
interface Hashable
    function hash() returns int
end 'Hashable'

type Point is Hashable
    var x int
    var y int

    function Hashable.hash() returns int
        return x + y * 31
    end 'hash'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    return p.hash()
end 'main'

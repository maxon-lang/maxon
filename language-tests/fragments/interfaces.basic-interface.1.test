  store i32 20, ptr %2
  %4 = getelementptr %Point, ptr %0, i32 0, i32 0
  %5 = load i32, ptr %4
  %6 = getelementptr %Point, ptr %0, i32 0, i32 1
  %7 = load i32, ptr %6
  %8 = mul i32 %7, 31
  %9 = add i32 %5, %8
  ret i32 %9
}


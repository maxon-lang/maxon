  store i32 %i, ptr %i2, align 4, !dbg !11
  %i3 = load i32, ptr %i2, align 4, !dbg !12
  store i32 %i3, ptr %last, align 4, !dbg !12
  br label %forincrement, !dbg !12

forincrement:                                     ; preds = %forloop
  %__iter.next = call %Iterator @iter.next(ptr %__iter), !dbg !12
  store %Iterator %__iter.next, ptr %__iter, align 4, !dbg !12

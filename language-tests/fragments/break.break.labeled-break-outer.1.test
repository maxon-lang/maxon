// Test: break.break.labeled-break-outer.1
function main() int
    var x = 0
    while x < 10 'outer'
        x = x + 1
        while true 'inner'
            if x = 3 'check'
                break 'outer'
            end 'check'
            break 'inner'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define range(i32 3, 11) i32 @main() {
entry:
  ret i32 3
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 3)
  unreachable
}

---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4
  store i32 0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  br label %whilecond, !dbg !11

whilecond:                                        ; preds = %afterloop, %entry
  %x1 = load i32, ptr %x, align 4, !dbg !11
  %cmptmp = icmp slt i32 %x1, 10, !dbg !11
  br i1 %cmptmp, label %loop, label %afterloop8, !dbg !11

loop:                                             ; preds = %whilecond
  %x2 = load i32, ptr %x, align 4, !dbg !12
  %addtmp = add i32 %x2, 1, !dbg !12
  store i32 %addtmp, ptr %x, align 4, !dbg !12
  br label %whilecond3, !dbg !13

whilecond3:                                       ; preds = %afterbreak7, %loop
  br i1 true, label %loop4, label %afterloop, !dbg !13

loop4:                                            ; preds = %whilecond3
  %x5 = load i32, ptr %x, align 4, !dbg !14
  %cmptmp6 = icmp eq i32 %x5, 3, !dbg !14
  br i1 %cmptmp6, label %then, label %ifcont, !dbg !14

then:                                             ; preds = %loop4
  br label %afterloop8, !dbg !15

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !15

ifcont:                                           ; preds = %afterbreak, %loop4
  br label %afterloop, !dbg !16

afterbreak7:                                      ; No predecessors!
  br label %whilecond3, !dbg !16

afterloop:                                        ; preds = %ifcont, %whilecond3
  br label %whilecond, !dbg !16

afterloop8:                                       ; preds = %then, %whilecond
  %x9 = load i32, ptr %x, align 4, !dbg !17
  ret i32 %x9, !dbg !17
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



// Test: break.break.labeled-break-outer.1
function main() int
    var x = 0
    while x < 10 'outer'
        x = x + 1
        while true 'inner'
            if x = 3 'check'
                break 'outer'
            end 'check'
            break 'inner'
        end 'inner'
    end 'outer'
    return x
end 'main'

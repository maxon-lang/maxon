// Test: contextual-literal-typing.int-vs-int.1
function main() int
    var a = 1000
    var b = 1000
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 13

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 1000, ptr %0
  %1 = alloca i32
  store i32 1000, ptr %1
  %2 = load i32, ptr %0
  %3 = load i32, ptr %1
  %4 = icmp eq i32 %2, %3
  br i1 %4, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


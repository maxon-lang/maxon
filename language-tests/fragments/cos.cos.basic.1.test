// Test: cos.cos.basic.1
function main() int
    var x1 = cos(0.0)
    var x2 = cos(0.5)
    var x3 = cos(1.0)
    var x4 = cos(1.5708)
    print_float(x1, 6)
    print_float(x2, 6)
    print_float(x3, 6)
    print_float(x4, 6)
    return 0
end 'main'

  %3 = getelementptr %Config, ptr %0, i32 0, i32 1
  store i32 5, ptr %3
  %4 = getelementptr %Config, ptr %0, i32 0, i32 1
  %5 = load i32, ptr %4
  ret i32 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


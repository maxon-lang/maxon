  %1 = getelementptr %Config, ptr %0, i32 0, i32 0
  store i64 1, ptr %1
  %3 = getelementptr %Config, ptr %0, i32 0, i32 1
  store i64 5, ptr %3
  %4 = getelementptr %Config, ptr %0, i32 0, i32 1
  %5 = load i64, ptr %4
  ret i64 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


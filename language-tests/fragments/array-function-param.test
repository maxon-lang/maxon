// Test arrays as function parameters
function main() int
    var nums [5]int = 0
    nums[2] = 42
    return nums[2]
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() #0 {
entry:
  %nums.malloc = call ptr @malloc(i64 20)
  %0 = call ptr @memset(ptr %nums.malloc, i32 0, i64 20)
  %arrayidx = getelementptr inbounds nuw i8, ptr %nums.malloc, i64 8
  store i32 42, ptr %arrayidx, align 4
  call void @free(ptr %nums.malloc)
  ret i32 42
}

declare ptr @GetProcessHeap()

declare ptr @HeapAlloc(ptr, i32, i64)

declare i32 @HeapFree(ptr, i32, ptr)

define ptr @malloc(i64 %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call ptr @HeapAlloc(ptr %1, i32 0, i64 %0)
  ret ptr %2
}

define void @free(ptr %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

declare ptr @memset(ptr, i32, i64)

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

attributes #0 = { "no-builtin-memset" }
---
ExitCode: 42
// Test: interfaces.non-interface-method.1
struct Calculator
    var value int

    function double() int
        return value * 2
    end 'double'

    function triple() int
        return value * 3
    end 'triple'
end 'Calculator'

function main() int
    var c = Calculator{value: 7}
    return c.double() + c.triple()
end 'main'

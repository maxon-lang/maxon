// Test: map.map-type-in-field.1
type Container
    var data map from int to int
end 'Container'

function main() returns int
    var m = map from int to int
    m.insert(1, 42)
    var c = Container{data: m}
    var result = c.data.get(1) else 'default'
        result = 0
    end 'default'
    return result
end 'main'

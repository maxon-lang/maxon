function main() int
    var x = 3.14159
    print_float(x)
    
    var y = -2.5
    print_float(y)
    
    var z = 0.0
    print_float(z)
    
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@.str.newline = private constant [1 x i8] c"\0A"

define i32 @main() {
entry:
  %0 = call i32 @print_float(double 3.141590e+00)
  %1 = call i32 @print_float(double -2.500000e+00)
  %2 = call i32 @print_float(double 0.000000e+00)
  ret i32 0
}

declare ptr @memset(ptr, i32, i64)

declare ptr @GetStdHandle(i32)

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr)

define i32 @print(i32 %0) #0 {
entry:
  %buffer = alloca [12 x i8], align 1
  %temp = alloca [12 x i8], align 1
  %bytesWritten = alloca i32, align 4
  %1 = call ptr @memset(ptr nonnull %buffer, i32 0, i64 12)
  %2 = call ptr @memset(ptr nonnull %temp, i32 0, i64 12)
  %3 = icmp eq i32 %0, 0
  br i1 %3, label %zero_case, label %non_zero

zero_case:                                        ; preds = %entry
  store i8 48, ptr %buffer, align 1
  br label %format_done

non_zero:                                         ; preds = %entry
  %4 = icmp slt i32 %0, 0
  br i1 %4, label %negative, label %extract_digits

format_done:                                      ; preds = %reverse_loop, %zero_case
  %final_offset = phi i32 [ 0, %zero_case ], [ %start_offset, %reverse_loop ]
  %final_digit_count = phi i32 [ 1, %zero_case ], [ %temp_idx, %reverse_loop ]
  %5 = add i32 %final_digit_count, %final_offset
  %6 = call ptr @GetStdHandle(i32 -11)
  %7 = call i32 @WriteFile(ptr %6, ptr nonnull %buffer, i32 %5, ptr nonnull %bytesWritten, ptr null)
  %8 = call i32 @WriteFile(ptr %6, ptr nonnull @.str.newline, i32 1, ptr nonnull %bytesWritten, ptr null)
  ret i32 0

negative:                                         ; preds = %non_zero
  store i8 45, ptr %buffer, align 1
  %9 = sub i32 0, %0
  br label %extract_digits

extract_digits:                                   ; preds = %non_zero, %negative
  %value_abs = phi i32 [ %9, %negative ], [ %0, %non_zero ]
  %start_offset = phi i32 [ 1, %negative ], [ 0, %non_zero ]
  br label %digit_loop

digit_loop:                                       ; preds = %digit_loop_body, %extract_digits
  %remaining = phi i32 [ %value_abs, %extract_digits ], [ %15, %digit_loop_body ]
  %temp_idx = phi i32 [ 0, %extract_digits ], [ %16, %digit_loop_body ]
  %.not = icmp eq i32 %remaining, 0
  br i1 %.not, label %reverse_loop, label %digit_loop_body

digit_loop_body:                                  ; preds = %digit_loop
  %10 = srem i32 %remaining, 10
  %11 = trunc nsw i32 %10 to i8
  %12 = add nsw i8 %11, 48
  %13 = sext i32 %temp_idx to i64
  %14 = getelementptr inbounds [12 x i8], ptr %temp, i64 0, i64 %13
  store i8 %12, ptr %14, align 1
  %15 = sdiv i32 %remaining, 10
  %16 = add i32 %temp_idx, 1
  br label %digit_loop

reverse_loop:                                     ; preds = %reverse_body, %digit_loop
  %reverse_idx = phi i32 [ 0, %digit_loop ], [ %26, %reverse_body ]
  %17 = icmp slt i32 %reverse_idx, %temp_idx
  br i1 %17, label %reverse_body, label %format_done

reverse_body:                                     ; preds = %reverse_loop
  %18 = xor i32 %reverse_idx, -1
  %19 = add i32 %18, %temp_idx
  %20 = sext i32 %19 to i64
  %21 = getelementptr inbounds [12 x i8], ptr %temp, i64 0, i64 %20
  %22 = load i8, ptr %21, align 1
  %23 = add i32 %reverse_idx, %start_offset
  %24 = sext i32 %23 to i64
  %25 = getelementptr inbounds [12 x i8], ptr %buffer, i64 0, i64 %24
  store i8 %22, ptr %25, align 1
  %26 = add i32 %reverse_idx, 1
  br label %reverse_loop
}

define i32 @print_float(double %0) #0 {
entry:
  %buffer = alloca [32 x i8], align 1
  %bytesWritten = alloca i32, align 4
  %1 = call ptr @memset(ptr nonnull %buffer, i32 0, i64 32)
  %2 = fcmp oeq double %0, 0.000000e+00
  br i1 %2, label %zero_case, label %non_zero

zero_case:                                        ; preds = %entry
  store i8 48, ptr %buffer, align 1
  %3 = getelementptr inbounds nuw i8, ptr %buffer, i64 1
  store i8 46, ptr %3, align 1
  %4 = getelementptr inbounds nuw i8, ptr %buffer, i64 2
  store i8 48, ptr %4, align 1
  %5 = getelementptr inbounds nuw i8, ptr %buffer, i64 3
  store i8 48, ptr %5, align 1
  %6 = getelementptr inbounds nuw i8, ptr %buffer, i64 4
  store i8 48, ptr %6, align 1
  %7 = getelementptr inbounds nuw i8, ptr %buffer, i64 5
  store i8 48, ptr %7, align 1
  %8 = getelementptr inbounds nuw i8, ptr %buffer, i64 6
  store i8 48, ptr %8, align 1
  %9 = getelementptr inbounds nuw i8, ptr %buffer, i64 7
  store i8 48, ptr %9, align 1
  br label %format_done

non_zero:                                         ; preds = %entry
  %pos = alloca i32, align 4
  store i32 0, ptr %pos, align 4
  %10 = fcmp olt double %0, 0.000000e+00
  br i1 %10, label %negative, label %extract_int

format_done:                                      ; preds = %frac_digits_done, %zero_case
  %final_float_length = phi i32 [ 8, %zero_case ], [ %49, %frac_digits_done ]
  %11 = call ptr @GetStdHandle(i32 -11)
  %12 = call i32 @WriteFile(ptr %11, ptr nonnull %buffer, i32 %final_float_length, ptr nonnull %bytesWritten, ptr null)
  %13 = call i32 @WriteFile(ptr %11, ptr nonnull @.str.newline, i32 1, ptr nonnull %bytesWritten, ptr null)
  ret i32 0

negative:                                         ; preds = %non_zero
  store i8 45, ptr %buffer, align 1
  store i32 1, ptr %pos, align 4
  %14 = fneg double %0
  br label %extract_int

extract_int:                                      ; preds = %non_zero, %negative
  %current_pos = phi i32 [ 1, %negative ], [ 0, %non_zero ]
  %work_value = phi double [ %14, %negative ], [ %0, %non_zero ]
  %int_part = fptosi double %work_value to i32
  %int_part_float = sitofp i32 %int_part to double
  %float_temp = alloca [20 x i8], align 1
  %15 = call ptr @memset(ptr nonnull %float_temp, i32 0, i64 20)
  %16 = icmp eq i32 %int_part, 0
  br i1 %16, label %int_zero, label %int_digit_loop

int_zero:                                         ; preds = %extract_int
  %17 = getelementptr inbounds nuw i8, ptr %float_temp, i64 19
  store i8 48, ptr %17, align 1
  br label %int_digits_done

int_digits_done:                                  ; preds = %int_digit_loop, %int_zero
  %final_temp_idx = phi i32 [ %current_temp_idx, %int_digit_loop ], [ 18, %int_zero ]
  %18 = add i32 %final_temp_idx, 1
  %19 = sub i32 19, %final_temp_idx
  br label %copy_int_loop

int_digit_loop:                                   ; preds = %extract_int, %int_digit_body
  %remaining_int = phi i32 [ %25, %int_digit_body ], [ %int_part, %extract_int ]
  %current_temp_idx = phi i32 [ %26, %int_digit_body ], [ 19, %extract_int ]
  %.not = icmp eq i32 %remaining_int, 0
  br i1 %.not, label %int_digits_done, label %int_digit_body

int_digit_body:                                   ; preds = %int_digit_loop
  %20 = srem i32 %remaining_int, 10
  %21 = trunc nsw i32 %20 to i8
  %22 = add nsw i8 %21, 48
  %23 = sext i32 %current_temp_idx to i64
  %24 = getelementptr inbounds [20 x i8], ptr %float_temp, i64 0, i64 %23
  store i8 %22, ptr %24, align 1
  %25 = sdiv i32 %remaining_int, 10
  %26 = add i32 %current_temp_idx, -1
  br label %int_digit_loop

copy_int_loop:                                    ; preds = %copy_int_body, %int_digits_done
  %copy_idx = phi i32 [ 0, %int_digits_done ], [ %35, %copy_int_body ]
  %27 = icmp slt i32 %copy_idx, %19
  br i1 %27, label %copy_int_body, label %copy_int_done

copy_int_body:                                    ; preds = %copy_int_loop
  %28 = add i32 %18, %copy_idx
  %29 = sext i32 %28 to i64
  %30 = getelementptr inbounds [20 x i8], ptr %float_temp, i64 0, i64 %29
  %31 = load i8, ptr %30, align 1
  %32 = add i32 %current_pos, %copy_idx
  %33 = sext i32 %32 to i64
  %34 = getelementptr inbounds [32 x i8], ptr %buffer, i64 0, i64 %33
  store i8 %31, ptr %34, align 1
  %35 = add i32 %copy_idx, 1
  br label %copy_int_loop

copy_int_done:                                    ; preds = %copy_int_loop
  %36 = add i32 %current_pos, %19
  store i32 %36, ptr %pos, align 4
  %37 = sext i32 %36 to i64
  %38 = getelementptr inbounds [32 x i8], ptr %buffer, i64 0, i64 %37
  store i8 46, ptr %38, align 1
  %39 = add i32 %36, 1
  store i32 %39, ptr %pos, align 4
  %frac_part = fsub double %work_value, %int_part_float
  %frac_scaled = fmul double %frac_part, 1.000000e+06
  %frac_rounded = fadd double %frac_scaled, 5.000000e-01
  %frac_int = fptosi double %frac_rounded to i32
  br label %frac_digit_loop

frac_digit_loop:                                  ; preds = %frac_digit_body, %copy_int_done
  %frac_idx = phi i32 [ 5, %copy_int_done ], [ %48, %frac_digit_body ]
  %frac_remaining = phi i32 [ %frac_int, %copy_int_done ], [ %47, %frac_digit_body ]
  %40 = icmp sgt i32 %frac_idx, -1
  br i1 %40, label %frac_digit_body, label %frac_digits_done

frac_digit_body:                                  ; preds = %frac_digit_loop
  %41 = srem i32 %frac_remaining, 10
  %42 = trunc nsw i32 %41 to i8
  %43 = add nsw i8 %42, 48
  %44 = add i32 %39, %frac_idx
  %45 = sext i32 %44 to i64
  %46 = getelementptr inbounds [32 x i8], ptr %buffer, i64 0, i64 %45
  store i8 %43, ptr %46, align 1
  %47 = sdiv i32 %frac_remaining, 10
  %48 = add nsw i32 %frac_idx, -1
  br label %frac_digit_loop

frac_digits_done:                                 ; preds = %frac_digit_loop
  %49 = add i32 %39, 6
  br label %format_done
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

attributes #0 = { "no-builtin-memset" }
---

// Test: method-call-on-parameter.method-call-on-same-type-parameter.1
type Foo
    var x int
    
    function bar() returns int
        return x
    end 'bar'
    
    function callBarOn(other Foo) returns int
        return other.bar()
    end 'callBarOn'
end 'Foo'

function main() returns int
    var f1 = Foo{x: 10}
    var f2 = Foo{x: 42}
    return f1.callBarOn(f2)
end 'main'
---
; Module: test.maxon
; Instructions: 12

%Foo = type { i32 }

define i32 @main() {
entry0:
  %0 = alloca %Foo
  %1 = getelementptr %Foo, ptr %0, i32 0, i32 0
  store i32 10, ptr %1
  %2 = alloca %Foo
  %3 = getelementptr %Foo, ptr %2, i32 0, i32 0
  store i32 42, ptr %3
  %5 = getelementptr %Foo, ptr %2, i32 0, i32 0
  %6 = load i32, ptr %5
  ret i32 %6
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
; Module: test.maxon
; Instructions: 24

%Foo = type { i32 }

define i32 @Foo.bar(ptr %self) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = load ptr, ptr %0
  %2 = getelementptr %Foo, ptr %1, i32 0, i32 0
  %3 = load i32, ptr %2
  ret i32 %3
}

define i32 @Foo.callBarOn(ptr %self, ptr %other) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = alloca ptr
  store ptr %other, ptr %1
  %2 = load ptr, ptr %1
  %3 = call i32 @Foo.bar(ptr %2)
  ret i32 %3
}

define i32 @main() {
entry0:
  %0 = alloca %Foo
  %1 = getelementptr %Foo, ptr %0, i32 0, i32 0
  store i32 10, ptr %1
  %2 = alloca %Foo
  %3 = getelementptr %Foo, ptr %2, i32 0, i32 0
  store i32 42, ptr %3
  %4 = call i32 @Foo.callBarOn(ptr %0, ptr %2)
  ret i32 %4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


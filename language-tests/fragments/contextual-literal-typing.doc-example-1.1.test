// Test: contextual-literal-typing.doc-example-1.1
function main() returns int
    var b = 100 as byte
    if b == 50 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 9

define i32 @main() {
entry0:
  %0 = trunc i32 100 to i8
  %3 = zext i8 %0 to i32
  %4 = icmp eq i32 %3, 50
  br i1 %4, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
; Module: test.maxon
; Instructions: 12

define i32 @main() {
entry0:
  %0 = trunc i32 100 to i8
  %1 = alloca i8
  store i8 %0, ptr %1
  %2 = load i8, ptr %1
  %3 = zext i8 %2 to i32
  %4 = icmp eq i32 %3, 50
  br i1 %4, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


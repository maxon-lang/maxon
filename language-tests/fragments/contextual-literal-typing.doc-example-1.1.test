// Test: contextual-literal-typing.doc-example-1.1
function main() int
    var b = 100b
    if b == 50 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 8

define i32 @main() {
entry0:
  %2 = zext i8 100 to i32
  %3 = icmp eq i32 %2, 50
  br i1 %3, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

function main(args []string) int
	print("{args[0]}", args[0])

    // Check argc is 3 (program name + 2 args)
    if args.length != 3 return 1
    
    // Check first arg (program name) has reasonable length
	if args[0] != "test.exe" return 2
    
    // Check second arg is "hello"
	if args[1] != "hello" return 3
    
    // Check third arg is "world"
	if args[2] != "world" return 4
    
    return 0
end 'main'

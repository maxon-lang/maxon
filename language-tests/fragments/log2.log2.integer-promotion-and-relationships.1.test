  %68 = load i32, ptr %pos, align 4, !dbg !13
  %69 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %68, !dbg !13
  store i8 46, ptr %69, align 1, !dbg !13
  %70 = add i32 %68, 1, !dbg !13
  store i32 %70, ptr %pos, align 4, !dbg !13

  %2 = call ptr @memset(ptr %temp, i32 0, i64 12), !dbg !13
  %3 = icmp eq i32 %0, 0, !dbg !13
  br i1 %3, label %zero_case, label %non_zero, !dbg !13

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !13
  store i8 48, ptr %4, align 1, !dbg !13

non_zero:                                         ; preds = %entry
  %5 = icmp slt i32 %0, 0, !dbg !13
  br i1 %5, label %negative, label %positive, !dbg !13

format_done:                                      ; preds = %reverse_loop, %zero_case
  %final_offset = phi i32 [ 0, %zero_case ], [ %offset_in_reverse, %reverse_loop ], !dbg !13
  %final_digit_count = phi i32 [ 1, %zero_case ], [ %digit_count_in_reverse, %reverse_loop ], !dbg !13
  %6 = add i32 %final_offset, %final_digit_count, !dbg !13
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !13
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %6, ptr %bytesWritten, ptr null), !dbg !13
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !13
  ret i32 0, !dbg !13

negative:                                         ; preds = %non_zero
  %10 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !13
  store i8 45, ptr %10, align 1, !dbg !13
  %11 = sub i32 0, %0, !dbg !13
  br label %extract_digits, !dbg !13

positive:                                         ; preds = %non_zero
  br label %extract_digits, !dbg !13

extract_digits:                                   ; preds = %positive, %negative
  %value_abs = phi i32 [ %11, %negative ], [ %0, %positive ], !dbg !13

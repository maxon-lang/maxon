  %1 = tail call fastcc double @math.log(double 6.400000e+01)
  %fdivtmp.i20 = fdiv double %1, 0x3FE62E42FEFA39EF
  tail call fastcc void @sys.print_float(double %fdivtmp.i20)
  %2 = tail call fastcc double @math.log(double 1.000000e+02)
  %fdivtmp.i21 = fdiv double %2, 0x3FE62E42FEFA39EF
  %3 = tail call fastcc double @math.log(double 2.000000e+00)
  %fdivtmp = fdiv double %2, %3
  %fsubtmp = fsub double %fdivtmp.i21, %fdivtmp
  %fcmptmp = fcmp olt double %fsubtmp, 0.000000e+00
  %fsubtmp11 = fsub double 0.000000e+00, %fsubtmp
  %abs_diff.0 = select i1 %fcmptmp, double %fsubtmp11, double %fsubtmp
  %fcmptmp13 = fcmp olt double %abs_diff.0, 0x3EB0C6F7A0B5ED8D
  br i1 %fcmptmp13, label %then14, label %math.log2.exit

then14:                                           ; preds = %entry
  tail call fastcc void @sys.print_float(double %fdivtmp.i)
  br label %math.log2.exit

math.log2.exit:                                   ; preds = %then14, %entry
  %4 = tail call fastcc double @math.log(double 1.280000e+02)
  %fdivtmp.i22 = fdiv double %4, 0x3FE62E42FEFA39EF

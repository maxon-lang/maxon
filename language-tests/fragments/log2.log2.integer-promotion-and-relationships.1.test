  %2 = tail call fastcc double @math.log(double 6.400000e+01)
  %fdivtmp.i20 = fdiv double %2, 0x3FE62E42FEFA39EF
  %3 = tail call i32 @print_float(double %fdivtmp.i20, i32 1)
  %4 = tail call fastcc double @math.log(double 1.000000e+02)
  %fdivtmp.i21 = fdiv double %4, 0x3FE62E42FEFA39EF
  %5 = tail call fastcc double @math.log(double 2.000000e+00)
  %fdivtmp = fdiv double %4, %5
  %fsubtmp = fsub double %fdivtmp.i21, %fdivtmp
  %fcmptmp = fcmp olt double %fsubtmp, 0.000000e+00
  %fsubtmp11 = fsub double 0.000000e+00, %fsubtmp
  %abs_diff.0 = select i1 %fcmptmp, double %fsubtmp11, double %fsubtmp
  %fcmptmp13 = fcmp olt double %abs_diff.0, 0x3EB0C6F7A0B5ED8D
  br i1 %fcmptmp13, label %then14, label %ifcont16

then14:                                           ; preds = %entry
  %6 = tail call i32 @print_float(double %fdivtmp.i, i32 1)
  br label %ifcont16

ifcont16:                                         ; preds = %then14, %entry
  %7 = tail call fastcc double @math.log(double 1.280000e+02)
  %fdivtmp.i22 = fdiv double %7, 0x3FE62E42FEFA39EF
  %8 = tail call i32 @print_float(double %fdivtmp.i22, i32 1)
  ret i32 0
}


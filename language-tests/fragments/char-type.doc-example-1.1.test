// Test: char-type.doc-example-1.1
function isUppercase(c char) bool
    var code = c as int
    if code >= 65 'check'
        if code <= 90 'check2'
            return true
        end 'check2'
    end 'check'
    return false
end 'isUppercase'

function main() int
    if isUppercase('Z') 'test'
        return 1
    end 'test'
    return 0
end 'main'
---
; Module: test.maxon

define i1 @isUppercase(i8 %c) {
entry0:
  %0 = alloca i8
  store i8 %c, ptr %0
  %2 = zext i8 %c to i32
  %3 = alloca i32
  store i32 %2, ptr %3
  %5 = icmp sge i32 %2, 65
  br i1 %5, label %then1, label %ifcont2
then1:
  %6 = load i32, ptr %3
  %7 = icmp sle i32 %6, 90
  br i1 %7, label %then3, label %ifcont4
ifcont2:
  ret i1 0
then3:
  ret i1 1
ifcont4:
  br label %ifcont2
}

define i32 @main() {
entry0:
  %0 = call i1 @isUppercase(i8 90)
  br i1 %0, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

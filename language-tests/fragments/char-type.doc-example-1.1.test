    #dbg_declare(ptr %code, !12, !DIExpression(), !11)
  %code2 = load i32, ptr %code, align 4, !dbg !13
  %cmptmp = icmp sge i32 %code2, 65, !dbg !13
  br i1 %cmptmp, label %then, label %ifcont6, !dbg !13

then:                                             ; preds = %entry
  %code3 = load i32, ptr %code, align 4, !dbg !14
  %cmptmp4 = icmp sle i32 %code3, 90, !dbg !14
  br i1 %cmptmp4, label %then5, label %ifcont, !dbg !14

then5:                                            ; preds = %then
  ret i1 true, !dbg !15

ifcont:                                           ; preds = %then
  br label %ifcont6, !dbg !15

ifcont6:                                          ; preds = %ifcont, %entry
  ret i1 false, !dbg !16
}

define i32 @main() !dbg !17 {
entry:
  %0 = call i1 @isUppercase(i8 90), !dbg !20
  br i1 %0, label %then, label %ifcont, !dbg !20

then:                                             ; preds = %entry
  ret i32 1, !dbg !21

ifcont:                                           ; preds = %entry

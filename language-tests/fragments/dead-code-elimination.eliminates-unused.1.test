// Test: dead-code-elimination.eliminates-unused.1
function used_function() int
    return 42
end 'used_function'

function unused_function() int
    return 999
end 'unused_function'

function another_unused_function() int
    return 123
end 'another_unused_function'

function main() int
    var result = used_function()
    return result
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 42
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 42)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define internal i32 @used_function() !dbg !4 {
entry:
  ret i32 42, !dbg !8
}

define i32 @main() !dbg !9 {
entry:
  %result = alloca i32, align 4, !dbg !11
  %0 = call i32 @used_function(), !dbg !11
  store i32 %0, ptr %result, align 4, !dbg !11
    #dbg_declare(ptr %result, !12, !DIExpression(), !11)
  %result1 = load i32, ptr %result, align 4, !dbg !13
  ret i32 %result1, !dbg !13
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "used_function", linkageName: "used_function", scope: !1, file: !1, line: 2, type: !5, scopeLine: 2, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0)
!5 = !DISubroutineType(types: !6)

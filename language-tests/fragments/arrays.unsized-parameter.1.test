// Test: arrays.unsized-parameter.1
function get_first(arr []int) int
    return arr[0]
end 'get_first'

function main() int
    var nums = [4]int
    nums[0] = 42
    nums[1] = 10
    nums[2] = 20
    nums[3] = 30
    return get_first(nums)
end 'main'

  store i32 10, ptr %1
  %2 = getelementptr %IntPair, ptr %0, i32 0, i32 1
  store i32 32, ptr %2
  %4 = getelementptr %IntPair, ptr %0, i32 0, i32 0
  %5 = load i32, ptr %4
  %6 = getelementptr %IntPair, ptr %0, i32 0, i32 1
  %7 = load i32, ptr %6
  %8 = add i32 %5, %7
  ret i32 %8
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)

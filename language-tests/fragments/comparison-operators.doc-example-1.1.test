// Test: comparison-operators.doc-example-1.1
function main() int
    var x = 10
    var y = 20
    
    if x < y 'test1'
        if x != y 'test2'
            return 1
        end 'test2'
    end 'test1'
    
    return 0
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 10, ptr %0
  %1 = alloca i32
  store i32 20, ptr %1
  %2 = load i32, ptr %0
  %3 = load i32, ptr %1
  %4 = icmp slt i32 %2, %3
  br i1 %4, label %then1, label %ifcont2
then1:
  %5 = load i32, ptr %0
  %6 = load i32, ptr %1
  %7 = icmp ne i32 %5, %6
  br i1 %7, label %then3, label %ifcont4
ifcont2:
  ret i32 0
then3:
  ret i32 1
ifcont4:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

// Test: comparison-operators.doc-example-1.1
function main() int
    var x = 10
    var y = 20
    
    if x < y 'test1'
        if x != y 'test2'
            return 1
        end 'test2'
    end 'test1'
    
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 1
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 1)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %y = alloca i32, align 4
  %x = alloca i32, align 4
  store i32 10, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  store i32 20, ptr %y, align 4, !dbg !11
    #dbg_declare(ptr %y, !12, !DIExpression(), !11)
  %x1 = load i32, ptr %x, align 4, !dbg !13
  %y2 = load i32, ptr %y, align 4, !dbg !13
  %cmptmp = icmp slt i32 %x1, %y2, !dbg !13
  br i1 %cmptmp, label %then, label %ifcont7, !dbg !13

then:                                             ; preds = %entry
  %x3 = load i32, ptr %x, align 4, !dbg !14
  %y4 = load i32, ptr %y, align 4, !dbg !14
  %cmptmp5 = icmp ne i32 %x3, %y4, !dbg !14
  br i1 %cmptmp5, label %then6, label %ifcont, !dbg !14

then6:                                            ; preds = %then
  ret i32 1, !dbg !15

ifcont:                                           ; preds = %then
  br label %ifcont7, !dbg !15

ifcont7:                                          ; preds = %ifcont, %entry
  ret i32 0, !dbg !16
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}


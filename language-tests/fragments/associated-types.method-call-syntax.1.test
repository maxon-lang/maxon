  %3 = getelementptr %Number, ptr %0, i32 0, i32 0
  %4 = load i64, ptr %3
  %5 = add i64 %4, 1
  ret i64 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void

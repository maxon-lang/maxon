// Test: associated-types.method-call-syntax.1
interface Addable
    function addOne() returns int
end 'Addable'

type Number is Addable
    var value int

    function Addable.addOne() returns int
        return value + 1
    end 'addOne'
end 'Number'

function main() returns int
    var n = Number{value: 41}
    return n.addOne()
end 'main'

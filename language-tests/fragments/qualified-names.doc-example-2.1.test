// Test: qualified-names.doc-example-2.1
namespace math 'math'
    function square(x int) int
        return x * x
    end 'square'
end 'math'

namespace utils 'utils'
    function test() int
        return math.square(5)  // Qualified call
    end 'test'
end 'utils'

function main() int
    return math.square(4)  // Qualified call from global scope
end 'main'

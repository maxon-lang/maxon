// Test: string-type.utf16-is-trail-surrogate.1
function main() returns int
    // 0xDE00 = 56832 (low surrogate for 😀)
    if utf16IsTrailSurrogate(56832) 'c4'
        print("{1}")
    end 'c4'
    if utf16IsTrailSurrogate(55357) 'c5'
        print("{0}")
    end 'c5'
    if utf16IsTrailSurrogate(65) 'c6'
        print("{0}")
    end 'c6'
    return 0
end 'main'

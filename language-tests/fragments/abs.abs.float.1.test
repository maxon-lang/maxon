// Test: abs.abs.float.1
function main() int
    var neg = 0.0 - 5.5
    var x = abs(neg)
    var y = trunc(x)
    return y
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %1 = alloca f64
  store f64 -5.5, ptr %1
  %2 = load f64, ptr %1
  %3 = call f64 @abs(f64 %2)
  %4 = alloca f64
  store f64 %3, ptr %4
  %5 = load f64, ptr %4
  %6 = call f64 @trunc(f64 %5)
  %7 = fptosi f64 %6 to i32
  %8 = alloca i32
  store i32 %7, ptr %8
  %9 = load i32, ptr %8
  ret i32 %9
}

declare f64 @abs(f64 %arg0)

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


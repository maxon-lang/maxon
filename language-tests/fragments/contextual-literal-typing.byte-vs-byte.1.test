// Test: contextual-literal-typing.byte-vs-byte.1
function main() returns int
    var a = 50b
    var b = 50b
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 6

define i32 @main() {
entry0:
  br i1 1, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
; Module: test.maxon
; Instructions: 13

define i32 @main() {
entry0:
  %0 = alloca i8
  store i8 50, ptr %0
  %1 = alloca i8
  store i8 50, ptr %1
  %2 = load i8, ptr %0
  %3 = load i8, ptr %1
  %4 = icmp eq i8 %2, %3
  br i1 %4, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


// Test: contextual-literal-typing.byte-vs-byte.1
function main() returns int
    var a = 50 as byte
    var b = 50 as byte
    if a == b 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 9

define i64 @main() {
entry0:
  %0 = trunc i64 50 to i8
  %2 = trunc i64 50 to i8
  %6 = icmp eq i8 %0, %2
  br i1 %6, label %then1, label %ifcont2
then1:
  ret i64 1
ifcont2:
  ret i64 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


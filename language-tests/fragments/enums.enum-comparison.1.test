// Test: enums.enum-comparison.1
enum Status
    case pending
    case active
    case done
end 'Status'

function main() returns int
    var s1 = Status.pending
    var s2 = Status.pending
    var s3 = Status.active
    if s1 == s2 'eq'
        if s1 != s3 'neq'
            return 1
        end 'neq'
    end 'eq'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 8

define i32 @main() {
entry0:
  br i1 1, label %then1, label %ifcont2
then1:
  br i1 1, label %then3, label %ifcont4
ifcont2:
  ret i32 0
then3:
  ret i32 1
ifcont4:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


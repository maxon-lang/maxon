// Test unsized array parameters
function sum(arr []int, n int) int
    var total = 0
    var i = 0
    while i < n 'loop'
        total = total + arr[i]
        i = i + 1
    end 'loop'
    return total
end 'sum'

function main() int
    var nums = [5]int
    nums[0] = 10
    nums[1] = 20
    nums[2] = 30
    nums[3] = 40
    nums[4] = 50
    return sum(nums, 5)
end 'main'
---

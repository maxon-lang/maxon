  %1 = tail call ptr @HeapAlloc(ptr %0, i32 0, i64 20)
  %2 = tail call ptr @memset(ptr %1, i32 0, i64 20)
  store i32 10, ptr %1, align 4
  %arrayidx2 = getelementptr inbounds nuw i8, ptr %1, i64 4
  store i32 20, ptr %arrayidx2, align 4
  %arrayidx4 = getelementptr inbounds nuw i8, ptr %1, i64 8
  store i32 30, ptr %arrayidx4, align 4
  %arrayidx6 = getelementptr inbounds nuw i8, ptr %1, i64 12
  store i32 40, ptr %arrayidx6, align 4
  %arrayidx8 = getelementptr inbounds nuw i8, ptr %1, i64 16
  store i32 50, ptr %arrayidx8, align 4
  %3 = tail call ptr @GetProcessHeap()
  %4 = tail call i32 @HeapFree(ptr %3, i32 0, ptr nonnull %1)
  ret i32 150
}


entry:
  %1 = tail call ptr @GetProcessHeap()
  %2 = tail call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

; Function Attrs: mustprogress nocallback nofree nounwind willreturn memory(argmem: readwrite)
declare ptr @memset(ptr writeonly, i32, i64) local_unnamed_addr #1


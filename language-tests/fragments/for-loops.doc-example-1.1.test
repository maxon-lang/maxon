// Test: for-loops.doc-example-1.1
function main() int
    var sum = 0
    for i in range(0, 10) 'sum_loop'
        sum = sum + i
    end 'sum_loop'
    return sum  // Returns 45 (0+1+2+...+9)
end 'main'
---
; Module: test.maxon
; Instructions: 25

%Iterator = type { i32, i32, i32 }

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  %2 = alloca i32
  store i32 10, ptr %2
  br label %forcond1
forcond1:
  %3 = load i32, ptr %1
  %4 = load i32, ptr %2
  %5 = icmp slt i32 %3, %4
  br i1 %5, label %forloop2, label %afterfor4
forloop2:
  %6 = load i32, ptr %0
  %7 = load i32, ptr %1
  %8 = add i32 %6, %7
  store i32 %8, ptr %0
  br label %forincrement3
forincrement3:
  %9 = load i32, ptr %1
  %10 = add i32 %9, 1
  store i32 %10, ptr %1
  br label %forcond1
afterfor4:
  %11 = load i32, ptr %0
  ret i32 %11
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


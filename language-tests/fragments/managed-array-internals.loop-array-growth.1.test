// Test: managed-array-internals.loop-array-growth.1
function main() returns int
    var arr = array of int
    var i = 0
    while i < 10 'loop'
        arr.push(i)
        i = i + 1
    end 'loop'
    print("{arr.count()}")
    return 0
end 'main'

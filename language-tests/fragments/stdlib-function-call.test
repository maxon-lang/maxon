// Test that stdlib function calls are recognized and don't cause errors
function main() int
    var buffer = [12]char
    return format_int_array(42, buffer)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define noundef i32 @main() local_unnamed_addr #0 {
entry:
  %0 = tail call ptr @GetProcessHeap()
  %1 = tail call ptr @HeapAlloc(ptr %0, i32 0, i64 12)
  %2 = tail call ptr @memset(ptr %1, i32 0, i64 12)
  %3 = tail call ptr @GetProcessHeap()
  %4 = tail call ptr @HeapAlloc(ptr %3, i32 0, i64 12)
  %5 = tail call ptr @memset(ptr %4, i32 0, i64 12)
  %arrayidx14.i = getelementptr inbounds nuw i8, ptr %4, i64 11
  store i8 50, ptr %arrayidx14.i, align 1
  %arrayidx14.1.i = getelementptr inbounds nuw i8, ptr %4, i64 10
  store i8 52, ptr %arrayidx14.1.i, align 1
  store i8 52, ptr %1, align 1
  %arrayidx39.1.i = getelementptr inbounds nuw i8, ptr %1, i64 1
  %arrayelem.1.i = load i8, ptr %arrayidx14.i, align 1
  store i8 %arrayelem.1.i, ptr %arrayidx39.1.i, align 1
  %6 = tail call ptr @GetProcessHeap()
  %7 = tail call i32 @HeapFree(ptr %6, i32 0, ptr nonnull %1)
  ret i32 2
}

declare ptr @GetProcessHeap() local_unnamed_addr

declare ptr @HeapAlloc(ptr, i32, i64) local_unnamed_addr

declare i32 @HeapFree(ptr, i32, ptr) local_unnamed_addr

define ptr @malloc(i64 %0) local_unnamed_addr {
entry:
  %1 = tail call ptr @GetProcessHeap()
  %2 = tail call ptr @HeapAlloc(ptr %1, i32 0, i64 %0)
  ret ptr %2
}

define void @free(ptr %0) local_unnamed_addr {
entry:
  %1 = tail call ptr @GetProcessHeap()
  %2 = tail call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

; Function Attrs: mustprogress nocallback nofree nounwind willreturn memory(argmem: readwrite)
declare ptr @memset(ptr writeonly, i32, i64) local_unnamed_addr #1

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #2 {
entry:
  %0 = tail call i32 @main()
  tail call void @ExitProcess(i32 %0)
  unreachable
}

attributes #0 = { "no-builtin-memset" }
attributes #1 = { mustprogress nocallback nofree nounwind willreturn memory(argmem: readwrite) }
attributes #2 = { noreturn }

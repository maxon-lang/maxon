define i32 @main() #0 !dbg !4 {
entry:
  %buffer.__length = alloca i32, align 4, !dbg !9
  %buffer = alloca ptr, align 8, !dbg !9
  %buffer.malloc = call ptr @malloc(i64 12), !dbg !9
  store ptr %buffer.malloc, ptr %buffer, align 8, !dbg !9
  store i32 12, ptr %buffer.__length, align 4, !dbg !9
  %0 = call ptr @memset(ptr %buffer.malloc, i32 0, i64 12), !dbg !9
    #dbg_declare(ptr %buffer, !10, !DIExpression(), !9)
  %buffer1 = load ptr, ptr %buffer, align 8, !dbg !12
  %length = load i32, ptr %buffer.__length, align 4, !dbg !12
  %1 = call i32 @stdlib.fmt.format_int_array(i32 42, ptr %buffer1, i32 %length), !dbg !12
  %buffer.ptr = load ptr, ptr %buffer, align 8, !dbg !12
  call void @free(ptr %buffer.ptr), !dbg !12
  ret i32 %1, !dbg !12
}

define internal i32 @stdlib.fmt.format_int_array(i32 %0, ptr %1, i32 %2) #0 !dbg !13 {
entry:
  %i = alloca i32, align 4

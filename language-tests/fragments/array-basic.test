// Test array functionality
function main() int
    var arr [5]int = 0
    
    // Set some values
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    
    // Read and return a value
    return arr[1]
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 20
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}
---
ExitCode: 20

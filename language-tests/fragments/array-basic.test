define i32 @main() #0 {
entry:
  %arr.malloc = call ptr @malloc(i64 20)
  %0 = call ptr @memset(ptr %arr.malloc, i32 0, i64 20)
  store i32 10, ptr %arr.malloc, align 4
  %arrayidx2 = getelementptr inbounds nuw i8, ptr %arr.malloc, i64 4
  store i32 20, ptr %arrayidx2, align 4
  call void @free(ptr nonnull %arr.malloc)
  ret i32 20
}

declare ptr @GetProcessHeap()

declare ptr @HeapAlloc(ptr, i32, i64)

declare i32 @HeapFree(ptr, i32, ptr)

define ptr @malloc(i64 %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call ptr @HeapAlloc(ptr %1, i32 0, i64 %0)
  ret ptr %2
}

define void @free(ptr %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

declare ptr @memset(ptr, i32, i64)

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

attributes #0 = { "no-builtin-memset" }

// Test: break.break.multiple-conditions.1
function main() int
    var x = 5
    var count = 0
    while x < 100 'loop'
        x = x + 1
        count = count + 1
        if count == 3 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 5, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %0
  %3 = icmp slt i32 %2, 100
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %0
  %5 = add i32 %4, 1
  store i32 %5, ptr %0
  %6 = load i32, ptr %1
  %7 = add i32 %6, 1
  store i32 %7, ptr %1
  %9 = icmp eq i32 %7, 3
  br i1 %9, label %then4, label %ifcont5
afterloop3:
  %10 = load i32, ptr %0
  ret i32 %10
then4:
  br label %afterloop3
ifcont5:
  br label %whilecond1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


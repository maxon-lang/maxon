// Test: arrays.arrays.basic.1
// Test new array syntax
function main() int
    var arr = [5]int
    arr[0] = 10
    arr[1] = 20
    return arr[1]
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 20
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 20)
  unreachable
}


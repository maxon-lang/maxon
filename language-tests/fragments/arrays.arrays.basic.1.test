// Test: arrays.arrays.basic.1
// Test new array syntax
function main() int
    var arr = [5]int
    arr[0] = 10
    arr[1] = 20
    return arr[1]
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = call ptr @malloc(i64 20)
  %1 = alloca ptr
  store ptr %0, ptr %1
  %2 = alloca i32
  store i32 5, ptr %2
  %3 = call ptr @memset(ptr %0, i32 0, i64 20)
  %4 = load ptr, ptr %1
  %5 = getelementptr i32, ptr %4, i64 0, i64 0
  store i32 10, ptr %5
  %6 = load ptr, ptr %1
  %7 = getelementptr i32, ptr %6, i64 0, i64 1
  store i32 20, ptr %7
  %8 = load ptr, ptr %1
  %9 = getelementptr i32, ptr %8, i64 0, i64 1
  %10 = load i32, ptr %9
  %11 = load ptr, ptr %1
  call void @free(ptr %11)
  ret i32 %10
}

declare ptr @malloc(i64 %arg0)

declare void @free(ptr %arg0)

declare ptr @memset(ptr %arg0, i32 %arg1, i64 %arg2)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


// Test: while-loops.while-loops.zero-iterations.1
function main() int
    var x = 10
    while x < 5 'loop'
        x = x + 1
    end 'loop'
    return x
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 10, ptr %0
  br label %whilecond1
whilecond1:
  %1 = load i32, ptr %0
  %2 = icmp slt i32 %1, 5
  br i1 %2, label %loop2, label %afterloop3
loop2:
  %3 = load i32, ptr %0
  %4 = add i32 %3, 1
  store i32 %4, ptr %0
  br label %whilecond1
afterloop3:
  %5 = load i32, ptr %0
  ret i32 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

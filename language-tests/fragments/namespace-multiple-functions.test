namespace math 'math'
    function square(x int) int
        return x * x
    end 'square'
    
    function cube(x int) int
        return x * x * x
    end 'cube'
end 'math'

function main() int
    return square(5) + cube(2)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %0 = call i32 @"math::square"(i32 5)
  %1 = call i32 @"math::cube"(i32 2)
  %addtmp = add i32 %1, %0
  ret i32 %addtmp
}

define i32 @"math::square"(i32 %0) {
entry:
  %multmp = mul i32 %0, %0
  ret i32 %multmp
}

define i32 @"math::cube"(i32 %0) {
entry:
  %multmp = mul i32 %0, %0
  %multmp4 = mul i32 %multmp, %0
  ret i32 %multmp4
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}
---
ExitCode: 33

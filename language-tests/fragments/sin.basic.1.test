scale_loop:                                       ; preds = %scale_body, %copy_int_done
  %scale_idx = phi i32 [ 0, %copy_int_done ], [ %41, %scale_body ], !dbg !17
  %scale_accum = phi double [ 1.000000e+00, %copy_int_done ], [ %next_scale, %scale_body ], !dbg !17
  %40 = icmp slt i32 %scale_idx, %1, !dbg !17
  br i1 %40, label %scale_body, label %scale_done, !dbg !17

scale_body:                                       ; preds = %scale_loop
  %next_scale = fmul double %scale_accum, 1.000000e+01, !dbg !17
  %41 = add i32 %scale_idx, 1, !dbg !17
  br label %scale_loop, !dbg !17

scale_done:                                       ; preds = %scale_loop
  %frac_scaled = fmul double %frac_part, %scale_accum, !dbg !17
  %frac_rounded = fadd double %frac_scaled, 5.000000e-01, !dbg !17
  %frac_int = fptosi double %frac_rounded to i64, !dbg !17

extract_int:                                      ; preds = %positive, %negative
  %work_value = phi double [ %16, %negative ], [ %0, %positive ], !dbg !17
  %int_part = fptosi double %work_value to i32, !dbg !17
  %int_part_float = sitofp i32 %int_part to double, !dbg !17
  %float_temp = alloca [20 x i8], align 1, !dbg !17
  %17 = call ptr @memset(ptr %float_temp, i32 0, i64 20), !dbg !17
  %float_temp_idx = alloca i32, align 4, !dbg !17
  store i32 19, ptr %float_temp_idx, align 4, !dbg !17
  %18 = icmp eq i32 %int_part, 0, !dbg !17
  br i1 %18, label %int_zero, label %int_nonzero, !dbg !17

int_zero:                                         ; preds = %extract_int
  %19 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 19, !dbg !17
  store i8 48, ptr %19, align 1, !dbg !17
  store i32 18, ptr %float_temp_idx, align 4, !dbg !17
  br label %int_digits_done, !dbg !17

int_nonzero:                                      ; preds = %extract_int
  br label %int_digit_loop, !dbg !17

int_digits_done:                                  ; preds = %int_digit_loop, %int_zero
  %final_temp_idx = phi i32 [ %current_temp_idx, %int_digit_loop ], [ 18, %int_zero ], !dbg !17
  %20 = add i32 %final_temp_idx, 1, !dbg !17
  %21 = sub i32 20, %20, !dbg !17
  br label %copy_int_loop, !dbg !17

int_digit_loop:                                   ; preds = %int_digit_body, %int_nonzero
  %remaining_int = phi i32 [ %int_part, %int_nonzero ], [ %27, %int_digit_body ], !dbg !17
  %current_temp_idx = phi i32 [ 19, %int_nonzero ], [ %28, %int_digit_body ], !dbg !17
  %22 = icmp ne i32 %remaining_int, 0, !dbg !17

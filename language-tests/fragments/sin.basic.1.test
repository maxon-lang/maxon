frac_digit_loop:                                  ; preds = %frac_digit_body, %scale_done
  %frac_idx = phi i32 [ %42, %scale_done ], [ %51, %frac_digit_body ], !dbg !17
  %frac_remaining = phi i64 [ %frac_int, %scale_done ], [ %50, %frac_digit_body ], !dbg !17

  %value_abs = phi i32 [ %11, %negative ], [ %0, %positive ], !dbg !17
  %start_offset = phi i32 [ 1, %negative ], [ 0, %positive ], !dbg !17
  br label %digit_loop, !dbg !17

digit_loop:                                       ; preds = %digit_loop_body, %extract_digits
  %remaining = phi i32 [ %value_abs, %extract_digits ], [ %17, %digit_loop_body ], !dbg !17
  %temp_idx = phi i32 [ 0, %extract_digits ], [ %18, %digit_loop_body ], !dbg !17
  %12 = icmp ne i32 %remaining, 0, !dbg !17
  br i1 %12, label %digit_loop_body, label %reverse_loop, !dbg !17

digit_loop_body:                                  ; preds = %digit_loop
  %13 = srem i32 %remaining, 10, !dbg !17
  %14 = add i32 %13, 48, !dbg !17
  %15 = trunc i32 %14 to i8, !dbg !17
  %16 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %temp_idx, !dbg !17
  store i8 %15, ptr %16, align 1, !dbg !17
  %17 = sdiv i32 %remaining, 10, !dbg !17
  %18 = add i32 %temp_idx, 1, !dbg !17
  br label %digit_loop, !dbg !17

reverse_loop:                                     ; preds = %reverse_body, %digit_loop
  %reverse_idx = phi i32 [ 0, %digit_loop ], [ %26, %reverse_body ], !dbg !17
  %offset_in_reverse = phi i32 [ %start_offset, %digit_loop ], [ %offset_in_reverse, %reverse_body ], !dbg !17
  %digit_count_in_reverse = phi i32 [ %temp_idx, %digit_loop ], [ %digit_count_in_reverse, %reverse_body ], !dbg !17
  %19 = icmp slt i32 %reverse_idx, %digit_count_in_reverse, !dbg !17
  br i1 %19, label %reverse_body, label %format_done, !dbg !17

reverse_body:                                     ; preds = %reverse_loop
  %20 = sub i32 %digit_count_in_reverse, %reverse_idx, !dbg !17
  %21 = sub i32 %20, 1, !dbg !17
  %22 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %21, !dbg !17
  %23 = load i8, ptr %22, align 1, !dbg !17
  %24 = add i32 %offset_in_reverse, %reverse_idx, !dbg !17
  %25 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 %24, !dbg !17
  store i8 %23, ptr %25, align 1, !dbg !17
  %26 = add i32 %reverse_idx, 1, !dbg !17
  br label %reverse_loop, !dbg !17
}

define i32 @print_float(double %0, i32 %1) #0 {
entry:
  %buffer = alloca [32 x i8], align 1, !dbg !17
  %bytesWritten = alloca i32, align 4, !dbg !17
  %2 = call ptr @memset(ptr %buffer, i32 0, i64 32), !dbg !17
  %3 = fcmp oeq double %0, 0.000000e+00, !dbg !17
  br i1 %3, label %zero_case, label %non_zero, !dbg !17

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !17
  store i8 48, ptr %4, align 1, !dbg !17
  %5 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 1, !dbg !17
  store i8 46, ptr %5, align 1, !dbg !17
  br label %zero_fill_loop, !dbg !17

non_zero:                                         ; preds = %entry
  %pos = alloca i32, align 4, !dbg !17
  store i32 0, ptr %pos, align 4, !dbg !17
  %6 = fcmp olt double %0, 0.000000e+00, !dbg !17
  br i1 %6, label %negative, label %positive, !dbg !17

format_done:                                      ; preds = %frac_digits_done, %zero_fill_done
  %final_float_length = phi i32 [ %14, %zero_fill_done ], [ %53, %frac_digits_done ], !dbg !17
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !17
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %final_float_length, ptr %bytesWritten, ptr null), !dbg !17
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !17
  ret i32 0, !dbg !17

zero_fill_loop:                                   ; preds = %zero_fill_body, %zero_case
  %zero_fill_idx = phi i32 [ 0, %zero_case ], [ %13, %zero_fill_body ], !dbg !17
  %10 = icmp slt i32 %zero_fill_idx, %1, !dbg !17
  br i1 %10, label %zero_fill_body, label %zero_fill_done, !dbg !17

zero_fill_body:                                   ; preds = %zero_fill_loop
  %11 = add i32 2, %zero_fill_idx, !dbg !17
  %12 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %11, !dbg !17
  store i8 48, ptr %12, align 1, !dbg !17
  %13 = add i32 %zero_fill_idx, 1, !dbg !17
  br label %zero_fill_loop, !dbg !17

zero_fill_done:                                   ; preds = %zero_fill_loop
  %14 = add i32 2, %1, !dbg !17
  br label %format_done, !dbg !17

negative:                                         ; preds = %non_zero
  %15 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !17
  store i8 45, ptr %15, align 1, !dbg !17
  store i32 1, ptr %pos, align 4, !dbg !17
  %16 = fneg double %0, !dbg !17
  br label %extract_int, !dbg !17

positive:                                         ; preds = %non_zero

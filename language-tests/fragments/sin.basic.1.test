function main() int
    var x1 = sin(0.0)
    var x2 = sin(0.5)
    var x3 = sin(1.0)
    var x4 = sin(1.5708)
    print_float(x1, 6)
    print_float(x2, 6)
    print_float(x3, 6)
    print_float(x4, 6)
    return 0
end 'main'

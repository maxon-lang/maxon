int_digit_body:                                   ; preds = %int_digit_loop
  %23 = srem i32 %remaining_int, 10, !dbg !17
  %24 = add i32 %23, 48, !dbg !17
  %25 = trunc i32 %24 to i8, !dbg !17
  %26 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %current_temp_idx, !dbg !17
  store i8 %25, ptr %26, align 1, !dbg !17
  %27 = sdiv i32 %remaining_int, 10, !dbg !17
  %28 = sub i32 %current_temp_idx, 1, !dbg !17
  br label %int_digit_loop, !dbg !17

copy_int_loop:                                    ; preds = %copy_int_body, %int_digits_done
  %copy_idx = phi i32 [ 0, %int_digits_done ], [ %35, %copy_int_body ], !dbg !17
  %29 = icmp slt i32 %copy_idx, %21, !dbg !17
  br i1 %29, label %copy_int_body, label %copy_int_done, !dbg !17

copy_int_body:                                    ; preds = %copy_int_loop
  %current_pos = load i32, ptr %pos, align 4, !dbg !17
  %30 = add i32 %20, %copy_idx, !dbg !17
  %31 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %30, !dbg !17
  %32 = load i8, ptr %31, align 1, !dbg !17
  %33 = add i32 %current_pos, %copy_idx, !dbg !17
  %34 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %33, !dbg !17
  store i8 %32, ptr %34, align 1, !dbg !17
  %35 = add i32 %copy_idx, 1, !dbg !17
  br label %copy_int_loop, !dbg !17

copy_int_done:                                    ; preds = %copy_int_loop
  %pos_after_int = load i32, ptr %pos, align 4, !dbg !17
  %36 = add i32 %pos_after_int, %21, !dbg !17
  store i32 %36, ptr %pos, align 4, !dbg !17
  %37 = load i32, ptr %pos, align 4, !dbg !17
  %38 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %37, !dbg !17
  store i8 46, ptr %38, align 1, !dbg !17
  %39 = add i32 %37, 1, !dbg !17
  store i32 %39, ptr %pos, align 4, !dbg !17
  %frac_part = fsub double %work_value, %int_part_float, !dbg !17

// Test: duplicate-block-identifiers.duplicate-block-identifiers.multiple-nested.1
function main() int
    var x = 0
    if true 'outer'
        x = 1
        while true 'inner'
            x = 2
            break
        end 'inner'
    end 'outer'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 2
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 2)
  unreachable
}

---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4
  store i32 0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  br i1 true, label %then, label %ifcont, !dbg !11

then:                                             ; preds = %entry
  store i32 1, ptr %x, align 4, !dbg !12
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %afterbreak, %then
  br i1 true, label %loop, label %afterloop, !dbg !13

loop:                                             ; preds = %whilecond
  store i32 2, ptr %x, align 4, !dbg !14
  br label %afterloop, !dbg !15

afterbreak:                                       ; No predecessors!
  br label %whilecond, !dbg !15

afterloop:                                        ; preds = %loop, %whilecond
  br label %ifcont, !dbg !15

ifcont:                                           ; preds = %afterloop, %entry
  %x1 = load i32, ptr %x, align 4, !dbg !16
  ret i32 %x1, !dbg !16
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}


!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"Dwarf Version", i32 4}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 2, type: !5, scopeLine: 2, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 3, column: 5, scope: !4)
!10 = !DILocalVariable(name: "x", scope: !4, file: !1, line: 3, type: !7, align: 32)
!11 = !DILocation(line: 4, column: 5, scope: !4)
!12 = !DILocation(line: 5, column: 11, scope: !4)
!13 = !DILocation(line: 6, column: 9, scope: !4)
!14 = !DILocation(line: 7, column: 15, scope: !4)
!15 = !DILocation(line: 8, column: 13, scope: !4)
!16 = !DILocation(line: 11, column: 5, scope: !4)

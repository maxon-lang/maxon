// Test: top-level-let.logical-operations.1
let BOTH = true and true
let EITHER = false or true
let NEITHER = not false

function main() returns int
    if BOTH and EITHER and NEITHER 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 12

@BOTH = constant i8 zeroinitializer
@EITHER = constant i8 zeroinitializer
@NEITHER = constant i8 zeroinitializer

define i64 @main() {
entry0:
  %0 = load i8, ptr @BOTH
  %1 = load i8, ptr @EITHER
  %2 = and i8 %0, %1
  %3 = load i8, ptr @NEITHER
  %4 = and i8 %2, %3
  %5 = icmp ne i8 %4, 0
  br i1 %5, label %then1, label %ifcont2
then1:
  ret i64 1
ifcont2:
  ret i64 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}

---

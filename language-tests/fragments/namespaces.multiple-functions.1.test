// Test: namespaces.multiple-functions.1
namespace utils 'utils'
    function double(x int) int
        return x * 2
    end 'double'
    
    function triple(x int) int
        return x * 3
    end 'triple'
end 'utils'

function main() int
    return double(5) + triple(4)
end 'main'

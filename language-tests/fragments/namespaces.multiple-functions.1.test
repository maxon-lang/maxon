; Module: test.maxon

define i32 @double(i32 %x) {
entry0:
  %0 = alloca i32
  store i32 %x, ptr %0
  %2 = shl i32 %x, 1
  ret i32 %2
}

define i32 @triple(i32 %x) {
entry0:
  %0 = alloca i32
  store i32 %x, ptr %0
  %2 = mul i32 %x, 3
  ret i32 %2
}

define i32 @main() {
entry0:
  %0 = call i32 @double(i32 5)
  %1 = call i32 @triple(i32 4)
  %2 = add i32 %0, %1
  ret i32 %2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


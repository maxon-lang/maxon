  %x1 = load i32, ptr %x, align 4, !dbg !15
  %multmp = mul i32 %x1, 2, !dbg !15
  ret i32 %multmp, !dbg !15
}

define internal i32 @utils.triple(i32 %0) !dbg !16 {

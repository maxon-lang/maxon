// Test: unary-operators.unary-plus.1
function main() int
    var x = +42
    return x
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 42, ptr %0
  ret i32 42
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 42, ptr %0
  %1 = load i32, ptr %0
  ret i32 %1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
ExitCode: 42

// Test: single-line-if.single-line-if.assignment.1
function main() int
	var x = 10
	var result = 0
	if x == 10 then result = 42
	return result
end 'main'
---
; Module: test.maxon
; Instructions: 10

define i32 @main() {
entry0:
  %1 = alloca i32
  store i32 0, ptr %1
  br i1 1, label %then1, label %ifcont2
then1:
  store i32 42, ptr %1
  br label %ifcont2
ifcont2:
  %4 = load i32, ptr %1
  ret i32 %4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


  %fdivtmp.i13 = fdiv double %5, 0x3FE62E42FEFA39EF
  %6 = tail call fastcc double @math.log(double 2.500000e-01)
  %fdivtmp.i14 = fdiv double %6, 0x3FE62E42FEFA39EF
  tail call fastcc void @sys.print_float(double 0.000000e+00)
  tail call fastcc void @sys.print_float(double %fdivtmp.i)
  tail call fastcc void @sys.print_float(double %fdivtmp.i9)
  tail call fastcc void @sys.print_float(double %fdivtmp.i10)

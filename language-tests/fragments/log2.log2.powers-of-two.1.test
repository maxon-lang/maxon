declare i32 @write_stdout(ptr, i32)

declare ptr @malloc(i64)

declare void @free(ptr)

declare ptr @memset(ptr, i32, i64)

declare double @llvm.floor.f64(double)

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



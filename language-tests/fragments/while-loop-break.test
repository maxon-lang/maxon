function main() int
    var x = 5
    while true 'loop'
        x = x + 2
        if x == 11 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4
  br label %whilecond

whilecond:                                        ; preds = %ifcont, %entry
  br i1 true, label %loop, label %afterloop

loop:                                             ; preds = %whilecond
  %x1 = load i32, ptr %x, align 4
  %addtmp = add i32 %x1, 2
  store i32 %addtmp, ptr %x, align 4
  %x2 = load i32, ptr %x, align 4
  %cmptmp = icmp eq i32 %x2, 11
  br i1 %cmptmp, label %then, label %ifcont

then:                                             ; preds = %loop
  br label %afterloop

afterbreak:                                       ; No predecessors!
  br label %ifcont

ifcont:                                           ; preds = %afterbreak, %loop
  br label %whilecond

afterloop:                                        ; preds = %then, %whilecond
  %x3 = load i32, ptr %x, align 4
  ret i32 %x3
}
---
ExitCode: 11

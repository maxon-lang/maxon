function main() int
    var x = 5
    while true 'loop'
        x = x + 2
        if x = 11 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@_fltused = constant i32 39029

define void @__chkstk() {
entry:
  ret void
}

define i32 @main() {
entry:
  br label %whilecond

whilecond:                                        ; preds = %whilecond, %entry
  %x.0 = phi i32 [ 5, %entry ], [ %addtmp, %whilecond ]
  %addtmp = add i32 %x.0, 2
  %cmptmp = icmp eq i32 %addtmp, 11
  br i1 %cmptmp, label %afterloop, label %whilecond

afterloop:                                        ; preds = %whilecond
  ret i32 11
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

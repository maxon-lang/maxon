function main() int
    var x = 5
    while true 'loop'
        x = x + 2
        if x = 11 'check'
            break
        end 'check'
    end 'loop'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  br label %whilecond

whilecond:                                        ; preds = %whilecond, %entry
  %x.0 = phi i32 [ 5, %entry ], [ %addtmp, %whilecond ]
  %addtmp = add i32 %x.0, 2
  %cmptmp = icmp eq i32 %addtmp, 11
  br i1 %cmptmp, label %afterloop, label %whilecond

afterloop:                                        ; preds = %whilecond
  ret i32 11
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  br label %whilecond, !dbg !11

whilecond:                                        ; preds = %ifcont, %entry
  br i1 true, label %loop, label %afterloop, !dbg !11

loop:                                             ; preds = %whilecond
  %x1 = load i32, ptr %x, align 4, !dbg !12
  %addtmp = add i32 %x1, 2, !dbg !12
  store i32 %addtmp, ptr %x, align 4, !dbg !12
  %x2 = load i32, ptr %x, align 4, !dbg !13
  %cmptmp = icmp eq i32 %x2, 11, !dbg !13
  br i1 %cmptmp, label %then, label %ifcont, !dbg !13

then:                                             ; preds = %loop
  br label %afterloop, !dbg !14

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !14

ifcont:                                           ; preds = %afterbreak, %loop
  br label %whilecond, !dbg !14

afterloop:                                        ; preds = %then, %whilecond
  %x3 = load i32, ptr %x, align 4, !dbg !15
  ret i32 %x3, !dbg !15
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 1, type: !5, scopeLine: 1, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 2, column: 5, scope: !4)
!10 = !DILocalVariable(name: "x", scope: !4, file: !1, line: 2, type: !7, align: 32)
!11 = !DILocation(line: 3, column: 5, scope: !4)

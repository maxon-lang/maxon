// Test: static-methods.static-no-params.1
type Point
    var x int
    var y int

    static function origin() returns Point
        return Point{x: 0, y: 0}
    end 'origin'
end 'Point'

function main() returns int
    var p = Point.origin()
    print("{p.x},{p.y}")
    return 0
end 'main'

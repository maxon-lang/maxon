%string = type { ptr, i32 }
%__ManagedStringData = type { %__unsized_array_byte, i32, i32 }

@.str.0 = constant [6 x i8] c"Hello\00"

define i32 @main() {
entry0:
  %0 = alloca %string
  %1 = alloca %__ManagedStringData
  %2 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 0
  %3 = getelementptr %__unsized_array_byte, ptr %2, i32 0, i32 0
  store ptr @.str.0, ptr %3
  %4 = getelementptr %__unsized_array_byte, ptr %2, i32 0, i32 1
  store i32 5, ptr %4
  %5 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 1
  store i32 5, ptr %5
  %6 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 2
  store i32 0, ptr %6
  %7 = getelementptr %string, ptr %0, i32 0, i32 0
  store ptr %1, ptr %7
  %10 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 2
  %11 = load i32, ptr %10
  %12 = icmp sgt i32 %11, 0
  br i1 %12, label %refcount.heap1, label %refcount.const2
refcount.heap1:
  %13 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 0
  %14 = getelementptr %__unsized_array_byte, ptr %13, i32 0, i32 0
  %15 = load ptr, ptr %14
  %16 = getelementptr i8, ptr %15, i64 -8
  %17 = load i32, ptr %16
  br label %refcount.merge3
refcount.const2:
  br label %refcount.merge3
refcount.merge3:
  %18 = phi i32 [ %17, %refcount.heap1 ], [ -1, %refcount.const2 ]
  ret i32 %18
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


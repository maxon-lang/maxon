entry0:
  %0 = alloca %string
  %1 = alloca %__ManagedStringData
  %2 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 0
  %3 = getelementptr %__unsized_array_byte, ptr %2, i32 0, i32 0
  store ptr @.str.0, ptr %3
  %4 = getelementptr %__unsized_array_byte, ptr %2, i32 0, i32 1
  store i32 5, ptr %4
  %5 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 1
  store i32 5, ptr %5
  %6 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 2
  store i32 0, ptr %6
  %7 = getelementptr %string, ptr %0, i32 0, i32 0
  store ptr %1, ptr %7
  %8 = getelementptr %string, ptr %0, i32 0, i32 1
  store i32 0, ptr %8
  %11 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 2
  %12 = load i32, ptr %11
  %13 = icmp sgt i32 %12, 0
  br i1 %13, label %refcount.heap1, label %refcount.const2
refcount.heap1:
  %14 = getelementptr %__ManagedStringData, ptr %1, i32 0, i32 0
  %15 = getelementptr %__unsized_array_byte, ptr %14, i32 0, i32 0
  %16 = load ptr, ptr %15
  %17 = getelementptr i8, ptr %16, i64 -8
  %18 = load i32, ptr %17
  br label %refcount.merge3
refcount.const2:
  br label %refcount.merge3
refcount.merge3:
  %19 = phi i32 [ %18, %refcount.heap1 ], [ -1, %refcount.const2 ]
  ret i32 %19
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


// Test: substring-type.sso-string-no-refcount.1
function main() int
    // Short string uses SSO (no heap)
    var s = "Hello"
    var refcount = __string_get_refcount(s._managed)
    // SSO strings return -1 for refcount
    return refcount
end 'main'

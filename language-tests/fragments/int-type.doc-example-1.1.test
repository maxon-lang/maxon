// Test: int-type.doc-example-1.1
function factorial(n int) int
    if n <= 1 'base'
        return 1
    end 'base'
    return n * factorial(n - 1)
end 'factorial'

function main() int
    return factorial(5)  // Returns 120
end 'main'
---
; Module: test.maxon
; Instructions: 17

define i32 @factorial(i32 %n) {
entry0:
  %0 = alloca i32
  store i32 %n, ptr %0
  %1 = load i32, ptr %0
  %2 = icmp sle i32 %1, 1
  br i1 %2, label %then1, label %ifcont2
then1:
  ret i32 1
ifcont2:
  %3 = load i32, ptr %0
  %4 = load i32, ptr %0
  %5 = sub i32 %4, 1
  %6 = call i32 @factorial(i32 %5)
  %7 = mul i32 %3, %6
  ret i32 %7
}

define i32 @main() {
entry0:
  %0 = call i32 @factorial(i32 5)
  ret i32 %0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


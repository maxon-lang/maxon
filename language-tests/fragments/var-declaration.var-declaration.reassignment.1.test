  store i32 3, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  %x1 = load i32, ptr %x, align 4, !dbg !11
  %addtmp = add i32 %x1, 2, !dbg !11
  store i32 %addtmp, ptr %x, align 4, !dbg !11
  %x2 = load i32, ptr %x, align 4, !dbg !12
  ret i32 %x2, !dbg !12
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



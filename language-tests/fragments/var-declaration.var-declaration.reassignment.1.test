// Test: var-declaration.var-declaration.reassignment.1
function main() int
    var x = 3
    x = x + 2
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 5
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 5)
  unreachable
}


// Test calling stdlib function without namespace qualification
// The compiler should automatically find and link format_int_array
function main() int
    var buffer [12]char = 0
    // Call without namespace - should work after Phase 4
    return format_int_array(42, buffer)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() #0 {
entry:
  %buffer.malloc = call ptr @malloc(i64 12)
  %0 = call ptr @memset(ptr %buffer.malloc, i32 0, i64 12)
  %1 = call i32 @"stdlib::fmt::format_int_array"(i32 42, ptr %buffer.malloc, i32 12)
  call void @free(ptr %buffer.malloc)
  ret i32 %1
}

define i32 @"stdlib::fmt::format_int_array"(i32 %0, ptr %1, i32 %2) #0 {
entry:
  %cmptmp = icmp eq i32 %0, 0
  br i1 %cmptmp, label %then, label %ifcont

common.ret:                                       ; preds = %whilecond32, %then
  %common.ret.op = phi i32 [ 1, %then ], [ %subtmp31, %whilecond32 ]
  ret i32 %common.ret.op

then:                                             ; preds = %entry
  store i8 48, ptr %1, align 1
  br label %common.ret

ifcont:                                           ; preds = %entry
  %temp.malloc = call ptr @malloc(i64 12)
  %3 = call ptr @memset(ptr %temp.malloc, i32 0, i64 12)
  %cmptmp4 = icmp slt i32 %0, 0
  %subtmp = sub i32 0, %0
  %spec.select = select i1 %cmptmp4, i32 %subtmp, i32 %0
  br label %whilecond

whilecond:                                        ; preds = %loop, %ifcont
  %abs_value.1 = phi i32 [ %spec.select, %ifcont ], [ %divtmp, %loop ]
  %pos.0 = phi i32 [ 11, %ifcont ], [ %subtmp17, %loop ]
  %cmptmp9 = icmp sgt i32 %abs_value.1, 0
  br i1 %cmptmp9, label %loop, label %afterloop

loop:                                             ; preds = %whilecond
  %modtmp = urem i32 %abs_value.1, 10
  %4 = trunc nuw nsw i32 %modtmp to i8
  %trunctmp = or disjoint i8 %4, 48
  %5 = sext i32 %pos.0 to i64
  %arrayidx15 = getelementptr inbounds i8, ptr %temp.malloc, i64 %5
  store i8 %trunctmp, ptr %arrayidx15, align 1
  %subtmp17 = add i32 %pos.0, -1
  %divtmp = udiv i32 %abs_value.1, 10
  br label %whilecond

afterloop:                                        ; preds = %whilecond
  br i1 %cmptmp4, label %then21, label %ifcont27

then21:                                           ; preds = %afterloop
  %6 = sext i32 %pos.0 to i64
  %arrayidx24 = getelementptr inbounds i8, ptr %temp.malloc, i64 %6
  store i8 45, ptr %arrayidx24, align 1
  %subtmp26 = add i32 %pos.0, -1
  br label %ifcont27

ifcont27:                                         ; preds = %then21, %afterloop
  %pos.1 = phi i32 [ %subtmp26, %then21 ], [ %pos.0, %afterloop ]
  %addtmp29 = add i32 %pos.1, 1
  %subtmp31 = sub i32 11, %pos.1
  br label %whilecond32

whilecond32:                                      ; preds = %loop36, %ifcont27
  %i.0 = phi i32 [ 0, %ifcont27 ], [ %addtmp46, %loop36 ]
  %cmptmp35 = icmp slt i32 %i.0, %subtmp31
  br i1 %cmptmp35, label %loop36, label %common.ret

loop36:                                           ; preds = %whilecond32
  %addtmp40 = add i32 %addtmp29, %i.0
  %7 = sext i32 %addtmp40 to i64
  %arrayidx42 = getelementptr inbounds i8, ptr %temp.malloc, i64 %7
  %arrayelem = load i8, ptr %arrayidx42, align 1
  %8 = sext i32 %i.0 to i64
  %arrayidx44 = getelementptr inbounds i8, ptr %1, i64 %8
  store i8 %arrayelem, ptr %arrayidx44, align 1
  %addtmp46 = add i32 %i.0, 1
  br label %whilecond32
}

declare ptr @GetProcessHeap()

declare ptr @HeapAlloc(ptr, i32, i64)

declare i32 @HeapFree(ptr, i32, ptr)

define ptr @malloc(i64 %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call ptr @HeapAlloc(ptr %1, i32 0, i64 %0)
  ret ptr %2
}

define void @free(ptr %0) {
entry:
  %1 = call ptr @GetProcessHeap()
  %2 = call i32 @HeapFree(ptr %1, i32 0, ptr %0)
  ret void
}

declare ptr @memset(ptr, i32, i64)

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

attributes #0 = { "no-builtin-memset" }
---
ExitCode: 2

  %x1 = load double, ptr %x, align 8, !dbg !11
  %round.result = call double @llvm.round.f64(double %x1), !dbg !11
  %toint = fptosi double %round.result to i32, !dbg !11
  store i32 %toint, ptr %y, align 4, !dbg !11
    #dbg_declare(ptr %y, !12, !DIExpression(), !11)
  %y2 = load i32, ptr %y, align 4, !dbg !13
  ret i32 %y2, !dbg !13
}


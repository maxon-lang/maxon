%IntFloat = type { i32, f64 }

define i32 @main() {
entry0:
  %0 = alloca %IntFloat
  %1 = getelementptr %IntFloat, ptr %0, i32 0, i32 0
  store i32 40, ptr %1
  %2 = getelementptr %IntFloat, ptr %0, i32 0, i32 1
  store f64 2.5, ptr %2
  %12 = getelementptr %IntFloat, ptr %0, i32 0, i32 0
  %13 = load i32, ptr %12
  %14 = getelementptr %IntFloat, ptr %0, i32 0, i32 1
  %15 = load f64, ptr %14
  %6 = call f64 @trunc(f64 %15)
  %7 = fptosi f64 %6 to i32
  %11 = add i32 %13, %7
  ret i32 %11
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


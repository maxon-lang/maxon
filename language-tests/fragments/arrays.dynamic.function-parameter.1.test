// Test: arrays.dynamic.function-parameter.1
function sum_array(arr []int, len int) int
    var total = 0
    var i = 0
    while i < len 'loop'
        total = total + arr[i]
        i = i + 1
    end 'loop'
    return total
end 'sum_array'

function main() int
    var data = [3]int
    data[0] = 5
    data[1] = 10
    data[2] = 15
    return sum_array(data, 3)
end 'main'

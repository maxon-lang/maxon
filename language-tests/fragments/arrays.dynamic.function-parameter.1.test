// Test: arrays.dynamic.function-parameter.1
function sum_array(arr array of int, len int) returns int
    var total = 0
    var i = 0
    while i < len 'loop'
        total = total + arr[i]
        i = i + 1
    end 'loop'
    return total
end 'sum_array'

function main() returns int
    var data = [5, 10, 15]
    return sum_array(data, 3)
end 'main'

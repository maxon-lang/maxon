// Test: bool-type.bool-parameter.1
function test_bool_param(flag bool) int
    if flag 'check'
        return 1
    else 'check'
        return 0
    end 'check'
end 'test_bool_param'

function main() int
    return test_bool_param(true)
end 'main'

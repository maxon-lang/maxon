// Test: constant-folding.with-let.1
function main() int
    let x = 100
    let y = 25
    return x mod y
end 'main'
---
; Module: test.maxon
; Instructions: 11

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 100, ptr %0
  %1 = alloca i32
  store i32 25, ptr %1
  %2 = load i32, ptr %0
  %3 = load i32, ptr %1
  %4 = srem i32 %2, %3
  ret i32 %4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


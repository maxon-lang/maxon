// Test: collection.map-closure-square.1
function main() returns int
    var arr = [1, 2, 3, 4]
    var squared = arr.map((n int) gives n * n)
    print("{squared[0]}")
    print("{squared[1]}")
    print("{squared[2]}")
    print("{squared[3]}")
    return 0
end 'main'

// Test: interfaces.self-return-type.1
interface Movable
    function move(dx int, dy int) Self
end 'Movable'

struct Point is Movable
    x int
    y int

    function move(dx int, dy int) Point
        return Point{x: x + dx, y: y + dy}
    end 'move'
end 'Point'

function main() int
    var p = Point{x: 10, y: 20}
    var p2 = p.move(5, 10)
    return p2.x + p2.y
end 'main'

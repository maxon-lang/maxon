end 'Movable'

type Point is Movable
    var x int
    var y int

    function Movable.move(dx int, dy int) returns Point
        return Point{x: x + dx, y: y + dy}
    end 'move'
end 'Point'

function main() returns int
    var p = Point{x: 10, y: 20}
    var p2 = p.move(5, 10)
    return p2.x + p2.y
end 'main'

// Test: enums.match-expr-enum-binding.1
enum Container
    case empty
    case value(n int)
end 'Container'

function main() int
    var c = Container.value(10)
    var result = match c 'get'
        case empty gives 0
        case value(n) gives n * 2
    end 'get'
    return result
end 'main'

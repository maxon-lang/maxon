// Test: string-type.endsWith.1
function main() returns int
    var s = "hello world"
    if s.endsWith("world") 'c1'
        print("{1}")
    end 'c1'
    if s.endsWith("hello") 'c2'
        print("{0}")
    end 'c2'
    return 0
end 'main'

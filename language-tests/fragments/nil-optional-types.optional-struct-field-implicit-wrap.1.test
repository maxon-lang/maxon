// Test: nil-optional-types.optional-struct-field-implicit-wrap.1
type Point
	var x int
	var y int or nil
end 'Point'

function main() returns int
	var p = Point{x: 10, y: 20}
	var result = p.y else 'default'
		result = 0
	end 'default'
	return p.x + result
end 'main'

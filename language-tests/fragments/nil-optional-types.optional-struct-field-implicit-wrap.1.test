  store i32 10, ptr %1
  %2 = getelementptr %Point, ptr %0, i32 0, i32 1
  %3 = alloca Optional<i32>
  %4 = getelementptr Optional<i32>, ptr %3, i32 0, i32 0
  store i8 1, ptr %4
  %5 = getelementptr Optional<i32>, ptr %3, i32 0, i32 1
  store i32 20, ptr %5
  %6 = load Optional<i32>, ptr %3
  store Optional<i32> %6, ptr %2
  %7 = getelementptr %Point, ptr %0, i32 0, i32 1
  %8 = load Optional<i32>, ptr %7
  %10 = alloca Optional<i32>
  store Optional<i32> %8, ptr %10
  %11 = getelementptr Optional<i32>, ptr %10, i32 0, i32 0
  %12 = load i8, ptr %11
  %13 = icmp eq i8 %12, 1
  br i1 %13, label %unwrap.hasvalue1, label %unwrap.else2
unwrap.hasvalue1:
  %14 = getelementptr Optional<i32>, ptr %10, i32 0, i32 1
  %15 = load i32, ptr %14
  br label %unwrap.after3
unwrap.else2:
  br label %unwrap.after3
unwrap.after3:
  %20 = phi i32 [ %15, %unwrap.hasvalue1 ], [ 0, %unwrap.else2 ]
  %16 = getelementptr %Point, ptr %0, i32 0, i32 0
  %17 = load i32, ptr %16
  %19 = add i32 %17, %20
  ret i32 %19
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


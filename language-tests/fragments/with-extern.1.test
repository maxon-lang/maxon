entry:
  %0 = tail call ptr @GetStdHandle(i32 -11)
  %1 = ptrtoint ptr %0 to i64
  %ptr2inttmp = trunc i64 %1 to i32
  %cmptmp = icmp sgt i32 %ptr2inttmp, 0
  %. = zext i1 %cmptmp to i32
  ret i32 %.
}


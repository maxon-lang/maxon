; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  tail call fastcc void @sys.print()
  ret i32 0
}

define internal fastcc void @sys.print() unnamed_addr {
entry:
  %buffer.malloc = tail call dereferenceable_or_null(12) ptr @malloc(i64 12)
  %0 = tail call ptr @memset(ptr %buffer.malloc, i32 0, i64 12)
  %temp.malloc.i = tail call dereferenceable_or_null(12) ptr @malloc(i64 12)
  %1 = tail call ptr @memset(ptr %temp.malloc.i, i32 0, i64 12)
  %arrayidx14.i = getelementptr inbounds nuw i8, ptr %temp.malloc.i, i64 11
  store i8 50, ptr %arrayidx14.i, align 1
  %arrayidx14.1.i = getelementptr i8, ptr %temp.malloc.i, i64 10
  store i8 52, ptr %arrayidx14.1.i, align 1
  %2 = load i16, ptr %arrayidx14.1.i, align 1
  store i16 %2, ptr %buffer.malloc, align 1
  %3 = tail call i32 @write_stdout(ptr nonnull %buffer.malloc, i32 2)
  %cmptmp = icmp sgt i32 %3, -1
  tail call void @llvm.assume(i1 %cmptmp)
  %newline.malloc = tail call dereferenceable_or_null(1) ptr @malloc(i64 1)
  store i8 10, ptr %newline.malloc, align 1
  %4 = tail call i32 @write_stdout(ptr nonnull %newline.malloc, i32 1)
  tail call void @free(ptr %newline.malloc)
  tail call void @free(ptr %buffer.malloc)
  ret void
}

declare i32 @write_stdout(ptr, i32)

declare noalias ptr @malloc(i64 noundef)

declare void @free(ptr allocptr captures(none))

declare ptr @memset(ptr writeonly, i32, i64)

declare void @exit(i32)

define void @_start() {
entry:
  %0 = tail call i32 @main()
  tail call void @exit(i32 0)
  unreachable
}

declare void @llvm.assume(i1 noundef)


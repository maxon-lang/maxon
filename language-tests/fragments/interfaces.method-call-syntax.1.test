// Test: interfaces.method-call-syntax.1
interface Incrementable
    function inc() int
end 'Incrementable'

struct Value is Incrementable
    n int

    function Incrementable.inc() int
        return n + 1
    end 'inc'
end 'Value'

function main() int
    var v = Value{n: 41}
    return v.inc()
end 'main'
---
; Module: test.maxon
; Instructions: 10

%Value = type { i32 }

define i32 @main() {
entry0:
  %0 = alloca %Value
  %1 = getelementptr %Value, ptr %0, i32 0, i32 0
  store i32 41, ptr %1
  %3 = getelementptr %Value, ptr %0, i32 0, i32 0
  %4 = load i32, ptr %3
  %5 = add i32 %4, 1
  ret i32 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


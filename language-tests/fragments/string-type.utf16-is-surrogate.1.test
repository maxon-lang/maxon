// Test: string-type.utf16-is-surrogate.1
function main() returns int
    if utf16IsSurrogate(55357) 'c7'
        print("{1}")
    end 'c7'
    if utf16IsSurrogate(56832) 'c8'
        print("{2}")
    end 'c8'
    if utf16IsSurrogate(65) 'c9'
        print("{0}")
    end 'c9'
    return 0
end 'main'

// Test: for-loops.doc-example-3.1
function main() int
    var last = 0
    for i in range(1, 4) 'loop'
        last = i  // Can copy value to mutable variable
        // i = 5  // ERROR: Loop variable is immutable
    end 'loop'
    // print(i)  // ERROR: i not in scope here
    return last  // Returns 3
end 'main'

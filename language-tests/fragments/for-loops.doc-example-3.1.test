%string = type { %__unsized_array_byte, i32, i32 }
%__unsized_array_byte = type { ptr, i32 }
%ByteView = type { %string, i32 }
%UTF16View = type { %string, i32, i32 }
%Iterator = type { i32, i32, i32 }

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 1, ptr %1
  %2 = alloca i32
  store i32 4, ptr %2
  br label %forcond1
forcond1:
  %3 = load i32, ptr %1
  %4 = load i32, ptr %2
  %5 = icmp slt i32 %3, %4
  br i1 %5, label %forloop2, label %afterfor4
forloop2:
  %6 = load i32, ptr %1
  store i32 %6, ptr %0
  br label %forincrement3
forincrement3:
  %7 = load i32, ptr %1
  %8 = add i32 %7, 1
  store i32 %8, ptr %1
  br label %forcond1
afterfor4:
  %9 = load i32, ptr %0
  ret i32 %9
}

declare ptr @malloc(i64 %arg0)

declare void @free(ptr %arg0)

declare ptr @memset(ptr %arg0, i32 %arg1, i64 %arg2)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


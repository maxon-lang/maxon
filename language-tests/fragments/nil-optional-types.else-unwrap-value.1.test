// Test: nil-optional-types.else-unwrap-value.1
function returnsValue() int or nil
	return 5
end 'returnsValue'

function main() int
	var opt = returnsValue()
	var result = opt else 'default'
		result = 99
	end 'default'
	return result
end 'main'

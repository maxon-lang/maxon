define Optional<i32> @returnsValue() {
entry0:
  %0 = alloca Optional<i32>
  %1 = getelementptr Optional<i32>, ptr %0, i32 0, i32 0
  store i8 1, ptr %1
  %2 = getelementptr Optional<i32>, ptr %0, i32 0, i32 1
  store i32 5, ptr %2
  %3 = load Optional<i32>, ptr %0
  ret Optional<i32> %3
}

define i32 @main() {
entry0:
  %0 = call Optional<i32> @returnsValue()
  %1 = alloca Optional<i32>
  store Optional<i32> %0, ptr %1
  %2 = load Optional<i32>, ptr %1
  %3 = alloca i32
  %4 = alloca Optional<i32>
  store Optional<i32> %2, ptr %4
  %5 = getelementptr Optional<i32>, ptr %4, i32 0, i32 0
  %6 = load i8, ptr %5
  %7 = icmp eq i8 %6, 1
  br i1 %7, label %unwrap.hasvalue1, label %unwrap.else2
unwrap.hasvalue1:
  %8 = getelementptr Optional<i32>, ptr %4, i32 0, i32 1
  %9 = load i32, ptr %8
  store i32 %9, ptr %3
  br label %unwrap.after3
unwrap.else2:
  store i32 99, ptr %3
  br label %unwrap.after3
unwrap.after3:
  %10 = load i32, ptr %3
  ret i32 %10
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


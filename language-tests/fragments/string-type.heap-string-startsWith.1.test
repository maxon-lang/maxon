// Test: string-type.heap-string-startsWith.1
function main() returns int
    var s = "This is a very long string that is heap allocated"
    if s.startsWith("This is") 'c17'
        print("{1}")
    end 'c17'
    if s.startsWith("That is") 'c18'
        print("{0}")
    end 'c18'
    return 0
end 'main'

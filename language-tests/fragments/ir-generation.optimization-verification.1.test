define internal i32 @compute() !dbg !4 {
entry:
  %x = alloca i32, align 4
  %result = alloca i32, align 4
  store i32 0, ptr %result, align 4, !dbg !9
    #dbg_declare(ptr %result, !10, !DIExpression(), !9)
  store i32 1, ptr %x, align 4, !dbg !11
    #dbg_declare(ptr %x, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %loop, %entry
  %x1 = load i32, ptr %x, align 4, !dbg !13
  %cmptmp = icmp sle i32 %x1, 5, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop, !dbg !13

loop:                                             ; preds = %whilecond
  %result2 = load i32, ptr %result, align 4, !dbg !14
  %x3 = load i32, ptr %x, align 4, !dbg !14
  %multmp = mul i32 %x3, 2, !dbg !14
  %addtmp = add i32 %result2, %multmp, !dbg !14
  store i32 %addtmp, ptr %result, align 4, !dbg !14
  %x4 = load i32, ptr %x, align 4, !dbg !15
  %addtmp5 = add i32 %x4, 1, !dbg !15
  store i32 %addtmp5, ptr %x, align 4, !dbg !15
  br label %whilecond, !dbg !15

afterloop:                                        ; preds = %whilecond
  %result6 = load i32, ptr %result, align 4, !dbg !16
  ret i32 %result6, !dbg !16
}

define i32 @main() !dbg !17 {
entry:
  %0 = call i32 @compute(), !dbg !18
  ret i32 %0, !dbg !18
}

declare void @ExitProcess(i32)

define void @_start() {

// Test: ir-generation.optimization-verification.1
function compute() int
    var result = 0
    var x = 1
    while x <= 5 'loop'
        result = result + x * 2
        x = x + 1
    end 'loop'
    return result
end 'compute'

function main() int
    return compute()
end 'main'

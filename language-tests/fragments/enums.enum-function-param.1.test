// Test: enums.enum-function-param.1
enum Status
    case on
    case off
end 'Status'

function isOn(s Status) bool
    if s == Status.on 'check'
        return true
    end 'check'
    return false
end 'isOn'

function main() int
    var status = Status.on
    if isOn(status) 'test'
        return 1
    end 'test'
    return 0
end 'main'

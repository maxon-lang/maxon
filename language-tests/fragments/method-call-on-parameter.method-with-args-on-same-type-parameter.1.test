// Test: method-call-on-parameter.method-with-args-on-same-type-parameter.1
type Adder
    var value int
    
    function addTo(n int) returns int
        return value + n
    end 'addTo'
    
    function delegateAdd(other Adder, n int) returns int
        return other.addTo(n)
    end 'delegateAdd'
end 'Adder'

function main() returns int
    var a = Adder{value: 100}
    var b = Adder{value: 50}
    return a.delegateAdd(b, 7)
end 'main'
---
; Module: test.maxon
; Instructions: 13

%Adder = type { i32 }

define i32 @main() {
entry0:
  %0 = alloca %Adder
  %1 = getelementptr %Adder, ptr %0, i32 0, i32 0
  store i32 100, ptr %1
  %2 = alloca %Adder
  %3 = getelementptr %Adder, ptr %2, i32 0, i32 0
  store i32 50, ptr %3
  %5 = getelementptr %Adder, ptr %2, i32 0, i32 0
  %6 = load i32, ptr %5
  %7 = add i32 %6, 7
  ret i32 %7
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


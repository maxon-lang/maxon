}

define i32 @Adder.delegateAdd(ptr %self, ptr %other, i32 %n) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = alloca ptr
  store ptr %other, ptr %1
  %2 = alloca i32
  store i32 %n, ptr %2
  %3 = load ptr, ptr %1
  %4 = load i32, ptr %2
  %5 = call i32 @Adder.addTo(ptr %3, i32 %4)

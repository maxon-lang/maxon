  %2 = icmp eq i8 %1, 65
  br i1 %2, label %then1, label %ifcont2
then1:
  ret i32 0
ifcont2:
  ret i32 1
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


define f64 @identity(f64 %x) {
entry0:
  %0 = alloca f64
  store f64 %x, ptr %0
  %1 = load f64, ptr %0
  ret f64 %1
}

define f64 @useFloats(f64 %a, f64 %b, f64 %c, f64 %d) {
entry0:
  %0 = alloca f64
  store f64 %a, ptr %0
  %1 = alloca f64
  store f64 %b, ptr %1
  %2 = alloca f64
  store f64 %c, ptr %2
  %3 = alloca f64
  store f64 %d, ptr %3
  %4 = call f64 @identity(f64 1)
  %5 = alloca f64
  store f64 %4, ptr %5
  %6 = load f64, ptr %0
  %7 = load f64, ptr %1
  %8 = fadd f64 %6, %7
  %9 = load f64, ptr %2
  %10 = fadd f64 %8, %9
  %11 = load f64, ptr %3
  %12 = fadd f64 %10, %11
  %13 = load f64, ptr %5
  %14 = fadd f64 %12, %13
  ret f64 %14
}

define i32 @main() {
entry0:
  %0 = call f64 @useFloats(f64 10, f64 20, f64 30, f64 40)
  %1 = alloca f64
  store f64 %0, ptr %1
  %2 = load f64, ptr %1
  %3 = call f64 @trunc(f64 %2)
  %4 = fptosi f64 %3 to i32
  ret i32 %4
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


  %2 = trunc i32 42 to i8
  store i8 %2, ptr %1
  %7 = getelementptr %SingleByte, ptr %0, i32 0, i32 0
  %8 = load i8, ptr %7
  %6 = zext i8 %8 to i32
  ret i32 %6
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


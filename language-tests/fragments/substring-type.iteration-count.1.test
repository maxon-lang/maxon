// Test: substring-type.iteration-count.1
function main() returns int
    var s = "abcde"
    var sub = s.slice(s.indexAdvanced(s.startIndex(), 1), s.indexAdvanced(s.startIndex(), 4))
    var sum = 0
    for c in sub 'loop'
        var cps = c.codepoints()
        if let cp = cps.next() 'get_cp'
            sum = sum + cp
        end 'get_cp'
    end 'loop'
    // 98 + 99 + 100 = 297 (b, c, d)
    return sum - 294
end 'main'

// Test: substring-type.iteration-count.1
function main() int
    var s = "abcde"
    var sub = s.slice(1, 4)
    var sum = 0
    for c in sub 'loop'
        sum = sum + c
    end 'loop'
    // 98 + 99 + 100 = 297 (b, c, d)
    return sum - 294
end 'main'

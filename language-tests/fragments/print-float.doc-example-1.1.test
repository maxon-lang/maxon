// Test: print-float.doc-example-1.1
function main() int
    var pi = 3.14159
    print_float(pi, 2)     // Prints: 3.14
    print_float(pi, 5)     // Prints: 3.14159
    
    var x = -2.5
    print_float(x, 1)      // Prints: -2.5
    
    return 0
end 'main'

  br label %ifcont2, !dbg !12

else:                                             ; preds = %entry
  br i1 true, label %then1, label %ifcont, !dbg !13

then1:                                            ; preds = %else
  store i32 2, ptr %x, align 4, !dbg !14
  br label %ifcont, !dbg !14

ifcont:                                           ; preds = %then1, %else
  br label %ifcont2, !dbg !14

ifcont2:                                          ; preds = %ifcont, %then
  %x3 = load i32, ptr %x, align 4, !dbg !15
  ret i32 %x3, !dbg !15
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



// Test: duplicate-block-identifiers.duplicate-block-identifiers.else-nested.1
function main() int
    var x = 0
    if false 'check'
        x = 1
    else 'check'
        if true 'nested'
            x = 2
        end 'nested'
    end 'check'
    return x
end 'main'

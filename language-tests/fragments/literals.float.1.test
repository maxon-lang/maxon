// Test: literals.float.1
function main() int
    var x = 3.14
    return trunc(x)
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca f64
  store f64 3.14, ptr %0
  %1 = load f64, ptr %0
  %2 = call f64 @trunc(f64 %1)
  %3 = fptosi f64 %2 to i32
  ret i32 %3
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


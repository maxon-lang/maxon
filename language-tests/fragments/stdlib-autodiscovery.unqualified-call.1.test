// Test: stdlib-autodiscovery.unqualified-call.1
function main() int
    var result = sqrt(16.0)
    return trunc(result)
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = call f64 @sqrt(f64 16)
  %1 = alloca f64
  store f64 %0, ptr %1
  %3 = call f64 @trunc(f64 %0)
  %4 = fptosi f64 %3 to i32
  ret i32 %4
}

declare f64 @sqrt(f64 %arg0)

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = call f64 @sqrt(f64 16)
  %1 = alloca f64
  store f64 %0, ptr %1
  %2 = load f64, ptr %1
  %3 = call f64 @trunc(f64 %2)
  %4 = fptosi f64 %3 to i32
  ret i32 %4
}

declare f64 @sqrt(f64 %arg0)

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---
ExitCode: 4

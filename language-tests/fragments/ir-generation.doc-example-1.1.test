// Test: ir-generation.doc-example-1.1
function main() int
    var sum = 0
    var i = 0
    while i < 10 'loop'
        sum = sum + i
        i = i + 1
    end 'loop'
    return sum
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 45
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 45)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %i = alloca i32, align 4
  %sum = alloca i32, align 4
  store i32 0, ptr %sum, align 4, !dbg !9
    #dbg_declare(ptr %sum, !10, !DIExpression(), !9)
  store i32 0, ptr %i, align 4, !dbg !11
    #dbg_declare(ptr %i, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %loop, %entry
  %i1 = load i32, ptr %i, align 4, !dbg !13
  %cmptmp = icmp slt i32 %i1, 10, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop, !dbg !13

loop:                                             ; preds = %whilecond
  %sum2 = load i32, ptr %sum, align 4, !dbg !14
  %i3 = load i32, ptr %i, align 4, !dbg !14
  %addtmp = add i32 %sum2, %i3, !dbg !14
  store i32 %addtmp, ptr %sum, align 4, !dbg !14
  %i4 = load i32, ptr %i, align 4, !dbg !15
  %addtmp5 = add i32 %i4, 1, !dbg !15
  store i32 %addtmp5, ptr %i, align 4, !dbg !15
  br label %whilecond, !dbg !15

afterloop:                                        ; preds = %whilecond
  %sum6 = load i32, ptr %sum, align 4, !dbg !16
  ret i32 %sum6, !dbg !16
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}


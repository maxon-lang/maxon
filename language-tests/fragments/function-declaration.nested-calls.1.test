// Test: function-declaration.nested-calls.1
function double(x int) int
    return x * 2
end 'double'

function quadruple(x int) int
    return double(double(x))
end 'quadruple'

function main() int
    return quadruple(3)
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 12
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 12)
  unreachable
}


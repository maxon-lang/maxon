define internal i32 @double(i32 %0) !dbg !4 {
entry:
  %x = alloca i32, align 4
  store i32 %0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  %x1 = load i32, ptr %x, align 4, !dbg !11
  %multmp = mul i32 %x1, 2, !dbg !11
  ret i32 %multmp, !dbg !11
}

define internal i32 @quadruple(i32 %0) !dbg !12 {
entry:
  %x = alloca i32, align 4
  store i32 %0, ptr %x, align 4, !dbg !13
    #dbg_declare(ptr %x, !14, !DIExpression(), !13)
  %x1 = load i32, ptr %x, align 4, !dbg !15
  %1 = call i32 @double(i32 %x1), !dbg !15
  %2 = call i32 @double(i32 %1), !dbg !15
  ret i32 %2, !dbg !15
}

define i32 @main() !dbg !16 {
entry:
  %0 = call i32 @quadruple(i32 3), !dbg !19
  ret i32 %0, !dbg !19
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



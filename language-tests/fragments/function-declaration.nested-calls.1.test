; Module: test.maxon
; Instructions: 16

define i32 @double(i32 %x) {
entry0:
  %0 = alloca i32
  store i32 %x, ptr %0
  %1 = load i32, ptr %0
  %2 = mul i32 %1, 2
  ret i32 %2
}

define i32 @quadruple(i32 %x) {
entry0:
  %0 = alloca i32
  store i32 %x, ptr %0
  %1 = load i32, ptr %0
  %2 = call i32 @double(i32 %1)
  %3 = call i32 @double(i32 %2)
  ret i32 %3
}

define i32 @main() {
entry0:
  %0 = call i32 @quadruple(i32 3)
  ret i32 %0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


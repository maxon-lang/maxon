// Test: grapheme-clusters.is-extended-pictographic.1
function main() returns int
    if isExtendedPictographic(128512) 'c1'
        print("{1}")  // 😀
    end 'c1'
    if isExtendedPictographic(65) 'c2'
        print("{0}")      // 'A'
    end 'c2'
    return 0
end 'main'

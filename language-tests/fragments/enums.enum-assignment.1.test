// Test: enums.enum-assignment.1
enum Color
	case red
	case green
	case blue
end 'Color'

function main() int
	var c = Color.red
	c = Color.blue
	if c == Color.blue 'check'
		return 1
	end 'check'
	return 0
end 'main'


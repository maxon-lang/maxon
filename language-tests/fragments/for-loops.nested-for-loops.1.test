  br i1 %cmptmp, label %then, label %ifcont5, !dbg !20

then:                                             ; preds = %entry
  %struct.ptr1 = load ptr, ptr %it, align 8, !dbg !21
  %current = getelementptr inbounds nuw %Iterator, ptr %struct.ptr1, i32 0, i32 0, !dbg !21

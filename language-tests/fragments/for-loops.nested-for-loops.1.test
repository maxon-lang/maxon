  %struct.ptr3 = load ptr, ptr %it, align 8, !dbg !34
  %limit = getelementptr inbounds nuw %Iterator, ptr %struct.ptr3, i32 0, i32 1, !dbg !34
  %limit.val = load i32, ptr %limit, align 4, !dbg !34

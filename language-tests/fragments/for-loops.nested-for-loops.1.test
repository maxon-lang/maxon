  br i1 %10, label %forloop6, label %afterfor8
forloop6:
  %11 = load i32, ptr %0
  %12 = load i32, ptr %1
  %13 = mul i32 %12, 10
  %14 = add i32 %11, %13
  %15 = load i32, ptr %6
  %16 = add i32 %14, %15
  store i32 %16, ptr %0
  br label %forincrement7
forincrement7:
  %17 = load i32, ptr %6
  %18 = add i32 %17, 1
  store i32 %18, ptr %6
  br label %forcond5
afterfor8:
  br label %forincrement3
}

declare void @exit(i32 %arg0)


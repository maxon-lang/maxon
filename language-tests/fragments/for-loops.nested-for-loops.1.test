%Iterator = type { i32, i32, i32 }

define i32 @main() !dbg !4 {
entry:
  %sum = alloca i32, align 4
  store i32 0, ptr %sum, align 4, !dbg !9
    #dbg_declare(ptr %sum, !10, !DIExpression(), !9)
  %0 = call %Iterator @iter.range(i32 0, i32 3), !dbg !11
  %__iter = alloca %Iterator, align 8, !dbg !11
  store %Iterator %0, ptr %__iter, align 4, !dbg !11
  br label %forcond, !dbg !11

forcond:                                          ; preds = %forincrement13, %entry
  %hasNext.result = call i32 @iter.hasNext(ptr %__iter), !dbg !11
  %forcond1 = icmp eq i32 %hasNext.result, 1, !dbg !11
  br i1 %forcond1, label %forloop, label %afterfor15, !dbg !11

forloop:                                          ; preds = %forcond
  %i = call i32 @iter.getCurrent(ptr %__iter), !dbg !11
  %i2 = alloca i32, align 4, !dbg !11
  store i32 %i, ptr %i2, align 4, !dbg !11
  %1 = call %Iterator @iter.range(i32 0, i32 3), !dbg !12
  %__iter3 = alloca %Iterator, align 8, !dbg !12
  store %Iterator %1, ptr %__iter3, align 4, !dbg !12
  br label %forcond4, !dbg !12

forcond4:                                         ; preds = %forincrement, %forloop
  %hasNext.result5 = call i32 @iter.hasNext(ptr %__iter3), !dbg !12
  %forcond6 = icmp eq i32 %hasNext.result5, 1, !dbg !12
  br i1 %forcond6, label %forloop7, label %afterfor, !dbg !12

forloop7:                                         ; preds = %forcond4
  %j = call i32 @iter.getCurrent(ptr %__iter3), !dbg !12
  %j8 = alloca i32, align 4, !dbg !12
  store i32 %j, ptr %j8, align 4, !dbg !12
  %sum9 = load i32, ptr %sum, align 4, !dbg !13
  %i10 = load i32, ptr %i2, align 4, !dbg !13
  %multmp = mul i32 %i10, 10, !dbg !13
  %addtmp = add i32 %sum9, %multmp, !dbg !13
  %j11 = load i32, ptr %j8, align 4, !dbg !13
  %addtmp12 = add i32 %addtmp, %j11, !dbg !13
  store i32 %addtmp12, ptr %sum, align 4, !dbg !13
  br label %forincrement, !dbg !13

forincrement:                                     ; preds = %forloop7
  %__iter.next = call %Iterator @iter.next(ptr %__iter3), !dbg !13
  store %Iterator %__iter.next, ptr %__iter3, align 4, !dbg !13
  br label %forcond4, !dbg !13

afterfor:                                         ; preds = %forcond4
  br label %forincrement13, !dbg !13

forincrement13:                                   ; preds = %afterfor
  %__iter.next14 = call %Iterator @iter.next(ptr %__iter), !dbg !13
  store %Iterator %__iter.next14, ptr %__iter, align 4, !dbg !13
  br label %forcond, !dbg !13

afterfor15:                                       ; preds = %forcond
  %sum16 = load i32, ptr %sum, align 4, !dbg !14
  ret i32 %sum16, !dbg !14
}

define internal i32 @iter.hasNext(ptr %0) !dbg !15 {
entry:
  %it = alloca ptr, align 8
  store ptr %0, ptr %it, align 8, !dbg !18
    #dbg_declare(ptr %it, !19, !DIExpression(), !18)
  %struct.ptr = load ptr, ptr %it, align 8, !dbg !20

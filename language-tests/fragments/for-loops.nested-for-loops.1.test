  %current.val8 = load i32, ptr %current7, align 4, !dbg !24
  %struct.ptr9 = load ptr, ptr %it, align 8, !dbg !24
  %limit10 = getelementptr inbounds nuw %Iterator, ptr %struct.ptr9, i32 0, i32 1, !dbg !24
  %limit.val11 = load i32, ptr %limit10, align 4, !dbg !24
  %cmptmp12 = icmp sgt i32 %current.val8, %limit.val11, !dbg !24
  br i1 %cmptmp12, label %then13, label %ifcont14, !dbg !24

then13:                                           ; preds = %ifcont5

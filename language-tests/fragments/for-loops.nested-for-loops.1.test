// Test: for-loops.nested-for-loops.1
function main() int
    var sum = 0
    for i in range(0, 3) 'outer'
        for j in range(0, 3) 'inner'
            sum = sum + (i * 10) + j
        end 'inner'
    end 'outer'
    return sum
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 99
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 99)
  unreachable
}


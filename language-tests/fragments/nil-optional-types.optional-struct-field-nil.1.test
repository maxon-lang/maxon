  store i64 3, ptr %7
  %8 = getelementptr %__ManagedStringData, ptr %3, i32 0, i32 2
  store i64 0, ptr %8
  %9 = getelementptr %string, ptr %2, i32 0, i32 0
  store ptr %3, ptr %9
  %10 = getelementptr %string, ptr %2, i32 0, i32 1
  store i64 0, ptr %10
  %11 = load %string, ptr %2
  store %string %11, ptr %1
  %12 = getelementptr %Person, ptr %0, i32 0, i32 1
  %13 = alloca Optional<i64>
  %14 = getelementptr Optional<i64>, ptr %13, i32 0, i32 0
  store i8 0, ptr %14
  %15 = load Optional<i64>, ptr %13
  store Optional<i64> %15, ptr %12
  %16 = getelementptr %Person, ptr %0, i32 0, i32 1
  %17 = load Optional<i64>, ptr %16
  %18 = alloca Optional<i64>
  store Optional<i64> %17, ptr %18
  %19 = getelementptr Optional<i64>, ptr %18, i32 0, i32 0
  %20 = load i8, ptr %19
  %21 = icmp eq i8 %20, 1

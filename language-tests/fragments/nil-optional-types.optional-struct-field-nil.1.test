// Test: nil-optional-types.optional-struct-field-nil.1
struct Person
	var name string
	var age int or nil
end 'Person'

function main() int
	var p = Person{name: "Bob", age: nil}
	if let a = p.age 'check'
		return a
	else 'check'
		return 99
	end 'check'
end 'main'

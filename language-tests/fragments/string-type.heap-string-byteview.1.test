// Test: string-type.heap-string-byteview.1
function main() int
    var s = "ABCDEFGHIJKLMNOPQR"  // 18 bytes, heap allocated
    var count = 0
    for b in s.bytes() 'loop'
        // Use b to avoid unused variable warning
        if b > 0 'use'
            count = count + 1
        end 'use'
    end 'loop'
    print(count)
    return 0
end 'main'

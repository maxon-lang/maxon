// Test: if-statements.if-statements.single-line-else.1
function main() int
    var x = 3
    if x > 5 then return 1
    else return 0
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 3, ptr %0
  %1 = load i32, ptr %0
  %2 = icmp sgt i32 %1, 5
  br i1 %2, label %then1, label %else3
then1:
  ret i32 1
else3:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


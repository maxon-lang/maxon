// Test: file-io.read-nonexistent-file.1
function main() returns int
    var result = readTextFile("nonexistent.txt")
    if let content = result 'hasContent'
        print("Unexpected: {content}")
        return 1
    end 'hasContent'
    print("File not found")
    return 0
end 'main'

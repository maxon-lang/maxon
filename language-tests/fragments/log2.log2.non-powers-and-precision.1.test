// Test: log2.log2.non-powers-and-precision.1
function main() int
    // Non-powers of 2 require high precision
    var r3 = log2(3.0)
    var r5 = log2(5.0)
    var r6 = log2(6.0)
    var r1000000 = log2(1000000.0)
    
    print_float(r3, 15)
    print_float(r5, 15)
    print_float(r6, 10)
    print_float(r1000000, 6)
    
    return 0
end 'main'

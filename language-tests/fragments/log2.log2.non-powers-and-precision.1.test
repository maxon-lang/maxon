define internal double @math.exp(double %0) !dbg !213 {
entry:
  %i = alloca i32, align 4
  %result = alloca double, align 8
  %k_float = alloca double, align 8
  %k = alloca i32, align 4
  %sum = alloca double, align 8
  %term = alloca double, align 8
  %reduction_count = alloca i32, align 4
  %is_negative = alloca i1, align 1
  %x = alloca double, align 8
  store double %0, ptr %x, align 8, !dbg !214
    #dbg_declare(ptr %x, !215, !DIExpression(), !214)
  %x1 = load double, ptr %x, align 8, !dbg !216
  %fcmptmp = fcmp oeq double %x1, 0.000000e+00, !dbg !216
  br i1 %fcmptmp, label %then, label %ifcont, !dbg !216

then:                                             ; preds = %entry
  ret double 1.000000e+00, !dbg !217

ifcont:                                           ; preds = %entry
  %x2 = load double, ptr %x, align 8, !dbg !218
  %fcmptmp3 = fcmp olt double %x2, 0.000000e+00, !dbg !218
  store i1 %fcmptmp3, ptr %is_negative, align 1, !dbg !218
    #dbg_declare(ptr %is_negative, !219, !DIExpression(), !218)
  %is_negative4 = load i1, ptr %is_negative, align 1, !dbg !220
  br i1 %is_negative4, label %then5, label %ifcont7, !dbg !220

then5:                                            ; preds = %ifcont
  %x6 = load double, ptr %x, align 8, !dbg !221
  %fnegtmp = fneg double %x6, !dbg !221
  store double %fnegtmp, ptr %x, align 8, !dbg !221
  br label %ifcont7, !dbg !221

ifcont7:                                          ; preds = %then5, %ifcont
  store i32 0, ptr %reduction_count, align 4, !dbg !222
    #dbg_declare(ptr %reduction_count, !223, !DIExpression(), !222)
  br label %whilecond, !dbg !224

whilecond:                                        ; preds = %loop, %ifcont7
  %x8 = load double, ptr %x, align 8, !dbg !224
  %fcmptmp9 = fcmp ogt double %x8, 1.000000e+00, !dbg !224
  br i1 %fcmptmp9, label %loop, label %afterloop, !dbg !224

loop:                                             ; preds = %whilecond
  %x10 = load double, ptr %x, align 8, !dbg !225
  %fdivtmp = fdiv double %x10, 2.000000e+00, !dbg !225
  store double %fdivtmp, ptr %x, align 8, !dbg !225
  %reduction_count11 = load i32, ptr %reduction_count, align 4, !dbg !226
  %addtmp = add i32 %reduction_count11, 1, !dbg !226
  store i32 %addtmp, ptr %reduction_count, align 4, !dbg !226
  br label %whilecond, !dbg !226

afterloop:                                        ; preds = %whilecond
  store double 1.000000e+00, ptr %term, align 8, !dbg !227
    #dbg_declare(ptr %term, !228, !DIExpression(), !227)
  store double 1.000000e+00, ptr %sum, align 8, !dbg !229
    #dbg_declare(ptr %sum, !230, !DIExpression(), !229)
  store i32 1, ptr %k, align 4, !dbg !231
    #dbg_declare(ptr %k, !232, !DIExpression(), !231)
  br label %whilecond12, !dbg !233

whilecond12:                                      ; preds = %loop14, %afterloop
  %k13 = load i32, ptr %k, align 4, !dbg !233
  %cmptmp = icmp slt i32 %k13, 20, !dbg !233
  br i1 %cmptmp, label %loop14, label %afterloop25, !dbg !233

loop14:                                           ; preds = %whilecond12
  %term15 = load double, ptr %term, align 8, !dbg !234
  %x16 = load double, ptr %x, align 8, !dbg !234
  %fmultmp = fmul double %term15, %x16, !dbg !234
  store double %fmultmp, ptr %term, align 8, !dbg !234
  %k17 = load i32, ptr %k, align 4, !dbg !235
  %int2floattmp = sitofp i32 %k17 to double, !dbg !235
  store double %int2floattmp, ptr %k_float, align 8, !dbg !235
    #dbg_declare(ptr %k_float, !236, !DIExpression(), !235)
  %term18 = load double, ptr %term, align 8, !dbg !237
  %k_float19 = load double, ptr %k_float, align 8, !dbg !237
  %fdivtmp20 = fdiv double %term18, %k_float19, !dbg !237
  store double %fdivtmp20, ptr %term, align 8, !dbg !237
  %sum21 = load double, ptr %sum, align 8, !dbg !238
  %term22 = load double, ptr %term, align 8, !dbg !238
  %faddtmp = fadd double %sum21, %term22, !dbg !238
  store double %faddtmp, ptr %sum, align 8, !dbg !238
  %k23 = load i32, ptr %k, align 4, !dbg !239
  %addtmp24 = add i32 %k23, 1, !dbg !239
  store i32 %addtmp24, ptr %k, align 4, !dbg !239
  br label %whilecond12, !dbg !239

afterloop25:                                      ; preds = %whilecond12
  %sum26 = load double, ptr %sum, align 8, !dbg !240
  store double %sum26, ptr %result, align 8, !dbg !240
    #dbg_declare(ptr %result, !241, !DIExpression(), !240)
  store i32 0, ptr %i, align 4, !dbg !242
    #dbg_declare(ptr %i, !243, !DIExpression(), !242)
  br label %whilecond27, !dbg !244

whilecond27:                                      ; preds = %loop31, %afterloop25
  %i28 = load i32, ptr %i, align 4, !dbg !244
  %reduction_count29 = load i32, ptr %reduction_count, align 4, !dbg !244
  %cmptmp30 = icmp slt i32 %i28, %reduction_count29, !dbg !244
  br i1 %cmptmp30, label %loop31, label %afterloop37, !dbg !244

loop31:                                           ; preds = %whilecond27
  %result32 = load double, ptr %result, align 8, !dbg !245
  %result33 = load double, ptr %result, align 8, !dbg !245
  %fmultmp34 = fmul double %result32, %result33, !dbg !245
  store double %fmultmp34, ptr %result, align 8, !dbg !245
  %i35 = load i32, ptr %i, align 4, !dbg !246
  %addtmp36 = add i32 %i35, 1, !dbg !246
  store i32 %addtmp36, ptr %i, align 4, !dbg !246
  br label %whilecond27, !dbg !246

afterloop37:                                      ; preds = %whilecond27
  %is_negative38 = load i1, ptr %is_negative, align 1, !dbg !247
  br i1 %is_negative38, label %then39, label %ifcont42, !dbg !247

then39:                                           ; preds = %afterloop37
  %result40 = load double, ptr %result, align 8, !dbg !248
  %fdivtmp41 = fdiv double 1.000000e+00, %result40, !dbg !248
  store double %fdivtmp41, ptr %result, align 8, !dbg !248
  br label %ifcont42, !dbg !248

ifcont42:                                         ; preds = %then39, %afterloop37
  %result43 = load double, ptr %result, align 8, !dbg !249
  ret double %result43, !dbg !249
}

declare i32 @write_stdout(ptr, i32)

declare ptr @malloc(i64)

declare void @free(ptr)

declare ptr @memset(ptr, i32, i64)

declare double @llvm.floor.f64(double)

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



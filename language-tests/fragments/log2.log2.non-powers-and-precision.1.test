entry:
  %0 = tail call fastcc double @math.log(double 3.000000e+00)
  %fdivtmp.i = fdiv double %0, 0x3FE62E42FEFA39EF
  %1 = tail call fastcc double @math.log(double 5.000000e+00)
  %fdivtmp.i5 = fdiv double %1, 0x3FE62E42FEFA39EF
  %2 = tail call fastcc double @math.log(double 6.000000e+00)
  %fdivtmp.i6 = fdiv double %2, 0x3FE62E42FEFA39EF
  %3 = tail call fastcc double @math.log(double 1.000000e+06)
  %fdivtmp.i7 = fdiv double %3, 0x3FE62E42FEFA39EF
  tail call fastcc void @sys.print_float(double %fdivtmp.i, i32 15)
  tail call fastcc void @sys.print_float(double %fdivtmp.i5, i32 15)
  tail call fastcc void @sys.print_float(double %fdivtmp.i6, i32 10)
  tail call fastcc void @sys.print_float(double %fdivtmp.i7, i32 6)
  ret i32 0
}


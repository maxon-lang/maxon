// Test: string-type.heap-string-data-access.1
function main() int
    // Verify heap-allocated string data is accessible via bytes()
    var s = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    var bytes = s.bytes()
    // Read first byte ('A' = 65)
    var first = bytes.getCurrent()
    print_int(first)
    // Skip 24 bytes to get to 'Z' (advance to position 25)
    var i = 0
    while i < 25 'skip'
        bytes = bytes.next()
        i = i + 1
    end 'skip'
    // Read last byte ('Z' = 90)
    var last = bytes.getCurrent()
    print_int(last)
    return 0
end 'main'

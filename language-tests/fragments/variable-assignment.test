function main() int
    var x = 3
    x = x + 2
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  %x = alloca i32, align 4
  store i32 3, ptr %x, align 4
  %x1 = load i32, ptr %x, align 4
  %addtmp = add i32 %x1, 2
  store i32 %addtmp, ptr %x, align 4
  %x2 = load i32, ptr %x, align 4
  ret i32 %x2
}
---
ExitCode: 5

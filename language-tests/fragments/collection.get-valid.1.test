// Test: collection.get-valid.1
function main() int
    var arr = [10, 20, 30]
    var sum = 0
    if let val = arr.get(0) 'get0'
        sum = sum + val
    end 'get0'
    if let val = arr.get(2) 'get2'
        sum = sum + val
    end 'get2'
    return sum
end 'main'

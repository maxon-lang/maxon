// Test: arithmetic-operators.division-returns-float.1
function main() returns int
    var result = 20 / 3      // 6.666...
    return trunc(result * 10.0)  // 66.666... * 10 = 66.666..., trunc = 66
end 'main'
---
; Module: test.maxon
; Instructions: 10

define i64 @main() {
entry0:
  %0 = sitofp i64 20 to f64
  %1 = sitofp i64 3 to f64
  %2 = fdiv f64 %0, %1
  %5 = fmul f64 %2, 10
  %6 = call f64 @trunc(f64 %5)
  %7 = fptosi f64 %6 to i64
  ret i64 %7
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


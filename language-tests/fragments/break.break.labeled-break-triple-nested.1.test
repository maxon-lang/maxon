// Test: break.break.labeled-break-triple-nested.1
function main() int
    var result = 0
    while true 'outer'
        while true 'middle'
            while true 'inner'
                result = result + 1
                if result = 5 'check'
                    break 'outer'
                end 'check'
            end 'inner'
        end 'middle'
    end 'outer'
    return result
end 'main'

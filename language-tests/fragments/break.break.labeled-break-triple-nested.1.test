// Test: break.break.labeled-break-triple-nested.1
function main() int
    var result = 0
    while true 'outer'
        while true 'middle'
            while true 'inner'
                result = result + 1
                if result = 5 'check'
                    break 'outer'
                end 'check'
            end 'inner'
        end 'middle'
    end 'outer'
    return result
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 5
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 5)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %result = alloca i32, align 4
  store i32 0, ptr %result, align 4, !dbg !9
    #dbg_declare(ptr %result, !10, !DIExpression(), !9)
  br label %whilecond, !dbg !11

whilecond:                                        ; preds = %afterloop7, %entry
  br i1 true, label %loop, label %afterloop8, !dbg !11

loop:                                             ; preds = %whilecond
  br label %whilecond1, !dbg !12

whilecond1:                                       ; preds = %afterloop, %loop
  br i1 true, label %loop2, label %afterloop7, !dbg !12

loop2:                                            ; preds = %whilecond1
  br label %whilecond3, !dbg !13

whilecond3:                                       ; preds = %ifcont, %loop2
  br i1 true, label %loop4, label %afterloop, !dbg !13

loop4:                                            ; preds = %whilecond3
  %result5 = load i32, ptr %result, align 4, !dbg !14
  %addtmp = add i32 %result5, 1, !dbg !14
  store i32 %addtmp, ptr %result, align 4, !dbg !14
  %result6 = load i32, ptr %result, align 4, !dbg !15
  %cmptmp = icmp eq i32 %result6, 5, !dbg !15
  br i1 %cmptmp, label %then, label %ifcont, !dbg !15

then:                                             ; preds = %loop4
  br label %afterloop8, !dbg !16

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !16

ifcont:                                           ; preds = %afterbreak, %loop4
  br label %whilecond3, !dbg !16

afterloop:                                        ; preds = %whilecond3
  br label %whilecond1, !dbg !16

afterloop7:                                       ; preds = %whilecond1
  br label %whilecond, !dbg !16

afterloop8:                                       ; preds = %then, %whilecond
  %result9 = load i32, ptr %result, align 4, !dbg !17
  ret i32 %result9, !dbg !17
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 2, type: !5, scopeLine: 2, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 3, column: 5, scope: !4)
!10 = !DILocalVariable(name: "result", scope: !4, file: !1, line: 3, type: !7, align: 32)
!11 = !DILocation(line: 4, column: 5, scope: !4)
!12 = !DILocation(line: 5, column: 9, scope: !4)
!13 = !DILocation(line: 6, column: 13, scope: !4)
!14 = !DILocation(line: 7, column: 24, scope: !4)
!15 = !DILocation(line: 8, column: 17, scope: !4)
!16 = !DILocation(line: 9, column: 21, scope: !4)
!17 = !DILocation(line: 14, column: 5, scope: !4)

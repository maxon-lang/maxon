// Test: top-level-let.cast-in-constant.1
let OFFSET = 10
let SCALED = OFFSET * 3

function main() returns int
    return SCALED
end 'main'
---
; Module: test.maxon
; Instructions: 5

@SCALED = constant i32 zeroinitializer

define i32 @main() {
entry0:
  %0 = load i32, ptr @SCALED
  ret i32 %0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


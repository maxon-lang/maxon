// Test: arithmetic-operators.trunc-division-optimizes.1
function main() int
    return trunc(20 / 3)     // Optimized to sdiv, returns 6
end 'main'
---
; Module: test.maxon
; Instructions: 9

define i32 @main() {
entry0:
  %0 = sitofp i32 20 to f64
  %1 = sitofp i32 3 to f64
  %2 = fdiv f64 %0, %1
  %3 = call f64 @trunc(f64 %2)
  %4 = fptosi f64 %3 to i32
  ret i32 %4
}

declare f64 @trunc(f64 %arg0)

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


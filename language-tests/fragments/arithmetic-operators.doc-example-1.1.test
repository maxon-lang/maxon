  %divtmp.i = udiv i32 %abs_value.164.i.frozen, 10
  %3 = mul i32 %divtmp.i, 10
  %modtmp.i.decomposed = sub i32 %abs_value.164.i.frozen, %3
  %4 = sext i32 %pos.063.i to i64
  %arrayidx14.i = getelementptr inbounds i8, ptr %temp.malloc.i, i64 %4
  %5 = trunc nuw nsw i32 %modtmp.i.decomposed to i8
  %trunctmp.i = or disjoint i8 %5, 48
  store i8 %trunctmp.i, ptr %arrayidx14.i, align 1
  %subtmp17.i = add i32 %pos.063.i, -1
  %cmptmp9.not.i = icmp samesign ult i32 %abs_value.164.i, 10
  %indvar.next = add i32 %indvar, 1
  br i1 %cmptmp9.not.i, label %ifcont27.i, label %loop.i

ifcont27.i:                                       ; preds = %loop.i
  %subtmp31.i = sub i32 12, %pos.063.i
  %cmptmp3565.i = icmp sgt i32 %subtmp31.i, 0
  br i1 %cmptmp3565.i, label %loop36.i.preheader, label %fmt.format_int_array.exit

loop36.i.preheader:                               ; preds = %ifcont27.i
  %min.iters.check = icmp ult i32 %subtmp31.i, 4
  %6 = add i32 %pos.063.i, %indvar
  %7 = icmp slt i32 %6, %pos.063.i
  %or.cond = select i1 %min.iters.check, i1 true, i1 %7
  br i1 %or.cond, label %loop36.i.preheader2, label %vector.ph

vector.ph:                                        ; preds = %loop36.i.preheader
  %n.vec = and i32 %subtmp31.i, 2147483644
  br label %vector.body

vector.body:                                      ; preds = %vector.body, %vector.ph
  %index = phi i32 [ 0, %vector.ph ], [ %index.next, %vector.body ]
  %8 = zext nneg i32 %index to i64
  %9 = getelementptr inbounds nuw i8, ptr %buffer.malloc, i64 %8
  %10 = add i32 %index, %pos.063.i
  %11 = sext i32 %10 to i64

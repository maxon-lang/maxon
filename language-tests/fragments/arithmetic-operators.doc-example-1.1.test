// Test: arithmetic-operators.doc-example-1.1
function main() int
    var a = 10
    var b = 3
    var sum = a + b      // 13
    var diff = a - b     // 7
    var prod = a * b     // 30
    var quot = a / b     // 3
    var rem = a % b      // 1
    
    // Use the values
    print(sum)
    print(diff)
    print(prod)
    print(quot)
    print(rem)
    
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  tail call fastcc void @sys.print(i32 13)
  tail call fastcc void @sys.print(i32 7)
  tail call fastcc void @sys.print(i32 30)
  tail call fastcc void @sys.print(i32 3)
  tail call fastcc void @sys.print(i32 1)
  ret i32 0
}


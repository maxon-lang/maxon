  %term29 = load double, ptr %term, align 8, !dbg !140
  %z_squared30 = load double, ptr %z_squared, align 8, !dbg !140
  %fmultmp31 = fmul double %term29, %z_squared30, !dbg !140
  store double %fmultmp31, ptr %term, align 8, !dbg !140
  %k32 = load i32, ptr %k, align 4, !dbg !141
  %multmp = mul i32 2, %k32, !dbg !141
  %addtmp33 = add i32 %multmp, 1, !dbg !141
  store i32 %addtmp33, ptr %divisor, align 4, !dbg !141
    #dbg_declare(ptr %divisor, !142, !DIExpression(), !141)
  %divisor34 = load i32, ptr %divisor, align 4, !dbg !143
  %int2floattmp = sitofp i32 %divisor34 to double, !dbg !143
  store double %int2floattmp, ptr %divisor_float, align 8, !dbg !143
    #dbg_declare(ptr %divisor_float, !144, !DIExpression(), !143)
  %sum35 = load double, ptr %sum, align 8, !dbg !145
  %term36 = load double, ptr %term, align 8, !dbg !145
  %divisor_float37 = load double, ptr %divisor_float, align 8, !dbg !145
  %fdivtmp38 = fdiv double %term36, %divisor_float37, !dbg !145
  %faddtmp39 = fadd double %sum35, %fdivtmp38, !dbg !145
  store double %faddtmp39, ptr %sum, align 8, !dbg !145
  %k40 = load i32, ptr %k, align 4, !dbg !146
  %addtmp41 = add i32 %k40, 1, !dbg !146
  store i32 %addtmp41, ptr %k, align 4, !dbg !146
  br label %whilecond26, !dbg !146

afterloop42:                                      ; preds = %whilecond26
  %sum43 = load double, ptr %sum, align 8, !dbg !147
  %fmultmp44 = fmul double 2.000000e+00, %sum43, !dbg !147
  store double %fmultmp44, ptr %result, align 8, !dbg !147
    #dbg_declare(ptr %result, !148, !DIExpression(), !147)
  store double 0x3FE62E42FEFA39EC, ptr %log2, align 8, !dbg !149
    #dbg_declare(ptr %log2, !150, !DIExpression(), !149)
  %n45 = load i32, ptr %n, align 4, !dbg !151
  %int2floattmp46 = sitofp i32 %n45 to double, !dbg !151
  store double %int2floattmp46, ptr %n_float, align 8, !dbg !151
    #dbg_declare(ptr %n_float, !152, !DIExpression(), !151)
  %result47 = load double, ptr %result, align 8, !dbg !153
  %n_float48 = load double, ptr %n_float, align 8, !dbg !153
  %log249 = load double, ptr %log2, align 8, !dbg !153
  %fmultmp50 = fmul double %n_float48, %log249, !dbg !153
  %faddtmp51 = fadd double %result47, %fmultmp50, !dbg !153
  store double %faddtmp51, ptr %result, align 8, !dbg !153
  %result52 = load double, ptr %result, align 8, !dbg !154
  ret double %result52, !dbg !154
}

declare ptr @memset(ptr, i32, i64)

declare ptr @GetStdHandle(i32)

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr)

define i32 @print(i32 %0) #0 {
entry:
  %buffer = alloca [12 x i8], align 1, !dbg !11
  %temp = alloca [12 x i8], align 1, !dbg !11
  %bytesWritten = alloca i32, align 4, !dbg !11
  %1 = call ptr @memset(ptr %buffer, i32 0, i64 12), !dbg !11
  %2 = call ptr @memset(ptr %temp, i32 0, i64 12), !dbg !11
  %3 = icmp eq i32 %0, 0, !dbg !11
  br i1 %3, label %zero_case, label %non_zero, !dbg !11

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !11
  store i8 48, ptr %4, align 1, !dbg !11
  br label %format_done, !dbg !11

non_zero:                                         ; preds = %entry
  %5 = icmp slt i32 %0, 0, !dbg !11
  br i1 %5, label %negative, label %positive, !dbg !11

format_done:                                      ; preds = %reverse_loop, %zero_case
  %final_offset = phi i32 [ 0, %zero_case ], [ %offset_in_reverse, %reverse_loop ], !dbg !11
  %final_digit_count = phi i32 [ 1, %zero_case ], [ %digit_count_in_reverse, %reverse_loop ], !dbg !11
  %6 = add i32 %final_offset, %final_digit_count, !dbg !11
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !11
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %6, ptr %bytesWritten, ptr null), !dbg !11
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !11
  ret i32 0, !dbg !11

negative:                                         ; preds = %non_zero
  %10 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 0, !dbg !11
  store i8 45, ptr %10, align 1, !dbg !11
  %11 = sub i32 0, %0, !dbg !11
  br label %extract_digits, !dbg !11

positive:                                         ; preds = %non_zero
  br label %extract_digits, !dbg !11

extract_digits:                                   ; preds = %positive, %negative
  %value_abs = phi i32 [ %11, %negative ], [ %0, %positive ], !dbg !11
  %start_offset = phi i32 [ 1, %negative ], [ 0, %positive ], !dbg !11
  br label %digit_loop, !dbg !11

digit_loop:                                       ; preds = %digit_loop_body, %extract_digits
  %remaining = phi i32 [ %value_abs, %extract_digits ], [ %17, %digit_loop_body ], !dbg !11
  %temp_idx = phi i32 [ 0, %extract_digits ], [ %18, %digit_loop_body ], !dbg !11
  %12 = icmp ne i32 %remaining, 0, !dbg !11
  br i1 %12, label %digit_loop_body, label %reverse_loop, !dbg !11

digit_loop_body:                                  ; preds = %digit_loop
  %13 = srem i32 %remaining, 10, !dbg !11
  %14 = add i32 %13, 48, !dbg !11
  %15 = trunc i32 %14 to i8, !dbg !11
  %16 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %temp_idx, !dbg !11
  store i8 %15, ptr %16, align 1, !dbg !11
  %17 = sdiv i32 %remaining, 10, !dbg !11
  %18 = add i32 %temp_idx, 1, !dbg !11
  br label %digit_loop, !dbg !11

reverse_loop:                                     ; preds = %reverse_body, %digit_loop
  %reverse_idx = phi i32 [ 0, %digit_loop ], [ %26, %reverse_body ], !dbg !11
  %offset_in_reverse = phi i32 [ %start_offset, %digit_loop ], [ %offset_in_reverse, %reverse_body ], !dbg !11
  %digit_count_in_reverse = phi i32 [ %temp_idx, %digit_loop ], [ %digit_count_in_reverse, %reverse_body ], !dbg !11
  %19 = icmp slt i32 %reverse_idx, %digit_count_in_reverse, !dbg !11
  br i1 %19, label %reverse_body, label %format_done, !dbg !11

reverse_body:                                     ; preds = %reverse_loop
  %20 = sub i32 %digit_count_in_reverse, %reverse_idx, !dbg !11
  %21 = sub i32 %20, 1, !dbg !11
  %22 = getelementptr inbounds [12 x i8], ptr %temp, i32 0, i32 %21, !dbg !11
  %23 = load i8, ptr %22, align 1, !dbg !11
  %24 = add i32 %offset_in_reverse, %reverse_idx, !dbg !11
  %25 = getelementptr inbounds [12 x i8], ptr %buffer, i32 0, i32 %24, !dbg !11
  store i8 %23, ptr %25, align 1, !dbg !11
  %26 = add i32 %reverse_idx, 1, !dbg !11
  br label %reverse_loop, !dbg !11
}

define i32 @print_float(double %0, i32 %1) #0 {
entry:
  %buffer = alloca [32 x i8], align 1, !dbg !11
  %bytesWritten = alloca i32, align 4, !dbg !11
  %2 = call ptr @memset(ptr %buffer, i32 0, i64 32), !dbg !11
  %3 = fcmp oeq double %0, 0.000000e+00, !dbg !11
  br i1 %3, label %zero_case, label %non_zero, !dbg !11

zero_case:                                        ; preds = %entry
  %4 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !11
  store i8 48, ptr %4, align 1, !dbg !11
  %5 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 1, !dbg !11
  store i8 46, ptr %5, align 1, !dbg !11
  br label %zero_fill_loop, !dbg !11

non_zero:                                         ; preds = %entry
  %pos = alloca i32, align 4, !dbg !11
  store i32 0, ptr %pos, align 4, !dbg !11
  %6 = fcmp olt double %0, 0.000000e+00, !dbg !11
  br i1 %6, label %negative, label %positive, !dbg !11

format_done:                                      ; preds = %frac_digits_done, %zero_fill_done
  %final_float_length = phi i32 [ %14, %zero_fill_done ], [ %80, %frac_digits_done ], !dbg !11
  %7 = call ptr @GetStdHandle(i32 -11), !dbg !11
  %8 = call i32 @WriteFile(ptr %7, ptr %buffer, i32 %final_float_length, ptr %bytesWritten, ptr null), !dbg !11
  %9 = call i32 @WriteFile(ptr %7, ptr @.str.newline, i32 1, ptr %bytesWritten, ptr null), !dbg !11
  ret i32 0, !dbg !11

zero_fill_loop:                                   ; preds = %zero_fill_body, %zero_case
  %zero_fill_idx = phi i32 [ 0, %zero_case ], [ %13, %zero_fill_body ], !dbg !11
  %10 = icmp slt i32 %zero_fill_idx, %1, !dbg !11
  br i1 %10, label %zero_fill_body, label %zero_fill_done, !dbg !11

zero_fill_body:                                   ; preds = %zero_fill_loop
  %11 = add i32 2, %zero_fill_idx, !dbg !11
  %12 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %11, !dbg !11
  store i8 48, ptr %12, align 1, !dbg !11
  %13 = add i32 %zero_fill_idx, 1, !dbg !11
  br label %zero_fill_loop, !dbg !11

zero_fill_done:                                   ; preds = %zero_fill_loop
  %14 = add i32 2, %1, !dbg !11
  br label %format_done, !dbg !11

negative:                                         ; preds = %non_zero
  %15 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 0, !dbg !11
  store i8 45, ptr %15, align 1, !dbg !11
  store i32 1, ptr %pos, align 4, !dbg !11
  %16 = fneg double %0, !dbg !11
  br label %extract_int, !dbg !11

positive:                                         ; preds = %non_zero
  br label %extract_int, !dbg !11

extract_int:                                      ; preds = %positive, %negative
  %work_value = phi double [ %16, %negative ], [ %0, %positive ], !dbg !11
  %int_part = fptosi double %work_value to i32, !dbg !11
  %int_part_float = sitofp i32 %int_part to double, !dbg !11
  %float_temp = alloca [20 x i8], align 1, !dbg !11
  %17 = call ptr @memset(ptr %float_temp, i32 0, i64 20), !dbg !11
  %float_temp_idx = alloca i32, align 4, !dbg !11
  store i32 19, ptr %float_temp_idx, align 4, !dbg !11
  %18 = icmp eq i32 %int_part, 0, !dbg !11
  br i1 %18, label %int_zero, label %int_nonzero, !dbg !11

int_zero:                                         ; preds = %extract_int
  %19 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 19, !dbg !11
  store i8 48, ptr %19, align 1, !dbg !11
  store i32 18, ptr %float_temp_idx, align 4, !dbg !11
  br label %int_digits_done, !dbg !11

int_nonzero:                                      ; preds = %extract_int
  br label %int_digit_loop, !dbg !11

int_digits_done:                                  ; preds = %int_digit_loop, %int_zero
  %final_temp_idx = phi i32 [ %current_temp_idx, %int_digit_loop ], [ 18, %int_zero ], !dbg !11
  %20 = add i32 %final_temp_idx, 1, !dbg !11
  %21 = sub i32 20, %20, !dbg !11
  br label %copy_int_loop, !dbg !11

int_digit_loop:                                   ; preds = %int_digit_body, %int_nonzero
  %remaining_int = phi i32 [ %int_part, %int_nonzero ], [ %27, %int_digit_body ], !dbg !11
  %current_temp_idx = phi i32 [ 19, %int_nonzero ], [ %28, %int_digit_body ], !dbg !11
  %22 = icmp ne i32 %remaining_int, 0, !dbg !11
  br i1 %22, label %int_digit_body, label %int_digits_done, !dbg !11

int_digit_body:                                   ; preds = %int_digit_loop
  %23 = srem i32 %remaining_int, 10, !dbg !11
  %24 = add i32 %23, 48, !dbg !11
  %25 = trunc i32 %24 to i8, !dbg !11
  %26 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %current_temp_idx, !dbg !11
  store i8 %25, ptr %26, align 1, !dbg !11
  %27 = sdiv i32 %remaining_int, 10, !dbg !11
  %28 = sub i32 %current_temp_idx, 1, !dbg !11
  br label %int_digit_loop, !dbg !11

copy_int_loop:                                    ; preds = %copy_int_body, %int_digits_done
  %copy_idx = phi i32 [ 0, %int_digits_done ], [ %35, %copy_int_body ], !dbg !11
  %29 = icmp slt i32 %copy_idx, %21, !dbg !11
  br i1 %29, label %copy_int_body, label %copy_int_done, !dbg !11

copy_int_body:                                    ; preds = %copy_int_loop
  %current_pos = load i32, ptr %pos, align 4, !dbg !11
  %30 = add i32 %20, %copy_idx, !dbg !11
  %31 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %30, !dbg !11
  %32 = load i8, ptr %31, align 1, !dbg !11
  %33 = add i32 %current_pos, %copy_idx, !dbg !11
  %34 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %33, !dbg !11
  store i8 %32, ptr %34, align 1, !dbg !11
  %35 = add i32 %copy_idx, 1, !dbg !11
  br label %copy_int_loop, !dbg !11

copy_int_done:                                    ; preds = %copy_int_loop
  %pos_after_int = load i32, ptr %pos, align 4, !dbg !11
  %36 = add i32 %pos_after_int, %21, !dbg !11
  store i32 %36, ptr %pos, align 4, !dbg !11
  %37 = load i32, ptr %pos, align 4, !dbg !11
  %38 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %37, !dbg !11
  store i8 46, ptr %38, align 1, !dbg !11
  %39 = add i32 %37, 1, !dbg !11
  store i32 %39, ptr %pos, align 4, !dbg !11
  %frac_part = fsub double %work_value, %int_part_float, !dbg !11
  br label %scale_loop, !dbg !11

scale_loop:                                       ; preds = %scale_body, %copy_int_done
  %scale_idx = phi i32 [ 0, %copy_int_done ], [ %41, %scale_body ], !dbg !11
  %scale_accum = phi double [ 1.000000e+00, %copy_int_done ], [ %next_scale, %scale_body ], !dbg !11
  %40 = icmp slt i32 %scale_idx, %1, !dbg !11
  br i1 %40, label %scale_body, label %scale_done, !dbg !11

scale_body:                                       ; preds = %scale_loop
  %next_scale = fmul double %scale_accum, 1.000000e+01, !dbg !11
  %41 = add i32 %scale_idx, 1, !dbg !11
  br label %scale_loop, !dbg !11

scale_done:                                       ; preds = %scale_loop
  %frac_scaled = fmul double %frac_part, %scale_accum, !dbg !11
  %frac_rounded = fadd double %frac_scaled, 5.000000e-01, !dbg !11
  %frac_int = fptosi double %frac_rounded to i64, !dbg !11
  br label %frac_overflow_check, !dbg !11

frac_overflow_check:                              ; preds = %scale_done
  %42 = fptosi double %scale_accum to i64, !dbg !11
  %43 = icmp sge i64 %frac_int, %42, !dbg !11
  br i1 %43, label %frac_overflow, label %frac_no_overflow, !dbg !11

frac_overflow:                                    ; preds = %frac_overflow_check
  %44 = add i32 %int_part, 1, !dbg !11
  %45 = load i32, ptr %pos, align 4, !dbg !11
  %46 = icmp eq i32 %45, 1, !dbg !11
  %47 = select i1 %46, i32 1, i32 0, !dbg !11
  %48 = call ptr @memset(ptr %float_temp, i32 0, i64 20), !dbg !11
  store i32 19, ptr %float_temp_idx, align 4, !dbg !11
  br label %overflow_int_loop, !dbg !11

frac_no_overflow:                                 ; preds = %overflow_copy_done, %frac_overflow_check
  %final_frac_int = phi i64 [ 0, %overflow_copy_done ], [ %frac_int, %frac_overflow_check ], !dbg !11
  %49 = sub i32 %1, 1, !dbg !11
  br label %frac_digit_loop, !dbg !11

overflow_int_loop:                                ; preds = %overflow_int_body, %frac_overflow
  %overflow_remaining = phi i32 [ %44, %frac_overflow ], [ %55, %overflow_int_body ], !dbg !11
  %overflow_temp_idx = phi i32 [ 19, %frac_overflow ], [ %56, %overflow_int_body ], !dbg !11
  %50 = icmp ne i32 %overflow_remaining, 0, !dbg !11
  br i1 %50, label %overflow_int_body, label %overflow_int_done, !dbg !11

overflow_int_body:                                ; preds = %overflow_int_loop
  %51 = srem i32 %overflow_remaining, 10, !dbg !11
  %52 = add i32 %51, 48, !dbg !11
  %53 = trunc i32 %52 to i8, !dbg !11
  %54 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %overflow_temp_idx, !dbg !11
  store i8 %53, ptr %54, align 1, !dbg !11
  %55 = sdiv i32 %overflow_remaining, 10, !dbg !11
  %56 = sub i32 %overflow_temp_idx, 1, !dbg !11
  br label %overflow_int_loop, !dbg !11

overflow_int_done:                                ; preds = %overflow_int_loop
  %57 = add i32 %overflow_temp_idx, 1, !dbg !11
  %58 = sub i32 20, %57, !dbg !11
  br label %overflow_copy_loop, !dbg !11

overflow_copy_loop:                               ; preds = %overflow_copy_body, %overflow_int_done
  %overflow_copy_idx = phi i32 [ 0, %overflow_int_done ], [ %65, %overflow_copy_body ], !dbg !11
  %59 = icmp slt i32 %overflow_copy_idx, %58, !dbg !11
  br i1 %59, label %overflow_copy_body, label %overflow_copy_done, !dbg !11

overflow_copy_body:                               ; preds = %overflow_copy_loop
  %60 = add i32 %57, %overflow_copy_idx, !dbg !11
  %61 = getelementptr inbounds [20 x i8], ptr %float_temp, i32 0, i32 %60, !dbg !11
  %62 = load i8, ptr %61, align 1, !dbg !11
  %63 = add i32 %47, %overflow_copy_idx, !dbg !11
  %64 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %63, !dbg !11
  store i8 %62, ptr %64, align 1, !dbg !11
  %65 = add i32 %overflow_copy_idx, 1, !dbg !11
  br label %overflow_copy_loop, !dbg !11

overflow_copy_done:                               ; preds = %overflow_copy_loop
  %66 = add i32 %47, %58, !dbg !11
  store i32 %66, ptr %pos, align 4, !dbg !11
  %67 = load i32, ptr %pos, align 4, !dbg !11
  %68 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %67, !dbg !11
  store i8 46, ptr %68, align 1, !dbg !11
  %69 = add i32 %67, 1, !dbg !11
  store i32 %69, ptr %pos, align 4, !dbg !11
  br label %frac_no_overflow, !dbg !11

frac_digit_loop:                                  ; preds = %frac_digit_body, %frac_no_overflow
  %frac_idx = phi i32 [ %49, %frac_no_overflow ], [ %78, %frac_digit_body ], !dbg !11
  %frac_remaining = phi i64 [ %final_frac_int, %frac_no_overflow ], [ %77, %frac_digit_body ], !dbg !11
  %70 = icmp sge i32 %frac_idx, 0, !dbg !11
  br i1 %70, label %frac_digit_body, label %frac_digits_done, !dbg !11

frac_digit_body:                                  ; preds = %frac_digit_loop
  %71 = srem i64 %frac_remaining, 10, !dbg !11
  %72 = add i64 %71, 48, !dbg !11
  %73 = trunc i64 %72 to i8, !dbg !11
  %74 = load i32, ptr %pos, align 4, !dbg !11
  %75 = add i32 %74, %frac_idx, !dbg !11
  %76 = getelementptr inbounds [32 x i8], ptr %buffer, i32 0, i32 %75, !dbg !11
  store i8 %73, ptr %76, align 1, !dbg !11
  %77 = sdiv i64 %frac_remaining, 10, !dbg !11
  %78 = sub i32 %frac_idx, 1, !dbg !11
  br label %frac_digit_loop, !dbg !11

frac_digits_done:                                 ; preds = %frac_digit_loop
  %79 = load i32, ptr %pos, align 4, !dbg !11
  %80 = add i32 %79, %1, !dbg !11
  br label %format_done, !dbg !11
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}


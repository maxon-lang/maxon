// Test: break.break.labeled-break-inner.1
function main() int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  br label %whilecond1
whilecond1:
  %2 = load i32, ptr %0
  %3 = icmp slt i32 %2, 5
  br i1 %3, label %loop2, label %afterloop3
loop2:
  %4 = load i32, ptr %0
  %5 = add i32 %4, 1
  store i32 %5, ptr %0
  br label %whilecond4
afterloop3:
  %12 = load i32, ptr %0
  ret i32 %12
whilecond4:
  %6 = load i32, ptr %1
  %7 = icmp slt i32 %6, 10
  br i1 %7, label %loop5, label %afterloop6
loop5:
  %8 = load i32, ptr %1
  %9 = add i32 %8, 1
  store i32 %9, ptr %1
  %11 = icmp eq i32 %9, 3
  br i1 %11, label %then7, label %ifcont8
afterloop6:
  br label %whilecond1
then7:
  br label %afterloop6
ifcont8:
  br label %whilecond4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


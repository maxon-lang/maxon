// Test: break.break.labeled-break-inner.1
function main() int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y = 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define range(i32 5, -2147483648) i32 @main() {
entry:
  ret i32 5
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 5)
  unreachable
}

---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() !dbg !4 {
entry:
  %y = alloca i32, align 4
  %x = alloca i32, align 4
  store i32 0, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  store i32 0, ptr %y, align 4, !dbg !11
    #dbg_declare(ptr %y, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %afterloop, %entry
  %x1 = load i32, ptr %x, align 4, !dbg !13
  %cmptmp = icmp slt i32 %x1, 5, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop11, !dbg !13

loop:                                             ; preds = %whilecond
  %x2 = load i32, ptr %x, align 4, !dbg !14
  %addtmp = add i32 %x2, 1, !dbg !14
  store i32 %addtmp, ptr %x, align 4, !dbg !14
  br label %whilecond3, !dbg !15

whilecond3:                                       ; preds = %ifcont, %loop
  %y4 = load i32, ptr %y, align 4, !dbg !15
  %cmptmp5 = icmp slt i32 %y4, 10, !dbg !15
  br i1 %cmptmp5, label %loop6, label %afterloop, !dbg !15

loop6:                                            ; preds = %whilecond3
  %y7 = load i32, ptr %y, align 4, !dbg !16
  %addtmp8 = add i32 %y7, 1, !dbg !16
  store i32 %addtmp8, ptr %y, align 4, !dbg !16
  %y9 = load i32, ptr %y, align 4, !dbg !17
  %cmptmp10 = icmp eq i32 %y9, 3, !dbg !17
  br i1 %cmptmp10, label %then, label %ifcont, !dbg !17

then:                                             ; preds = %loop6
  br label %afterloop, !dbg !18

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !18

ifcont:                                           ; preds = %afterbreak, %loop6
  br label %whilecond3, !dbg !18

afterloop:                                        ; preds = %then, %whilecond3
  br label %whilecond, !dbg !18

afterloop11:                                      ; preds = %whilecond
  %x12 = load i32, ptr %x, align 4, !dbg !19
  ret i32 %x12, !dbg !19
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



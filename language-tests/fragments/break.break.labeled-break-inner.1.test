// Test: break.break.labeled-break-inner.1
function main() returns int
    var x = 0
    var y = 0
    while x < 5 'outer'
        x = x + 1
        while y < 10 'inner'
            y = y + 1
            if y == 3 'check'
                break 'inner'
            end 'check'
        end 'inner'
    end 'outer'
    return x
end 'main'

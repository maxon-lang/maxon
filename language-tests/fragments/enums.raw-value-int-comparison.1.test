// Test: enums.raw-value-int-comparison.1
enum Priority int
    case low = 1
    case medium = 5
    case high = 10
end 'Priority'

function main() returns int
    var p = Priority.high
    if p.rawValue > 5 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
; Module: test.maxon
; Instructions: 14

define i32 @main() {
entry0:
  br i1 0, label %rawValue.case.low2, label %rawValue.next.03
rawValue.end1:
  %8 = phi i32 [ 1, %rawValue.case.low2 ], [ 5, %rawValue.case.medium4 ], [ 0, %rawValue.next.15 ], [ 10, %rawValue.case.high6 ]
  %7 = icmp sgt i32 %8, 5
  br i1 %7, label %then7, label %ifcont8
rawValue.case.low2:
  br label %rawValue.end1
rawValue.next.03:
  br i1 0, label %rawValue.case.medium4, label %rawValue.next.15
rawValue.case.medium4:
  br label %rawValue.end1
rawValue.next.15:
  br i1 1, label %rawValue.case.high6, label %rawValue.end1
rawValue.case.high6:
  br label %rawValue.end1
then7:
  ret i32 1
ifcont8:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


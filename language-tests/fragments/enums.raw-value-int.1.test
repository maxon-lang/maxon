// Test: enums.raw-value-int.1
enum HttpStatus int
    case ok = 200
    case notFound = 404
    case serverError = 500
end 'HttpStatus'

function main() int
    var status = HttpStatus.ok
    if status.rawValue == 200 'check'
        return 1
    end 'check'
    return 0
end 'main'

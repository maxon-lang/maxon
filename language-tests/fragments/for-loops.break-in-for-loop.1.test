// Test: for-loops.break-in-for-loop.1
function main() int
    var sum = 0
    for i in range(0, 10) 'loop'
        if i == 5 'check'
            break
        end 'check'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
; Module: test.maxon
; Instructions: 29

%Iterator = type { i32, i32, i32 }

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 0, ptr %0
  %1 = alloca i32
  store i32 0, ptr %1
  %2 = alloca i32
  store i32 10, ptr %2
  br label %forcond1
forcond1:
  %3 = load i32, ptr %1
  %4 = load i32, ptr %2
  %5 = icmp slt i32 %3, %4
  br i1 %5, label %forloop2, label %afterfor4
forloop2:
  %6 = load i32, ptr %1
  %7 = icmp eq i32 %6, 5
  br i1 %7, label %then5, label %ifcont6
forincrement3:
  %11 = load i32, ptr %1
  %12 = add i32 %11, 1
  store i32 %12, ptr %1
  br label %forcond1
afterfor4:
  %13 = load i32, ptr %0
  ret i32 %13
then5:
  br label %afterfor4
ifcont6:
  %8 = load i32, ptr %0
  %9 = load i32, ptr %1
  %10 = add i32 %8, %9
  store i32 %10, ptr %0
  br label %forincrement3
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


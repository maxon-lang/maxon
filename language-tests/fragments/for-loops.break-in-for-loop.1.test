// Test: for-loops.break-in-for-loop.1
function main() returns int
    var sum = 0
    for i in range(0, 10) 'loop'
        if i == 5 'check'
            break
        end 'check'
        sum = sum + i
    end 'loop'
    return sum
end 'main'

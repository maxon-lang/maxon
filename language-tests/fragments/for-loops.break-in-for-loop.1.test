// Test: for-loops.break-in-for-loop.1
function main() int
    var sum = 0
    for i in range(0, 10) 'loop'
        if i = 5 'check'
            break
        end 'check'
        sum = sum + i
    end 'loop'
    return sum
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 10
}

declare void @exit(i32)

define void @_start() {
entry:
  tail call void @exit(i32 10)
  unreachable
}

---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

%Iterator = type { i32, i32, i32 }

define i32 @main() !dbg !4 {
entry:
  %sum = alloca i32, align 4
  store i32 0, ptr %sum, align 4, !dbg !9
    #dbg_declare(ptr %sum, !10, !DIExpression(), !9)
  %0 = call %Iterator @iter.range(i32 0, i32 10), !dbg !11
  %__iter = alloca %Iterator, align 8, !dbg !11
  store %Iterator %0, ptr %__iter, align 4, !dbg !11
  br label %forcond, !dbg !11

forcond:                                          ; preds = %forincrement, %entry
  %hasNext.result = call i32 @iter.hasNext(ptr %__iter), !dbg !11
  %forcond1 = icmp eq i32 %hasNext.result, 1, !dbg !11
  br i1 %forcond1, label %forloop, label %afterfor, !dbg !11

forloop:                                          ; preds = %forcond
  %i = call i32 @iter.getCurrent(ptr %__iter), !dbg !11
  %i2 = alloca i32, align 4, !dbg !11
  store i32 %i, ptr %i2, align 4, !dbg !11
  %i3 = load i32, ptr %i2, align 4, !dbg !12
  %cmptmp = icmp eq i32 %i3, 5, !dbg !12
  br i1 %cmptmp, label %then, label %ifcont, !dbg !12

then:                                             ; preds = %forloop
  br label %afterfor, !dbg !13

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !13

ifcont:                                           ; preds = %afterbreak, %forloop
  %sum4 = load i32, ptr %sum, align 4, !dbg !14
  %i5 = load i32, ptr %i2, align 4, !dbg !14
  %addtmp = add i32 %sum4, %i5, !dbg !14
  store i32 %addtmp, ptr %sum, align 4, !dbg !14
  br label %forincrement, !dbg !14

forincrement:                                     ; preds = %ifcont
  %__iter.next = call %Iterator @iter.next(ptr %__iter), !dbg !14
  store %Iterator %__iter.next, ptr %__iter, align 4, !dbg !14
  br label %forcond, !dbg !14

afterfor:                                         ; preds = %then, %forcond
  %sum6 = load i32, ptr %sum, align 4, !dbg !15
  ret i32 %sum6, !dbg !15
}

define internal i32 @iter.hasNext(ptr %0) !dbg !16 {
entry:
  %it = alloca ptr, align 8
  store ptr %0, ptr %it, align 8, !dbg !19
    #dbg_declare(ptr %it, !20, !DIExpression(), !19)
  %struct.ptr = load ptr, ptr %it, align 8, !dbg !21
  %step = getelementptr inbounds nuw %Iterator, ptr %struct.ptr, i32 0, i32 2, !dbg !21
  %step.val = load i32, ptr %step, align 4, !dbg !21
  %cmptmp = icmp sgt i32 %step.val, 0, !dbg !21
  br i1 %cmptmp, label %then, label %ifcont5, !dbg !21

then:                                             ; preds = %entry
  %struct.ptr1 = load ptr, ptr %it, align 8, !dbg !22
  %current = getelementptr inbounds nuw %Iterator, ptr %struct.ptr1, i32 0, i32 0, !dbg !22
  %current.val = load i32, ptr %current, align 4, !dbg !22
  %struct.ptr2 = load ptr, ptr %it, align 8, !dbg !22
  %limit = getelementptr inbounds nuw %Iterator, ptr %struct.ptr2, i32 0, i32 1, !dbg !22
  %limit.val = load i32, ptr %limit, align 4, !dbg !22
  %cmptmp3 = icmp slt i32 %current.val, %limit.val, !dbg !22
  br i1 %cmptmp3, label %then4, label %ifcont, !dbg !22

then4:                                            ; preds = %then
  ret i32 1, !dbg !23

ifcont:                                           ; preds = %then
  ret i32 0, !dbg !24

ifcont5:                                          ; preds = %entry
  %struct.ptr6 = load ptr, ptr %it, align 8, !dbg !25
  %current7 = getelementptr inbounds nuw %Iterator, ptr %struct.ptr6, i32 0, i32 0, !dbg !25
  %current.val8 = load i32, ptr %current7, align 4, !dbg !25
  %struct.ptr9 = load ptr, ptr %it, align 8, !dbg !25
  %limit10 = getelementptr inbounds nuw %Iterator, ptr %struct.ptr9, i32 0, i32 1, !dbg !25
  %limit.val11 = load i32, ptr %limit10, align 4, !dbg !25
  %cmptmp12 = icmp sgt i32 %current.val8, %limit.val11, !dbg !25
  br i1 %cmptmp12, label %then13, label %ifcont14, !dbg !25

then13:                                           ; preds = %ifcont5
  ret i32 1, !dbg !26

ifcont14:                                         ; preds = %ifcont5
  ret i32 0, !dbg !27
}

define internal i32 @iter.getCurrent(ptr %0) !dbg !28 {
entry:
  %it = alloca ptr, align 8
  store ptr %0, ptr %it, align 8, !dbg !29
    #dbg_declare(ptr %it, !30, !DIExpression(), !29)
  %struct.ptr = load ptr, ptr %it, align 8, !dbg !31
  %current = getelementptr inbounds nuw %Iterator, ptr %struct.ptr, i32 0, i32 0, !dbg !31
  %current.val = load i32, ptr %current, align 4, !dbg !31
  ret i32 %current.val, !dbg !31
}

define internal %Iterator @iter.next(ptr %0) !dbg !32 {
entry:
  %result = alloca %Iterator, align 8
  %it = alloca ptr, align 8
  store ptr %0, ptr %it, align 8, !dbg !33
    #dbg_declare(ptr %it, !34, !DIExpression(), !33)
  %struct.ptr = load ptr, ptr %it, align 8, !dbg !35
  %current = getelementptr inbounds nuw %Iterator, ptr %struct.ptr, i32 0, i32 0, !dbg !35
  %current.val = load i32, ptr %current, align 4, !dbg !35
  %struct.ptr1 = load ptr, ptr %it, align 8, !dbg !35
  %step = getelementptr inbounds nuw %Iterator, ptr %struct.ptr1, i32 0, i32 2, !dbg !35
  %step.val = load i32, ptr %step, align 4, !dbg !35
  %addtmp = add i32 %current.val, %step.val, !dbg !35
  %current2 = getelementptr inbounds nuw %Iterator, ptr %result, i32 0, i32 0, !dbg !35
  store i32 %addtmp, ptr %current2, align 4, !dbg !35
  %struct.ptr3 = load ptr, ptr %it, align 8, !dbg !35
  %limit = getelementptr inbounds nuw %Iterator, ptr %struct.ptr3, i32 0, i32 1, !dbg !35
  %limit.val = load i32, ptr %limit, align 4, !dbg !35
  %limit4 = getelementptr inbounds nuw %Iterator, ptr %result, i32 0, i32 1, !dbg !35
  store i32 %limit.val, ptr %limit4, align 4, !dbg !35
  %struct.ptr5 = load ptr, ptr %it, align 8, !dbg !35
  %step6 = getelementptr inbounds nuw %Iterator, ptr %struct.ptr5, i32 0, i32 2, !dbg !35
  %step.val7 = load i32, ptr %step6, align 4, !dbg !35
  %step8 = getelementptr inbounds nuw %Iterator, ptr %result, i32 0, i32 2, !dbg !35
  store i32 %step.val7, ptr %step8, align 4, !dbg !35
  %result9 = load %Iterator, ptr %result, align 4, !dbg !36
  ret %Iterator %result9, !dbg !36
}

define internal %Iterator @iter.range(i32 %0, i32 %1) !dbg !37 {
entry:
  %it = alloca %Iterator, align 8
  %end_exclusive = alloca i32, align 4
  %start = alloca i32, align 4
  store i32 %0, ptr %start, align 4, !dbg !40
    #dbg_declare(ptr %start, !41, !DIExpression(), !40)
  store i32 %1, ptr %end_exclusive, align 4, !dbg !42
    #dbg_declare(ptr %end_exclusive, !43, !DIExpression(), !42)
  %start1 = load i32, ptr %start, align 4, !dbg !44
  %current = getelementptr inbounds nuw %Iterator, ptr %it, i32 0, i32 0, !dbg !44
  store i32 %start1, ptr %current, align 4, !dbg !44
  %end_exclusive2 = load i32, ptr %end_exclusive, align 4, !dbg !44
  %limit = getelementptr inbounds nuw %Iterator, ptr %it, i32 0, i32 1, !dbg !44
  store i32 %end_exclusive2, ptr %limit, align 4, !dbg !44
  %step = getelementptr inbounds nuw %Iterator, ptr %it, i32 0, i32 2, !dbg !44
  store i32 1, ptr %step, align 4, !dbg !44
  %it3 = load %Iterator, ptr %it, align 4, !dbg !45
  ret %Iterator %it3, !dbg !45
}

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



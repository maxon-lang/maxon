// Test: structs.struct-field-access.1
type Rect
    var width int
    var height int
end 'Rect'

function main() returns int
    var r = Rect { width: 5, height: 10 }
    return r.width * r.height
end 'main'
---
; Module: test.maxon
; Instructions: 14

%Rect = type { i64, i64 }

define i64 @main() {
entry0:
  %0 = alloca %Rect
  %1 = getelementptr %Rect, ptr %0, i32 0, i32 0
  store i64 5, ptr %1
  %2 = getelementptr %Rect, ptr %0, i32 0, i32 1
  store i64 10, ptr %2
  %3 = getelementptr %Rect, ptr %0, i32 0, i32 0
  %4 = load i64, ptr %3
  %5 = getelementptr %Rect, ptr %0, i32 0, i32 1
  %6 = load i64, ptr %5
  %7 = mul i64 %4, %6
  ret i64 %7
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


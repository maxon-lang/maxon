// Test: structs.struct-field-access.1
struct Rect
    var width int
    var height int
end 'Rect'

function main() int
    var r = Rect { width: 5, height: 10 }
    return r.width * r.height
end 'main'
---
; Module: test.maxon
; Instructions: 14

%Rect = type { i32, i32 }

define i32 @main() {
entry0:
  %0 = alloca %Rect
  %1 = getelementptr %Rect, ptr %0, i32 0, i32 0
  store i32 5, ptr %1
  %2 = getelementptr %Rect, ptr %0, i32 0, i32 1
  store i32 10, ptr %2
  %3 = getelementptr %Rect, ptr %0, i32 0, i32 0
  %4 = load i32, ptr %3
  %5 = getelementptr %Rect, ptr %0, i32 0, i32 1
  %6 = load i32, ptr %5
  %7 = mul i32 %4, %6
  ret i32 %7
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


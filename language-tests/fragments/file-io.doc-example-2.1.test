// Test: file-io.doc-example-2.1
function main() returns int
    let success = writeTextFile("temp/output.txt", "Hello, World!")
    if success 'write_ok'
        print("File written successfully")
    end 'write_ok' else 'write_fail'
        print("Failed to write file")
    end 'write_fail'
    return 0
end 'main'

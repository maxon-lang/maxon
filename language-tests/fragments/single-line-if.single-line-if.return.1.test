// Test: single-line-if.single-line-if.return.1
function main() int
	var x = 42
	if x == 42 then return 100
	return 0
end 'main'
---
; Module: test.maxon

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 42, ptr %0
  %1 = load i32, ptr %0
  %2 = icmp eq i32 %1, 42
  br i1 %2, label %then1, label %ifcont2
then1:
  ret i32 100
ifcont2:
  ret i32 0
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

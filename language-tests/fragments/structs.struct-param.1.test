// Test: structs.struct-param.1
struct Vec2
    var x int
    var y int
end 'Vec2'

function dot(a Vec2, b Vec2) int
    return a.x * b.x + a.y * b.y
end 'dot'

function main() int
    var v1 = Vec2 { x: 3, y: 4 }
    var v2 = Vec2 { x: 2, y: 1 }
    return dot(v1, v2)
end 'main'

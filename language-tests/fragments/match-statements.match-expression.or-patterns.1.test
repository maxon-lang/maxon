// Test: match-statements.match-expression.or-patterns.1
function main() int
    var x = 4
    let result = match x 'eval'
        1 or 2 gives 10
        3 or 4 gives 20
        default gives 0
    end 'eval'
    return result
end 'main'
---
; Module: test.maxon
; Instructions: 31

define i32 @main() {
entry0:
  %0 = alloca i32
  store i32 4, ptr %0
  %1 = load i32, ptr %0
  %2 = alloca i32
  store i32 %1, ptr %2
  %3 = alloca i32
  br label %matchexpr.check.05
matchexpr.merge1:
  %12 = load i32, ptr %3
  %13 = alloca i32
  store i32 %12, ptr %13
  %14 = load i32, ptr %13
  ret i32 %14
matchexpr.case.02:
  store i32 10, ptr %3
  br label %matchexpr.merge1
matchexpr.case.13:
  store i32 20, ptr %3
  br label %matchexpr.merge1
matchexpr.case.24:
  store i32 0, ptr %3
  br label %matchexpr.merge1
matchexpr.check.05:
  %4 = load i32, ptr %2
  %5 = icmp eq i32 %4, 1
  %6 = icmp eq i32 %4, 2
  %7 = or i1 %5, %6
  br i1 %7, label %matchexpr.case.02, label %matchexpr.check.16
matchexpr.check.16:
  %8 = load i32, ptr %2
  %9 = icmp eq i32 %8, 3
  %10 = icmp eq i32 %8, 4
  %11 = or i1 %9, %10
  br i1 %11, label %matchexpr.case.13, label %matchexpr.case.24
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


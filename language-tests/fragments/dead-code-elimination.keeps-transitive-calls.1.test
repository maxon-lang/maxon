// Test: dead-code-elimination.keeps-transitive-calls.1
function helper() int
    return 10
end 'helper'

function used() int
    return helper()
end 'used'

function unused() int
    return 999
end 'unused'

function main() int
    return used()
end 'main'
---
; Module: test.maxon

define i32 @helper() {
entry0:
  ret i32 10
}

define i32 @used() {
entry0:
  ret i32 10
}

define i32 @unused() {
entry0:
  ret i32 999
}

define i32 @main() {
entry0:
  ret i32 10
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}

---

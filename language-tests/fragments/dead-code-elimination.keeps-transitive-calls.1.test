// Test: dead-code-elimination.keeps-transitive-calls.1
function helper() int
    return 10
end 'helper'

function used() int
    return helper()
end 'used'

function unused() int
    return 999
end 'unused'

function main() int
    return used()
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

; Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
define noundef i32 @main() local_unnamed_addr #0 {
entry:
  ret i32 10
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #1 {
entry:
  tail call void @ExitProcess(i32 10)
  unreachable
}

attributes #0 = { mustprogress nofree norecurse nosync nounwind willreturn memory(none) }
attributes #1 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define internal i32 @helper() !dbg !4 {
entry:
  ret i32 10, !dbg !8
}

define internal i32 @used() !dbg !9 {
entry:
  %0 = call i32 @helper(), !dbg !10
  ret i32 %0, !dbg !10
}

define i32 @main() !dbg !11 {
entry:
  %0 = call i32 @used(), !dbg !12
  ret i32 %0, !dbg !12
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "helper", linkageName: "helper", scope: !1, file: !1, line: 2, type: !5, scopeLine: 2, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !DILocation(line: 3, column: 5, scope: !4)
!9 = distinct !DISubprogram(name: "used", linkageName: "used", scope: !1, file: !1, line: 6, type: !5, scopeLine: 6, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0)
!10 = !DILocation(line: 7, column: 5, scope: !9)
!11 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 14, type: !5, scopeLine: 14, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0)
!12 = !DILocation(line: 15, column: 5, scope: !11)
---
ExitCode: 10
OptimizedInstructionCount: 4
UnoptimizedInstructionCount: 4

entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = load ptr, ptr %0
  %2 = getelementptr %IntSum, ptr %1, i32 0, i32 0
  %3 = load i32, ptr %2
  ret i32 %3
}

define i32 @main() {
entry0:
  %0 = alloca %IntSum
  %1 = getelementptr %IntSum, ptr %0, i32 0, i32 0
  store i32 0, ptr %1
  %2 = call %IntSum @IntSum.add(ptr %0, i32 10)
  store %IntSum %2, ptr %0
  %3 = call %IntSum @IntSum.add(ptr %0, i32 32)
  store %IntSum %3, ptr %0
  %4 = call i32 @IntSum.total(ptr %0)
  ret i32 %4
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


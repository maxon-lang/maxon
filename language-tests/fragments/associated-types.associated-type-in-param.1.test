  %2 = alloca %IntSum
  %3 = load ptr, ptr %0
  %4 = getelementptr %IntSum, ptr %3, i32 0, i32 0
  %5 = load i32, ptr %4
  %6 = load i32, ptr %1
  %7 = add i32 %5, %6
  %8 = getelementptr %IntSum, ptr %2, i32 0, i32 0
  store i32 %7, ptr %8
  %9 = load %IntSum, ptr %2
  ret %IntSum %9
}


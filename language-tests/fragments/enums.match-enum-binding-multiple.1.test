// Test: enums.match-enum-binding-multiple.1
enum Result
    success(value int)
    failure(code int)
end 'Result'

function main() returns int
    var r = Result.failure(404)
    match r 'handle'
        success(v) then return v
        failure(c) then return c
    end 'handle'
end 'main'

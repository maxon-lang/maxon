extern function GetStdHandle(nStdHandle int) ptr
extern function WriteFile(hFile ptr, lpBuffer ptr, nBytes int, written ptr, overlapped ptr) int

function main() int
    let stdout = GetStdHandle(-11)
    var written = 0
    var msg1 = "Hello "
    var msg2 = "World!"
    WriteFile(stdout, msg1, 6, &written, 0 as ptr)
    WriteFile(stdout, msg2, 6, &written, 0 as ptr)
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@.str = private constant [6 x i8] c"Hello "
@.str.1 = private constant [6 x i8] c"World!"

declare ptr @GetStdHandle(i32) local_unnamed_addr

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr) local_unnamed_addr

define noundef i32 @main() local_unnamed_addr {
entry:
  %written = alloca i32, align 4
  %0 = tail call ptr @GetStdHandle(i32 -11)
  store i32 0, ptr %written, align 4
  %1 = call i32 @WriteFile(ptr %0, ptr nonnull @.str, i32 6, ptr nonnull %written, ptr null)
  %2 = call i32 @WriteFile(ptr %0, ptr nonnull @.str.1, i32 6, ptr nonnull %written, ptr null)
  ret i32 0
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #0 {
entry:
  %0 = tail call i32 @main()
  tail call void @ExitProcess(i32 0)
  unreachable
}

attributes #0 = { noreturn }
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@.str = private constant [6 x i8] c"Hello "
@.str.1 = private constant [6 x i8] c"World!"

declare ptr @GetStdHandle(i32)

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr)

define i32 @main() !dbg !4 {
entry:
  %msg2 = alloca ptr, align 8, !dbg !9
  %msg1 = alloca ptr, align 8, !dbg !9
  %written = alloca i32, align 4, !dbg !9
  %stdout = alloca ptr, align 8, !dbg !9
  %0 = call ptr @GetStdHandle(i32 -11), !dbg !9
  store ptr %0, ptr %stdout, align 8, !dbg !9
    #dbg_declare(ptr %stdout, !10, !DIExpression(), !9)
  store i32 0, ptr %written, align 4, !dbg !11
    #dbg_declare(ptr %written, !12, !DIExpression(), !11)
  store ptr @.str, ptr %msg1, align 8, !dbg !13
    #dbg_declare(ptr %msg1, !14, !DIExpression(), !13)
  store ptr @.str.1, ptr %msg2, align 8, !dbg !15
    #dbg_declare(ptr %msg2, !16, !DIExpression(), !15)
  %stdout1 = load ptr, ptr %stdout, align 8, !dbg !17
  %msg12 = load ptr, ptr %msg1, align 8, !dbg !17
  %1 = call i32 @WriteFile(ptr %stdout1, ptr %msg12, i32 6, ptr %written, ptr null), !dbg !17
  %stdout3 = load ptr, ptr %stdout, align 8, !dbg !18
  %msg24 = load ptr, ptr %msg2, align 8, !dbg !18
  %2 = call i32 @WriteFile(ptr %stdout3, ptr %msg24, i32 6, ptr %written, ptr null), !dbg !18
  ret i32 0, !dbg !19
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}


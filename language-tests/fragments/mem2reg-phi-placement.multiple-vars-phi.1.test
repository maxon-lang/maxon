// Test: mem2reg-phi-placement.multiple-vars-phi.1
function main() returns int
    var a = 0
    var b = 0
    if 1 > 0 'branch'
        a = 10
        b = 20
    end 'branch' else 'else_branch'
        a = 100
        b = 200
    end 'else_branch'
    return a + b
end 'main'
---
OptimizedInstructions: 0
UnoptimizedInstructions: 0
ExitCode: 30
---
; Module: test.maxon

define i64 @main() {
entry0:
  br i1 1, label %then1, label %else3
then1:
  br label %ifcont2
ifcont2:
  %7 = phi i64 [ 20, %then1 ], [ 200, %else3 ]
  %6 = phi i64 [ 10, %then1 ], [ 100, %else3 ]
  %5 = add i64 %6, %7
  ret i64 %5
else3:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}

---
; Module: test.maxon

define i64 @main() {
entry0:
  %0 = alloca i64
  store i64 0, ptr %0
  %1 = alloca i64
  store i64 0, ptr %1
  %2 = icmp sgt i64 1, 0
  br i1 %2, label %then1, label %else3
then1:
  store i64 10, ptr %0
  store i64 20, ptr %1
  br label %ifcont2
ifcont2:
  %3 = load i64, ptr %0
  %4 = load i64, ptr %1
  %5 = add i64 %3, %4
  ret i64 %5
else3:
  store i64 100, ptr %0
  store i64 200, ptr %1
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


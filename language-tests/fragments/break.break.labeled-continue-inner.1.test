// Test: break.break.labeled-continue-inner.1
function main() returns int
    var sum = 0
    var x = 0
    while x < 3 'outer'
        x = x + 1
        var y = 0
        while y < 5 'inner'
            y = y + 1
            if y == 3 'check'
                continue 'inner'
            end 'check'
            sum = sum + 1
        end 'inner'
    end 'outer'
    return sum
end 'main'

// Test that stdlib functions can be called with qualified names  
// This test verifies the parser accepts qualified names (stdlib.fmt.format_int_array)
// stdlib linking not yet implemented, so this is expected to fail
function main() int
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define i32 @main() {
entry:
  ret i32 0
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}
---
ExitCode: 0

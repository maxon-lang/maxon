// Test: mem2reg-phi-placement.if-else-phi.1
function main() returns int
    var x = 0
    if 5 > 3 'check'
        x = 42
    end 'check' else 'else_check'
        x = 100
    end 'else_check'
    return x
end 'main'
---
OptimizedInstructions: 0
UnoptimizedInstructions: 0
ExitCode: 42
---
; Module: test.maxon

define i64 @main() {
entry0:
  br i1 1, label %then1, label %else3
then1:
  br label %ifcont2
ifcont2:
  %3 = phi i64 [ 42, %then1 ], [ 100, %else3 ]
  ret i64 %3
else3:
  br label %ifcont2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i64 @main()
  call void @exit(i64 %0)
  ret void
}


    #dbg_declare(ptr %exp_times_log, !210, !DIExpression(), !209)
  %exp_times_log43 = load double, ptr %exp_times_log, align 8, !dbg !211
  %3 = call double @math.exp(double %exp_times_log43), !dbg !211
  ret double %3, !dbg !211
}

define internal double @math.exp(double %0) !dbg !212 {
entry:
  %i = alloca i32, align 4
  %result = alloca double, align 8
  %k_float = alloca double, align 8
  %k = alloca i32, align 4
  %sum = alloca double, align 8
  %term = alloca double, align 8
  %reduction_count = alloca i32, align 4
  %is_negative = alloca i1, align 1
  %x = alloca double, align 8
  store double %0, ptr %x, align 8, !dbg !213
    #dbg_declare(ptr %x, !214, !DIExpression(), !213)
  %x1 = load double, ptr %x, align 8, !dbg !215
  %fcmptmp = fcmp oeq double %x1, 0.000000e+00, !dbg !215
  br i1 %fcmptmp, label %then, label %ifcont, !dbg !215

then:                                             ; preds = %entry
  ret double 1.000000e+00, !dbg !216

ifcont:                                           ; preds = %entry
  %x2 = load double, ptr %x, align 8, !dbg !217
  %fcmptmp3 = fcmp olt double %x2, 0.000000e+00, !dbg !217
  store i1 %fcmptmp3, ptr %is_negative, align 1, !dbg !217
    #dbg_declare(ptr %is_negative, !218, !DIExpression(), !217)
  %is_negative4 = load i1, ptr %is_negative, align 1, !dbg !219
  br i1 %is_negative4, label %then5, label %ifcont7, !dbg !219

then5:                                            ; preds = %ifcont
  %x6 = load double, ptr %x, align 8, !dbg !220
  %fnegtmp = fneg double %x6, !dbg !220
  store double %fnegtmp, ptr %x, align 8, !dbg !220
  br label %ifcont7, !dbg !220

ifcont7:                                          ; preds = %then5, %ifcont
  store i32 0, ptr %reduction_count, align 4, !dbg !221
    #dbg_declare(ptr %reduction_count, !222, !DIExpression(), !221)
  br label %whilecond, !dbg !223

whilecond:                                        ; preds = %loop, %ifcont7
  %x8 = load double, ptr %x, align 8, !dbg !223
  %fcmptmp9 = fcmp ogt double %x8, 1.000000e+00, !dbg !223
  br i1 %fcmptmp9, label %loop, label %afterloop, !dbg !223

loop:                                             ; preds = %whilecond
  %x10 = load double, ptr %x, align 8, !dbg !224
  %fdivtmp = fdiv double %x10, 2.000000e+00, !dbg !224
  store double %fdivtmp, ptr %x, align 8, !dbg !224
  %reduction_count11 = load i32, ptr %reduction_count, align 4, !dbg !225
  %addtmp = add i32 %reduction_count11, 1, !dbg !225
  store i32 %addtmp, ptr %reduction_count, align 4, !dbg !225
  br label %whilecond, !dbg !225

afterloop:                                        ; preds = %whilecond
  store double 1.000000e+00, ptr %term, align 8, !dbg !226
    #dbg_declare(ptr %term, !227, !DIExpression(), !226)
  store double 1.000000e+00, ptr %sum, align 8, !dbg !228
    #dbg_declare(ptr %sum, !229, !DIExpression(), !228)
  store i32 1, ptr %k, align 4, !dbg !230
    #dbg_declare(ptr %k, !231, !DIExpression(), !230)
  br label %whilecond12, !dbg !232

whilecond12:                                      ; preds = %loop14, %afterloop
  %k13 = load i32, ptr %k, align 4, !dbg !232
  %cmptmp = icmp slt i32 %k13, 20, !dbg !232
  br i1 %cmptmp, label %loop14, label %afterloop25, !dbg !232

loop14:                                           ; preds = %whilecond12
  %term15 = load double, ptr %term, align 8, !dbg !233
  %x16 = load double, ptr %x, align 8, !dbg !233
  %fmultmp = fmul double %term15, %x16, !dbg !233
  store double %fmultmp, ptr %term, align 8, !dbg !233
  %k17 = load i32, ptr %k, align 4, !dbg !234
  %int2floattmp = sitofp i32 %k17 to double, !dbg !234
  store double %int2floattmp, ptr %k_float, align 8, !dbg !234
    #dbg_declare(ptr %k_float, !235, !DIExpression(), !234)
  %term18 = load double, ptr %term, align 8, !dbg !236
  %k_float19 = load double, ptr %k_float, align 8, !dbg !236
  %fdivtmp20 = fdiv double %term18, %k_float19, !dbg !236
  store double %fdivtmp20, ptr %term, align 8, !dbg !236
  %sum21 = load double, ptr %sum, align 8, !dbg !237
  %term22 = load double, ptr %term, align 8, !dbg !237
  %faddtmp = fadd double %sum21, %term22, !dbg !237
  store double %faddtmp, ptr %sum, align 8, !dbg !237
  %k23 = load i32, ptr %k, align 4, !dbg !238
  %addtmp24 = add i32 %k23, 1, !dbg !238
  store i32 %addtmp24, ptr %k, align 4, !dbg !238
  br label %whilecond12, !dbg !238

afterloop25:                                      ; preds = %whilecond12
  %sum26 = load double, ptr %sum, align 8, !dbg !239
  store double %sum26, ptr %result, align 8, !dbg !239
    #dbg_declare(ptr %result, !240, !DIExpression(), !239)
  store i32 0, ptr %i, align 4, !dbg !241
    #dbg_declare(ptr %i, !242, !DIExpression(), !241)
  br label %whilecond27, !dbg !243

whilecond27:                                      ; preds = %loop31, %afterloop25
  %i28 = load i32, ptr %i, align 4, !dbg !243
  %reduction_count29 = load i32, ptr %reduction_count, align 4, !dbg !243
  %cmptmp30 = icmp slt i32 %i28, %reduction_count29, !dbg !243
  br i1 %cmptmp30, label %loop31, label %afterloop37, !dbg !243

loop31:                                           ; preds = %whilecond27
  %result32 = load double, ptr %result, align 8, !dbg !244
  %result33 = load double, ptr %result, align 8, !dbg !244
  %fmultmp34 = fmul double %result32, %result33, !dbg !244
  store double %fmultmp34, ptr %result, align 8, !dbg !244
  %i35 = load i32, ptr %i, align 4, !dbg !245
  %addtmp36 = add i32 %i35, 1, !dbg !245
  store i32 %addtmp36, ptr %i, align 4, !dbg !245
  br label %whilecond27, !dbg !245

afterloop37:                                      ; preds = %whilecond27
  %is_negative38 = load i1, ptr %is_negative, align 1, !dbg !246
  br i1 %is_negative38, label %then39, label %ifcont42, !dbg !246

then39:                                           ; preds = %afterloop37
  %result40 = load double, ptr %result, align 8, !dbg !247
  %fdivtmp41 = fdiv double 1.000000e+00, %result40, !dbg !247
  store double %fdivtmp41, ptr %result, align 8, !dbg !247
  br label %ifcont42, !dbg !247

ifcont42:                                         ; preds = %then39, %afterloop37
  %result43 = load double, ptr %result, align 8, !dbg !248
  ret double %result43, !dbg !248
}

declare i32 @write_stdout(ptr, i32)

declare ptr @malloc(i64)

declare void @free(ptr)

declare ptr @memset(ptr, i32, i64)

declare double @llvm.floor.f64(double)

declare void @exit(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  unreachable
}



// Test: collection.map-basic-transform.1
function double(x int) returns int
    return x * 2
end 'double'

function main() returns int
    var arr = [1, 2, 3, 4, 5]
    var result = arr.map(double)
    print("{result[0]}")
    print("{result[1]}")
    print("{result[2]}")
    print("{result[3]}")
    print("{result[4]}")
    return 0
end 'main'

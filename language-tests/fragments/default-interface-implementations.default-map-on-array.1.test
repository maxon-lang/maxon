// Test: default-interface-implementations.default-map-on-array.1
function double(x int) int
    return x * 2
end 'double'

function main() int
    var arr = [1, 2, 3]
    var result = arr.map(double)
    printInt(result[0])
    printInt(result[1])
    printInt(result[2])
    return 0
end 'main'

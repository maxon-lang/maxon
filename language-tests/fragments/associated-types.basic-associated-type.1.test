// Test: associated-types.basic-associated-type.1
interface Wrapper uses Inner
    function unwrap() Inner
end 'Wrapper'

struct IntBox is Wrapper with int
    var value int

    function Wrapper.unwrap() int
        return value
    end 'unwrap'
end 'IntBox'

function main() int
    var box = IntBox{value: 42}
    return box.unwrap()
end 'main'
---
; Module: test.maxon
; Instructions: 14

%IntBox = type { i32 }

define i32 @IntBox.unwrap(ptr %self) {
entry0:
  %0 = alloca ptr
  store ptr %self, ptr %0
  %1 = load ptr, ptr %0
  %2 = getelementptr %IntBox, ptr %1, i32 0, i32 0
  %3 = load i32, ptr %2
  ret i32 %3
}

define i32 @main() {
entry0:
  %0 = alloca %IntBox
  %1 = getelementptr %IntBox, ptr %0, i32 0, i32 0
  store i32 42, ptr %1
  %2 = call i32 @IntBox.unwrap(ptr %0)
  ret i32 %2
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


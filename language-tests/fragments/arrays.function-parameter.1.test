  %len2 = load i32, ptr %len, align 4, !dbg !17
  %cmptmp = icmp slt i32 %i1, %len2, !dbg !17
  br i1 %cmptmp, label %loop, label %afterloop, !dbg !17

loop:                                             ; preds = %whilecond
  %total3 = load i32, ptr %total, align 4, !dbg !18
  %i4 = load i32, ptr %i, align 4, !dbg !18
  %arrayptr = load ptr, ptr %arr, align 8, !dbg !18
  %arrayidx = getelementptr inbounds i32, ptr %arrayptr, i32 %i4, !dbg !18
  %arrayelem = load i32, ptr %arrayidx, align 4, !dbg !18
  %addtmp = add i32 %total3, %arrayelem, !dbg !18
  store i32 %addtmp, ptr %total, align 4, !dbg !18
  %i5 = load i32, ptr %i, align 4, !dbg !19
  %addtmp6 = add i32 %i5, 1, !dbg !19
  store i32 %addtmp6, ptr %i, align 4, !dbg !19
  br label %whilecond, !dbg !19

afterloop:                                        ; preds = %whilecond
  %total7 = load i32, ptr %total, align 4, !dbg !20
  ret i32 %total7, !dbg !20
}


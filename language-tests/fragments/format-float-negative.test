function pow10(n int) float
    var result = 1.0
    var i = 0
    while i < n 'loop'
        result = result * 10.0
        i = i + 1
    end 'loop'
    return result
end 'pow10'

function format_float_array(value float, buffer []char, precision int) int
    if value = 0.0 'zero_case'
        buffer[0] = '0' as char
        buffer[1] = '.' as char
        var i = 0
        while i < precision 'zero_decimals'
            buffer[2 + i] = '0' as char
            i = i + 1
        end 'zero_decimals'
        return 2 + precision
    end 'zero_case'
    
    var pos = 0
    
    var work_value = value
    if value < 0.0 'negative_check'
        buffer[pos] = '-' as char
        pos = pos + 1
        work_value = -value
    end 'negative_check'
    
    var int_part = trunc(work_value)
    
    var temp [20]char = 0
    var temp_pos = 19
    var abs_int = int_part
    
    if int_part = 0 'int_zero'
        temp[temp_pos] = '0' as char
        temp_pos = temp_pos - 1
    end 'int_zero'
    
    while abs_int > 0 'convert_int'
        var digit = abs_int % 10
        var digit_char = ('0' as int) + digit
        temp[temp_pos] = digit_char as char
        temp_pos = temp_pos - 1
        abs_int = abs_int / 10
    end 'convert_int'
    
    var start = temp_pos + 1
    var length = 20 - start
    var i = 0
    while i < length 'copy_int'
        buffer[pos + i] = temp[start + i]
        i = i + 1
    end 'copy_int'
    pos = pos + length
    
    buffer[pos] = '.' as char
    pos = pos + 1
    
    var frac_part = work_value - int_part
    var scale = pow10(precision)
    var frac_scaled = trunc(frac_part * scale + 0.5)
    
    var j = precision - 1
    while j >= 0 'convert_frac'
        var digit = frac_scaled % 10
        var digit_char = ('0' as int) + digit
        buffer[pos + j] = digit_char as char
        frac_scaled = frac_scaled / 10
        j = j - 1
    end 'convert_frac'
    
    pos = pos + precision
    return pos
end 'format_float_array'

function main() int
    var buffer [32]char = 0
    var len = format_float_array(-5.75, buffer, 2)
    
    if len != 5 return 1
    if buffer[0] as int != '-' as int return 2
    if buffer[1] as int != '5' as int return 3
    if buffer[2] as int != '.' as int return 4
    if buffer[3] as int != '7' as int return 5
    if buffer[4] as int != '5' as int return 6
    
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

define double @pow10(i32 %0) {
entry:
  br label %whilecond

whilecond:                                        ; preds = %loop, %entry
  %result.0 = phi double [ 1.000000e+00, %entry ], [ %fmultmp, %loop ]
  %i.0 = phi i32 [ 0, %entry ], [ %addtmp, %loop ]
  %cmptmp = icmp slt i32 %i.0, %0
  br i1 %cmptmp, label %loop, label %afterloop

loop:                                             ; preds = %whilecond
  %fmultmp = fmul double %result.0, 1.000000e+01
  %addtmp = add i32 %i.0, 1
  br label %whilecond

afterloop:                                        ; preds = %whilecond
  ret double %result.0
}

define i32 @format_float_array(double %0, ptr %1, i32 %2, i32 %3) #0 {
entry:
  %fcmptmp = fcmp oeq double %0, 0.000000e+00
  br i1 %fcmptmp, label %then, label %ifcont

then:                                             ; preds = %entry
  store i8 48, ptr %1, align 1
  %arrayidx3 = getelementptr inbounds nuw i8, ptr %1, i64 1
  store i8 46, ptr %arrayidx3, align 1
  br label %whilecond

whilecond:                                        ; preds = %loop, %then
  %i.0 = phi i32 [ 0, %then ], [ %addtmp10, %loop ]
  %cmptmp = icmp slt i32 %i.0, %3
  br i1 %cmptmp, label %loop, label %afterloop

loop:                                             ; preds = %whilecond
  %addtmp = add i32 %i.0, 2
  %4 = sext i32 %addtmp to i64
  %arrayidx8 = getelementptr inbounds i8, ptr %1, i64 %4
  store i8 48, ptr %arrayidx8, align 1
  %addtmp10 = add i32 %i.0, 1
  br label %whilecond

common.ret:                                       ; preds = %afterloop109, %afterloop
  %common.ret.op = phi i32 [ %addtmp12, %afterloop ], [ %addtmp112, %afterloop109 ]
  ret i32 %common.ret.op

afterloop:                                        ; preds = %whilecond
  %addtmp12 = add i32 %3, 2
  br label %common.ret

ifcont:                                           ; preds = %entry
  %fcmptmp15 = fcmp olt double %0, 0.000000e+00
  br i1 %fcmptmp15, label %then16, label %ifcont23

then16:                                           ; preds = %ifcont
  store i8 45, ptr %1, align 1
  %fnegtmp = fneg double %0
  br label %ifcont23

ifcont23:                                         ; preds = %then16, %ifcont
  %work_value.0 = phi double [ %fnegtmp, %then16 ], [ %0, %ifcont ]
  %pos.0 = phi i32 [ 1, %then16 ], [ 0, %ifcont ]
  %trunc = fptosi double %work_value.0 to i32
  %temp.malloc = call ptr @malloc(i64 20)
  %5 = call ptr @memset(ptr %temp.malloc, i32 0, i64 20)
  %cmptmp27 = icmp eq i32 %trunc, 0
  br i1 %cmptmp27, label %then28, label %ifcont33

then28:                                           ; preds = %ifcont23
  %arrayidx31 = getelementptr inbounds nuw i8, ptr %temp.malloc, i64 19
  store i8 48, ptr %arrayidx31, align 1
  br label %ifcont33

ifcont33:                                         ; preds = %then28, %ifcont23
  %temp_pos.0 = phi i32 [ 18, %then28 ], [ 19, %ifcont23 ]
  br label %whilecond34

whilecond34:                                      ; preds = %loop37, %ifcont33
  %abs_int.0 = phi i32 [ %trunc, %ifcont33 ], [ %divtmp, %loop37 ]
  %temp_pos.1 = phi i32 [ %temp_pos.0, %ifcont33 ], [ %subtmp46, %loop37 ]
  %cmptmp36 = icmp sgt i32 %abs_int.0, 0
  br i1 %cmptmp36, label %loop37, label %afterloop48

loop37:                                           ; preds = %whilecond34
  %modtmp = urem i32 %abs_int.0, 10
  %6 = trunc nuw nsw i32 %modtmp to i8
  %trunctmp = or disjoint i8 %6, 48
  %7 = sext i32 %temp_pos.1 to i64
  %arrayidx44 = getelementptr inbounds i8, ptr %temp.malloc, i64 %7
  store i8 %trunctmp, ptr %arrayidx44, align 1
  %subtmp46 = add i32 %temp_pos.1, -1
  %divtmp = udiv i32 %abs_int.0, 10
  br label %whilecond34

afterloop48:                                      ; preds = %whilecond34
  %addtmp50 = add i32 %temp_pos.1, 1
  %subtmp52 = sub i32 19, %temp_pos.1
  br label %whilecond54

whilecond54:                                      ; preds = %loop58, %afterloop48
  %i53.0 = phi i32 [ 0, %afterloop48 ], [ %addtmp70, %loop58 ]
  %cmptmp57 = icmp slt i32 %i53.0, %subtmp52
  br i1 %cmptmp57, label %loop58, label %afterloop71

loop58:                                           ; preds = %whilecond54
  %addtmp61 = add i32 %i53.0, %pos.0
  %addtmp64 = add i32 %addtmp50, %i53.0
  %8 = sext i32 %addtmp64 to i64
  %arrayidx66 = getelementptr inbounds i8, ptr %temp.malloc, i64 %8
  %arrayelem = load i8, ptr %arrayidx66, align 1
  %9 = sext i32 %addtmp61 to i64
  %arrayidx68 = getelementptr inbounds i8, ptr %1, i64 %9
  store i8 %arrayelem, ptr %arrayidx68, align 1
  %addtmp70 = add i32 %i53.0, 1
  br label %whilecond54

afterloop71:                                      ; preds = %whilecond54
  %addtmp74 = add i32 %subtmp52, %pos.0
  %10 = sext i32 %addtmp74 to i64
  %arrayidx77 = getelementptr inbounds i8, ptr %1, i64 %10
  store i8 46, ptr %arrayidx77, align 1
  %promotetmp = sitofp i32 %trunc to double
  %fsubtmp = fsub double %work_value.0, %promotetmp
  %11 = call double @pow10(i32 %3)
  %fmultmp = fmul double %fsubtmp, %11
  %faddtmp = fadd double %fmultmp, 5.000000e-01
  %trunc85 = fptosi double %faddtmp to i32
  br label %whilecond88

whilecond88:                                      ; preds = %loop91, %afterloop71
  %frac_scaled.0 = phi i32 [ %trunc85, %afterloop71 ], [ %divtmp106, %loop91 ]
  %j.0.in = phi i32 [ %3, %afterloop71 ], [ %j.0, %loop91 ]
  %j.0 = add i32 %j.0.in, -1
  %cmptmp90 = icmp sgt i32 %j.0, -1
  br i1 %cmptmp90, label %loop91, label %afterloop109

loop91:                                           ; preds = %whilecond88
  %modtmp93 = srem i32 %frac_scaled.0, 10
  %addtmp100 = add i32 %j.0.in, %addtmp74
  %12 = trunc nsw i32 %modtmp93 to i8
  %trunctmp102 = add nsw i8 %12, 48
  %13 = sext i32 %addtmp100 to i64
  %arrayidx104 = getelementptr inbounds i8, ptr %1, i64 %13
  store i8 %trunctmp102, ptr %arrayidx104, align 1
  %divtmp106 = sdiv i32 %frac_scaled.0, 10
  br label %whilecond88

afterloop109:                                     ; preds = %whilecond88
  %addtmp79 = add i32 %3, 1
  %addtmp112 = add i32 %addtmp79, %addtmp74
  br label %common.ret
}

define i32 @main() #0 {
entry:
  %buffer.malloc = call ptr @malloc(i64 32)
  %0 = call ptr @memset(ptr %buffer.malloc, i32 0, i64 32)
  %1 = call i32 @format_float_array(double -5.750000e+00, ptr %buffer.malloc, i32 32, i32 2)
  %cmptmp.not = icmp eq i32 %1, 5
  br i1 %cmptmp.not, label %ifcont, label %then

common.ret:                                       ; preds = %ifcont26, %ifcont19, %ifcont12, %ifcont5, %ifcont, %then
  %common.ret.op = phi i32 [ 1, %then ], [ 2, %ifcont ], [ 3, %ifcont5 ], [ 4, %ifcont12 ], [ 5, %ifcont19 ], [ %., %ifcont26 ]

// Test: associated-types.char-element-type.1
interface CharSource uses Element
    function getChar() Element
end 'CharSource'

struct SingleChar is CharSource with char
    var ch char

    function CharSource.getChar() char
        return ch
    end 'getChar'
end 'SingleChar'

function main() int
    var s = SingleChar{ch: 'A'}
    var c = s.getChar()
    return c as int
end 'main'

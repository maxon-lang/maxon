  %6 = getelementptr %SingleChar, ptr %0, i32 0, i32 0
  %7 = load i8, ptr %6
  %5 = zext i8 %7 to i32
  ret i32 %5
}

declare void @exit(i32 %arg0)

define void @_start() {
entry0:
  %0 = call i32 @main()
  call void @exit(i32 %0)
  ret void
}


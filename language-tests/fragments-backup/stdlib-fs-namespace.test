source_filename = "test.maxon"

@.str = private constant [8 x i8] c"Output!\0A"

declare ptr @GetStdHandle(i32) local_unnamed_addr

declare i32 @WriteFile(ptr, ptr, i32, ptr, ptr) local_unnamed_addr

define noundef i32 @main() local_unnamed_addr {
entry:
  %bytesWritten.i = alloca i32, align 4
  %0 = tail call ptr @GetStdHandle(i32 -11)
  call void @llvm.lifetime.start.p0(i64 4, ptr nonnull %bytesWritten.i)
  store i32 0, ptr %bytesWritten.i, align 4
  %1 = call i32 @WriteFile(ptr %0, ptr nonnull @.str, i32 8, ptr nonnull %bytesWritten.i, ptr null)
  call void @llvm.lifetime.end.p0(i64 4, ptr nonnull %bytesWritten.i)
  ret i32 0
}

declare void @ExitProcess(i32) local_unnamed_addr

; Function Attrs: noreturn
define void @_start() local_unnamed_addr #0 {
entry:
  %0 = tail call i32 @main()
  tail call void @ExitProcess(i32 0)
  unreachable
}

; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: readwrite)
declare void @llvm.lifetime.start.p0(i64 immarg, ptr captures(none)) #1

; Function Attrs: nocallback nofree nosync nounwind willreturn memory(argmem: readwrite)
declare void @llvm.lifetime.end.p0(i64 immarg, ptr captures(none)) #1

attributes #0 = { noreturn }
attributes #1 = { nocallback nofree nosync nounwind willreturn memory(argmem: readwrite) }

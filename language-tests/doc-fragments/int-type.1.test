  %subtmp = sub i32 %n3, 1, !dbg !13
  %1 = call i32 @factorial(i32 %subtmp), !dbg !13
  %multmp = mul i32 %n2, %1, !dbg !13
  ret i32 %multmp, !dbg !13
}


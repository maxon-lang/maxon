func main() int {
	var x = 5;
	var i = 3;
	while true {
		x = x + 2;
		i--;
		if i == 0 {
			break;
		}
	}
	return x;
}
---
; ModuleID = 'main'
source_filename = "main"
target triple = "x86_64-pc-windows-msvc19.38.33133"

define i32 @main() {
entry:
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4
  %i = alloca i32, align 4
  store i32 3, ptr %i, align 4
  br label %while

while:                                            ; preds = %while, %entry
  %i2 = phi i32 [ 3, %entry ], [ %subtmp, %while ]
  %x1 = phi i32 [ 5, %entry ], [ %addtmp, %while ]
  %addtmp = add i32 %x1, 2
  store i32 %addtmp, ptr %x, align 4
  %subtmp = add i32 %i2, -1
  store i32 %subtmp, ptr %i, align 4
  %eqtmp = icmp eq i32 %subtmp, 0
  br i1 %eqtmp, label %then, label %while

then:                                             ; preds = %while
  ret i32 %addtmp
}
---
ExitCode: 11
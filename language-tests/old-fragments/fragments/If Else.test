func main() int {
	var x = 5;
	var i = 3;
	while i > 0 {
    if (i == 3) {
      x = x + 5;
    } else {
      x = x + 2;
    }
		i--;
	}
	return x;
}
---
; ModuleID = 'main'
source_filename = "main"
target triple = "x86_64-pc-windows-msvc19.38.33133"

define i32 @main() {
entry:
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4
  %i = alloca i32, align 4
  br label %while

while:                                            ; preds = %whilebody, %entry
  %x3 = phi i32 [ 5, %entry ], [ %storemerge8, %whilebody ]
  %i6 = phi i32 [ 3, %entry ], [ %subtmp, %whilebody ]
  store i32 %i6, ptr %i, align 4
  %gttmp = icmp sgt i32 %i6, 0
  br i1 %gttmp, label %whilebody, label %whileexit

whilebody:                                        ; preds = %while
  %eqtmp = icmp eq i32 %i6, 3
  %addtmp5 = add i32 %x3, 2
  %addtmp = add i32 %x3, 5
  %storemerge8 = select i1 %eqtmp, i32 %addtmp, i32 %addtmp5
  store i32 %storemerge8, ptr %x, align 4
  %subtmp = add i32 %i6, -1
  br label %while

whileexit:                                        ; preds = %while
  ret i32 %x3
}
---
ExitCode: 14
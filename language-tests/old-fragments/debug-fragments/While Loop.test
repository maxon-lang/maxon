func main() int {
	var x = 5;
	var i = 3;
	while true {
		x = x + 2;
		i--;
		if (i == 0) {
			break;
		}
	}
	return x;
}
---
; ModuleID = 'main'
source_filename = "main"
target triple = "x86_64-pc-windows-msvc19.38.33133"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4, !dbg !11
  store i32 5, ptr %x, align 4, !dbg !11
  call void @llvm.dbg.declare(metadata ptr %x, metadata !9, metadata !DIExpression()), !dbg !11
  %i = alloca i32, align 4, !dbg !12
  store i32 3, ptr %i, align 4, !dbg !12
  call void @llvm.dbg.declare(metadata ptr %i, metadata !10, metadata !DIExpression()), !dbg !12
  br label %while, !dbg !12

while:                                            ; preds = %endif, %entry
  br i1 true, label %whilebody, label %whileexit, !dbg !13

whilebody:                                        ; preds = %while
  %x1 = load i32, ptr %x, align 4, !dbg !14
  %addtmp = add i32 %x1, 2, !dbg !14
  store i32 %addtmp, ptr %x, align 4, !dbg !14
  %i2 = load i32, ptr %i, align 4, !dbg !16
  %subtmp = sub i32 %i2, 1, !dbg !16
  store i32 %subtmp, ptr %i, align 4, !dbg !16
  br label %if, !dbg !16

whileexit:                                        ; preds = %then, %while
  %x4 = load i32, ptr %x, align 4, !dbg !17
  ret i32 %x4, !dbg !17

if:                                               ; preds = %whilebody
  %i3 = load i32, ptr %i, align 4, !dbg !18
  %eqtmp = icmp eq i32 %i3, 0, !dbg !18
  br i1 %eqtmp, label %then, label %endif, !dbg !18

then:                                             ; preds = %if
  br label %whileexit, !dbg !19

endif:                                            ; preds = %if
  br label %while, !dbg !18
}

; Function Attrs: nocallback nofree nosync nounwind speculatable willreturn memory(none)
declare void @llvm.dbg.declare(metadata, metadata, metadata) #0

attributes #0 = { nocallback nofree nosync nounwind speculatable willreturn memory(none) }

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug, splitDebugInlining: false)
!1 = !DIFile(filename: "While Loop.test", directory: "../../../../DebugFragments")

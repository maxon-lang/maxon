func main() int {
	var x = 5;
	var i = 3;
	while i > 0 {
    if (i == 3) {
      x = x + 5;
    } else {
      x = x + 2;
    }
		i--;
	}
	return x;
}
---
; ModuleID = 'main'
source_filename = "main"
target triple = "x86_64-pc-windows-msvc19.38.33133"

define i32 @main() !dbg !4 {
entry:
  %x = alloca i32, align 4, !dbg !11
  store i32 5, ptr %x, align 4, !dbg !11
  call void @llvm.dbg.declare(metadata ptr %x, metadata !9, metadata !DIExpression()), !dbg !11
  %i = alloca i32, align 4, !dbg !12
  store i32 3, ptr %i, align 4, !dbg !12
  call void @llvm.dbg.declare(metadata ptr %i, metadata !10, metadata !DIExpression()), !dbg !12
  br label %while, !dbg !12

while:                                            ; preds = %endif, %entry
  %i1 = load i32, ptr %i, align 4, !dbg !13
  %gttmp = icmp sgt i32 %i1, 0, !dbg !13
  br i1 %gttmp, label %whilebody, label %whileexit, !dbg !13

whilebody:                                        ; preds = %while
  br label %if, !dbg !13

whileexit:                                        ; preds = %while
  %x7 = load i32, ptr %x, align 4, !dbg !14
  ret i32 %x7, !dbg !14

if:                                               ; preds = %whilebody
  %i2 = load i32, ptr %i, align 4, !dbg !15
  %eqtmp = icmp eq i32 %i2, 3, !dbg !15
  br i1 %eqtmp, label %then, label %else, !dbg !15

then:                                             ; preds = %if
  %x3 = load i32, ptr %x, align 4, !dbg !17
  %addtmp = add i32 %x3, 5, !dbg !17
  store i32 %addtmp, ptr %x, align 4, !dbg !17
  br label %endif, !dbg !17

else:                                             ; preds = %if
  %x4 = load i32, ptr %x, align 4, !dbg !19
  %addtmp5 = add i32 %x4, 2, !dbg !19
  store i32 %addtmp5, ptr %x, align 4, !dbg !19
  br label %endif, !dbg !17

endif:                                            ; preds = %else, %then
  %i6 = load i32, ptr %i, align 4, !dbg !21
  %subtmp = sub i32 %i6, 1, !dbg !21
  store i32 %subtmp, ptr %i, align 4, !dbg !21
  br label %while, !dbg !21
}


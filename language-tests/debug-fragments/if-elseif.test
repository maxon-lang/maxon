function main() int
	var x = 5
	var i = 3
	while i > 0 'loop'
		if i = 3 'check1'
			x = x + 5
		else 'check1'
			if i = 2 'check2'
				x = x + 2
			end 'check2'
		end 'check1'
		i = i - 1
	end 'loop'
	return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@_fltused = constant i32 39029

define i32 @main() !dbg !4 {
entry:
  %i = alloca i32, align 4
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  store i32 3, ptr %i, align 4, !dbg !11
    #dbg_declare(ptr %i, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %ifcont10, %entry
  %i1 = load i32, ptr %i, align 4, !dbg !13
  %cmptmp = icmp sgt i32 %i1, 0, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop, !dbg !13

loop:                                             ; preds = %whilecond
  %i2 = load i32, ptr %i, align 4, !dbg !14
  %cmptmp3 = icmp eq i32 %i2, 3, !dbg !14
  br i1 %cmptmp3, label %then, label %else, !dbg !14

then:                                             ; preds = %loop
  %x4 = load i32, ptr %x, align 4, !dbg !15
  %addtmp = add i32 %x4, 5, !dbg !15
  store i32 %addtmp, ptr %x, align 4, !dbg !15
  br label %ifcont10, !dbg !15

else:                                             ; preds = %loop
  %i5 = load i32, ptr %i, align 4, !dbg !16
  %cmptmp6 = icmp eq i32 %i5, 2, !dbg !16
  br i1 %cmptmp6, label %then7, label %ifcont, !dbg !16

then7:                                            ; preds = %else
  %x8 = load i32, ptr %x, align 4, !dbg !17
  %addtmp9 = add i32 %x8, 2, !dbg !17
  store i32 %addtmp9, ptr %x, align 4, !dbg !17
  br label %ifcont, !dbg !17

ifcont:                                           ; preds = %then7, %else
  br label %ifcont10, !dbg !17

ifcont10:                                         ; preds = %ifcont, %then
  %i11 = load i32, ptr %i, align 4, !dbg !18
  %subtmp = sub i32 %i11, 1, !dbg !18
  store i32 %subtmp, ptr %i, align 4, !dbg !18
  br label %whilecond, !dbg !18

afterloop:                                        ; preds = %whilecond
  %x12 = load i32, ptr %x, align 4, !dbg !19
  ret i32 %x12, !dbg !19
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 1, type: !5, scopeLine: 1, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 2, column: 2, scope: !4)
!10 = !DILocalVariable(name: "x", scope: !4, file: !1, line: 2, type: !7, align: 32)
!11 = !DILocation(line: 3, column: 2, scope: !4)
!12 = !DILocalVariable(name: "i", scope: !4, file: !1, line: 3, type: !7, align: 32)
!13 = !DILocation(line: 4, column: 2, scope: !4)
!14 = !DILocation(line: 5, column: 3, scope: !4)
!15 = !DILocation(line: 6, column: 6, scope: !4)
!16 = !DILocation(line: 8, column: 4, scope: !4)
!17 = !DILocation(line: 9, column: 7, scope: !4)
!18 = !DILocation(line: 12, column: 5, scope: !4)
!19 = !DILocation(line: 14, column: 2, scope: !4)

function main(args []string) int
    // Check argc is 3 (program name + 2 args)
    if args.length != 3 return 1
    
    // Check first arg (program name) has reasonable length
	if args[0] != "test.exe" return 2
    
    // Check second arg is "hello"
	if args[1] != "hello" return 3
    
    // Check third arg is "world"
	if args[2] != "world" return 4
    
    return 0
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@_fltused = constant i32 39029
@.str = private constant [8 x i8] c"test.exe"
@.str.1 = private constant [5 x i8] c"hello"
@.str.2 = private constant [5 x i8] c"world"

define i32 @main(ptr %0, i32 %1) !dbg !4 {
entry:
  %args.__length = alloca i32, align 4
  %args = alloca ptr, align 8
  store ptr %0, ptr %args, align 8, !dbg !9
  store i32 %1, ptr %args.__length, align 4, !dbg !9
    #dbg_declare(ptr %args, !10, !DIExpression(), !9)
  %length = load i32, ptr %args.__length, align 4, !dbg !11
  %cmptmp = icmp ne i32 %length, 3, !dbg !11
  br i1 %cmptmp, label %then, label %ifcont, !dbg !11

then:                                             ; preds = %entry
  ret i32 1, !dbg !12

ifcont:                                           ; preds = %entry
  %arrayptr = load ptr, ptr %args, align 8, !dbg !13
  %arrayidx = getelementptr inbounds ptr, ptr %arrayptr, i32 0, !dbg !13
  %arrayelem = load ptr, ptr %arrayidx, align 8, !dbg !13
  %cmptmp1 = icmp ne ptr %arrayelem, @.str, !dbg !13
  br i1 %cmptmp1, label %then2, label %ifcont3, !dbg !13

then2:                                            ; preds = %ifcont
  ret i32 2, !dbg !14

ifcont3:                                          ; preds = %ifcont
  %arrayptr4 = load ptr, ptr %args, align 8, !dbg !15
  %arrayidx5 = getelementptr inbounds ptr, ptr %arrayptr4, i32 1, !dbg !15
  %arrayelem6 = load ptr, ptr %arrayidx5, align 8, !dbg !15
  %cmptmp7 = icmp ne ptr %arrayelem6, @.str.1, !dbg !15
  br i1 %cmptmp7, label %then8, label %ifcont9, !dbg !15

then8:                                            ; preds = %ifcont3
  ret i32 3, !dbg !16

ifcont9:                                          ; preds = %ifcont3
  %arrayptr10 = load ptr, ptr %args, align 8, !dbg !17
  %arrayidx11 = getelementptr inbounds ptr, ptr %arrayptr10, i32 2, !dbg !17
  %arrayelem12 = load ptr, ptr %arrayidx11, align 8, !dbg !17
  %cmptmp13 = icmp ne ptr %arrayelem12, @.str.2, !dbg !17
  br i1 %cmptmp13, label %then14, label %ifcont15, !dbg !17

then14:                                           ; preds = %ifcont9
  ret i32 4, !dbg !18

ifcont15:                                         ; preds = %ifcont9
  ret i32 0, !dbg !19
}

declare void @ExitProcess(i32)

declare ptr @GetCommandLineW()

declare ptr @CommandLineToArgvW(ptr, ptr)

define void @_start() {
entry:
  %0 = call ptr @GetCommandLineW()
  %1 = alloca i32, align 4
  %2 = call ptr @CommandLineToArgvW(ptr %0, ptr %1)
  %3 = load i32, ptr %1, align 4
  %4 = call i32 @main(ptr %2, i32 %3)
  call void @ExitProcess(i32 %4)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 1, type: !5, scopeLine: 1, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7, !7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 1, column: 15, scope: !4)
!10 = !DILocalVariable(name: "args", arg: 1, scope: !4, file: !1, line: 1, type: !7)
!11 = !DILocation(line: 3, column: 5, scope: !4)
!12 = !DILocation(line: 3, column: 25, scope: !4)
!13 = !DILocation(line: 6, column: 2, scope: !4)
!14 = !DILocation(line: 6, column: 27, scope: !4)
!15 = !DILocation(line: 9, column: 2, scope: !4)
!16 = !DILocation(line: 9, column: 24, scope: !4)
!17 = !DILocation(line: 12, column: 2, scope: !4)
!18 = !DILocation(line: 12, column: 24, scope: !4)
!19 = !DILocation(line: 14, column: 5, scope: !4)
---
ExitCode: 1
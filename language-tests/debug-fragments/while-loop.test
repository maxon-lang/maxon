function main() int
	var x = 5
	var i = 3
	while i > 0 'loop'
		x = x + 2
		i = i - 1
		if i = 0 'check'
			break
		end 'check'
	end 'loop'
	return x
end 'main'
---
; ModuleID = 'test.maxon'
source_filename = "test.maxon"

@_fltused = constant i32 39029

define void @__chkstk() {
entry:
  ret void
}

define i32 @main() !dbg !4 {
entry:
  %i = alloca i32, align 4
  %x = alloca i32, align 4
  store i32 5, ptr %x, align 4, !dbg !9
    #dbg_declare(ptr %x, !10, !DIExpression(), !9)
  store i32 3, ptr %i, align 4, !dbg !11
    #dbg_declare(ptr %i, !12, !DIExpression(), !11)
  br label %whilecond, !dbg !13

whilecond:                                        ; preds = %ifcont, %entry
  %i1 = load i32, ptr %i, align 4, !dbg !13
  %cmptmp = icmp sgt i32 %i1, 0, !dbg !13
  br i1 %cmptmp, label %loop, label %afterloop, !dbg !13

loop:                                             ; preds = %whilecond
  %x2 = load i32, ptr %x, align 4, !dbg !14
  %addtmp = add i32 %x2, 2, !dbg !14
  store i32 %addtmp, ptr %x, align 4, !dbg !14
  %i3 = load i32, ptr %i, align 4, !dbg !15
  %subtmp = sub i32 %i3, 1, !dbg !15
  store i32 %subtmp, ptr %i, align 4, !dbg !15
  %i4 = load i32, ptr %i, align 4, !dbg !16
  %cmptmp5 = icmp eq i32 %i4, 0, !dbg !16
  br i1 %cmptmp5, label %then, label %ifcont, !dbg !16

then:                                             ; preds = %loop
  br label %afterloop, !dbg !17

afterbreak:                                       ; No predecessors!
  br label %ifcont, !dbg !17

ifcont:                                           ; preds = %afterbreak, %loop
  br label %whilecond, !dbg !17

afterloop:                                        ; preds = %then, %whilecond
  %x6 = load i32, ptr %x, align 4, !dbg !18
  ret i32 %x6, !dbg !18
}

declare void @ExitProcess(i32)

define void @_start() {
entry:
  %0 = call i32 @main()
  call void @ExitProcess(i32 %0)
  unreachable
}

!llvm.dbg.cu = !{!0}
!llvm.module.flags = !{!2, !3}

!0 = distinct !DICompileUnit(language: DW_LANG_C, file: !1, producer: "Maxon Compiler", isOptimized: false, runtimeVersion: 0, emissionKind: FullDebug)
!1 = !DIFile(filename: "test.maxon", directory: ".")
!2 = !{i32 2, !"CodeView", i32 1}
!3 = !{i32 2, !"Debug Info Version", i32 3}
!4 = distinct !DISubprogram(name: "main", linkageName: "main", scope: !1, file: !1, line: 1, type: !5, scopeLine: 1, flags: DIFlagPrototyped, spFlags: DISPFlagDefinition, unit: !0, retainedNodes: !8)
!5 = !DISubroutineType(types: !6)
!6 = !{!7}
!7 = !DIBasicType(name: "int", size: 32, encoding: DW_ATE_signed)
!8 = !{}
!9 = !DILocation(line: 2, column: 2, scope: !4)
!10 = !DILocalVariable(name: "x", scope: !4, file: !1, line: 2, type: !7, align: 32)
!11 = !DILocation(line: 3, column: 2, scope: !4)
!12 = !DILocalVariable(name: "i", scope: !4, file: !1, line: 3, type: !7, align: 32)
!13 = !DILocation(line: 4, column: 2, scope: !4)
!14 = !DILocation(line: 5, column: 5, scope: !4)
!15 = !DILocation(line: 6, column: 5, scope: !4)
!16 = !DILocation(line: 7, column: 3, scope: !4)
!17 = !DILocation(line: 8, column: 4, scope: !4)
!18 = !DILocation(line: 11, column: 2, scope: !4)

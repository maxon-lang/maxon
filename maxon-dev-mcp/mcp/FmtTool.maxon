// `fmt` MCP tool. Wraps `./bin/maxon.exe fmt` so a client can format a
// snippet (returning the formatted text inline) or a file (formatted
// in-place on disk).
//
// Inputs (JSON):
//   source: { kind: "file", path } | { kind: "snippet", code }
//
// Output (JSON):
//   exitCode, success, durationMs, changed (true iff the formatter modified
//   the input), and — for snippets only — formatted (the formatted text).
//   File sources are rewritten in place and do NOT echo the formatted source
//   back: the caller already has the file on disk, so returning it would only
//   burn tokens. Read the file (or check `changed`) instead.

let fmtTimeoutMs = 30000
let fmtRawTailMaxBytes = 4096

/// Entry point called by Server.maxon's dispatch table.
export function fmtHandler(argsDoc JsonDoc, argsId JsonNodeId) returns ToolOutcome
	let resolved = try resolveFileSource(argsDoc, argsId: argsId, snippetPrefix: "fmt") otherwise (err) 'badSrc'
		return ToolOutcome.error(RpcStandardErrorCode.invalidParams.rawValue, message: "fmt: {sourceArgErrorReason(err)}")
	end 'badSrc'

	let repoRoot = repoRootPath()
	let csharpBinary = childPath(repoRoot, segment: "bin/maxon.exe")
	if not File.exists(csharpBinary) 'noCsharp'
		cleanupResolvedSource(resolved)
		return ToolOutcome.error(RpcStandardErrorCode.invalidRequest.rawValue, message: "fmt: `{csharpBinary.path}` does not exist. Build the C# bootstrap first via the `build` tool.")
	end 'noCsharp'

	let originalBytes = try File.readText(resolved.mainFile) otherwise 'readErr'
		cleanupResolvedSource(resolved)
		return ToolOutcome.error(RpcStandardErrorCode.internalError.rawValue, message: "fmt: cannot read input `{resolved.mainFile.path}` to compute before/after diff")
	end 'readErr'

	var argv = StringArray.create()
	argv.push("fmt")
	argv.push(resolved.mainFile.path)
	let timing = Clock.nowMs()
	let result = try Subprocess.run(Executable.path(csharpBinary), arguments: argv, workingDirectory: repoRoot, timeoutMs: fmtTimeoutMs) otherwise (err) 'spawn'
		cleanupResolvedSource(resolved)
		return ToolOutcome.error(RpcStandardErrorCode.internalError.rawValue, message: "fmt: spawn failed: {err.displayReason()}")
	end 'spawn'
	let elapsed = Clock.elapsedMs(timing)

	let formatted = try File.readText(resolved.mainFile) otherwise 'readBackErr'
		cleanupResolvedSource(resolved)
		return ToolOutcome.error(RpcStandardErrorCode.internalError.rawValue, message: "fmt: cannot read formatted output back from `{resolved.mainFile.path}`")
	end 'readBackErr'

	let changed = not originalBytes.equals(formatted)
	let outcome = buildFmtOutcome(formatted, changed: changed, includeFormatted: resolved.isSnippet, durationMs: elapsed, exitCode: result.exitCode(), output: result)
	cleanupResolvedSource(resolved)
	return outcome
end 'fmtHandler'

// =============================================================================
// Outcome construction
// =============================================================================

// `includeFormatted` controls whether the (potentially large) formatted
// source is echoed back in the response. For snippet sources it MUST be
// true — the caller has no on-disk file to read it from. For file sources
// it is false: the file was rewritten in place, so echoing the source back
// only burns tokens. Callers learn whether anything changed via `changed`.
function buildFmtOutcome(formatted String, changed bool, includeFormatted bool, durationMs DurationMs, exitCode ExitInt, output CollectedOutput) returns ToolOutcome
	var doc = JsonDoc.create()
	let exitId = doc.add(JsonNode.numberNode(exitCode))
	let successId = doc.add(JsonNode.boolNode(output.succeeded()))
	let durId = doc.add(JsonNode.numberNode(durationMs))
	let changedId = doc.add(JsonNode.boolNode(changed))
	let combined = combineStreams(output.stdout, stderr: output.stderr)
	let rawTailId = doc.add(JsonNode.stringNode(lastBytes(combined, max: fmtRawTailMaxBytes)))

	var keys = StringArray.create()
	var children = JsonNodeIdArray.create()
	keys.push("exitCode")
	children.push(exitId)
	keys.push("success")
	children.push(successId)
	keys.push("durationMs")
	children.push(durId)
	if includeFormatted 'withFormatted'
		let formattedId = doc.add(JsonNode.stringNode(formatted))
		keys.push("formatted")
		children.push(formattedId)
	end 'withFormatted'
	keys.push("changed")
	children.push(changedId)
	keys.push("rawTail")
	children.push(rawTailId)
	doc.root = doc.add(JsonNode.objectNode(keys, children: children))

	return ToolOutcome.success(doc, root: doc.root)
end 'buildFmtOutcome'

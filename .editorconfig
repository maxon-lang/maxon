# EditorConfig for Maxon compiler project
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Maxon source files and test fragments
[*.{maxon,test}]
indent_style = tab
indent_size = 2
end_of_line = lf

# C/C++ source files
[*.{c,cpp,h,hpp}]
indent_style = tab
indent_size = 2
end_of_line = lf

# TypeScript/JavaScript
[*.{ts,js}]
indent_style = tab
indent_size = 2
end_of_line = lf

# JSON files
[*.json]
indent_style = space
indent_size = 2
end_of_line = lf

# Markdown files
[*.md]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = false

# Makefiles (must use tabs)
[{Makefile,makefile,*.mk}]
indent_style = tab
end_of_line = lf

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 2
end_of_line = lf

# Windows batch files (must use CRLF)
[*.{bat,cmd}]
end_of_line = crlf

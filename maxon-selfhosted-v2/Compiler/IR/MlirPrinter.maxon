// MlirPrinter: serializes an MlirModule to human-readable text.

export function moduleToString(module MlirModule) returns String
	let lb = "\{"
	let rb = "\}"
	var sb = "module "
	sb = "{sb}{lb}\n"
	for func in module.functions 'eachFunc'
		sb = "{sb}{functionToString(func)}"
	end 'eachFunc'
	sb = "{sb}{rb}\n"
	return sb
end 'moduleToString'

function functionToString(func MlirFunction) returns String
	let lb = "\{"
	let rb = "\}"
	let funcName = String.from(func.name)
	let retType = String.from(func.returnType)
	var sb = "  func @{funcName}("

	for i in 0 upto func.paramCount 'eachParam'
		if i > 0 'comma'
			sb = "{sb}, "
		end 'comma'
		sb = "{sb}i64"
	end 'eachParam'

	sb = "{sb})"
	if not retType.isEmpty() 'hasReturn'
		if retType != "void" 'notVoid'
			sb = "{sb} -> {retType}"
		end 'notVoid'
	end 'hasReturn'
	sb = "{sb} {lb}\n"

	let blocks = func.region.blocks
	for block in blocks 'eachBlock'
		let blockLabel = String.from(block.label)
		sb = "{sb}  {blockLabel}:\n"
		for op in block.ops 'eachOp'
			let opText = opToString(op)
			sb = "{sb}    {opText}\n"
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			let termText = opToString(block.terminator)
			sb = "{sb}    {termText}\n"
		end 'hasTerm'
	end 'eachBlock'

	sb = "{sb}  {rb}\n"
	return sb
end 'functionToString'

export function opToString(op MlirOp) returns String
	return match op 'dispatch'
		maxon(hlOp) gives maxonOpToString(hlOp)
	end 'dispatch'
end 'opToString'

// Hand-written scanner for Maxon source code.
// Simple character-dispatch loop — no DFA tables.

export typealias LineNumber = int(0 to u64.max)
export typealias ColumnNumber = int(0 to u64.max)
typealias CharOffset = int(0 to u64.max)

// --- Token kind enum ---

export enum TokenKind
	// Keywords
	function
	returns
	return
	end
	// Literals
	intLiteral
	stringLiteral
	// Identifiers
	identifier
	// Punctuation
	leftParen
	rightParen
	// Structural
	newline
	eof
end 'TokenKind'

export type Token
	export let kind TokenKind
	export let value ByteArray
	export let line LineNumber
	export let column ColumnNumber
end 'Token'

export typealias TokenArray = Array with Token

// --- Lexer type ---

type Lexer
	var source ByteArray
	var tokens TokenArray
	var pos CharOffset
	var line LineNumber
	var column ColumnNumber

	// --- Navigation helpers ---

	function advance()
		pos = pos + 1
		column = column + 1
	end 'advance'

	function emit(kind TokenKind, value ByteArray, startLine LineNumber, startCol ColumnNumber)
		tokens.push(Token{kind: kind, value: value, line: startLine, column: startCol})
	end 'emit'

	// --- Sub-scanners ---

	function scanSingleQuoteString(startLine LineNumber, startCol ColumnNumber)
		let len = source.count()
		let strStart = pos
		while pos < len 'strBody'
			let c = try source.get(pos) otherwise 0
			if c == 39 'endStr'
				break
			end 'endStr'
			if c == 10 'newlineInStr'
				break
			end 'newlineInStr'
			advance()
		end 'strBody'
		let strVal = source.slice(strStart, endIndex: pos)
		if pos < len 'consumeClose'
			advance()
		end 'consumeClose'
		emit(TokenKind.stringLiteral, value: strVal, startLine: startLine, startCol: startCol)
	end 'scanSingleQuoteString'

	function scanNumber(startLine LineNumber, startCol ColumnNumber)
		let len = source.count()
		let numStart = pos
		while pos < len 'digits'
			let c = try source.get(pos) otherwise 0
			if c < 48 or c > 57 'notDigit'
				break
			end 'notDigit'
			advance()
		end 'digits'
		let numVal = source.slice(numStart, endIndex: pos)
		emit(TokenKind.intLiteral, value: numVal, startLine: startLine, startCol: startCol)
	end 'scanNumber'

	function scanIdentifier(startLine LineNumber, startCol ColumnNumber)
		let len = source.count()
		let idStart = pos
		while pos < len 'identBody'
			let c = try source.get(pos) otherwise 0
			if not isAlphaNum(c) 'endIdent'
				break
			end 'endIdent'
			advance()
		end 'identBody'
		let idVal = source.slice(idStart, endIndex: pos)
		let kind = classifyKeyword(idVal)
		emit(kind, value: idVal, startLine: startLine, startCol: startCol)
	end 'scanIdentifier'

	function skipLineComment()
		let len = source.count()
		while pos < len 'skipComment'
			let c = try source.get(pos) otherwise 0
			if c == 10 'endComment'
				break
			end 'endComment'
			pos = pos + 1
		end 'skipComment'
	end 'skipLineComment'

	// --- Main loop ---

	function run() returns TokenArray
		let len = source.count()

		while pos < len 'scan'
			let c = try source.get(pos) otherwise 0
			let startLine = line
			let startCol = column

			// Whitespace (space and tab)
			if c == 32 or c == 9 'isSpace'
				advance()
				continue
			end 'isSpace'

			// Carriage return
			if c == 13 'isCr'
				advance()
				continue
			end 'isCr'

			// Newline
			if c == 10 'isLf'
				tokens.push(Token{kind: TokenKind.newline, value: b"", line: startLine, column: startCol})
				pos = pos + 1
				line = line + 1
				column = 1
				continue
			end 'isLf'

			// Parentheses
			if c == 40 'isLParen'
				advance()
				emit(TokenKind.leftParen, value: b"(", startLine: startLine, startCol: startCol)
				continue
			end 'isLParen'
			if c == 41 'isRParen'
				advance()
				emit(TokenKind.rightParen, value: b")", startLine: startLine, startCol: startCol)
				continue
			end 'isRParen'

			// Single-quote string
			if c == 39 'isSquote'
				advance()
				scanSingleQuoteString(startLine: startLine, startCol: startCol)
				continue
			end 'isSquote'

			// Slash — could be comment
			if c == 47 'isSlash'
				if pos + 1 < len 'checkComment'
					let next = try source.get(pos + 1) otherwise 0
					if next == 47 'isComment'
						advance()
						advance()
						skipLineComment()
						continue
					end 'isComment'
				end 'checkComment'
				// Bare slash — skip for now
				advance()
				continue
			end 'isSlash'

			// Digit
			if c >= 48 and c <= 57 'isDigit'
				scanNumber(startLine: startLine, startCol: startCol)
				continue
			end 'isDigit'

			// Alpha or underscore
			if isAlpha(c) 'isAlpha'
				scanIdentifier(startLine: startLine, startCol: startCol)
				continue
			end 'isAlpha'

			// Skip unknown characters
			advance()
		end 'scan'

		emit(TokenKind.eof, value: b"", startLine: line, startCol: column)
		return tokens
	end 'run'
end 'Lexer'

// --- Public API ---

export function tokenize(source ByteArray) returns TokenArray
	var lexer = Lexer{source: source, tokens: TokenArray{}, pos: 0, line: 1, column: 1}
	return lexer.run()
end 'tokenize'

// --- Pure helpers ---

function isAlpha(b Byte) returns bool
	return (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or b == 95
end 'isAlpha'

function isAlphaNum(b Byte) returns bool
	return isAlpha(b) or (b >= 48 and b <= 57)
end 'isAlphaNum'

function classifyKeyword(name ByteArray) returns TokenKind
	if name == b"function" 'isFunction'
		return TokenKind.function
	end 'isFunction'
	if name == b"returns" 'isReturns'
		return TokenKind.returns
	end 'isReturns'
	if name == b"return" 'isReturn'
		return TokenKind.return
	end 'isReturn'
	if name == b"end" 'isEnd'
		return TokenKind.end
	end 'isEnd'
	return TokenKind.identifier
end 'classifyKeyword'

// Dialect operations as enums with associated values.

// --- Maxon Dialect Operations ---

export enum MaxonOp
    literal(resultId int, value int)
    returnOp(retValId int)
end 'MaxonOp'

// --- Standard Dialect Operations ---

export enum StdOp
    constI64(resultId int, value int)
    returnOp(retValId int)
end 'StdOp'

// --- X86 Dialect ---

export enum X86Register
    rax
    rcx
    rdx
    rbx
    rsp
    rbp
    rsi
    rdi
    r8
    r9
    r10
    r11
end 'X86Register'

export enum X86Op
    prologue(stackSize int)
    epilogue
    movRegImm(dest X86Register, value int)
end 'X86Op'

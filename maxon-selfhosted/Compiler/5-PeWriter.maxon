// PE64 file writer for Windows executables.
// Produces a minimal PE with .text and .idata sections.

export typealias ByteCount = int(0 to u64.max)
export typealias ByteOffset = int(0 to u64.max)
typealias Rva = int(0 to u64.max)
typealias IatSlotIndex = int(0 to u64.max)
typealias SectionFlags = int(0 to u64.max)

// --- ByteBuffer multi-byte write helpers ---

export function writeWord(buf ByteBuffer, value MachineWord)
    buf.push(value and 0xFF)
    buf.push((value shr 8) and 0xFF)
end 'writeWord'

export function writeDword(buf ByteBuffer, value MachineWord)
    buf.push(value and 0xFF)
    buf.push((value shr 8) and 0xFF)
    buf.push((value shr 16) and 0xFF)
    buf.push((value shr 24) and 0xFF)
end 'writeDword'

export function writeQword(buf ByteBuffer, value MachineWord)
    buf.push(value and 0xFF)
    buf.push((value shr 8) and 0xFF)
    buf.push((value shr 16) and 0xFF)
    buf.push((value shr 24) and 0xFF)
    buf.push((value shr 32) and 0xFF)
    buf.push((value shr 40) and 0xFF)
    buf.push((value shr 48) and 0xFF)
    buf.push((value shr 56) and 0xFF)
end 'writeQword'

export function writeZeros(buf ByteBuffer, n ByteCount)
    var i = 0
    while i < n 'zeros'
        buf.push(0)
        i = i + 1
    end 'zeros'
end 'writeZeros'

export function writeAscii(buf ByteBuffer, text String)
    for ch in text 'chars'
        let b = try ch.asciiValue() otherwise 0
        buf.push(b)
    end 'chars'
    buf.push(0)
end 'writeAscii'

export function padTo(buf ByteBuffer, size ByteCount)
    while buf.count() < size 'pad'
        buf.push(0)
    end 'pad'
end 'padTo'

export function patchDword(buf ByteBuffer, offset ByteOffset, value MachineWord)
    buf.set(offset, value: value and 0xFF)
    buf.set(offset + 1, value: (value shr 8) and 0xFF)
    buf.set(offset + 2, value: (value shr 16) and 0xFF)
    buf.set(offset + 3, value: (value shr 24) and 0xFF)
end 'patchDword'

let FILE_ALIGNMENT = 512
let SECTION_ALIGNMENT = 4096

export function alignUp(value ByteCount, alignment ByteCount) returns ByteCount
    return (value + alignment - 1) and not (alignment - 1)
end 'alignUp'

// --- Import section builder ---
// IAT slot indices for kernel32.dll imports
let IAT_SLOT_EXIT_PROCESS = 0
let IAT_SLOT_GET_STD_HANDLE = 1
let IAT_SLOT_WRITE_FILE = 2

type ImportSection
    export var data ByteBuffer
    export var iatRva Rva
    export var importDirRva Rva
    export var importDirSize ByteCount
end 'ImportSection'

export type IatFixup
    export var codeOffset CodeOffset
    export var iatSlotIndex IatSlotIndex
end 'IatFixup'


function buildImportSection(idataRva Rva) returns ImportSection
    var data = ByteBuffer{}
    data.reserve(256)

    let iatOffset = 0
    let iltOffset = 32
    let importDirOffset = 64
    let hintNameOffset = 104
    let hintExitProcess = hintNameOffset
    let hintGetStdHandle = hintExitProcess + 14
    let hintWriteFile = hintGetStdHandle + 16
    let dllNameOffset = hintWriteFile + 12

    // IAT entries: point to hint/name table entries
    writeQword(data, value: idataRva + hintExitProcess)
    writeQword(data, value: idataRva + hintGetStdHandle)
    writeQword(data, value: idataRva + hintWriteFile)
    writeQword(data, value: 0)

    // ILT entries: same as IAT
    writeQword(data, value: idataRva + hintExitProcess)
    writeQword(data, value: idataRva + hintGetStdHandle)
    writeQword(data, value: idataRva + hintWriteFile)
    writeQword(data, value: 0)

    // Import Directory entry
    writeDword(data, value: idataRva + iltOffset)
    writeDword(data, value: 0)
    writeDword(data, value: 0)
    writeDword(data, value: idataRva + dllNameOffset)
    writeDword(data, value: idataRva + iatOffset)

    // Import Directory null terminator
    writeZeros(data, n: 20)

    // Hint/Name table
    writeWord(data, value: 0)
    writeAscii(data, text: "ExitProcess")

    writeWord(data, value: 0)
    writeAscii(data, text: "GetStdHandle")
    data.push(0) // pad to even boundary

    writeWord(data, value: 0)
    writeAscii(data, text: "WriteFile")

    // DLL name
    writeAscii(data, text: "kernel32.dll")

    return {
        data: data,
        iatRva: idataRva + iatOffset,
        importDirRva: idataRva + importDirOffset,
        importDirSize: 20
    }
end 'buildImportSection'

// --- Section header writer ---

function writeSectionName(buf ByteBuffer, name String)
    var written = 0
    for ch in name 'chars'
        let b = try ch.asciiValue() otherwise 0
        buf.push(b)
        written = written + 1
    end 'chars'
    while written < 8 'pad'
        buf.push(0)
        written = written + 1
    end 'pad'
end 'writeSectionName'

function writeSectionHeader(buf ByteBuffer, name String, virtualSize ByteCount, virtualAddress Rva, rawDataSize ByteCount, rawDataPointer ByteOffset, characteristics SectionFlags)
    writeSectionName(buf, name: name)
    writeDword(buf, value: virtualSize)
    writeDword(buf, value: virtualAddress)
    writeDword(buf, value: rawDataSize)
    writeDword(buf, value: rawDataPointer)
    writeDword(buf, value: 0)
    writeDword(buf, value: 0)
    writeWord(buf, value: 0)
    writeWord(buf, value: 0)
    writeDword(buf, value: characteristics)
end 'writeSectionHeader'

// --- Main PE writer ---

export type CodeResult
    export var code ByteBuffer
    export var mainCallFixupOffset CodeOffset
    export var iatFixups IatFixupArray
end 'CodeResult'

export function writePe(outputPath String, codeResult CodeResult)
    logDebug(LogCategory.pe, message: "Writing PE file: {outputPath}")
    var pe = ByteBuffer{}
    pe.reserve(4096)

    var code = codeResult.code
    let codeSize = code.count()
    let numSections = 2

    // Header sizes
    let headersSize = 64 + 4 + 20 + 240 + (40 * numSections)
    let headersAligned = alignUp(headersSize, alignment: FILE_ALIGNMENT)

    // .text section
    let codeSizeAligned = alignUp(codeSize, alignment: FILE_ALIGNMENT)
    let codeSizeVirtual = alignUp(codeSize, alignment: SECTION_ALIGNMENT)
    let textRva = SECTION_ALIGNMENT

    // .idata section
    let idataRva = textRva + codeSizeVirtual
    let idata = buildImportSection(idataRva)
    let idataSize = idata.data.count()
    let idataSizeAligned = alignUp(idataSize, alignment: FILE_ALIGNMENT)
    let idataSizeVirtual = alignUp(idataSize, alignment: SECTION_ALIGNMENT)

    let imageSize = idataRva + idataSizeVirtual

    logDebug(LogCategory.pe, message: "Code section: {codeSize} bytes")
    logDebug(LogCategory.pe, message: "Import section: {idataSize} bytes")

    // Patch all IAT RIP-relative references in code
    for fixup in codeResult.iatFixups 'patchIat'
        let ripAtFixup = textRva + fixup.codeOffset + 4
        let iatEntryRva = idataRva + (fixup.iatSlotIndex * 8)
        let iatRel = iatEntryRva - ripAtFixup
        patchDword(code, offset: fixup.codeOffset, value: iatRel)
    end 'patchIat'

    // IAT directory size: 3 entries + null terminator = 32 bytes
    let iatDirSize = 32

    // === DOS Header (64 bytes) ===
    writeWord(pe, value: 0x5A4D)
    writeZeros(pe, n: 58)
    writeDword(pe, value: 64)

    // === PE Signature ===
    writeDword(pe, value: 0x00004550)

    // === COFF Header (20 bytes) ===
    writeWord(pe, value: 0x8664)
    writeWord(pe, value: numSections)
    writeDword(pe, value: 0)
    writeDword(pe, value: 0)
    writeDword(pe, value: 0)
    writeWord(pe, value: 240)
    writeWord(pe, value: 0x22)

    // === Optional Header PE32+ (240 bytes) ===
    writeWord(pe, value: 0x20B)
    pe.push(14)
    pe.push(0)
    writeDword(pe, value: codeSizeAligned)
    writeDword(pe, value: idataSizeAligned)
    writeDword(pe, value: 0)
    writeDword(pe, value: textRva)
    writeDword(pe, value: textRva)

    // PE32+ additional fields
    writeQword(pe, value: 0x140000000)
    writeDword(pe, value: SECTION_ALIGNMENT)
    writeDword(pe, value: FILE_ALIGNMENT)
    writeWord(pe, value: 6)
    writeWord(pe, value: 0)
    writeWord(pe, value: 0)
    writeWord(pe, value: 0)
    writeWord(pe, value: 6)
    writeWord(pe, value: 0)
    writeDword(pe, value: 0)
    writeDword(pe, value: imageSize)
    writeDword(pe, value: headersAligned)
    writeDword(pe, value: 0)
    writeWord(pe, value: 3)
    writeWord(pe, value: 0x8160)
    writeQword(pe, value: 0x100000)
    writeQword(pe, value: 0x1000)
    writeQword(pe, value: 0x100000)
    writeQword(pe, value: 0x1000)
    writeDword(pe, value: 0)
    writeDword(pe, value: 16)

    // Data directories (16 entries, 8 bytes each)
    // 0: Export Table
    writeDword(pe, value: 0)
    writeDword(pe, value: 0)
    // 1: Import Table
    writeDword(pe, value: idata.importDirRva)
    writeDword(pe, value: idata.importDirSize)
    // 2-11: zeros
    writeZeros(pe, n: 80)
    // 12: IAT
    writeDword(pe, value: idata.iatRva)
    writeDword(pe, value: iatDirSize)
    // 13-15: zeros
    writeZeros(pe, n: 24)

    // === Section Headers ===
    writeSectionHeader(pe, name: ".text", virtualSize: codeSize, virtualAddress: textRva, rawDataSize: codeSizeAligned, rawDataPointer: headersAligned, characteristics: 0x60000020)
    writeSectionHeader(pe, name: ".idata", virtualSize: idataSize, virtualAddress: idataRva, rawDataSize: idataSizeAligned, rawDataPointer: headersAligned + codeSizeAligned, characteristics: 0xC0000040)

    // Pad headers to alignment
    padTo(pe, size: headersAligned)

    // === .text section ===
    pe.append(code)
    padTo(pe, size: headersAligned + codeSizeAligned)

    // === .idata section ===
    pe.append(idata.data)
    padTo(pe, size: headersAligned + codeSizeAligned + idataSizeAligned)

    // Write to file
    try File.writeBinary(outputPath, content: pe) otherwise ignore
    logDebug(LogCategory.pe, message: "PE write complete: {pe.count()} bytes total")
end 'writePe'

// Structured error codes and error formatting for the compiler.
// Mirrors maxon-sharp ErrorCode.cs and CompileError.cs.

// Error codes grouped by compilation stage:
// - 1xxx: Lexer errors
// - 2xxx: Parser errors
// - 3xxx: Semantic analysis errors
// - 4xxx: IR pipeline errors
// - 5xxx: Code emitter errors
// - 6xxx: PE writer errors
export union ErrorCode
	lexerUnexpectedCharacter = 1001
	lexerUnterminatedString = 1002
	lexerInvalidEscape = 1004
	lexerUnescapedBrace = 1006
	lexerUnterminatedBlockComment = 1007
	parserUnexpectedToken = 2001
	parserExpectedType = 2003
	parserExpectedExpression = 2004
	parserUnexpectedEof = 2007
	parserExpectedToken = 2010
	parserLiteralOverflow = 2011
	parserCircularDependency = 2012
	parserImmutableVariable = 2013
	parserMatchFallthroughWithReturn = 2025
	parserMatchNotExhaustive = 2026
	parserMatchDuplicatePattern = 2027
	// E2028: a match arm or postfix-ternary's two arms produce different types,
	// or a ternary condition is not bool. Mirrors the C# bootstrap's
	// ParserMatchTypeMismatch — thrown at parse time so it wins over the
	// body-finish unused-variable check (E3012).
	parserMatchTypeMismatch = 2028
	parserMatchDefaultNotLast = 2029
	parserMatchMissingBlockId = 2042
	parserMatchMismatchedBlockId = 2043
	parserNonConstantInitializer = 2045
	parserMatchDefaultEnumMustThrow = 2046
	// Phase 9 Stage 0: a match arm body cannot be a block-opening
	// statement (`if` / `while` / `for` / `match` / block-form `try`).
	// Each arm body is a single statement; block-form constructs would
	// allocate persistent slots that leak on every error path through
	// the match.
	parserMatchBlockStatementNotAllowed = 2049
	parserReservedIdentifier = 2051
	// E2052: a call site labeled its first argument (`f(name: value, ...)`).
	// The first argument is positional-only; only the second and subsequent
	// arguments may be labeled.
	parserFirstArgCannotBeNamed = 2052
	semanticNoMain = 3001
	semanticMainWrongReturnType = 3002
	semanticUndefinedVariable = 3003
	semanticEqualsRequiresEquatable = 3004
	semanticTypeMismatch = 3005
	// E3006: a duplicate definition or a local-vs-self-field shadow. Two
	// shapes share the code: (a) two function definitions with the same
	// name and signature — fires from `reportDuplicateFunction` in the
	// parser for same-file duplicates and from the project-level main
	// registration for cross-file `main` collisions; (b) a local
	// declaration inside an instance method whose name collides with a
	// `self.field` (matches the C# bootstrap's broader interpretation of
	// "duplicate definition" — the local would silently shadow the field).
	semanticDuplicateDefinition = 3006
	// E3007: call site cannot pick a unique overload because multiple
	// variants have indistinguishable signatures at this call. Emitted when
	// two overloads share the same parameter types and the caller doesn't
	// disambiguate with named arguments. Matches the C# bootstrap wording.
	semanticAmbiguousOverload = 3007
	semanticSymbolNotExported = 3008
	semanticInvalidCast = 3009
	semanticUnneededCast = 3010
	semanticUnknownType = 3011
	semanticUnusedVariable = 3012
	semanticMissingReturn = 3013
	// E3014 (was internally `semanticTypeResolutionCycle` while the
	// unexported-field-access check was unimplemented). Bootstrap parity
	// reclaims 3014 for the field-visibility diagnostic; the typealias-cycle
	// diagnostic moves to 3091 (a code unused on both sides).
	semanticUnexportedFieldAccess = 3014
	semanticUnknownInterface = 3015
	semanticPartialInterfaceImpl = 3016
	semanticConstraintViolation = 3017
	semanticEnumDuplicateCase = 3030
	semanticEnumDuplicateRawValue = 3031
	semanticEnumRawValueTypeMismatch = 3032
	semanticEnumUnknownCase = 3034
	// E3035: a match-arm payload-binding pattern (`case(x, y)`) supplies
	// the wrong number of bindings for the case's declared payload. Emitted
	// by `parseCaseBindingPattern` when an arity check can be performed at
	// parse time, or deferred to TypeResolution when the case's owning
	// union isn't yet known.
	semanticMatchPayloadArityMismatch = 3035
	semanticWrongArgCount = 3036
	semanticMatchDiscardedBindings = 3081
	// E3082: a labeled control-flow block (`if`/`else`/`while`/`for`) has no
	// statements between its header and matching `end`. The C# bootstrap
	// rejects this so dead control-flow can't sneak past a refactor; emitted
	// from `parseBodyOrEmpty` after `parseScopedStatements` reports no
	// statements were consumed.
	semanticEmptyBlock = 3082
	// E3067: a textual self-assignment (`x = x`, `p.x = p.x`) or a
	// discard-assignment whose RHS isn't a function call (`_ = 42`). The
	// former has no effect; the latter is the historic shape for opting out
	// of a "discarded result" warning, but a non-call RHS makes the discard
	// nonsensical. Emitted from `parseVarAssignment`,
	// `parseLocalFieldAssignment`, and `parseDiscardAssignment`.
	semanticSelfAssignment = 3067
	// E2048: `break 'lab'` / `continue 'lab'` where `lab` names the
	// innermost enclosing loop (with no intervening match for `break`). The
	// label is redundant — unlabeled `break`/`continue` already targets
	// that loop. Emitted from `resolveBreakTarget` / `resolveContinueTarget`.
	parserRedundantLoopLabel = 2048
	// E3087: an `if x.contains(k)` whose then-block immediately performs
	// `try x.get(k) otherwise ...` on the same receiver/key pair does the
	// lookup twice. The compiler asks the user to rewrite as `if let v =
	// try x.get(k) ... 'lbl'` (or `if var`) so a single lookup serves both
	// the membership test and the value bind.
	semanticRedundantContainsGet = 3087
	semanticSymbolNotInModuleScope = 3088
	semanticTypeResolutionLeak = 3089
	semanticTypeResolutionCycle = 3091
	semanticMainCannotThrow = 3054
	semanticTryRequiresThrowingFunction = 3055
	// E3075: qualified enum case names (`Color.red`) aren't allowed in
	// match arms — the scrutinee's enum is known so the bare case name
	// suffices.
	semanticMatchQualifiedCaseName = 3075
	semanticThrowingFunctionRequiresTry = 3057
	semanticOtherwiseRequiresTry = 3058
	semanticOtherwiseTypeMismatch = 3059
	semanticDuplicateTypeAlias = 3061
	semanticUnusedTypeAlias = 3062
	// E3063: a bare-name type reference has more than one reachable
	// typealias definition under directory-as-module rules. The user must
	// write the directory-qualified form (`dir.Name`) to disambiguate.
	// Mirrors E3095 (functions) but operates on the typealias registry.
	semanticAmbiguousTypeAlias = 3063
	// E3064: a pure-function call's result was discarded. Pure callees must
	// have their result used — neither bare `foo()` nor `_ = foo()` is
	// permitted. Fires from `checkDiscardedResults`.
	semanticDiscardedPureResult = 3064
	// E3065: an impure-function call's result was discarded without the
	// explicit `_ =` opt-in. The impure-call result still has to flow into
	// either a binding (`let r = foo()`) or an explicit discard
	// (`_ = foo()`). Fires from `checkDiscardedResults`.
	semanticDiscardedImpureResult = 3065
	// E3092: an `export` (global) decl is never referenced from any file
	// outside its declaring file. The decl could be file-private (drop the
	// modifier) or `module`-visible. Applies to functions, types, enums,
	// typealiases, top-level constants, top-level vars, and exported struct
	// fields. Emitted by `checkUnusedExports` after all files have been
	// parsed and type-resolved.
	semanticUnusedExportedSymbol = 3092
	// E3093: an `export` (global) decl is referenced only from files inside
	// its declaring directory subtree. The decl could be downgraded to
	// `module`-visible. Emitted by `checkUnusedExports`.
	semanticExportableAsModule = 3093
	// E3094: a `module` decl is never referenced from any file other than
	// the one it was declared in. The decl could be file-private (drop the
	// `module` modifier). Emitted by `checkUnusedExports`.
	semanticUnusedModuleSymbol = 3094
	// E3095: a bare-name function call has more than one reachable
	// definition under directory-as-module rules. The user must write the
	// directory-qualified form (`dir.name()`) to disambiguate. Emitted by
	// the cross-file fallback in `qualifyCalleeForContextWithType` when
	// `methodNameIndex` returns multiple distinct visible candidates.
	semanticAmbiguousCrossFileCall = 3095
	// E3070: borrow conflict — a collection was mutated (e.g. `arr.push(x)`)
	// while a reference into its backing buffer is still live (e.g.
	// `let s = try arr.get(0) ...`). A growth could reallocate the buffer
	// and dangle the outstanding reference. Emitted by the Maxon-tier
	// `runMaxonBorrowCheck` pass. Mirrors the C# bootstrap's
	// `SemanticBorrowConflict` (same code, same message format).
	semanticBorrowConflict = 3070
	// E3072: a struct-literal names a compiler builtin managed type
	// (`__ManagedFile`, `__ManagedMemory`, `__ManagedDirectory`, ...). These
	// carry an opaque runtime handle and must be obtained through their static
	// factory methods (e.g. `__ManagedFile.openRead`), never built directly.
	// Emitted by the parser at the struct-literal site. Mirrors the C#
	// bootstrap's `SemanticBuiltinTypeConstruction`.
	semanticBuiltinTypeConstruction = 3072
	// E3077: a local declared with `var` is never reassigned, so it should
	// be a `let`. Detected after type resolution by
	// `checkVarShouldBeLetForEntry` (a `var` whose name never appears in the
	// per-function reassigned-var set). E3012 (unused variable) takes
	// precedence — an unused `var` reports as unused, not as should-be-let.
	// Mirrors the C# bootstrap's `SemanticVarShouldBeLet`.
	semanticVarShouldBeLet = 3077
	// E3078: `var b = a` (or `var b = a.field`) where the source `a` is an
	// immutable (`let`) binding of a reference type (struct / enum /
	// function). Copying an immutable reference-type binding into a mutable
	// one would alias the same heap value through a writable name; the user
	// must either keep `b` immutable (`let`) or take an independent copy via
	// `clone()`. Value-typed sources (int/float/bool/byte) are independent
	// copies and are allowed. Detected after type resolution by
	// `checkVarFromImmutableForEntry`. Mirrors the C# bootstrap's
	// `SemanticVarFromImmutable`.
	semanticVarFromImmutable = 3078
	irInvalidFieldAccess = 4006
	// E4014: a type definition contains a reference cycle — it transitively
	// contains itself through struct fields, union associated values, or
	// container element types. Maxon's ownership model requires acyclic type
	// graphs for deterministic destruction, so recursive type references are
	// rejected. Emitted by the type-cycle check after type resolution. Mirrors
	// the C# bootstrap's `IrTypeCycle` (same code, same message format).
	irTypeCycle = 4014
	// E4099: internal compiler-invariant violation — a `call` / `methodCall`
	// / `tryCall` / `tryMethodCall` op survived past TypeResolution without an
	// entry in `project.resolvedCallees` and without an "intentionally dynamic"
	// dispatch shape (interface receiver / type-parameter receiver). Indicates
	// a resolver-or-propagation gap; surfacing it here catches future
	// regressions before lowering trips its own panic.
	irUnresolvedCall = 4099
end 'ErrorCode'

// A single diagnostic (error) collected during compilation.
export type Diagnostic
	export let code as ErrorCode
	export let message as String
	export let line as LineNumber
	export let column as ColumnNumber
	export let filePath as FilePath

	export static function create(code ErrorCode, message String, line LineNumber, column ColumnNumber, filePath FilePath) returns Diagnostic
		return Self{code: code, message: message, line: line, column: column, filePath: filePath}
	end 'create'
end 'Diagnostic'

export typealias DiagnosticArray = Array with Diagnostic

// Reports a compile error with source location. Appends to the project's
// diagnostics list and logs to stderr, but does NOT throw.
//
// Parser-cascade gate: the self-hosted parser uses an error-and-recover
// strategy where one user mistake (truncated input, mistyped keyword, etc.)
// cascades — the recovery walks the cursor forward, and downstream
// expect/end checks (and later semantic passes inspecting the partial IR)
// emit follow-up errors that are all artifacts of the original mistake.
// The recovery is load-bearing for the lexer-parser-robustness suite; we
// keep it but suppress the resulting noise. C# bootstrap reports a single
// error per file via throw-and-unwind; this gate gives parity.
//
// Specifically: once a lexer- (1xxx), parser- (2xxx), or IR/borrow-stage
// (4xxx) error has been recorded for `filePath`, every subsequent semantic
// error (3xxx) for that file is dropped — semantic checks operate on a
// partially-parsed/lowered module and are downstream noise once the
// upstream stages have already complained. Tests that assert multiple
// errors (e.g. `void-function-unused` with two independent semantic
// problems) still work because they have no upstream error first.
export function reportCompileError(project Project, code ErrorCode, message String, line LineNumber, column ColumnNumber, filePath FilePath)
	let newIsSemantic = code.rawValue >= 3000 and code.rawValue < 4000
	for d in project.diagnostics 'firstErrorGate'
		let existingIsLexParser = d.code.rawValue >= 1000 and d.code.rawValue < 3000
		let existingIsIr = d.code.rawValue >= 4000 and d.code.rawValue < 5000
		if (existingIsLexParser or (existingIsIr and newIsSemantic)) and d.filePath == filePath 'sameFile'
			return
		end 'sameFile'
	end 'firstErrorGate'
	logError(LogCategory.compiler, message: function() gives "error E{code.rawValue:04}: {filePath}:{line}:{column}: {message}")
	project.diagnostics.push(Diagnostic.create(code, message: message, line: line, column: column, filePath: filePath))
end 'reportCompileError'

// Reports a semantic error without source location. Appends to the project's
// diagnostics list and logs to stderr, but does NOT throw.
export function reportSemanticError(project Project, code ErrorCode, message String)
	logError(LogCategory.compiler, message: function() gives "error E{code.rawValue:04}: {message}")
	project.diagnostics.push(Diagnostic.create(code, message: message, line: 0, column: 0, filePath: FilePath from ""))
end 'reportSemanticError'

export union CompileError implements Error
	fileNotFound(path FilePath)
	directoryNotFound(path FilePath)
	noSourceFiles(root FilePath)
	readError(path FilePath)
	compileError
end 'CompileError'

// PE64 file writer for Windows executables.
// Produces a minimal PE with .text, .rdata, .symtab, .idata, and .data sections.

typealias Rva = int(0 to u64.max)
typealias SectionFlags = int(0 to u64.max)

let FILE_ALIGNMENT = 512
let SECTION_ALIGNMENT = 4096

// Size of the writable .data section (heap arena for bump allocator).
let DATA_SECTION_VIRTUAL_SIZE = 65536

// --- Import section builder ---
// IAT slot indices for kernel32.dll / shell32.dll imports. Must stay in sync
// with the identically-named constants in
// Compiler/Targets/X64/MirToX64Conversion.maxon.
let IAT_SLOT_EXIT_PROCESS = 0
let IAT_SLOT_GET_STD_HANDLE = 1
let IAT_SLOT_WRITE_FILE = 2
let IAT_SLOT_READ_FILE = 3
let IAT_SLOT_CREATE_FILE_A = 4
let IAT_SLOT_CLOSE_HANDLE = 5
let IAT_SLOT_GET_ENVIRONMENT_VARIABLE_A = 6
let IAT_SLOT_VIRTUAL_ALLOC = 7
let IAT_SLOT_VIRTUAL_FREE = 8
let IAT_SLOT_INITIALIZE_CRITICAL_SECTION = 9
let IAT_SLOT_ENTER_CRITICAL_SECTION = 10
let IAT_SLOT_LEAVE_CRITICAL_SECTION = 11
// Phase 15b: command-line argument retrieval.
let IAT_SLOT_GET_COMMAND_LINE_W = 12
let IAT_SLOT_LOCAL_FREE = 13
let IAT_SLOT_WIDE_CHAR_TO_MULTI_BYTE = 14
// Phase 15f: executable-path retrieval. kernel32!GetModuleFileNameW writes the
// running module's path into a caller-supplied UTF-16 buffer; the runtime
// helper then re-encodes via WideCharToMultiByte (slot 13). Kernel32 slot.
let IAT_SLOT_GET_MODULE_FILE_NAME_W = 15
// shell32.dll's CommandLineToArgvW. Lives in a second DLL import directory.
let IAT_SLOT_COMMAND_LINE_TO_ARGV_W = 16
let IAT_SLOT_COUNT = 17

type ImportSection
	export var data ByteArray
	export var iatRva Rva
	export var importDirRva Rva
	export var importDirSize ByteCount

	static function create(data ByteArray, iatRva Rva, importDirRva Rva, importDirSize ByteCount) returns ImportSection
		return Self{data: data, iatRva: iatRva, importDirRva: importDirRva, importDirSize: importDirSize}
	end 'create'
end 'ImportSection'

// Number of import-directory entries (kernel32, shell32). The flat IAT
// is split into two per-DLL runs: kernel32 takes slots 0..KERNEL32_END-1
// and shell32 takes slot SHELL32_START..IAT_SLOT_COUNT-1. Each run gets
// its own null terminator, so the table layout is:
//   IAT  [k32 entries] 0  [s32 entries] 0
//   ILT  [k32 entries] 0  [s32 entries] 0
// followed by the Import Directory (3 entries: kernel32, shell32, null).
let KERNEL32_IAT_END = 16  // exclusive; slots 0..15 are kernel32
let SHELL32_IAT_START = 16 // slot 16 is shell32 (CommandLineToArgvW)
let IMPORT_DIRECTORY_ENTRIES = 2

function buildImportSection(idataRva Rva) returns ImportSection
	var data = ByteArray.create()
	data.reserve(512)

	// Per-DLL slot count for kernel32; shell32's count is implicit in the
	// run that follows. Each per-DLL run gets its own trailing null
	// terminator in IAT/ILT so the loader stops at the right place.
	let kernel32Count = KERNEL32_IAT_END
	// Total table size: every slot + one null terminator per DLL.
	let tableBytes = (IAT_SLOT_COUNT + IMPORT_DIRECTORY_ENTRIES) * 8
	let iatOffset = 0
	let iltOffset = tableBytes
	let importDirOffset = tableBytes * 2
	// Import directory: 2 entries (kernel32, shell32) + 1 null = 60 bytes.
	let hintNameOffset = importDirOffset + 20 * (IMPORT_DIRECTORY_ENTRIES + 1)
	let hintExitProcess = hintNameOffset
	let hintGetStdHandle = hintExitProcess + 14
	let hintWriteFile = hintGetStdHandle + 16
	// "ReadFile\0" = 9; with leading 2-byte hint and pad to even → 12.
	let hintReadFile = hintWriteFile + 12
	let hintCreateFileA = hintReadFile + 12
	let hintCloseHandle = hintCreateFileA + 14
	let hintGetEnvironmentVariableA = hintCloseHandle + 14
	let hintVirtualAlloc = hintGetEnvironmentVariableA + 26
	let hintVirtualFree = hintVirtualAlloc + 16
	let hintInitializeCriticalSection = hintVirtualFree + 14
	let hintEnterCriticalSection = hintInitializeCriticalSection + 28
	let hintLeaveCriticalSection = hintEnterCriticalSection + 24
	// New kernel32 entries for Phase 15b. Name byte counts:
	// "GetCommandLineW\0" = 16; "LocalFree\0" = 10; "WideCharToMultiByte\0" = 20.
	// Each preceded by `\x00\x00` hint (2 bytes), padded to even total.
	let hintGetCommandLineW = hintLeaveCriticalSection + 24
	let hintLocalFree = hintGetCommandLineW + 18
	let hintWideCharToMultiByte = hintLocalFree + 12
	// Phase 15f: "GetModuleFileNameW\0" = 19 → padded to 20 with the leading hint.
	let hintGetModuleFileNameW = hintWideCharToMultiByte + 22
	// shell32 entry. "CommandLineToArgvW\0" = 19 → padded to 20 with leading hint.
	let hintCommandLineToArgvW = hintGetModuleFileNameW + 22
	let kernel32DllNameOffset = hintCommandLineToArgvW + 22
	// "kernel32.dll\0" is 13 bytes — no pad needed; the next entry is the
	// shell32 DLL name string at offset +13.
	let shell32DllNameOffset = kernel32DllNameOffset + 13

	// IAT entries: kernel32 run, null terminator, shell32 run, null terminator.
	writeQword(data, value: idataRva + hintExitProcess)
	writeQword(data, value: idataRva + hintGetStdHandle)
	writeQword(data, value: idataRva + hintWriteFile)
	writeQword(data, value: idataRva + hintReadFile)
	writeQword(data, value: idataRva + hintCreateFileA)
	writeQword(data, value: idataRva + hintCloseHandle)
	writeQword(data, value: idataRva + hintGetEnvironmentVariableA)
	writeQword(data, value: idataRva + hintVirtualAlloc)
	writeQword(data, value: idataRva + hintVirtualFree)
	writeQword(data, value: idataRva + hintInitializeCriticalSection)
	writeQword(data, value: idataRva + hintEnterCriticalSection)
	writeQword(data, value: idataRva + hintLeaveCriticalSection)
	writeQword(data, value: idataRva + hintGetCommandLineW)
	writeQword(data, value: idataRva + hintLocalFree)
	writeQword(data, value: idataRva + hintWideCharToMultiByte)
	writeQword(data, value: idataRva + hintGetModuleFileNameW)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeQword(data, value: idataRva + hintCommandLineToArgvW)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")

	// ILT entries: same as IAT.
	writeQword(data, value: idataRva + hintExitProcess)
	writeQword(data, value: idataRva + hintGetStdHandle)
	writeQword(data, value: idataRva + hintWriteFile)
	writeQword(data, value: idataRva + hintReadFile)
	writeQword(data, value: idataRva + hintCreateFileA)
	writeQword(data, value: idataRva + hintCloseHandle)
	writeQword(data, value: idataRva + hintGetEnvironmentVariableA)
	writeQword(data, value: idataRva + hintVirtualAlloc)
	writeQword(data, value: idataRva + hintVirtualFree)
	writeQword(data, value: idataRva + hintInitializeCriticalSection)
	writeQword(data, value: idataRva + hintEnterCriticalSection)
	writeQword(data, value: idataRva + hintLeaveCriticalSection)
	writeQword(data, value: idataRva + hintGetCommandLineW)
	writeQword(data, value: idataRva + hintLocalFree)
	writeQword(data, value: idataRva + hintWideCharToMultiByte)
	writeQword(data, value: idataRva + hintGetModuleFileNameW)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeQword(data, value: idataRva + hintCommandLineToArgvW)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")

	// Per-DLL Import Directory entries. Each: 4-byte OriginalFirstThunk
	// (ILT RVA), 8-byte zeros (TimeDateStamp, ForwarderChain), 4-byte
	// Name RVA, 4-byte FirstThunk (IAT RVA).
	// kernel32 occupies offsets [0..kernel32Count*8) inside IAT and ILT.
	let kernel32IatRva = idataRva + iatOffset
	let kernel32IltRva = idataRva + iltOffset
	// shell32 begins one null terminator (8 bytes) after the kernel32 run.
	let shell32IatRva = kernel32IatRva + (kernel32Count + 1) * 8
	let shell32IltRva = kernel32IltRva + (kernel32Count + 1) * 8

	writeDword(data, value: kernel32IltRva)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(data, value: idataRva + kernel32DllNameOffset)
	writeDword(data, value: kernel32IatRva)

	writeDword(data, value: shell32IltRva)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(data, value: idataRva + shell32DllNameOffset)
	writeDword(data, value: shell32IatRva)

	// Import Directory null terminator (20 bytes).
	writeZeros(data, n: 20)

	// Hint/Name table entries (hint=0 for each) + DLL names.
	data.append(b"\x00\x00ExitProcess\x00")
	data.append(b"\x00\x00GetStdHandle\x00\x00")
	data.append(b"\x00\x00WriteFile\x00")
	data.append(b"\x00\x00ReadFile\x00\x00")
	data.append(b"\x00\x00CreateFileA\x00")
	data.append(b"\x00\x00CloseHandle\x00")
	data.append(b"\x00\x00GetEnvironmentVariableA\x00")
	data.append(b"\x00\x00VirtualAlloc\x00\x00")
	data.append(b"\x00\x00VirtualFree\x00")
	data.append(b"\x00\x00InitializeCriticalSection\x00")
	data.append(b"\x00\x00EnterCriticalSection\x00\x00")
	data.append(b"\x00\x00LeaveCriticalSection\x00\x00")
	data.append(b"\x00\x00GetCommandLineW\x00")
	data.append(b"\x00\x00LocalFree\x00")
	data.append(b"\x00\x00WideCharToMultiByte\x00")
	data.append(b"\x00\x00GetModuleFileNameW\x00\x00")
	data.append(b"\x00\x00CommandLineToArgvW\x00\x00")
	data.append(b"kernel32.dll\x00")
	data.append(b"shell32.dll\x00\x00")

	return ImportSection.create(data, iatRva: idataRva + iatOffset, importDirRva: idataRva + importDirOffset, importDirSize: 20 * IMPORT_DIRECTORY_ENTRIES)
end 'buildImportSection'

// --- Section header writer ---

function writeSectionName(buf ByteArray, name String)
	for ch in name 'chars'
		// Sentinel: non-ASCII becomes null byte; PE section names are always ASCII literals.
		let b = try ch.asciiValue() otherwise 0
		buf.push(b)
	end 'chars'
	for _ in name.count() upto 8 'pad'
		buf.push(0)
	end 'pad'
end 'writeSectionName'

function writeSectionHeader(buf ByteArray, name String, virtualSize ByteCount, virtualAddress Rva, rawDataSize ByteCount, rawDataPointer ByteOffset, characteristics SectionFlags)
	writeSectionName(buf, name: name)
	writeDword(buf, value: virtualSize)
	writeDword(buf, value: virtualAddress)
	writeDword(buf, value: rawDataSize)
	writeDword(buf, value: rawDataPointer)
	// PointerToRelocations(0), PointerToLinenumbers(0), NumberOfRelocations(0), NumberOfLinenumbers(0)
	buf.append(b"\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(buf, value: characteristics)
end 'writeSectionHeader'

// --- COFF symbol table ---
// Standard COFF symbol entries appended after all sections. Debuggers (lldb,
// llvm-objdump) read this table; the loader ignores everything past the last
// section so runtime behavior is unaffected. Backpatches PointerToSymbolTable
// and NumberOfSymbols in the COFF header. The custom .symtab runtime section
// (read by mrt_panic for stack traces) is unrelated and untouched.

// Write one 18-byte COFF symbol entry. Names ≤8 bytes are stored inline (NUL-padded);
// longer names are placed in the COFF string table and the entry stores a 4-byte
// offset (with 4 leading zero bytes to mark the long-name form).
function writeCoffSymbolEntry(pe ByteArray, stringTable ByteArray, name String, value MachineWord, sectionNumber MachineWord, symType MachineWord, storageClass MachineWord, numAux MachineWord)
	let nameBytes = name.toByteArray()
	let nameLen = nameBytes.count()
	if nameLen <= 8 'shortName'
		pe.append(nameBytes)
		for _ in nameLen upto 8 'pad'
			pe.push(0)
		end 'pad'
	end 'shortName' else 'longName'
		writeDword(pe, value: 0)
		writeDword(pe, value: stringTable.count())
		stringTable.append(nameBytes)
		stringTable.push(0)
	end 'longName'
	writeDword(pe, value: value)
	writeWord(pe, value: sectionNumber)
	writeWord(pe, value: symType)
	pe.push(storageClass and 0xFF)
	pe.push(numAux and 0xFF)
end 'writeCoffSymbolEntry'

// One emitted PE section, paired with the size that goes into its COFF
// section-definition auxiliary record (raw on-disk size for PROGBITS-style
// sections like .text/.rdata/.idata/.data/.covdata/.symtab).
type PeSectionRec
	export var name String
	export var rawSize ByteCount

	export static function create(name String, rawSize ByteCount) returns PeSectionRec
		return Self{name: name, rawSize: rawSize}
	end 'create'
end 'PeSectionRec'

typealias PeSectionList = Array with PeSectionRec

// Append section symbols (one per emitted section, with a format-5 auxiliary
// record carrying the section's raw size) followed by one external function
// symbol per DebugSymbol entry, then the COFF string table. Returns the total
// symbol count for the COFF header backpatch.
function writeCoffSymbolTable(pe ByteArray, debugSymbols DebugSymbolArray, codeSize ByteCount, hasRdata bool, rdataSize ByteCount, hasSymdata bool, symdataSize ByteCount, idataSize ByteCount, dataRawSize ByteCount, hasCovdata bool, covdataSize ByteCount) returns MachineWord
	var stringTable = ByteArray.create()
	// Reserve the leading 4-byte size prefix; patched after all names are appended.
	writeZeros(stringTable, n: 4)

	// Section-symbol order MUST match the section-emission order in writePe so
	// the section number assigned here lines up with the COFF section index.
	var sections = PeSectionList.create()
	sections.push(PeSectionRec.create(".text", rawSize: codeSize))
	if hasRdata 'addRdata'
		sections.push(PeSectionRec.create(".rdata", rawSize: rdataSize))
	end 'addRdata'
	if hasSymdata 'addSymtab'
		sections.push(PeSectionRec.create(".symtab", rawSize: symdataSize))
	end 'addSymtab'
	sections.push(PeSectionRec.create(".idata", rawSize: idataSize))
	sections.push(PeSectionRec.create(".data", rawSize: dataRawSize))
	if hasCovdata 'addCovdata'
		sections.push(PeSectionRec.create(".covdata", rawSize: covdataSize))
	end 'addCovdata'

	var totalSymbolCount = 0 as MachineWord
	for (iter, section) in sections.withIterator() 'sectionSyms'
		// IMAGE_SYM_CLASS_STATIC = 3, no type, one auxiliary section-definition record.
		writeCoffSymbolEntry(pe, stringTable: stringTable, name: section.name, value: 0, sectionNumber: iter.index() + 1, symType: 0x0000, storageClass: 3, numAux: 1)
		totalSymbolCount = totalSymbolCount + 1
		// Auxiliary format 5 (section definition): 18 bytes total.
		writeDword(pe, value: section.rawSize)  // Length
		writeWord(pe, value: 0)                  // NumberOfRelocations
		writeWord(pe, value: 0)                  // NumberOfLinenumbers
		writeDword(pe, value: 0)                 // CheckSum
		writeWord(pe, value: 0)                  // Number (COMDAT)
		pe.push(0)                               // Selection
		writeZeros(pe, n: 3)                     // Unused
		totalSymbolCount = totalSymbolCount + 1
	end 'sectionSyms'

	// Function symbols: all live in .text (section 1).
	// IMAGE_SYM_DTYPE_FUNCTION = 0x0020, IMAGE_SYM_CLASS_EXTERNAL = 2.
	for sym in debugSymbols 'funcSyms'
		writeCoffSymbolEntry(pe, stringTable: stringTable, name: sym.name, value: sym.codeOffset, sectionNumber: 1, symType: 0x0020, storageClass: 2, numAux: 0)
		totalSymbolCount = totalSymbolCount + 1
	end 'funcSyms'

	// String table size prefix is the total table size (including the prefix itself).
	patchDword(stringTable, offset: 0, value: stringTable.count())
	pe.append(stringTable)

	return totalSymbolCount
end 'writeCoffSymbolTable'

// --- Main PE writer ---

// Convert a flat slot index into its byte offset in the IAT. Each DLL run
// in the IAT/ILT is followed by an 8-byte null terminator, so slots past
// the first DLL boundary are shifted by 8 bytes for every prior boundary.
// Today the only boundary is between kernel32 (slots 0..KERNEL32_IAT_END-1)
// and shell32 (slot SHELL32_IAT_START onward); extend this stepwise as
// more DLLs are imported.
function iatSlotByteOffset(slotIndex MachineWord) returns ByteOffset
	if slotIndex >= SHELL32_IAT_START 'inShell32'
		return (slotIndex + 1) * 8
	end 'inShell32'
	return slotIndex * 8
end 'iatSlotByteOffset'

// Patch x64 RIP-relative relocations: each relocation is a disp32 at codeOffset
function patchRelocationsX86(code ByteArray, relocations RelocationArray, textRva Rva, idataRva Rva)
	for reloc in relocations 'patch'
		let ripAtReloc = textRva + reloc.codeOffset + 4
		let iatEntryRva = idataRva + iatSlotByteOffset(reloc.slotIndex)
		let rel = iatEntryRva - ripAtReloc
		patchDword(code, offset: reloc.codeOffset, value: rel)
	end 'patch'
end 'patchRelocationsX86'

function patchRdataRelocationsX86(code ByteArray, rdataRelocs RdataRelocationArray, textRva Rva, rdataRva Rva, symdataRva Rva, dataRva Rva, covdataRva Rva)
	for reloc in rdataRelocs 'patch'
		let ripAtReloc = textRva + reloc.codeOffset + 4
		match reloc.kind 'kind'
			ripRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: rdataRva + reloc.rdataOffset - ripAtReloc)
			symdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: symdataRva - ripAtReloc)
			dataSectionRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: dataRva + reloc.rdataOffset - ripAtReloc)
			covdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: covdataRva + reloc.rdataOffset - ripAtReloc)
			arm64Adr to covdataArm64Adr then break 'kind'
			funcAbs64InRdata then break 'kind'
		end 'kind'
	end 'patch'
end 'patchRdataRelocationsX86'

function patchRdataRelocationsArm64(code ByteArray, rdataRelocs RdataRelocationArray, textRva Rva, rdataRva Rva, symdataRva Rva, dataRva Rva, covdataRva Rva)
	for reloc in rdataRelocs 'patch'
		let instrRva = textRva + reloc.codeOffset
		match reloc.kind 'patchKind'
			ripRelDisp32 to covdataRipRelDisp32 then break 'patchKind'
			arm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: rdataRva + reloc.rdataOffset)
			arm64LdrLiteral then patchArm64LdrLiteral(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: rdataRva + reloc.rdataOffset)
			symdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: symdataRva)
			dataSectionArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: dataRva + reloc.rdataOffset)
			covdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: covdataRva + reloc.rdataOffset)
			funcAbs64InRdata then break 'patchKind'
		end 'patchKind'
	end 'patch'
end 'patchRdataRelocationsArm64'

// Patch ARM64 ADRP+LDR relocations: codeOffset points to ADRP, LDR is at codeOffset+4
function patchRelocationsArm64(code ByteArray, relocations RelocationArray, textRva Rva, idataRva Rva)
	for reloc in relocations 'patch'
		let iatEntryRva = idataRva + iatSlotByteOffset(reloc.slotIndex)
		let instrRva = textRva + reloc.codeOffset

		// ADRP: target page relative to instruction page
		let instrPage = instrRva and not 0xFFF
		let targetPage = iatEntryRva and not 0xFFF
		let pageOff = targetPage - instrPage
		let pageOffShifted = pageOff shr 12
		let immlo = pageOffShifted and 0x3
		let immhi = (pageOffShifted shr 2) and 0x7FFFF
		// Patch ADRP: preserve Rd, encode page offset
		let origAdrp = readDword(code, offset: reloc.codeOffset)
		let rd = origAdrp and 0x1F
		let patchedAdrp = (immlo shl 29) or 0x90000000 or (immhi shl 5) or rd
		patchDword(code, offset: reloc.codeOffset, value: patchedAdrp)

		// Patch LDR: encode page offset within the 4KB page, scaled by 8
		let pageOffset = iatEntryRva and 0xFFF
		let ldrOffset = reloc.codeOffset + 4
		let origLdr = readDword(code, offset: ldrOffset)
		let ldrImm = (pageOffset / 8) and 0xFFF
		let patchedLdr = (origLdr and 0xFFC003FF) or (ldrImm shl 10)
		patchDword(code, offset: ldrOffset, value: patchedLdr)
	end 'patch'
end 'patchRelocationsArm64'

export function writePe(outputPath FilePath, codeResult CodeResult, target Target)
	logInfo(LogCategory.binary, message: () gives "Writing PE file: {outputPath}")
	var pe = ByteArray.create()
	pe.reserve(4096)

	var code = codeResult.code
	let codeSize = code.count()
	let rdataSize = codeResult.rdata.count()
	let symdataSize = codeResult.symdata.count()
	let covdataSize = codeResult.covDataSectionBytes.count()
	let hasRdata = rdataSize > 0
	let hasSymdata = symdataSize > 0
	let hasCovdata = covdataSize > 0

	// Count sections: .text + .idata + .data + optional .rdata + optional .symtab + optional .covdata
	var numSections = 3
	if hasRdata 'countRdata'
		numSections = numSections + 1
	end 'countRdata'
	if hasSymdata 'countSymdata'
		numSections = numSections + 1
	end 'countSymdata'
	if hasCovdata 'countCovdata'
		numSections = numSections + 1
	end 'countCovdata'

	// Header sizes
	let headersSize = 64 + 4 + 20 + 240 + (40 * numSections)
	let headersAligned = alignUp(headersSize, alignment: FILE_ALIGNMENT)

	// .text section
	let codeSizeAligned = alignUp(codeSize, alignment: FILE_ALIGNMENT)
	let codeSizeVirtual = alignUp(codeSize, alignment: SECTION_ALIGNMENT)
	let textRva = SECTION_ALIGNMENT

	// .rdata section
	let rdataRva = textRva + codeSizeVirtual
	let rdataSizeAligned = alignUp(rdataSize, alignment: FILE_ALIGNMENT)
	var rdataSizeVirtual = 0
	if hasRdata 'setRdataVirtual'
		rdataSizeVirtual = alignUp(rdataSize, alignment: SECTION_ALIGNMENT)
	end 'setRdataVirtual'

	// .symtab section
	let symdataRva = rdataRva + rdataSizeVirtual
	let symdataSizeAligned = alignUp(symdataSize, alignment: FILE_ALIGNMENT)
	var symdataSizeVirtual = 0
	if hasSymdata 'setSymdataVirtual'
		symdataSizeVirtual = alignUp(symdataSize, alignment: SECTION_ALIGNMENT)
	end 'setSymdataVirtual'

	// .idata section
	let idataRva = symdataRva + symdataSizeVirtual
	let idata = buildImportSection(idataRva)
	let idataSize = idata.data.count()
	let idataSizeAligned = alignUp(idataSize, alignment: FILE_ALIGNMENT)
	let idataSizeVirtual = alignUp(idataSize, alignment: SECTION_ALIGNMENT)

	// .data section: 64KB heap arena, zero-initialized by the OS loader. The
	// on-disk image is a single file-aligned block sized just large enough to
	// hold every initialized prelude entry (top-level vars + runtime state
	// slots like `__slab_*`, `__mm_*`); the rest of the virtual region is
	// uninitialized and the loader zero-fills it. Step 6a.17 pushed the
	// prelude past 512 bytes once the slab/MM allocator state was registered,
	// so a single FILE_ALIGNMENT block is no longer enough.
	let dataRva = idataRva + idataSizeVirtual
	let preludeSize = codeResult.dataPrelude.count()
	var dataRawSize = FILE_ALIGNMENT
	if preludeSize > dataRawSize 'growDataRaw'
		dataRawSize = alignUp(preludeSize, alignment: FILE_ALIGNMENT)
	end 'growDataRaw'
	let dataSizeVirtual = alignUp(DATA_SECTION_VIRTUAL_SIZE, alignment: SECTION_ALIGNMENT)

	// .covdata section: dedicated writable RVA for coverage counter globals.
	// Emitted only when the backend produced covDataSectionBytes so non-coverage
	// builds stay byte-identical.
	let covdataRva = dataRva + dataSizeVirtual
	let covdataSizeAligned = alignUp(covdataSize, alignment: FILE_ALIGNMENT)
	var covdataSizeVirtual = 0
	if hasCovdata 'setCovdataVirtual'
		covdataSizeVirtual = alignUp(covdataSize, alignment: SECTION_ALIGNMENT)
	end 'setCovdataVirtual'

	let imageSize = covdataRva + covdataSizeVirtual

	logDebug(LogCategory.binary, message: () gives "Code section: {codeSize} bytes")
	logDebug(LogCategory.binary, message: () gives "Rdata section: {rdataSize} bytes")
	logDebug(LogCategory.binary, message: () gives "Symdata section: {symdataSize} bytes")
	logDebug(LogCategory.binary, message: () gives "Import section: {idataSize} bytes")
	logDebug(LogCategory.binary, message: () gives "Data section: {DATA_SECTION_VIRTUAL_SIZE} bytes (virtual)")
	logDebug(LogCategory.binary, message: () gives "Covdata section: {covdataSize} bytes")

	// Patch IAT references in code (different encoding per CPU architecture)
	match target.cpu 'patchCpu'
		x64 then patchRelocationsX86(code, relocations: codeResult.relocations, textRva: textRva, idataRva: idataRva)
		arm64 then patchRelocationsArm64(code, relocations: codeResult.relocations, textRva: textRva, idataRva: idataRva)
		wasm32 then panic("PE writer not used for WASM targets")
	end 'patchCpu'

	// Patch rdata, symdata, data, and covdata section references in code
	match target.cpu 'patchRdata'
		x64 then patchRdataRelocationsX86(code, rdataRelocs: codeResult.rdataRelocations, textRva: textRva, rdataRva: rdataRva, symdataRva: symdataRva, dataRva: dataRva, covdataRva: covdataRva)
		arm64 then patchRdataRelocationsArm64(code, rdataRelocs: codeResult.rdataRelocations, textRva: textRva, rdataRva: rdataRva, symdataRva: symdataRva, dataRva: dataRva, covdataRva: covdataRva)
		wasm32 then panic("PE writer not used for WASM targets")
	end 'patchRdata'

	// Phase 11.2: patch the rdata-internal funcAbs64 slots (layout-descriptor
	// copy/destroy, witness-table methods). PE ImageBase is fixed at
	// 0x140000000 below; absolute VAs we write here assume the loader places
	// the image there. We clear DYNAMIC_BASE / HIGH_ENTROPY_VA in
	// DllCharacteristics so the loader pins the image at ImageBase — without
	// a base-relocation table, ASLR would leave these abs64 slots pointing at
	// the wrong VA and indirect calls through them DEP-fault. If a future PE
	// update adds a base reloc table, every funcAbs64 slot will need a
	// corresponding entry there and DYNAMIC_BASE can be re-enabled.
	let imageBase = 0x140000000
	patchFuncAbs64InRdata(codeResult.rdata, rdataRelocs: codeResult.rdataRelocations, textAbsBase: imageBase + textRva, debugSymbols: codeResult.debugSymbols)

	// IAT directory size: one qword per slot plus one null terminator per
	// imported DLL. Layout matches `buildImportSection`.
	let iatDirSize = (IAT_SLOT_COUNT + IMPORT_DIRECTORY_ENTRIES) * 8

	// === DOS Header (64 bytes) + PE Signature ===
	// MZ magic, 58 zero bytes, PE offset=64, then PE\0\0 signature
	pe.append(b"MZ\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x40\x00\x00\x00PE\x00\x00")

	// === COFF Header (20 bytes) ===
	let coffMachine = match target.cpu 'coffCpu'
		x64 gives 0x8664
		arm64 gives 0xAA64
		default panic("PE writer not used for WASM targets")
	end 'coffCpu'
	writeWord(pe, value: coffMachine)
	writeWord(pe, value: numSections)
	// TimeDateStamp stays zero; PointerToSymbolTable + NumberOfSymbols are
	// backpatched after the COFF symbol table is appended at the end of the file.
	writeZeros(pe, n: 4)                              // TimeDateStamp
	let pointerToSymbolTableOffset = pe.count()       // file offset 76
	writeZeros(pe, n: 4)                              // PointerToSymbolTable (patched later)
	let numberOfSymbolsOffset = pe.count()            // file offset 80
	writeZeros(pe, n: 4)                              // NumberOfSymbols (patched later)
	writeWord(pe, value: 240)                         // SizeOfOptionalHeader
	writeWord(pe, value: 0x22)                        // Characteristics

	// === Optional Header PE32+ (240 bytes) ===
	pe.append(b"\x0b\x02\x0e\x00")
	writeDword(pe, value: codeSizeAligned)
	writeDword(pe, value: rdataSizeAligned + symdataSizeAligned + idataSizeAligned + covdataSizeAligned)
	pe.append(b"\x00\x00\x00\x00")  // BaseOfCode(0) — placeholder before textRva writes
	writeDword(pe, value: textRva)
	writeDword(pe, value: textRva)

	// ImageBase(0x140000000), SectionAlignment(4096), FileAlignment(512)
	// MajorOSVersion(6), MinorOSVersion(0), MajorImageVersion(0), MinorImageVersion(0)
	// MajorSubsystemVersion(6), MinorSubsystemVersion(0), Win32VersionValue(0)
	pe.append(b"\x00\x00\x00\x40\x01\x00\x00\x00\x00\x10\x00\x00\x00\x02\x00\x00\x06\x00\x00\x00\x00\x00\x00\x00\x06\x00\x00\x00\x00\x00\x00\x00")
	writeDword(pe, value: imageSize)
	writeDword(pe, value: headersAligned)
	// CheckSum(0), Subsystem(3=CONSOLE), DllCharacteristics(0x8100 — NX_COMPAT
	// + TERMINAL_SERVER_AWARE; DYNAMIC_BASE/HIGH_ENTROPY_VA cleared because
	// rdata abs64 slots have no base-relocs to fix up under ASLR slide).
	// SizeOfStackReserve(0x100000), SizeOfStackCommit(0x1000)
	// SizeOfHeapReserve(0x100000), SizeOfHeapCommit(0x1000)
	// LoaderFlags(0), NumberOfRvaAndSizes(16)
	pe.append(b"\x00\x00\x00\x00\x03\x00\x00\x81\x00\x00\x10\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00")

	// Data directories: 0=Export(zeros), 1=Import
	pe.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(pe, value: idata.importDirRva)
	writeDword(pe, value: idata.importDirSize)
	// 2-11: zeros
	writeZeros(pe, n: 80)
	// 12: IAT
	writeDword(pe, value: idata.iatRva)
	writeDword(pe, value: iatDirSize)
	// 13-15: zeros
	writeZeros(pe, n: 24)

	// === Section Headers ===
	// .text uses R+X (0x60000020); .rdata uses R-only (0x40000040); .idata, .data, .symtab,
	// and .covdata are all writable initialized data (0xC0000040).
	var nextFilePointer = headersAligned + codeSizeAligned
	writeSectionHeader(pe, name: ".text", virtualSize: codeSize, virtualAddress: textRva, rawDataSize: codeSizeAligned, rawDataPointer: headersAligned, characteristics: 0x60000020)
	if hasRdata 'writeRdataHeader'
		writeSectionHeader(pe, name: ".rdata", virtualSize: rdataSize, virtualAddress: rdataRva, rawDataSize: rdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0x40000040)
		nextFilePointer = nextFilePointer + rdataSizeAligned
	end 'writeRdataHeader'
	if hasSymdata 'writeSymdataHeader'
		writeSectionHeader(pe, name: ".symtab", virtualSize: symdataSize, virtualAddress: symdataRva, rawDataSize: symdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
		nextFilePointer = nextFilePointer + symdataSizeAligned
	end 'writeSymdataHeader'
	writeSectionHeader(pe, name: ".idata", virtualSize: idataSize, virtualAddress: idataRva, rawDataSize: idataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	nextFilePointer = nextFilePointer + idataSizeAligned
	// .data section: writable, 64KB virtual size with one file-aligned block on disk
	writeSectionHeader(pe, name: ".data", virtualSize: DATA_SECTION_VIRTUAL_SIZE, virtualAddress: dataRva, rawDataSize: dataRawSize, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	nextFilePointer = nextFilePointer + dataRawSize
	if hasCovdata 'writeCovdataHeader'
		writeSectionHeader(pe, name: ".covdata", virtualSize: covdataSize, virtualAddress: covdataRva, rawDataSize: covdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	end 'writeCovdataHeader'

	// Pad headers to alignment
	padTo(pe, size: headersAligned)

	// === .text section ===
	pe.append(code)
	padTo(pe, size: headersAligned + codeSizeAligned)

	// === .rdata section ===
	if hasRdata 'writeRdata'
		pe.append(codeResult.rdata)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned)
	end 'writeRdata'

	// === .symtab section ===
	if hasSymdata 'writeSymdata'
		pe.append(codeResult.symdata)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned)
	end 'writeSymdata'

	// === .idata section ===
	pe.append(idata.data)
	padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned + idataSizeAligned)

	// === .data section ===
	// First the data prelude (initial values for top-level / static-field
	// globals), then zeros for the rest of the on-disk block. The OS loader
	// zero-fills the remaining virtual bytes (the heap arena) at load time.
	if codeResult.dataPrelude.count() > dataRawSize 'preludeOverflow'
		panic("data prelude ({codeResult.dataPrelude.count()} bytes) exceeds .data raw size ({dataRawSize}); raise FILE_ALIGNMENT or grow the on-disk .data block.")
	end 'preludeOverflow'
	pe.append(codeResult.dataPrelude)
	writeZeros(pe, n: dataRawSize - codeResult.dataPrelude.count())

	// === .covdata section ===
	// Coverage counter globals (initial bytes carry the __data_cov_num_sites
	// header; __data_cov_counters is zero-filled). Emitted only when present.
	if hasCovdata 'writeCovdata'
		pe.append(codeResult.covDataSectionBytes)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned + idataSizeAligned + dataRawSize + covdataSizeAligned)
	end 'writeCovdata'

	// === COFF symbol table + string table ===
	// Appended past the last loadable section. Image loaders ignore trailing
	// bytes; debuggers (lldb, llvm-objdump) read this table to resolve names.
	if codeResult.debugSymbols.count() > 0 'writeCoff'
		let symbolTableFileOffset = pe.count()
		let totalSymbolCount = writeCoffSymbolTable(pe, debugSymbols: codeResult.debugSymbols, codeSize: codeSize, hasRdata: hasRdata, rdataSize: rdataSize, hasSymdata: hasSymdata, symdataSize: symdataSize, idataSize: idataSize, dataRawSize: dataRawSize, hasCovdata: hasCovdata, covdataSize: covdataSize)
		patchDword(pe, offset: pointerToSymbolTableOffset, value: symbolTableFileOffset)
		patchDword(pe, offset: numberOfSymbolsOffset, value: totalSymbolCount)
		logDebug(LogCategory.binary, message: () gives "COFF symbol table: {totalSymbolCount} entries at file offset {symbolTableFileOffset}")
	end 'writeCoff'

	// Write to file
	try File.writeBinary(outputPath, content: pe) otherwise 'writeErr'
		logError(LogCategory.binary, message: () gives "Failed to write PE file: {outputPath}")
	end 'writeErr'
end 'writePe'

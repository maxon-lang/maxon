// PE64 file writer for Windows executables.
// Produces a minimal PE with .text, .rdata, .symtab, .idata, and .data sections.

typealias Rva = int(0 to u64.max)
typealias SectionFlags = int(0 to u64.max)

let FILE_ALIGNMENT = 512
let SECTION_ALIGNMENT = 4096

// Size of the writable .data section (heap arena for bump allocator).
let DATA_SECTION_VIRTUAL_SIZE = 65536

// --- Import section builder ---
// IAT slot indices for kernel32.dll / shell32.dll imports.
//
// Every code site that emits a call into the import table (per-target
// `iatCall` op, hand-emitted Windows helpers in X64Backend / Arm64Win32Helpers,
// OsDescriptor strategy variants) names the destination by enum case rather
// than a raw integer. Renumbering happens in exactly one place — the
// `iatSlotIndex` table below — and everything else picks the right slot via
// the typechecker. Prior to the enum, several call sites referred to slots
// by literal integer (`iatCall 27`, etc.), and inserting a new import in
// the middle of the table silently broke them; the enum makes that class of
// bug a compile error instead.
//
// Slot ordering still matters for the PE file format (the IAT/ILT byte
// streams in `buildImportSection` are written in slot-index order), but the
// ordering is now a single source of truth.
export union IatSlot
	// kernel32 — Phase 7 / 8 baseline run.
	exitProcess
	getStdHandle
	writeFile
	readFile
	createFileA
	closeHandle
	getEnvironmentVariableA
	virtualAlloc
	virtualFree
	initializeCriticalSection
	enterCriticalSection
	leaveCriticalSection

	// Phase 15b: command-line argument retrieval.
	getCommandLineW
	localFree
	wideCharToMultiByte

	// Phase 15f: executable-path retrieval. `GetModuleFileNameW` writes a
	// UTF-16 path; the runtime helper re-encodes via WideCharToMultiByte.
	getModuleFileNameW

	// Phase 15c Stream 3.1: Win32 file/directory I/O. All kernel32. Path-
	// taking APIs use the wide-char (W) variants; UTF-8 paths from Maxon
	// strings get converted via MultiByteToWideChar.
	createFileW
	deleteFileW
	getFileSizeEx
	getFileAttributesExW
	setFilePointerEx
	findFirstFileW
	findNextFileW
	findClose
	createDirectoryW
	getCurrentDirectoryW
	multiByteToWideChar
	getLastError

	// kernel32!Sleep — `osSleep` lowering routes through this slot on
	// Windows. Appended at the end of the kernel32 run; adding new kernel32
	// imports here keeps the existing slot ordinals stable, only shifting
	// the shell32 cases.
	sleep

	// Tier 4 async: multi-OS-thread green-thread scheduler (+ reserved IOCP
	// async-I/O slots). All kernel32. CreateThread spawns worker OS threads; the
	// event + wait + TLS APIs drive parking/waking; GetSystemInfo sizes the P
	// array. The IOCP APIs (createIoCompletionPort / get+postQueuedCompletionStatus),
	// GetTickCount64 (timer heap), WaitForMultipleObjects, ResetEvent and
	// DeleteCriticalSection are imported ahead of the async-I/O specs but are not
	// yet referenced by emitted code — keep them in lockstep with `iatSlotIndex`.
	createThread
	createEventA
	setEvent
	resetEvent
	waitForSingleObject
	waitForMultipleObjects
	getSystemInfo
	tlsAlloc
	tlsSetValue
	deleteCriticalSection
	createIoCompletionPort
	getQueuedCompletionStatus
	postQueuedCompletionStatus
	getTickCount64

	// Tier 4 subprocess (`stdlib/Subprocess.maxon`). All kernel32. CreateProcessW
	// spawns the child; CreatePipe / CreateNamedPipeW + SetHandleInformation wire
	// up redirected/streaming stdio; the ProcThreadAttributeList trio scopes
	// handle inheritance so concurrent spawns don't leak each other's pipes; the
	// Job Object quartet group-kills a child (+ its descendants) on timeout;
	// GetExitCodeProcess / TerminateProcess / WaitForSingleObject drive
	// wait-and-collect; SearchPathW resolves bare exe names; FormatMessageA
	// renders the last Win32 error; GenerateConsoleCtrlEvent / ResumeThread serve
	// signal delivery and the create-suspended spawn path. Appended at the end of
	// the kernel32 run so existing slot ordinals stay stable.
	createProcessW
	createPipe
	createNamedPipeW
	setHandleInformation
	getExitCodeProcess
	terminateProcess
	searchPathW
	formatMessageA
	createJobObjectW
	assignProcessToJobObject
	setInformationJobObject
	terminateJobObject
	generateConsoleCtrlEvent
	resumeThread
	initializeProcThreadAttributeList
	updateProcThreadAttribute
	deleteProcThreadAttributeList

	// CPU-fault diagnostics (Tier 4 fault handler). kernel32!AddVectoredException-
	// Handler registers the runtime's VEH thunk at __gt_init time. Appended at the
	// end of the kernel32 run so existing kernel32 slot ordinals stay stable
	// (shell32 below shifts by one).
	addVectoredExceptionHandler

	// Tier 4 async-I/O IOCP completion machinery (x64-Windows `emitX64IoRuntime`).
	// All kernel32. The overlapped read/write path uses SetFileCompletionNotification-
	// Modes (FILE_SKIP_COMPLETION_PORT_ON_SUCCESS) + GetOverlappedResult; the sync-
	// fallback worker drives the ANSI filesystem ops (GetFileAttributesA, DeleteFileA,
	// FindFirstFileA / FindNextFileA, CreateDirectoryA, GetCurrentDirectoryA). Appended
	// at the end of the kernel32 run so existing kernel32 slot ordinals stay stable
	// (shell32 below shifts by eight). INERT until async-I/O specs submit work — the
	// emitted IOCP functions reference these, but no lowering invokes those functions
	// yet, so the slots are never hit at runtime.
	setFileCompletionNotificationModes
	getOverlappedResult
	getFileAttributesA
	deleteFileA
	findFirstFileA
	findNextFileA
	createDirectoryA
	getCurrentDirectoryA

	// shell32 — single entry, lives at the end of the IAT in its own
	// import-directory DLL.
	commandLineToArgvW

	// ws2_32 - Winsock TCP networking (x64-windows `emitX64NetworkingRuntime`).
	// Lives in its own import-directory DLL run AFTER shell32, but UNLIKE every
	// other run its DLL directory entry + IAT/ILT thunks + hint-name strings are
	// emitted CONDITIONALLY: only when a program actually references a ws2_32 slot
	// (detected from `codeResult.relocations` in `writePe`). A non-networking PE
	// therefore carries no ws2_32 import at all and is byte-identical to the
	// pre-networking output. The slot ORDINALS below are fixed compile-time
	// constants regardless of presence - they are a numbering scheme the call-site
	// relocations and `patchRelocationsX86` depend on, not a guarantee the import
	// is emitted. ConnectEx is intentionally absent: it is called through the
	// `__io_connectex_ptr` function pointer (loaded via WSAIoctl), not an IAT slot.
	wsaStartup
	wsaSocketW
	wsaGetLastError
	wsaIoctl
	bind
	getAddrInfo
	freeAddrInfo
	wsaSend
	wsaRecv
	setSockOpt
	closeSocket
end 'IatSlot'

// Integer slot index of an `IatSlot`. Mirrors the case order above and is
// the only place that translates the symbolic enum back to a PE-level
// integer. `iatSlotByteOffset` (call-site relocation arithmetic), the
// per-target `iatCall` op emitters, and the PE writer's hint/IAT/ILT
// builder all funnel through this function.
export function iatSlotIndex(slot IatSlot) returns MachineWord
	return match slot 's'
		exitProcess gives 0
		getStdHandle gives 1
		writeFile gives 2
		readFile gives 3
		createFileA gives 4
		closeHandle gives 5
		getEnvironmentVariableA gives 6
		virtualAlloc gives 7
		virtualFree gives 8
		initializeCriticalSection gives 9
		enterCriticalSection gives 10
		leaveCriticalSection gives 11
		getCommandLineW gives 12
		localFree gives 13
		wideCharToMultiByte gives 14
		getModuleFileNameW gives 15
		createFileW gives 16
		deleteFileW gives 17
		getFileSizeEx gives 18
		getFileAttributesExW gives 19
		setFilePointerEx gives 20
		findFirstFileW gives 21
		findNextFileW gives 22
		findClose gives 23
		createDirectoryW gives 24
		getCurrentDirectoryW gives 25
		multiByteToWideChar gives 26
		getLastError gives 27
		sleep gives 28
		createThread gives 29
		createEventA gives 30
		setEvent gives 31
		resetEvent gives 32
		waitForSingleObject gives 33
		waitForMultipleObjects gives 34
		getSystemInfo gives 35
		tlsAlloc gives 36
		tlsSetValue gives 37
		deleteCriticalSection gives 38
		createIoCompletionPort gives 39
		getQueuedCompletionStatus gives 40
		postQueuedCompletionStatus gives 41
		getTickCount64 gives 42
		createProcessW gives 43
		createPipe gives 44
		createNamedPipeW gives 45
		setHandleInformation gives 46
		getExitCodeProcess gives 47
		terminateProcess gives 48
		searchPathW gives 49
		formatMessageA gives 50
		createJobObjectW gives 51
		assignProcessToJobObject gives 52
		setInformationJobObject gives 53
		terminateJobObject gives 54
		generateConsoleCtrlEvent gives 55
		resumeThread gives 56
		initializeProcThreadAttributeList gives 57
		updateProcThreadAttribute gives 58
		deleteProcThreadAttributeList gives 59
		addVectoredExceptionHandler gives 60
		setFileCompletionNotificationModes gives 61
		getOverlappedResult gives 62
		getFileAttributesA gives 63
		deleteFileA gives 64
		findFirstFileA gives 65
		findNextFileA gives 66
		createDirectoryA gives 67
		getCurrentDirectoryA gives 68
		commandLineToArgvW gives 69
		wsaStartup gives 70
		wsaSocketW gives 71
		wsaGetLastError gives 72
		wsaIoctl gives 73
		bind gives 74
		getAddrInfo gives 75
		freeAddrInfo gives 76
		wsaSend gives 77
		wsaRecv gives 78
		setSockOpt gives 79
		closeSocket gives 80
	end 's'
end 'iatSlotIndex'

// Total IAT slot space — kernel32 run + shell32 run + ws2_32 run. Mirrors the
// last enum case's index + 1. This is the maximum slot NUMBERING; the IAT/ILT
// table actually emitted is sized from the present-DLL set (see
// `emittedIatSlotCount`), which drops the ws2_32 run when networking is unused.
let IAT_SLOT_COUNT = 81

type ImportSection
	export var data as ByteArray
	export var iatRva as Rva
	export var importDirRva as Rva
	export var importDirSize as ByteCount

	static function create(data ByteArray, iatRva Rva, importDirRva Rva, importDirSize ByteCount) returns ImportSection
		return Self{data: data, iatRva: iatRva, importDirRva: importDirRva, importDirSize: importDirSize}
	end 'create'
end 'ImportSection'

// Number of import-directory entries (kernel32, shell32). The flat IAT
// is split into two per-DLL runs: kernel32 takes slots 0..KERNEL32_END-1
// and shell32 takes slot SHELL32_START..IAT_SLOT_COUNT-1. Each run gets
// its own null terminator, so the table layout is:
//   IAT  [k32 entries] 0  [s32 entries] 0
//   ILT  [k32 entries] 0  [s32 entries] 0
// followed by the Import Directory (3 entries: kernel32, shell32, null).
let KERNEL32_IAT_END = 69  // exclusive; slots 0..68 are kernel32
let SHELL32_IAT_START = 69  // slot 69 is shell32 (commandLineToArgvW)
// ws2_32 run: slots 70..80 (11 imports). Emitted ONLY when a program references
// a ws2_32 slot (see `usesWs2_32` in `writePe`); otherwise the run, its DLL
// directory entry, and its hint-name strings are omitted entirely.
let WS2_32_IAT_START = 70
let WS2_32_IAT_COUNT = 11

// Number of import-directory entries actually emitted for this build: 2 when
// ws2_32 is unused (kernel32, shell32), 3 when it is (kernel32, shell32,
// ws2_32). Replaces the former fixed `IMPORT_DIRECTORY_ENTRIES` constant so the
// table sizing, directory-entry loop, `importDirSize`, and `iatDirSize` all
// agree with whether the ws2_32 run was physically written.
function importDirEntries(usesWs2_32 bool) returns ByteCount
	if usesWs2_32 'withWs2'
		return 3
	end 'withWs2'
	return 2
end 'importDirEntries'

// Number of IAT/ILT thunk slots actually emitted for this build. Without ws2_32
// the table holds the kernel32 + shell32 slots (0..SHELL32_IAT_START); with it,
// the full slot space. The per-DLL null terminators are added on top of this by
// the table-size arithmetic.
function emittedIatSlotCount(usesWs2_32 bool) returns ByteCount
	if usesWs2_32 'withWs2'
		return IAT_SLOT_COUNT
	end 'withWs2'
	return WS2_32_IAT_START
end 'emittedIatSlotCount'

// True when any code relocation targets a ws2_32 IAT slot (index in
// [WS2_32_IAT_START, IAT_SLOT_COUNT)). This is the single reachability signal
// that drives whether the ws2_32 import is emitted: it is true EXACTLY when
// `emitX64NetworkingRuntime` ran and produced ws2 IAT calls, so the import-table
// gate and the runtime-emit gate cannot disagree (see the networking-port plan's
// "PE conditional-import correctness" gotcha). A non-networking program produces
// no such relocation, so this is false and the PE is byte-identical to the
// pre-networking output.
function programUsesWs2_32(relocations RelocationArray) returns bool
	for reloc in relocations 'each'
		if reloc.slotIndex >= WS2_32_IAT_START and reloc.slotIndex < IAT_SLOT_COUNT 'isWs2'
			return true
		end 'isWs2'
	end 'each'
	return false
end 'programUsesWs2_32'

// kernel32 import names in slot order (slots 0..KERNEL32_IAT_END-1). MUST stay
// in lockstep with `iatSlotIndex`'s kernel32 arm — same order, same count.
function kernel32ImportNames() returns StringArray
	var n = StringArray.create()
	n.push("ExitProcess")
	n.push("GetStdHandle")
	n.push("WriteFile")
	n.push("ReadFile")
	n.push("CreateFileA")
	n.push("CloseHandle")
	n.push("GetEnvironmentVariableA")
	n.push("VirtualAlloc")
	n.push("VirtualFree")
	n.push("InitializeCriticalSection")
	n.push("EnterCriticalSection")
	n.push("LeaveCriticalSection")
	n.push("GetCommandLineW")
	n.push("LocalFree")
	n.push("WideCharToMultiByte")
	n.push("GetModuleFileNameW")
	n.push("CreateFileW")
	n.push("DeleteFileW")
	n.push("GetFileSizeEx")
	n.push("GetFileAttributesExW")
	n.push("SetFilePointerEx")
	n.push("FindFirstFileW")
	n.push("FindNextFileW")
	n.push("FindClose")
	n.push("CreateDirectoryW")
	n.push("GetCurrentDirectoryW")
	n.push("MultiByteToWideChar")
	n.push("GetLastError")
	n.push("Sleep")
	n.push("CreateThread")
	n.push("CreateEventA")
	n.push("SetEvent")
	n.push("ResetEvent")
	n.push("WaitForSingleObject")
	n.push("WaitForMultipleObjects")
	n.push("GetSystemInfo")
	n.push("TlsAlloc")
	n.push("TlsSetValue")
	n.push("DeleteCriticalSection")
	n.push("CreateIoCompletionPort")
	n.push("GetQueuedCompletionStatus")
	n.push("PostQueuedCompletionStatus")
	n.push("GetTickCount64")
	n.push("CreateProcessW")
	n.push("CreatePipe")
	n.push("CreateNamedPipeW")
	n.push("SetHandleInformation")
	n.push("GetExitCodeProcess")
	n.push("TerminateProcess")
	n.push("SearchPathW")
	n.push("FormatMessageA")
	n.push("CreateJobObjectW")
	n.push("AssignProcessToJobObject")
	n.push("SetInformationJobObject")
	n.push("TerminateJobObject")
	n.push("GenerateConsoleCtrlEvent")
	n.push("ResumeThread")
	n.push("InitializeProcThreadAttributeList")
	n.push("UpdateProcThreadAttribute")
	n.push("DeleteProcThreadAttributeList")
	n.push("AddVectoredExceptionHandler")
	n.push("SetFileCompletionNotificationModes")
	n.push("GetOverlappedResult")
	n.push("GetFileAttributesA")
	n.push("DeleteFileA")
	n.push("FindFirstFileA")
	n.push("FindNextFileA")
	n.push("CreateDirectoryA")
	n.push("GetCurrentDirectoryA")
	return n
end 'kernel32ImportNames'

// ws2_32 import names in slot order (slots WS2_32_IAT_START..IAT_SLOT_COUNT-1).
// MUST stay in lockstep with `iatSlotIndex`'s ws2_32 arm — same order, same
// count (`WS2_32_IAT_COUNT`). Only emitted into the PE when networking is linked.
function ws2_32ImportNames() returns StringArray
	var n = StringArray.create()
	n.push("WSAStartup")
	n.push("WSASocketW")
	n.push("WSAGetLastError")
	n.push("WSAIoctl")
	n.push("bind")
	n.push("getaddrinfo")
	n.push("freeaddrinfo")
	n.push("WSASend")
	n.push("WSARecv")
	n.push("setsockopt")
	n.push("closesocket")
	return n
end 'ws2_32ImportNames'

// Byte size of one Hint/Name table entry for `name`: 2-byte hint + name + NUL,
// padded up to an even total (PE requires even alignment).
function importHintNameEntrySize(name String) returns ByteCount
	var total = 2 + name.toByteArray().count() + 1
	if total mod 2 != 0 'odd'
		total = total + 1
	end 'odd'
	return total
end 'importHintNameEntrySize'

// Append one Hint/Name table entry: `\x00\x00` (hint=0) + name + NUL + even pad.
function appendImportHintNameEntry(data ByteArray, name String)
	data.append(b"\x00\x00")
	let nameBytes = name.toByteArray()
	data.append(nameBytes)
	data.push(0)
	if (2 + nameBytes.count() + 1) mod 2 != 0 'odd'
		data.push(0)
	end 'odd'
end 'appendImportHintNameEntry'

// Build the .idata import section. `usesWs2_32` controls whether the ws2_32 run
// (IAT/ILT thunks + directory entry + hint-name strings) is physically emitted.
// When false the output is byte-identical to the pre-networking layout: only
// kernel32 + shell32 runs, a 2-entry directory, and the two DLL-name strings.
// When true the ws2_32 run is APPENDED after shell32, so kernel32/shell32 RVAs
// and offsets are unchanged either way (ws2 only ever adds at the tail).
function buildImportSection(idataRva Rva, usesWs2_32 bool) returns ImportSection
	var data = ByteArray.create()
	data.reserve(1024)

	let kernel32Names = kernel32ImportNames()
	let shell32Name = "CommandLineToArgvW"
	let ws2_32Names = ws2_32ImportNames()
	let kernel32Count = kernel32Names.count()
	let ws2_32Count = ws2_32Names.count()
	let dirEntries = importDirEntries(usesWs2_32)

	// Layout: IAT [k32 | null | s32 | null (| ws2 | null)], ILT [same], import
	// directory (kernel32, shell32 (, ws2_32), null), then the Hint/Name table +
	// DLL name strings. The ws2_32 run appears only when `usesWs2_32`.
	let tableBytes = (emittedIatSlotCount(usesWs2_32) + dirEntries) * 8
	let iatOffset = 0
	let iltOffset = tableBytes
	let importDirOffset = tableBytes * 2
	let hintNameOffset = importDirOffset + 20 * (dirEntries + 1)

	// Hint/Name offsets, all derived (no hand-maintained constants). kernel32
	// names first, then shell32's single name, then (conditionally) the ws2_32
	// run, then the even-padded DLL-name strings.
	let shell32Hint = hintNameOffset + sumHintSizes(kernel32Names)
	let ws2_32HintStart = shell32Hint + importHintNameEntrySize(shell32Name)
	var afterNames = ws2_32HintStart
	if usesWs2_32 'ws2Names'
		afterNames = ws2_32HintStart + sumHintSizes(ws2_32Names)
	end 'ws2Names'

	let kernel32DllField = dllNameField("kernel32.dll")
	let shell32DllField = dllNameField("shell32.dll")
	let ws2_32DllField = dllNameField("ws2_32.dll")
	let kernel32DllNameOffset = afterNames
	let shell32DllNameOffset = kernel32DllNameOffset + kernel32DllField.count()
	let ws2_32DllNameOffset = shell32DllNameOffset + shell32DllField.count()

	// IAT then ILT (identical content): kernel32 run + null, shell32 + null, and
	// (conditionally) ws2_32 run + null.
	for _ in 0 upto 2 'iatIltPasses'
		var running = hintNameOffset
		for i in 0 upto kernel32Count 'k32thunk'
			writeQword(data, value: idataRva + running)
			let nm = try kernel32Names.get(i) otherwise panic("buildImportSection: kernel32Names.get OOB at {i}")
			running = running + importHintNameEntrySize(nm)
		end 'k32thunk'
		data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
		writeQword(data, value: idataRva + shell32Hint)
		data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
		if usesWs2_32 'ws2thunks'
			var ws2Running = ws2_32HintStart
			for i in 0 upto ws2_32Count 'ws2thunk'
				writeQword(data, value: idataRva + ws2Running)
				let nm = try ws2_32Names.get(i) otherwise panic("buildImportSection: ws2_32Names.get OOB at {i}")
				ws2Running = ws2Running + importHintNameEntrySize(nm)
			end 'ws2thunk'
			data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
		end 'ws2thunks'
	end 'iatIltPasses'

	// Per-DLL Import Directory entries: 4-byte ILT RVA, 8 zero bytes
	// (TimeDateStamp, ForwarderChain), 4-byte Name RVA, 4-byte IAT RVA.
	let kernel32IatRva = idataRva + iatOffset
	let kernel32IltRva = idataRva + iltOffset
	let shell32IatRva = kernel32IatRva + (kernel32Count + 1) * 8
	let shell32IltRva = kernel32IltRva + (kernel32Count + 1) * 8
	let ws2_32IatRva = shell32IatRva + 2 * 8  // shell32 has 1 slot + 1 null term
	let ws2_32IltRva = shell32IltRva + 2 * 8

	writeDword(data, value: kernel32IltRva)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(data, value: idataRva + kernel32DllNameOffset)
	writeDword(data, value: kernel32IatRva)

	writeDword(data, value: shell32IltRva)
	data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(data, value: idataRva + shell32DllNameOffset)
	writeDword(data, value: shell32IatRva)

	if usesWs2_32 'ws2Dir'
		writeDword(data, value: ws2_32IltRva)
		data.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
		writeDword(data, value: idataRva + ws2_32DllNameOffset)
		writeDword(data, value: ws2_32IatRva)
	end 'ws2Dir'

	// Import Directory null terminator (20 bytes).
	writeZeros(data, n: 20)

	// Hint/Name table + DLL name strings.
	for i in 0 upto kernel32Count 'k32name'
		appendImportHintNameEntry(data, name: try kernel32Names.get(i) otherwise panic("buildImportSection: kernel32Names.get OOB at {i}"))
	end 'k32name'
	appendImportHintNameEntry(data, name: shell32Name)
	if usesWs2_32 'ws2HintNames'
		for i in 0 upto ws2_32Count 'ws2name'
			appendImportHintNameEntry(data, name: try ws2_32Names.get(i) otherwise panic("buildImportSection: ws2_32Names.get OOB at {i}"))
		end 'ws2name'
	end 'ws2HintNames'
	data.append(kernel32DllField)
	data.append(shell32DllField)
	if usesWs2_32 'ws2DllName'
		data.append(ws2_32DllField)
	end 'ws2DllName'

	return ImportSection.create(data, iatRva: idataRva + iatOffset, importDirRva: idataRva + importDirOffset, importDirSize: 20 * dirEntries)
end 'buildImportSection'

// Sum of Hint/Name entry sizes across a run of imports — the offset delta from
// the first entry of the run to whatever follows it in the Hint/Name table.
// Used for both the kernel32 run (delta to shell32) and the ws2_32 run (delta
// to the DLL-name strings).
function sumHintSizes(names StringArray) returns ByteCount
	var total = 0
	for i in 0 upto names.count() 'each'
		total = total + importHintNameEntrySize(try names.get(i) otherwise panic("sumHintSizes: get OOB at {i}"))
	end 'each'
	return total
end 'sumHintSizes'

// The even-padded DLL-name string field for the import directory: name + NUL,
// then one extra NUL when the total is odd (PE requires even alignment for the
// strings that follow). Deriving this removes the hand-maintained pad literals
// (`b"kernel32.dll\x00"`, `b"shell32.dll\x00\x00"`) that an off-by-pad edit
// would silently corrupt the IAT with — a load crash, given a 3rd conditional
// DLL run now shifts these around.
function dllNameField(name String) returns ByteArray
	var field = ByteArray.create()
	field.append(name.toByteArray())
	field.push(0)
	if field.count() mod 2 != 0 'odd'
		field.push(0)
	end 'odd'
	return field
end 'dllNameField'

// --- Section header writer ---

function writeSectionName(buf ByteArray, name String)
	for ch in name 'chars'
		// Sentinel: non-ASCII becomes null byte; PE section names are always ASCII literals.
		let b = try ch.asciiValue() otherwise 0
		buf.push(b)
	end 'chars'
	for _ in name.count() upto 8 'pad'
		buf.push(0)
	end 'pad'
end 'writeSectionName'

function writeSectionHeader(buf ByteArray, name String, virtualSize ByteCount, virtualAddress Rva, rawDataSize ByteCount, rawDataPointer ByteOffset, characteristics SectionFlags)
	writeSectionName(buf, name: name)
	writeDword(buf, value: virtualSize)
	writeDword(buf, value: virtualAddress)
	writeDword(buf, value: rawDataSize)
	writeDword(buf, value: rawDataPointer)
	// PointerToRelocations(0), PointerToLinenumbers(0), NumberOfRelocations(0), NumberOfLinenumbers(0)
	buf.append(b"\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(buf, value: characteristics)
end 'writeSectionHeader'

// --- COFF symbol table ---
// Standard COFF symbol entries appended after all sections. Debuggers (lldb,
// llvm-objdump) read this table; the loader ignores everything past the last
// section so runtime behavior is unaffected. Backpatches PointerToSymbolTable
// and NumberOfSymbols in the COFF header. The custom .symtab runtime section
// (read by mrt_panic for stack traces) is unrelated and untouched.

// Write one 18-byte COFF symbol entry. Names ≤8 bytes are stored inline (NUL-padded);
// longer names are placed in the COFF string table and the entry stores a 4-byte
// offset (with 4 leading zero bytes to mark the long-name form).
function writeCoffSymbolEntry(pe ByteArray, stringTable ByteArray, name String, value MachineWord, sectionNumber MachineWord, symType MachineWord, storageClass MachineWord, numAux MachineWord)
	let nameBytes = name.toByteArray()
	let nameLen = nameBytes.count()
	if nameLen <= 8 'shortName'
		pe.append(nameBytes)
		for _ in nameLen upto 8 'pad'
			pe.push(0)
		end 'pad'
	end 'shortName' else 'longName'
		writeDword(pe, value: 0)
		writeDword(pe, value: stringTable.count())
		stringTable.append(nameBytes)
		stringTable.push(0)
	end 'longName'
	writeDword(pe, value: value)
	writeWord(pe, value: sectionNumber)
	writeWord(pe, value: symType)
	pe.push(storageClass and 0xFF)
	pe.push(numAux and 0xFF)
end 'writeCoffSymbolEntry'

// One emitted PE section, paired with the size that goes into its COFF
// section-definition auxiliary record (raw on-disk size for PROGBITS-style
// sections like .text/.rdata/.idata/.data/.covdata/.symtab).
type PeSectionRec
	export var name as String
	export var rawSize as ByteCount

	export static function create(name String, rawSize ByteCount) returns PeSectionRec
		return Self{name: name, rawSize: rawSize}
	end 'create'
end 'PeSectionRec'

typealias PeSectionList = Array with PeSectionRec

// Append section symbols (one per emitted section, with a format-5 auxiliary
// record carrying the section's raw size) followed by one external function
// symbol per DebugSymbol entry, then the COFF string table. Returns the total
// symbol count for the COFF header backpatch.
function writeCoffSymbolTable(pe ByteArray, debugSymbols DebugSymbolArray, codeSize ByteCount, hasRdata bool, rdataSize ByteCount, hasSymdata bool, symdataSize ByteCount, idataSize ByteCount, dataRawSize ByteCount, hasCovdata bool, covdataSize ByteCount) returns MachineWord
	var stringTable = ByteArray.create()
	// Reserve the leading 4-byte size prefix; patched after all names are appended.
	writeZeros(stringTable, n: 4)

	// Section-symbol order MUST match the section-emission order in writePe so
	// the section number assigned here lines up with the COFF section index.
	var sections = PeSectionList.create()
	sections.push(PeSectionRec.create(".text", rawSize: codeSize))
	if hasRdata 'addRdata'
		sections.push(PeSectionRec.create(".rdata", rawSize: rdataSize))
	end 'addRdata'
	if hasSymdata 'addSymtab'
		sections.push(PeSectionRec.create(".symtab", rawSize: symdataSize))
	end 'addSymtab'
	sections.push(PeSectionRec.create(".idata", rawSize: idataSize))
	sections.push(PeSectionRec.create(".data", rawSize: dataRawSize))
	if hasCovdata 'addCovdata'
		sections.push(PeSectionRec.create(".covdata", rawSize: covdataSize))
	end 'addCovdata'

	var totalSymbolCount = 0 as MachineWord
	for (iter, section) in sections.withIterator() 'sectionSyms'
		// IMAGE_SYM_CLASS_STATIC = 3, no type, one auxiliary section-definition record.
		writeCoffSymbolEntry(pe, stringTable: stringTable, name: section.name, value: 0, sectionNumber: iter.index() + 1, symType: 0x0000, storageClass: 3, numAux: 1)
		totalSymbolCount = totalSymbolCount + 1
		// Auxiliary format 5 (section definition): 18 bytes total.
		writeDword(pe, value: section.rawSize)  // Length
		writeWord(pe, value: 0)  // NumberOfRelocations
		writeWord(pe, value: 0)  // NumberOfLinenumbers
		writeDword(pe, value: 0)  // CheckSum
		writeWord(pe, value: 0)  // Number (COMDAT)
		pe.push(0)  // Selection
		writeZeros(pe, n: 3)  // Unused
		totalSymbolCount = totalSymbolCount + 1
	end 'sectionSyms'

	// Function symbols: all live in .text (section 1).
	// IMAGE_SYM_DTYPE_FUNCTION = 0x0020, IMAGE_SYM_CLASS_EXTERNAL = 2.
	for sym in debugSymbols 'funcSyms'
		writeCoffSymbolEntry(pe, stringTable: stringTable, name: sym.name, value: sym.codeOffset, sectionNumber: 1, symType: 0x0020, storageClass: 2, numAux: 0)
		totalSymbolCount = totalSymbolCount + 1
	end 'funcSyms'

	// String table size prefix is the total table size (including the prefix itself).
	patchDword(stringTable, offset: 0, value: stringTable.count())
	pe.append(stringTable)

	return totalSymbolCount
end 'writeCoffSymbolTable'

// --- Main PE writer ---

// Convert a flat slot index into its byte offset in the IAT. Each DLL run
// in the IAT/ILT is followed by an 8-byte null terminator, so slots past
// the first DLL boundary are shifted by 8 bytes for every prior boundary.
// Boundaries: kernel32 (slots 0..KERNEL32_IAT_END-1), shell32 (slot
// SHELL32_IAT_START), ws2_32 (slots WS2_32_IAT_START onward). A ws2_32 slot is
// only ever the target of a relocation when the ws2_32 run is present (it is
// emitted exactly when `emitX64NetworkingRuntime` ran), so the ws2 branch can
// assume both prior null gaps (after kernel32, after shell32) exist.
function iatSlotByteOffset(slotIndex MachineWord) returns ByteOffset
	if slotIndex >= WS2_32_IAT_START 'inWs2'
		return (slotIndex + 2) * 8
	end 'inWs2'
	if slotIndex >= SHELL32_IAT_START 'inShell32'
		return (slotIndex + 1) * 8
	end 'inShell32'
	return slotIndex * 8
end 'iatSlotByteOffset'

// Patch x64 RIP-relative relocations: each relocation is a disp32 at codeOffset
function patchRelocationsX86(code ByteArray, relocations RelocationArray, textRva Rva, idataRva Rva)
	for reloc in relocations 'patch'
		let ripAtReloc = textRva + reloc.codeOffset + 4
		let iatEntryRva = idataRva + iatSlotByteOffset(reloc.slotIndex)
		let rel = iatEntryRva - ripAtReloc
		patchDword(code, offset: reloc.codeOffset, value: rel)
	end 'patch'
end 'patchRelocationsX86'

function patchRdataRelocationsX86(code ByteArray, rdataRelocs RdataRelocationArray, textRva Rva, rdataRva Rva, symdataRva Rva, dataRva Rva, covdataRva Rva)
	for reloc in rdataRelocs 'patch'
		let ripAtReloc = textRva + reloc.codeOffset + 4
		match reloc.kind 'kind'
			ripRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: rdataRva + reloc.rdataOffset - ripAtReloc)
			symdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: symdataRva - ripAtReloc)
			dataSectionRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: dataRva + reloc.rdataOffset - ripAtReloc)
			covdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: covdataRva + reloc.rdataOffset - ripAtReloc)
			arm64Adr to covdataArm64Adr then break 'kind'
			funcAbs64InRdata then break 'kind'
		end 'kind'
	end 'patch'
end 'patchRdataRelocationsX86'

function patchRdataRelocationsArm64(code ByteArray, rdataRelocs RdataRelocationArray, textRva Rva, rdataRva Rva, symdataRva Rva, dataRva Rva, covdataRva Rva)
	for reloc in rdataRelocs 'patch'
		let instrRva = textRva + reloc.codeOffset
		match reloc.kind 'patchKind'
			ripRelDisp32 to covdataRipRelDisp32 then break 'patchKind'
			arm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: rdataRva + reloc.rdataOffset)
			arm64LdrLiteral then patchArm64LdrLiteral(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: rdataRva + reloc.rdataOffset)
			symdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: symdataRva)
			dataSectionArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: dataRva + reloc.rdataOffset)
			covdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrRva, targetAddr: covdataRva + reloc.rdataOffset)
			funcAbs64InRdata then break 'patchKind'
		end 'patchKind'
	end 'patch'
end 'patchRdataRelocationsArm64'

// Patch ARM64 ADRP+LDR relocations: codeOffset points to ADRP, LDR is at codeOffset+4
function patchRelocationsArm64(code ByteArray, relocations RelocationArray, textRva Rva, idataRva Rva)
	for reloc in relocations 'patch'
		let iatEntryRva = idataRva + iatSlotByteOffset(reloc.slotIndex)
		let instrRva = textRva + reloc.codeOffset

		// ADRP: target page relative to instruction page
		let instrPage = instrRva and not 0xFFF
		let targetPage = iatEntryRva and not 0xFFF
		let pageOff = targetPage - instrPage
		let pageOffShifted = pageOff shr 12
		let immlo = pageOffShifted and 0x3
		let immhi = (pageOffShifted shr 2) and 0x7FFFF
		// Patch ADRP: preserve Rd, encode page offset
		let origAdrp = readDword(code, offset: reloc.codeOffset)
		let rd = origAdrp and 0x1F
		let patchedAdrp = (immlo shl 29) or 0x90000000 or (immhi shl 5) or rd
		patchDword(code, offset: reloc.codeOffset, value: patchedAdrp)

		// Patch LDR: encode page offset within the 4KB page, scaled by 8
		let pageOffset = iatEntryRva and 0xFFF
		let ldrOffset = reloc.codeOffset + 4
		let origLdr = readDword(code, offset: ldrOffset)
		let ldrImm = (pageOffset / 8) and 0xFFF
		let patchedLdr = (origLdr and 0xFFC003FF) or (ldrImm shl 10)
		patchDword(code, offset: ldrOffset, value: patchedLdr)
	end 'patch'
end 'patchRelocationsArm64'

export function writePe(outputPath FilePath, codeResult CodeResult, target Target)
	logInfo(LogCategory.binary, message: function() gives "Writing PE file: {outputPath}")
	var pe = ByteArray.create()
	pe.reserve(4096)

	var code = codeResult.code
	let codeSize = code.count()
	let rdataSize = codeResult.rdata.count()
	let symdataSize = codeResult.symdata.count()
	let covdataSize = codeResult.covDataSectionBytes.count()
	let hasRdata = rdataSize > 0
	let hasSymdata = symdataSize > 0
	let hasCovdata = covdataSize > 0

	// Count sections: .text + .idata + .data + optional .rdata + optional .symtab + optional .covdata
	var numSections = 3
	if hasRdata 'countRdata'
		numSections = numSections + 1
	end 'countRdata'
	if hasSymdata 'countSymdata'
		numSections = numSections + 1
	end 'countSymdata'
	if hasCovdata 'countCovdata'
		numSections = numSections + 1
	end 'countCovdata'

	// Header sizes
	let headersSize = 64 + 4 + 20 + 240 + (40 * numSections)
	let headersAligned = alignUp(headersSize, alignment: FILE_ALIGNMENT)

	// .text section
	let codeSizeAligned = alignUp(codeSize, alignment: FILE_ALIGNMENT)
	let codeSizeVirtual = alignUp(codeSize, alignment: SECTION_ALIGNMENT)
	let textRva = SECTION_ALIGNMENT

	// .rdata section
	let rdataRva = textRva + codeSizeVirtual
	let rdataSizeAligned = alignUp(rdataSize, alignment: FILE_ALIGNMENT)
	var rdataSizeVirtual = 0
	if hasRdata 'setRdataVirtual'
		rdataSizeVirtual = alignUp(rdataSize, alignment: SECTION_ALIGNMENT)
	end 'setRdataVirtual'

	// .symtab section
	let symdataRva = rdataRva + rdataSizeVirtual
	let symdataSizeAligned = alignUp(symdataSize, alignment: FILE_ALIGNMENT)
	var symdataSizeVirtual = 0
	if hasSymdata 'setSymdataVirtual'
		symdataSizeVirtual = alignUp(symdataSize, alignment: SECTION_ALIGNMENT)
	end 'setSymdataVirtual'

	// .idata section. ws2_32 is imported only when the emitted code actually
	// references a ws2_32 IAT slot (i.e. `emitX64NetworkingRuntime` ran). The
	// same `usesWs2_32` drives the IAT data-directory size below so the directory
	// and the physically-emitted table always agree.
	let usesWs2_32 = programUsesWs2_32(codeResult.relocations)
	let idataRva = symdataRva + symdataSizeVirtual
	let idata = buildImportSection(idataRva, usesWs2_32: usesWs2_32)
	let idataSize = idata.data.count()
	let idataSizeAligned = alignUp(idataSize, alignment: FILE_ALIGNMENT)
	let idataSizeVirtual = alignUp(idataSize, alignment: SECTION_ALIGNMENT)

	// .data section: 64KB heap arena, zero-initialized by the OS loader. The
	// on-disk image is a single file-aligned block sized just large enough to
	// hold every initialized prelude entry (top-level vars + runtime state
	// slots like `__slab_*`, `__mm_*`); the rest of the virtual region is
	// uninitialized and the loader zero-fills it. Step 6a.17 pushed the
	// prelude past 512 bytes once the slab/MM allocator state was registered,
	// so a single FILE_ALIGNMENT block is no longer enough.
	let dataRva = idataRva + idataSizeVirtual
	let preludeSize = codeResult.dataPrelude.count()
	var dataRawSize = FILE_ALIGNMENT
	if preludeSize > dataRawSize 'growDataRaw'
		dataRawSize = alignUp(preludeSize, alignment: FILE_ALIGNMENT)
	end 'growDataRaw'
	let dataSizeVirtual = alignUp(DATA_SECTION_VIRTUAL_SIZE, alignment: SECTION_ALIGNMENT)

	// .covdata section: dedicated writable RVA for coverage counter globals.
	// Emitted only when the backend produced covDataSectionBytes so non-coverage
	// builds stay byte-identical.
	let covdataRva = dataRva + dataSizeVirtual
	let covdataSizeAligned = alignUp(covdataSize, alignment: FILE_ALIGNMENT)
	var covdataSizeVirtual = 0
	if hasCovdata 'setCovdataVirtual'
		covdataSizeVirtual = alignUp(covdataSize, alignment: SECTION_ALIGNMENT)
	end 'setCovdataVirtual'

	let imageSize = covdataRva + covdataSizeVirtual

	logDebug(LogCategory.binary, message: function() gives "Code section: {codeSize} bytes")
	logDebug(LogCategory.binary, message: function() gives "Rdata section: {rdataSize} bytes")
	logDebug(LogCategory.binary, message: function() gives "Symdata section: {symdataSize} bytes")
	logDebug(LogCategory.binary, message: function() gives "Import section: {idataSize} bytes")
	logDebug(LogCategory.binary, message: function() gives "Data section: {DATA_SECTION_VIRTUAL_SIZE} bytes (virtual)")
	logDebug(LogCategory.binary, message: function() gives "Covdata section: {covdataSize} bytes")

	// Patch IAT references in code (different encoding per CPU architecture)
	match target.cpu 'patchCpu'
		x64 then patchRelocationsX86(code, relocations: codeResult.relocations, textRva: textRva, idataRva: idataRva)
		arm64 then patchRelocationsArm64(code, relocations: codeResult.relocations, textRva: textRva, idataRva: idataRva)
		wasm32 then panic("PE writer not used for WASM targets")
	end 'patchCpu'

	// Patch rdata, symdata, data, and covdata section references in code
	match target.cpu 'patchRdata'
		x64 then patchRdataRelocationsX86(code, rdataRelocs: codeResult.rdataRelocations, textRva: textRva, rdataRva: rdataRva, symdataRva: symdataRva, dataRva: dataRva, covdataRva: covdataRva)
		arm64 then patchRdataRelocationsArm64(code, rdataRelocs: codeResult.rdataRelocations, textRva: textRva, rdataRva: rdataRva, symdataRva: symdataRva, dataRva: dataRva, covdataRva: covdataRva)
		wasm32 then panic("PE writer not used for WASM targets")
	end 'patchRdata'

	// Phase 11.2: patch the rdata-internal funcAbs64 slots (layout-descriptor
	// copy/destroy, witness-table methods). PE ImageBase is fixed at
	// 0x140000000 below; absolute VAs we write here assume the loader places
	// the image there. We clear DYNAMIC_BASE / HIGH_ENTROPY_VA in
	// DllCharacteristics so the loader pins the image at ImageBase — without
	// a base-relocation table, ASLR would leave these abs64 slots pointing at
	// the wrong VA and indirect calls through them DEP-fault. If a future PE
	// update adds a base reloc table, every funcAbs64 slot will need a
	// corresponding entry there and DYNAMIC_BASE can be re-enabled.
	let imageBase = 0x140000000
	patchFuncAbs64InRdata(codeResult.rdata, rdataRelocs: codeResult.rdataRelocations, textAbsBase: imageBase + textRva, debugSymbols: codeResult.debugSymbols)

	// IAT directory size: one qword per emitted slot plus one null terminator per
	// imported DLL. Layout matches `buildImportSection` — both sized from the
	// same `usesWs2_32`, so the directory size never diverges from the table.
	let iatDirSize = (emittedIatSlotCount(usesWs2_32) + importDirEntries(usesWs2_32)) * 8

	// === DOS Header (64 bytes) + PE Signature ===
	// MZ magic, 58 zero bytes, PE offset=64, then PE\0\0 signature
	pe.append(b"MZ\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x40\x00\x00\x00PE\x00\x00")

	// === COFF Header (20 bytes) ===
	let coffMachine = match target.cpu 'coffCpu'
		x64 gives 0x8664
		arm64 gives 0xAA64
		default panic("PE writer not used for WASM targets")
	end 'coffCpu'
	writeWord(pe, value: coffMachine)
	writeWord(pe, value: numSections)
	// TimeDateStamp stays zero; PointerToSymbolTable + NumberOfSymbols are
	// backpatched after the COFF symbol table is appended at the end of the file.
	writeZeros(pe, n: 4)  // TimeDateStamp
	let pointerToSymbolTableOffset = pe.count()  // file offset 76
	writeZeros(pe, n: 4)  // PointerToSymbolTable (patched later)
	let numberOfSymbolsOffset = pe.count()  // file offset 80
	writeZeros(pe, n: 4)  // NumberOfSymbols (patched later)
	writeWord(pe, value: 240)  // SizeOfOptionalHeader
	writeWord(pe, value: 0x22)  // Characteristics

	// === Optional Header PE32+ (240 bytes) ===
	pe.append(b"\x0b\x02\x0e\x00")
	writeDword(pe, value: codeSizeAligned)
	writeDword(pe, value: rdataSizeAligned + symdataSizeAligned + idataSizeAligned + covdataSizeAligned)
	pe.append(b"\x00\x00\x00\x00")  // BaseOfCode(0) — placeholder before textRva writes
	writeDword(pe, value: textRva)
	writeDword(pe, value: textRva)

	// ImageBase(0x140000000), SectionAlignment(4096), FileAlignment(512)
	// MajorOSVersion(6), MinorOSVersion(0), MajorImageVersion(0), MinorImageVersion(0)
	// MajorSubsystemVersion(6), MinorSubsystemVersion(0), Win32VersionValue(0)
	pe.append(b"\x00\x00\x00\x40\x01\x00\x00\x00\x00\x10\x00\x00\x00\x02\x00\x00\x06\x00\x00\x00\x00\x00\x00\x00\x06\x00\x00\x00\x00\x00\x00\x00")
	writeDword(pe, value: imageSize)
	writeDword(pe, value: headersAligned)
	// CheckSum(0), Subsystem(3=CONSOLE), DllCharacteristics(0x8100 — NX_COMPAT
	// + TERMINAL_SERVER_AWARE; DYNAMIC_BASE/HIGH_ENTROPY_VA cleared because
	// rdata abs64 slots have no base-relocs to fix up under ASLR slide).
	// SizeOfStackReserve(0x100000), SizeOfStackCommit(0x1000)
	// SizeOfHeapReserve(0x100000), SizeOfHeapCommit(0x1000)
	// LoaderFlags(0), NumberOfRvaAndSizes(16)
	pe.append(b"\x00\x00\x00\x00\x03\x00\x00\x81\x00\x00\x10\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x10\x00\x00\x00")

	// Data directories: 0=Export(zeros), 1=Import
	pe.append(b"\x00\x00\x00\x00\x00\x00\x00\x00")
	writeDword(pe, value: idata.importDirRva)
	writeDword(pe, value: idata.importDirSize)
	// 2-11: zeros
	writeZeros(pe, n: 80)
	// 12: IAT
	writeDword(pe, value: idata.iatRva)
	writeDword(pe, value: iatDirSize)
	// 13-15: zeros
	writeZeros(pe, n: 24)

	// === Section Headers ===
	// .text uses R+X (0x60000020); .rdata uses R-only (0x40000040); .idata, .data, .symtab,
	// and .covdata are all writable initialized data (0xC0000040).
	var nextFilePointer = headersAligned + codeSizeAligned
	writeSectionHeader(pe, name: ".text", virtualSize: codeSize, virtualAddress: textRva, rawDataSize: codeSizeAligned, rawDataPointer: headersAligned, characteristics: 0x60000020)
	if hasRdata 'writeRdataHeader'
		writeSectionHeader(pe, name: ".rdata", virtualSize: rdataSize, virtualAddress: rdataRva, rawDataSize: rdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0x40000040)
		nextFilePointer = nextFilePointer + rdataSizeAligned
	end 'writeRdataHeader'
	if hasSymdata 'writeSymdataHeader'
		writeSectionHeader(pe, name: ".symtab", virtualSize: symdataSize, virtualAddress: symdataRva, rawDataSize: symdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
		nextFilePointer = nextFilePointer + symdataSizeAligned
	end 'writeSymdataHeader'
	writeSectionHeader(pe, name: ".idata", virtualSize: idataSize, virtualAddress: idataRva, rawDataSize: idataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	nextFilePointer = nextFilePointer + idataSizeAligned
	// .data section: writable, 64KB virtual size with one file-aligned block on disk
	writeSectionHeader(pe, name: ".data", virtualSize: DATA_SECTION_VIRTUAL_SIZE, virtualAddress: dataRva, rawDataSize: dataRawSize, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	nextFilePointer = nextFilePointer + dataRawSize
	if hasCovdata 'writeCovdataHeader'
		writeSectionHeader(pe, name: ".covdata", virtualSize: covdataSize, virtualAddress: covdataRva, rawDataSize: covdataSizeAligned, rawDataPointer: nextFilePointer, characteristics: 0xC0000040)
	end 'writeCovdataHeader'

	// Pad headers to alignment
	padTo(pe, size: headersAligned)

	// === .text section ===
	pe.append(code)
	padTo(pe, size: headersAligned + codeSizeAligned)

	// === .rdata section ===
	if hasRdata 'writeRdata'
		pe.append(codeResult.rdata)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned)
	end 'writeRdata'

	// === .symtab section ===
	if hasSymdata 'writeSymdata'
		pe.append(codeResult.symdata)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned)
	end 'writeSymdata'

	// === .idata section ===
	pe.append(idata.data)
	padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned + idataSizeAligned)

	// === .data section ===
	// First the data prelude (initial values for top-level / static-field
	// globals), then zeros for the rest of the on-disk block. The OS loader
	// zero-fills the remaining virtual bytes (the heap arena) at load time.
	if codeResult.dataPrelude.count() > dataRawSize 'preludeOverflow'
		panic("data prelude ({codeResult.dataPrelude.count()} bytes) exceeds .data raw size ({dataRawSize}); raise FILE_ALIGNMENT or grow the on-disk .data block.")
	end 'preludeOverflow'
	pe.append(codeResult.dataPrelude)
	writeZeros(pe, n: dataRawSize - codeResult.dataPrelude.count())

	// === .covdata section ===
	// Coverage counter globals (initial bytes carry the __data_cov_num_sites
	// header; __data_cov_counters is zero-filled). Emitted only when present.
	if hasCovdata 'writeCovdata'
		pe.append(codeResult.covDataSectionBytes)
		padTo(pe, size: headersAligned + codeSizeAligned + rdataSizeAligned + symdataSizeAligned + idataSizeAligned + dataRawSize + covdataSizeAligned)
	end 'writeCovdata'

	// === COFF symbol table + string table ===
	// Appended past the last loadable section. Image loaders ignore trailing
	// bytes; debuggers (lldb, llvm-objdump) read this table to resolve names.
	if codeResult.debugSymbols.count() > 0 'writeCoff'
		let symbolTableFileOffset = pe.count()
		let totalSymbolCount = writeCoffSymbolTable(pe, debugSymbols: codeResult.debugSymbols, codeSize: codeSize, hasRdata: hasRdata, rdataSize: rdataSize, hasSymdata: hasSymdata, symdataSize: symdataSize, idataSize: idataSize, dataRawSize: dataRawSize, hasCovdata: hasCovdata, covdataSize: covdataSize)
		patchDword(pe, offset: pointerToSymbolTableOffset, value: symbolTableFileOffset)
		patchDword(pe, offset: numberOfSymbolsOffset, value: totalSymbolCount)
		logDebug(LogCategory.binary, message: function() gives "COFF symbol table: {totalSymbolCount} entries at file offset {symbolTableFileOffset}")
	end 'writeCoff'

	// Write to file
	try File.writeBinary(outputPath, content: pe) otherwise 'writeErr'
		logError(LogCategory.binary, message: function() gives "Failed to write PE file: {outputPath}")
	end 'writeErr'
end 'writePe'

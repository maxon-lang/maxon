end 'remapX64BaseUseFpUse'

function remapX64BaseUseFpDef(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		loadIndirectXmm(dest, base, offset, precision) gives X64Op.loadIndirectXmm(remapFpReg(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset, precision: precision)
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64BaseUseFpDef'

function remapX64MovRegReg(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		movRegReg(dest, src) gives X64Op.movRegReg(remapGpr(dest, remap: remap), srcReg: remapGpr(src, remap: remap))
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64MovRegReg'

function remapX64ConstImm(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		movRegImm(dest, value) gives X64Op.movRegImm(remapGpr(dest, remap: remap), value: value)
		movRegImm32(dest, value) gives X64Op.movRegImm32(remapGpr(dest, remap: remap), value: value)
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64ConstImm'

function remapX64Shift(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		shlRegCl(dest, operand, shiftCount) gives X64Op.shlRegCl(remapGpr(dest, remap: remap), operand: remapGpr(operand, remap: remap), shiftCount: remapGpr(shiftCount, remap: remap))
		sarRegCl(dest, operand, shiftCount) gives X64Op.sarRegCl(remapGpr(dest, remap: remap), operand: remapGpr(operand, remap: remap), shiftCount: remapGpr(shiftCount, remap: remap))
		shrRegCl(dest, operand, shiftCount) gives X64Op.shrRegCl(remapGpr(dest, remap: remap), operand: remapGpr(operand, remap: remap), shiftCount: remapGpr(shiftCount, remap: remap))
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64Shift'

function remapX64DivReg(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		idivReg(divisor) gives X64Op.idivReg(remapGpr(divisor, remap: remap))
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64DivReg'

function remapX64CallIndirect(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		callIndirect(reg) gives X64Op.callIndirect(remapGpr(reg, remap: remap))
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64CallIndirect'

function remapX64Exchange(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		xchgRegReg(r1, r2) gives X64Op.xchgRegReg(remapGpr(r1, remap: remap), reg2: remapGpr(r2, remap: remap))
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64Exchange'

// Phase 2: remap virtual regs in a memory-operand ALU op.
function remapX64BaseUseUseDef(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		addRegMem(dest, base, offset) gives X64Op.addRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		subRegMem(dest, base, offset) gives X64Op.subRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		andRegMem(dest, base, offset) gives X64Op.andRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		orRegMem(dest, base, offset) gives X64Op.orRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		xorRegMem(dest, base, offset) gives X64Op.xorRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		imulRegMem(dest, base, offset) gives X64Op.imulRegMem(remapGpr(dest, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64BaseUseUseDef'

// Phase 2: remap virtual regs in a memory-operand compare op.
function remapX64BaseTwoUse(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		cmpRegMem(lhs, base, offset) gives X64Op.cmpRegMem(remapGpr(lhs, remap: remap), baseReg: remapGpr(base, remap: remap), offset: offset)
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64BaseTwoUse'

// Phase 2: remap virtual regs in a three-operand immediate-form op.
function remapX64DefUseImm(x64Op X64Op, remap RegIntArray) returns X64Op
	return match x64Op 'remap'
		imulRegImm(dest, src, value) gives X64Op.imulRegImm(remapGpr(dest, remap: remap), srcReg: remapGpr(src, remap: remap), value: value)
		default panic("remapX64: unexpected op for pattern")
	end 'remap'
end 'remapX64DefUseImm'

// Phase 3: try to rewrite `x64Op` to read its spilled `valueId` operand
// directly from memory at [rbp+stackOffset], instead of from a register.
// On success appends the new op to module.x64Ops and returns its index;
// on failure returns -1 so the caller falls back to a normal reload.
//
// The match is exhaustive over X64Op to satisfy Maxon's exhaustiveness
// check; only the foldable two-address ALU forms and cmpRegReg with a
// spilled rhs produce a folded op. All other shapes return -1.
function tryAppendFoldedX64Op(module TargetModule, x64Op X64Op, valueId RegInt, stackOffset RegInt) returns RegInt
	let rbp = physReg(X64Register.rbp)
	return match x64Op 'fold'
		prologue to ret gives -1
		movRegImm to movRegImm32 gives -1
		movSlot to loadSlot gives -1
		addRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 0, rbpBase: rbp, stackOffset: stackOffset)
		subRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 1, rbpBase: rbp, stackOffset: stackOffset)
		addRegImm to subRegImm gives -1
		imulRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 5, rbpBase: rbp, stackOffset: stackOffset)
		idivRcx to bitNotReg gives -1
		andRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 2, rbpBase: rbp, stackOffset: stackOffset)
		orRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 3, rbpBase: rbp, stackOffset: stackOffset)
		xorRegReg(destReg, srcReg) gives foldTwoAddrToMem(module, destReg: destReg, srcReg: srcReg, valueId: valueId, kind: 4, rbpBase: rbp, stackOffset: stackOffset)
		shlRegCl to addRspImm gives -1
		movRspOffsetReg to memcpyOp gives -1
		// movRegReg(dest, src) with spilled src is equivalent to a
		// reloadFromStack(dest, srcOffset) — the dest is fresh and the
		// load IS the mov. Folding removes the intermediate reload vreg.
		movRegReg(destReg, srcReg) gives foldMovToReload(module, destReg: destReg, srcReg: srcReg, valueId: valueId, stackOffset: stackOffset)
		cmpRegReg(lhsReg, rhsReg) gives foldCmpToMem(module, lhsReg: lhsReg, rhsReg: rhsReg, valueId: valueId, rbpBase: rbp, stackOffset: stackOffset)
		cmpRegImm to testRegReg gives -1
		cqo to xchgRegReg gives -1
		movXmmXmm to globalStoreXmm gives -1
		leaFromStack to cmov gives -1
		movsxd to stashEntryArgv gives -1
		addRegMem to imulRegImm gives -1
	end 'fold'
end 'tryAppendFoldedX64Op'

// Push a `kind`-tagged reg-mem two-address fold to module.x64Ops and
// return its index, or -1 if the spilled valueId is not the source of
// `destReg, srcReg` (or source == dest aliasing precludes folding).
// kind codes: 0=add, 1=sub, 2=and, 3=or, 4=xor, 5=imul.
function foldTwoAddrToMem(module TargetModule, destReg X64VReg, srcReg X64VReg, valueId RegInt, kind RegInt, rbpBase X64VReg, stackOffset RegInt) returns RegInt
	let srcId = x64VRegId(srcReg)
	let destId = x64VRegId(destReg)
	if srcId != valueId 'srcNotSpilled'
		return -1
	end 'srcNotSpilled'
	if destId == srcId 'aliased'
		// Same-vreg two-address (e.g. xorRegReg(v, v)): the source operand
		// IS the dest. Fall back to reload so coloring sees the dest as a
		// real virtual register and the fold doesn't generate `op mem, mem`.
		return -1
	end 'aliased'
	let newIdx = module.x64Ops.count()
	let newOp = match kind 'pick'
		0 gives X64Op.addRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		1 gives X64Op.subRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		2 gives X64Op.andRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		3 gives X64Op.orRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		4 gives X64Op.xorRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		5 gives X64Op.imulRegMem(destReg, baseReg: rbpBase, offset: stackOffset)
		default panic("foldTwoAddrToMem: unknown kind {kind}")
	end 'pick'
	module.x64Ops.push(newOp)
	return newIdx
end 'foldTwoAddrToMem'

// Fold movRegReg(dest, srcSpilled) → reloadFromStack(dest, srcOffset).
// Eliminates the intermediate reload vreg that would otherwise be needed
// to load srcSpilled into a register before the mov. The dest is virtual,
// so the reload's def assigns it directly. Physical-reg dests fold too —
// reloadFromStack accepts either kind for destReg.
function foldMovToReload(module TargetModule, destReg X64VReg, srcReg X64VReg, valueId RegInt, stackOffset RegInt) returns RegInt
	let srcId = x64VRegId(srcReg)
	if srcId != valueId 'srcNotSpilled'
		return -1
	end 'srcNotSpilled'
	let newIdx = module.x64Ops.count()
	module.x64Ops.push(X64Op.reloadFromStack(destReg, offset: stackOffset))
	return newIdx
end 'foldMovToReload'

// Fold cmpRegReg → cmpRegMem when the spilled value is the rhs operand.
// Refuse to fold when rhs != valueId (would need a swapped variant that
// flips flag semantics) or when lhs == rhs (no clear single-operand fold).
function foldCmpToMem(module TargetModule, lhsReg X64VReg, rhsReg X64VReg, valueId RegInt, rbpBase X64VReg, stackOffset RegInt) returns RegInt
	let lhsId = x64VRegId(lhsReg)
	let rhsId = x64VRegId(rhsReg)
	if rhsId != valueId 'rhsNotSpilled'
		return -1
	end 'rhsNotSpilled'
	if lhsId == rhsId 'aliased'
		return -1
	end 'aliased'
	let newIdx = module.x64Ops.count()
	module.x64Ops.push(X64Op.cmpRegMem(lhsReg, baseReg: rbpBase, offset: stackOffset))
	return newIdx
end 'foldCmpToMem'

// ============================================================
// X64 CopyEmitter implementation
// ============================================================

// Concrete CopyEmitter for x64 phi / call-arg parallel-copy resolution. Stores
// concrete module/block/desc (no interface field) and calls the free x64 emit
// functions, appending movRegReg / movXmmXmm / xchg ops into `dstBlock`.
export type X64CopyEmitter implements CopyEmitter
	export var module as TargetModule
	export var dstBlock as IrBlock
	export var desc as TargetRegAlloc

	export static function create(module TargetModule, dstBlock IrBlock, desc TargetRegAlloc) returns X64CopyEmitter
		return Self{module: module, dstBlock: dstBlock, desc: desc}
	end 'create'

	function emitMovReg(destOrd RegOrdinal, srcOrd RegOrdinal)
		emitMovRegX64(self.module, dstBlock: self.dstBlock, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovReg'

	function emitMovFp(destOrd RegOrdinal, srcOrd RegOrdinal)
		emitMovFpX64(self.module, dstBlock: self.dstBlock, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovFp'

	function emitXchg(ord1 RegOrdinal, ord2 RegOrdinal)
		emitXchgX64(self.module, dstBlock: self.dstBlock, ord1: ord1, ord2: ord2)
	end 'emitXchg'

	function gprCycleBreakOrd() returns RegOrdinal
		return self.desc.gprCycleBreakOrd
	end 'gprCycleBreakOrd'

	function fpCycleBreakOrd() returns RegOrdinal
		return self.desc.fpCycleBreakOrd
	end 'fpCycleBreakOrd'

	function hasXchg() returns bool
		return self.desc.hasXchg
	end 'hasXchg'
end 'X64CopyEmitter'

// ============================================================
// X64 RegAllocTarget implementation
// ============================================================

export type X64RegAllocTarget implements RegAllocTarget
	export let tag as RegInt

	// --- GPR emission ---

	function emitSpill(module TargetModule, dstBlock IrBlock, regOrdinal RegOrdinal, stackOffset RegInt)
		emitSpillX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
	end 'emitSpill'

	function emitReload(module TargetModule, dstBlock IrBlock, regOrdinal RegOrdinal, stackOffset RegInt)
		emitReloadX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
	end 'emitReload'

	function emitMovImm(module TargetModule, dstBlock IrBlock, regOrdinal RegOrdinal, value RegInt)
		emitMovImmX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, value: value)
	end 'emitMovImm'

	function emitMovReg(module TargetModule, dstBlock IrBlock, destOrd RegOrdinal, srcOrd RegOrdinal)
		emitMovRegX64(module, dstBlock: dstBlock, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovReg'

	// --- FP emission ---

	function emitSpillFp(module TargetModule, dstBlock IrBlock, fpOrdinal RegOrdinal, stackOffset RegInt)
		emitSpillFpX64(module, dstBlock: dstBlock, fpOrdinal: fpOrdinal, stackOffset: stackOffset)
	end 'emitSpillFp'

	function emitReloadFp(module TargetModule, dstBlock IrBlock, fpOrdinal RegOrdinal, stackOffset RegInt)
		emitReloadFpX64(module, dstBlock: dstBlock, fpOrdinal: fpOrdinal, stackOffset: stackOffset)
	end 'emitReloadFp'

	function emitMovFp(module TargetModule, dstBlock IrBlock, destOrd RegOrdinal, srcOrd RegOrdinal)
		emitMovFpX64(module, dstBlock: dstBlock, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovFp'

	function emitGprToFp(module TargetModule, dstBlock IrBlock, fpOrdinal RegOrdinal, gprOrdinal RegOrdinal)
		emitGprToFpX64(module, dstBlock: dstBlock, fpOrdinal: fpOrdinal, gprOrdinal: gprOrdinal)
	end 'emitGprToFp'

	// --- Call/stack emission ---

	function emitCallDirect(module TargetModule, dstBlock IrBlock, callee String)
		emitCallDirectX64(module, dstBlock: dstBlock, callee: callee)
	end 'emitCallDirect'

	function emitCallIndirect(module TargetModule, dstBlock IrBlock, regOrd RegOrdinal)
		emitCallIndirectX64(module, dstBlock: dstBlock, regOrd: regOrd)
	end 'emitCallIndirect'

	function emitSubSp(module TargetModule, dstBlock IrBlock, amount RegInt)
		emitSubSpX64(module, dstBlock: dstBlock, amount: amount)
	end 'emitSubSp'

	function emitAddSp(module TargetModule, dstBlock IrBlock, amount RegInt)
		emitAddSpX64(module, dstBlock: dstBlock, amount: amount)
	end 'emitAddSp'

	function emitStoreToSpOffset(module TargetModule, dstBlock IrBlock, regOrd RegOrdinal, offset RegInt)
		emitStoreToSpOffsetX64(module, dstBlock: dstBlock, regOrd: regOrd, offset: offset)
	end 'emitStoreToSpOffset'

	function emitXchg(module TargetModule, dstBlock IrBlock, ord1 RegOrdinal, ord2 RegOrdinal)
		emitXchgX64(module, dstBlock: dstBlock, ord1: ord1, ord2: ord2)
	end 'emitXchg'

	function makeCopyEmitter(module TargetModule, dstBlock IrBlock, desc TargetRegAlloc) returns CopyEmitter
		return X64CopyEmitter.create(module, dstBlock: dstBlock, desc: desc)
	end 'makeCopyEmitter'

	function emitEpilogue(module TargetModule, dstBlock IrBlock)
		emitEpilogueX64(module, dstBlock: dstBlock)
	end 'emitEpilogue'

	// --- Register queries ---

	function regName(ord RegOrdinal) returns String
		return regNameX64(ord)
	end 'regName'

	function isReturnTerminator(module TargetModule, packed OpIndex) returns bool
		return isX64RetTerminator(module, packed: packed)
	end 'isReturnTerminator'

	function isDivergingBlock(module TargetModule, block IrBlock) returns bool
		return isX64DivergingBlock(module, block: block)
	end 'isDivergingBlock'

	function preSeedParams(module TargetModule, state RegState, srcFunc IrFunction)
		preSeedX64ParamRegisters(module, state: state, srcFunc: srcFunc)
	end 'preSeedParams'

	// --- Op analysis ---

	function opHasVirtualRegs(module TargetModule, packed OpIndex) returns bool
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return x64OpHasVirtualRegs(x64Op)
	end 'opHasVirtualRegs'

	function getImplicitGprDefs(module TargetModule, packed OpIndex) returns RegMask
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return x64Op.rawValue.implicitGprDefs
	end 'getImplicitGprDefs'

	// Explicit phys-dest writes (arg movs, folded spill reloads, phys-dest
	// leas/imms) are surfaced separately from the instantaneous side-effect
	// clobbers above: `insertPhysicalConstraints` extends their pseudo-ranges
	// to the next call in the block, modeling the arg register's OCCUPANCY
	// from the move to the call it feeds. Without this, a sequence like
	//     mov rcx, count_v
	//     mov resultV, value_v   ; <-- regalloc may pick rcx for resultV
	//     shr resultV, resultV, rcx
	// happily clobbers rcx in the second mov — and a value hint-coalesced
	// into an arg register was clobbered by a later constant materialized
	// into the same register before the call (see `x64OpPhysGprDestMask`).
	function getPhysGprDestMask(module TargetModule, packed OpIndex) returns RegMask
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return x64OpPhysGprDestMask(x64Op)
	end 'getPhysGprDestMask'

	function getImplicitGprReads(module TargetModule, packed OpIndex) returns RegMask
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return x64Op.rawValue.implicitGprReads
	end 'getImplicitGprReads'

	function getCallConvGprOrd(index RegInt) returns CallConvSlot
		let regs = [1, 2, 0, 9, 6, 7, 3]
		if let ord = try regs.get(index) 'inRange'
			return CallConvSlot.gpr(ord)
		end 'inRange'
		return CallConvSlot.spilled
	end 'getCallConvGprOrd'

	// --- Liveness helpers ---

	function countOpReads(module TargetModule, counts RegIntArray, packed OpIndex)
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		countX64OpReads(counts, x64Op: x64Op)
	end 'countOpReads'

	function noteOpDefs(module TargetModule, defBlocks RegIntArray, blockIdx RegInt, packed OpIndex)
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		noteX64OpDefs(defBlocks, blockIdx: blockIdx, x64Op: x64Op)
	end 'noteOpDefs'

	// --- Remap/substitute ---

	function remapOp(module TargetModule, packed OpIndex, remap RegIntArray) returns OpIndex
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		let remapped = remapX64Op(x64Op, remap: remap)
		let newIdx = module.x64Ops.count()
		module.x64Ops.push(remapped)
		return newIdx
	end 'remapOp'

	function substituteOp(module TargetModule, packed OpIndex, coloring ColoringResult, opRefs OpIndexList)
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		colorX64Op(module, x64Op: x64Op, coloring: coloring, opRefs: opRefs)
	end 'substituteOp'

	// --- CFG queries ---

	function getCondBrTarget(module TargetModule, packed OpIndex) returns RegInt
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return match x64Op 'check'
			condJump(_, targetBlock) gives targetBlock
			prologue to testRaxRax gives -1
			jmp to imulRegImm gives -1
		end 'check'
	end 'getCondBrTarget'

	function isUnconditionalJmp(module TargetModule, packed OpIndex) returns bool
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return match x64Op 'check'
			jmp gives true
			prologue to condJump gives false
			movF64Slot to imulRegImm gives false
		end 'check'
	end 'isUnconditionalJmp'

	function getBranchTarget(module TargetModule, packed OpIndex) returns RegInt
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return match x64Op 'check'
			jmp(targetBlock) gives targetBlock
			prologue to condJump gives -1
			movF64Slot to imulRegImm gives -1
		end 'check'
	end 'getBranchTarget'

	function getUncondJmpTarget(module TargetModule, packed OpIndex) returns RegInt
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return match x64Op 'check'
			jmp(targetBlock) gives targetBlock
			prologue to condJump gives -1
			movF64Slot to imulRegImm gives -1
		end 'check'
	end 'getUncondJmpTarget'

	function rewriteJmpTarget(module TargetModule, packed OpIndex, newTarget RegInt) returns OpIndex
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		let newOp = match x64Op 'rewrite'
			jmp gives X64Op.jmp(newTarget)
			prologue to condJump gives x64Op
			movF64Slot to imulRegImm gives x64Op
		end 'rewrite'
		let newIdx = module.x64Ops.count()
		module.x64Ops.push(newOp)
		return newIdx
	end 'rewriteJmpTarget'

	function rewriteCondBrTarget(module TargetModule, packed OpIndex, newTarget RegInt) returns OpIndex
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		let newOp = match x64Op 'rewrite'
			condJump(condition, _) gives X64Op.condJump(condition, targetBlock: newTarget)
			prologue to testRaxRax gives x64Op
			jmp to imulRegImm gives x64Op
		end 'rewrite'
		let newIdx = module.x64Ops.count()
		module.x64Ops.push(newOp)
		return newIdx
	end 'rewriteCondBrTarget'

	function createJmpOp(module TargetModule, blockId BlockId) returns OpIndex
		let idx = module.x64Ops.count()
		module.x64Ops.push(X64Op.jmp(blockId))
		return idx
	end 'createJmpOp'

	// --- Spill code emission ---

	function emitSpillStore(module TargetModule, ops OpIndexList, valueId RegInt, stackOffset RegInt, regClass RegInt)
		if regClass == 1 'fp'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.spillXmmToStack(stackOffset, src: X64FpVReg.virtual(valueId), precision: FloatPrecision.f64))
			ops.append(idx)
		end 'fp' else 'gpr'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.spillToStack(stackOffset, srcReg: X64VReg.virtual(valueId)))
			ops.append(idx)
		end 'gpr'
	end 'emitSpillStore'

	function emitReloadOp(module TargetModule, ops OpIndexList, freshId RegInt, stackOffset RegInt, regClass RegInt)
		if regClass == 1 'fp'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.reloadXmmFromStack(X64FpVReg.virtual(freshId), offset: stackOffset, precision: FloatPrecision.f64))
			ops.append(idx)
		end 'fp' else 'gpr'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.reloadFromStack(X64VReg.virtual(freshId), offset: stackOffset))
			ops.append(idx)
		end 'gpr'
	end 'emitReloadOp'

	function emitVirtualMov(module TargetModule, ops OpIndexList, destValueId RegInt, srcValueId RegInt, regClass RegInt)
		if regClass == 1 'fp'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.movXmmXmm(X64FpVReg.virtual(destValueId), src: X64FpVReg.virtual(srcValueId), precision: FloatPrecision.f64))
			ops.append(idx)
		end 'fp' else 'gpr'
			let idx = module.x64Ops.count()
			module.x64Ops.push(X64Op.movRegReg(X64VReg.virtual(destValueId), srcReg: X64VReg.virtual(srcValueId)))
			ops.append(idx)
		end 'gpr'
	end 'emitVirtualMov'

	function emitRematConst(module TargetModule, ops OpIndexList, freshId RegInt, constantValue RegInt, regClass RegInt)
		if regClass == 1 'fp'
			// FP rematerialization would require a movXmmRipRel + a fresh
			// constant pool entry — not needed for any current case (sha256
			// uses integer arithmetic only). Defer to a later phase.
			panic("emitRematConst: FP rematerialization not yet implemented (freshId={freshId}, value={constantValue})")
		end 'fp'
		// GPR: emit a full movRegImm regardless of `constantValue` magnitude.
		// We can't canonicalize to xorRegRegSelf (would clobber flags) or
		// movRegImm32 (zero-extension would change a negative-i64 constant's
		// semantics) without more care. movRegImm is always correct.
		let idx = module.x64Ops.count()
		module.x64Ops.push(X64Op.movRegImm(X64VReg.virtual(freshId), value: constantValue))
		ops.append(idx)
	end 'emitRematConst'

	// Phase 3: memory-operand folding. When the spill code insertion is about
	// to emit a reload for `valueId` as the read input of `packed`, ask
	// whether we can instead rewrite `packed` to read directly from
	// [rbp+stackOffset]. Returns the new op's index on success or -1 if no
	// foldable variant applies.
	//
	// Rules:
	//   * Only fold reads from the spill slot — never folds when valueId is
	//     a def or alias of the def.
	//   * Reg-reg ALU forms where `srcReg` is the spilled value fold into
	//     their `*Mem` counterparts (addRegReg → addRegMem, etc.).
	//   * `cmpRegReg(lhs, rhs)` only folds when `rhs` is the spilled value;
	//     swapping operands would change flag semantics, so a spilled lhs
	//     falls back to the existing reload path.
	//   * Two-address ops where dest == src refuse to fold: the dest would
	//     still be a virtual register that needs a real reload to bootstrap.
	//   * Anything else returns -1 to fall back to the reload path.
	function tryFoldReadFromSlot(module TargetModule, packed OpIndex, valueId RegInt, stackOffset RegInt) returns RegInt
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return tryAppendFoldedX64Op(module, x64Op: x64Op, valueId: valueId, stackOffset: stackOffset)
	end 'tryFoldReadFromSlot'

	// Slot-to-slot move via a fixed scratch register. Used by the memory-
	// routed-phi optimization to copy data between two spill slots without
	// creating a long-lived reload vreg at the predecessor's terminator.
	// Uses the gprCycleBreakOrd scratch (r11 on x64) which is reserved for
	// register-allocator use and is guaranteed not to conflict with anything
	// live at this point.
	function isCallOp(module TargetModule, packed OpIndex) returns bool
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return x64Op.rawValue.isCall
	end 'isCallOp'

	function classifyCallArgSetup(module TargetModule, packed OpIndex, coloring ColoringResult) returns CallArgKind
		let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
		return classifyX64CallArgSetup(x64Op, coloring: coloring)
	end 'classifyCallArgSetup'

	function emitSlotToSlotMove(module TargetModule, ops OpIndexList, srcStackOffset RegInt, destStackOffset RegInt, regClass RegInt)
		if regClass == 1 'fp'
			// xmm15 is the fpCycleBreakOrd scratch reserved for register-
			// allocator use; safe to clobber here for a transient load-
			// then-store sequence.
			let fpScratch = physFpReg(X64XmmRegister.xmm15)
			let loadIdxF = module.x64Ops.count()
			module.x64Ops.push(X64Op.reloadXmmFromStack(fpScratch, offset: srcStackOffset, precision: FloatPrecision.f64))
			ops.append(loadIdxF)
			let storeIdxF = module.x64Ops.count()
			module.x64Ops.push(X64Op.spillXmmToStack(destStackOffset, src: fpScratch, precision: FloatPrecision.f64))
			ops.append(storeIdxF)
			return
		end 'fp'
		let scratch = physReg(X64Register.r11)
		let loadIdx = module.x64Ops.count()
		module.x64Ops.push(X64Op.reloadFromStack(scratch, offset: srcStackOffset))
		ops.append(loadIdx)
		let storeIdx = module.x64Ops.count()
		module.x64Ops.push(X64Op.spillToStack(destStackOffset, srcReg: scratch))
		ops.append(storeIdx)
	end 'emitSlotToSlotMove'

	// --- Factory ---

	export static function create() returns Self
		return Self{tag: 0}
	end 'create'
end 'X64RegAllocTarget'

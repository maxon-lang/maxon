// X64 Dialect — x86-64 machine instructions.

export enum FloatPrecision
	f64
	f32
end 'FloatPrecision'

export enum X64XmmRegister
	xmm0
	xmm1
	xmm2
	xmm3
	xmm4
	xmm5
	xmm6
	xmm7
	xmm8
	xmm9
	xmm10
	xmm11
	xmm12
	xmm13
	xmm14
	xmm15
end 'X64XmmRegister'

export enum X64SetccCondition
	e
	ne
	g
	ge
	l
	le
	a
	ae
	b
	be
end 'X64SetccCondition'

export enum X64CmovCondition
	e
	ne
	g
	ge
	l
	le
	a
	ae
	b
	be
end 'X64CmovCondition'

export enum X64Register
	rax
	rcx
	rdx
	rbx
	rsp
	rbp
	rsi
	rdi
	r8
	r9
	r10
	r11
end 'X64Register'

export enum X64JumpCondition
	b = 130
	be = 134
	e = 132
	ne = 133
	ae = 131
	a = 135
	l = 140
	le = 142
	ge = 141
	g = 143
	p = 138
	np = 139
end 'X64JumpCondition'

export enum X64VReg
	physical(reg X64Register)
	virtual(id ValueId)
end 'X64VReg'

export enum X64FpVReg
	physical(reg X64XmmRegister)
	virtual(id ValueId)
end 'X64FpVReg'

export function x64VRegToString(vreg X64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "v{id}"
	end 'fmt'
end 'x64VRegToString'

export function x64VRegToString32(vreg X64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives match reg 'r32'
			rax gives "eax"
			rcx gives "ecx"
			rdx gives "edx"
			rbx gives "ebx"
			rsp gives "esp"
			rbp gives "ebp"
			rsi gives "esi"
			rdi gives "edi"
			r8 gives "r8d"
			r9 gives "r9d"
			r10 gives "r10d"
			r11 gives "r11d"
		end 'r32'
		virtual(id) gives "v{id}"
	end 'fmt'
end 'x64VRegToString32'

export function x64FpVRegToString(vreg X64FpVReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "vf{id}"
	end 'fmt'
end 'x64FpVRegToString'

// Convenience wrappers for creating VRegs from physical registers
export function physReg(reg X64Register) returns X64VReg
	return X64VReg.physical(reg)
end 'physReg'

export function physFpReg(reg X64XmmRegister) returns X64FpVReg
	return X64FpVReg.physical(reg)
end 'physFpReg'

export type X64OpMeta
	export let latency Latency
	export let isMemory bool
	export let isStore bool
	export let isCall bool
	export let setsFlags bool
end 'X64OpMeta'

export enum X64Op
	// Control flow / bookkeeping
	prologue(stackSize StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	epilogue = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	ret = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Simple ALU ops
	movRegImm(dest X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movRegImm32(dest X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movSlot(slotIndex VarSlot, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	loadSlot(destReg X64VReg, slotIndex VarSlot) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	addRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	subRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	addRegImm(destReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	subRegImm(destReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	imulRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	idivRcx = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	iremRcx = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	negReg(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	bitNotReg(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	andRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	orRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	xorRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true}
	shlRegCl(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	sarRegCl(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cmpRaxRcx = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	testRaxRax = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	condJump(condition X64JumpCondition, targetBlock BlockId) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	jmp(targetBlock BlockId) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Legacy FP slot ops
	movF64Slot(slotIndex VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	loadF64Slot(slotIndex VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	movF64Rdata(rdataOffset CodeOffset) = X64OpMeta{latency: 3, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	ucomisd = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Print ops (I/O = memory + call)
	printLiteral(data ByteArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	printInt = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	// Stack adjustment
	subRspImm(value StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	addRspImm(value StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movRspOffsetReg(offset StackSize, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	loadRegRbpOffset(destReg X64VReg, offset StackSize) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	// Calls
	callDirect(target ByteArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	// SysOp lowering: x86-64 syscall instruction
	syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	// SysOp lowering: indirect call through IAT slot
	iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	// SysOp lowering: data island + LEA for named global data
	globalAddr(resultSlot VarSlot, name ByteArray) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// SysOp lowering: LEA rax, [rbp - offset] for stack slot address
	stackAddrOp(resultSlot VarSlot, targetSlot VarSlot) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// SysOp lowering: mov byte [base + offset], value
	storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	// SysOp lowering: movzx rax, byte [base + offset]
	loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	// SysOp lowering: rep movsb (memcpy)
	memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	// Register allocator ops
	movRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cmpRegReg(lhsReg X64VReg, rhsReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cmpRegImm(lhsReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	testRegReg(reg1 X64VReg, reg2 X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cqo = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	idivReg(divisorReg X64VReg) = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	spillToStack(offset MachineWord, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	reloadFromStack(destReg X64VReg, offset MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	xorRegRegSelf(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Call support ops
	callIndirect(reg X64VReg) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false}
	xchgRegReg(reg1 X64VReg, reg2 X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// XMM FP ops
	movXmmXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	spillXmmToStack(offset MachineWord, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	reloadXmmFromStack(dest X64FpVReg, offset MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	movXmmRipRel(dest X64FpVReg, rdataLabel ByteArray, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	addXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	subXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	mulXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	divXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 15, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	sqrtXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 20, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	roundXmm(dest X64FpVReg, src X64FpVReg, mode MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	ucomisXmm(src1 X64FpVReg, src2 X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cvtSi2Float(dest X64FpVReg, src X64VReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cvttFloat2Si(dest X64VReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cvtSd2Ss(dest X64FpVReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cvtSs2Sd(dest X64FpVReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movqXmmToGpr(dest X64VReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movqGprToXmm(dest X64FpVReg, src X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	andMaskRipRel(dest X64FpVReg, rdataLabel ByteArray, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	// Indirect memory ops
	storeIndirect(baseReg X64VReg, offset MachineWord, srcReg X64VReg, size MachineWord) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	loadIndirect(destReg X64VReg, baseReg X64VReg, offset MachineWord, size MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	storeIndirectXmm(baseReg X64VReg, offset MachineWord, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	loadIndirectXmm(dest X64FpVReg, baseReg X64VReg, offset MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	// Global variable ops
	globalLoad(dest X64VReg, name ByteArray, size MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	globalStore(name ByteArray, src X64VReg, size MachineWord) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	globalLoadXmm(dest X64FpVReg, name ByteArray, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	globalStoreXmm(name ByteArray, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	// LEA ops
	leaFromStack(dest X64VReg, stackOffset MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	leaRipRelative(dest X64VReg, rdataLabel ByteArray) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	leaFuncAddr(dest X64VReg, funcName ByteArray) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Conditional ops
	setcc(dest X64VReg, condition X64SetccCondition) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	cmov(dest X64VReg, src X64VReg, condition X64CmovCondition) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Width conversion ops
	movsxd(dest X64VReg, src X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	movzx32(dest X64VReg, src X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false}
	// Null-safe load
	nullSafeLoad(dest X64VReg, baseReg X64VReg, offset MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false}
	// Memcopy/BulkZero
	repMovsb = X64OpMeta{latency: 5, isMemory: true, isStore: true, isCall: false, setsFlags: false}
	repStosq = X64OpMeta{latency: 5, isMemory: true, isStore: true, isCall: false, setsFlags: false}
end 'X64Op'

export typealias X64OpArray = Array with X64Op

function slotOffset(slotIndex VarSlot) returns StackSize
	return(slotIndex + 1) * 8
end 'slotOffset'

function formatSignedOffset(offset MachineWord) returns String
	// MachineWord is unsigned; negative offsets wrap to large values (> i64.max).
	if offset > i64.max 'negative'
		let pos = 0 - offset
		return "-{pos}"
	end 'negative'
	return "+{offset}"
end 'formatSignedOffset'

export function formatVarSlotArgs(argSlots VarSlotArray) returns String
	var result = ""
	for i in 0 upto argSlots.count() 'each'
		let slot = try argSlots.get(i) otherwise 'skip'
			continue
		end 'skip'
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}slot_{slot}"
	end 'each'
	return result
end 'formatVarSlotArgs'

export function x64OpToString(op X64Op, blocks MlirBlockArray) returns String
	return match op 'toString'
		prologue(stackSize) gives "x64.prologue stack_size={stackSize}"
		epilogue gives "x64.epilogue"
		ret gives "x64.ret"
		movRegImm(dest, value) gives "x64.mov {x64VRegToString(dest)}, {value}"
		movRegImm32(dest, value) gives "x64.mov {x64VRegToString32(dest)}, {value}"
		movSlot(slotIndex, srcReg) gives "x64.mov [rbp-{slotOffset(slotIndex)}], {x64VRegToString(srcReg)}"
		loadSlot(destReg, slotIndex) gives "x64.mov {x64VRegToString(destReg)}, [rbp-{slotOffset(slotIndex)}]"
		addRegReg(destReg, srcReg) gives "x64.add {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		subRegReg(destReg, srcReg) gives "x64.sub {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		addRegImm(destReg, value) gives "x64.add {x64VRegToString(destReg)}, {value}"
		subRegImm(destReg, value) gives "x64.sub {x64VRegToString(destReg)}, {value}"
		imulRegReg(destReg, srcReg) gives "x64.imul {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		idivRcx gives "x64.idiv rcx"
		iremRcx gives "x64.idiv rcx"
		negReg(reg) gives "x64.neg {x64VRegToString(reg)}"
		bitNotReg(reg) gives "x64.not {x64VRegToString(reg)}"
		andRegReg(destReg, srcReg) gives "x64.and {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		orRegReg(destReg, srcReg) gives "x64.or {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		xorRegReg(destReg, srcReg) gives "x64.xor {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		shlRegCl(reg) gives "x64.shl {x64VRegToString(reg)}, cl"
		sarRegCl(reg) gives "x64.sar {x64VRegToString(reg)}, cl"
		cmpRaxRcx gives "x64.cmp rax, rcx"
		testRaxRax gives "x64.test rax, rax"
		condJump(condition, targetBlock) gives "x64.j{condition.name} {resolveBlockLabel(targetBlock, blocks: blocks)}"
		jmp(targetBlock) gives "x64.jmp {resolveBlockLabel(targetBlock, blocks: blocks)}"
		movF64Slot(slotIndex) gives "x64.movsd [rbp-{slotOffset(slotIndex)}], xmm0"
		loadF64Slot(slotIndex) gives "x64.movsd xmm0, [rbp-{slotOffset(slotIndex)}]"
		movF64Rdata(rdataOffset) gives "x64.movsd xmm0, [rip+__float_{rdataOffset}]"
		ucomisd gives "x64.ucomisd xmm0, xmm1"
		printLiteral(data) gives "x64.print_literal \"{String.from(data)}\""
		printInt gives "x64.print_int"
		subRspImm(value) gives "x64.sub rsp, {value}"
		addRspImm(value) gives "x64.add rsp, {value}"
		movRspOffsetReg(offset, srcReg) gives "x64.mov [rsp+{offset}], {x64VRegToString(srcReg)}"
		loadRegRbpOffset(destReg, offset) gives "x64.mov {x64VRegToString(destReg)}, [rbp-{offset}]"
		callDirect(target) gives "x64.call {String.from(target)}"
		syscall(_, number, argSlots) gives "x64.syscall {number}({formatVarSlotArgs(argSlots)})"
		iatCall(_, slotIndex, _) gives "x64.call_import slot_{slotIndex}"
		globalAddr(_, name) gives "x64.lea_rdata {X64Register.rax.name}, [{String.from(name)}]"
		stackAddrOp(_, targetSlot) gives "x64.lea rax, [rbp-{slotOffset(targetSlot)}]"
		storeByteOp(_, _, _) gives "x64.mov byte ptr [rax+0], cl"
		loadByteOp(_, _, _) gives "x64.movzx rax, byte ptr [rax+0]"
		memcpyOp(_, _, _) gives "x64.rep_movsb"
		movRegReg(destReg, srcReg) gives "x64.mov {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		cmpRegReg(lhsReg, rhsReg) gives "x64.cmp {x64VRegToString(lhsReg)}, {x64VRegToString(rhsReg)}"
		cmpRegImm(lhsReg, value) gives "x64.cmp {x64VRegToString(lhsReg)}, {value}"
		testRegReg(reg1, reg2) gives "x64.test {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		cqo gives "x64.cqo"
		idivReg(divisorReg) gives "x64.idiv {x64VRegToString(divisorReg)}"
		spillToStack(offset, srcReg) gives "x64.mov [rbp{formatSignedOffset(offset)}], {x64VRegToString(srcReg)}"
		reloadFromStack(destReg, offset) gives "x64.mov {x64VRegToString(destReg)}, [rbp{formatSignedOffset(offset)}]"
		xorRegRegSelf(reg) gives "x64.xor {x64VRegToString(reg)}, {x64VRegToString(reg)}"
		callIndirect(reg) gives "x64.call {x64VRegToString(reg)}"
		xchgRegReg(reg1, reg2) gives "x64.xchg {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		movXmmXmm(dest, src, _) gives "x64.movsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		spillXmmToStack(offset, src, _) gives "x64.movsd [rbp{formatSignedOffset(offset)}], {x64FpVRegToString(src)}"
		reloadXmmFromStack(dest, offset, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		movXmmRipRel(dest, label, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rip+{String.from(label)}]"
		addXmm(dest, src, _) gives "x64.addsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		subXmm(dest, src, _) gives "x64.subsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		mulXmm(dest, src, _) gives "x64.mulsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		divXmm(dest, src, _) gives "x64.divsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		sqrtXmm(dest, src, _) gives "x64.sqrtsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		roundXmm(dest, src, mode, _) gives "x64.roundsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}, {mode}"
		ucomisXmm(src1, src2, _) gives "x64.ucomisd {x64FpVRegToString(src1)}, {x64FpVRegToString(src2)}"
		cvtSi2Float(dest, src, _) gives "x64.cvtsi2sd {x64FpVRegToString(dest)}, {x64VRegToString(src)}"
		cvttFloat2Si(dest, src, _) gives "x64.cvttsd2si {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSd2Ss(dest, src) gives "x64.cvtsd2ss {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSs2Sd(dest, src) gives "x64.cvtss2sd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		movqXmmToGpr(dest, src) gives "x64.movq {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		movqGprToXmm(dest, src) gives "x64.movq {x64FpVRegToString(dest)}, {x64VRegToString(src)}"
		andMaskRipRel(dest, label, _) gives "x64.andpd {x64FpVRegToString(dest)}, [rip+{String.from(label)}]"
		storeIndirect(baseReg, offset, srcReg, size) gives "x64.mov [{x64VRegToString(baseReg)}+{offset}], {x64VRegToString(srcReg)} ({size}b)"
		loadIndirect(destReg, baseReg, offset, size) gives "x64.mov {x64VRegToString(destReg)}, [{x64VRegToString(baseReg)}+{offset}] ({size}b)"
		storeIndirectXmm(baseReg, offset, src, _) gives "x64.movsd [{x64VRegToString(baseReg)}+{offset}], {x64FpVRegToString(src)}"
		loadIndirectXmm(dest, baseReg, offset, _) gives "x64.movsd {x64FpVRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		globalLoad(dest, name, _) gives "x64.mov {x64VRegToString(dest)}, [rip+{String.from(name)}]"
		globalStore(name, src, _) gives "x64.mov [rip+{String.from(name)}], {x64VRegToString(src)}"
		globalLoadXmm(dest, name, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rip+{String.from(name)}]"
		globalStoreXmm(name, src, _) gives "x64.movsd [rip+{String.from(name)}], {x64FpVRegToString(src)}"
		leaFromStack(dest, offset) gives "x64.lea {x64VRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		leaRipRelative(dest, label) gives "x64.lea {x64VRegToString(dest)}, [rip+{String.from(label)}]"
		leaFuncAddr(dest, funcName) gives "x64.lea {x64VRegToString(dest)}, [rip+{String.from(funcName)}]"
		setcc(dest, condition) gives "x64.set{condition.name} {x64VRegToString(dest)}"
		cmov(dest, src, condition) gives "x64.cmov{condition.name} {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movsxd(dest, src) gives "x64.movsxd {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movzx32(dest, src) gives "x64.mov {x64VRegToString(dest)}d, {x64VRegToString(src)}d"
		nullSafeLoad(dest, baseReg, offset) gives "x64.null_safe_load {x64VRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		repMovsb gives "x64.rep movsb"
		repStosq gives "x64.rep stosq"
	end 'toString'
end 'x64OpToString'

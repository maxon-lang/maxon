// X64 Dialect — x86-64 machine instructions.

export union FloatPrecision
	f64
	f32
end 'FloatPrecision'

export enum X64XmmRegister
	xmm0
	xmm1
	xmm2
	xmm3
	xmm4
	xmm5
	xmm6
	xmm7
	xmm8
	xmm9
	xmm10
	xmm11
	xmm12
	xmm13
	xmm14
	xmm15
end 'X64XmmRegister'

export union X64SetccCondition
	e
	ne
	g
	ge
	l
	le
	a
	ae
	b
	be
end 'X64SetccCondition'

export union X64CmovCondition
	e
	ne
	g
	ge
	l
	le
	a
	ae
	b
	be
end 'X64CmovCondition'

export enum X64Register
	rax
	rcx
	rdx
	rbx
	rsp
	rbp
	rsi
	rdi
	r8
	r9
	r10
	r11
	r12
	r13
	r14
	r15
end 'X64Register'

export union X64JumpCondition
	b = 130
	be = 134
	e = 132
	ne = 133
	ae = 131
	a = 135
	l = 140
	le = 142
	ge = 141
	g = 143
	p = 138
	np = 139
end 'X64JumpCondition'

export union X64VReg
	physical(reg X64Register)
	virtual(id ValueId)
end 'X64VReg'

export union X64FpVReg
	physical(reg X64XmmRegister)
	virtual(id ValueId)
end 'X64FpVReg'

export function x64VRegToString(vreg X64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "v{id}"
	end 'fmt'
end 'x64VRegToString'

export function x64VRegToString32(vreg X64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives match reg 'r32'
			rax gives "eax"
			rcx gives "ecx"
			rdx gives "edx"
			rbx gives "ebx"
			rsp gives "esp"
			rbp gives "ebp"
			rsi gives "esi"
			rdi gives "edi"
			r8 gives "r8d"
			r9 gives "r9d"
			r10 gives "r10d"
			r11 gives "r11d"
			r12 gives "r12d"
			r13 gives "r13d"
			r14 gives "r14d"
			r15 gives "r15d"
		end 'r32'
		virtual(id) gives "v{id}"
	end 'fmt'
end 'x64VRegToString32'

export function x64FpVRegToString(vreg X64FpVReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "vf{id}"
	end 'fmt'
end 'x64FpVRegToString'

// Convenience wrappers for creating VRegs from physical registers
export function physReg(reg X64Register) returns X64VReg
	return X64VReg.physical(reg)
end 'physReg'

export function physFpReg(reg X64XmmRegister) returns X64FpVReg
	return X64FpVReg.physical(reg)
end 'physFpReg'

// Register constraint bitmask constants (bit N = X64Register ordinal N)
export let REG_NONE = 0
export let REG_RAX = 1
export let REG_RCX = 2
export let REG_RDX = 4
export let REG_RBX = 8
export let REG_RSI = 64
export let REG_RDI = 128
export let REG_R8 = 256
export let REG_R9 = 512
export let X64_CALLER_SAVED = 975

export type X64OpMeta
	export let latency Latency
	export let isMemory bool
	export let isStore bool
	export let isCall bool
	export let setsFlags bool
	export let pattern OpPattern
	export let implicitGprReads RegMask
	export let implicitGprDefs RegMask
end 'X64OpMeta'

export union X64Op
	// Control flow / bookkeeping
	prologue(stackSize StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	epilogue = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 256, implicitGprDefs: 0}
	ret = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 256, implicitGprDefs: 0}
	// Simple ALU ops
	movRegImm(dest X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.constImm, implicitGprReads: 0, implicitGprDefs: 0}
	movRegImm32(dest X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.constImm, implicitGprReads: 0, implicitGprDefs: 0}
	movSlot(slotIndex VarSlot, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	loadSlot(destReg X64VReg, slotIndex VarSlot) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	addRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	subRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	addRegImm(destReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.useDefImm, implicitGprReads: 0, implicitGprDefs: 0}
	subRegImm(destReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.useDefImm, implicitGprReads: 0, implicitGprDefs: 0}
	imulRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	idivRcx = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 7, implicitGprDefs: 5}
	iremRcx = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 7, implicitGprDefs: 5}
	negReg(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.unaryInPlace, implicitGprReads: 0, implicitGprDefs: 0}
	bitNotReg(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.unaryInPlace, implicitGprReads: 0, implicitGprDefs: 0}
	andRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	orRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	xorRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	shlRegCl(dest X64VReg, operand X64VReg, shiftCount X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.shift, implicitGprReads: 2, implicitGprDefs: 0}
	sarRegCl(dest X64VReg, operand X64VReg, shiftCount X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.shift, implicitGprReads: 2, implicitGprDefs: 0}
	shrRegCl(dest X64VReg, operand X64VReg, shiftCount X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.shift, implicitGprReads: 2, implicitGprDefs: 0}
	cmpRaxRcx = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.passThrough, implicitGprReads: 3, implicitGprDefs: 0}
	testRaxRax = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 0}
	condJump(condition X64JumpCondition, targetBlock BlockId) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	jmp(targetBlock BlockId) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	// Unused FP slot ops (superseded by XMM virtual register ops, kept for enum range stability)
	movF64Slot(slotIndex VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	loadF64Slot(slotIndex VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	movF64Rdata(rdataOffset CodeOffset) = X64OpMeta{latency: 3, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	ucomisd = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	// Print ops (I/O = memory + call)
	printLiteral(data String) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 975}
	printInt = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 2, implicitGprDefs: 975}
	// Stack adjustment
	subRspImm(value StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	addRspImm(value StackSize) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	movRspOffsetReg(offset StackSize, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	loadRegRbpOffset(destReg X64VReg, offset StackSize) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Calls
	callDirect(target String) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 975}
	// StdSystemOp lowering: x86-64 syscall instruction
	syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 1}
	// StdSystemOp lowering: indirect call through IAT slot
	iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 1}
	// StdSystemOp lowering: data island + LEA for named global data
	globalAddr(resultSlot VarSlot, name String) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 1}
	// StdSystemOp lowering: LEA rax, [rbp - offset] for stack slot address
	stackAddrOp(resultSlot VarSlot, targetSlot VarSlot) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 1}
	// StdSystemOp lowering: mov byte [base + offset], value
	storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 7}
	// StdSystemOp lowering: movzx rax, byte [base + offset]
	loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 7}
	// StdSystemOp lowering: rep movsb (memcpy)
	memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 195, implicitGprDefs: 194}
	// Register allocator ops
	movRegReg(destReg X64VReg, srcReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.movRegReg, implicitGprReads: 0, implicitGprDefs: 0}
	cmpRegReg(lhsReg X64VReg, rhsReg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoUse, implicitGprReads: 0, implicitGprDefs: 0}
	cmpRegImm(lhsReg X64VReg, value MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	testRegReg(reg1 X64VReg, reg2 X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoUse, implicitGprReads: 0, implicitGprDefs: 0}
	cqo = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 4}
	idivReg(divisorReg X64VReg) = X64OpMeta{latency: 40, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.divReg, implicitGprReads: 5, implicitGprDefs: 5}
	spillToStack(offset MachineWord, srcReg X64VReg) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	reloadFromStack(destReg X64VReg, offset MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	xorRegRegSelf(reg X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Call support ops
	callIndirect(reg X64VReg) = X64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.callIndirect, implicitGprReads: 0, implicitGprDefs: 975}
	xchgRegReg(reg1 X64VReg, reg2 X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.exchange, implicitGprReads: 0, implicitGprDefs: 0}
	// XMM FP ops
	movXmmXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpMov, implicitGprReads: 0, implicitGprDefs: 0}
	spillXmmToStack(offset MachineWord, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleUse, implicitGprReads: 0, implicitGprDefs: 0}
	reloadXmmFromStack(dest X64FpVReg, offset MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	movXmmRipRel(dest X64FpVReg, rdataLabel String, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	addXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpTwoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	subXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpTwoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	mulXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpTwoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	divXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 15, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpTwoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	sqrtXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 20, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	roundXmm(dest X64FpVReg, src X64FpVReg, mode MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	ucomisXmm(src1 X64FpVReg, src2 X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.fpTwoUse, implicitGprReads: 0, implicitGprDefs: 0}
	cvtSi2Float(dest X64FpVReg, src X64VReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.gprToFp, implicitGprReads: 0, implicitGprDefs: 0}
	cvttFloat2Si(dest X64VReg, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpToGpr, implicitGprReads: 0, implicitGprDefs: 0}
	cvtSd2Ss(dest X64FpVReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	cvtSs2Sd(dest X64FpVReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	movqXmmToGpr(dest X64VReg, src X64FpVReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpToGpr, implicitGprReads: 0, implicitGprDefs: 0}
	movqGprToXmm(dest X64FpVReg, src X64VReg) = X64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.gprToFp, implicitGprReads: 0, implicitGprDefs: 0}
	andMaskRipRel(dest X64FpVReg, rdataLabel String, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleUse, implicitGprReads: 0, implicitGprDefs: 0}
	// Indirect memory ops
	storeIndirect(baseReg X64VReg, offset MachineWord, srcReg X64VReg, size MachineWord) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.baseUseSrcUse, implicitGprReads: 0, implicitGprDefs: 0}
	loadIndirect(destReg X64VReg, baseReg X64VReg, offset MachineWord, size MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseDest, implicitGprReads: 0, implicitGprDefs: 0}
	storeIndirectXmm(baseReg X64VReg, offset MachineWord, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.baseUseFpUse, implicitGprReads: 0, implicitGprDefs: 0}
	loadIndirectXmm(dest X64FpVReg, baseReg X64VReg, offset MachineWord, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseFpDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Global variable ops
	globalLoad(dest X64VReg, name String, size MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	globalStore(name String, src X64VReg, size MachineWord) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	globalLoadXmm(dest X64FpVReg, name String, precision FloatPrecision) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	globalStoreXmm(name String, src X64FpVReg, precision FloatPrecision) = X64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleUse, implicitGprReads: 0, implicitGprDefs: 0}
	// LEA ops
	leaFromStack(dest X64VReg, stackOffset MachineWord) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	leaRipRelative(dest X64VReg, rdataLabel String) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	leaFuncAddr(dest X64VReg, funcName String) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Conditional ops
	setcc(dest X64VReg, condition X64SetccCondition) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	cmov(dest X64VReg, src X64VReg, condition X64CmovCondition) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.twoAddr, implicitGprReads: 0, implicitGprDefs: 0}
	// Width conversion ops
	movsxd(dest X64VReg, src X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.defUse, implicitGprReads: 0, implicitGprDefs: 0}
	movzx32(dest X64VReg, src X64VReg) = X64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.defUse, implicitGprReads: 0, implicitGprDefs: 0}
	// Null-safe load
	nullSafeLoad(dest X64VReg, baseReg X64VReg, offset MachineWord) = X64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseDest, implicitGprReads: 0, implicitGprDefs: 0}
	// Memcopy/BulkZero
	repMovsb = X64OpMeta{latency: 5, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 194, implicitGprDefs: 194}
	repStosq = X64OpMeta{latency: 5, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 131, implicitGprDefs: 130}
end 'X64Op'

export typealias X64OpArray = Array with X64Op

function slotOffset(slotIndex VarSlot) returns StackSize
	return(slotIndex + 1) * 8
end 'slotOffset'

function formatSignedOffset(offset MachineWord) returns String
	// MachineWord is unsigned; negative offsets wrap to large values (> i64.max).
	if offset > i64.max 'negative'
		let pos = 0 - offset
		return "-{pos}"
	end 'negative'
	return "+{offset}"
end 'formatSignedOffset'

export function formatVarSlotArgs(argSlots VarSlotArray) returns String
	var result = ""
	for i in 0 upto argSlots.count() 'each'
		let slot = try argSlots.get(i) otherwise 'skip'
			continue
		end 'skip'
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}slot_{slot}"
	end 'each'
	return result
end 'formatVarSlotArgs'

export function x64OpToString(op X64Op, blocks IrBlockArray) returns String
	return match op 'toString'
		prologue(stackSize) gives "x64.prologue stack_size={stackSize}"
		epilogue gives "x64.epilogue"
		ret gives "x64.ret"
		movRegImm(dest, value) gives "x64.mov {x64VRegToString(dest)}, {value}"
		movRegImm32(dest, value) gives "x64.mov {x64VRegToString32(dest)}, {value}"
		movSlot(slotIndex, srcReg) gives "x64.mov [rbp-{slotOffset(slotIndex)}], {x64VRegToString(srcReg)}"
		loadSlot(destReg, slotIndex) gives "x64.mov {x64VRegToString(destReg)}, [rbp-{slotOffset(slotIndex)}]"
		addRegReg(destReg, srcReg) gives "x64.add {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		subRegReg(destReg, srcReg) gives "x64.sub {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		addRegImm(destReg, value) gives "x64.add {x64VRegToString(destReg)}, {value}"
		subRegImm(destReg, value) gives "x64.sub {x64VRegToString(destReg)}, {value}"
		imulRegReg(destReg, srcReg) gives "x64.imul {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		idivRcx gives "x64.idiv rcx"
		iremRcx gives "x64.idiv rcx"
		negReg(reg) gives "x64.neg {x64VRegToString(reg)}"
		bitNotReg(reg) gives "x64.not {x64VRegToString(reg)}"
		andRegReg(destReg, srcReg) gives "x64.and {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		orRegReg(destReg, srcReg) gives "x64.or {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		xorRegReg(destReg, srcReg) gives "x64.xor {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		shlRegCl(dest, operand, shiftCount) gives "x64.shl {x64VRegToString(dest)}, {x64VRegToString(operand)}, {x64VRegToString(shiftCount)}"
		sarRegCl(dest, operand, shiftCount) gives "x64.sar {x64VRegToString(dest)}, {x64VRegToString(operand)}, {x64VRegToString(shiftCount)}"
		shrRegCl(dest, operand, shiftCount) gives "x64.shr {x64VRegToString(dest)}, {x64VRegToString(operand)}, {x64VRegToString(shiftCount)}"
		cmpRaxRcx gives "x64.cmp rax, rcx"
		testRaxRax gives "x64.test rax, rax"
		condJump(condition, targetBlock) gives "x64.j{condition.name} {resolveBlockLabel(targetBlock, blocks: blocks)}"
		jmp(targetBlock) gives "x64.jmp {resolveBlockLabel(targetBlock, blocks: blocks)}"
		movF64Slot(slotIndex) gives "x64.movsd [rbp-{slotOffset(slotIndex)}], xmm0"
		loadF64Slot(slotIndex) gives "x64.movsd xmm0, [rbp-{slotOffset(slotIndex)}]"
		movF64Rdata(rdataOffset) gives "x64.movsd xmm0, [rip+__float_{rdataOffset}]"
		ucomisd gives "x64.ucomisd xmm0, xmm1"
		printLiteral(data) gives "x64.print_literal \"{data}\""
		printInt gives "x64.print_int"
		subRspImm(value) gives "x64.sub rsp, {value}"
		addRspImm(value) gives "x64.add rsp, {value}"
		movRspOffsetReg(offset, srcReg) gives "x64.mov [rsp+{offset}], {x64VRegToString(srcReg)}"
		loadRegRbpOffset(destReg, offset) gives "x64.mov {x64VRegToString(destReg)}, [rbp-{offset}]"
		callDirect(target) gives "x64.call {target}"
		syscall(_, number, argSlots) gives "x64.syscall {number}({formatVarSlotArgs(argSlots)})"
		iatCall(_, slotIndex, _) gives "x64.call_import slot_{slotIndex}"
		globalAddr(_, name) gives "x64.lea_rdata {X64Register.rax.name}, [{name}]"
		stackAddrOp(_, targetSlot) gives "x64.lea rax, [rbp-{slotOffset(targetSlot)}]"
		storeByteOp(_, _, _) gives "x64.mov byte ptr [rax+0], cl"
		loadByteOp(_, _, _) gives "x64.movzx rax, byte ptr [rax+0]"
		memcpyOp(_, _, _) gives "x64.rep_movsb"
		movRegReg(destReg, srcReg) gives "x64.mov {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		cmpRegReg(lhsReg, rhsReg) gives "x64.cmp {x64VRegToString(lhsReg)}, {x64VRegToString(rhsReg)}"
		cmpRegImm(lhsReg, value) gives "x64.cmp {x64VRegToString(lhsReg)}, {value}"
		testRegReg(reg1, reg2) gives "x64.test {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		cqo gives "x64.cqo"
		idivReg(divisorReg) gives "x64.idiv {x64VRegToString(divisorReg)}"
		spillToStack(offset, srcReg) gives "x64.mov [rbp{formatSignedOffset(offset)}], {x64VRegToString(srcReg)}"
		reloadFromStack(destReg, offset) gives "x64.mov {x64VRegToString(destReg)}, [rbp{formatSignedOffset(offset)}]"
		xorRegRegSelf(reg) gives "x64.xor {x64VRegToString32(reg)}, {x64VRegToString32(reg)}"
		callIndirect(reg) gives "x64.call {x64VRegToString(reg)}"
		xchgRegReg(reg1, reg2) gives "x64.xchg {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		movXmmXmm(dest, src, _) gives "x64.movsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		spillXmmToStack(offset, src, _) gives "x64.movsd [rbp{formatSignedOffset(offset)}], {x64FpVRegToString(src)}"
		reloadXmmFromStack(dest, offset, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		movXmmRipRel(dest, label, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rip+{label}]"
		addXmm(dest, src, _) gives "x64.addsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		subXmm(dest, src, _) gives "x64.subsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		mulXmm(dest, src, _) gives "x64.mulsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		divXmm(dest, src, _) gives "x64.divsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		sqrtXmm(dest, src, _) gives "x64.sqrtsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		roundXmm(dest, src, mode, _) gives "x64.roundsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}, {mode}"
		ucomisXmm(src1, src2, _) gives "x64.ucomisd {x64FpVRegToString(src1)}, {x64FpVRegToString(src2)}"
		cvtSi2Float(dest, src, _) gives "x64.cvtsi2sd {x64FpVRegToString(dest)}, {x64VRegToString(src)}"
		cvttFloat2Si(dest, src, _) gives "x64.cvttsd2si {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSd2Ss(dest, src) gives "x64.cvtsd2ss {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSs2Sd(dest, src) gives "x64.cvtss2sd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		movqXmmToGpr(dest, src) gives "x64.movq {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		movqGprToXmm(dest, src) gives "x64.movq {x64FpVRegToString(dest)}, {x64VRegToString(src)}"
		andMaskRipRel(dest, label, _) gives "x64.andpd {x64FpVRegToString(dest)}, [rip+{label}]"
		storeIndirect(baseReg, offset, srcReg, size) gives "x64.mov [{x64VRegToString(baseReg)}+{offset}], {x64VRegToString(srcReg)} ({size}b)"
		loadIndirect(destReg, baseReg, offset, size) gives "x64.mov {x64VRegToString(destReg)}, [{x64VRegToString(baseReg)}+{offset}] ({size}b)"
		storeIndirectXmm(baseReg, offset, src, _) gives "x64.movsd [{x64VRegToString(baseReg)}+{offset}], {x64FpVRegToString(src)}"
		loadIndirectXmm(dest, baseReg, offset, _) gives "x64.movsd {x64FpVRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		globalLoad(dest, name, _) gives "x64.mov {x64VRegToString(dest)}, [rip+{name}]"
		globalStore(name, src, _) gives "x64.mov [rip+{name}], {x64VRegToString(src)}"
		globalLoadXmm(dest, name, _) gives "x64.movsd {x64FpVRegToString(dest)}, [rip+{name}]"
		globalStoreXmm(name, src, _) gives "x64.movsd [rip+{name}], {x64FpVRegToString(src)}"
		leaFromStack(dest, offset) gives "x64.lea {x64VRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		leaRipRelative(dest, label) gives "x64.lea {x64VRegToString(dest)}, [rip+{label}]"
		leaFuncAddr(dest, funcName) gives "x64.lea {x64VRegToString(dest)}, [rip+{funcName}]"
		setcc(dest, condition) gives "x64.set{condition.name} {x64VRegToString(dest)}"
		cmov(dest, src, condition) gives "x64.cmov{condition.name} {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movsxd(dest, src) gives "x64.movsxd {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movzx32(dest, src) gives "x64.mov {x64VRegToString(dest)}d, {x64VRegToString(src)}d"
		nullSafeLoad(dest, baseReg, offset) gives "x64.null_safe_load {x64VRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		repMovsb gives "x64.rep movsb"
		repStosq gives "x64.rep stosq"
	end 'toString'
end 'x64OpToString'

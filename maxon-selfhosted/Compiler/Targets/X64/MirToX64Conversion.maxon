// Mid dialect -> X64 dialect conversion.
// Pure instruction selection: emits virtual registers (X64VReg.virtual) only.
// Register allocation, prologue/epilogue, and stack frame sizing are handled
// by standalone passes that run after this one.

// Constant map: tracks valueId -> immediate value for integer movImm ops.
// Enables addRegImm/subRegImm/cmpRegImm when an operand is a known constant.
typealias ConstMap = Array with ParsedInt
typealias ImmediateValue = int(i64.min to i64.max)

let CONST_NOT_FOUND = -i64.max

function constMapSet(cm ConstMap, valueId ValueId, value ImmediateValue)
	while cm.count() <= valueId 'grow'
		cm.push(CONST_NOT_FOUND)
	end 'grow'
	cm.set(valueId, value: value)
end 'constMapSet'

function constMapSetIfInt(cm ConstMap, resultId ValueId, value ImmediateValue, isFloat bool)
	if not isFloat 'intConst'
		constMapSet(cm, valueId: resultId, value: value)
	end 'intConst'
end 'constMapSetIfInt'

function buildConstMap(module MirModule, func MirFunction) returns ConstMap
	var cm = ConstMap.create()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise 'skipOp'
			continue
		end 'skipOp'
		for opIdx in block.opRefs 'eachOp'
			let mirOp = try module.ops.get(opIdx) otherwise 'skipItem'
				continue
			end 'skipItem'
			match mirOp 'checkMir'
				movImm(resultId, value, isFloat) then constMapSetIfInt(cm, resultId: resultId, value: value, isFloat: isFloat)
				movReg to loadByte then break 'checkMir'
			end 'checkMir'
		end 'eachOp'
	end 'eachBlock'
	return cm
end 'buildConstMap'

function constMapGet(cm ConstMap, valueId ValueId) returns ImmediateValue
	if valueId < 0 or valueId >= cm.count() 'outOfRange'
		return CONST_NOT_FOUND
	end 'outOfRange'
	return try cm.get(valueId) otherwise CONST_NOT_FOUND
end 'constMapGet'

// Absorbed-constant set: marks constant values whose every use is absorbed as
// an immediate operand (cmpRegImm, addRegImm, subRegImm), so their movImm can
// be elided entirely. Built from constMap + use analysis.
typealias AbsorbedConstSet = Array with bool

function tryMarkAbsorbed(result AbsorbedConstSet, totalUses UseCountMap, nonAbsorbUses UseCountMap, resultId ValueId, value ImmediateValue, isFloat bool)
	if not isFloat 'intOnly'
		let fits = value >= 0 and value <= i32.max
		if fits 'fitsImm'
			let total = ucGet(totalUses, valueId: resultId)
			let nonAbs = ucGet(nonAbsorbUses, valueId: resultId)
			if total > 0 and nonAbs == 0 'fullyAbsorbed'
				while result.count() <= resultId 'grow'
					result.push(false)
				end 'grow'
				result.set(resultId, value: true)
			end 'fullyAbsorbed'
		end 'fitsImm'
	end 'intOnly'
end 'tryMarkAbsorbed'

function buildAbsorbedConsts(module MirModule, func MirFunction, constMap ConstMap) returns AbsorbedConstSet
	// Count total uses and non-absorbable uses for each value.
	var totalUses = UseCountMap.create()
	var nonAbsorbUses = UseCountMap.create()

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise 'skipEntry'
			continue
		end 'skipEntry'
		for opIdx in block.opRefs 'eachOp'
			countPackedOpUses(module, packed: opIdx, uc: totalUses)
			countPackedNonAbsorbableUses(module, packed: opIdx, uc: nonAbsorbUses, constMap: constMap)
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			countPackedOpUses(module, packed: block.terminator, uc: totalUses)
			countPackedNonAbsorbableUses(module, packed: block.terminator, uc: nonAbsorbUses, constMap: constMap)
		end 'hasTerm'
	end 'eachBlock'

	// A constant is fully absorbed if it has uses and all of them are absorbable.
	var result = AbsorbedConstSet.create()
	for blockRef in func.blockRefs 'scan'
		let block = try module.blocks.get(blockRef) otherwise 'skipElem'
			continue
		end 'skipElem'
		for opIdx in block.opRefs 'scanOp'
			let mirOp = try module.ops.get(opIdx) otherwise 'nextOp'
				continue
			end 'nextOp'
			match mirOp 'checkMir'
				movImm(resultId, value, isFloat) then tryMarkAbsorbed(result, totalUses: totalUses, nonAbsorbUses: nonAbsorbUses, resultId: resultId, value: value, isFloat: isFloat)
				movReg to loadByte then break 'checkMir'
			end 'checkMir'
		end 'scanOp'
	end 'scan'
	return result
end 'buildAbsorbedConsts'

function isAbsorbedConst(absorbed AbsorbedConstSet, valueId ValueId) returns bool
	if valueId < 0 or valueId >= absorbed.count() 'outOfRange'
		return false
	end 'outOfRange'
	return try absorbed.get(valueId) otherwise false
end 'isAbsorbedConst'

// Count uses that will NOT be absorbed as immediates. A use is absorbable when
// it appears as the rightId of an integer cmp or an add/sub binOp AND the
// constant fits imm32 (the constMap+range check in lowerIntCmp/lowerIntBinOp).
function countPackedNonAbsorbableUses(module MirModule, packed OpIndex, uc UseCountMap, constMap ConstMap)
	let mirOp = try module.ops.get(packed) otherwise 'noBlock'
		return
	end 'noBlock'
	countMirNonAbsorbUses(mirOp, uc: uc, constMap: constMap)
end 'countPackedNonAbsorbableUses'

function countMirNonAbsorbUses(op MirOp, uc UseCountMap, constMap ConstMap)
	match op 'count'
		movImm then break 'count'
		movReg(_, srcId) then ucIncrement(uc, valueId: srcId)
		binOp(_, leftId, rightId, opcode) then countBinOpNonAbsorb(leftId, rightId: rightId, opcode: opcode, uc: uc, constMap: constMap)
		unaryOp(_, operandId, _) then ucIncrement(uc, valueId: operandId)
		cmp(_, leftId, rightId, predicate) then countCmpNonAbsorb(leftId, rightId: rightId, predicate: predicate, uc: uc, constMap: constMap)
		condBranch(condId, _, thenArgs, _, elseArgs) then ucIncrementCondBr(uc, condId: condId, thenArgs: thenArgs, elseArgs: elseArgs)
		branch(_, args) then ucIncrementArray(uc, ids: args)
		call(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		indirectCall(_, calleeId, argIds) then ucIncrementIdAndArray(uc, id: calleeId, arr: argIds)
		ret(retValId) then ucIncrement(uc, valueId: retValId)
		param then break 'count'
		load(_, baseId, _) then ucIncrement(uc, valueId: baseId)
		store(valueId, baseId, _) then ucIncrementTwo(uc, a: valueId, b: baseId)
		loadSlot then break 'count'
		storeSlot(_, valueId) then ucIncrement(uc, valueId: valueId)
		stackSlotAddr to loadFramePtr then break 'count'
		syscall(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		iatCall(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		osExit(codeId) then ucIncrement(uc, valueId: codeId)
		osWrite(ptrId, lenId) then ucIncrementTwo(uc, a: ptrId, b: lenId)
		osWriteErr(ptrId, lenId) then ucIncrementTwo(uc, a: ptrId, b: lenId)
		memcpy(dstId, srcId, lenId) then ucIncrementThree(uc, a: dstId, b: srcId, c: lenId)
		storeByte(baseId, offsetId, byteId) then ucIncrementThree(uc, a: baseId, b: offsetId, c: byteId)
		loadByte(_, baseId, offsetId) then ucIncrementTwo(uc, a: baseId, b: offsetId)
	end 'count'
end 'countMirNonAbsorbUses'

// For binOp: leftId is always a non-absorbable use. rightId is absorbable
// only if the opcode is add/sub and the constant fits imm32.
function countBinOpNonAbsorb(leftId ValueId, rightId ValueId, opcode MirBinOpcode, uc UseCountMap, constMap ConstMap)
	ucIncrement(uc, valueId: leftId)
	let isAddSub = match opcode 'check'
		addI64 gives true
		subI64 gives true
		mulI64 to shrI64 gives false
		addF64 to divF64 gives false
	end 'check'
	if isAddSub 'mayAbsorb'
		let cv = constMapGet(constMap, valueId: rightId)
		let absorbed = cv != CONST_NOT_FOUND and cv >= 0 and cv <= i32.max
		if not absorbed 'notAbsorbed'
			ucIncrement(uc, valueId: rightId)
		end 'notAbsorbed'
	end 'mayAbsorb' else 'noAbsorb'
		ucIncrement(uc, valueId: rightId)
	end 'noAbsorb'
end 'countBinOpNonAbsorb'

// For cmp: leftId is always a non-absorbable use. rightId is absorbable
// for integer predicates when the constant fits imm32.
function countCmpNonAbsorb(leftId ValueId, rightId ValueId, predicate MirCmpPredicate, uc UseCountMap, constMap ConstMap)
	ucIncrement(uc, valueId: leftId)
	let isIntCmp = match predicate 'check'
		eq to ugt gives true
		feq to fge gives false
	end 'check'
	if isIntCmp 'mayAbsorb'
		let cv = constMapGet(constMap, valueId: rightId)
		let absorbed = cv != CONST_NOT_FOUND and cv >= 0 and cv <= i32.max
		if not absorbed 'notAbsorbed'
			ucIncrement(uc, valueId: rightId)
		end 'notAbsorbed'
	end 'mayAbsorb' else 'noAbsorb'
		ucIncrement(uc, valueId: rightId)
	end 'noAbsorb'
end 'countCmpNonAbsorb'

// Use count map: tracks how many times each ValueId is read as an operand.
// Used by isFlagsOnly to detect cmp results whose sole consumer is a condBr.
typealias UseCountMap = Array with ParsedInt

function buildUseCountMap(module MirModule, func MirFunction) returns UseCountMap
	var uc = UseCountMap.create()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise 'nextBlock'
			continue
		end 'nextBlock'
		for opIdx in block.opRefs 'eachOp'
			countPackedOpUses(module, packed: opIdx, uc: uc)
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			countPackedOpUses(module, packed: block.terminator, uc: uc)
		end 'hasTerm'
	end 'eachBlock'
	return uc
end 'buildUseCountMap'

function ucIncrement(uc UseCountMap, valueId ValueId)
	while uc.count() <= valueId 'grow'
		uc.push(0)
	end 'grow'
	let current = try uc.get(valueId) otherwise 0
	uc.set(valueId, value: current + 1)
end 'ucIncrement'

function ucGet(uc UseCountMap, valueId ValueId) returns ParsedInt
	if valueId < 0 or valueId >= uc.count() 'outOfRange'
		return 0
	end 'outOfRange'
	return try uc.get(valueId) otherwise 0
end 'ucGet'

function ucIncrementArray(uc UseCountMap, ids ValueIdArray)
	for id in ids 'each'
		ucIncrement(uc, valueId: id)
	end 'each'
end 'ucIncrementArray'

function countPackedOpUses(module MirModule, packed OpIndex, uc UseCountMap)
	let mirOp = try module.ops.get(packed) otherwise 'noElem'
		return
	end 'noElem'
	countMirOpUses(mirOp, uc: uc)
end 'countPackedOpUses'

function ucIncrementTwo(uc UseCountMap, a ValueId, b ValueId)
	ucIncrement(uc, valueId: a)
	ucIncrement(uc, valueId: b)
end 'ucIncrementTwo'

function ucIncrementThree(uc UseCountMap, a ValueId, b ValueId, c ValueId)
	ucIncrement(uc, valueId: a)
	ucIncrement(uc, valueId: b)
	ucIncrement(uc, valueId: c)
end 'ucIncrementThree'

function ucIncrementIdAndArray(uc UseCountMap, id ValueId, arr ValueIdArray)
	ucIncrement(uc, valueId: id)
	ucIncrementArray(uc, ids: arr)
end 'ucIncrementIdAndArray'

function ucIncrementCondBr(uc UseCountMap, condId ValueId, thenArgs ValueIdArray, elseArgs ValueIdArray)
	ucIncrement(uc, valueId: condId)
	ucIncrementArray(uc, ids: thenArgs)
	ucIncrementArray(uc, ids: elseArgs)
end 'ucIncrementCondBr'

function countMirOpUses(op MirOp, uc UseCountMap)
	match op 'count'
		movImm then break 'count'
		movReg(_, srcId) then ucIncrement(uc, valueId: srcId)
		binOp(_, leftId, rightId, _) then ucIncrementTwo(uc, a: leftId, b: rightId)
		unaryOp(_, operandId, _) then ucIncrement(uc, valueId: operandId)
		cmp(_, leftId, rightId, _) then ucIncrementTwo(uc, a: leftId, b: rightId)
		condBranch(condId, _, thenArgs, _, elseArgs) then ucIncrementCondBr(uc, condId: condId, thenArgs: thenArgs, elseArgs: elseArgs)
		branch(_, args) then ucIncrementArray(uc, ids: args)
		call(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		indirectCall(_, calleeId, argIds) then ucIncrementIdAndArray(uc, id: calleeId, arr: argIds)
		ret(retValId) then ucIncrement(uc, valueId: retValId)
		param then break 'count'
		load(_, baseId, _) then ucIncrement(uc, valueId: baseId)
		store(valueId, baseId, _) then ucIncrementTwo(uc, a: valueId, b: baseId)
		loadSlot then break 'count'
		storeSlot(_, valueId) then ucIncrement(uc, valueId: valueId)
		stackSlotAddr to loadFramePtr then break 'count'
		syscall(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		iatCall(_, _, argIds) then ucIncrementArray(uc, ids: argIds)
		osExit(codeId) then ucIncrement(uc, valueId: codeId)
		osWrite(ptrId, lenId) then ucIncrementTwo(uc, a: ptrId, b: lenId)
		osWriteErr(ptrId, lenId) then ucIncrementTwo(uc, a: ptrId, b: lenId)
		memcpy(dstId, srcId, lenId) then ucIncrementThree(uc, a: dstId, b: srcId, c: lenId)
		storeByte(baseId, offsetId, byteId) then ucIncrementThree(uc, a: baseId, b: offsetId, c: byteId)
		loadByte(_, baseId, offsetId) then ucIncrementTwo(uc, a: baseId, b: offsetId)
	end 'count'
end 'countMirOpUses'

// Extract the condId from a block's terminator if it is a condBr.
let NOT_CONDBR = u64.max

function getTerminatorCondId(module MirModule, block IrBlock) returns ValueId
	if not block.hasTerminator 'noTerm'
		return NOT_CONDBR
	end 'noTerm'
	let mirOp = try module.ops.get(block.terminator) otherwise 'noFunc'
		return NOT_CONDBR
	end 'noFunc'
	return match mirOp 'mirCheck'
		movImm to cmp gives NOT_CONDBR
		condBranch(condId, _, _, _, _) gives condId
		branch to loadByte gives NOT_CONDBR
	end 'mirCheck'
end 'getTerminatorCondId'

// A cmp result is flags-only when it has exactly 1 use and that use is the
// block's condBr terminator. The condBr reads CPU flags directly via condJump,
// so the setcc (which materializes the boolean into a register) can be skipped.
function isFlagsOnly(useCounts UseCountMap, resultId ValueId, condBrCondId ValueId) returns bool
	return ucGet(useCounts, valueId: resultId) <= 1 and condBrCondId == resultId
end 'isFlagsOnly'

// ============================================================
// Slot scanning helpers (free functions)
// ============================================================

// Count temp slots needed by a MIR system op (looked up by its plain index).
function sysOpTempSlotCountPacked(module MirModule, opIdx OpIndex) returns SlotIndex
	let mirOp = try module.ops.get(opIdx) otherwise 'noMem'
		return 0
	end 'noMem'
	return mirSysTempCount(mirOp)
end 'sysOpTempSlotCountPacked'

function mirSysTempCount(op MirOp) returns SlotIndex
	return match op 'check'
		syscall gives 1
		iatCall gives 1
		globalAddr gives 1
		funcAddr gives 1
		loadFramePtr gives 1
		stackSlotAddr gives 1
		storeByte gives 3
		loadByte gives 3
		memcpy gives 3
		osExit gives 1
		osWrite gives 6
		osWriteErr gives 6
		movImm to storeSlot gives 0
	end 'check'
end 'mirSysTempCount'

// ============================================================
// Jump kind helpers (free functions)
// ============================================================

function mirCmpGuard(condId ValueId, resultId ValueId, predicate MirCmpPredicate) returns JumpKind
	if condId < 0 or resultId == condId 'matchesCond'
		return mirPredicateToJumpKind(predicate)
	end 'matchesCond'
	return JumpKind.boolTest
end 'mirCmpGuard'

function tryMirCmpJumpKind(mirOp MirOp, condId ValueId) returns JumpKind
	match mirOp 'check'
		cmp(resultId, _, _, predicate) then return mirCmpGuard(condId: condId, resultId: resultId, predicate: predicate)
		movImm to unaryOp then break 'check'
		condBranch to loadByte then break 'check'
	end 'check'
	return JumpKind.boolTest
end 'tryMirCmpJumpKind'

// ============================================================
// Predicate / calling convention helpers (free functions)
// ============================================================

function predicateToSetcc(predicate MirCmpPredicate) returns X64SetccCondition
	return match predicate 'map'
		eq gives X64SetccCondition.e
		ne gives X64SetccCondition.ne
		lt gives X64SetccCondition.l
		le gives X64SetccCondition.le
		gt gives X64SetccCondition.g
		ge gives X64SetccCondition.ge
		ugt gives X64SetccCondition.a
		feq gives X64SetccCondition.e
		fne gives X64SetccCondition.ne
		flt gives X64SetccCondition.b
		fle gives X64SetccCondition.be
		fgt gives X64SetccCondition.a
		fge gives X64SetccCondition.ae
	end 'map'
end 'predicateToSetcc'

// Internal calling convention: GPR args in rcx, rdx, rax, r9, rsi, rdi, rbx
// R8 is reserved for return values. FP args in xmm0-xmm7. GPR and FP use separate index counters.
function getCallConvGpr(index VarSlot) returns X64Register
	let regs = [X64Register.rcx, X64Register.rdx, X64Register.rax, X64Register.r9, X64Register.rsi, X64Register.rdi, X64Register.rbx]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getCallConvGpr: param index {index} exceeds register count")
	end 'outOfRange'
end 'getCallConvGpr'

function getCallConvXmm(index VarSlot) returns X64XmmRegister
	let regs = [X64XmmRegister.xmm0, X64XmmRegister.xmm1, X64XmmRegister.xmm2, X64XmmRegister.xmm3, X64XmmRegister.xmm4, X64XmmRegister.xmm5, X64XmmRegister.xmm6, X64XmmRegister.xmm7]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getCallConvXmm: FP param index {index} exceeds register count")
	end 'outOfRange'
end 'getCallConvXmm'

// ============================================================
// Binary / float operation kind unions
// ============================================================

union X64BinKind
	add
	sub
	mul
	bitAnd
	bitOr
	bitXor
end 'X64BinKind'

union FloatBinKind
	add
	sub
	mul
	div
end 'FloatBinKind'

// ============================================================
// Branch edge stashing helpers (free functions)
// ============================================================

function stashMirEdges(op MirOp, dstBlock IrBlock)
	match op 'extract'
		branch(target, argIds) then dstBlock.branchEdges.push(BranchEdge.create(target, argIds: argIds))
		condBranch(_, thenTarget, thenArgs, elseTarget, elseArgs) then stashCondBrEdges(dstBlock, thenTarget: thenTarget, thenArgs: thenArgs, elseTarget: elseTarget, elseArgs: elseArgs)
		movImm to cmp then break 'extract'
		call to loadByte then break 'extract'
	end 'extract'
end 'stashMirEdges'

function stashCondBrEdges(dstBlock IrBlock, thenTarget BlockId, thenArgs ValueIdArray, elseTarget BlockId, elseArgs ValueIdArray)
	dstBlock.branchEdges.push(BranchEdge.create(thenTarget, argIds: thenArgs))
	dstBlock.branchEdges.push(BranchEdge.create(elseTarget, argIds: elseArgs))
end 'stashCondBrEdges'

// ============================================================
// Op-level flag detection (free function)
// ============================================================

function lastX64OpSetsFlagsFor(op X64Op, condId ValueId) returns bool
	// Check if op is a flag-setting ALU instruction whose virtual dest matches condId.
	if not op.rawValue.setsFlags 'notFlagSetting'
		return false
	end 'notFlagSetting'

	// Only ALU ops with a dest register can match condId.
	// Compare/test ops (passThrough, twoUse, singleUse, fpTwoUse) set flags but have no dest.
	let pattern = op.rawValue.pattern
	if pattern != OpPattern.twoAddr and pattern != OpPattern.useDefImm and pattern != OpPattern.unaryInPlace 'noDestReg'
		return false
	end 'noDestReg'

	match op 'extractDest'
		addRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		subRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		addRegImm(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		subRegImm(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		imulRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		andRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		orRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		xorRegReg(destReg, _) then return x64VRegMatchesId(destReg, condId: condId)
		negReg(reg) then return x64VRegMatchesId(reg, condId: condId)
		default panic("unreachable: non-ALU flag-setting op in lastX64OpSetsFlagsFor")
	end 'extractDest'
end 'lastX64OpSetsFlagsFor'

function x64VRegMatchesId(vreg X64VReg, condId ValueId) returns bool
	return match vreg 'check'
		virtual(vid) gives vid == condId
		physical gives false
	end 'check'
end 'x64VRegMatchesId'

// ============================================================
// Append integer immediate to register (exported free function)
// ============================================================

// Append the canonical X64 op sequence for "load integer immediate into GPR".
// Centralizes the size/zero choice so MirToX64Conversion, the spill helpers
// (emitMovImmX64), and any future caller all produce the same shape:
//   value == 0       -> xorRegRegSelf  (2-3 bytes, no false dependency)
//   0 <= value <= u32.max -> movRegImm32 (5-byte form, zero-extends)
//   otherwise        -> movRegImm       (full 10-byte mov r64, imm64)
// Doing this at the X64-op-construction layer rather than in the encoder
// keeps the IR dumps and downstream passes seeing a single canonical form.
export function appendIntImmToReg(target TargetModule, dstBlock IrBlock, dest X64VReg, value MachineWord)
	if value == 0 'zeroImm'
		appendX64Op(target, block: dstBlock, op: X64Op.xorRegRegSelf(dest))
		return
	end 'zeroImm'
	if value >= 0 and value <= u32.max 'u32Imm'
		appendX64Op(target, block: dstBlock, op: X64Op.movRegImm32(dest, value: value))
		return
	end 'u32Imm'
	appendX64Op(target, block: dstBlock, op: X64Op.movRegImm(dest, value: value))
end 'appendIntImmToReg'

// ============================================================
// X64FunctionLowering type — per-function lowering state
// ============================================================

type X64FunctionLowering
	var module MirModule
	var target TargetModule
	var osDesc OsDescriptor
	var allFunctions MirFunctionArray
	var globalData GlobalDataTable
	var funcParamTypes StdTypeArray
	var stdlibFunctions ObjectFunctionArray
	var constMap ConstMap
	var useCounts UseCountMap
	var absorbedConsts AbsorbedConstSet
	var valueSlots ValueSlotMap
	var nextTempSlot SlotIndex
	var condBrCondId ValueId

	static function create(module MirModule, target TargetModule, osDesc OsDescriptor, allFunctions MirFunctionArray, globalData GlobalDataTable, stdlibFunctions ObjectFunctionArray) returns X64FunctionLowering
		return Self{module: module, target: target, osDesc: osDesc, allFunctions: allFunctions, globalData: globalData, stdlibFunctions: stdlibFunctions, funcParamTypes: StdTypeArray.create(), constMap: ConstMap.create(), useCounts: UseCountMap.create(), absorbedConsts: AbsorbedConstSet.create(), valueSlots: ValueSlotMap.create(), nextTempSlot: 0, condBrCondId: NOT_CONDBR}
	end 'create'

	// ============================================================
	// Main orchestrator
	// ============================================================

	function lowerFunction(srcFunc MirFunction)

		// Phase 1: Compute variable stack space from memref slots.
		let loadedSlots = scanLoadedSlots(srcFunc)
		var liveSlotCount = 0
		for slot in loadedSlots 'countLive'
			if slot + 1 > liveSlotCount 'updateMax'
				liveSlotCount = slot + 1
			end 'updateMax'
		end 'countLive'

		// Count temp slots needed by SysOps (they still use slot-based addressing).
		// Skip diverging blocks (panic paths) since their slots are dead.
		var sysOpTempCount = 0
		for blockRef in srcFunc.blockRefs 'countSysTemps'
			let block = try module.blocks.get(blockRef) otherwise 'nextItem'
				continue
			end 'nextItem'
			if isMirDivergingBlock(module, block: block) 'skipDiverging'
				continue
			end 'skipDiverging'
			for packed in block.opRefs 'countOp'
				sysOpTempCount = sysOpTempCount + sysOpTempSlotCountPacked(module, opIdx: packed)
			end 'countOp'
		end 'countSysTemps'

		// Pre-compute an initial slot count estimate
		let precomputedSlotCount = liveSlotCount + sysOpTempCount

		// Initialize per-function state
		nextTempSlot = liveSlotCount
		valueSlots = ValueSlotMap.create()
		constMap = buildConstMap(module, func: srcFunc)
		useCounts = buildUseCountMap(module, func: srcFunc)
		absorbedConsts = buildAbsorbedConsts(module, func: srcFunc, constMap: constMap)

		// Create the destination TargetFunction and its blocks up front so terminator
		// block IDs from MIR still refer to valid blocks.
		var targetFunc = TargetFunction.create(srcFunc.name, returnType: srcFunc.returnType, paramCount: srcFunc.paramCount, paramTypes: srcFunc.paramTypes, returnLine: srcFunc.returnLine)
		targetFunc.nextBlockId = srcFunc.nextBlockId
		funcParamTypes = srcFunc.paramTypes
		// Pre-create an IrBlock for every source block, keyed by srcBlock.id.
		var blockByBlockId = IrBlockArray.create()
		for srcBlockRef in srcFunc.blockRefs 'createBlocks'
			let srcBlock = try module.blocks.get(srcBlockRef) otherwise 'skipCreate'
				continue
			end 'skipCreate'
			let dstIdx = target.blocks.count()
			var dstBlock = IrBlock.create(srcBlock.id, label: srcBlock.label)
			// Copy block args (used by regalloc for SSA phis)
			for srcArg in srcBlock.blockArgs 'copyArgs'
				dstBlock.blockArgs.push(IrBlockArg.create(srcArg.valueId, argType: srcArg.argType))
			end 'copyArgs'
			target.blocks.push(dstBlock)
			targetFunc.blockRefs.append(dstIdx)
			// Track for lookup during lowering
			while blockByBlockId.count() <= srcBlock.id 'growMap'
				blockByBlockId.push(IrBlock.create(0, label: ""))
			end 'growMap'
			blockByBlockId.set(srcBlock.id, value: dstBlock)
		end 'createBlocks'

		// Phase 2: Lower all blocks.
		var blockIdx = 0
		for blockRef in srcFunc.blockRefs 'eachBlock'
			let srcBlock = try module.blocks.get(blockRef) otherwise 'nextEntry'
				blockIdx = blockIdx + 1
				continue
			end 'nextEntry'
			var dstBlock = try blockByBlockId.get(srcBlock.id) otherwise 'noDst'
				blockIdx = blockIdx + 1
				continue
			end 'noDst'

			// Identify the condBr's condId so we can skip setcc for flags-only cmp results.
			condBrCondId = getTerminatorCondId(module, block: srcBlock)

			// Pre-compute jump kind while original MIR/arith ops are still in the block.
			let condBrJumpKind = determineJumpKindForCond(srcBlock)

			// Stash outgoing branch args on the target block's edges so the
			// regalloc CopyResolution can find them after the MIR is gone.
			if srcBlock.hasTerminator 'stashEdges'
				stashBranchEdges(srcTerminator: srcBlock.terminator, dstBlock: dstBlock)
			end 'stashEdges'

			// Lower each op in the source block
			for packed in srcBlock.opRefs 'eachOp'
				lowerPackedOp(opIdx: packed, dstBlock: dstBlock)
			end 'eachOp'

			// Lower terminator. Both branch and non-branch terminators emit their
			// ops into dstBlock.opRefs; setLastOpAsTerminator promotes the last one.
			if srcBlock.hasTerminator 'hasTerm'
				lowerTerminator(srcTerminator: srcBlock.terminator, dstBlock: dstBlock, returnType: srcFunc.returnType, jumpKind: condBrJumpKind)
				setLastOpAsTerminator(dstBlock)
			end 'hasTerm'
			blockIdx = blockIdx + 1
		end 'eachBlock'

		// Remove unconditional jumps that fall through to the next block.
		eliminateFallthroughJumps(targetFunc)

		// Record the actual total slot count after lowering.
		let actualSlotCount = nextTempSlot
		if actualSlotCount > precomputedSlotCount 'useActual'
			targetFunc.varSlotCount = actualSlotCount
		end 'useActual' else 'usePrecomputed'
			targetFunc.varSlotCount = precomputedSlotCount
		end 'usePrecomputed'

		target.functions.push(targetFunc)
	end 'lowerFunction'

	// ============================================================
	// Slot scanning
	// ============================================================

	// Scan which variable slots are read by memref.load ops.
	function scanLoadedSlots(func MirFunction) returns VarSlotArray
		var loaded = VarSlotArray.create()
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise 'skipRef'
				continue
			end 'skipRef'
			for opIdx in block.opRefs 'eachOp'
				let mirOp = try module.ops.get(opIdx) otherwise 'skipIdx'
					continue
				end 'skipIdx'
				match mirOp 'checkMir'
					stackSlotAddr(_, slotId) then loaded.push(slotId)
					loadSlot(_, slotId) then loaded.push(slotId)
					storeSlot(slotId, _) then loaded.push(slotId)
					movImm to store then break 'checkMir'
					globalAddr to loadByte then break 'checkMir'
				end 'checkMir'
			end 'eachOp'
		end 'eachBlock'
		return loaded
	end 'scanLoadedSlots'

	// ============================================================
	// Block helpers
	// ============================================================

	// Pop the last op from the block and set it as the terminator.
	function setLastOpAsTerminator(block IrBlock)
		let lastPacked = try block.opRefs.removeLast() otherwise 'noOps'
			return
		end 'noOps'
		block.terminator = lastPacked
		block.hasTerminator = true
	end 'setLastOpAsTerminator'

	function stashBranchEdges(srcTerminator OpIndex, dstBlock IrBlock)
		let mirOp = try module.ops.get(srcTerminator) otherwise 'noMir'
			return
		end 'noMir'
		stashMirEdges(mirOp, dstBlock: dstBlock)
	end 'stashBranchEdges'

	// ============================================================
	// Jump kind determination
	// ============================================================

	function determineJumpKindForCond(block IrBlock) returns JumpKind
		var j = block.opRefs.count() - 1
		while j >= 0 'scanBack'
			let opIdx = try block.opRefs.get(j) otherwise 'skipBack'
				j = j - 1
				continue
			end 'skipBack'
			let mirOp = try module.ops.get(opIdx) otherwise 'skipMir'
				j = j - 1
				continue
			end 'skipMir'
			let kind = tryMirCmpJumpKind(mirOp, condId: condBrCondId)
			if kind != JumpKind.boolTest 'foundMir'
				return kind
			end 'foundMir'
			j = j - 1
		end 'scanBack'
		return JumpKind.boolTest
	end 'determineJumpKindForCond'

	// ============================================================
	// Fallthrough jump elimination
	// ============================================================

	let NOT_A_JUMP_X64 = -1

	function getX64JumpTarget(packed OpIndex) returns BlockId
		let x64Op = try target.x64Ops.get(packed) otherwise 'noOp'
			return NOT_A_JUMP_X64
		end 'noOp'
		return match x64Op 'check'
			jmp(targetBlock) gives targetBlock
			prologue to condJump gives NOT_A_JUMP_X64
			movF64Slot to repStosq gives NOT_A_JUMP_X64
		end 'check'
	end 'getX64JumpTarget'

	// Remove unconditional jumps that fall through to the next block in layout
	// order. This runs after setLastOpAsTerminator has promoted the trailing jmp
	// into block.terminator, so the jmp lives in the terminator slot (not opRefs).
	//
	// When we eliminate the trailing jmp, we look at the last op in opRefs:
	//   - If it's a conditional jump (condJump), promote it to the terminator
	//     slot so the cond-br pattern detection in destroySSA still recognizes
	//     this block as having a conditional branch.
	//   - Otherwise (a regular ALU op or empty), just clear hasTerminator. The
	//     block has no real terminator anymore, but still has its branchEdges
	//     attached for parallel-copy resolution at the fall-through edge.
	//
	// Outgoing block arguments are not a concern here: they're stashed in
	// block.branchEdges at lowering time, and the regalloc / SSA destruction
	// passes read them from there, not from the terminator op.
	function eliminateFallthroughJumps(func TargetFunction)
		let blockCount = func.blockRefs.count()
		var i = 0
		while i < blockCount - 1 'eachBlock'
			let blockRef = try func.blockRefs.get(i) otherwise 'skipBlock'
				i = i + 1
				continue
			end 'skipBlock'
			var block = try target.blocks.get(blockRef) otherwise 'skipBlock2'
				i = i + 1
				continue
			end 'skipBlock2'
			if not block.hasTerminator 'noTerm'
				i = i + 1
				continue
			end 'noTerm'
			let nextBlockRef = try func.blockRefs.get(i + 1) otherwise 'skipNext'
				i = i + 1
				continue
			end 'skipNext'
			let nextBlock = try target.blocks.get(nextBlockRef) otherwise 'skipNext2'
				i = i + 1
				continue
			end 'skipNext2'
			let targetId = getX64JumpTarget(packed: block.terminator)
			if targetId != NOT_A_JUMP_X64 and targetId == nextBlock.id 'isFallthrough'
				block.hasTerminator = false
				// Only promote a trailing conditional jump back into the terminator
				// slot. Promoting an arbitrary ALU op here would let it execute AFTER
				// any parallel-copy moves the SSA destruction pass appends, breaking
				// the moves' values.
				let lastIdx = block.opRefs.count() - 1
				if lastIdx >= 0 'hasOps'
					let lastPacked = try block.opRefs.get(lastIdx) otherwise 'noLast'
						i = i + 1
						continue
					end 'noLast'
					if terminatorIsConditionalBranch(target, packed: lastPacked) 'isCondJmp'
						try block.opRefs.removeLast() otherwise ignore
						block.terminator = lastPacked
						block.hasTerminator = true
					end 'isCondJmp'
				end 'hasOps'
			end 'isFallthrough'
			i = i + 1
		end 'eachBlock'
	end 'eliminateFallthroughJumps'

	// ============================================================
	// Op dispatch
	// ============================================================

	function lowerPackedOp(opIdx OpIndex, dstBlock IrBlock)
		let mirOp = try module.ops.get(opIdx) otherwise 'noMir'
			return
		end 'noMir'
		lowerMirOp(op: mirOp, dstBlock: dstBlock)
	end 'lowerPackedOp'

	function lowerMirOp(op MirOp, dstBlock IrBlock)
		match op 'dispatch'
			movImm(resultId, value, isFloat) then lowerMovImm(resultId: resultId, value: value, isFloat: isFloat, dstBlock: dstBlock)
			movReg(resultId, srcId) then lowerMovReg(resultId: resultId, srcId: srcId, dstBlock: dstBlock)
			binOp(resultId, leftId, rightId, opcode) then lowerBinOp(resultId: resultId, leftId: leftId, rightId: rightId, opcode: opcode, dstBlock: dstBlock)
			unaryOp(resultId, operandId, opcode) then lowerUnaryOp(resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
			cmp(resultId, leftId, rightId, predicate) then lowerCmp(resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
			condBranch then break 'dispatch'
			branch then break 'dispatch'
			call(resultId, callee, argIds) then lowerCall(resultId: resultId, callee: callee, argIds: argIds, dstBlock: dstBlock)
			indirectCall(resultId, calleeId, argIds) then lowerIndirectCall(resultId: resultId, calleeId: calleeId, argIds: argIds, dstBlock: dstBlock)
			ret then break 'dispatch'
			param(resultId, paramIndex, paramType) then lowerParam(resultId: resultId, paramIndex: paramIndex, paramType: paramType, dstBlock: dstBlock)
			load(resultId, baseId, offset) then lowerLoad(resultId: resultId, baseId: baseId, offset: offset, dstBlock: dstBlock)
			store(valueId, baseId, offset) then lowerStore(valueId: valueId, baseId: baseId, offset: offset, dstBlock: dstBlock)
			loadSlot(resultId, slotId) then appendX64Op(target, block: dstBlock, op: X64Op.loadSlot(X64VReg.virtual(resultId), slotIndex: slotId))
			storeSlot(slotId, valueId) then appendX64Op(target, block: dstBlock, op: X64Op.movSlot(slotId, srcReg: X64VReg.virtual(valueId)))
			stackSlotAddr to loadByte then lowerMirSysOp(op: op, dstBlock: dstBlock)
		end 'dispatch'
	end 'lowerMirOp'

	// ============================================================
	// Constants & moves
	// ============================================================

	function lowerMovImm(resultId ValueId, value ParsedInt, isFloat bool, dstBlock IrBlock)
		// Skip emission if every consumer absorbs this constant as an immediate.
		if isAbsorbedConst(absorbedConsts, valueId: resultId) 'skip'
			return
		end 'skip'
		if isFloat 'floatImm'
			lowerFloatConst(resultId: resultId, rawBits: value, dstBlock: dstBlock)
			return
		end 'floatImm'
		appendIntImmToReg(target, dstBlock: dstBlock, dest: X64VReg.virtual(resultId), value: value)
	end 'lowerMovImm'

	// Float constant: load directly into XMM via movsd [rip+data island].
	function lowerFloatConst(resultId ValueId, rawBits ParsedInt, dstBlock IrBlock)
		let label = registerFloatConstant(rawBits, globalData: globalData)
		appendX64Op(target, block: dstBlock, op: X64Op.movXmmRipRel(X64FpVReg.virtual(resultId), rdataLabel: label, precision: FloatPrecision.f64))
	end 'lowerFloatConst'

	function lowerMovReg(resultId ValueId, srcId ValueId, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: X64VReg.virtual(srcId)))
	end 'lowerMovReg'

	// ============================================================
	// Binary operations
	// ============================================================

	function lowerBinOp(resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode, dstBlock IrBlock)
		match opcode 'lower'
			addI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.add, dstBlock: dstBlock)
			subI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.sub, dstBlock: dstBlock)
			mulI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.mul, dstBlock: dstBlock)
			divI64 then lowerDivRem(resultId: resultId, leftId: leftId, rightId: rightId, isRem: false, dstBlock: dstBlock)
			remI64 then lowerDivRem(resultId: resultId, leftId: leftId, rightId: rightId, isRem: true, dstBlock: dstBlock)
			andI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.bitAnd, dstBlock: dstBlock)
			orI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.bitOr, dstBlock: dstBlock)
			xorI64 then lowerIntBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: X64BinKind.bitXor, dstBlock: dstBlock)
			shlI64 then lowerShift(resultId: resultId, leftId: leftId, rightId: rightId, isLeft: true, dstBlock: dstBlock)
			shrI64 then lowerShift(resultId: resultId, leftId: leftId, rightId: rightId, isLeft: false, dstBlock: dstBlock)
			addF64 then lowerFloatBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: FloatBinKind.add, dstBlock: dstBlock)
			subF64 then lowerFloatBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: FloatBinKind.sub, dstBlock: dstBlock)
			mulF64 then lowerFloatBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: FloatBinKind.mul, dstBlock: dstBlock)
			divF64 then lowerFloatBinOp(resultId: resultId, leftId: leftId, rightId: rightId, kind: FloatBinKind.div, dstBlock: dstBlock)
		end 'lower'
	end 'lowerBinOp'

	function emitAddOp(dstBlock IrBlock, dest X64VReg, rightId ValueId, useImm bool, constVal ImmediateValue)
		if useImm 'addImm'
			appendX64Op(target, block: dstBlock, op: X64Op.addRegImm(dest, value: constVal))
		end 'addImm' else 'addReg'
			appendX64Op(target, block: dstBlock, op: X64Op.addRegReg(dest, srcReg: X64VReg.virtual(rightId)))
		end 'addReg'
	end 'emitAddOp'

	function emitSubOp(dstBlock IrBlock, dest X64VReg, rightId ValueId, useImm bool, constVal ImmediateValue)
		if useImm 'subImm'
			appendX64Op(target, block: dstBlock, op: X64Op.subRegImm(dest, value: constVal))
		end 'subImm' else 'subReg'
			appendX64Op(target, block: dstBlock, op: X64Op.subRegReg(dest, srcReg: X64VReg.virtual(rightId)))
		end 'subReg'
	end 'emitSubOp'

	// x64 has destructive binary ops: dest = dest OP src.
	// Copy left to result first, then apply the operation.
	// For add/sub, if the right operand is a known small constant, emit addRegImm/subRegImm.
	function lowerIntBinOp(resultId ValueId, leftId ValueId, rightId ValueId, kind X64BinKind, dstBlock IrBlock)
		let dest = X64VReg.virtual(resultId)
		// Check if right operand is a known constant suitable for immediate encoding (fits imm32)
		let constVal = constMapGet(constMap, valueId: rightId)
		let useImm = constVal != CONST_NOT_FOUND and constVal >= 0 and constVal <= i32.max
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(dest, srcReg: X64VReg.virtual(leftId)))
		match kind 'emit'
			add then emitAddOp(dstBlock: dstBlock, dest: dest, rightId: rightId, useImm: useImm, constVal: constVal)
			sub then emitSubOp(dstBlock: dstBlock, dest: dest, rightId: rightId, useImm: useImm, constVal: constVal)
			mul then appendX64Op(target, block: dstBlock, op: X64Op.imulRegReg(dest, srcReg: X64VReg.virtual(rightId)))
			bitAnd then appendX64Op(target, block: dstBlock, op: X64Op.andRegReg(dest, srcReg: X64VReg.virtual(rightId)))
			bitOr then appendX64Op(target, block: dstBlock, op: X64Op.orRegReg(dest, srcReg: X64VReg.virtual(rightId)))
			bitXor then appendX64Op(target, block: dstBlock, op: X64Op.xorRegReg(dest, srcReg: X64VReg.virtual(rightId)))
		end 'emit'
	end 'lowerIntBinOp'

	// Float binary op: both operands as FP virtuals, result in FP virtual.
	// Destructive: copy left to result, then apply operation.
	function lowerFloatBinOp(resultId ValueId, leftId ValueId, rightId ValueId, kind FloatBinKind, dstBlock IrBlock)
		let dest = X64FpVReg.virtual(resultId)
		let src = X64FpVReg.virtual(rightId)
		appendX64Op(target, block: dstBlock, op: X64Op.movXmmXmm(dest, src: X64FpVReg.virtual(leftId), precision: FloatPrecision.f64))
		match kind 'emit'
			add then appendX64Op(target, block: dstBlock, op: X64Op.addXmm(dest, src: src, precision: FloatPrecision.f64))
			sub then appendX64Op(target, block: dstBlock, op: X64Op.subXmm(dest, src: src, precision: FloatPrecision.f64))
			mul then appendX64Op(target, block: dstBlock, op: X64Op.mulXmm(dest, src: src, precision: FloatPrecision.f64))
			div then appendX64Op(target, block: dstBlock, op: X64Op.divXmm(dest, src: src, precision: FloatPrecision.f64))
		end 'emit'
	end 'lowerFloatBinOp'

	// Division/remainder: IDIV uses fixed registers RAX:RDX.
	// Move dividend to RAX, zero or sign-extend into RDX:RAX, emit IDIV.
	// Result: quotient in RAX, remainder in RDX.
	// When the dividend is a known non-negative constant, use XOR RDX,RDX
	// instead of CQO — shorter, breaks the RAX dependency, and can execute
	// in parallel with the MOV to RAX.
	function lowerDivRem(resultId ValueId, leftId ValueId, rightId ValueId, isRem bool, dstBlock IrBlock)
		let rax = physReg(X64Register.rax)
		let rdx = physReg(X64Register.rdx)
		// Move dividend to RAX (ABI-fixed)
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(rax, srcReg: X64VReg.virtual(leftId)))
		// Prepare RDX: xor rdx,rdx for non-negative constants, cqo otherwise
		let dividendConst = constMapGet(constMap, valueId: leftId)
		if dividendConst != CONST_NOT_FOUND and dividendConst >= 0 'knownNonNeg'
			appendX64Op(target, block: dstBlock, op: X64Op.xorRegRegSelf(rdx))
		end 'knownNonNeg' else 'signExtend'
			appendX64Op(target, block: dstBlock, op: X64Op.cqo)
		end 'signExtend'
		// IDIV by the divisor virtual register
		appendX64Op(target, block: dstBlock, op: X64Op.idivReg(X64VReg.virtual(rightId)))
		// Move result from fixed register to virtual
		if isRem 'remainder'
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: rdx))
		end 'remainder' else 'quotient'
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: rax))
		end 'quotient'
	end 'lowerDivRem'

	// Shift: the register allocator handles moving the shift count to
	// RCX and allocating a non-RCX register for the result.
	function lowerShift(resultId ValueId, leftId ValueId, rightId ValueId, isLeft bool, dstBlock IrBlock)
		if isLeft 'shl'
			appendX64Op(target, block: dstBlock, op: X64Op.shlRegCl(X64VReg.virtual(resultId), operand: X64VReg.virtual(leftId), shiftCount: X64VReg.virtual(rightId)))
		end 'shl' else 'shr'
			appendX64Op(target, block: dstBlock, op: X64Op.shrRegCl(X64VReg.virtual(resultId), operand: X64VReg.virtual(leftId), shiftCount: X64VReg.virtual(rightId)))
		end 'shr'
	end 'lowerShift'

	// ============================================================
	// Unary operations
	// ============================================================

	function lowerUnaryOp(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock IrBlock)
		match opcode 'lower'
			negI64 then lowerIntUnary(resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
			bitNotI64 then lowerIntUnary(resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
			fpToSiI64 then lowerFpToSi(resultId: resultId, operandId: operandId, dstBlock: dstBlock)
			siToFpF64 then lowerSiToFp(resultId: resultId, operandId: operandId, dstBlock: dstBlock)
		end 'lower'
	end 'lowerUnaryOp'

	function lowerIntUnary(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock IrBlock)
		let dest = X64VReg.virtual(resultId)
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(dest, srcReg: X64VReg.virtual(operandId)))
		match opcode 'emit'
			negI64 then appendX64Op(target, block: dstBlock, op: X64Op.negReg(dest))
			bitNotI64 then appendX64Op(target, block: dstBlock, op: X64Op.bitNotReg(dest))
			fpToSiI64 to siToFpF64 then panic("lowerIntUnary: unexpected float opcode")
		end 'emit'
	end 'lowerIntUnary'

	// Float-to-integer truncation: cvttsd2si
	function lowerFpToSi(resultId ValueId, operandId ValueId, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.cvttFloat2Si(X64VReg.virtual(resultId), src: X64FpVReg.virtual(operandId), precision: FloatPrecision.f64))
	end 'lowerFpToSi'

	// Integer-to-float conversion: cvtsi2sd
	function lowerSiToFp(resultId ValueId, operandId ValueId, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.cvtSi2Float(X64FpVReg.virtual(resultId), src: X64VReg.virtual(operandId), precision: FloatPrecision.f64))
	end 'lowerSiToFp'

	// ============================================================
	// Compare
	// ============================================================

	function lowerCmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
		match predicate 'kind'
			eq to ugt then lowerIntCmp(resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
			feq to fge then lowerFloatCmp(resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
		end 'kind'
	end 'lowerCmp'

	function lowerIntCmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
		let constVal = constMapGet(constMap, valueId: rightId)
		if constVal == 0 'testZero'
			// test reg, reg is shorter and faster than cmp reg, 0
			let lhs = X64VReg.virtual(leftId)
			appendX64Op(target, block: dstBlock, op: X64Op.testRegReg(lhs, reg2: lhs))
		end 'testZero' else if constVal != CONST_NOT_FOUND and constVal >= 0 and constVal <= i32.max 'useImm'
			appendX64Op(target, block: dstBlock, op: X64Op.cmpRegImm(X64VReg.virtual(leftId), value: constVal))
		end 'useImm' else 'useReg'
			appendX64Op(target, block: dstBlock, op: X64Op.cmpRegReg(X64VReg.virtual(leftId), rhsReg: X64VReg.virtual(rightId)))
		end 'useReg'
		// Skip setcc when the sole consumer is a condBr (which reads flags directly).
		if not isFlagsOnly(useCounts, resultId: resultId, condBrCondId: condBrCondId) 'needsSetcc'
			let condition = predicateToSetcc(predicate)
			appendX64Op(target, block: dstBlock, op: X64Op.setcc(X64VReg.virtual(resultId), condition: condition))
		end 'needsSetcc'
	end 'lowerIntCmp'

	function lowerFloatCmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.ucomisXmm(X64FpVReg.virtual(leftId), src2: X64FpVReg.virtual(rightId), precision: FloatPrecision.f64))
		// Skip setcc when the sole consumer is a condBr (which reads flags directly).
		if not isFlagsOnly(useCounts, resultId: resultId, condBrCondId: condBrCondId) 'needsSetcc'
			let condition = predicateToSetcc(predicate)
			appendX64Op(target, block: dstBlock, op: X64Op.setcc(X64VReg.virtual(resultId), condition: condition))
		end 'needsSetcc'
	end 'lowerFloatCmp'

	// ============================================================
	// Call
	// ============================================================

	function lowerCall(resultId ValueId, callee String, argIds ValueIdArray, dstBlock IrBlock)
		// Look up callee's param types to route float args to XMM registers
		let paramTypes = lookupFuncParamTypes(callee, allFunctions: allFunctions, stdlibFunctions: stdlibFunctions)

		// Move args to calling convention registers with separate GPR/FP counters
		var argIdx = 0
		var gprIdx = 0
		var fpIdx = 0
		while argIdx < argIds.count() 'moveArgs'
			let argId = try argIds.get(argIdx) otherwise 'skipArg'
				argIdx = argIdx + 1
				continue
			end 'skipArg'
			let paramType = try paramTypes.get(argIdx) otherwise StdType.i64
			if stdTypeIsFloat(paramType) and fpIdx < 8 'fpRegArg'
				let xmmReg = getCallConvXmm(fpIdx)
				appendX64Op(target, block: dstBlock, op: X64Op.movXmmXmm(physFpReg(xmmReg), src: X64FpVReg.virtual(argId), precision: FloatPrecision.f64))
				fpIdx = fpIdx + 1
			end 'fpRegArg' else if gprIdx < 8 'gprRegArg'
				let ccReg = getCallConvGpr(gprIdx)
				appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(physReg(ccReg), srcReg: X64VReg.virtual(argId)))
				gprIdx = gprIdx + 1
			end 'gprRegArg'
			argIdx = argIdx + 1
		end 'moveArgs'

		// Emit the call
		appendX64Op(target, block: dstBlock, op: X64Op.callDirect(callee))

		// Move return value from R8/XMM0 to virtual result. Void-returning
		// callees have no result to capture.
		let calleeReturnType = lookupFuncReturnStdType(callee, allFunctions: allFunctions, stdlibFunctions: stdlibFunctions)
		match calleeReturnType 'capture'
			void then break 'capture'
			value(inner) then emitCallResultCapture(resultId: resultId, dstBlock: dstBlock, resultType: inner)
		end 'capture'
	end 'lowerCall'

	function emitCallResultCapture(resultId ValueId, dstBlock IrBlock, resultType StdType)
		if stdTypeIsFloat(resultType) 'floatResult'
			appendX64Op(target, block: dstBlock, op: X64Op.movXmmXmm(X64FpVReg.virtual(resultId), src: physFpReg(X64XmmRegister.xmm0), precision: FloatPrecision.f64))
		end 'floatResult' else 'intResult'
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: physReg(X64Register.r8)))
		end 'intResult'
	end 'emitCallResultCapture'

	function lowerIndirectCall(resultId ValueId, calleeId ValueId, argIds ValueIdArray, dstBlock IrBlock)
		// Move args to calling convention registers
		var argIdx = 0
		while argIdx < argIds.count() and argIdx < 8 'moveArgs'
			let argId = try argIds.get(argIdx) otherwise 'skipArg'
				argIdx = argIdx + 1
				continue
			end 'skipArg'
			let ccReg = getCallConvGpr(argIdx)
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(physReg(ccReg), srcReg: X64VReg.virtual(argId)))
			argIdx = argIdx + 1
		end 'moveArgs'
		if argIds.count() > 8 'tooManyArgs'
			panic("lowerIndirectCall: more than 8 arguments not yet supported (got {argIds.count()})")
		end 'tooManyArgs'

		// Move callee address to a scratch register for indirect call
		appendX64Op(target, block: dstBlock, op: X64Op.callIndirect(X64VReg.virtual(calleeId)))

		// Move return value from R8
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: physReg(X64Register.r8)))
	end 'lowerIndirectCall'

	// ============================================================
	// Param
	// ============================================================

	// Move from calling convention register to virtual register.
	// Float params arrive in XMM registers, int params in GPR registers.
	function lowerParam(resultId ValueId, paramIndex VarSlot, paramType StdType, dstBlock IrBlock)
		let slotIdx = computeParamSlotIndex(paramIndex, paramTypes: funcParamTypes)
		if stdTypeIsFloat(paramType) and slotIdx < 8 'fpRegParam'
			let xmmReg = getCallConvXmm(slotIdx)
			appendX64Op(target, block: dstBlock, op: X64Op.movXmmXmm(X64FpVReg.virtual(resultId), src: physFpReg(xmmReg), precision: FloatPrecision.f64))
		end 'fpRegParam' else if slotIdx < 8 'gprRegParam'
			let ccReg = getCallConvGpr(slotIdx)
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: physReg(ccReg)))
		end 'gprRegParam'
	end 'lowerParam'

	// ============================================================
	// Memory (load/store indirect)
	// ============================================================

	function lowerLoad(resultId ValueId, baseId ValueId, offset MachineWord, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.loadIndirect(X64VReg.virtual(resultId), baseReg: X64VReg.virtual(baseId), offset: offset, size: 8))
	end 'lowerLoad'

	function lowerStore(valueId ValueId, baseId ValueId, offset MachineWord, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.storeIndirect(X64VReg.virtual(baseId), offset: offset, srcReg: X64VReg.virtual(valueId), size: 8))
	end 'lowerStore'

	// ============================================================
	// Terminators
	// ============================================================

	function lowerTerminator(srcTerminator OpIndex, dstBlock IrBlock, returnType StdReturnType, jumpKind JumpKind)
		let mirOp = try module.ops.get(srcTerminator) otherwise 'noMir'
			return
		end 'noMir'
		lowerMirTerminator(op: mirOp, dstBlock: dstBlock, returnType: returnType, jumpKind: jumpKind)
	end 'lowerTerminator'

	function lowerMirTerminator(op MirOp, dstBlock IrBlock, returnType StdReturnType, jumpKind JumpKind)
		match op 'lower'
			condBranch(condId, thenTarget, _, elseTarget, _) then lowerCondBr(condId: condId, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock, jumpKind: jumpKind)
			branch(branchTarget, _) then lowerBrWithArgs(targetBlockId: branchTarget, dstBlock: dstBlock)
			ret(retValId) then lowerReturn(retValId: retValId, dstBlock: dstBlock, returnType: returnType)
			movImm to cmp then break 'lower'
			call to indirectCall then break 'lower'
			param to loadByte then break 'lower'
		end 'lower'
	end 'lowerMirTerminator'

	// Return: move value to R8 (or XMM0 for float), then emit epilogue+ret.
	// Void-returning functions still get the move so that the implicit 0 returned
	// by the parser lands in the canonical return register — this keeps the dead
	// `mov r8d, 0` visible in the output instead of letting regalloc assign it to
	// an arbitrary callee-saved register. Floating-point void is unreachable
	// (only value-returning functions can have float return type).
	function lowerReturn(retValId ValueId, dstBlock IrBlock, returnType StdReturnType)
		let isFloat = stdReturnTypeIsFloat(returnType)
		if isFloat 'floatReturn'
			appendX64Op(target, block: dstBlock, op: X64Op.movXmmXmm(physFpReg(X64XmmRegister.xmm0), src: X64FpVReg.virtual(retValId), precision: FloatPrecision.f64))
		end 'floatReturn' else 'intReturn'
			appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(physReg(X64Register.r8), srcReg: X64VReg.virtual(retValId)))
		end 'intReturn'
		appendX64Op(target, block: dstBlock, op: X64Op.epilogue)
		appendX64Op(target, block: dstBlock, op: X64Op.ret)
	end 'lowerReturn'

	// ============================================================
	// Branch helpers
	// ============================================================

	// Block arguments are NOT handled by the ISel. The SSA register allocator's
	// destroySSA pass inserts properly-sequentialized parallel copies at CFG edges
	// using CopyResolution. The ISel just emits jumps.

	function lowerBrWithArgs(targetBlockId BlockId, dstBlock IrBlock)
		// Block arg passing is handled by the register allocator's destroySSA pass.
		appendX64Op(target, block: dstBlock, op: X64Op.jmp(targetBlockId))
	end 'lowerBrWithArgs'

	function lowerCondBr(condId ValueId, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock, jumpKind JumpKind)
		// Block arg passing is handled by the register allocator's destroySSA pass.
		// Emit inverted conditional jump to else block, then unconditional jump to then block.
		match jumpKind 'emitJump'
			eq then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.ne, targetBlock: elseTarget))
			ne then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.e, targetBlock: elseTarget))
			lt then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.ge, targetBlock: elseTarget))
			le then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.g, targetBlock: elseTarget))
			gt then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.le, targetBlock: elseTarget))
			ge then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.l, targetBlock: elseTarget))
			ugt then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.be, targetBlock: elseTarget))
			feq then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.ne, targetBlock: elseTarget))
			fne then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.e, targetBlock: elseTarget))
			flt then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.ae, targetBlock: elseTarget))
			fle then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.a, targetBlock: elseTarget))
			fgt then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.be, targetBlock: elseTarget))
			fge then appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.b, targetBlock: elseTarget))
			boolTest then lowerBoolTestCondBr(condId: condId, elseTarget: elseTarget, dstBlock: dstBlock)
		end 'emitJump'
		// Unconditional jump to then block
		appendX64Op(target, block: dstBlock, op: X64Op.jmp(thenTarget))
	end 'lowerCondBr'

	function lowerBoolTestCondBr(condId ValueId, elseTarget BlockId, dstBlock IrBlock)
		// If the previous op is an or/and/xor that defines condId, its flags are still
		// live — skip the redundant test instruction.
		if not lastOpSetsFlagsFor(block: dstBlock, condId: condId) 'needsTest'
			let vr = X64VReg.virtual(condId)
			appendX64Op(target, block: dstBlock, op: X64Op.testRegReg(vr, reg2: vr))
		end 'needsTest'
		appendX64Op(target, block: dstBlock, op: X64Op.condJump(X64JumpCondition.e, targetBlock: elseTarget))
	end 'lowerBoolTestCondBr'

	// Check if the last op in the block is an or/and/xor whose dest is condId.
	// These instructions set ZF based on their result, so a subsequent test is redundant.
	function lastOpSetsFlagsFor(block IrBlock, condId ValueId) returns bool
		let opCount = block.opRefs.count()
		if opCount == 0 'empty'
			return false
		end 'empty'
		let lastPacked = try block.opRefs.get(opCount - 1) otherwise 'noOp'
			return false
		end 'noOp'
		let x64Op = try target.x64Ops.get(lastPacked) otherwise 'noOp7'
			return false
		end 'noOp7'
		return lastX64OpSetsFlagsFor(x64Op, condId: condId)
	end 'lastOpSetsFlagsFor'

	// ============================================================
	// SysOps — slot-based lowering (no register allocation)
	// ============================================================

	// MIR system-like ops (stackSlotAddr, globalAddr, syscall, etc.)
	function lowerMirSysOp(op MirOp, dstBlock IrBlock)
		match op 'lower'
			stackSlotAddr(resultId, slotId) then lowerStackAddr(resultId: resultId, slotId: slotId, dstBlock: dstBlock)
			globalAddr(resultId, name) then lowerGlobalAddr(resultId: resultId, name: name, dstBlock: dstBlock)
			funcAddr(resultId, name) then lowerFuncAddr(resultId: resultId, name: name, dstBlock: dstBlock)
			loadFramePtr(resultId) then lowerLoadFramePtr(resultId: resultId, dstBlock: dstBlock)
			syscall(resultId, number, argIds) then lowerSyscall(resultId: resultId, number: number, argIds: argIds, dstBlock: dstBlock)
			iatCall(resultId, slotIndex, argIds) then lowerIatCall(resultId: resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock)
			osExit(codeId) then lowerOsExit(codeId: codeId, dstBlock: dstBlock)
			osWrite(ptrId, lenId) then lowerOsWrite(ptrId: ptrId, lenId: lenId, dstBlock: dstBlock)
			osWriteErr(ptrId, lenId) then lowerOsWriteErr(ptrId: ptrId, lenId: lenId, dstBlock: dstBlock)
			memcpy(dstId, srcId, lenId) then lowerMemcpy(dstId: dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock)
			storeByte(baseId, offsetId, byteId) then lowerStoreByte(baseId: baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock)
			loadByte(resultId, baseId, offsetId) then lowerLoadByte(resultId: resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock)
			movImm to storeSlot then break 'lower'
		end 'lower'
	end 'lowerMirSysOp'

	// Ensure a value is stored to a VarSlot. For SysOps that need slot-based addressing,
	// we store the virtual register value into a temp slot. Self-bumps nextTempSlot
	// when allocating a new slot.
	function ensureValueInSlot(valueId ValueId, dstBlock IrBlock) returns VarSlot
		if valueSlotMapHas(valueSlots, valueId: valueId) 'hasSlot'
			let existingSlot = valueSlotMapGet(valueSlots, valueId: valueId)
			// Re-store current value to its existing slot
			appendX64Op(target, block: dstBlock, op: X64Op.movSlot(existingSlot, srcReg: X64VReg.virtual(valueId)))
			return existingSlot
		end 'hasSlot'
		// No slot yet — assign a temp slot and store
		let slot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.movSlot(slot, srcReg: X64VReg.virtual(valueId)))
		valueSlotMapSet(valueSlots, valueId: valueId, slot: slot)
		nextTempSlot = nextTempSlot + 1
		return slot
	end 'ensureValueInSlot'

	// Slot-based syscall lowering used by lowerMirSysOp for MIR syscall ops.
	function lowerSyscall(resultId ValueId, number MachineWord, argIds ValueIdArray, dstBlock IrBlock)
		var argSlots = VarSlotArray.create()
		for argId in argIds 'mapArgs'
			let slot = ensureValueInSlot(valueId: argId, dstBlock: dstBlock)
			argSlots.push(slot)
		end 'mapArgs'
		let resultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.syscall(resultSlot, number: number, argSlots: argSlots))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
		appendX64Op(target, block: dstBlock, op: X64Op.loadSlot(X64VReg.virtual(resultId), slotIndex: resultSlot))
		nextTempSlot = nextTempSlot + 1
	end 'lowerSyscall'

	function lowerIatCall(resultId ValueId, slotIndex MachineWord, argIds ValueIdArray, dstBlock IrBlock)
		var argSlots = VarSlotArray.create()
		for argId in argIds 'mapArgs'
			let slot = ensureValueInSlot(valueId: argId, dstBlock: dstBlock)
			argSlots.push(slot)
		end 'mapArgs'
		let resultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.iatCall(resultSlot, slotIndex: slotIndex, argSlots: argSlots))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
		appendX64Op(target, block: dstBlock, op: X64Op.loadSlot(X64VReg.virtual(resultId), slotIndex: resultSlot))
		nextTempSlot = nextTempSlot + 1
	end 'lowerIatCall'

	function lowerGlobalAddr(resultId ValueId, name String, dstBlock IrBlock)
		// Emit LEA directly into a virtual register — no slot indirection needed.
		// The code emitter resolves the label via a data island + RIP-relative LEA.
		appendX64Op(target, block: dstBlock, op: X64Op.leaRipRelative(X64VReg.virtual(resultId), rdataLabel: name))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	end 'lowerGlobalAddr'

	function lowerStackAddr(resultId ValueId, slotId VarSlot, dstBlock IrBlock)
		// Ensure the result slot doesn't overlap with the target slot or any
		// slot at or below the target. The target slot and its surrounding area
		// may be used as a buffer (e.g., mrt_i64_to_string writes 20 bytes starting
		// from the target slot address). Place the result above all such slots.
		if nextTempSlot <= slotId 'conflict'
			nextTempSlot = slotId + 1
		end 'conflict'
		let tempSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.stackAddrOp(tempSlot, targetSlot: slotId))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
		// Also load the result into a virtual register so regular ops can use it
		appendX64Op(target, block: dstBlock, op: X64Op.loadSlot(X64VReg.virtual(resultId), slotIndex: tempSlot))
		nextTempSlot = nextTempSlot + 1
	end 'lowerStackAddr'

	function lowerStoreByte(baseId ValueId, offsetId ValueId, byteId ValueId, dstBlock IrBlock)
		let baseSlot = ensureValueInSlot(valueId: baseId, dstBlock: dstBlock)
		let offsetSlot = ensureValueInSlot(valueId: offsetId, dstBlock: dstBlock)
		let byteSlot = ensureValueInSlot(valueId: byteId, dstBlock: dstBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.storeByteOp(baseSlot, offsetSlot: offsetSlot, byteSlot: byteSlot))
	end 'lowerStoreByte'

	function lowerLoadByte(resultId ValueId, baseId ValueId, offsetId ValueId, dstBlock IrBlock)
		let baseSlot = ensureValueInSlot(valueId: baseId, dstBlock: dstBlock)
		let offsetSlot = ensureValueInSlot(valueId: offsetId, dstBlock: dstBlock)
		let resultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.loadByteOp(resultSlot, baseSlot: baseSlot, offsetSlot: offsetSlot))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
		// Also load the result into a virtual register so regular ops can use it
		appendX64Op(target, block: dstBlock, op: X64Op.loadSlot(X64VReg.virtual(resultId), slotIndex: resultSlot))
		nextTempSlot = nextTempSlot + 1
	end 'lowerLoadByte'

	function lowerMemcpy(dstId ValueId, srcId ValueId, lenId ValueId, dstBlock IrBlock)
		let dstSlot = ensureValueInSlot(valueId: dstId, dstBlock: dstBlock)
		let srcSlot = ensureValueInSlot(valueId: srcId, dstBlock: dstBlock)
		let lenSlot = ensureValueInSlot(valueId: lenId, dstBlock: dstBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.memcpyOp(dstSlot, srcSlot: srcSlot, lenSlot: lenSlot))
	end 'lowerMemcpy'

	// ============================================================
	// OS-neutral exit/write
	// ============================================================

	function lowerOsExit(codeId ValueId, dstBlock IrBlock)
		let codeSlot = ensureValueInSlot(valueId: codeId, dstBlock: dstBlock)
		match osDesc.exit 'strategy'
			syscall(num) then lowerOsExitSyscall(codeSlot: codeSlot, num: num, dstBlock: dstBlock)
			iatCall(slotIdx) then lowerOsExitIat(codeSlot: codeSlot, slotIdx: slotIdx, dstBlock: dstBlock)
		end 'strategy'
	end 'lowerOsExit'

	function lowerOsExitSyscall(codeSlot VarSlot, num MachineWord, dstBlock IrBlock)
		var argSlots = VarSlotArray.create()
		argSlots.push(codeSlot)
		appendX64Op(target, block: dstBlock, op: X64Op.syscall(nextTempSlot, number: num, argSlots: argSlots))
		nextTempSlot = nextTempSlot + 1
	end 'lowerOsExitSyscall'

	function lowerOsExitIat(codeSlot VarSlot, slotIdx MachineWord, dstBlock IrBlock)
		var argSlots = VarSlotArray.create()
		argSlots.push(codeSlot)
		appendX64Op(target, block: dstBlock, op: X64Op.iatCall(nextTempSlot, slotIndex: slotIdx, argSlots: argSlots))
		nextTempSlot = nextTempSlot + 1
	end 'lowerOsExitIat'

	function lowerOsWrite(ptrId ValueId, lenId ValueId, dstBlock IrBlock)
		lowerOsWriteWithStrategy(ptrId: ptrId, lenId: lenId, strategy: osDesc.write, dstBlock: dstBlock)
	end 'lowerOsWrite'

	function lowerOsWriteSyscall(ptrSlot VarSlot, lenSlot VarSlot, writeNum MachineWord, fd MachineWord, dstBlock IrBlock)
		// fd constant -> temp slot (use physReg for the intermediate mov since
		// the syscall binary emitter uses hardcoded registers anyway)
		let fdSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.movRegImm(physReg(X64Register.rax), value: fd))
		appendX64Op(target, block: dstBlock, op: X64Op.movSlot(fdSlot, srcReg: physReg(X64Register.rax)))
		nextTempSlot = nextTempSlot + 1
		// syscall(writeNum, fd, ptr, len)
		var argSlots = VarSlotArray.create()
		argSlots.push(fdSlot)
		argSlots.push(ptrSlot)
		argSlots.push(lenSlot)
		let resultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.syscall(resultSlot, number: writeNum, argSlots: argSlots))
		nextTempSlot = nextTempSlot + 1
	end 'lowerOsWriteSyscall'

	function lowerOsWriteWinApi(ptrSlot VarSlot, lenSlot VarSlot, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord, dstBlock IrBlock)
		// GetStdHandle(handleConstant)
		let handleConstSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.movRegImm(physReg(X64Register.rax), value: handleConstant))
		appendX64Op(target, block: dstBlock, op: X64Op.movSlot(handleConstSlot, srcReg: physReg(X64Register.rax)))
		nextTempSlot = nextTempSlot + 1
		var getHandleArgs = VarSlotArray.create()
		getHandleArgs.push(handleConstSlot)
		let handleResultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.iatCall(handleResultSlot, slotIndex: getHandleSlot, argSlots: getHandleArgs))
		nextTempSlot = nextTempSlot + 1

		// bytesWritten = 0 stored to a slot
		let writtenSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.xorRegRegSelf(physReg(X64Register.rax)))
		appendX64Op(target, block: dstBlock, op: X64Op.movSlot(writtenSlot, srcReg: physReg(X64Register.rax)))
		nextTempSlot = nextTempSlot + 1

		// Get address of bytesWritten slot
		let writtenAddrSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.stackAddrOp(writtenAddrSlot, targetSlot: writtenSlot))
		nextTempSlot = nextTempSlot + 1

		// NULL for lpOverlapped
		let nullSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.xorRegRegSelf(physReg(X64Register.rax)))
		appendX64Op(target, block: dstBlock, op: X64Op.movSlot(nullSlot, srcReg: physReg(X64Register.rax)))
		nextTempSlot = nextTempSlot + 1

		// WriteFile(handle, ptr, len, &bytesWritten, NULL)
		var writeArgs = VarSlotArray.create()
		writeArgs.push(handleResultSlot)
		writeArgs.push(ptrSlot)
		writeArgs.push(lenSlot)
		writeArgs.push(writtenAddrSlot)
		writeArgs.push(nullSlot)
		let writeResultSlot = nextTempSlot
		appendX64Op(target, block: dstBlock, op: X64Op.iatCall(writeResultSlot, slotIndex: writeFileSlot, argSlots: writeArgs))
		nextTempSlot = nextTempSlot + 1
	end 'lowerOsWriteWinApi'

	function lowerOsWriteErr(ptrId ValueId, lenId ValueId, dstBlock IrBlock)
		lowerOsWriteWithStrategy(ptrId: ptrId, lenId: lenId, strategy: osDesc.writeErr, dstBlock: dstBlock)
	end 'lowerOsWriteErr'

	function lowerOsWriteWithStrategy(ptrId ValueId, lenId ValueId, strategy WriteStrategy, dstBlock IrBlock)
		let ptrSlot = ensureValueInSlot(valueId: ptrId, dstBlock: dstBlock)
		let lenSlot = ensureValueInSlot(valueId: lenId, dstBlock: dstBlock)
		match strategy 'dispatch'
			syscall(writeNum, fd) then lowerOsWriteSyscall(ptrSlot: ptrSlot, lenSlot: lenSlot, writeNum: writeNum, fd: fd, dstBlock: dstBlock)
			winApi(getHandleSlot, handleConstant, writeFileSlot) then lowerOsWriteWinApi(ptrSlot: ptrSlot, lenSlot: lenSlot, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot, dstBlock: dstBlock)
			libcall then panic("x64 does not support libcall write strategy")
		end 'dispatch'
	end 'lowerOsWriteWithStrategy'

	function lowerLoadFramePtr(resultId ValueId, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.movRegReg(X64VReg.virtual(resultId), srcReg: physReg(X64Register.rbp)))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	end 'lowerLoadFramePtr'

	function lowerFuncAddr(resultId ValueId, name String, dstBlock IrBlock)
		appendX64Op(target, block: dstBlock, op: X64Op.leaFuncAddr(X64VReg.virtual(resultId), funcName: name))
		valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	end 'lowerFuncAddr'

end 'X64FunctionLowering'

// ============================================================
// Module-level entry point (unchanged exported API)
// ============================================================

export function lowerMirToX64(module MirModule, target Target, globalData GlobalDataTable, stdlibFunctions ObjectFunctionArray) returns TargetModule
	logDebug(LogCategory.ir, message: () gives "Lowering Mid to X64 dialect")
	let osDesc = makeOsDescriptor(target)

	// Create the destination TargetModule.
	var targetModule = createTargetModule(CpuArch.x64)

	var lowering = X64FunctionLowering.create(module, target: targetModule, osDesc: osDesc, allFunctions: module.functions, globalData: globalData, stdlibFunctions: stdlibFunctions)
	for func in module.functions 'eachFunc'
		logTrace(LogCategory.ir, message: () gives "mid-to-x64: === lowering function: {func.name} ===")
		lowering.lowerFunction(func)
	end 'eachFunc'

	return targetModule
end 'lowerMirToX64'

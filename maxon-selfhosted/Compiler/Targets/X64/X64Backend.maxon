	helperStoreSlot(code, slotIndex: 51, src: X64Register.rcx)  // payload len
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 50, src: X64Register.rax)  // payload copy = 0 (empty payload → no copy/thread)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)  // jz stdin_done (empty payload)

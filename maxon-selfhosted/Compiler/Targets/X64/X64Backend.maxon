// X64 implementation of the TargetBackend interface.

// Mutable tracker for the current function's callee-saved registers
export type X64StackTracker
	export var calleeSavedGprs RegIntArray = RegIntArray.create()
	// Bytes reserved at the bottom of the frame for outgoing call args; the
	// prologue/epilogue use this to offset the callee-saved-reg save slots so
	// they don't collide with the outgoing-arg area.
	export var outgoingArgSize StackSize = 0

	export static function create() returns X64StackTracker
		return Self{}
	end 'create'
end 'X64StackTracker'

export type X64Backend implements TargetBackend
	var module MirModule
	var target Target
	var globalData GlobalDataTable
	var stdlibFunctions ObjectFunctionArray
	export var targetModule TargetModule = TargetModule.create(CpuArch.x64)

	export static function create(module MirModule, target Target, globalData GlobalDataTable, stdlibFunctions ObjectFunctionArray) returns Self
		return Self{module: module, target: target, globalData: globalData, stdlibFunctions: stdlibFunctions}
	end 'create'

	function lowerMirToTarget() returns TargetModule
		targetModule = lowerMirToX64(module, target: target, globalData: globalData, stdlibFunctions: stdlibFunctions)
		return targetModule
	end 'lowerMirToTarget'

	function lowerMirToTargetForFunctions(funcsToLower IrFunctionArray) returns TargetModule
		targetModule = lowerMirToX64Subset(module, funcsToLower: funcsToLower, target: target, globalData: globalData, stdlibFunctions: stdlibFunctions)
		return targetModule
	end 'lowerMirToTargetForFunctions'

	// Emit a single function into a FunctionCodeChunk with chunk-local fixup
	// offsets. The caller is responsible for prepending the chunk's bytes
	// into the final `.text` and shifting every chunk-local fixup by the
	// chunk's start offset (see `concatX64FunctionChunks`).
	//
	// Used by both the whole-module emit path (`emitTargetCode`, which loops
	// over `targetModule.functions` and concatenates the chunks) and the
	// chunk-driven incremental path, which calls this directly on a per-
	// function-cache miss — bypassing `queryCodeResult` keeps the chunk-
	// driven path from recursing through itself when `enableIncremental` is
	// on. Block-jump resolution is intra-function and call / rdata fixups
	// carry chunk-local offsets that the concat step rebases, so the
	// per-function emit produces byte-identical output to a single-pass
	// emission.
	function emitFunctionChunk(func IrFunction) returns FunctionCodeChunk
		var chunk = FunctionCodeChunk.create(func.name)
		chunk.code.reserve(256)

		var stackTracker = X64StackTracker.create()
		stackTracker.calleeSavedGprs = func.calleeSavedGprs
		stackTracker.outgoingArgSize = func.outgoingArgSize

		// Block offset table for this function (indexed by BlockId). Offsets
		// recorded here are chunk-local; block-jump fixups (also chunk-local)
		// resolve to chunk-local jump targets in one shot.
		var blockOffsets = CodeOffsetArray.create()
		for _ in 0 upto func.nextBlockId 'alloc'
			blockOffsets.push(0)
		end 'alloc'

		var blockFixups = BlockJumpFixupArray.create()

		for blockRef in func.blockRefs 'eachBlock'
			let block = try targetModule.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in targetModule.blocks")
			try blockOffsets.set(block.id, value: chunk.code.count()) otherwise panic("invariant: blockOffsets.set OOB")

			for packed in block.opRefs 'emitOps'
				emitPackedOp(packed, code: chunk.code, blockFixups: blockFixups, callFixups: chunk.callFixups, relocations: chunk.iatRelocs, rdataRelocs: chunk.rdataRelocs, tracker: stackTracker)
			end 'emitOps'

			if block.hasTerminatorOp() 'hasTerm'
				emitPackedOp(block.terminatorIndex(), code: chunk.code, blockFixups: blockFixups, callFixups: chunk.callFixups, relocations: chunk.iatRelocs, rdataRelocs: chunk.rdataRelocs, tracker: stackTracker)
			end 'hasTerm'
		end 'eachBlock'

		// Resolve intra-function block jumps using chunk-local offsets.
		resolveBlockFixups(chunk.code, blockOffsets: blockOffsets, blockFixups: blockFixups)
		return chunk
	end 'emitFunctionChunk'

	function emitTargetCode(project Project, stdlibCache StdlibCacheData) returns CodeResult
		logInfo(LogCategory.codegen, message: function() gives "X64: Emitting machine code from TargetModule ({targetToString(target)}), stdlib cache has {stdlibCache.functions.count()} functions")

		// `registerPanicStrings(globalData)` runs in the caller (`emitBackend` /
		// `emitBackendIncremental`) once per build so both the whole-module
		// emit and the chunk-driven path mutate `globalData` exactly once.
		// Calling it here would double-register when the chunk-driven path
		// dispatches whole-module via this helper as a fallback.

		// Emit each function into its own chunk. Iteration order matches
		// `targetModule.functions`; concatX64FunctionChunks lays chunks out
		// in that same order so `.text` byte layout is identical to a
		// single-pass whole-module emission.
		var chunks = FunctionCodeChunkArray.create()
		for func in targetModule.functions 'eachFunc'
			let chunk = emitFunctionChunk(func)
			// Stamp the freshly-emitted chunk into the per-function cache
			// here so the next same-`Project` rebuild can hit it without
			// re-running the whole-module emit. Shares `stampChunkMemo`
			// with the chunk-driven miss path so the keyHash recipe and
			// memo shape stay in lockstep across writers.
			if project.db.enableIncremental 'stamp'
				stampChunkMemo(project, funcName: func.name, chunk: chunk)
			end 'stamp'
			chunks.push(chunk)
		end 'eachFunc'

		return concatX64FunctionChunks(chunks, targetModule: targetModule, mirModule: module, globalData: globalData, stdlibCache: stdlibCache, os: target.os)
	end 'emitTargetCode'

	function scanOpForFrameInfo(packed OpIndex, state FrameScanState)
		let x64Op = try targetModule.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in targetModule.x64Ops")
		scanX64InstrForFrame(x64Op, state: state)
	end 'scanOpForFrameInfo'

	function detectCalleeSavedRegs(func IrFunction)
		x64DetectCalleeSavedRegs(targetModule, func: func)
	end 'detectCalleeSavedRegs'

	function calleeSaveAreaBytes(func IrFunction) returns StackSize
		return func.calleeSavedGprs.count() * 8
	end 'calleeSaveAreaBytes'

	function needsPrologue(adjustedStackSize StackSize, _ bool) returns bool
		return adjustedStackSize > 0
	end 'needsPrologue'

	function insertPrologueAtEntry(func IrFunction, block IrBlock, stackSize StackSize)
		x64InsertPrologueAtEntry(targetModule, func: func, block: block, stackSize: stackSize, os: target.os)
	end 'insertPrologueAtEntry'

	function insertEpilogueAtReturnBlock(block IrBlock)
		x64InsertEpilogueAtReturnBlock(targetModule, block: block)
	end 'insertEpilogueAtReturnBlock'

	function createOpQuery() returns TargetOpQuery
		return X64OpQuery.create()
	end 'createOpQuery'

	export static function createLatencyTable() returns TargetLatencyTable
		return TargetLatencyTable.create(1, intDivLatency: 40, fpDivLatency: 15, gprCount: 10, fpCount: 16, pressureThreshold: 8)
	end 'createLatencyTable'

	function emitPerFunction() returns ObjectFunctionArray
		var result = ObjectFunctionArray.create()
		var stackTracker = X64StackTracker.create()

		registerPanicStrings(globalData)

		for func in targetModule.functions 'eachFunc'
			var objFunc = ObjectFunction.create(func.name, returnType: func.returnType, paramCount: func.paramCount)
			objFunc.paramTypes = func.paramTypes
			var code = objFunc.code
			var callFixups = objFunc.callFixups
			var relocations = objFunc.relocations
			var rdataRelocs = objFunc.rdataRelocs

			stackTracker.calleeSavedGprs = func.calleeSavedGprs
			stackTracker.outgoingArgSize = func.outgoingArgSize

			var blockOffsets = CodeOffsetArray.create()
			for _ in 0 upto func.nextBlockId 'alloc'
				blockOffsets.push(0)
			end 'alloc'

			var blockFixups = BlockJumpFixupArray.create()

			for blockRef in func.blockRefs 'eachBlock'
				let block = try targetModule.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in targetModule.blocks")

				try blockOffsets.set(block.id, value: code.count()) otherwise panic("invariant: blockOffsets.set OOB")

				for packed in block.opRefs 'emitOps'
					emitPackedOp(packed, code: code, blockFixups: blockFixups, callFixups: callFixups, relocations: relocations, rdataRelocs: rdataRelocs, tracker: stackTracker)
				end 'emitOps'

				if block.hasTerminatorOp() 'hasTerm'
					emitPackedOp(block.terminatorIndex(), code: code, blockFixups: blockFixups, callFixups: callFixups, relocations: relocations, rdataRelocs: rdataRelocs, tracker: stackTracker)
				end 'hasTerm'
			end 'eachBlock'

			resolveBlockFixups(code, blockOffsets: blockOffsets, blockFixups: blockFixups)
			result.push(objFunc)
		end 'eachFunc'

		return result
	end 'emitPerFunction'

	// Emit bytes for a single x64 op by index.
	function emitPackedOp(packed OpIndex, code ByteArray, blockFixups BlockJumpFixupArray, callFixups CallFixupArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, tracker X64StackTracker)
		let x64Op = try targetModule.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in targetModule.x64Ops")
		emitX64Op(x64Op, code: code, blockFixups: blockFixups, callFixups: callFixups, relocations: relocations, rdataRelocs: rdataRelocs, tracker: tracker)
	end 'emitPackedOp'

	// Link pre-compiled stdlib functions into the x64 code output.
	// Uses shared reachability analysis, then appends code with x64-specific fixup adjustment.
	function linkX64StdlibFunctions(code ByteArray, labelNames StringArray, labelOffsets CodeOffsetArray, labelOffsetMap CodeLabelOffsetMap, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, relocations RelocationArray, stdlibCache StdlibCacheData)
		// Collect seed names from user call fixups
		var seeds = StringArray.create()
		for fixup in callFixups 'collectSeeds'
			seeds.push(fixup.targetName)
		end 'collectSeeds'

		// Phase 11.2/11.3: rdata-resident `funcAbs64InRdata` relocs reference
		// __layout_copy_*/destroy thunks and witness method-impls that are
		// reachable only through static rdata pointers — never via a `call`
		// op. Without seeding them as link-roots here, the PE writer panics
		// when the reloc target is missing from `.text`. The witness/layout
		// relocs live on `globalData.pendingRdataRelocs` until the post-link
		// merge below, so seed from both places to cover stdlib targets.
		appendFuncAbs64Seeds(seeds, relocs: rdataRelocs)
		appendFuncAbs64Seeds(seeds, relocs: globalData.pendingRdataRelocs)

		let needed = computeNeededStdlibFunctions(seeds, stdlibCache: stdlibCache)

		// Append each needed function's code and fixups
		for func in stdlibCache.functions 'linkFuncs'
			if not needed.contains(func.name) 'skip'
				continue
			end 'skip'

			let funcStart = code.count()
			logDebug(LogCategory.compiler, message: function() gives "  Linking '{func.name}': {func.code.count()} bytes at offset {funcStart}")

			labelNames.push(func.name)
			labelOffsets.push(funcStart)
			labelOffsetMap.upsert(func.name, value: funcStart)
			code.append(func.code)

			for fixup in func.callFixups 'adjustFixups'
				callFixups.push(CallFixup.create(funcStart + fixup.codeOffset, targetName: fixup.targetName))
			end 'adjustFixups'

			for reloc in func.rdataRelocs 'adjustRdata'
				rdataRelocs.push(RdataRelocation.create(funcStart + reloc.codeOffset, rdataLabel: reloc.rdataLabel, kind: reloc.kind))
			end 'adjustRdata'

			for reloc in func.relocations 'adjustRelocs'
				relocations.push(Relocation.create(funcStart + reloc.codeOffset, slotIndex: reloc.slotIndex))
			end 'adjustRelocs'
		end 'linkFuncs'

		mergeStdlibGlobalData(globalData, rdataRelocs: rdataRelocs, stdlibCache: stdlibCache)
		logInfo(LogCategory.compiler, message: function() gives "Linked {needed.count()} stdlib functions ({stdlibCache.functions.count()} available)")
	end 'linkX64StdlibFunctions'
end 'X64Backend'

// Concat path — lay each chunk's bytes into the final `.text`, rebase every
// chunk-local fixup to the chunk's absolute placement, then run the post-
// emit pipeline (stdlib link, symbol table, call-fixup resolve, rdata
// serialize). Iteration over `chunks` matches `targetModule.functions`
// order, preserving the byte layout a single-pass whole-module emit would
// produce.
//
// Inputs come pre-bundled so the same concat works whether chunks were
// emitted fresh by the whole-module `emitTargetCode` driver or pulled from
// the per-function query cache by `emitBackendIncrementalWith`. The same
// downstream rdata/IAT/symbol post-process applies — the only thing that
// changes between the two callers is where the chunks came from.
export function concatX64FunctionChunks(chunks FunctionCodeChunkArray, targetModule TargetModule, mirModule MirModule, globalData GlobalDataTable, stdlibCache StdlibCacheData, os Os) returns CodeResult
	var code = ByteArray.create()
	code.reserve(1024)
	var relocations = RelocationArray.create()
	var callFixups = CallFixupArray.create()
	var rdataRelocs = RdataRelocationArray.create()

	var funcLabelNames = StringArray.create()
	var funcLabelOffsets = CodeOffsetArray.create()
	var funcLabelOffsetMap = CodeLabelOffsetMap.create()

	for chunk in chunks 'eachChunk'
		let funcStart = code.count()
		recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: chunk.funcName, offset: funcStart)
		code.append(chunk.code)

		// Rewrite chunk-local fixup offsets to absolute `.text` offsets by
		// shifting each by the chunk's start position. CallFixup, IAT
		// Relocation, and RdataRelocation all share the same chunk-local
		// → absolute translation rule.
		for fx in chunk.callFixups 'rebaseCalls'
			callFixups.push(CallFixup.create(funcStart + fx.codeOffset, targetName: fx.targetName))
		end 'rebaseCalls'
		for r in chunk.iatRelocs 'rebaseIat'
			relocations.push(Relocation.create(funcStart + r.codeOffset, slotIndex: r.slotIndex))
		end 'rebaseIat'
		for r in chunk.rdataRelocs 'rebaseRdata'
			rdataRelocs.push(RdataRelocation.create(funcStart + r.codeOffset, rdataLabel: r.rdataLabel, kind: r.kind))
		end 'rebaseRdata'
	end 'eachChunk'

	// Link pre-compiled stdlib functions. Mirrors the old whole-module flow:
	// stdlib bodies append to `code` after all user/runtime chunks, and their
	// fixups arrive with already-shifted offsets via `linkX64StdlibFunctions`.
	// The link pass also pre-seeds `mrt_alloc` / `mm_decref` on Windows so
	// the soon-to-be-emitted hand-rolled `mrt_win32_*` helpers'
	// call fixups resolve against linked cache bodies. The cache-off path
	// gets the same names via `filterRuntimeByReachability`.
	if stdlibCache.functions.count() > 0 'hasStdlib'
		linkX64StdlibFunctionsConcat(code, labelNames: funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, callFixups: callFixups, rdataRelocs: rdataRelocs, relocations: relocations, globalData: globalData, stdlibCache: stdlibCache, os: os)
	end 'hasStdlib'

	// Phase B1: emit hand-rolled `mrt_win32_*` helpers AFTER the
	// stdlib cache is linked. Emitting them last keeps the byte layout
	// identical between cache-off and cache-on: in both paths the helpers
	// sit at the very tail of `.text`, immediately following the linked
	// stdlib (cache-on) or the inline-compiled runtime (cache-off).
	let isWindowsOs = match os 'check'
		windows gives true
		linux gives false
		macos gives false
		wasi gives false
	end 'check'

	if isWindowsOs 'emitHelpers'
		emitX64Win32Helpers(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	end 'emitHelpers'

	let symdata = buildSymbolTable(funcLabelNames, funcLabelOffsets: funcLabelOffsets)

	resolveCallFixups(code, labelOffsetMap: funcLabelOffsetMap, callFixups: callFixups)

	let startOffset = lookupLabel(funcLabelOffsetMap, name: "mrt_start")

	var rdataOffsetMap = RdataOffsetMap.create()
	let rdata = buildRdataSection(globalData, map: rdataOffsetMap)
	let covDataSectionBytes = buildCovDataSection(globalData, map: rdataOffsetMap)
	let dataPrelude = buildDataPreludeSection(globalData, map: rdataOffsetMap)
	rdataRelocs.append(globalData.pendingRdataRelocs)
	let resolvedRdataRelocs = resolveRdataRelocations(rdataRelocs, map: rdataOffsetMap)

	var result = CodeResult.create(code, mainCallFixupOffset: startOffset, relocations: relocations, globalData: globalData, targetModule: targetModule, mirModule: mirModule, rdata: rdata, rdataRelocations: resolvedRdataRelocs, symdata: symdata, covDataSectionBytes: covDataSectionBytes)
	result.dataPrelude = dataPrelude
	result.debugSymbols = buildDebugSymbols(funcLabelNames, labelOffsets: funcLabelOffsets)
	return result
end 'concatX64FunctionChunks'

// Free-function variant of `X64Backend.linkX64StdlibFunctions`. The method
// version is a member on the backend type so it can read `globalData` from
// the backend; the concat path doesn't have a backend instance handy, so we
// take `globalData` as an explicit parameter. Body is otherwise identical.
function linkX64StdlibFunctionsConcat(code ByteArray, labelNames StringArray, labelOffsets CodeOffsetArray, labelOffsetMap CodeLabelOffsetMap, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, relocations RelocationArray, globalData GlobalDataTable, stdlibCache StdlibCacheData, os Os)
	var seeds = StringArray.create()
	for fixup in callFixups 'collectSeeds'
		seeds.push(fixup.targetName)
	end 'collectSeeds'
	appendFuncAbs64Seeds(seeds, relocs: rdataRelocs)
	appendFuncAbs64Seeds(seeds, relocs: globalData.pendingRdataRelocs)

	// Phase B1: the hand-rolled `mrt_win32_*` helpers (emitted by
	// `emitX64Win32Helpers` after this link pass) reference `mrt_alloc` and
	// `mm_decref` via call fixups. Their fixups can't seed the link walk yet
	// (they're emitted after this pass), so we add the names here explicitly
	// on Windows targets — this matches the `filterRuntimeByReachability`
	// seed addition that pulls the same names into the cache-off pipeline.
	if os == Os.windows 'win32Helpers'
		seeds.push("mrt_alloc")
		seeds.push("mm_decref")
	end 'win32Helpers'

	let needed = computeNeededStdlibFunctions(seeds, stdlibCache: stdlibCache)

	for func in stdlibCache.functions 'linkFuncs'
		if not needed.contains(func.name) 'skip'
			continue
		end 'skip'

		let funcStart = code.count()
		logDebug(LogCategory.compiler, message: function() gives "  Linking '{func.name}': {func.code.count()} bytes at offset {funcStart}")

		labelNames.push(func.name)
		labelOffsets.push(funcStart)
		labelOffsetMap.upsert(func.name, value: funcStart)
		code.append(func.code)

		for fixup in func.callFixups 'adjustFixups'
			callFixups.push(CallFixup.create(funcStart + fixup.codeOffset, targetName: fixup.targetName))
		end 'adjustFixups'

		for reloc in func.rdataRelocs 'adjustRdata'
			rdataRelocs.push(RdataRelocation.create(funcStart + reloc.codeOffset, rdataLabel: reloc.rdataLabel, kind: reloc.kind))
		end 'adjustRdata'

		for reloc in func.relocations 'adjustRelocs'
			relocations.push(Relocation.create(funcStart + reloc.codeOffset, slotIndex: reloc.slotIndex))
		end 'adjustRelocs'
	end 'linkFuncs'

	mergeStdlibGlobalData(globalData, rdataRelocs: rdataRelocs, stdlibCache: stdlibCache)
	logInfo(LogCategory.compiler, message: function() gives "Linked {needed.count()} stdlib functions ({stdlibCache.functions.count()} available)")
end 'linkX64StdlibFunctionsConcat'

// Block jump fixup: records where a jump instruction needs its target patched.
export type BlockJumpFixup
	export var codeOffset CodeOffset
	export var targetBlockId BlockId

	export static function create(codeOffset CodeOffset, targetBlockId BlockId) returns BlockJumpFixup
		return Self{codeOffset: codeOffset, targetBlockId: targetBlockId}
	end 'create'
end 'BlockJumpFixup'

export typealias BlockJumpFixupArray = Array with BlockJumpFixup

// Maintains a name → code-offset hash alongside the `labelNames` /
// `labelOffsets` parallel arrays so label lookups during call-fixup
// resolution are O(1) instead of O(N) per call. The arrays still serve
// other consumers (logging, ordered traversal); the map is the lookup
// engine.
typealias CodeLabelOffsetMap = Map with (String, CodeOffset)

function recordLabel(labelNames StringArray, labelOffsets CodeOffsetArray, labelOffsetMap CodeLabelOffsetMap, name String, offset CodeOffset)
	logTrace(LogCategory.codegen, message: function() gives "Label '{name}' at code offset {offset}")
	labelNames.push(name)
	labelOffsets.push(offset)
	labelOffsetMap.upsert(name, value: offset)
end 'recordLabel'

function lookupLabel(labelOffsetMap CodeLabelOffsetMap, name String) returns CodeOffset
	let offset = try labelOffsetMap.get(name) otherwise 'missing'
		logError(LogCategory.codegen, message: function() gives "Unresolved label '{name}' -- call will jump to offset 0")
		return 0
	end 'missing'
	return offset
end 'lookupLabel'

function resolveCallFixups(code ByteArray, labelOffsetMap CodeLabelOffsetMap, callFixups CallFixupArray)
	logTrace(LogCategory.codegen, message: function() gives "Resolving {callFixups.count()} call fixups")
	for fixup in callFixups 'resolve'
		let targetOffset = lookupLabel(labelOffsetMap, name: fixup.targetName)
		let callEnd = fixup.codeOffset + 4
		let rel = targetOffset - callEnd
		patchDword(code, offset: fixup.codeOffset, value: rel)
	end 'resolve'
end 'resolveCallFixups'

function resolveBlockFixups(code ByteArray, blockOffsets CodeOffsetArray, blockFixups BlockJumpFixupArray)
	for fixup in blockFixups 'resolve'
		// Sentinel: unrecorded block returns 0 — produces a visibly-wrong jump that diagnostics surface.
		let targetOffset = try blockOffsets.get(fixup.targetBlockId) otherwise 0
		let jumpEnd = fixup.codeOffset + 4
		let rel = targetOffset - jumpEnd
		patchDword(code, offset: fixup.codeOffset, value: rel)
	end 'resolve'
end 'resolveBlockFixups'

// 3-bit register code (low 3 bits of register number)
function regCode(reg X64Register) returns MachineWord
	return match reg 'code'
		rax gives 0
		rcx gives 1
		rdx gives 2
		rbx gives 3
		rsp gives 4
		rbp gives 5
		rsi gives 6
		rdi gives 7
		r8 gives 0
		r9 gives 1
		r10 gives 2
		r11 gives 3
		r12 gives 4
		r13 gives 5
		r14 gives 6
		r15 gives 7
	end 'code'
end 'regCode'

// True for extended registers (R8-R15) that need REX.B or REX.R
function isExtended(reg X64Register) returns bool
	return match reg 'ext'
		rax to rdi gives false
		r8 to r15 gives true
	end 'ext'
end 'isExtended'

// Emit REX.W prefix with optional R and B bits for extended registers
// regField = register in ModRM reg field; rmField = register in ModRM r/m field
function emitRexWPrefix(code ByteArray, regField X64Register, rmField X64Register)
	var rex = 0x48
	if isExtended(regField) 'rBit'
		rex = rex or 0x04
	end 'rBit'
	if isExtended(rmField) 'bBit'
		rex = rex or 0x01
	end 'bBit'
	code.push(rex)
end 'emitRexWPrefix'

// Emit REX.W prefix for single-register ops (register in r/m field)
function emitRexWSingle(code ByteArray, rmField X64Register)
	var rex = 0x48
	if isExtended(rmField) 'bBit'
		rex = rex or 0x01
	end 'bBit'
	code.push(rex)
end 'emitRexWSingle'

// Emit ModRM byte: mod=11 (register), reg field, r/m field
function emitModRMReg(code ByteArray, regField X64Register, rmField X64Register)
	let regBits = regCode(regField)
	let rmBits = regCode(rmField)
	let modrm = 0xC0 or (regBits shl 3) or rmBits
	code.push(modrm)
end 'emitModRMReg'

// Emit ModRM byte with a fixed opcode extension in the reg field
function emitModRMExt(code ByteArray, ext MachineWord, rmField X64Register)
	let rmBits = regCode(rmField)
	let modrm = 0xC0 or (ext shl 3) or rmBits
	code.push(modrm)
end 'emitModRMExt'

// --- Emitters for register-allocator ops ---

function emitMovRegRegOp(code ByteArray, dest X64Register, src X64Register)
	// mov dest, src  =>  REX.W 89 ModRM(src -> dest)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x89)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitMovRegRegOp'

function emitCmpRegRegOp(code ByteArray, lhs X64Register, rhs X64Register)
	// cmp lhs, rhs  =>  REX.W 39 ModRM(rhs -> lhs)
	// CMP r/m64, r64: opcode 0x39, reg=rhs, r/m=lhs
	emitRexWPrefix(code, regField: rhs, rmField: lhs)
	code.push(0x39)
	emitModRMReg(code, regField: rhs, rmField: lhs)
end 'emitCmpRegRegOp'

function emitCmpRegImmOp(code ByteArray, lhs X64Register, value MachineWord)
	// cmp lhs, imm8   =>  REX.W 83 ModRM(/7, lhs) imm8
	// cmp lhs, imm32  =>  REX.W 81 ModRM(/7, lhs) imm32
	emitRexWSingle(code, rmField: lhs)
	if value <= i8.max 'imm8'
		code.push(0x83)
		emitModRMExt(code, ext: 7, rmField: lhs)
		code.push(value and 0xFF)
	end 'imm8' else 'imm32'
		code.push(0x81)
		emitModRMExt(code, ext: 7, rmField: lhs)
		writeDword(code, value: value)
	end 'imm32'
end 'emitCmpRegImmOp'

function emitTestRegRegOp(code ByteArray, reg1 X64Register, reg2 X64Register)
	// test reg1, reg2  =>  REX.W 85 ModRM(reg2 -> reg1)
	emitRexWPrefix(code, regField: reg2, rmField: reg1)
	code.push(0x85)
	emitModRMReg(code, regField: reg2, rmField: reg1)
end 'emitTestRegRegOp'

function emitCqoOp(code ByteArray)
	// cqo  =>  48 99
	code.append(b"\x48\x99")
end 'emitCqoOp'

function emitIdivRegOp(code ByteArray, divisor X64Register)
	// idiv divisor  =>  REX.W F7 ModRM(/7, divisor)
	emitRexWSingle(code, rmField: divisor)
	code.push(0xF7)
	emitModRMExt(code, ext: 7, rmField: divisor)
end 'emitIdivRegOp'

function emitXorRegRegSelfOp(code ByteArray, reg X64Register)
	// xor e_reg, e_reg  =>  [REX] 31 ModRM(reg, reg)
	// Use 32-bit operand size (no REX.W): writing a 32-bit register implicitly
	// zero-extends to 64 bits, and saves a byte for non-extended registers.
	if isExtended(reg) 'needsRex'
		// REX prefix with R and B bits but no W bit
		code.push(0x45)
	end 'needsRex'
	code.push(0x31)
	emitModRMReg(code, regField: reg, rmField: reg)
end 'emitXorRegRegSelfOp'

function emitCallIndirectOp(code ByteArray, reg X64Register)
	// call reg  =>  REX FF /2 ModRM(reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xFF)
	emitModRMExt(code, ext: 2, rmField: reg)
end 'emitCallIndirectOp'

function emitXchgRegRegOp(code ByteArray, reg1 X64Register, reg2 X64Register)
	// xchg reg1, reg2  =>  REX.W 87 ModRM(reg1, reg2)
	emitRexWPrefix(code, regField: reg1, rmField: reg2)
	code.push(0x87)
	emitModRMReg(code, regField: reg1, rmField: reg2)
end 'emitXchgRegRegOp'

// --- XMM emission helpers ---

function xmmRegCode(reg X64XmmRegister) returns MachineWord
	return reg.rawValue
end 'xmmRegCode'

// MOVSD xmm1, xmm2: F2 0F 10 ModRM (reg, reg)
// MOVSS xmm1, xmm2: F3 0F 10 ModRM (reg, reg)
function emitMovXmmXmmOp(code ByteArray, dest X64XmmRegister, src X64XmmRegister, precision FloatPrecision)
	let destC = xmmRegCode(dest)
	let srcC = xmmRegCode(src)
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	if destC >= 8 or srcC >= 8 'needRex'
		var rex = 0x40
		if destC >= 8 'rexR'
			rex = rex or 0x04
		end 'rexR'
		if srcC >= 8 'rexB'
			rex = rex or 0x01
		end 'rexB'
		code.push(rex)
	end 'needRex'
	code.push(0x0F)
	code.push(0x10)
	let modrm = 0xC0 or ((destC and 7) shl 3) or (srcC and 7)
	code.push(modrm)
end 'emitMovXmmXmmOp'

// MOVSD [rbp+disp], xmm: F2 0F 11 ModRM
function emitSpillXmmToStackOp(code ByteArray, offset MachineWord, src X64XmmRegister, precision FloatPrecision)
	let srcC = xmmRegCode(src)
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	if srcC >= 8 'needRex'
		code.push(0x44)
	end 'needRex'
	code.push(0x0F)
	code.push(0x11)
	let signedOffset = offset
	if signedOffset >= i8.min and signedOffset <= i8.max 'disp8'
		let modrm = 0x45 or ((srcC and 7) shl 3)
		code.push(modrm)
		code.push(signedOffset and 0xFF)
	end 'disp8' else 'disp32'
		let modrm = 0x85 or ((srcC and 7) shl 3)
		code.push(modrm)
		writeDword(code, value: signedOffset)
	end 'disp32'
end 'emitSpillXmmToStackOp'

// MOVSD xmm, [rbp+disp]: F2 0F 10 ModRM
function emitReloadXmmFromStackOp(code ByteArray, dest X64XmmRegister, offset MachineWord, precision FloatPrecision)
	let destC = xmmRegCode(dest)
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	if destC >= 8 'needRex'
		code.push(0x44)
	end 'needRex'
	code.push(0x0F)
	code.push(0x10)
	let signedOffset = offset
	if signedOffset >= i8.min and signedOffset <= i8.max 'disp8'
		let modrm = 0x45 or ((destC and 7) shl 3)
		code.push(modrm)
		code.push(signedOffset and 0xFF)
	end 'disp8' else 'disp32'
		let modrm = 0x85 or ((destC and 7) shl 3)
		code.push(modrm)
		writeDword(code, value: signedOffset)
	end 'disp32'
end 'emitReloadXmmFromStackOp'

// Emit optional REX prefix for XMM instructions when high registers are used.
// rexBase 0x48 forces REX.W (64-bit operand), 0x40 emits REX only for high registers.
function emitXmmRexIfNeeded(code ByteArray, regFieldCode MachineWord, rmFieldCode MachineWord, rexBase MachineWord)
	let needsHighReg = regFieldCode >= 8 or rmFieldCode >= 8
	let needsRexW = rexBase >= 0x48
	if needsHighReg or needsRexW 'needRex'
		var rex = rexBase
		if regFieldCode >= 8 'rexR'
			rex = rex or 0x04
		end 'rexR'
		if rmFieldCode >= 8 'rexB'
			rex = rex or 0x01
		end 'rexB'
		code.push(rex)
	end 'needRex'
end 'emitXmmRexIfNeeded'

// Emit 0F + opcode + ModRM(reg, rm) suffix shared by all SSE2 register-register ops
function emitXmmOpModRM(code ByteArray, opcode Byte, regFieldCode MachineWord, rmFieldCode MachineWord)
	code.push(0x0F)
	code.push(opcode)
	let modrm = 0xC0 or ((regFieldCode and 7) shl 3) or (rmFieldCode and 7)
	code.push(modrm)
end 'emitXmmOpModRM'

// SSE2 binary op: prefix + [REX] + 0F + opcode + ModRM (xmm, xmm)
function emitXmmBinaryOp(code ByteArray, dest X64XmmRegister, src X64XmmRegister, precision FloatPrecision, opcode Byte)
	let destC = xmmRegCode(dest)
	let srcC = xmmRegCode(src)
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	emitXmmRexIfNeeded(code, regFieldCode: destC, rmFieldCode: srcC, rexBase: 0x40)
	emitXmmOpModRM(code, opcode: opcode, regFieldCode: destC, rmFieldCode: srcC)
end 'emitXmmBinaryOp'

// UCOMISD/UCOMISS: compare two XMM registers and set flags
function emitUcomisXmmOp(code ByteArray, src1 X64XmmRegister, src2 X64XmmRegister, precision FloatPrecision)
	let src1C = xmmRegCode(src1)
	let src2C = xmmRegCode(src2)
	match precision 'pre'
		f64 then code.push(0x66)
		f32 then break 'pre'
	end 'pre'
	emitXmmRexIfNeeded(code, regFieldCode: src1C, rmFieldCode: src2C, rexBase: 0x40)
	emitXmmOpModRM(code, opcode: 0x2E, regFieldCode: src1C, rmFieldCode: src2C)
end 'emitUcomisXmmOp'

// CVTSI2SD/CVTSI2SS: convert 64-bit integer GPR to XMM float
function emitCvtSi2FloatOp(code ByteArray, dest X64XmmRegister, src X64Register, precision FloatPrecision)
	let destC = xmmRegCode(dest)
	let srcC = regCode(src)
	// GPR src needs full code (3-bit + extended flag) so emitXmmRexIfNeeded
	// can set REX.B for r8-r15. regCode by itself returns just the low 3 bits,
	// which collides with rax/rcx/etc and silently emits the wrong source.
	var srcFull = srcC
	if isExtended(src) 'extSrc'
		srcFull = srcC + 8
	end 'extSrc'
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	emitXmmRexIfNeeded(code, regFieldCode: destC, rmFieldCode: srcFull, rexBase: 0x48)
	emitXmmOpModRM(code, opcode: 0x2A, regFieldCode: destC, rmFieldCode: srcC)
end 'emitCvtSi2FloatOp'

// CVTTSD2SI/CVTTSS2SI: truncate XMM float to 64-bit integer GPR
function emitCvttFloat2SiOp(code ByteArray, dest X64Register, src X64XmmRegister, precision FloatPrecision)
	let destC = regCode(dest)
	let srcC = xmmRegCode(src)
	// GPR dest needs full code (3-bit + extended flag) for REX.R detection
	var destFull = destC
	if isExtended(dest) 'extDest'
		destFull = destC + 8
	end 'extDest'
	match precision 'pre'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'pre'
	emitXmmRexIfNeeded(code, regFieldCode: destFull, rmFieldCode: srcC, rexBase: 0x48)
	emitXmmOpModRM(code, opcode: 0x2C, regFieldCode: destC, rmFieldCode: srcC)
end 'emitCvttFloat2SiOp'

// --- End XMM emission helpers ---

// Spill: mov [rbp+offset], srcReg (offset is negative for spill slots)
function emitSpillToStackOp(code ByteArray, offset MachineWord, srcReg X64Register)
	let srcCode = regCode(srcReg)
	let signedOffset = offset
	if signedOffset >= i8.min and signedOffset <= i8.max 'disp8'
		emitRexWPrefix(code, regField: srcReg, rmField: X64Register.rbp)
		code.push(0x89)
		let modrm = 0x45 or (srcCode shl 3)
		code.push(modrm)
		code.push(signedOffset and 0xFF)
	end 'disp8' else 'disp32'
		emitRexWPrefix(code, regField: srcReg, rmField: X64Register.rbp)
		code.push(0x89)
		let modrm = 0x85 or (srcCode shl 3)
		code.push(modrm)
		writeDword(code, value: signedOffset)
	end 'disp32'
end 'emitSpillToStackOp'

// Reload: mov destReg, [rbp+offset] (offset is negative for spill slots)
function emitReloadFromStackOp(code ByteArray, dest X64Register, offset MachineWord)
	let destCode = regCode(dest)
	let signedOffset = offset
	if signedOffset >= i8.min and signedOffset <= i8.max 'disp8'
		emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
		code.push(0x8B)
		let modrm = 0x45 or (destCode shl 3)
		code.push(modrm)
		code.push(signedOffset and 0xFF)
	end 'disp8' else 'disp32'
		emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
		code.push(0x8B)
		let modrm = 0x85 or (destCode shl 3)
		code.push(modrm)
		writeDword(code, value: signedOffset)
	end 'disp32'
end 'emitReloadFromStackOp'

// movRegImm for arbitrary destination register (not just rax). Callers must
// canonicalize value=0 into xorRegRegSelf via appendIntImmToReg before
// constructing the X64 op — this encoder picks the smallest mov form for the
// remaining (nonzero) value range.
function emitMovRegImmGeneric(code ByteArray, dest X64Register, value MachineWord)
	if value >= i32.min and value <= i32.max 'small'
		// mov r/m64, imm32 (sign-extended)  =>  REX.W C7 ModRM(/0, dest) + imm32
		emitRexWSingle(code, rmField: dest)
		code.push(0xC7)
		emitModRMExt(code, ext: 0, rmField: dest)
		writeDword(code, value: value)
	end 'small' else 'large'
		// mov reg, imm64  =>  REX.W B8+rd <qword>
		var rex = 0x48
		if isExtended(dest) 'extBit'
			rex = rex or 0x01
		end 'extBit'
		code.push(rex)
		let destCode = regCode(dest)
		code.push(0xB8 + destCode)
		writeQword(code, value: value)
	end 'large'
end 'emitMovRegImmGeneric'

// mov r32, imm32: writing to a 32-bit register zero-extends to 64 bits.
// 5 bytes for base regs, 6 bytes for extended regs (vs 10 for mov r64, imm64).
function emitMovRegImm32(code ByteArray, dest X64Register, value MachineWord)
	let destCode = regCode(dest)
	if isExtended(dest) 'extBit'
		code.push(0x41)
	end 'extBit'
	code.push(0xB8 + destCode)
	writeDword(code, value: value)
end 'emitMovRegImm32'

// --- Upgraded emitters for register-parameterized existing ops ---

function emitAddRegRegParam(code ByteArray, dest X64Register, src X64Register)
	// add dest, src  =>  REX.W 01 ModRM(src -> dest)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x01)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitAddRegRegParam'

function emitSubRegRegParam(code ByteArray, dest X64Register, src X64Register)
	// sub dest, src  =>  REX.W 29 ModRM(src -> dest)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x29)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitSubRegRegParam'

function emitAddRegImmParam(code ByteArray, dest X64Register, value MachineWord)
	// add dest, imm8   =>  REX.W 83 ModRM(/0, dest) imm8
	// add dest, imm32  =>  REX.W 81 ModRM(/0, dest) imm32
	emitRexWSingle(code, rmField: dest)
	if value <= i8.max 'imm8'
		code.push(0x83)
		emitModRMExt(code, ext: 0, rmField: dest)
		code.push(value and 0xFF)
	end 'imm8' else 'imm32'
		code.push(0x81)
		emitModRMExt(code, ext: 0, rmField: dest)
		writeDword(code, value: value)
	end 'imm32'
end 'emitAddRegImmParam'

function emitSubRegImmParam(code ByteArray, dest X64Register, value MachineWord)
	// sub dest, imm8   =>  REX.W 83 ModRM(/5, dest) imm8
	// sub dest, imm32  =>  REX.W 81 ModRM(/5, dest) imm32
	emitRexWSingle(code, rmField: dest)
	if value <= i8.max 'imm8'
		code.push(0x83)
		emitModRMExt(code, ext: 5, rmField: dest)
		code.push(value and 0xFF)
	end 'imm8' else 'imm32'
		code.push(0x81)
		emitModRMExt(code, ext: 5, rmField: dest)
		writeDword(code, value: value)
	end 'imm32'
end 'emitSubRegImmParam'

function emitImulRegRegParam(code ByteArray, dest X64Register, src X64Register)
	// imul dest, src  =>  REX.W 0F AF ModRM(dest -> src)
	emitRexWPrefix(code, regField: dest, rmField: src)
	code.push(0x0F)
	code.push(0xAF)
	emitModRMReg(code, regField: dest, rmField: src)
end 'emitImulRegRegParam'

// Phase 2 dialect groundwork: `op dest, [base+disp]` for ADD/SUB/AND/OR/XOR/CMP.
// All five share REX.W + opcode + ModRM/disp encoding; only the opcode differs.
// The ModRM reg field is `dest` (or `lhs` for CMP), r/m is `baseReg`. The shared
// emitMemDisp helper handles disp8 vs disp32 and rsp/r12 SIB requirements (and
// the rbp/r13 disp0 quirk where mod=01 disp8=0 is required).
function emitRegMemAluOp(code ByteArray, dest X64Register, baseReg X64Register, offset MachineWord, opcode MachineWord)
	emitRexWPrefix(code, regField: dest, rmField: baseReg)
	code.push(opcode)
	emitMemDisp(code, regField: dest, baseReg: baseReg, offset: offset)
end 'emitRegMemAluOp'

// `imul dest, [base+disp]` is a two-byte opcode (0F AF) but otherwise mirrors
// emitRegMemAluOp.
function emitImulRegMemOp(code ByteArray, dest X64Register, baseReg X64Register, offset MachineWord)
	emitRexWPrefix(code, regField: dest, rmField: baseReg)
	code.push(0x0F)
	code.push(0xAF)
	emitMemDisp(code, regField: dest, baseReg: baseReg, offset: offset)
end 'emitImulRegMemOp'

// Phase 2 dialect groundwork: `op dest, imm` for AND/OR/XOR (add/sub/cmp already
// have dedicated emitters). The shared REX.W + 81/83 /ext encoding picks the
// shortest immediate that fits — 8-bit imm via opcode 83 + sign-extension when
// it fits in i8, otherwise 32-bit imm via opcode 81. `ext` selects the operation
// via ModRM /ext slot: AND=4, OR=1, XOR=6.
function emitAluRegImmParam(code ByteArray, dest X64Register, value MachineWord, ext MachineWord)
	emitRexWSingle(code, rmField: dest)
	// Use the sign-extending imm8 form when the value fits. We must also exclude
	// the range (i8.max, u8.max] because raw u8 values like 0xFF would encode
	// as -1 sign-extended — fine for AND/OR/XOR on 64-bit registers in most
	// cases but ambiguous when callers pass small unsigned masks. Match the
	// existing emitAddRegImmParam convention (use imm8 only when value <= i8.max).
	if value <= i8.max 'imm8'
		code.push(0x83)
		emitModRMExt(code, ext: ext, rmField: dest)
		code.push(value and 0xFF)
	end 'imm8' else 'imm32'
		code.push(0x81)
		emitModRMExt(code, ext: ext, rmField: dest)
		writeDword(code, value: value)
	end 'imm32'
end 'emitAluRegImmParam'

// Three-operand `imul dest, src, imm` => REX.W 6B/69 ModRM(dest, src) imm.
// 6B is the imm8 form, 69 is the imm32 form. Unlike the two-operand imul which
// writes a 16-bit result, this form yields the low 64 bits in dest.
function emitImulRegImmOp(code ByteArray, dest X64Register, src X64Register, value MachineWord)
	emitRexWPrefix(code, regField: dest, rmField: src)
	if value >= i8.min and value <= i8.max 'imm8'
		code.push(0x6B)
		emitModRMReg(code, regField: dest, rmField: src)
		code.push(value and 0xFF)
	end 'imm8' else 'imm32'
		code.push(0x69)
		emitModRMReg(code, regField: dest, rmField: src)
		writeDword(code, value: value)
	end 'imm32'
end 'emitImulRegImmOp'

function emitNegRegParam(code ByteArray, reg X64Register)
	// neg reg  =>  REX.W F7 ModRM(/3, reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xF7)
	emitModRMExt(code, ext: 3, rmField: reg)
end 'emitNegRegParam'

function emitBitNotRegParam(code ByteArray, reg X64Register)
	// not reg  =>  REX.W F7 ModRM(/2, reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xF7)
	emitModRMExt(code, ext: 2, rmField: reg)
end 'emitBitNotRegParam'

function emitAndRegRegParam(code ByteArray, dest X64Register, src X64Register)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x21)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitAndRegRegParam'

function emitOrRegRegParam(code ByteArray, dest X64Register, src X64Register)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x09)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitOrRegRegParam'

function emitXorRegRegParam(code ByteArray, dest X64Register, src X64Register)
	emitRexWPrefix(code, regField: src, rmField: dest)
	code.push(0x31)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitXorRegRegParam'

function emitShlRegClParam(code ByteArray, reg X64Register)
	// shl reg, cl  =>  REX.W D3 ModRM(/4, reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xD3)
	emitModRMExt(code, ext: 4, rmField: reg)
end 'emitShlRegClParam'

function emitSarRegClParam(code ByteArray, reg X64Register)
	// sar reg, cl  =>  REX.W D3 ModRM(/7, reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xD3)
	emitModRMExt(code, ext: 7, rmField: reg)
end 'emitSarRegClParam'

function emitShrRegClParam(code ByteArray, reg X64Register)
	// shr reg, cl  =>  REX.W D3 ModRM(/5, reg)
	emitRexWSingle(code, rmField: reg)
	code.push(0xD3)
	emitModRMExt(code, ext: 5, rmField: reg)
end 'emitShrRegClParam'

// --- Byte emission helpers (identical to X86CodeEmitter) ---

function emitPrologue(code ByteArray, stackSize StackSize, calleeSavedGprs RegIntArray, outgoingArgSize StackSize)
	// push rbp; mov rbp, rsp
	code.append(b"\x55\x48\x89\xe5")
	// sub rsp, stackSize (only if non-zero)
	// stackSize already includes space for callee-saved registers + outgoing
	// stack args; layout from low addresses up is:
	//   [rsp + 0 .. outgoingArgSize)              outgoing call args
	//   [rsp + outgoingArgSize .. + savedRegs*8)  callee-saved registers
	//   ...                                       spills (regalloc)
	//   ...                                       local var slots
	//   [rbp - 8] ↑                                first local
	if stackSize > 0 and stackSize <= i8.max 'smallSub'
		code.append(b"\x48\x83\xec")
		code.push(stackSize and 0xFF)
	end 'smallSub' else if stackSize > 127 'largeSub'
		code.append(b"\x48\x81\xec")
		writeDword(code, value: stackSize)
	end 'largeSub'
	// Save callee-saved registers immediately above the outgoing-arg block.
	// Storing them above the outgoing-arg area (rather than at [rsp+0]) keeps
	// the outgoing-arg writes a single `mov [rsp+offset], reg` per arg with no
	// frame-pointer-relative addressing.
	var csi = 0
	while csi < calleeSavedGprs.count() 'saveCalleeSaved'
		let regOrd = try calleeSavedGprs.get(csi) otherwise 'skipSave'
			csi = csi + 1
			continue
		end 'skipSave'
		emitMovToRspOffset(code, regOrd: regOrd, offset: outgoingArgSize + csi * 8)
		csi = csi + 1
	end 'saveCalleeSaved'
end 'emitPrologue'

function emitEpilogue(code ByteArray, calleeSavedGprs RegIntArray, outgoingArgSize StackSize)
	// Restore callee-saved registers from above the outgoing-arg block, mirror
	// of emitPrologue. The teardown follows: `mov rsp, rbp; pop rbp` peels both
	// the locals/spills/calleeSaved area and the outgoing-arg area in one shot.
	var csi = 0
	while csi < calleeSavedGprs.count() 'restoreCalleeSaved'
		let regOrd = try calleeSavedGprs.get(csi) otherwise 'skipRestore'
			csi = csi + 1
			continue
		end 'skipRestore'
		emitMovFromRspOffset(code, regOrd: regOrd, offset: outgoingArgSize + csi * 8)
		csi = csi + 1
	end 'restoreCalleeSaved'
	// mov rsp, rbp; pop rbp
	code.append(b"\x48\x89\xec\x5d")
end 'emitEpilogue'

// Emit mov [rsp+offset], reg
function emitMovToRspOffset(code ByteArray, regOrd RegInt, offset RegInt)
	if regOrd >= 8 'extended'
		code.push(0x4C)
	end 'extended' else 'base'
		code.push(0x48)
	end 'base'
	code.push(0x89)
	let regField = regOrd mod 8
	if offset == 0 'noDisp'
		code.push((regField shl 3) or 4)
		code.push(0x24)
	end 'noDisp' else if offset > 0 and offset <= 127 'disp8'
		code.push((1 shl 6) or (regField shl 3) or 4)
		code.push(0x24)
		code.push(offset and 0xFF)
	end 'disp8' else 'disp32'
		code.push((2 shl 6) or (regField shl 3) or 4)
		code.push(0x24)
		writeDword(code, value: offset)
	end 'disp32'
end 'emitMovToRspOffset'

// Emit mov reg, [rsp+offset]
function emitMovFromRspOffset(code ByteArray, regOrd RegInt, offset RegInt)
	if regOrd >= 8 'extended'
		code.push(0x4C)
	end 'extended' else 'base'
		code.push(0x48)
	end 'base'
	code.push(0x8B)
	let regField = regOrd mod 8
	if offset == 0 'noDisp'
		code.push((regField shl 3) or 4)
		code.push(0x24)
	end 'noDisp' else if offset > 0 and offset <= 127 'disp8'
		code.push((1 shl 6) or (regField shl 3) or 4)
		code.push(0x24)
		code.push(offset and 0xFF)
	end 'disp8' else 'disp32'
		code.push((2 shl 6) or (regField shl 3) or 4)
		code.push(0x24)
		writeDword(code, value: offset)
	end 'disp32'
end 'emitMovFromRspOffset'

function emitRet(code ByteArray)
	code.push(0xC3)
end 'emitRet'

function emitMovRegImm(code ByteArray, value MachineWord)
	// Use 32-bit sign-extended form if value fits in signed 32-bit range
	if value >= i32.min and value <= i32.max 'small'
		// mov rax, imm32 (sign-extended)  =>  48 C7 C0 <dword>
		code.append(b"\x48\xc7\xc0")
		writeDword(code, value: value)
	end 'small' else 'large'
		// mov rax, imm64  =>  48 B8 <qword>
		code.append(b"\x48\xb8")
		writeQword(code, value: value)
	end 'large'
end 'emitMovRegImm'

// Store a register to a stack slot: mov [rbp - offset], srcReg
// Uses disp8 (mod=01) for offsets <= 128, disp32 (mod=10) for larger.
function emitMovSlot(code ByteArray, slotIndex VarSlot, srcReg X64Register)
	let offset = (slotIndex + 1) * 8
	let negOffset = 0 - offset
	if offset <= 128 'useDisp8'
		match srcReg 'pickReg8'
			rax then code.append(b"\x48\x89\x45")
			rcx then code.append(b"\x48\x89\x4d")
			rdx then code.append(b"\x48\x89\x55")
			rbx then code.append(b"\x48\x89\x5d")
			rsp then code.append(b"\x48\x89\x65")
			rbp then code.append(b"\x48\x89\x6d")
			rsi then code.append(b"\x48\x89\x75")
			rdi then code.append(b"\x48\x89\x7d")
			r8 then code.append(b"\x4c\x89\x45")
			r9 then code.append(b"\x4c\x89\x4d")
			r10 then code.append(b"\x4c\x89\x55")
			r11 then code.append(b"\x4c\x89\x5d")
			r12 then code.append(b"\x4c\x89\x65")
			r13 then code.append(b"\x4c\x89\x6d")
			r14 then code.append(b"\x4c\x89\x75")
			r15 then code.append(b"\x4c\x89\x7d")
		end 'pickReg8'
		code.push(negOffset and 0xFF)
	end 'useDisp8' else 'useDisp32'
		match srcReg 'pickReg32'
			rax then code.append(b"\x48\x89\x85")
			rcx then code.append(b"\x48\x89\x8d")
			rdx then code.append(b"\x48\x89\x95")
			rbx then code.append(b"\x48\x89\x9d")
			rsp then code.append(b"\x48\x89\xa5")
			rbp then code.append(b"\x48\x89\xad")
			rsi then code.append(b"\x48\x89\xb5")
			rdi then code.append(b"\x48\x89\xbd")
			r8 then code.append(b"\x4c\x89\x85")
			r9 then code.append(b"\x4c\x89\x8d")
			r10 then code.append(b"\x4c\x89\x95")
			r11 then code.append(b"\x4c\x89\x9d")
			r12 then code.append(b"\x4c\x89\xa5")
			r13 then code.append(b"\x4c\x89\xad")
			r14 then code.append(b"\x4c\x89\xb5")
			r15 then code.append(b"\x4c\x89\xbd")
		end 'pickReg32'
		writeDword(code, value: negOffset)
	end 'useDisp32'
end 'emitMovSlot'

// Load stack slot to a register: mov REG, [rbp - (slotIndex+1)*8]
// Uses disp8 (mod=01) for offsets <= 128, disp32 (mod=10) for larger.
function emitLoadSlotToReg(code ByteArray, slotIndex VarSlot, dest X64Register)
	let offset = (slotIndex + 1) * 8
	let negOffset = 0 - offset
	if offset <= 128 'useDisp8'
		match dest 'pickReg8'
			rax then code.append(b"\x48\x8b\x45")
			rcx then code.append(b"\x48\x8b\x4d")
			rdx then code.append(b"\x48\x8b\x55")
			rbx then code.append(b"\x48\x8b\x5d")
			rsp then code.append(b"\x48\x8b\x65")
			rbp then code.append(b"\x48\x8b\x6d")
			rsi then code.append(b"\x48\x8b\x75")
			rdi then code.append(b"\x48\x8b\x7d")
			r8 then code.append(b"\x4c\x8b\x45")
			r9 then code.append(b"\x4c\x8b\x4d")
			r10 then code.append(b"\x4c\x8b\x55")
			r11 then code.append(b"\x4c\x8b\x5d")
			r12 then code.append(b"\x4c\x8b\x65")
			r13 then code.append(b"\x4c\x8b\x6d")
			r14 then code.append(b"\x4c\x8b\x75")
			r15 then code.append(b"\x4c\x8b\x7d")
		end 'pickReg8'
		code.push(negOffset and 0xFF)
	end 'useDisp8' else 'useDisp32'
		match dest 'pickReg32'
			rax then code.append(b"\x48\x8b\x85")
			rcx then code.append(b"\x48\x8b\x8d")
			rdx then code.append(b"\x48\x8b\x95")
			rbx then code.append(b"\x48\x8b\x9d")
			rsp then code.append(b"\x48\x8b\xa5")
			rbp then code.append(b"\x48\x8b\xad")
			rsi then code.append(b"\x48\x8b\xb5")
			rdi then code.append(b"\x48\x8b\xbd")
			r8 then code.append(b"\x4c\x8b\x85")
			r9 then code.append(b"\x4c\x8b\x8d")
			r10 then code.append(b"\x4c\x8b\x95")
			r11 then code.append(b"\x4c\x8b\x9d")
			r12 then code.append(b"\x4c\x8b\xa5")
			r13 then code.append(b"\x4c\x8b\xad")
			r14 then code.append(b"\x4c\x8b\xb5")
			r15 then code.append(b"\x4c\x8b\xbd")
		end 'pickReg32'
		writeDword(code, value: negOffset)
	end 'useDisp32'
end 'emitLoadSlotToReg'

function emitAddRegReg(code ByteArray)
	// add rax, rcx  =>  48 01 C8
	code.append(b"\x48\x01\xc8")
end 'emitAddRegReg'

function emitSubRegReg(code ByteArray)
	// sub rax, rcx  =>  48 29 C8  (rax = rax - rcx)
	code.append(b"\x48\x29\xc8")
end 'emitSubRegReg'

function emitImulRegReg(code ByteArray)
	// imul rax, rcx  =>  48 0F AF C1
	code.append(b"\x48\x0f\xaf\xc1")
end 'emitImulRegReg'

// CQO + IDIV RCX: sign-extend RAX into RDX:RAX, then divide. Quotient in RAX.
function emitIdivRcx(code ByteArray)
	// cqo  =>  48 99
	// idiv rcx  =>  48 F7 F9
	code.append(b"\x48\x99\x48\xf7\xf9")
end 'emitIdivRcx'

// CQO + IDIV RCX + MOV RAX,RDX: same as idiv but moves remainder to RAX.
function emitIremRcx(code ByteArray)
	// cqo; idiv rcx; mov rax, rdx
	code.append(b"\x48\x99\x48\xf7\xf9\x48\x89\xd0")
end 'emitIremRcx'

function emitNegReg(code ByteArray)
	// neg rax  =>  48 F7 D8
	code.append(b"\x48\xf7\xd8")
end 'emitNegReg'

function emitBitNotReg(code ByteArray)
	// not rax  =>  48 F7 D0
	code.append(b"\x48\xf7\xd0")
end 'emitBitNotReg'

function emitAndRegReg(code ByteArray)
	// and rax, rcx  =>  48 21 C8
	code.append(b"\x48\x21\xc8")
end 'emitAndRegReg'

function emitOrRegReg(code ByteArray)
	// or rax, rcx  =>  48 09 C8
	code.append(b"\x48\x09\xc8")
end 'emitOrRegReg'

function emitXorRegReg(code ByteArray)
	// xor rax, rcx  =>  48 31 C8
	code.append(b"\x48\x31\xc8")
end 'emitXorRegReg'

function emitShlRegCl(code ByteArray)
	// shl rax, cl  =>  48 D3 E0
	code.append(b"\x48\xd3\xe0")
end 'emitShlRegCl'

function emitSarRegCl(code ByteArray)
	// sar rax, cl  =>  48 D3 F8
	code.append(b"\x48\xd3\xf8")
end 'emitSarRegCl'

// cmp rax, rcx (sets flags based on rax - rcx)
function emitCmpRaxRcx(code ByteArray)
	// cmp rax, rcx  =>  48 39 C8
	code.append(b"\x48\x39\xc8")
end 'emitCmpRaxRcx'

function emitTestRaxRax(code ByteArray)
	// test rax, rax  =>  48 85 C0  (sets ZF if rax == 0)
	code.append(b"\x48\x85\xc0")
end 'emitTestRaxRax'

// ucomisd xmm0, xmm1 (compare float in xmm0 vs xmm1)
function emitUcomisd(code ByteArray)
	// movq xmm0, rcx; movq xmm1, rax; ucomisd xmm0, xmm1
	code.append(b"\x66\x48\x0f\x6e\xc1\x66\x48\x0f\x6e\xc8\x66\x0f\x2e\xc1")
end 'emitUcomisd'

typealias CondJumpOpcode = int(0x80 to 0x8F)

// Emit a 2-byte conditional jump (0F xx) with rel32 placeholder, record block fixup.
function emitCondJumpBlock(code ByteArray, blockFixups BlockJumpFixupArray, opcode CondJumpOpcode, targetBlock BlockId)
	code.push(0x0F)
	code.push(opcode)
	blockFixups.push(BlockJumpFixup.create(code.count(), targetBlockId: targetBlock))
	writeDword(code, value: 0)
end 'emitCondJumpBlock'

// Emit unconditional jump with rel32 placeholder, record block fixup.
function emitJmpBlock(code ByteArray, blockFixups BlockJumpFixupArray, targetBlock BlockId)
	// jmp rel32  =>  E9 <rel32>
	code.push(0xE9)
	blockFixups.push(BlockJumpFixup.create(code.count(), targetBlockId: targetBlock))
	writeDword(code, value: 0)
end 'emitJmpBlock'

// Emit a relative call: call <rel32>
function emitRelativeCall(code ByteArray, targetOffset CodeOffset)
	code.push(0xE8)
	let callEnd = code.count() + 4
	let rel = targetOffset - callEnd
	code.push(rel and 0xFF)
	code.push((rel shr 8) and 0xFF)
	code.push((rel shr 16) and 0xFF)
	code.push((rel shr 24) and 0xFF)
end 'emitRelativeCall'

// --- Runtime Stubs (OS-neutral) ---

// mrt_i64_to_string(value_in_rcx, buffer_in_rdx) -> length in RAX
function emitI64ToString(code ByteArray) returns CodeOffset
	let offset = code.count()

	// Prologue: push rbp; mov rbp, rsp; sub rsp, 0x30
	// Save args: [rbp-8] = rcx, [rbp-16] = rdx
	// test rcx, rcx; jnz not_zero
	// Zero case: mov byte[rdx]='0'; mov byte[rdx+1]=0; mov r8,1; jmp epilogue
	code.append(b"\x55\x48\x89\xe5\x48\x83\xec\x30\x48\x89\x4d\xf8\x48\x89\x55\xf0\x48\x85\xc9\x75\x13\xc6\x02\x30\xc6\x42\x01\x00\x49\xc7\xc0\x01\x00\x00\x00\xe9")
	let jmpToEpilogueFixup1 = code.count()
	writeDword(code, value: 0)

	// Zero is_negative; test rcx; jns positive
	// neg rcx; save; mov rax,1; save flag
	code.append(b"\x48\xc7\x45\xe8\x00\x00\x00\x00\x48\x85\xc9\x79\x12\x48\xf7\xd9\x48\x89\x4d\xf8\x48\xc7\xc0\x01\x00\x00\x00\x48\x89\x45\xe8")

	// positive: mov r9, rdx; add r9, 20; mov byte [r9], 0
	code.append(b"\x49\x89\xd1\x49\x83\xc1\x14\x41\xc6\x01\x00")

	// digit_loop:
	let digitLoopOffset = code.count()

	// dec r9; mov rax,[rbp-8]; mov rcx,10; xor rdx,rdx; div rcx
	// mov [rbp-8],rax; add rdx,0x30; mov byte [r9],dl; cmp qword [rbp-8],0
	code.append(b"\x49\xff\xc9\x48\x8b\x45\xf8\x48\xc7\xc1\x0a\x00\x00\x00\x48\x31\xd2\x48\xf7\xf1\x48\x89\x45\xf8\x48\x83\xc2\x30\x41\x88\x11\x48\x83\x7d\xf8\x00")
	// jnz digit_loop
	code.push(0x75)
	let jnzTarget = digitLoopOffset - (code.count() + 1)
	code.push(jnzTarget and 0xFF)

	// Check is_negative; jz no_sign; dec r9; mov byte [r9], '-'
	// Compute length = (buffer+20) - r9; save length
	// Copy: mov rsi,r9; mov rdi,[rbp-16]; mov rcx,[rbp-24]; rep movsb
	// Return length in r8
	code.append(b"\x48\x8b\x45\xe8\x48\x85\xc0\x74\x07\x49\xff\xc9\x41\xc6\x01\x2d\x48\x8b\x45\xf0\x48\x83\xc0\x14\x4c\x29\xc8\x48\x89\x45\xe8\x4c\x89\xce\x48\x8b\x7d\xf0\x48\x8b\x4d\xe8\xf3\xa4\x4c\x8b\x45\xe8")

	// epilogue label (patch jump from zero case)
	let epilogueOffset = code.count()
	let jmpRel = epilogueOffset - (jmpToEpilogueFixup1 + 4)
	patchDword(code, offset: jmpToEpilogueFixup1, value: jmpRel)

	// Epilogue: mov rsp, rbp; pop rbp; ret
	code.append(b"\x48\x89\xec\x5d\xc3")

	return offset
end 'emitI64ToString'

// --- OS-parameterized stubs ---

// Emit mrt_start: optional shadow space, call main, then exit via OsDescriptor strategy
function emitX64Start(code ByteArray, osDesc OsDescriptor, relocations RelocationArray, callFixups CallFixupArray) returns CodeOffset
	// Shadow space (Windows x64 ABI requires it)
	if osDesc.startShadowSpace > 0 'hasShadow'
		// sub rsp, shadowSpace
		code.append(b"\x48\x83\xec")
		code.push(osDesc.startShadowSpace and 0xFF)
	end 'hasShadow'

	// call main (relative call, patched by label resolution)
	code.push(0xE8)
	let mainCallFixupOffset = code.count()
	let mainName = "main"
	callFixups.push(CallFixup.create(mainCallFixupOffset, targetName: mainName))
	code.append(b"\x00\x00\x00\x00")

	// Exit using the OS-specified strategy
	match osDesc.exit 'exitStrategy'
		syscall(num) then emitX64ExitSyscall(code, syscallNumber: num)
		iatCall(slotIdx) then emitX64ExitIat(code, relocations: relocations, slotIndex: slotIdx)
	end 'exitStrategy'

	// int3 (unreachable)
	code.push(0xCC)
	return mainCallFixupOffset
end 'emitX64Start'

// Exit via syscall (Linux): mov edi, r8d; mov eax, N; syscall
function emitX64ExitSyscall(code ByteArray, syscallNumber MachineWord)
	// mov edi, r8d; mov eax, syscallNumber
	code.append(b"\x44\x89\xc7\xb8")
	writeDword(code, value: syscallNumber)
	// syscall
	code.append(b"\x0f\x05")
end 'emitX64ExitSyscall'

// Exit via IAT (Windows): mov ecx, r8d; call [rip+disp32]
function emitX64ExitIat(code ByteArray, relocations RelocationArray, slotIndex MachineWord)
	// mov ecx, r8d; call [rip+disp32]
	code.append(b"\x44\x89\xc1\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: slotIndex))
	code.append(b"\x00\x00\x00\x00")
end 'emitX64ExitIat'

// Emit mrt_write_stdout stub parameterized by OsDescriptor
function emitX64WriteStdout(code ByteArray, osDesc OsDescriptor, relocations RelocationArray) returns CodeOffset
	let offset = code.count()
	match osDesc.write 'writeStrategy'
		syscall(writeNum, fd) then emitX64WriteStdoutSyscall(code, writeNumber: writeNum, fd: fd)
		winApi(getHandleSlot, handleConstant, writeFileSlot) then emitX64WriteStdoutWinApi(code, relocations: relocations, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot)
		libcall then panic("x64 does not support libcall write strategy")
	end 'writeStrategy'
	return offset
end 'emitX64WriteStdout'

// mrt_write_stdout via syscall (Linux): args in rcx=ptr, rdx=len
function emitX64WriteStdoutSyscall(code ByteArray, writeNumber MachineWord, fd MachineWord)
	// Prologue; mov rsi, rcx; mov edi, fd
	code.append(b"\x55\x48\x89\xe5\x48\x89\xce\xbf")
	writeDword(code, value: fd)
	// mov eax, writeNumber; syscall; epilogue
	code.push(0xB8)
	writeDword(code, value: writeNumber)
	code.append(b"\x0f\x05\x5d\xc3")
end 'emitX64WriteStdoutSyscall'

// mrt_write_stdout via Win32 API (GetStdHandle + WriteFile through IAT)
function emitX64WriteStdoutWinApi(code ByteArray, relocations RelocationArray, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
	// Prologue; save args; zero bytesWritten; mov ecx, handleConstant
	code.append(b"\x55\x48\x89\xe5\x48\x83\xec\x40\x48\x89\x4d\xf8\x48\x89\x55\xf0\x48\xc7\x45\xe0\x00\x00\x00\x00\x48\xc7\xc1")
	writeDword(code, value: handleConstant)

	// call [rip+disp32] GetStdHandle
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: getHandleSlot))
	writeDword(code, value: 0)

	// Save handle; load WriteFile args; mov qword [rsp+0x20], 0
	code.append(b"\x48\x89\x45\xe8\x48\x8b\x4d\xe8\x48\x8b\x55\xf8\x4c\x8b\x45\xf0\x4c\x8d\x4d\xe0\x48\xc7\x44\x24\x20\x00\x00\x00\x00")

	// call [rip+disp32] WriteFile
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: writeFileSlot))
	writeDword(code, value: 0)

	// Epilogue: mov rsp, rbp; pop rbp; ret
	code.append(b"\x48\x89\xec\x5d\xc3")
end 'emitX64WriteStdoutWinApi'

// Emit mrt_read_stdin stub parameterized by OsDescriptor. The Maxon-source
// `mrt_read_stdin` body in runtime.std already routes through `std osRead` and
// the regular MIR lowering pipeline; this hand-emitter mirrors the parallel
// `emitX64WriteStdout` stubs above so a future caller (or build mode that
// bypasses the runtime.std body) can splice in the OS-specific code directly.
// Signature matches mrt_read_stdin(ptr len) returns bytes-read; callers pass
// ptr in rcx and len in rdx, result in rax.
function emitX64ReadStdin(code ByteArray, osDesc OsDescriptor, relocations RelocationArray) returns CodeOffset
	let offset = code.count()
	match osDesc.read 'readStrategy'
		syscall(readNum, fd) then emitX64ReadStdinSyscall(code, readNumber: readNum, fd: fd)
		winApi(getHandleSlot, handleConstant, readFileSlot) then emitX64ReadStdinWinApi(code, relocations: relocations, getHandleSlot: getHandleSlot, handleConstant: handleConstant, readFileSlot: readFileSlot)
		libcall then panic("x64 does not support libcall read strategy")
	end 'readStrategy'
	return offset
end 'emitX64ReadStdin'

// mrt_read_stdin via syscall (Linux): args in rcx=ptr, rdx=len
function emitX64ReadStdinSyscall(code ByteArray, readNumber MachineWord, fd MachineWord)
	// Prologue (push rbp; mov rbp, rsp); mov rsi, rcx; mov edi, fd
	code.append(b"\x55\x48\x89\xe5\x48\x89\xce\xbf")
	writeDword(code, value: fd)
	// mov eax, readNumber; syscall; epilogue (pop rbp; ret)
	code.push(0xB8)
	writeDword(code, value: readNumber)
	code.append(b"\x0f\x05\x5d\xc3")
end 'emitX64ReadStdinSyscall'

// mrt_read_stdin via Win32 API (GetStdHandle(STD_INPUT_HANDLE) + ReadFile through IAT).
// Stack frame matches the WriteFile stub: [rbp-0x08]=savedPtr, [rbp-0x10]=savedLen,
// [rbp-0x18]=handle, [rbp-0x20]=bytesRead (out param). Returns bytesRead in rax.
function emitX64ReadStdinWinApi(code ByteArray, relocations RelocationArray, getHandleSlot MachineWord, handleConstant MachineWord, readFileSlot MachineWord)
	// Prologue; save args; zero bytesRead; mov ecx, handleConstant (STD_INPUT_HANDLE)
	code.append(b"\x55\x48\x89\xe5\x48\x83\xec\x40\x48\x89\x4d\xf8\x48\x89\x55\xf0\x48\xc7\x45\xe0\x00\x00\x00\x00\x48\xc7\xc1")
	writeDword(code, value: handleConstant)

	// call [rip+disp32] GetStdHandle
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: getHandleSlot))
	writeDword(code, value: 0)

	// Save handle (rax → [rbp-0x18]); load ReadFile args; mov qword [rsp+0x20], 0 (lpOverlapped=NULL)
	// rcx=hFile (handle), rdx=lpBuffer (saved ptr), r8=nNumberOfBytesToRead (saved len),
	// r9=lpNumberOfBytesRead (lea r9, [rbp-0x20]), [rsp+0x20]=lpOverlapped=NULL
	code.append(b"\x48\x89\x45\xe8\x48\x8b\x4d\xe8\x48\x8b\x55\xf8\x4c\x8b\x45\xf0\x4c\x8d\x4d\xe0\x48\xc7\x44\x24\x20\x00\x00\x00\x00")

	// call [rip+disp32] ReadFile
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: readFileSlot))
	writeDword(code, value: 0)

	// Discard ReadFile's BOOL return; load bytesRead into rax. mov rax, [rbp-0x20]
	code.append(b"\x48\x8b\x45\xe0")

	// Epilogue: mov rsp, rbp; pop rbp; ret
	code.append(b"\x48\x89\xec\x5d\xc3")
end 'emitX64ReadStdinWinApi'

// --- Stack argument passing helpers ---

function emitSubRspImm(code ByteArray, value StackSize)
	if value <= i8.max 'small'
		// sub rsp, imm8
		code.append(b"\x48\x83\xec")
		code.push(value and 0xFF)
	end 'small' else 'large'
		// sub rsp, imm32
		code.append(b"\x48\x81\xec")
		writeDword(code, value: value)
	end 'large'
end 'emitSubRspImm'

function emitAddRspImm(code ByteArray, value StackSize)
	if value <= i8.max 'small'
		// add rsp, imm8
		code.append(b"\x48\x83\xc4")
		code.push(value and 0xFF)
	end 'small' else 'large'
		// add rsp, imm32
		code.append(b"\x48\x81\xc4")
		writeDword(code, value: value)
	end 'large'
end 'emitAddRspImm'

// mov [rsp+offset], srcReg
function emitMovRspOffsetReg(code ByteArray, offset StackSize, srcReg X64Register)
	// REX + 0x89 + ModR/M(mod=01, reg=source, rm=100/SIB) + SIB(ss=00,idx=100/none,base=100/rsp) + disp8
	let disp = offset and 0xFF
	match srcReg 'pickReg'
		rax then code.append(b"\x48\x89\x44\x24")
		rcx then code.append(b"\x48\x89\x4c\x24")
		rdx then code.append(b"\x48\x89\x54\x24")
		rbx then code.append(b"\x48\x89\x5c\x24")
		rsp then code.append(b"\x48\x89\x64\x24")
		rbp then code.append(b"\x48\x89\x6c\x24")
		rsi then code.append(b"\x48\x89\x74\x24")
		rdi then code.append(b"\x48\x89\x7c\x24")
		r8 then code.append(b"\x4c\x89\x44\x24")
		r9 then code.append(b"\x4c\x89\x4c\x24")
		r10 then code.append(b"\x4c\x89\x54\x24")
		r11 then code.append(b"\x4c\x89\x5c\x24")
		r12 then code.append(b"\x4c\x89\x64\x24")
		r13 then code.append(b"\x4c\x89\x6c\x24")
		r14 then code.append(b"\x4c\x89\x74\x24")
		r15 then code.append(b"\x4c\x89\x7c\x24")
	end 'pickReg'
	code.push(disp)
end 'emitMovRspOffsetReg'

// mov destReg, [rbp+offset] (positive offset, for loading caller-passed stack args)
function emitLoadRegRbpOffset(code ByteArray, destReg X64Register, offset StackSize)
	let disp = offset and 0xFF
	match destReg 'pickReg'
		rax then code.append(b"\x48\x8b\x45")
		rcx then code.append(b"\x48\x8b\x4d")
		rdx then code.append(b"\x48\x8b\x55")
		rbx then code.append(b"\x48\x8b\x5d")
		rsp then code.append(b"\x48\x8b\x65")
		rbp then code.append(b"\x48\x8b\x6d")
		rsi then code.append(b"\x48\x8b\x75")
		rdi then code.append(b"\x48\x8b\x7d")
		r8 then code.append(b"\x4c\x8b\x45")
		r9 then code.append(b"\x4c\x8b\x4d")
		r10 then code.append(b"\x4c\x8b\x55")
		r11 then code.append(b"\x4c\x8b\x5d")
		r12 then code.append(b"\x4c\x8b\x65")
		r13 then code.append(b"\x4c\x8b\x6d")
		r14 then code.append(b"\x4c\x8b\x75")
		r15 then code.append(b"\x4c\x8b\x7d")
	end 'pickReg'
	code.push(disp)
end 'emitLoadRegRbpOffset'

// --- Call fixup resolution (inter-function) ---

// Emit call rel32 placeholder -- resolved after all functions are emitted.
function emitCallFixup(code ByteArray, callFixups CallFixupArray, target String)
	logTrace(LogCategory.codegen, message: function() gives "Call fixup to '{target}' at offset {code.count()}")
	code.push(0xE8)
	let fixupOffset = code.count()
	callFixups.push(CallFixup.create(fixupOffset, targetName: target))
	code.append(b"\x00\x00\x00\x00")
end 'emitCallFixup'

function resolveGpr(vreg X64VReg) returns X64Register
	var result = X64Register.rax
	match vreg 'resolve'
		physical(reg) then result = reg
		virtual(id) then panic("x64 emitter: unresolved virtual GPR v{id}")
	end 'resolve'
	return result
end 'resolveGpr'

function resolveFp(vreg X64FpVReg) returns X64XmmRegister
	var result = X64XmmRegister.xmm0
	match vreg 'resolve'
		physical(reg) then result = reg
		virtual(id) then panic("x64 emitter: unresolved virtual FP vf{id}")
	end 'resolve'
	return result
end 'resolveFp'

// --- Setcc: set byte based on condition code ---
function emitSetccOp(code ByteArray, dest X64Register, condition X64SetccCondition)
	// setcc dest: 0F 9x ModRM(/0, dest) sets low byte
	// Then movzx r64, r8 to zero-extend
	let condByte = match condition 'map'
		e gives 0x94
		ne gives 0x95
		g gives 0x9F
		ge gives 0x9D
		l gives 0x9C
		le gives 0x9E
		a gives 0x97
		ae gives 0x93
		b gives 0x92
		be gives 0x96
		p gives 0x9A
		np gives 0x9B
	end 'map'
	// REX prefix needed for extended regs (r8-r11) and to access sil/dil/spl/bpl
	if isExtended(dest) 'extRex'
		code.push(0x41)
	end 'extRex' else 'baseRex'
		// Need REX.40 for rsi/rdi/rsp/rbp to get sil/dil/spl/bpl instead of dh/bh/ah/ch
		let destBits = regCode(dest)
		if destBits >= 4 'needsRex'
			code.push(0x40)
		end 'needsRex'
	end 'baseRex'
	code.push(0x0F)
	code.push(condByte)
	emitModRMExt(code, ext: 0, rmField: dest)
	// movzx r64, r8: REX.W 0F B6 ModRM (zero-extend byte to qword)
	emitRexWPrefix(code, regField: dest, rmField: dest)
	code.push(0x0F)
	code.push(0xB6)
	emitModRMReg(code, regField: dest, rmField: dest)
end 'emitSetccOp'

// --- Cmov: conditional move ---
function emitCmovOp(code ByteArray, dest X64Register, src X64Register, condition X64CmovCondition)
	// cmovcc dest, src: REX.W 0F 4x ModRM(src -> dest)
	let condByte = match condition 'map'
		e gives 0x44
		ne gives 0x45
		g gives 0x4F
		ge gives 0x4D
		l gives 0x4C
		le gives 0x4E
		a gives 0x47
		ae gives 0x43
		b gives 0x42
		be gives 0x46
	end 'map'
	emitRexWPrefix(code, regField: dest, rmField: src)
	code.push(0x0F)
	code.push(condByte)
	emitModRMReg(code, regField: dest, rmField: src)
end 'emitCmovOp'

// --- Store indirect: mov [base+offset], src ---
// Each arm emits its width-specific prefixes and opcode here, then a single
// shared `emitMemDisp` writes the ModRM + displacement (and SIB if needed).
function emitStoreIndirectOp(code ByteArray, baseReg X64Register, offset MachineWord, srcReg X64Register, width StoreWidth)
	match width 'w'
		qword then emitStoreIndirectQword(code, baseReg: baseReg, srcReg: srcReg)
		word then emitStoreIndirectWord(code, baseReg: baseReg, srcReg: srcReg)
		halfword then emitStoreIndirectHalfword(code, baseReg: baseReg, srcReg: srcReg)
		byte then emitStoreIndirectByte(code, baseReg: baseReg, srcReg: srcReg)
	end 'w'
	emitMemDisp(code, regField: srcReg, baseReg: baseReg, offset: offset)
end 'emitStoreIndirectOp'

// REX.W + `mov [base], src` opcode (no ModRM/disp — those come from the
// shared `emitMemDisp` call in the caller).
function emitStoreIndirectQword(code ByteArray, baseReg X64Register, srcReg X64Register)
	emitRexWPrefix(code, regField: srcReg, rmField: baseReg)
	code.push(0x89)
end 'emitStoreIndirectQword'

// `mov [base], src32`: `89 /r`. No REX.W (operand size is 32). Emit a plain
// REX only if base or src is an extended register; the upper 32 bits of the
// source are simply ignored by the store, so no operand-size prefix is needed.
function emitStoreIndirectWord(code ByteArray, baseReg X64Register, srcReg X64Register)
	emitRexNoWIfNeeded(code, regField: srcReg, rmField: baseReg)
	code.push(0x89)
end 'emitStoreIndirectWord'

// `mov [base], src16`: `66 89 /r`. The 0x66 operand-size prefix selects
// 16-bit operand. A plain REX may follow for extended regs.
function emitStoreIndirectHalfword(code ByteArray, baseReg X64Register, srcReg X64Register)
	code.push(0x66)
	emitRexNoWIfNeeded(code, regField: srcReg, rmField: baseReg)
	code.push(0x89)
end 'emitStoreIndirectHalfword'

// `mov [base], src8`: `88 /r`. Byte stores must emit a REX prefix whenever
// the source is one of rsp/rbp/rsi/rdi (so the byte register decodes as
// SPL/BPL/SIL/DIL instead of AH/CH/DH/BH) OR when either src or base is in
// r8..r15. For rax..rdx the AL/CL/DL/BL encoding is fine without REX.
function emitStoreIndirectByte(code ByteArray, baseReg X64Register, srcReg X64Register)
	emitRexNoWForByteOp(code, regField: srcReg, rmField: baseReg)
	code.push(0x88)
end 'emitStoreIndirectByte'

// --- Load indirect (XMM): movsd/movss xmm, [base+offset] ---
// Encoding: F2/F3 [REX] 0F 10 ModRM disp
// REX.R is set when xmm dest is XMM8..15; REX.B when base is R8..15.
// No REX.W — operand size is implicit in the F2/F3 prefix.
function emitLoadIndirectXmmOp(code ByteArray, destReg X64XmmRegister, baseReg X64Register, offset MachineWord, precision FloatPrecision)
	match precision 'prec'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'prec'
	let destC = xmmRegCode(destReg)
	emitXmmMemRexIfNeeded(code, regFieldCode: destC, baseReg: baseReg)
	code.push(0x0F)
	code.push(0x10)
	emitXmmMemDisp(code, regFieldCode: destC, baseReg: baseReg, offset: offset)
end 'emitLoadIndirectXmmOp'

// --- Store indirect (XMM): movsd/movss [base+offset], xmm ---
// Same encoding shape as the load with opcode 0x11 instead of 0x10.
function emitStoreIndirectXmmOp(code ByteArray, baseReg X64Register, offset MachineWord, srcReg X64XmmRegister, precision FloatPrecision)
	match precision 'prec'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'prec'
	let srcC = xmmRegCode(srcReg)
	emitXmmMemRexIfNeeded(code, regFieldCode: srcC, baseReg: baseReg)
	code.push(0x0F)
	code.push(0x11)
	emitXmmMemDisp(code, regFieldCode: srcC, baseReg: baseReg, offset: offset)
end 'emitStoreIndirectXmmOp'

// REX prefix for the XMM-with-GP-base mem ops above. The reg field carries
// an XMM (extended bit by `regFieldCode >= 8`); the r/m field carries a GP
// register whose extended-ness comes from `isExtended(baseReg)`.
function emitXmmMemRexIfNeeded(code ByteArray, regFieldCode MachineWord, baseReg X64Register)
	let needRexR = regFieldCode >= 8
	let needRexB = isExtended(baseReg)
	if needRexR or needRexB 'needRex'
		var rex = 0x40
		if needRexR 'rBit'
			rex = rex or 0x04
		end 'rBit'
		if needRexB 'bBit'
			rex = rex or 0x01
		end 'bBit'
		code.push(rex)
	end 'needRex'
end 'emitXmmMemRexIfNeeded'

// ModRM + displacement for XMM mem ops. Mirrors `emitMemDisp` but takes
// the reg-field as a numeric XMM code (0..15); the high bit was already
// pushed via REX.R in `emitXmmMemRexIfNeeded`, so only the low 3 bits go
// into ModRM here.
function emitXmmMemDisp(code ByteArray, regFieldCode MachineWord, baseReg X64Register, offset MachineWord)
	emitMemDispBits(code, regBits: regFieldCode and 7, baseReg: baseReg, offset: offset)
end 'emitXmmMemDisp'

// --- Load indirect: mov dest, [base+offset] ---
// Each arm emits its width-specific prefixes and opcode here, then a single
// shared `emitMemDisp` writes the ModRM + displacement (and SIB if needed).
// `signed` selects between sign- and zero-extending forms for the narrow
// widths; for qword it's unused (a full-width load doesn't extend).
function emitLoadIndirectOp(code ByteArray, destReg X64Register, baseReg X64Register, offset MachineWord, width StoreWidth, signed bool)
	match width 'w'
		qword then emitLoadIndirectQword(code, destReg: destReg, baseReg: baseReg)
		word then emitLoadIndirectWord(code, destReg: destReg, baseReg: baseReg, signed: signed)
		halfword then emitLoadIndirectHalfword(code, destReg: destReg, baseReg: baseReg, signed: signed)
		byte then emitLoadIndirectByte(code, destReg: destReg, baseReg: baseReg, signed: signed)
	end 'w'
	emitMemDisp(code, regField: destReg, baseReg: baseReg, offset: offset)
end 'emitLoadIndirectOp'

// REX.W + `mov dest, [base]` opcode (ModRM/disp emitted by the caller's
// `emitMemDisp`).
function emitLoadIndirectQword(code ByteArray, destReg X64Register, baseReg X64Register)
	emitRexWPrefix(code, regField: destReg, rmField: baseReg)
	code.push(0x8B)
end 'emitLoadIndirectQword'

// 32-bit load. Signed form uses MOVSXD (REX.W + 63 /r). Unsigned form uses
// `MOV r32, r/m32` (8B /r) without REX.W; the implicit zero-extension of a
// 32-bit write covers the upper 32 bits of the 64-bit register.
function emitLoadIndirectWord(code ByteArray, destReg X64Register, baseReg X64Register, signed bool)
	if signed 'signed'
		emitRexWPrefix(code, regField: destReg, rmField: baseReg)
		code.push(0x63)
	end 'signed' else 'unsigned'
		emitRexNoWIfNeeded(code, regField: destReg, rmField: baseReg)
		code.push(0x8B)
	end 'unsigned'
end 'emitLoadIndirectWord'

// 16-bit load. MOVSX r64, r/m16 = REX.W + 0F BF /r; MOVZX r64, r/m16 =
// REX.W + 0F B7 /r. REX.W keeps the destination at full 64-bit operand
// size; the extension semantics are encoded in the opcode byte.
function emitLoadIndirectHalfword(code ByteArray, destReg X64Register, baseReg X64Register, signed bool)
	emitRexWPrefix(code, regField: destReg, rmField: baseReg)
	code.push(0x0F)
	code.push(0xBF if signed else 0xB7)
end 'emitLoadIndirectHalfword'

// 8-bit load. MOVSX r64, r/m8 = REX.W + 0F BE /r; MOVZX r64, r/m8 =
// REX.W + 0F B6 /r.
function emitLoadIndirectByte(code ByteArray, destReg X64Register, baseReg X64Register, signed bool)
	emitRexWPrefix(code, regField: destReg, rmField: baseReg)
	code.push(0x0F)
	code.push(0xBE if signed else 0xB6)
end 'emitLoadIndirectByte'

// Emit a plain REX prefix (no W bit) when either operand is extended
// (r8-r15). Used for the narrow stores and the unsigned 32-bit load
// where REX.W must NOT be set.
function emitRexNoWIfNeeded(code ByteArray, regField X64Register, rmField X64Register)
	let needRexR = isExtended(regField)
	let needRexB = isExtended(rmField)
	if needRexR or needRexB 'needRex'
		var rex = 0x40
		if needRexR 'rBit'
			rex = rex or 0x04
		end 'rBit'
		if needRexB 'bBit'
			rex = rex or 0x01
		end 'bBit'
		code.push(rex)
	end 'needRex'
end 'emitRexNoWIfNeeded'

// REX (no W) emitter for byte ops. In addition to the extended-register
// cases handled by `emitRexNoWIfNeeded`, byte ops MUST emit a REX prefix
// when the byte source/destination register is one of rsp/rbp/rsi/rdi —
// without REX those encodings select AH/CH/DH/BH (the high halves of
// rax/rcx/rdx/rbx) instead of SPL/BPL/SIL/DIL. ModRM.reg holds the GP
// register in our store sequence (src for `mov [r/m], r`).
function emitRexNoWForByteOp(code ByteArray, regField X64Register, rmField X64Register)
	let needsRexForByteReg = needsRexForByteAccess(regField) or needsRexForByteAccess(rmField)
	let needRexR = isExtended(regField)
	let needRexB = isExtended(rmField)
	if needsRexForByteReg or needRexR or needRexB 'needRex'
		var rex = 0x40
		if needRexR 'rBit'
			rex = rex or 0x04
		end 'rBit'
		if needRexB 'bBit'
			rex = rex or 0x01
		end 'bBit'
		code.push(rex)
	end 'needRex'
end 'emitRexNoWForByteOp'

// rsp/rbp/rsi/rdi require a REX prefix on byte ops to disambiguate from
// AH/CH/DH/BH (which encode without REX). For all other registers the
// byte form is reachable without REX (rax->al, rcx->cl, rdx->dl, rbx->bl
// — and r8..r15's REX.B is already covered by isExtended).
function needsRexForByteAccess(reg X64Register) returns bool
	return match reg 'b'
		rsp gives true
		rbp gives true
		rsi gives true
		rdi gives true
		rax to rbx gives false
		r8 to r15 gives false
	end 'b'
end 'needsRexForByteAccess'

// Emit ModRM + displacement for [base+offset] addressing.
// Thin wrapper around `emitMemDispBits` that extracts the GP reg-field code
// for callers whose reg field is an X64Register (most of the GP path).
function emitMemDisp(code ByteArray, regField X64Register, baseReg X64Register, offset MachineWord)
	emitMemDispBits(code, regBits: regCode(regField), baseReg: baseReg, offset: offset)
end 'emitMemDisp'

// Shared ModRM + displacement encoder for `[baseReg + offset]` addressing.
// Caller passes the full reg-field code; the high bit of an extended
// register (XMM8..15 or R8..15) belongs in REX.R and must already be
// pushed before calling — only the low 3 bits land in ModRM.reg.
function emitMemDispBits(code ByteArray, regBits MachineWord, baseReg X64Register, offset MachineWord)
	let regFieldBits = regBits and 7
	let baseBits = regCode(baseReg)
	if offset == 0 and baseBits != 5 'noDisp'
		// mod=00, no displacement (rbp/r13 are always encoded with disp8 — `baseBits != 5` rules them out).
		let modrm = 0x00 or (regFieldBits shl 3) or baseBits
		code.push(modrm)
		// RSP/R12 base needs SIB byte.
		if baseBits == 4 'needSib'
			code.push(0x24)
		end 'needSib'
	end 'noDisp' else 'hasDisp'
		if offset >= i8.min and offset <= i8.max 'disp8'
			let modrm = 0x40 or (regFieldBits shl 3) or baseBits
			code.push(modrm)
			if baseBits == 4 'needSib'
				code.push(0x24)
			end 'needSib'
			code.push(offset and 0xFF)
		end 'disp8' else 'disp32'
			let modrm = 0x80 or (regFieldBits shl 3) or baseBits
			code.push(modrm)
			if baseBits == 4 'needSib'
				code.push(0x24)
			end 'needSib'
			writeDword(code, value: offset)
		end 'disp32'
	end 'hasDisp'
end 'emitMemDispBits'

// --- LEA from stack: lea dest, [rbp+offset] ---
function emitLeaFromStackOp(code ByteArray, dest X64Register, offset MachineWord)
	emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
	code.push(0x8D)
	emitMemDisp(code, regField: dest, baseReg: X64Register.rbp, offset: offset)
end 'emitLeaFromStackOp'

// --- LEA RIP-relative: lea dest, [rip+label] ---
// Emits a RIP-relative LEA to any destination register, with a placeholder
// disp32 that is patched by the binary writer after rdata section layout.
// Labels starting with "__data_" use dataSectionRipRelDisp32 to target the .data section.
function emitLeaRipRelOp(code ByteArray, dest X64Register, rdataLabel String, rdataRelocs RdataRelocationArray)
	// lea dest, [rip + disp32]
	emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
	code.push(0x8D)
	let destBits = regCode(dest)
	let modrm = 0x05 or (destBits shl 3)
	code.push(modrm)
	rdataRelocs.push(RdataRelocation.create(code.count(), rdataLabel: rdataLabel, kind: relocKindForLabel(rdataLabel)))
	writeDword(code, value: 0)
end 'emitLeaRipRelOp'

// Route a named rdata label to the appropriate relocation kind based on its
// prefix. `__data_cov_*` globals live in the dedicated .covdata section and
// must be checked before the generic `__data_` branch (which would otherwise
// swallow them). Other `__data_*` labels target the writable .data heap arena,
// as do the slab/MM allocator globals (`__slab_*` and `__mm_*`) registered by
// `registerSlabAndMmGlobalsForDataSection` — these are mutable counters and
// list heads that get atomic increments and pointer writes, so they MUST live
// in the writable .data section, not read-only .rdata. Everything else
// resolves against .rdata.
function relocKindForLabel(label String) returns RdataRelocKind
	if label.startsWith("__data_cov_") 'isCovData'
		return RdataRelocKind.covdataRipRelDisp32
	end 'isCovData'
	if label.startsWith("__data_") 'isDataSection'
		return RdataRelocKind.dataSectionRipRelDisp32
	end 'isDataSection'
	if label.startsWith("__slab_") or label.startsWith("__mm_") 'isAllocatorGlobal'
		return RdataRelocKind.dataSectionRipRelDisp32
	end 'isAllocatorGlobal'
	// Phase B3: the lazy-init argv cache globals used by hand-rolled
	// `mrt_win32_get_argc` / `mrt_win32_get_argv` are mutable counters and
	// pointers — they live in writable .data alongside the slab/MM globals.
	if label.startsWith("__mrt_") 'isMrtGlobal'
		return RdataRelocKind.dataSectionRipRelDisp32
	end 'isMrtGlobal'
	return RdataRelocKind.ripRelDisp32
end 'relocKindForLabel'

// --- LEA func addr: lea dest, [rip+funcName] ---
function emitLeaFuncAddrOp(code ByteArray, dest X64Register, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcName String)
	emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
	code.push(0x8D)
	let destBits = regCode(dest)
	let modrm = 0x05 or (destBits shl 3)
	code.push(modrm)
	let fixupOffset = code.count()
	writeDword(code, value: 0)
	// __symtable lives in a separate .symtab section — use an rdata relocation
	if funcName == "__symtable" 'isSymtable'
		rdataRelocs.push(RdataRelocation.create(fixupOffset, rdataLabel: "__symtable", kind: RdataRelocKind.symdataRipRelDisp32))
	end 'isSymtable' else 'isFunc'
		callFixups.push(CallFixup.create(fixupOffset, targetName: funcName))
	end 'isFunc'
end 'emitLeaFuncAddrOp'

// --- MOVSXD: sign-extend 32-bit to 64-bit ---
function emitMovsxdOp(code ByteArray, dest X64Register, src X64Register)
	// movsxd dest, src  =>  REX.W 63 ModRM(dest -> src)
	emitRexWPrefix(code, regField: dest, rmField: src)
	code.push(0x63)
	emitModRMReg(code, regField: dest, rmField: src)
end 'emitMovsxdOp'

// --- MOVZX32: zero-extend 32-bit (just mov r32, r32 which zero-extends) ---
function emitMovzx32Op(code ByteArray, dest X64Register, src X64Register)
	// mov r32, r32 zero-extends to 64 bit
	if isExtended(dest) or isExtended(src) 'needRex'
		var rex = 0x40
		if isExtended(dest) 'rBit'
			rex = rex or 0x04
		end 'rBit'
		if isExtended(src) 'bBit'
			rex = rex or 0x01
		end 'bBit'
		code.push(rex)
	end 'needRex'
	code.push(0x89)
	emitModRMReg(code, regField: src, rmField: dest)
end 'emitMovzx32Op'

// --- Null-safe load ---
function emitNullSafeLoadOp(code ByteArray, dest X64Register, baseReg X64Register, offset MachineWord)
	panic("emitNullSafeLoadOp: null check emission not yet implemented (dest={dest}, base={baseReg}, offset={offset}, codeLen={code.count()})")
end 'emitNullSafeLoadOp'

// --- REP MOVSB: memory copy ---
function emitRepMovsbOp(code ByteArray)
	// rep movsb: F3 A4
	code.push(0xF3)
	code.push(0xA4)
end 'emitRepMovsbOp'

// --- REP STOSQ: memory fill ---
function emitRepStosqOp(code ByteArray)
	// rep stosq: F3 REX.W AB
	code.push(0xF3)
	code.push(0x48)
	code.push(0xAB)
end 'emitRepStosqOp'

// --- LOCK INC qword ptr [addr] ---
// Encoding: F0 REX.W FF /0 ModRM
// REX.B is set when addr is in r8..r15. We delegate ModRM/SIB/disp encoding to
// the shared `emitMemDispBits` helper with `regBits = 0` for the /0 opcode
// extension, and offset=0 so it picks the no-displacement form (with SIB for
// rsp/r12 and the disp8=0 form for rbp/r13 — both handled by the helper).
function emitLockIncMemoryOp(code ByteArray, addrReg X64Register)
	code.push(0xF0)
	// REX.W with the addr register in the r/m field (no reg-field register here,
	// since ModRM.reg holds the /0 opcode extension).
	var rex = 0x48
	if isExtended(addrReg) 'bBit'
		rex = rex or 0x01
	end 'bBit'
	code.push(rex)
	code.push(0xFF)
	emitMemDispBits(code, regBits: 0, baseReg: addrReg, offset: 0)
end 'emitLockIncMemoryOp'

// --- LOCK DEC qword ptr [addr] ---
// Encoding: F0 REX.W FF /1 ModRM — same shape as INC but with /1 in ModRM.reg.
function emitLockDecMemoryOp(code ByteArray, addrReg X64Register)
	code.push(0xF0)
	var rex = 0x48
	if isExtended(addrReg) 'bBit'
		rex = rex or 0x01
	end 'bBit'
	code.push(rex)
	code.push(0xFF)
	emitMemDispBits(code, regBits: 1, baseReg: addrReg, offset: 0)
end 'emitLockDecMemoryOp'

// --- LOCK XADD qword ptr [addr], val ---
// Encoding: F0 REX.W 0F C1 ModRM — `XADD r/m64, r64`. ModRM.reg holds the value
// register, ModRM.r/m holds the address register. After execution, the value
// register holds the prior memory contents.
function emitLockXaddMemRegOp(code ByteArray, addrReg X64Register, valReg X64Register)
	code.push(0xF0)
	// REX.W + REX.R for valReg (reg field) + REX.B for addrReg (r/m field).
	emitRexWPrefix(code, regField: valReg, rmField: addrReg)
	code.push(0x0F)
	code.push(0xC1)
	emitMemDisp(code, regField: valReg, baseReg: addrReg, offset: 0)
end 'emitLockXaddMemRegOp'

// --- Global load/store ---
// Phase D1: emit a `mov dest, [rip+disp32]` / `mov [rip+disp32], src` against
// the named global, recording an rdata relocation routed via `relocKindForLabel`.
// The 8-byte form (full quadword load/store) is the only width used today by
// the Linux/macOS `osGetArgc` / `osGetArgv` lowerings and the hand-rolled
// `mrt_win32_*` helpers — narrower widths would need a width-specific encoding.
//
// Both load and store share the modrm = 0x05 | ((reg & 7) << 3) shape; the
// only differences are the opcode byte (0x8B vs 0x89) and the prefix's
// `regField` source. `emitGlobalAccess` centralises the common sequence.
function emitGlobalAccess(code ByteArray, opcode MachineWord, regField X64Register, name String, rdataRelocs RdataRelocationArray)
	emitRexWPrefix(code, regField: regField, rmField: X64Register.rbp)
	code.push(opcode)
	let regBits = regCode(regField)
	let modrm = 0x05 or ((regBits and 7) shl 3)
	code.push(modrm)
	rdataRelocs.push(RdataRelocation.create(code.count(), rdataLabel: name, kind: relocKindForLabel(name)))
	writeDword(code, value: 0)
end 'emitGlobalAccess'

function emitGlobalLoadOp(code ByteArray, dest X64Register, name String, size MachineWord, rdataRelocs RdataRelocationArray)
	if size != 8 'sizeOk'
		panic("emitGlobalLoadOp: only 8-byte global loads supported (name={name}, size={size})")
	end 'sizeOk'
	emitGlobalAccess(code, opcode: 0x8B, regField: dest, name: name, rdataRelocs: rdataRelocs)
end 'emitGlobalLoadOp'

function emitGlobalStoreOp(code ByteArray, src X64Register, name String, size MachineWord, rdataRelocs RdataRelocationArray)
	if size != 8 'sizeOk'
		panic("emitGlobalStoreOp: only 8-byte global stores supported (name={name}, size={size})")
	end 'sizeOk'
	emitGlobalAccess(code, opcode: 0x89, regField: src, name: name, rdataRelocs: rdataRelocs)
end 'emitGlobalStoreOp'

// --- movXmmRipRel: load float from RIP-relative rdata ---
// Emits a movsd/movss xmm, [rip+disp32] with a placeholder disp32
// that is patched by the binary writer after rdata section layout.
function emitMovXmmRipRelOp(code ByteArray, dest X64XmmRegister, rdataLabel String, precision FloatPrecision, rdataRelocs RdataRelocationArray)
	// movsd/movss xmm, [rip+disp32]
	match precision 'prec'
		f64 then code.push(0xF2)
		f32 then code.push(0xF3)
	end 'prec'
	code.push(0x0F)
	code.push(0x10)
	let destBits = dest.rawValue and 0x07
	let modrm = 0x05 or (destBits shl 3)
	code.push(modrm)
	// Record relocation at the disp32 position
	rdataRelocs.push(RdataRelocation.create(code.count(), rdataLabel: rdataLabel, kind: RdataRelocKind.ripRelDisp32))
	writeDword(code, value: 0)
end 'emitMovXmmRipRelOp'

// SSE 4.1 ROUNDSD/ROUNDSS: round XMM by immediate mode byte.
// Encoding: 66 [REX] 0F 3A 0B /r ib (double) or 66 [REX] 0F 3A 0A /r ib (single)
function emitRoundXmmOp(code ByteArray, dest X64XmmRegister, src X64XmmRegister, mode MachineWord, precision FloatPrecision)
	let destC = xmmRegCode(dest)
	let srcC = xmmRegCode(src)
	code.push(0x66)
	emitXmmRexIfNeeded(code, regFieldCode: destC, rmFieldCode: srcC, rexBase: 0x40)
	code.push(0x0F)
	code.push(0x3A)
	let opcode = match precision 'prec'
		f64 gives 0x0B
		f32 gives 0x0A
	end 'prec'
	code.push(opcode)
	let modrm = 0xC0 or ((destC and 7) shl 3) or (srcC and 7)
	code.push(modrm)
	code.push(mode and 0xFF)
end 'emitRoundXmmOp'

// ANDPD xmm, [rip+disp32]: bitwise AND of XMM register with 64-bit memory mask.
// Encoding: 66 [REX] 0F 54 /r with r/m=0b101 (disp32 RIP-relative).
// Used for absF64 with mask 0x7FFFFFFFFFFFFFFF (clears sign bit). The op is
// f64-only today; ANDPS would need a different encoding (no 0x66 prefix).
function emitAndMaskRipRelOp(code ByteArray, dest X64XmmRegister, rdataLabel String, precision FloatPrecision, rdataRelocs RdataRelocationArray)
	match precision 'prec'
		f64 then break 'prec'
		f32 then panic("emitAndMaskRipRelOp: f32 (ANDPS) not yet supported")
	end 'prec'
	let destC = xmmRegCode(dest)
	code.push(0x66)
	// Only REX.R may be needed (for xmm8-xmm15 in reg field). Memory r/m=0b101 is fixed.
	if destC >= 8 'rexR'
		code.push(0x44)
	end 'rexR'
	code.push(0x0F)
	code.push(0x54)
	let destBits = destC and 0x07
	let modrm = 0x05 or (destBits shl 3)
	code.push(modrm)
	rdataRelocs.push(RdataRelocation.create(code.count(), rdataLabel: rdataLabel, kind: RdataRelocKind.ripRelDisp32))
	writeDword(code, value: 0)
end 'emitAndMaskRipRelOp'

// --- movq XMM to GPR ---
function emitMovqXmmToGprOp(code ByteArray, dest X64Register, src X64XmmRegister)
	// movq r64, xmm: 66 REX.W 0F 7E ModRM(xmm -> r/m)
	// GPR in r/m field needs full code for REX.B detection
	var destFull = regCode(dest)
	if isExtended(dest) 'ext'
		destFull = destFull + 8
	end 'ext'
	code.push(0x66)
	emitXmmRexIfNeeded(code, regFieldCode: xmmRegCode(src), rmFieldCode: destFull, rexBase: 0x48)
	emitXmmOpModRM(code, opcode: 0x7E, regFieldCode: xmmRegCode(src), rmFieldCode: regCode(dest))
end 'emitMovqXmmToGprOp'

// --- movq GPR to XMM ---
function emitMovqGprToXmmOp(code ByteArray, dest X64XmmRegister, src X64Register)
	// movq xmm, r64: 66 REX.W 0F 6E ModRM(xmm <- r/m)
	// GPR in r/m field needs full code for REX.B detection
	var srcFull = regCode(src)
	if isExtended(src) 'ext'
		srcFull = srcFull + 8
	end 'ext'
	code.push(0x66)
	emitXmmRexIfNeeded(code, regFieldCode: xmmRegCode(dest), rmFieldCode: srcFull, rexBase: 0x48)
	emitXmmOpModRM(code, opcode: 0x6E, regFieldCode: xmmRegCode(dest), rmFieldCode: regCode(src))
end 'emitMovqGprToXmmOp'

// Emit bytes for a single X64Op.
function emitX64Op(op X64Op, code ByteArray, blockFixups BlockJumpFixupArray, callFixups CallFixupArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, tracker X64StackTracker)
	match op 'emit'
		prologue(stackSize) then emitPrologue(code, stackSize: stackSize, calleeSavedGprs: tracker.calleeSavedGprs, outgoingArgSize: tracker.outgoingArgSize)
		epilogue then emitEpilogue(code, calleeSavedGprs: tracker.calleeSavedGprs, outgoingArgSize: tracker.outgoingArgSize)
		ret then emitRet(code)
		movRegImm(dest, value) then emitMovRegImmGeneric(code, dest: resolveGpr(dest), value: value)
		movRegImm32(dest, value) then emitMovRegImm32(code, dest: resolveGpr(dest), value: value)
		movSlot(slotIndex, srcReg) then emitMovSlot(code, slotIndex: slotIndex, srcReg: resolveGpr(srcReg))
		loadSlot(destReg, slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: resolveGpr(destReg))
		addRegReg(destReg, srcReg) then emitAddRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		subRegReg(destReg, srcReg) then emitSubRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		addRegImm(destReg, value) then emitAddRegImmParam(code, dest: resolveGpr(destReg), value: value)
		subRegImm(destReg, value) then emitSubRegImmParam(code, dest: resolveGpr(destReg), value: value)
		imulRegReg(destReg, srcReg) then emitImulRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		idivRcx then emitIdivRcx(code)
		iremRcx then emitIremRcx(code)
		negReg(reg) then emitNegRegParam(code, reg: resolveGpr(reg))
		bitNotReg(reg) then emitBitNotRegParam(code, reg: resolveGpr(reg))
		andRegReg(destReg, srcReg) then emitAndRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		orRegReg(destReg, srcReg) then emitOrRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		xorRegReg(destReg, srcReg) then emitXorRegRegParam(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		shlRegCl(dest, _, _) then emitShlRegClParam(code, reg: resolveGpr(dest))
		sarRegCl(dest, _, _) then emitSarRegClParam(code, reg: resolveGpr(dest))
		shrRegCl(dest, _, _) then emitShrRegClParam(code, reg: resolveGpr(dest))
		cmpRaxRcx then emitCmpRaxRcx(code)
		testRaxRax then emitTestRaxRax(code)
		condJump(condition, targetBlock) then emitCondJumpBlock(code, blockFixups: blockFixups, opcode: condition.rawValue, targetBlock: targetBlock)
		jmp(targetBlock) then emitJmpBlock(code, blockFixups: blockFixups, targetBlock: targetBlock)
		movF64Slot(slotIndex) then emitMovSlot(code, slotIndex: slotIndex, srcReg: X64Register.rax)
		loadF64Slot(slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: X64Register.rax)
		movF64Rdata(rdataOffset) then emitMovRegImm(code, value: rdataOffset)
		ucomisd then emitUcomisd(code)
		subRspImm(value) then emitSubRspImm(code, value: value)
		addRspImm(value) then emitAddRspImm(code, value: value)
		movRspOffsetReg(offset, srcReg) then emitMovRspOffsetReg(code, offset: offset, srcReg: resolveGpr(srcReg))
		loadRegRbpOffset(destReg, offset) then emitLoadRegRbpOffset(code, destReg: resolveGpr(destReg), offset: offset)
		callDirect(target) then emitCallFixup(code, callFixups: callFixups, target: target)
		syscall(resultSlot, number, argSlots) then emitX64SyscallOp(code, resultSlot: resultSlot, number: number, argSlots: argSlots)
		iatCall(resultSlot, slotIndex, argSlots) then emitX64IatCallOp(code, relocations: relocations, resultSlot: resultSlot, slotIndex: slotIndex, argSlots: argSlots)
		globalAddr(resultSlot, name) then emitX64GlobalAddrOp(code, rdataRelocs: rdataRelocs, resultSlot: resultSlot, name: name)
		stackAddrOp(resultSlot, targetSlot) then emitX64StackAddrOp(code, resultSlot: resultSlot, targetSlot: targetSlot)
		storeByteOp(baseSlot, offsetSlot, byteSlot) then emitX64StoreByteOp(code, baseSlot: baseSlot, offsetSlot: offsetSlot, byteSlot: byteSlot)
		loadByteOp(resultSlot, baseSlot, offsetSlot) then emitX64LoadByteOp(code, resultSlot: resultSlot, baseSlot: baseSlot, offsetSlot: offsetSlot)
		memcpyOp(dstSlot, srcSlot, lenSlot) then emitX64MemcpyOp(code, dstSlot: dstSlot, srcSlot: srcSlot, lenSlot: lenSlot)
		// Register allocator ops
		movRegReg(destReg, srcReg) then emitMovRegRegOp(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg))
		cmpRegReg(lhsReg, rhsReg) then emitCmpRegRegOp(code, lhs: resolveGpr(lhsReg), rhs: resolveGpr(rhsReg))
		cmpRegImm(lhsReg, value) then emitCmpRegImmOp(code, lhs: resolveGpr(lhsReg), value: value)
		testRegReg(reg1, reg2) then emitTestRegRegOp(code, reg1: resolveGpr(reg1), reg2: resolveGpr(reg2))
		cqo then emitCqoOp(code)
		idivReg(divisorReg) then emitIdivRegOp(code, divisor: resolveGpr(divisorReg))
		spillToStack(offset, srcReg) then emitSpillToStackOp(code, offset: offset, srcReg: resolveGpr(srcReg))
		reloadFromStack(destReg, offset) then emitReloadFromStackOp(code, dest: resolveGpr(destReg), offset: offset)
		xorRegRegSelf(reg) then emitXorRegRegSelfOp(code, reg: resolveGpr(reg))
		callIndirect(reg) then emitCallIndirectOp(code, reg: resolveGpr(reg))
		xchgRegReg(reg1, reg2) then emitXchgRegRegOp(code, reg1: resolveGpr(reg1), reg2: resolveGpr(reg2))
		// XMM FP ops — emit XMM instruction encodings
		movXmmXmm(dest, src, precision) then emitMovXmmXmmOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision)
		spillXmmToStack(offset, src, precision) then emitSpillXmmToStackOp(code, offset: offset, src: resolveFp(src), precision: precision)
		reloadXmmFromStack(dest, offset, precision) then emitReloadXmmFromStackOp(code, dest: resolveFp(dest), offset: offset, precision: precision)
		movXmmRipRel(dest, rdataLabel, precision) then emitMovXmmRipRelOp(code, dest: resolveFp(dest), rdataLabel: rdataLabel, precision: precision, rdataRelocs: rdataRelocs)
		addXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x58)
		subXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x5C)
		mulXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x59)
		divXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x5E)
		minXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x5D)
		maxXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x5F)
		sqrtXmm(dest, src, precision) then emitXmmBinaryOp(code, dest: resolveFp(dest), src: resolveFp(src), precision: precision, opcode: 0x51)
		roundXmm(dest, src, mode, precision) then emitRoundXmmOp(code, dest: resolveFp(dest), src: resolveFp(src), mode: mode, precision: precision)
		ucomisXmm(src1, src2, precision) then emitUcomisXmmOp(code, src1: resolveFp(src1), src2: resolveFp(src2), precision: precision)
		cvtSi2Float(dest, src, precision) then emitCvtSi2FloatOp(code, dest: resolveFp(dest), src: resolveGpr(src), precision: precision)
		cvttFloat2Si(dest, src, precision) then emitCvttFloat2SiOp(code, dest: resolveGpr(dest), src: resolveFp(src), precision: precision)
		cvtSd2Ss then panic("X86 cvtSd2Ss not yet implemented in binary emitter")
		cvtSs2Sd then panic("X86 cvtSs2Sd not yet implemented in binary emitter")
		movqXmmToGpr(dest, src) then emitMovqXmmToGprOp(code, dest: resolveGpr(dest), src: resolveFp(src))
		movqGprToXmm(dest, src) then emitMovqGprToXmmOp(code, dest: resolveFp(dest), src: resolveGpr(src))
		andMaskRipRel(dest, rdataLabel, precision) then emitAndMaskRipRelOp(code, dest: resolveFp(dest), rdataLabel: rdataLabel, precision: precision, rdataRelocs: rdataRelocs)
		storeIndirect(baseReg, offset, srcReg, width) then emitStoreIndirectOp(code, baseReg: resolveGpr(baseReg), offset: offset, srcReg: resolveGpr(srcReg), width: width)
		loadIndirect(destReg, baseReg, offset, width, signed) then emitLoadIndirectOp(code, destReg: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, width: width, signed: signed)
		storeIndirectXmm(baseReg, offset, src, precision) then emitStoreIndirectXmmOp(code, baseReg: resolveGpr(baseReg), offset: offset, srcReg: resolveFp(src), precision: precision)
		loadIndirectXmm(dest, baseReg, offset, precision) then emitLoadIndirectXmmOp(code, destReg: resolveFp(dest), baseReg: resolveGpr(baseReg), offset: offset, precision: precision)
		globalLoad(dest, name, size) then emitGlobalLoadOp(code, dest: resolveGpr(dest), name: name, size: size, rdataRelocs: rdataRelocs)
		globalStore(name, src, size) then emitGlobalStoreOp(code, src: resolveGpr(src), name: name, size: size, rdataRelocs: rdataRelocs)
		globalLoadXmm then panic("X86 globalLoadXmm not yet implemented in binary emitter")
		globalStoreXmm then panic("X86 globalStoreXmm not yet implemented in binary emitter")
		leaFromStack(dest, stackOffset) then emitLeaFromStackOp(code, dest: resolveGpr(dest), offset: stackOffset)
		leaRipRelative(dest, rdataLabel) then emitLeaRipRelOp(code, dest: resolveGpr(dest), rdataLabel: rdataLabel, rdataRelocs: rdataRelocs)
		leaFuncAddr(dest, funcName) then emitLeaFuncAddrOp(code, dest: resolveGpr(dest), callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: funcName)
		setcc(dest, condition) then emitSetccOp(code, dest: resolveGpr(dest), condition: condition)
		cmov(dest, src, condition) then emitCmovOp(code, dest: resolveGpr(dest), src: resolveGpr(src), condition: condition)
		movsxd(dest, src) then emitMovsxdOp(code, dest: resolveGpr(dest), src: resolveGpr(src))
		movzx32(dest, src) then emitMovzx32Op(code, dest: resolveGpr(dest), src: resolveGpr(src))
		nullSafeLoad(dest, baseReg, offset) then emitNullSafeLoadOp(code, dest: resolveGpr(dest), baseReg: resolveGpr(baseReg), offset: offset)
		repMovsb then emitRepMovsbOp(code)
		repStosq then emitRepStosqOp(code)
		lockIncMemory(addrReg) then emitLockIncMemoryOp(code, addrReg: resolveGpr(addrReg))
		lockDecMemory(addrReg) then emitLockDecMemoryOp(code, addrReg: resolveGpr(addrReg))
		lockXaddMemReg(valReg, addrReg) then emitLockXaddMemRegOp(code, addrReg: resolveGpr(addrReg), valReg: resolveGpr(valReg))
		stashEntryArgv then emitX64StashEntryArgvOp(code, rdataRelocs: rdataRelocs)
		// Phase 2 dialect groundwork: memory-operand ALU forms `op reg, [base+disp]`.
		// Each opcode shares the same ModR/M + displacement encoding (delegated to
		// emitMemDisp). The reg field is `destReg`/`lhsReg`; the r/m field is `baseReg`.
		addRegMem(destReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x03)
		subRegMem(destReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x2B)
		andRegMem(destReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x23)
		orRegMem(destReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x0B)
		xorRegMem(destReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x33)
		cmpRegMem(lhsReg, baseReg, offset) then emitRegMemAluOp(code, dest: resolveGpr(lhsReg), baseReg: resolveGpr(baseReg), offset: offset, opcode: 0x3B)
		imulRegMem(destReg, baseReg, offset) then emitImulRegMemOp(code, dest: resolveGpr(destReg), baseReg: resolveGpr(baseReg), offset: offset)
		// Immediate-form ALU `op reg, imm`. and/or/xor share the REX.W + 81/83
		// /ext, dest encoding — just the ModR/M extension differs.
		andRegImm(destReg, value) then emitAluRegImmParam(code, dest: resolveGpr(destReg), value: value, ext: 4)
		orRegImm(destReg, value) then emitAluRegImmParam(code, dest: resolveGpr(destReg), value: value, ext: 1)
		xorRegImm(destReg, value) then emitAluRegImmParam(code, dest: resolveGpr(destReg), value: value, ext: 6)
		// Three-operand `imul dest, src, imm`.
		imulRegImm(destReg, srcReg, value) then emitImulRegImmOp(code, dest: resolveGpr(destReg), src: resolveGpr(srcReg), value: value)
	end 'emit'
end 'emitX64Op'

// Phase D2: stash the kernel-supplied argc/argv from rdi/rsi (System V x86-64
// entry-point convention) into the `__mrt_argc` / `__mrt_argv` globals. This
// runs at the very start of `mrt_start` on Linux/macOS, BEFORE the prologue
// stomps the registers. The prologue insertion pass only inserts this op on
// Linux/macOS, so when this emit runs we know we want the two-store sequence.
function emitX64StashEntryArgvOp(code ByteArray, rdataRelocs RdataRelocationArray)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdi, name: "__mrt_argc")
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rsi, name: "__mrt_argv")
end 'emitX64StashEntryArgvOp'

// --- StdSystemOp emission (x86-64) ---

// sys.syscall: Linux x86-64 syscall ABI
// Syscall ABI: rax=number, rdi=arg0, rsi=arg1, rdx=arg2, r10=arg3, r8=arg4, r9=arg5
// Result in rax, stored to resultSlot.
function emitX64SyscallOp(code ByteArray, resultSlot VarSlot, number MachineWord, argSlots VarSlotArray)
	let argCount = argSlots.count()

	// Linux syscall register order: rdi, rsi, rdx, r10, r8, r9
	if argCount >= 1 'arg0'
		let slot0 = try argSlots.get(0) otherwise panic("emitX64SyscallOp.arg0: argCount >= 1 just checked but get(0) failed")
		emitLoadSlotToReg(code, slotIndex: slot0, dest: X64Register.rdi)
	end 'arg0'
	if argCount >= 2 'arg1'
		let slot1 = try argSlots.get(1) otherwise panic("emitX64SyscallOp.arg1: argCount >= 2 just checked but get(1) failed")
		emitLoadSlotToReg(code, slotIndex: slot1, dest: X64Register.rsi)
	end 'arg1'
	if argCount >= 3 'arg2'
		let slot2 = try argSlots.get(2) otherwise panic("emitX64SyscallOp.arg2: argCount >= 3 just checked but get(2) failed")
		emitLoadSlotToReg(code, slotIndex: slot2, dest: X64Register.rdx)
	end 'arg2'
	if argCount >= 4 'arg3'
		let slot3 = try argSlots.get(3) otherwise panic("emitX64SyscallOp.arg3: argCount >= 4 just checked but get(3) failed")
		emitLoadSlotToReg(code, slotIndex: slot3, dest: X64Register.r10)
	end 'arg3'
	if argCount >= 5 'arg4'
		let slot4 = try argSlots.get(4) otherwise panic("emitX64SyscallOp.arg4: argCount >= 5 just checked but get(4) failed")
		emitLoadSlotToReg(code, slotIndex: slot4, dest: X64Register.r8)
	end 'arg4'
	if argCount >= 6 'arg5'
		let slot5 = try argSlots.get(5) otherwise panic("emitX64SyscallOp.arg5: argCount >= 6 just checked but get(5) failed")
		emitLoadSlotToReg(code, slotIndex: slot5, dest: X64Register.r9)
	end 'arg5'

	// mov eax, number
	code.push(0xB8)
	writeDword(code, value: number)
	// syscall
	code.append(b"\x0f\x05")

	// Store result (rax) to resultSlot
	emitMovSlot(code, slotIndex: resultSlot, srcReg: X64Register.rax)
end 'emitX64SyscallOp'

// sys.iatCall: Windows IAT indirect call
// Windows x64 ABI: rcx=arg0, rdx=arg1, r8=arg2, r9=arg3, stack for arg4+
// Shadow space (32 bytes) must be allocated by caller.
function emitX64IatCallOp(code ByteArray, relocations RelocationArray, resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray)
	let argCount = argSlots.count()

	// Allocate shadow space + stack args
	let stackArgCount = argCount - 4
	var totalStackBytes = 32
	if stackArgCount > 0 'extraStack'
		totalStackBytes = totalStackBytes + stackArgCount * 8
	end 'extraStack'
	// Align to 16
	totalStackBytes = (totalStackBytes + 15) and (-16)
	emitSubRspImm(code, value: totalStackBytes)

	// Load register args (first 4)
	if argCount >= 1 'arg0'
		let slot0 = try argSlots.get(0) otherwise panic("emitX64IatCallOp.arg0: argCount >= 1 just checked but get(0) failed")
		emitLoadSlotToReg(code, slotIndex: slot0, dest: X64Register.rcx)
	end 'arg0'
	if argCount >= 2 'arg1'
		let slot1 = try argSlots.get(1) otherwise panic("emitX64IatCallOp.arg1: argCount >= 2 just checked but get(1) failed")
		emitLoadSlotToReg(code, slotIndex: slot1, dest: X64Register.rdx)
	end 'arg1'
	if argCount >= 3 'arg2'
		let slot2 = try argSlots.get(2) otherwise panic("emitX64IatCallOp.arg2: argCount >= 3 just checked but get(2) failed")
		emitLoadSlotToReg(code, slotIndex: slot2, dest: X64Register.r8)
	end 'arg2'
	if argCount >= 4 'arg3'
		let slot3 = try argSlots.get(3) otherwise panic("emitX64IatCallOp.arg3: argCount >= 4 just checked but get(3) failed")
		emitLoadSlotToReg(code, slotIndex: slot3, dest: X64Register.r9)
	end 'arg3'

	// Stack args (arg4+ go to [rsp+32], [rsp+40], etc.)
	var stackIdx = 4
	while stackIdx < argCount 'pushStackArgs'
		let argSlotN = try argSlots.get(stackIdx) otherwise panic("emitX64IatCallOp.pushStackArgs: stackIdx < argCount by loop guard but get({stackIdx}) failed")
		emitLoadSlotToReg(code, slotIndex: argSlotN, dest: X64Register.rax)
		let rspOffset = 32 + (stackIdx - 4) * 8
		emitMovRspOffsetReg(code, offset: rspOffset, srcReg: X64Register.rax)
		stackIdx = stackIdx + 1
	end 'pushStackArgs'

	// call [rip + disp32] (IAT indirect call)
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: slotIndex))
	writeDword(code, value: 0)

	// Deallocate stack space
	emitAddRspImm(code, value: totalStackBytes)

	// Store result (rax) to resultSlot
	emitMovSlot(code, slotIndex: resultSlot, srcReg: X64Register.rax)
end 'emitX64IatCallOp'

// sys.globalAddr: LEA rax, [rip+disp32] to get pointer to named rdata/data entry
function emitX64GlobalAddrOp(code ByteArray, rdataRelocs RdataRelocationArray, resultSlot VarSlot, name String)
	// lea rax, [rip + disp32]
	code.append(b"\x48\x8d\x05")
	rdataRelocs.push(RdataRelocation.create(code.count(), rdataLabel: name, kind: relocKindForLabel(name)))
	writeDword(code, value: 0)

	// Store to result slot
	emitMovSlot(code, slotIndex: resultSlot, srcReg: X64Register.rax)
end 'emitX64GlobalAddrOp'

// sys.stackAddr: lea rax, [rbp - offset] to get address of a stack slot
function emitX64StackAddrOp(code ByteArray, resultSlot VarSlot, targetSlot VarSlot)
	let offset = (targetSlot + 1) * 8
	let negOffset = 0 - offset
	// lea rax, [rbp + negOffset]
	if offset <= 128 'smallDisp'
		code.append(b"\x48\x8d\x45")
		code.push(negOffset and 0xFF)
	end 'smallDisp' else 'largeDisp'
		code.append(b"\x48\x8d\x85")
		writeDword(code, value: negOffset)
	end 'largeDisp'

	emitMovSlot(code, slotIndex: resultSlot, srcReg: X64Register.rax)
end 'emitX64StackAddrOp'

// sys.storeByte: mov byte [base + offset], value
function emitX64StoreByteOp(code ByteArray, baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot)
	// Load base into rcx
	emitLoadSlotToReg(code, slotIndex: baseSlot, dest: X64Register.rcx)
	// Load offset into rdx
	emitLoadSlotToReg(code, slotIndex: offsetSlot, dest: X64Register.rdx)
	// Load byte value into rax
	emitLoadSlotToReg(code, slotIndex: byteSlot, dest: X64Register.rax)
	// add rcx, rdx (base + offset)
	code.append(b"\x48\x01\xd1")
	// mov byte [rcx], al
	code.append(b"\x88\x01")
end 'emitX64StoreByteOp'

// sys.loadByte: movzx rax, byte [base + offset]
function emitX64LoadByteOp(code ByteArray, resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot)
	// Load base into rcx
	emitLoadSlotToReg(code, slotIndex: baseSlot, dest: X64Register.rcx)
	// Load offset into rdx
	emitLoadSlotToReg(code, slotIndex: offsetSlot, dest: X64Register.rdx)
	// add rcx, rdx (base + offset)
	code.append(b"\x48\x01\xd1")
	// movzx rax, byte [rcx]   =>  48 0F B6 01
	code.append(b"\x48\x0f\xb6\x01")
	// Store result
	emitMovSlot(code, slotIndex: resultSlot, srcReg: X64Register.rax)
end 'emitX64LoadByteOp'

// sys.memcpy: rep movsb (rdi=dst, rsi=src, rcx=len)
function emitX64MemcpyOp(code ByteArray, dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot)
	// Load dst into rdi
	emitLoadSlotToReg(code, slotIndex: dstSlot, dest: X64Register.rdi)
	// Load src into rsi
	emitLoadSlotToReg(code, slotIndex: srcSlot, dest: X64Register.rsi)
	// Load len into rcx
	emitLoadSlotToReg(code, slotIndex: lenSlot, dest: X64Register.rcx)
	// rep movsb
	code.append(b"\xf3\xa4")
end 'emitX64MemcpyOp'

// =============================================================================
// Phase B1+B2: Hand-rolled x86-64 machine code for the twelve `mrt_win32_*`
// runtime helpers. Each function is a byte-level translation of the original
// Std-level body that used to live in runtime.std (deleted in Phase B2).
// The hand-rolled helpers register themselves under the public `mrt_win32_*`
// label names — `lowerFileIoOp` calls them directly.
//
// Calling conventions used by these emitters:
//   * Internal Maxon ABI (every helper's entry/exit): GPR params in
//     rcx, rdx, rax (and r9, rsi, rdi, rbx for >3 params); return value in r8.
//   * Win64 ABI (every IAT call): GPR args in rcx, rdx, r8, r9; remaining
//     args on the stack starting at [rsp+32]; return value in rax.
//     Shadow space (32 bytes) is allocated before each IAT call.
//
// Frame layout (per helper):
//   [rbp]                        saved rbp
//   [rbp + 8]                    return address
//   [rbp -  8 .. rbp - 8*N]      local slots (slot 0 .. slot N-1)
//   [rbp - 8*N .. rsp]           outgoing call args (shadow space + extras)
//
// Slot N is addressed as `[rbp - (N+1)*8]`. Outgoing args at the bottom of
// the frame are addressed as `[rsp + 0 .. + outgoingBytes)`.
// =============================================================================

// Local-block tracker for hand-rolled helpers. We re-use the same `BlockId`
// + offset-table + fixup-list machinery the regular code emitter uses, but
// the BlockId values are local to each helper (starting from 0).
type Win32HelperState
	export var nextBlockId BlockId
	export var blockOffsets CodeOffsetArray
	export var blockFixups BlockJumpFixupArray
	export var outgoingBytes StackSize
	export var localBytes StackSize

	static function create(numBlocks BlockId, outgoingBytes StackSize, localBytes StackSize) returns Win32HelperState
		var offsets = CodeOffsetArray.create()
		for _ in 0 upto numBlocks 'alloc'
			offsets.push(0)
		end 'alloc'
		return Self{nextBlockId: numBlocks, blockOffsets: offsets, blockFixups: BlockJumpFixupArray.create(), outgoingBytes: outgoingBytes, localBytes: localBytes}
	end 'create'
end 'Win32HelperState'

// Stack-frame slot N → byte offset relative to rbp (negative).
function helperSlotRbpOffset(slotIndex VarSlot) returns StackSize
	return 0 - ((slotIndex + 1) * 8)
end 'helperSlotRbpOffset'

// Mark the start of a block at the current code offset.
function helperMarkBlock(state Win32HelperState, code ByteArray, blockId BlockId)
	try state.blockOffsets.set(blockId, value: code.count()) otherwise panic("helperMarkBlock: blockId {blockId} out of range")
end 'helperMarkBlock'

// Prologue: push rbp; mov rbp, rsp; sub rsp, frameSize.
function helperPrologue(code ByteArray, frameSize StackSize)
	code.append(b"\x55\x48\x89\xe5")
	if frameSize > 0 'sub'
		emitSubRspImm(code, value: frameSize)
	end 'sub'
end 'helperPrologue'

// Epilogue: mov rsp, rbp; pop rbp; ret.
function helperEpilogue(code ByteArray)
	code.append(b"\x48\x89\xec\x5d\xc3")
end 'helperEpilogue'

// Load a local slot into a register: mov dest, [rbp - (slot+1)*8].
function helperLoadSlot(code ByteArray, slotIndex VarSlot, dest X64Register)
	emitLoadSlotToReg(code, slotIndex: slotIndex, dest: dest)
end 'helperLoadSlot'

// Store a register into a local slot: mov [rbp - (slot+1)*8], src.
function helperStoreSlot(code ByteArray, slotIndex VarSlot, src X64Register)
	emitMovSlot(code, slotIndex: slotIndex, srcReg: src)
end 'helperStoreSlot'

// LEA stackAddr: lea dest, [rbp - (slot+1)*8].
function helperLeaStackSlot(code ByteArray, slotIndex VarSlot, dest X64Register)
	let negOffset = helperSlotRbpOffset(slotIndex)
	// LEA r64, [rbp + disp]
	emitRexWPrefix(code, regField: dest, rmField: X64Register.rbp)
	code.push(0x8D)
	if negOffset >= -128 and negOffset <= 127 'disp8'
		// mod=01, reg=dest, rm=rbp
		let regBits = regCode(dest)
		code.push((1 shl 6) or ((regBits and 7) shl 3) or 5)
		code.push(negOffset and 0xFF)
	end 'disp8' else 'disp32'
		let regBits = regCode(dest)
		code.push((2 shl 6) or ((regBits and 7) shl 3) or 5)
		writeDword(code, value: negOffset)
	end 'disp32'
end 'helperLeaStackSlot'

// Load a constant into a register: mov dest, imm.
function helperMovRegImm(code ByteArray, dest X64Register, value MachineWord)
	emitMovRegImmGeneric(code, dest: dest, value: value)
end 'helperMovRegImm'

// Encode the modrm + optional SIB + displacement bytes for `[base + disp]`
// addressing where `reg` is the register field of the ModR/M byte. Used by
// every helperLoad*/helperStore* below — extracting the shared encoding keeps
// each helper to a single REX/opcode preamble plus a call to this routine.
//
//   * `regCode(base) != 5` excludes rbp/r13 from the mod=00 short form
//     because mod=00 + rm=101 means [rip+disp32], not [rbp].
//   * `regCode(base) == 4` (rsp/r12) requires a SIB byte; we encode it as
//     `0x24` (scale=00, index=100=none, base=100).
function emitMemBaseDisp(code ByteArray, reg MachineWord, base X64Register, disp StackSize)
	let regBits = reg
	let baseBits = regCode(base)
	if disp == 0 and baseBits != 5 'mod0'
		if baseBits == 4 'sib'
			code.push(((regBits and 7) shl 3) or 4)
			code.push(0x24)
		end 'sib' else 'noSib'
			code.push(((regBits and 7) shl 3) or (baseBits and 7))
		end 'noSib'
	end 'mod0' else if disp >= -128 and disp <= 127 'disp8'
		code.push((1 shl 6) or ((regBits and 7) shl 3) or (baseBits and 7))
		if baseBits == 4 'sib'
			code.push(0x24)
		end 'sib'
		code.push(disp and 0xFF)
	end 'disp8' else 'disp32'
		code.push((2 shl 6) or ((regBits and 7) shl 3) or (baseBits and 7))
		if baseBits == 4 'sib'
			code.push(0x24)
		end 'sib'
		writeDword(code, value: disp)
	end 'disp32'
end 'emitMemBaseDisp'

// Load indirect: mov dest, [base + disp].
function helperLoadIndirect(code ByteArray, dest X64Register, base X64Register, disp StackSize)
	// REX.W 8B /r [base+disp]
	emitRexWPrefix(code, regField: dest, rmField: base)
	code.push(0x8B)
	emitMemBaseDisp(code, reg: regCode(dest), base: base, disp: disp)
end 'helperLoadIndirect'

// Store indirect: mov [base + disp], src.
function helperStoreIndirect(code ByteArray, base X64Register, disp StackSize, src X64Register)
	// REX.W 89 /r [base+disp]
	emitRexWPrefix(code, regField: src, rmField: base)
	code.push(0x89)
	emitMemBaseDisp(code, reg: regCode(src), base: base, disp: disp)
end 'helperStoreIndirect'

// Store byte: mov byte [base + disp], src_low. Requires src to be one of
// rax/rcx/rdx/rbx (al/cl/dl/bl accessible without REX), or any reg with REX.
function helperStoreByteRcx(code ByteArray, base X64Register, disp StackSize, src X64Register)
	// mov [base+disp], src8. Use 0x88 /r with REX as needed.
	var rex = 0x40
	if isExtended(base) 'extB'
		rex = rex or 0x01
	end 'extB'
	if isExtended(src) 'extR'
		rex = rex or 0x04
	end 'extR'
	// Force REX even for rax/rcx/rdx/rbx to make the encoding uniform.
	code.push(rex)
	code.push(0x88)
	emitMemBaseDisp(code, reg: regCode(src), base: base, disp: disp)
end 'helperStoreByteRcx'

// Load byte (zero-extended): movzx dest, byte [base + disp].
function helperLoadByte(code ByteArray, dest X64Register, base X64Register, disp StackSize)
	// REX.W 0F B6 /r
	emitRexWPrefix(code, regField: dest, rmField: base)
	code.push(0x0F)
	code.push(0xB6)
	emitMemBaseDisp(code, reg: regCode(dest), base: base, disp: disp)
end 'helperLoadByte'

// Emit an IAT-indirect call to the given slot. The caller is responsible
// for pre-loading args into rcx/rdx/r8/r9 and placing extra args on the
// stack. Outgoing-arg space (incl. 32-byte shadow region) is already
// reserved by the prologue.
function helperEmitIatCall(code ByteArray, relocations RelocationArray, slotIndex MachineWord)
	code.append(b"\xff\x15")
	relocations.push(Relocation.create(code.count(), slotIndex: slotIndex))
	writeDword(code, value: 0)
end 'helperEmitIatCall'

// Load a global into `dest`: mov dest, [rip+global]. Records an rdata
// relocation against the named global so the binary writer can resolve
// the displacement after .data section layout.
function helperLoadGlobal(code ByteArray, rdataRelocs RdataRelocationArray, dest X64Register, name String)
	emitGlobalAccess(code, opcode: 0x8B, regField: dest, name: name, rdataRelocs: rdataRelocs)
end 'helperLoadGlobal'

// Store `src` to a global: mov [rip+global], src.
function helperStoreGlobal(code ByteArray, rdataRelocs RdataRelocationArray, src X64Register, name String)
	emitGlobalAccess(code, opcode: 0x89, regField: src, name: name, rdataRelocs: rdataRelocs)
end 'helperStoreGlobal'

// shl reg, imm8: REX.W C1 /4 reg, imm8.
function helperShlRegImm(code ByteArray, dest X64Register, value MachineWord)
	emitRexWSingle(code, rmField: dest)
	code.push(0xC1)
	emitModRMExt(code, ext: 4, rmField: dest)
	code.push(value and 0xFF)
end 'helperShlRegImm'

// Emit an internal-ABI direct call (call rel32) to another runtime helper.
// Args are pre-loaded into rcx/rdx/rax (Maxon internal ABI). The callee
// returns its value in r8; the caller is responsible for moving r8 → rax
// if it wants the result there.
function helperEmitDirectCall(code ByteArray, callFixups CallFixupArray, target String)
	emitCallFixup(code, callFixups: callFixups, target: target)
end 'helperEmitDirectCall'

// test reg, reg (uses REX.W 85 /r).
function helperTestReg(code ByteArray, reg X64Register)
	emitTestRegRegOp(code, reg1: reg, reg2: reg)
end 'helperTestReg'

// cmp reg, imm
function helperCmpRegImm(code ByteArray, reg X64Register, value MachineWord)
	emitCmpRegImmOp(code, lhs: reg, value: value)
end 'helperCmpRegImm'

// jcc with placeholder, recorded as a BlockJumpFixup.
function helperEmitCondJump(code ByteArray, state Win32HelperState, opcode CondJumpOpcode, targetBlock BlockId)
	code.push(0x0F)
	code.push(opcode)
	state.blockFixups.push(BlockJumpFixup.create(code.count(), targetBlockId: targetBlock))
	writeDword(code, value: 0)
end 'helperEmitCondJump'

// Unconditional jmp rel32 placeholder, recorded as a BlockJumpFixup.
function helperEmitJmp(code ByteArray, state Win32HelperState, targetBlock BlockId)
	code.push(0xE9)
	state.blockFixups.push(BlockJumpFixup.create(code.count(), targetBlockId: targetBlock))
	writeDword(code, value: 0)
end 'helperEmitJmp'

// Finalize: resolve all per-helper block fixups.
function helperFinalize(state Win32HelperState, code ByteArray)
	resolveBlockFixups(code, blockOffsets: state.blockOffsets, blockFixups: state.blockFixups)
end 'helperFinalize'

// Return helper: move return value (in src) to r8, then epilogue.
function helperReturn(code ByteArray, src X64Register)
	if regCode(src) != regCode(X64Register.r8) or isExtended(src) != isExtended(X64Register.r8) 'mov'
		emitMovRegRegOp(code, dest: X64Register.r8, src: src)
	end 'mov'
	helperEpilogue(code)
end 'helperReturn'

// Return helper: load value from slot, then epilogue with r8.
function helperReturnFromSlot(code ByteArray, slotIndex VarSlot)
	helperLoadSlot(code, slotIndex: slotIndex, dest: X64Register.r8)
	helperEpilogue(code)
end 'helperReturnFromSlot'

// Return helper: load imm into r8, then epilogue.
function helperReturnImm(code ByteArray, value MachineWord)
	helperMovRegImm(code, dest: X64Register.r8, value: value)
	helperEpilogue(code)
end 'helperReturnImm'

// =============================================================================
// Top-level driver: emit every hand-rolled `mrt_win32_*` helper.
// =============================================================================

function emitX64Win32Helpers(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	emitX64Win32TranslateLasterror(code, relocations: relocations, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Write(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Read(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Close(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Lseek(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Unlink(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Mkdir(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Access(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Stat(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Getcwd(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Open(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32Getdents64(code, relocations: relocations, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	// Phase B3: argv / executable-path helpers. These access lazy-init
	// globals (`__mrt_win32_argv_init_done`, `__mrt_win32_argc`,
	// `__mrt_win32_argv_cache_ptr`) registered by
	// `registerSlabAndMmGlobalsForDataSection`, so they need the
	// `rdataRelocs` array to record .data displacement fixups.
	emitX64Win32GetArgc(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32GetArgv(code, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64Win32GetExecutablePath(code, relocations: relocations, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
end 'emitX64Win32Helpers'

// =============================================================================
// 1. mrt_win32_translate_lasterror — calls GetLastError (IAT 27),
// then maps Win32 error codes to POSIX errno-style negative values.
// Stack layout:
//   slot 0 = masked Win32 error code
// Outgoing-arg area: 32 bytes (GetLastError takes 0 args; we still need
// shadow space).
// Block plan (ids):
//   0: entry
//   1: success                (-> ret 0)
//   2: check_enoent_2
//   3: check_enoent_3
//   4: ret_enoent             (-> ret -2)
//   5: check_eacces_5
//   6: check_eacces_32
//   7: ret_eacces             (-> ret -13)
//   8: check_eexist_80
//   9: check_eexist_183
//  10: ret_eexist             (-> ret -17)
//  11: ret_eio                (-> ret -5)
// =============================================================================
function emitX64Win32TranslateLasterror(code ByteArray, relocations RelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_translate_lasterror", offset: helperStart)

	// Frame: 1 slot (slot 0) + 32 bytes shadow.
	// localBytes = 8, outgoingBytes = 32. Total = 40, aligned to 16 = 48.
	let frameSize = 48
	var state = Win32HelperState.create(12, outgoingBytes: 32, localBytes: 8)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: entry — GetLastError; mask; storeSlot 0.
	helperMarkBlock(state, code: code, blockId: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	// rax &= 0xFFFFFFFF — use mov eax, eax (zero-extends to 64 bits in 2 bytes).
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)

	// if (slot 0 == 0) goto block 1 (success), else block 2.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ block 1
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	// jmp block 2
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 1: success — ret 0.
	helperMarkBlock(state, code: code, blockId: 1)
	helperReturnImm(code, value: 0)

	// Block 2: check_enoent_2.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 2)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: check_enoent_3.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 3)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: ret_enoent — ret -2.
	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -2)

	// Block 5: check_eacces_5.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 5)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: check_eacces_32.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 32)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 8)

	// Block 7: ret_eacces — ret -13.
	helperMarkBlock(state, code: code, blockId: 7)
	helperReturnImm(code, value: -13)

	// Block 8: check_eexist_80.
	helperMarkBlock(state, code: code, blockId: 8)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 80)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 9)

	// Block 9: check_eexist_183.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 183)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 11)

	// Block 10: ret_eexist — ret -17.
	helperMarkBlock(state, code: code, blockId: 10)
	helperReturnImm(code, value: -17)

	// Block 11: ret_eio — ret -5.
	helperMarkBlock(state, code: code, blockId: 11)
	helperReturnImm(code, value: -5)

	helperFinalize(state, code: code)
end 'emitX64Win32TranslateLasterror'

// =============================================================================
// 2. mrt_win32_write(wrapperBlock, bufPtr, count)
// Internal ABI: rcx=wrapper, rdx=bufPtr, rax=count.
// Stack:
//   slot 0 = wrapper
//   slot 1 = HANDLE
//   slot 2 = bytes-written DWORD (out-param to WriteFile)
//   slot 3 = WriteFile BOOL
// Outgoing-arg area: WriteFile takes 5 args → 32 + 8 = 40 → 48 bytes.
// Block plan:
//   0: entry
//   1: fail   (-> tailcall mrt_win32_translate_lasterror)
//   2: ok     (-> ret slot 2 masked)
// =============================================================================
function emitX64Win32Write(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_write", offset: helperStart)

	// 4 slots × 8 = 32 bytes locals + 48 outgoing = 80, aligned to 16 = 80.
	let frameSize = 80
	let outgoingBytes = 48
	var state = Win32HelperState.create(3, outgoingBytes: outgoingBytes, localBytes: 32)

	helperPrologue(code, frameSize: frameSize)

	// Save wrapper/buf/count into slots 0..(unused-but-keep-in-regs):
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	// Save bufPtr (rdx) and count (rax) into a stack home in case we need them
	// across the IAT call.
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	// HANDLE = wrapper[8].
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	// slot 2 = 0 (bytesWritten out-param).
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// Call WriteFile(handle, buf, count, &bytesWritten, NULL).
	// rcx=handle, rdx=buf, r8=count, r9=&bytesWritten, [rsp+32]=NULL.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.r8)
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.writeFile))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// if (slot 3 == 0) goto fail else ok.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 1: fail — tailcall translate_lasterror, return its result.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	// Callee returns its value in r8 (internal ABI). Use it directly.
	helperEpilogue(code)

	// Block 2: ok — return slot 2 masked to 32 bits.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	// mov eax, eax — zero-extends.
	code.append(b"\x89\xc0")
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Write'

// =============================================================================
// 3. mrt_win32_read — identical structure to write, calls ReadFile.
// =============================================================================
function emitX64Win32Read(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_read", offset: helperStart)

	let frameSize = 80
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 32)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.r8)
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.readFile))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	code.append(b"\x89\xc0")
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Read'

// =============================================================================
// 4. mrt_win32_close(wrapper) — dispatch on wrapper[0]:
//   kind 0 (file)      → CloseHandle(wrapper[8])
//   kind 1 (directory) → FindClose(wrapper[8])
// Always mm_decrefs the wrapper. Skips when wrapper == 0 or wrapper == -1.
// Block plan:
//   0: entry
//   1: check_neg_one
//   2: load_kind
//   3: close_find
//   4: close_handle
//   5: free_wrapper
//   6: done
// =============================================================================
function emitX64Win32Close(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_close", offset: helperStart)

	// 2 slots (slot 0 wrapper, slot 1 kind) = 16; outgoing 32. Total 48.
	let frameSize = 48
	var state = Win32HelperState.create(7, outgoingBytes: 32, localBytes: 16)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: entry.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	// if (wrapper == 0) goto done else check_neg_one.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: check_neg_one.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: load_kind.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 4)

	// Block 3: close_find — FindClose(wrapper[8]).
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findClose))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: close_handle — CloseHandle(wrapper[8]).
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 5: free_wrapper — call mm_decref(wrapper).
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: done — return 0.
	helperMarkBlock(state, code: code, blockId: 6)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Close'

// =============================================================================
// 5. mrt_win32_lseek(wrapper, offset, whence)
// rcx=wrapper, rdx=offset, rax=whence.
// Stack:
//   slot 0 = wrapper
//   slot 1 = offset
//   slot 2 = whence
//   slot 3 = HANDLE
//   slot 4 = new position (LARGE_INTEGER out-param)
//   slot 5 = SetFilePointerEx BOOL
// Outgoing-arg area: 4-arg call = 32. Frame: 6*8 + 32 = 80.
// =============================================================================
function emitX64Win32Lseek(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_lseek", offset: helperStart)

	let frameSize = 80
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 48)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	// SetFilePointerEx(handle, distance, &newPos, moveMethod).
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r8)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setFilePointerEx))
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Lseek'

// =============================================================================
// 6. mrt_win32_unlink(cStringPtr)
// rcx=cstr. Converts UTF-8 → UTF-16 via MultiByteToWideChar, calls DeleteFileW.
// Stack:
//   slot 0 = cstr ptr
//   slot 1 = DeleteFileW BOOL
//   slots 11..267 = wide path (1024 wchars × 2 = 2048 bytes)
// Outgoing-arg area for MBTWC = 6 args → 32 + 16 = 48; DeleteFileW = 1 arg → 32.
// Frame: 268*8 + 48 = 2192, aligned to 16 = 2192.
// =============================================================================
function emitX64Win32Unlink(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_unlink", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide, 1024).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// DeleteFileW(&wide).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.deleteFileW))
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Unlink'

// =============================================================================
// 7. mrt_win32_mkdir(cStringPtr, mode)
// rcx=cstr, rdx=mode (ignored). CreateDirectoryW(cstr, NULL).
// =============================================================================
function emitX64Win32Mkdir(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_mkdir", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)

	// MultiByteToWideChar.
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// CreateDirectoryW(&wide, NULL).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createDirectoryW))
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Mkdir'

// =============================================================================
// 8. mrt_win32_access(cStringPtr, mode)
// rcx=cstr, rdx=mode. Calls GetFileAttributesExW; if W_OK requested, checks
// FILE_ATTRIBUTE_READONLY.
// Stack:
//   slot 0 = cstr
//   slot 1 = mode
//   slot 2 = GetFileAttributesExW BOOL
//   slot 3 = scratch
//   slots 11..267 = wide path
//   slots 50..54  = WIN32_FILE_ATTRIBUTE_DATA (5 qwords)
// Block plan:
//   0: entry
//   1: fail
//   2: check_write
//   3: verify_writable
//   4: fail_eacces
//   5: ok
// =============================================================================
function emitX64Win32Access(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_access", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(6, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide, 1024).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// GetFileAttributesExW(&wide, GetFileExInfoStandard=0, &data).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.r8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getFileAttributesExW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	// if (mode & 2) goto verify_writable else ok.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 2)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ goes to block 5 (ok), else fall through to block 3.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 3)

	helperMarkBlock(state, code: code, blockId: 3)
	// scratch = data.dwFileAttributes & 0xFFFFFFFF; if (scratch & 1) → eacces else ok.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	// mov eax, eax — zero-extend.
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → ok, JNZ → fail_eacces.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 4)

	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -13)

	helperMarkBlock(state, code: code, blockId: 5)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Access'

// =============================================================================
// 9. mrt_win32_stat(cStringPtr, statBufPtr)
// Translates Win32 file attributes to Linux struct stat layout.
// rcx=cstr, rdx=statBufPtr.
// Stack:
//   slot 0 = cstr
//   slot 1 = statBuf
//   slot 2 = GetFileAttributesExW BOOL
//   slot 3 = scratch
//   slots 11..267 = wide path
//   slots 50..54  = WIN32_FILE_ATTRIBUTE_DATA
// Block plan:
//   0: entry
//   1: fail
//   2: ok / mode-decision-prep
//   3: set_dir
//   4: set_reg
//   5: add_writable
//   6: mark_writable
//   7: write_mode (final writes + ret 0)
// =============================================================================
function emitX64Win32Stat(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_stat", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(8, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// MultiByteToWideChar.
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// GetFileAttributesExW.
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.r8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getFileAttributesExW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	// statBuf[24] = 0 (st_mode zero).
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 24, src: X64Register.rax)

	// scratch = data[0] & 0xFFFFFFFF.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// if (scratch & 0x10) goto set_dir else set_reg.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0x10)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → set_reg, else set_dir.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 3)

	helperMarkBlock(state, code: code, blockId: 3)
	// set_dir: scratch = 16384.
	helperMovRegImm(code, dest: X64Register.rax, value: 16384)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 4)
	// set_reg: scratch = 32768.
	helperMovRegImm(code, dest: X64Register.rax, value: 32768)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 5)
	// if ((data[0] & 0xFFFFFFFF) & 1) == 0 goto mark_writable else write_mode.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → mark_writable, JNZ → write_mode.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 7)

	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 128)
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 7)

	helperMarkBlock(state, code: code, blockId: 7)
	// statBuf[24] = slot 3.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 24, src: X64Register.rax)

	// size = (data[28]u32 << 32) | (data[32]u32).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 28)
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rdx, value: 32)
	// shl rax, cl (rdx -> cl) — actually we need to mov rcx, rdx then shl rax, cl.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rdx)
	emitShlRegClParam(code, reg: X64Register.rax)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 32)
	code.append(b"\x89\xc0")
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 48, src: X64Register.rax)

	// mtime: data[20] (qword) - 116444736000000000 / 10000000 → statBuf[88].
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 20)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	// Divide by 10000000 — use idiv. Set up: cqo; idiv rcx where rcx=10000000.
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	// cqo: 0x48 0x99.
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 88, src: X64Register.rax)

	// ctime: data[4] (qword).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 4)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 104, src: X64Register.rax)

	// atime: data[12] (qword).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 12)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 72, src: X64Register.rax)

	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Stat'

// =============================================================================
// 10. mrt_win32_getcwd(bufPtr, bufSize)
// Stack:
//   slot 0 = buf
//   slot 1 = bufSize
//   slot 2 = GetCurrentDirectoryW wchar count
//   slot 3 = WideCharToMultiByte byte count
//   slots 11..267 = wide buffer
// Block plan:
//   0: entry
//   1: check_too_big
//   2: fail
//   3: fail_oversized
//   4: convert
//   5: nul_terminate
// =============================================================================
function emitX64Win32Getcwd(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_getcwd", offset: helperStart)

	// WideCharToMultiByte = 8 args → 32 + 4*8 = 64.
	let frameSize = 2208
	var state = Win32HelperState.create(6, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// GetCurrentDirectoryW(1024, &wide).
	helperMovRegImm(code, dest: X64Register.rcx, value: 1024)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rdx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getCurrentDirectoryW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → fail.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 1)

	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1024)
	// JG (signed greater) → fail_oversized.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 4)

	helperMarkBlock(state, code: code, blockId: 2)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 3)
	helperReturnImm(code, value: -36)

	helperMarkBlock(state, code: code, blockId: 4)
	// WideCharToMultiByte(65001, 0, &wide, wcharLen, buf, bufSize-1, NULL, NULL).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.r8)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 5)
	// buf[byteCount] = 0.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	// return buf.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Getcwd'

// =============================================================================
// 11. mrt_win32_open(cstr, flags, fileMode)
// rcx=cstr, rdx=flags, rax=fileMode (ignored).
// See runtime.std body for full details. Block plan:
//   0: entry
//   1: invalid_path  (-> ret -22)
//   2: check_dir_flag
//   3: file_branch
//   4: file_read
//   5: file_write
//   6: after_createfile
//   7: file_fail
//   8: file_ok
//   9: dir_branch
//  10: dir_fail
//  11: dir_ok
// =============================================================================
function emitX64Win32Open(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_open", offset: helperStart)

	// CreateFileW = 7 args → 32 + 24 = 56, aligned 64. Outgoing = 64.
	let frameSize = 2208
	var state = Win32HelperState.create(12, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	// param 2 (rax) is ignored.

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide[267], 1024).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperReturnImm(code, value: -22)

	helperMarkBlock(state, code: code, blockId: 2)
	// if (flags & 65536) goto dir_branch else file_branch.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65536)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → file_branch, JNZ → dir_branch.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 9)

	helperMarkBlock(state, code: code, blockId: 3)
	// if (flags & 1) → file_write, else file_read.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → file_read.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 4)
	// CreateFileW(path, GENERIC_READ=0x80000000, FILE_SHARE_READ=1, NULL, OPEN_EXISTING=3, FILE_ATTRIBUTE_NORMAL=0x80, NULL).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x80000000)
	helperMovRegImm(code, dest: X64Register.r8, value: 1)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 3)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x80)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)

	helperMarkBlock(state, code: code, blockId: 5)
	// CreateFileW(path, GENERIC_WRITE=0x40000000, 0, NULL, CREATE_ALWAYS=2, FILE_ATTRIBUTE_NORMAL=0x80, NULL).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x40000000)
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 2)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x80)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)

	helperMarkBlock(state, code: code, blockId: 6)
	// if HANDLE == -1 → file_fail else file_ok.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 8)

	helperMarkBlock(state, code: code, blockId: 7)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 8)
	// Allocate 16-byte wrapper: rcx = 16; call mrt_alloc. Result in r8.
	helperMovRegImm(code, dest: X64Register.rcx, value: 16)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	// r8 = wrapper pointer; move to rax for storeSlot 2.
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// wrapper[0] = 0, wrapper[8] = HANDLE.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 9)
	// Allocate 616-byte wrapper.
	helperMovRegImm(code, dest: X64Register.rcx, value: 616)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// FindFirstFileW(pattern=&wide[267], &wrapper[24]).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: 24)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findFirstFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 11)

	helperMarkBlock(state, code: code, blockId: 10)
	// mm_decref(wrapper); return translate_lasterror.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 11)
	// wrapper[0] = 1, wrapper[8] = HANDLE, wrapper[16] = 1.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Open'

// =============================================================================
// 12. mrt_win32_getdents64(wrapper, buf, bufSize)
// Most complex helper. Iterates FindNextFileW, packs Linux dirent64 entries
// into caller-supplied buffer.
// Stack layout per runtime.std:
//   slot 0 = wrapper
//   slot 1 = buf
//   slot 2 = bufSize
//   slot 3 = cursor
//   slot 4 = HANDLE
//   slot 5 = pending flag
//   slot 6 = FindNextFileW BOOL
//   slot 7 = utf-8 byte count
//   slot 8 = reclen
//   slot 9 = attribute word
//   slot 10 = name UTF-8 length
//   slot 11 = entry base (overlaps wide-buffer space but legal — see runtime.std)
//   stackAddr 267 = UTF-8 scratch buffer
// Block plan:
//   0: entry
//   1: emit_loop
//   2: call_find_next
//   3: check_no_more_files
//   4: end_of_iteration
//   5: find_next_error
//   6: mark_pending
//   7: process_entry
//   8: maybe_single_dot
//   9: check_double_dot
//  10: maybe_double_dot
//  11: check_second_dot
//  12: consume_entry
//  13: emit_entry
//  14: return_partial
//  15: write_entry
//  16: set_dir_type
//  17: set_reg_type
//  18: copy_name
// =============================================================================
function emitX64Win32Getdents64(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_getdents64", offset: helperStart)

	// WideCharToMultiByte = 8 args → outgoing 64. Frame: 2144 + 64 = 2208.
	let frameSize = 2208
	var state = Win32HelperState.create(19, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: emit_loop.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 16)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1)
	// JE → process_entry (block 7).
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: call_find_next.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: 24)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findNextFileW))
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → check_no_more_files, JNZ → mark_pending.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 3: check_no_more_files.
	helperMarkBlock(state, code: code, blockId: 3)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	// mask to 32 bits.
	code.append(b"\x89\xc0")
	helperCmpRegImm(code, reg: X64Register.rax, value: 18)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: end_of_iteration.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)
	helperEpilogue(code)

	// Block 5: find_next_error.
	helperMarkBlock(state, code: code, blockId: 5)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	// Block 6: mark_pending.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 7)

	// Block 7: process_entry.
	helperMarkBlock(state, code: code, blockId: 7)
	// WideCharToMultiByte(65001, 0, &wrapper[68], -1, &scratch[267], 1024, 0, 0).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	emitAddRegImmParam(code, dest: X64Register.r8, value: 68)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)

	// if slot 7 == 2 → maybe_single_dot else check_double_dot.
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 2)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 8)
	helperEmitJmp(code, state: state, targetBlock: 9)

	// Block 8: maybe_single_dot.
	helperMarkBlock(state, code: code, blockId: 8)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 9: check_double_dot.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 3)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 10: maybe_double_dot.
	helperMarkBlock(state, code: code, blockId: 10)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 11)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 11: check_second_dot.
	helperMarkBlock(state, code: code, blockId: 11)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 1)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 12: consume_entry — wrapper[16] = 0; jump to emit_loop.
	helperMarkBlock(state, code: code, blockId: 12)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 13: emit_entry.
	helperMarkBlock(state, code: code, blockId: 13)
	// nameLen = byteCount - 1.
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	// reclen = ((nameLen + 20) + 7) & ~7.
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	emitAddRegImmParam(code, dest: X64Register.rax, value: 27)
	helperMovRegImm(code, dest: X64Register.rcx, value: -8)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)

	// if (cursor + reclen > bufSize) → return_partial.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JG (signed) → return_partial.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 14)
	helperEmitJmp(code, state: state, targetBlock: 15)

	// Block 14: return_partial — return cursor.
	helperMarkBlock(state, code: code, blockId: 14)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)
	helperEpilogue(code)

	// Block 15: write_entry.
	helperMarkBlock(state, code: code, blockId: 15)
	// entry = buf + cursor → slot 11.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 11, src: X64Register.rax)

	// entry[0] = 0; entry[8] = 0; entry[16] = reclen.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)

	// attribute = wrapper[24] & 0xFFFFFFFF.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 24)
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 9, src: X64Register.rax)
	// if (attribute & 0x10) → set_dir_type else set_reg_type.
	helperLoadSlot(code, slotIndex: 9, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0x10)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 17)
	helperEmitJmp(code, state: state, targetBlock: 16)

	// Block 16: set_dir_type — entry[18] = 4.
	helperMarkBlock(state, code: code, blockId: 16)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 4)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 18, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 18)

	// Block 17: set_reg_type — entry[18] = 8.
	helperMarkBlock(state, code: code, blockId: 17)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 8)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 18, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 18)

	// Block 18: copy_name.
	helperMarkBlock(state, code: code, blockId: 18)
	// memcpy(entry+19, scratch, nameLen).
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)
	emitAddRegImmParam(code, dest: X64Register.rdi, value: 19)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rsi)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)
	// rep movsb.
	code.append(b"\xf3\xa4")

	// entry[19+nameLen] = 0.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 19)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)

	// cursor += reclen.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// wrapper[16] = 0.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)

	helperEmitJmp(code, state: state, targetBlock: 1)

	helperFinalize(state, code: code)
end 'emitX64Win32Getdents64'

// =============================================================================
// 13. mrt_win32_get_argc — 0 args, returns argc.
//
// Lazy-initialized cache. First call:
//   1. GetCommandLineW (IAT 12) → LPCWSTR
//   2. CommandLineToArgvW(cmdLine, &argc) (IAT 29) → LPWSTR*; argc in out-param
//   3. Store argc into `__mrt_win32_argc` global.
//   4. mrt_alloc(argc*8) → store into `__mrt_win32_argv_cache_ptr`.
//   5. For i in 0..argc:
//        - wstr = wargv[i]
//        - byteSize = WideCharToMultiByte(CP_UTF8, 0, wstr, -1, NULL, 0, NULL, NULL) (IAT 14)
//        - utf8buf = mrt_alloc(byteSize)
//        - argv_cache_ptr[i*8] = utf8buf
//        - WideCharToMultiByte(CP_UTF8, 0, wstr, -1, utf8buf, byteSize, NULL, NULL) (IAT 14)
//   6. LocalFree(wargv) (IAT 13)
//   7. Set `__mrt_win32_argv_init_done` = 1.
//
// Subsequent calls: short-circuit on the init flag and return cached argc.
//
// Stack:
//   slot 0 = cmdLineW       (LPCWSTR from GetCommandLineW)
//   slot 1 = argc           (out-param for CommandLineToArgvW; also holds final argc)
//   slot 2 = wargv          (LPWSTR* from CommandLineToArgvW)
//   slot 3 = i              (loop index)
//   slot 4 = byteSize       (WideCharToMultiByte query result)
//   slot 5 = utf8buf        (per-iteration UTF-8 buffer pointer)
//   slot 6 = wstr           (current wargv[i] pointer)
//
// Outgoing: WCTMB has 8 args → 32 shadow + 32 stack = 64 bytes.
// Frame: 7 slots * 8 = 56 + 64 outgoing = 120, aligned to 16 = 128.
//
// Block plan:
//   0: entry — check init flag; if set, jump to return_cached.
//   1: do_init — call GetCommandLineW + CommandLineToArgvW + store argc.
//   2: alloc_argv_array — call mrt_alloc(argc*8).
//   3: loop_head — if i >= argc, jump to loop_done.
//   4: loop_body — load wstr, query size, alloc buffer, store in cache, convert.
//   5: loop_done — LocalFree + set init_done.
//   6: return_cached — load argc into r8, epilogue.
// =============================================================================
function emitX64Win32GetArgc(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_argc", offset: helperStart)

	let frameSize = 128
	var state = Win32HelperState.create(7, outgoingBytes: 64, localBytes: 56)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: check init flag.
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_init_done")
	helperTestReg(code, reg: X64Register.rax)
	// JNZ → return_cached.
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: do_init. Call GetCommandLineW (IAT 12) → rax = LPCWSTR.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getCommandLineW))
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)

	// CommandLineToArgvW(cmdLine, &argc) (IAT 29 — shell32 slot). rcx=cmdLine, rdx=&argc.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.commandLineToArgvW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// Store argc to global. CommandLineToArgvW writes a 32-bit int into the
	// out-param; the upper 32 bits of the 8-byte slot are uninitialized stack
	// bytes. Mask via `mov eax, eax` (zero-extends 32 → 64) before storing.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	code.append(b"\x89\xc0")
	// Re-write the slot so the rest of the helper can use the 8-byte load
	// without masking again.
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argc")
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: alloc argv array (argc * 8 bytes).
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	// r8 = argv array → store as cache_ptr.
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")

	// i = 0.
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: loop head — if i >= argc, jump to loop_done.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JGE (signed greater-or-equal) → loop_done.
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 4)

	// Block 4: loop body.
	helperMarkBlock(state, code: code, blockId: 4)
	// wstr = wargv[i] = *(wargv + i*8). Compute address into rcx:
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	// Load *rcx → wstr.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)

	// Query UTF-8 byte size:
	//   WCTMB(CP_UTF8=65001, 0, wstr, -1, NULL, 0, NULL, NULL)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// Mask the 32-bit return to a clean 64-bit before stashing.
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	// Allocate UTF-8 buffer: mrt_alloc(byteSize, 0, 0).
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	// argv_cache_ptr[i*8] = utf8buf.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)

	// Convert: WCTMB(65001, 0, wstr, -1, utf8buf, byteSize, NULL, NULL).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))

	// i++.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitAddRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 5: loop_done — LocalFree(wargv) + set init flag.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.localFree))
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argv_init_done")
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: return_cached — load argc, move to r8, epilogue.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.r8, name: "__mrt_win32_argc")
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetArgc'

// =============================================================================
// 14. mrt_win32_get_argv(index) — returns raw UTF-8 C-string pointer for
// argv[index], or 0 if index is out of bounds.
//
// Lazy-init via direct call to `mrt_win32_get_argc` (which performs the
// cache build and ignores its return value here). Then:
//   if (index < 0 || index >= argc) return 0
//   else return *(argv_cache_ptr + index*8)
//
// rcx = index. Returns raw pointer in r8.
//
// Stack:
//   slot 0 = index
// Outgoing: get_argc has 0 args → 32 shadow.
// Frame: 1 slot (8) + 32 outgoing = 40, aligned 16 = 48.
//
// Block plan:
//   0: entry — save index, call get_argc.
//   1: bounds_check — compare index to argc.
//   2: out_of_bounds (-> ret 0)
//   3: in_bounds — load argv_cache_ptr[index*8], return.
// =============================================================================
function emitX64Win32GetArgv(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_argv", offset: helperStart)

	let frameSize = 48
	var state = Win32HelperState.create(4, outgoingBytes: 32, localBytes: 8)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: save index; call get_argc to ensure cache is built.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_get_argc")
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: bounds check. Treat negative index as out-of-bounds; argc is
	// non-negative, so a signed `index >= argc` comparison covers both
	// "negative index" and "index >= argc" in one branch (any negative i64
	// is < 0 <= argc, so the JL below catches negatives too).
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 0)
	// JL → out_of_bounds.
	helperEmitCondJump(code, state: state, opcode: 0x8C, targetBlock: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__mrt_win32_argc")
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JGE → out_of_bounds.
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 2: out_of_bounds → return 0.
	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	// Block 3: in_bounds — return *(cache_ptr + index*8).
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.rcx, disp: 0)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetArgv'

// =============================================================================
// 15. mrt_win32_get_executable_path(buf, bufSize) — writes UTF-8 path of the
// running executable into buf; returns bytes written (excluding NUL) or -34
// (-ERANGE) on truncation.
//
// Algorithm:
//   1. Stack-allocate a 4096-wchar (8192-byte) wide buffer.
//   2. GetModuleFileNameW(NULL, &wbuf, 4096) (IAT 15) → wcharCount.
//   3. WCTMB(CP_UTF8, 0, &wbuf, -1, NULL, 0, NULL, NULL) (IAT 14) → utf8ByteSize
//      (includes trailing NUL).
//   4. If utf8ByteSize > bufSize, return -34.
//   5. WCTMB(CP_UTF8, 0, &wbuf, -1, buf, bufSize, NULL, NULL) → bytes written
//      (including NUL).
//   6. Return bytesWritten - 1 (excluding the NUL).
//
// rcx = buf, rdx = bufSize. Returns count in r8.
//
// Stack:
//   slot 0 = buf
//   slot 1 = bufSize
//   slot 2 = utf8ByteSize (size query result)
//   slots 3..1026 = wide buffer (4096 wchars = 8192 bytes = 1024 slots).
// Outgoing: WCTMB has 8 args → 64 bytes.
// Frame: 3*8 + 8192 wide + 64 outgoing = 8280, aligned 16 = 8288.
//
// Block plan:
//   0: entry — save args.
//   1: get_module — GetModuleFileNameW into wide buf.
//   2: size_query — WCTMB to learn UTF-8 size.
//   3: check_fit — if utf8ByteSize > bufSize → too_big.
//   4: too_big (-> ret -34)
//   5: convert — WCTMB into caller buf; return bytes-1.
// =============================================================================
function emitX64Win32GetExecutablePath(code ByteArray, relocations RelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_executable_path", offset: helperStart)

	// localBytes layout: 3 fixed slots + 1024 wide-buf slots = 1027 * 8 = 8216.
	let frameSize = 8288
	let outgoingBytes = 64
	let localBytes = 8216
	var state = Win32HelperState.create(6, outgoingBytes: outgoingBytes, localBytes: localBytes)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: save args.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: GetModuleFileNameW(NULL, &wbuf, 4096).
	helperMarkBlock(state, code: code, blockId: 1)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.rdx)
	helperMovRegImm(code, dest: X64Register.r8, value: 4096)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getModuleFileNameW))
	// We ignore the wide-char count return; WCTMB with cchWideChar=-1 (NUL-
	// terminated) will measure from the buffer directly.
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: query UTF-8 byte size (including trailing NUL).
	helperMarkBlock(state, code: code, blockId: 2)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// WCTMB returns a 32-bit int; mask to a clean 64-bit value before the
	// signed compare in block 3.
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: if utf8ByteSize > bufSize → too_big.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JG (signed greater) → too_big.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: too_big.
	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -34)

	// Block 5: convert into caller buf.
	helperMarkBlock(state, code: code, blockId: 5)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// WCTMB returns 32-bit; mask to 64-bit clean before subtracting 1.
	code.append(b"\x89\xc0")
	// Return bytes written - 1 (excluding the NUL WCTMB appends).
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetExecutablePath'

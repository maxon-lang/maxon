	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 8)  // feed_launch
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)  // handle struct
	// Record payload copy + length so release_handle frees the copy.
	helperLoadSlot(code, slotIndex: 50, dest: X64Register.rax)  // payload copy
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffStdinPayloadPtr, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 51, dest: X64Register.rax)  // payload len
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffStdinPayloadLen, src: X64Register.rax)
	// feedCtx = __slab_alloc(FeedCtxSize); fill {hWrite, dataPtr, dataLen}.
	helperMovRegImm(code, dest: X64Register.rcx, value: SubpFeedCtxSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 52, src: X64Register.r8)  // feedCtx
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)  // handle struct
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffFeedCtxStdin, src: X64Register.r8)
	helperLoadSlot(code, slotIndex: 49, dest: X64Register.rax)  // parent write end (hWrite)
	helperStoreIndirect(code, base: X64Register.r8, disp: SubpFeedCtxOffHWrite, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 50, dest: X64Register.rax)  // payload copy
	helperStoreIndirect(code, base: X64Register.r8, disp: SubpFeedCtxOffDataPtr, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 51, dest: X64Register.rax)  // payload len
	helperStoreIndirect(code, base: X64Register.r8, disp: SubpFeedCtxOffDataLen, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)  // handle struct
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHStdinFeed, src: X64Register.rax)  // thread handle
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.r8)  // return the handle
	helperEmitJmp(code, state: state, targetBlock: 2)
	// CreateThread failed (OOM-class). Don't orphan the already-spawned child:
	// close the parent write end directly so the child sees EOF on stdin, then
	// return the live handle. release_handle still frees the recorded feedCtx +
	// payload copy; SubpOffHStdinFeed stays 0 (no thread handle to close).
	helperMarkBlock(state, code: code, blockId: 11)  // feed_no_thread
	helperLoadSlot(code, slotIndex: 49, dest: X64Register.rcx)  // parent write end
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.r8)  // return the handle
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // fail
	// Render GetLastError() into __subp_last_error_buf via FormatMessageA so the
	// reason carries the real Win32 diagnostic ("The system cannot find the file
	// specified", etc.). rbx (callee-saved) holds the code across the call.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getLastError))
	emitMovRegRegOp(code, dest: X64Register.rbx, src: X64Register.rax)
	// FormatMessageA has 7 args (4 reg + 3 stack at [rsp+0x20..+0x30]) → the
	// Enter/Leave system-stack pair. frameSize 0x40 = shadow(0x20) + 3 qwords,
	// rounded up to a 16-byte multiple so RSP stays 16-aligned at the call;
	// rbx (callee-saved, the saved error code) survives the system-stack switch.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	helperMovRegImm(code, dest: X64Register.rcx, value: 4608)  // FORMAT_MESSAGE_FROM_SYSTEM|IGNORE_INSERTS = 0x1200
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rbx)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpBuffer
	helperMovRegImm(code, dest: X64Register.rax, value: 512)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // nSize
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // Arguments = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.formatMessageA))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessSpawn'

// maxon_subprocess_detach(argv, argc, cwd, env, envInherit, stdinKind, stdinData,
//   stdoutKind, stdoutData, stdoutLimit, stderrKind, stderrData, stderrLimit,
//   flags) — same 14-arg layout as maxon_subprocess_spawn (rcx/rdx/rax/r9/rsi/rdi/
//   rbx, then [rbp+0x10..+0x40]). Spawns a child that runs INDEPENDENTLY of the
//   parent and returns (r8) its OS pid, or -1 on failure (the stdlib throws
//   spawnFailed when pid == -1).
//
// Unlike spawn, the child is fire-and-forget: all three std streams point at the
// NUL device (no capture pipes, no feed thread), there is no Job Object (so the
// child is not killed when the parent's handles close), no handle struct, and no
// wait. We read the pid straight from PROCESS_INFORMATION, CloseHandle the process
// + thread + the three NUL handles, free the cmdline scratch, and return the pid.
//
// dwCreationFlags mirror the C# bootstrap's EmitMaxonSubprocessDetach (which routes
// through spawn_core with the SpawnFlagDetach bit set): bit 0 → CREATE_NO_WINDOW,
// bit 1 → CREATE_NEW_PROCESS_GROUP, bit 2 → DETACHED_PROCESS|CREATE_NEW_PROCESS_GROUP.
// The stdlib always sets the detach bit, so DETACHED_PROCESS is always present. We
// deliberately omit the CREATE_SUSPENDED|EXTENDED_STARTUPINFO_PRESENT base the C#
// spawn_core adds — those only exist there to gate a child into the Job Object,
// which the detach path has none of.
//
// Frame (frameSize 576): slots 0/1 (argv/argc), 5 (cmdline), 6/7/8 (the three NUL
// handles to close post-spawn), 10 (computed dwCreationFlags), 11 (saved pid), then
// the zeroed Win32 struct regions reused from spawn — SECURITY_ATTRIBUTES
// (slots 13..15, base &slot15), STARTUPINFOEX (112 bytes, slots 18..31, base
// &slot31 — cb=112; lpAttributeList at SI+0x68 = slot18). PROCESS_INFORMATION is
// relocated to slots 54..56 (base &slot56; slot55 = PI+8 = hThread; slot54 =
// PI+0x10 = dwProcessId) so SI+0x68 no longer collides with the old PI base.
// New scratch: slot 53 = attrListPtr, slot 57 = attrListSize, 3-HANDLE inherit
// vector at slots 58..60 (base &slot60). outgoing 80 bytes covers the direct
// helper calls' shadow space; the CreateProcessW kernel call lands on the per-P
// system stack via Enter/Leave.
//
// Detach spawns the child with bInheritHandles=TRUE concurrently with the rest
// of the pool, so it inherits the same global-inherit-flag race; the explicit
// 3-NUL-handle inherit list (STARTUPINFOEX + EXTENDED_STARTUPINFO_PRESENT)
// scopes inheritance so a concurrent spawn can't leak its pipe ends into the
// detached child. Mirrors the sync/streaming spawn handle-list build.
function emitX64SubprocessDetach(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_detach", offset: code.count())
	// Blocks: 0 (entry), 1 (fail), 2 (done), the three dwCreationFlags bit-skip
	// targets (3 no_hide, 4 no_group, 5 no_detach), and the attribute-list build
	// joins (6 attr_init_ok, 7 attr_update_ok). localBytes 496 (16-aligned)
	// carries the new high slots 53..60; frameSize 576 = 496 local + 80 outgoing.
	var state = Win32HelperState.create(8, outgoingBytes: 80, localBytes: 496)
	helperPrologue(code, frameSize: 576)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // argv (MM struct ptr)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // argc
	// Zero the struct regions (slots 13..31 = 19 qwords, low address = &slot31).
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rdi)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperMovRegImm(code, dest: X64Register.rcx, value: 19)
	code.append(b"\xf3\x48\xab")  // rep stosq
	// cmdline = __subp_build_cmdline_wide(argv, argc)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_build_cmdline_wide")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 5, src: X64Register.r8)  // cmdline
	// SECURITY_ATTRIBUTES: nLength=24 @slot15, lpSD=0 @slot14, bInherit=1 @slot13.
	helperMovRegImm(code, dest: X64Register.rax, value: 24)
	helperStoreSlot(code, slotIndex: 15, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 14, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 13, src: X64Register.rax)
	// STARTUPINFOEX: cb=112 @slot31 (STARTUPINFOW(104) + lpAttributeList(8));
	// dwFlags=STARTF_USESTDHANDLES @SI+0x3C (unaligned).
	helperMovRegImm(code, dest: X64Register.rax, value: 112)
	helperStoreSlot(code, slotIndex: 31, src: X64Register.rax)
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rax)  // SI base
	helperMovRegImm(code, dest: X64Register.rcx, value: 256)  // STARTF_USESTDHANDLES = 0x100
	helperStoreIndirect(code, base: X64Register.rax, disp: 0x3C, src: X64Register.rcx)
	// stdin → fresh NUL handle (GENERIC_READ); closed post-spawn.
	helperMovRegImm(code, dest: X64Register.rcx, value: 2147483648)  // GENERIC_READ = 0x80000000
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_open_nul_wide")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 6, src: X64Register.r8)  // close after spawn
	helperStoreSlot(code, slotIndex: 21, src: X64Register.r8)  // SI.hStdInput (SI+0x50)
	// stdout → fresh NUL handle (GENERIC_WRITE); closed post-spawn.
	helperMovRegImm(code, dest: X64Register.rcx, value: 1073741824)  // GENERIC_WRITE = 0x40000000
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_open_nul_wide")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 7, src: X64Register.r8)  // close after spawn
	helperStoreSlot(code, slotIndex: 20, src: X64Register.r8)  // SI.hStdOutput (SI+0x58)
	// stderr → fresh NUL handle (GENERIC_WRITE); closed post-spawn.
	helperMovRegImm(code, dest: X64Register.rcx, value: 1073741824)  // GENERIC_WRITE = 0x40000000
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_open_nul_wide")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 8, src: X64Register.r8)  // close after spawn
	helperStoreSlot(code, slotIndex: 19, src: X64Register.r8)  // SI.hStdError (SI+0x60)
	// dwCreationFlags from the flags arg (arg14 @[rbp+0x40]). Mirror the C# bit map:
	//   bit 0 → CREATE_NO_WINDOW (0x08000000)
	//   bit 1 → CREATE_NEW_PROCESS_GROUP (0x200)
	//   bit 2 → DETACHED_PROCESS (0x08) | CREATE_NEW_PROCESS_GROUP (0x200)
	// Accumulate into slot 10 so it survives the system-stack switch below.
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)  // creationFlags = 0
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rbp, disp: 0x40)  // flags arg
	helperMovRegImm(code, dest: X64Register.rax, value: 1)  // SpawnFlag.hideWindow
	emitAndRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz no_hide
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rdx, value: 134217728)  // CREATE_NO_WINDOW = 0x08000000
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	helperMarkBlock(state, code: code, blockId: 3)  // no_hide
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rbp, disp: 0x40)  // flags arg
	helperMovRegImm(code, dest: X64Register.rax, value: 2)  // SpawnFlag.newProcessGroup
	emitAndRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz no_group
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rdx, value: 512)  // CREATE_NEW_PROCESS_GROUP = 0x200
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	helperMarkBlock(state, code: code, blockId: 4)  // no_group
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rbp, disp: 0x40)  // flags arg
	helperMovRegImm(code, dest: X64Register.rax, value: 4)  // SpawnFlag.detach
	emitAndRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz no_detach
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rdx, value: 520)  // DETACHED_PROCESS(0x08) | CREATE_NEW_PROCESS_GROUP(0x200)
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	helperMarkBlock(state, code: code, blockId: 5)  // no_detach
	// OR EXTENDED_STARTUPINFO_PRESENT (0x80000) into the computed dwCreationFlags
	// so the kernel reads SI as a STARTUPINFOEX and honors the explicit inherit
	// list built below.
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rdx, value: 524288)  // EXTENDED_STARTUPINFO_PRESENT = 0x00080000
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	// ===== Build PROC_THREAD_ATTRIBUTE_LIST with HANDLE_LIST (mirrors the sync
	// spawn). SI stdio (the three NUL handles, slots 21/20/19) are already final.
	// Blocks 6/7 are this function's success-continuation IDs; the fail target is
	// block 1. See emitX64SubprocessBuildAttrList for the full slot contract.
	emitX64SubprocessBuildAttrList(code, state: state, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, attrInitOkBlock: 6, attrUpdateOkBlock: 7, failBlock: 1)
	// CreateProcessW(NULL, cmdline, NULL, NULL, TRUE, creationFlags, NULL, NULL, &SI, &PI).
	// creationFlags already carries EXTENDED_STARTUPINFO_PRESENT (set above).
	// >4 args → the per-P system stack via Enter/Leave (frameSize 0x50 = shadow(0x20)
	// + 6 qwords). rbp-relative slot reads below stay on the GT stack (only RSP moves);
	// register args are set after Enter, which clobbers rax/r11.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x50)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // bInheritHandles = TRUE
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // dwCreationFlags
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // lpEnvironment = NULL
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)  // lpCurrentDirectory = NULL
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 64, srcReg: X64Register.rax)  // lpStartupInfo = &SI
	helperLeaStackSlot(code, slotIndex: 56, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 72, srcReg: X64Register.rax)  // lpProcessInformation = &PI
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)  // lpApplicationName = NULL
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rdx)  // lpCommandLine
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createProcessW))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x50)
	// Tear down the attribute list (success or fail); preserve CreateProcessW's
	// BOOL in slot 57 across the Delete+free, then reload.
	helperStoreSlot(code, slotIndex: 57, src: X64Register.rax)
	emitX64FreeAttrList(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, slotIndex: 53)
	helperLoadSlot(code, slotIndex: 57, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	// Success: read the pid from PI+0x10 (dwProcessId | dwThreadId<<32); zero-extend
	// the low dword and stash it for the return.
	helperLoadSlot(code, slotIndex: 54, dest: X64Register.rax)  // PI+0x10 = slot54
	code.append(b"\x89\xc0")  // mov eax, eax — keep only dwProcessId
	helperStoreSlot(code, slotIndex: 11, src: X64Register.rax)  // saved pid
	// CloseHandle the process + thread handles (the child runs on; we just drop our
	// references) and the three NUL handles (the child kept its own inheritable
	// copies). The handles outlive nothing here — there is no wait and no struct.
	helperLoadSlot(code, slotIndex: 56, dest: X64Register.rcx)  // PI.hProcess (PI+0 = slot56)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 55, dest: X64Register.rcx)  // PI.hThread (PI+8 = slot55)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rcx)  // NUL stdin
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rcx)  // NUL stdout
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)  // NUL stderr
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	// Free the cmdline scratch and return the pid.
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.r8)  // pid
	helperEmitJmp(code, state: state, targetBlock: 2)  // done
	helperMarkBlock(state, code: code, blockId: 1)  // fail
	// Render GetLastError() into __subp_last_error_buf via FormatMessageA so the
	// reason carries the real Win32 diagnostic. rbx (callee-saved) holds the code
	// across the call. Mirrors emitX64SubprocessSpawn's fail block.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getLastError))
	emitMovRegRegOp(code, dest: X64Register.rbx, src: X64Register.rax)
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	helperMovRegImm(code, dest: X64Register.rcx, value: 4608)  // FORMAT_MESSAGE_FROM_SYSTEM|IGNORE_INSERTS = 0x1200
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rbx)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpBuffer
	helperMovRegImm(code, dest: X64Register.rax, value: 512)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // nSize
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // Arguments = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.formatMessageA))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessDetach'

// __subp_feed_thread(feedCtx) — Win32 thread proc (lpParameter arrives in rcx).
// Writes the staged stdin payload into the child's stdin pipe, then closes the
// write end so the child sees EOF. A single WriteFile loop handles arbitrarily
// large payloads (Windows pipes block when full; the child's read unblocks us).
//
// This runs on its OWN OS thread (CreateThread gave it a real OS stack), NOT a
// green thread, so it has no per-P scheduler binding — its WriteFile/CloseHandle
// go through DIRECT IAT calls (helperEmitIatCall), never the GT system-stack
// dance. It reads the three FeedCtx fields ONCE into locals at entry and never
// touches the ctx again, so release_handle is free to __slab_free the ctx as
// soon as the thread has closed hWrite (no use-after-free even if the thread has
// not fully returned). Ownership: the thread closes hWrite; release_handle frees
// the ctx + payload copy and closes the thread handle.
//
// Slots: 0=ctx (unused after load), 1=hWrite, 2=dataPtr, 3=remaining, 4=bytesWritten.
// Mirrors the C# EmitMaxonSubprocessFeedThreadEntry.
function emitX64SubprocessFeedThreadEntry(code ByteArray, relocations RelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_feed_thread", offset: code.count())
	// outgoing 0x30 covers WriteFile's 5 args (shadow 0x20 + lpOverlapped @ +0x20);
	// local 0x30 holds the 5 slots. frameSize 0x60 keeps the stack 16-aligned for
	// the direct IAT calls.
	var state = Win32HelperState.create(3, outgoingBytes: 0x30, localBytes: 0x30)
	helperPrologue(code, frameSize: 0x60)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // ctx
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: SubpFeedCtxOffHWrite)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)  // hWrite
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: SubpFeedCtxOffDataPtr)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // dataPtr
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: SubpFeedCtxOffDataLen)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // remaining
	helperMarkBlock(state, code: code, blockId: 1)  // feed_loop
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // remaining
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz feed_done
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // bytesWritten = 0
	// WriteFile(hWrite, dataPtr, remaining, &bytesWritten, NULL).
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // hWrite
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // dataPtr
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)  // remaining (low DWORD used)
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r9)  // &bytesWritten
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // lpOverlapped = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.writeFile))
	code.append(b"\x89\xc0")  // mov eax, eax — clear the dirty high half before the 64-bit test
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz feed_done (write error)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // bytesWritten
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz feed_done (0 bytes → avoid spin)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // dataPtr += written
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // remaining -= written
	emitSubRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)
	helperMarkBlock(state, code: code, blockId: 2)  // feed_done
	// Close the write end so the child sees EOF on its stdin.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // hWrite
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperMovRegImm(code, dest: X64Register.rax, value: 0)  // thread proc returns DWORD 0
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessFeedThreadEntry'

// __subp_drain_pipe(readHandle=rcx, outLenPtr=rdx) → a `__slab_alloc`'d buffer
// holding everything read from `readHandle` until EOF, with the byte count
// written to [outLenPtr]; returns 0 on allocation failure. MINIMAL: a fixed
// 64 KB buffer read after the child exits (the read-after-wait model only works
// for small output; concurrent drain threads land with the async path). Slots:
// 0=readHandle, 1=outLenPtr, 2=buf, 3=total, 4=nRead.
function emitX64SubprocessDrainPipe(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_drain_pipe", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 40)
	helperPrologue(code, frameSize: 96)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // readHandle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // outLenPtr
	helperMovRegImm(code, dest: X64Register.rcx, value: 65536)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)  // buf (0 on alloc failure)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // total = 0
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz done (return 0, len 0)
	helperMarkBlock(state, code: code, blockId: 1)  // loop
	// remaining = 65536 - total; stop if full.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 65536)
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 2)  // jge done (full)
	// ReadFile(readHandle, buf + total, 65536 - total, &nRead, NULL)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rdx, src: X64Register.rax)  // buf + total
	helperMovRegImm(code, dest: X64Register.r8, value: 65536)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitSubRegRegParam(code, dest: X64Register.r8, src: X64Register.rax)  // 65536 - total
	// Zero the full 8-byte nRead slot first: ReadFile writes only the low DWORD
	// (lpNumberOfBytesRead), so without this the high 4 bytes keep stale stack
	// garbage and the qword `test`/`add` below would over-count. The bug stays
	// latent on a clean-EOF drain but corrupts on the timeout-kill path, where the
	// ERROR_BROKEN_PIPE ReadFile leaves those high bytes dirty.
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // nRead = 0
	// __subp_drain_pipe runs synchronously inside wait_collect, i.e. on the caller
	// (green) thread — NOT on a dedicated OS thread — so ReadFile must go on the
	// per-P system stack. 5 args (4 reg + lpOverlapped at [rsp+0x20]) → the
	// Enter/Leave pair (frameSize 0x30 = shadow + 1 stack arg, 16-aligned). &nRead
	// is computed into r9 before Enter and survives the RSP switch (Enter touches
	// only rax/r10/r11); rcx/rdx/r8 were set above and likewise survive.
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r9)  // &nRead
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpOverlapped = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.readFile))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	code.append(b"\x89\xc0")  // mov eax, eax — ReadFile's BOOL is in EAX; clear the dirty high half before the 64-bit test
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz done (EOF/broken pipe)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // nRead (slot pre-zeroed → high bytes clean)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz done (0 bytes)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)  // total += nRead
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	// [outLenPtr] = total; return buf.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // outLenPtr
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // total
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)  // buf (0 if alloc failed → slot2 untouched = 0? set below)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessDrainPipe'

// maxon_subprocess_wait_collect(handle=rcx, timeoutMs=rdx) → a heap result
// struct, or -1 on failure. WaitForSingleObject (timeout-aware) → on WAIT_TIMEOUT
// TerminateJobObject the tree → drain stdout/stderr (read-after-wait) →
// GetExitCodeProcess; reports timedOut(124) on timeout, else exited(code).
// (signalled decoding lands later.) Slots: 0=handle, 1=timeout, 2=stdoutBuf,
// 3=stdoutLen, 4=stderrBuf, 5=stderrLen, 6=result, 7=waitResult, 8=exitCode.
function emitX64SubprocessWaitCollect(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	emitX64SubprocessDrainPipe(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_wait_collect", offset: code.count())
	var state = Win32HelperState.create(7, outgoingBytes: 48, localBytes: 80)
	helperPrologue(code, frameSize: 128)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // timeout
	// WaitForSingleObject(handle.hProcess, timeout<=0 ? INFINITE : timeout)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHProcess)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperCmpRegImm(code, reg: X64Register.rdx, value: 0)
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 1)  // jg wait (timeout > 0)
	helperMovRegImm(code, dest: X64Register.rdx, value: 4294967295)  // INFINITE = 0xFFFFFFFF
	helperMarkBlock(state, code: code, blockId: 1)  // wait
	// Blocking wait on the per-P system stack (default wait model). On a worker P
	// this blocks that P's OS thread until the child exits, but other Ps keep
	// running their own GTs/children — so N async children run in parallel (one per
	// P), matching the file-I/O / sleep "block heavy calls on the system stack"
	// pattern. ≤4 args → emitX64GtIatCallOnSystemStack.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	code.append(b"\x89\xc0")  // mov eax, eax — WaitForSingleObject returns a DWORD; zero the high half before the 64-bit cmp
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)  // waitResult (0=WAIT_OBJECT_0, 0x102=WAIT_TIMEOUT)
	// On WAIT_TIMEOUT, kill the whole job tree before draining. The child (and
	// its descendants — e.g. `cmd /c ping ...`) hold the stdout/stderr pipes
	// open; without the kill, __subp_drain_pipe's ReadFile blocks until their
	// natural exit. TerminateJobObject(hJob, 1) closes those handles so ReadFile
	// hits EOF. Skipped when the wait completed normally or when there is no Job.
	helperCmpRegImm(code, reg: X64Register.rax, value: 258)  // WAIT_TIMEOUT = 0x102
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 4)  // jne no_kill
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHJob)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz no_kill (no Job)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)  // uExitCode for killed tree
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.terminateJobObject))
	helperMarkBlock(state, code: code, blockId: 4)  // no_kill
	// Drain stdout: buf = __subp_drain_pipe(handle.hStdoutRead, &stdoutLen)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHStdoutRead)
	helperLeaStackSlot(code, slotIndex: 3, dest: X64Register.rdx)  // &stdoutLen
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_drain_pipe")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)  // stdoutBuf
	// Drain stderr.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHStderrRead)
	helperLeaStackSlot(code, slotIndex: 5, dest: X64Register.rdx)  // &stderrLen
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_drain_pipe")
	helperStoreSlot(code, slotIndex: 4, src: X64Register.r8)  // stderrBuf
	// GetExitCodeProcess(handle.hProcess, &exitCode@slot8)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHProcess)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)  // clear exitCode slot (DWORD write below)
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rdx)  // &exitCode
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getExitCodeProcess))
	// Allocate + zero the result struct.
	helperMovRegImm(code, dest: X64Register.rcx, value: SubpResultStructSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz fail
	helperStoreSlot(code, slotIndex: 6, src: X64Register.r8)
	emitMovRegRegOp(code, dest: X64Register.rdi, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperMovRegImm(code, dest: X64Register.rcx, value: SubpResultStructSize / 8)
	code.append(b"\xf3\x48\xab")  // rep stosq
	// Populate status: timedOut(2)/124 on WAIT_TIMEOUT, else exited(0)/exitCode.
	// The struct is already zeroed, so the exited path only writes statusCode
	// (statusKind stays 0); the timedOut path writes both. The stdlib throws on
	// the timedOut kind and ignores statusCode there, so 124 is just a sentinel.
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rdi)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)  // waitResult
	helperCmpRegImm(code, reg: X64Register.rax, value: 258)  // WAIT_TIMEOUT = 0x102
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // je timedout_status
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)  // exitCode
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStatusCode, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)  // status_done
	helperMarkBlock(state, code: code, blockId: 5)  // timedout_status
	helperMovRegImm(code, dest: X64Register.rax, value: 2)  // ResultStatusKind.timedOut
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStatusKind, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 124)  // sentinel statusCode (unused by stdlib)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStatusCode, src: X64Register.rax)
	helperMarkBlock(state, code: code, blockId: 6)  // status_done
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStdoutPtr, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStdoutLen, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStderrPtr, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffStderrLen, src: X64Register.rax)
	// durationMs = GetTickCount64() - handle.startTime
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getTickCount64))
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: SubpOffStartTime)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rdi)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpResOffDurationMs, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)  // return the result
	helperEmitJmp(code, state: state, targetBlock: 3)
	helperMarkBlock(state, code: code, blockId: 2)  // fail
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_wait_failed", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 3)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessWaitCollect'

// Emit one "CloseHandle the handle-struct field if non-zero, then null it"
// step inside maxon_subprocess_release_handle. The handle-struct pointer lives
// in slot `handleSlot`; `skipBlock` is the per-field block reached when the
// field is already null (so a double-release is a no-op). release_handle runs on
// whoever called Subprocess.run — a green thread under `async` — so CloseHandle
// goes through the per-P system stack (emitX64GtIatCallOnSystemStack), which
// self-gates to a direct call on the main thread. Mirrors the C#
// EmitSubprocessCloseHandleField.
function emitX64SubpReleaseCloseHandleField(state Win32HelperState, code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, handleSlot VarSlot, fieldOff MachineWord, skipBlock BlockId)
	helperLoadSlot(code, slotIndex: handleSlot, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: fieldOff)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: skipBlock)  // jz skip (already null)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))  // CloseHandle(rcx)
	helperLoadSlot(code, slotIndex: handleSlot, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperStoreIndirect(code, base: X64Register.rax, disp: fieldOff, src: X64Register.rcx)  // null the slot
	helperMarkBlock(state, code: code, blockId: skipBlock)
end 'emitX64SubpReleaseCloseHandleField'

// Emit one "__slab_free the struct field if non-zero, then null it" step. Used
// both by maxon_subprocess_release_handle (the drain/feed/line buffers and the
// drain/feed context records) and by maxon_subprocess_result_release (the
// captured stdout/stderr buffers transferred into the result struct) — every
// such field is allocated with __slab_alloc by the synchronous runtime (the C#
// backend VirtualAlloc's its drain buffers, hence its VirtualFree; the
// self-hosted runtime's __subp_drain_pipe uses __slab_alloc, so the matching
// deallocator is __slab_free). `handleSlot` holds the struct pointer (handle
// struct or result struct); `skipBlock` is reached when the field is already
// null/empty.
function emitX64SubpReleaseSlabFreeField(state Win32HelperState, code ByteArray, callFixups CallFixupArray, handleSlot VarSlot, fieldOff MachineWord, skipBlock BlockId)
	helperLoadSlot(code, slotIndex: handleSlot, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: fieldOff)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: skipBlock)  // jz skip (already null)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")  // __slab_free(rcx)
	helperLoadSlot(code, slotIndex: handleSlot, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperStoreIndirect(code, base: X64Register.rax, disp: fieldOff, src: X64Register.rcx)  // null the slot
	helperMarkBlock(state, code: code, blockId: skipBlock)
end 'emitX64SubpReleaseSlabFreeField'

// maxon_subprocess_release_handle(handle=rcx) — close every OS handle the spawn
// recorded and free every buffer/context still owned by the handle struct, then
// free the struct itself. Void. Null-guarded (a null handle returns
// immediately) and idempotent (each field is nulled after release, so a second
// call is a no-op). Mirrors the C# EmitMaxonSubprocessReleaseHandle.
//
// The handle struct + all its buffers/contexts are __slab_alloc'd by the
// synchronous spawn/wait path, so they free with __slab_free (not VirtualFree —
// the C# backend's drain buffers are VirtualAlloc'd, which is why it VirtualFrees
// them; ours are not). The Job handle is closed LAST so that, once the Job's
// last handle drops, JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE can tear down any
// still-running descendants after the process handle is already gone.
//
// In the current minimal spawn only hProcess/hStdoutRead/hStderrRead are
// populated; the remaining handle/buffer/context fields are zero and their
// release steps no-op. They are released here unconditionally (guarded by the
// per-field null check) so the function is already correct as the later phases
// (Job object, drain/feed threads, stdin feed, streaming line buffers) populate
// those fields.
//
// Block plan: block 0 (entry / null-guard), then 8 CloseHandle skip blocks
// (1..8), then 8 __slab_free skip blocks (9..16), then block 17 (done).
function emitX64SubprocessReleaseHandle(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_release_handle", offset: code.count())
	let doneBlock = 17
	var state = Win32HelperState.create(doneBlock + 1, outgoingBytes: 32, localBytes: 8)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: doneBlock)  // jz done (null handle)
	// CloseHandle each live OS handle (skip blocks 1..8); Job handle LAST.
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHProcess, skipBlock: 1)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStdoutRead, skipBlock: 2)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStderrRead, skipBlock: 3)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStdinWrite, skipBlock: 4)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStdoutDrain, skipBlock: 5)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStderrDrain, skipBlock: 6)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHStdinFeed, skipBlock: 7)
	emitX64SubpReleaseCloseHandleField(state, code: code, relocations: relocations, rdataRelocs: rdataRelocs, handleSlot: 0, fieldOff: SubpOffHJob, skipBlock: 8)
	// Free any still-owned drain/feed buffers + context records (skip blocks
	// 9..16). Only present when wait_collect hasn't transferred them into a
	// result struct; once it has, these slots are null and the steps no-op.
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffStdoutBufPtr, skipBlock: 9)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffStderrBufPtr, skipBlock: 10)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffStdinPayloadPtr, skipBlock: 11)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffDrainCtxStdout, skipBlock: 12)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffDrainCtxStderr, skipBlock: 13)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffFeedCtxStdin, skipBlock: 14)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffHStdoutLineBufPtr, skipBlock: 15)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpOffHStderrLineBufPtr, skipBlock: 16)
	// Free the handle struct itself.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: doneBlock)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessReleaseHandle'

// maxon_subprocess_result_release(result=rcx) — free the captured stdout/stderr
// buffers transferred in from the handle by wait_collect, then free the result
// struct. Void. Null-guarded and idempotent. The captured buffers are the
// __slab_alloc'd drain buffers wait_collect moved into the result struct, so
// they free with the shared emitX64SubpReleaseSlabFreeField step (a null field
// is a no-op — wait_collect stores a null pointer for empty output, not a shared
// sentinel, so the plain null check covers it). Mirrors the C#
// EmitMaxonSubprocessResultRelease.
//
// Block plan: block 0 (entry / null-guard), block 1 (stdout skip), block 2
// (stderr skip), block 3 (done).
function emitX64SubprocessResultRelease(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_result_release", offset: code.count())
	let doneBlock = 3
	var state = Win32HelperState.create(doneBlock + 1, outgoingBytes: 32, localBytes: 8)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // result
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: doneBlock)  // jz done (null result)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpResOffStdoutPtr, skipBlock: 1)
	emitX64SubpReleaseSlabFreeField(state, code: code, callFixups: callFixups, handleSlot: 0, fieldOff: SubpResOffStderrPtr, skipBlock: 2)
	// Free the result struct itself.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: doneBlock)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessResultRelease'

// =============================================================================
// Streaming subprocess API (StreamingSubprocess — `stdlib/Subprocess.maxon`).
// The streaming child keeps all three pipes open on the parent side so the
// caller drives stdin (writeStdinLine) and stdout/stderr (readStdoutLine /
// readStderrLine) by hand over the child's lifetime. Unlike the sync
// run-collect path there is no feed thread and no read-after-wait drain: the
// readers ReadFile on demand and the writer WriteFiles on demand, all blocking
// on the per-P system stack (the self-hosted backend has no overlapped-pipe /
// IOCP machinery; a blocking call on the system stack is the same wait model as
// the sync wait_collect and sleep). The C# bootstrap uses named overlapped
// pipes + IOCP so green threads yield during pipe I/O; the self-hosted runtime
// instead uses anonymous CreatePipe pipes + blocking ReadFile/WriteFile routed
// through emitX64GtIatCallOnSystemStack — when a streaming op blocks on a worker
// P, that P's OS thread blocks but the other Ps keep running their own GTs (the
// same "block heavy calls on the system stack" property the parallel worker
// pool relies on for the sync path). The streaming handle reuses the SAME
// handle struct (and the SAME release_handle) as the sync path: hStdoutRead /
// hStderrRead / hStdinWrite are the parent ends; the per-stream line pushback
// buffers live in SubpOffH{Stdout,Stderr}LineBuf{Ptr,Len}, which release_handle
// already __slab_free's.
// =============================================================================

// maxon_subprocess_spawn_streaming(argv=rcx, argc=rdx, cwd=rax, flags=r9) →
// (r8) a heap handle struct, or -1 on failure. Creates three anonymous pipes
// (stdin: parent writes / child reads; stdout & stderr: child writes / parent
// reads), strips inheritance off each parent-side end, builds STARTUPINFOW with
// the three child ends, CreateProcessW + a kill-on-close Job Object (reused from
// the sync spawn), and returns the handle owning the three parent-side handles.
// No feed/drain threads (streaming reads/writes on demand). Mirrors the C#
// EmitMaxonSubprocessSpawnStreaming (which calls __subp_spawn_core with noDrain=1).
//
// Frame (frameSize 576): scalar/pointer slots 0..12 + handle-struct slot 48,
// then the zeroed Win32 struct regions — SECURITY_ATTRIBUTES (slots 13..15,
// base &slot15), STARTUPINFOEX (112 bytes, slots 18..31, base &slot31 — cb=112;
// lpAttributeList at SI+0x68 = slot18), and the JOBOBJECT_EXTENDED_LIMIT_INFOR-
// MATION scratch (112 bytes, slots 32..45, base &slot45). Mirrors the
// emitX64SubprocessSpawn STARTUPINFOEX handle-list fix: PROCESS_INFORMATION is
// relocated to slots 54..56 (base &slot56; slot55 = PI+8 = hThread; slot54 =
// PI+0x10 = dwProcessId) so SI+0x68 no longer collides with the old PI base.
// New scratch: slot 53 = attrListPtr, slot 57 = attrListSize, 3-HANDLE inherit
// vector at slots 58..60 (base &slot60 = vec[0]=hStdInput; slot59 = hStdOutput;
// slot58 = hStdError). This is the path the test dispatcher's 12-worker pool
// spawns through concurrently, so the explicit inherit list closes the same
// cross-spawn handle-leak race the sync spawn does.
function emitX64SubprocessSpawnStreaming(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_spawn_streaming", offset: code.count())
	// Blocks: 0 (entry), 1 (fail), 2 (done), 3 (job_done), 4 (attr_init_ok),
	// 5 (attr_update_ok). localBytes 496 (16-aligned) carries the new high slots
	// 53..60; frameSize 576 = 496 local + 80 outgoing, 16-aligned.
	var state = Win32HelperState.create(6, outgoingBytes: 80, localBytes: 496)
	helperPrologue(code, frameSize: 576)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // argv (MM struct ptr)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // argc
	// flags (param 3) is unused by the streaming runtime today (streaming spawns
	// never detach and take no platform-options — the stdlib always passes 0);
	// read it for completeness so a future flags-bearing variant has it staged.
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r9)  // flags
	// Zero the struct regions (slots 13..31 = 19 qwords, low address = &slot31).
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rdi)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperMovRegImm(code, dest: X64Register.rcx, value: 19)
	code.append(b"\xf3\x48\xab")  // rep stosq
	// cmdline = __subp_build_cmdline_wide(argv, argc)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_build_cmdline_wide")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 5, src: X64Register.r8)  // cmdline
	// SECURITY_ATTRIBUTES: nLength=24 @slot15, lpSD=0 @slot14, bInherit=1 @slot13.
	helperMovRegImm(code, dest: X64Register.rax, value: 24)
	helperStoreSlot(code, slotIndex: 15, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 14, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 13, src: X64Register.rax)
	// STARTUPINFOEX: cb=112 @slot31 (STARTUPINFOW(104) + lpAttributeList(8));
	// dwFlags=STARTF_USESTDHANDLES @SI+0x3C.
	helperMovRegImm(code, dest: X64Register.rax, value: 112)
	helperStoreSlot(code, slotIndex: 31, src: X64Register.rax)
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rax)  // SI base
	helperMovRegImm(code, dest: X64Register.rcx, value: 256)  // STARTF_USESTDHANDLES = 0x100
	helperStoreIndirect(code, base: X64Register.rax, disp: 0x3C, src: X64Register.rcx)
	// stdin pipe: CreatePipe(&hStdinRead@6, &hStdinWrite@7, &SA, 0). SA.bInherit=1
	// makes BOTH ends inheritable; strip inheritance off the parent WRITE end so
	// only the child inherits the read end. The parent write end stays open for
	// writeStdinLine; close_stdin / release_handle close it.
	helperLeaStackSlot(code, slotIndex: 6, dest: X64Register.rcx)  // &hStdinRead (child)
	helperLeaStackSlot(code, slotIndex: 7, dest: X64Register.rdx)  // &hStdinWrite (parent)
	helperLeaStackSlot(code, slotIndex: 15, dest: X64Register.r8)  // &SA
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.createPipe))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rcx)  // parent write end
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)  // HANDLE_FLAG_INHERIT
	helperMovRegImm(code, dest: X64Register.r8, value: 0)  // clear → not inherited
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setHandleInformation))
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)  // child read end
	helperStoreSlot(code, slotIndex: 21, src: X64Register.rax)  // SI.hStdInput
	// stdout pipe: CreatePipe(&hStdoutRead@8, &hStdoutWrite@9, &SA, 0). Strip
	// inheritance off the parent READ end.
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 15, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.createPipe))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setHandleInformation))
	helperLoadSlot(code, slotIndex: 9, dest: X64Register.rax)
	helperStoreSlot(code, slotIndex: 20, src: X64Register.rax)  // SI.hStdOutput = child write end
	// stderr pipe: CreatePipe(&hStderrRead@10, &hStderrWrite@11, &SA, 0). Strip
	// inheritance off the parent READ end.
	helperLeaStackSlot(code, slotIndex: 10, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 11, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 15, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.createPipe))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setHandleInformation))
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rax)
	helperStoreSlot(code, slotIndex: 19, src: X64Register.rax)  // SI.hStdError = child write end
	// ===== Build PROC_THREAD_ATTRIBUTE_LIST with HANDLE_LIST (mirrors the sync
	// spawn). The stdio handles are now final in SI (slots 21/20/19), so the inherit
	// vector reads the child-visible handles. Must run BEFORE CreateProcessW. Blocks
	// 4/5 are this function's success-continuation IDs; the fail target is block 1.
	// See emitX64SubprocessBuildAttrList for the full slot contract.
	emitX64SubprocessBuildAttrList(code, state: state, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, attrInitOkBlock: 4, attrUpdateOkBlock: 5, failBlock: 1)
	// CreateProcessW(NULL, cmdline, NULL, NULL, TRUE, EXTENDED_STARTUPINFO_PRESENT,
	//   NULL, NULL, &SI, &PI). >4 args → the per-P system stack via Enter/Leave.
	// frameSize 0x50 = shadow + 6 qwords. EXTENDED_STARTUPINFO_PRESENT (0x80000)
	// makes the kernel read SI as STARTUPINFOEX and honor the explicit inherit list.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x50)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // bInheritHandles = TRUE
	helperMovRegImm(code, dest: X64Register.rax, value: 524288)  // EXTENDED_STARTUPINFO_PRESENT = 0x00080000
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // dwCreationFlags
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // lpEnvironment = NULL
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)  // lpCurrentDirectory = NULL
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 64, srcReg: X64Register.rax)  // lpStartupInfo = &SI
	helperLeaStackSlot(code, slotIndex: 56, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 72, srcReg: X64Register.rax)  // lpProcessInformation = &PI
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)  // lpApplicationName = NULL
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rdx)  // lpCommandLine
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createProcessW))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x50)
	// Tear down the attribute list (success or fail); preserve CreateProcessW's
	// BOOL in slot 57 across the Delete+free, then reload.
	helperStoreSlot(code, slotIndex: 57, src: X64Register.rax)
	emitX64FreeAttrList(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, slotIndex: 53)
	helperLoadSlot(code, slotIndex: 57, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	// Job Object (best-effort; identical to the sync spawn) so close_stdin /
	// release_handle (Job closed LAST + JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE) tears
	// down a child that outlives the parent's interest.
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)  // lpJobAttributes = NULL
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)  // lpName = NULL
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.createJobObjectW))
	helperStoreSlot(code, slotIndex: 12, src: X64Register.rax)  // hJob (0 on failure)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz job_done
	helperLeaStackSlot(code, slotIndex: 45, dest: X64Register.rdi)  // info struct base
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperMovRegImm(code, dest: X64Register.rcx, value: 14)  // 112 / 8 qwords
	code.append(b"\xf3\x48\xab")  // rep stosq
	helperLeaStackSlot(code, slotIndex: 45, dest: X64Register.rdi)
	helperMovRegImm(code, dest: X64Register.rax, value: 8192)  // JOB_OBJECT_LIMIT_KILL_ON_JOB_CLOSE = 0x2000
	helperStoreIndirect(code, base: X64Register.rdi, disp: 0x10, src: X64Register.rax)  // LimitFlags
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rcx)  // hJob
	helperMovRegImm(code, dest: X64Register.rdx, value: 9)  // JobObjectExtendedLimitInformation
	helperLeaStackSlot(code, slotIndex: 45, dest: X64Register.r8)  // &info
	helperMovRegImm(code, dest: X64Register.r9, value: 112)  // sizeof(info)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setInformationJobObject))
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rcx)  // hJob
	helperLoadSlot(code, slotIndex: 56, dest: X64Register.rdx)  // PI.hProcess (PI+0 = slot56)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.assignProcessToJobObject))
	helperMarkBlock(state, code: code, blockId: 3)  // job_done
	// Close the child-side handles the parent no longer needs: child stdin READ
	// end, child stdout WRITE end, child stderr WRITE end, and PI.hThread. The
	// parent keeps hStdinWrite (slot 7), hStdoutRead (slot 8), hStderrRead (slot 10).
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rcx)  // child stdin read end
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 9, dest: X64Register.rcx)  // child stdout write end
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)  // child stderr write end
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadSlot(code, slotIndex: 55, dest: X64Register.rcx)  // PI.hThread (PI+8 = slot55)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	// Free the cmdline scratch.
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// Allocate + zero the handle struct.
	helperMovRegImm(code, dest: X64Register.rcx, value: SubpHandleStructSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz fail
	helperStoreSlot(code, slotIndex: 48, src: X64Register.r8)
	emitMovRegRegOp(code, dest: X64Register.rdi, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperMovRegImm(code, dest: X64Register.rcx, value: SubpHandleStructSize / 8)
	code.append(b"\xf3\x48\xab")  // rep stosq
	// Populate the handle struct. hStdinWrite / hStdoutRead / hStderrRead are the
	// parent ends the streaming ops drive; release_handle closes all three (+ the
	// per-stream line pushback buffers, lazily allocated by the readers).
	helperLoadSlot(code, slotIndex: 48, dest: X64Register.rdi)
	helperLoadSlot(code, slotIndex: 56, dest: X64Register.rax)  // PI.hProcess (PI+0 = slot56)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHProcess, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 54, dest: X64Register.rax)  // PI+0x10 = slot54 (dwProcessId | dwThreadId<<32)
	code.append(b"\x89\xc0")  // mov eax, eax — keep only dwProcessId
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffPid, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)  // hStdinWrite (parent)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHStdinWrite, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)  // hStdoutRead (parent)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHStdoutRead, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)  // hStderrRead (parent)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHStderrRead, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rax)  // hJob (0 if Job setup failed)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffHJob, src: X64Register.rax)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getTickCount64))  // rax = ticks
	helperLoadSlot(code, slotIndex: 48, dest: X64Register.rdi)
	helperStoreIndirect(code, base: X64Register.rdi, disp: SubpOffStartTime, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 48, dest: X64Register.r8)  // return the handle
	helperEmitJmp(code, state: state, targetBlock: 2)  // done
	helperMarkBlock(state, code: code, blockId: 1)  // fail
	// Render GetLastError() into __subp_last_error_buf via FormatMessageA (same as
	// the sync spawn). rbx (callee-saved) holds the code across the call.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getLastError))
	emitMovRegRegOp(code, dest: X64Register.rbx, src: X64Register.rax)
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	helperMovRegImm(code, dest: X64Register.rcx, value: 4608)  // FROM_SYSTEM|IGNORE_INSERTS = 0x1200
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rbx)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpBuffer
	helperMovRegImm(code, dest: X64Register.rax, value: 512)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // nSize
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // Arguments = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.formatMessageA))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_last_error_buf", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessSpawnStreaming'

// maxon_subprocess_write_stdin_all(handle=rcx, dataMm=rdx) → (r8) 0 on a full
// write, -1 on error (null handle, stdin already closed, or WriteFile failure;
// sets __subp_last_error). dataMm is the __ManagedMemory buffer pointer (a
// UTF-8 cstring — the stdlib passes `withNewline.cstr()`); strlen recovers the
// byte count. WriteFile loops until every byte is out, blocking on the per-P
// system stack. Mirrors the C# EmitMaxonSubprocessWriteStdinAll (minus the
// overlapped-pipe path — anonymous-pipe blocking writes suffice here).
// Slots: 0=handle, 1=data, 2=cursor, 3=remaining, 4=hStdinWrite, 5=bytesWritten.
function emitX64SubprocessWriteStdinAll(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_write_stdin_all", offset: code.count())
	// Blocks: 0 (entry), 1 (strlen_loop), 2 (strlen_end), 3 (write_loop),
	// 4 (ok), 5 (bad), 6 (done). outgoing 48 covers WriteFile's 5 args
	// (shadow 0x20 + lpOverlapped at [rsp+0x20]).
	var state = Win32HelperState.create(7, outgoingBytes: 48, localBytes: 48)
	helperPrologue(code, frameSize: 96)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // data (MM buffer ptr / cstring)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz bad (null handle)
	// hStdinWrite = handle.hStdinWrite; if 0 (close_stdin already ran) → bad.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: SubpOffHStdinWrite)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz bad
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // hStdinWrite
	// cursor = data; if null data → ok. Otherwise strlen(data) → remaining.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // data
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz ok (null data)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // cursor = data
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rax)  // scan ptr
	helperMarkBlock(state, code: code, blockId: 1)  // strlen_loop
	helperLoadByte(code, dest: X64Register.rdx, base: X64Register.rcx, disp: 0)
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz strlen_end
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 1)
	helperMarkBlock(state, code: code, blockId: 2)  // strlen_end: remaining = scanPtr - data
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // data
	emitSubRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)  // remaining
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz ok (empty payload)
	helperMarkBlock(state, code: code, blockId: 3)  // write_loop
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // remaining
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz ok (all written)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // bytesWritten = 0 (zero high half for the qword read)
	// WriteFile(hStdinWrite, cursor, remaining, &bytesWritten, NULL). 5 args (4
	// reg + lpOverlapped at [rsp+0x20]) → the Enter/Leave system-stack pair
	// (frameSize 0x30 = shadow + 1 stack arg, 16-aligned). &bytesWritten is
	// computed into r9 before Enter and survives the RSP switch.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)  // hStdinWrite
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // cursor
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)  // remaining (low DWORD used)
	helperLeaStackSlot(code, slotIndex: 5, dest: X64Register.r9)  // &bytesWritten
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpOverlapped = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.writeFile))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	code.append(b"\x89\xc0")  // mov eax, eax — clear the dirty high half before the 64-bit test
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz bad (WriteFile failed)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)  // bytesWritten
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz bad (0 bytes = broken pipe → avoid spin)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // cursor += written
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // remaining -= written
	emitSubRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 3)  // write_loop
	helperMarkBlock(state, code: code, blockId: 4)  // ok
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperEmitJmp(code, state: state, targetBlock: 6)  // done
	helperMarkBlock(state, code: code, blockId: 5)  // bad
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_invalid_handle", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 6)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessWriteStdinAll'

// maxon_subprocess_close_stdin(handle=rcx) — close the parent's write end of the
// child's stdin pipe so the child sees EOF, then null SubpOffHStdinWrite so
// release_handle's later close is a no-op (and a double close_stdin is harmless).
// Void. Mirrors the C# EmitMaxonSubprocessCloseStdin. Slots: 0=handle.
function emitX64SubprocessCloseStdin(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_close_stdin", offset: code.count())
	// Blocks: 0 (entry), 1 (done).
	var state = Win32HelperState.create(2, outgoingBytes: 32, localBytes: 8)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done (null handle)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: SubpOffHStdinWrite)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done (already closed)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeHandle))  // CloseHandle(rcx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // handle
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperStoreIndirect(code, base: X64Register.rax, disp: SubpOffHStdinWrite, src: X64Register.rcx)  // null the slot
	helperMarkBlock(state, code: code, blockId: 1)  // done
	helperMovRegImm(code, dest: X64Register.r8, value: 0)  // void
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessCloseStdin'

// maxon_subprocess_wait_exit(handle=rcx, timeoutMs=rdx) → (r8) the child's exit
// code (>= 0), -2 on timeout (the child is killed via the Job tree, matching
// wait_collect), or -1 on error (sets __subp_last_error). Unlike wait_collect
// this neither drains the pipes nor transfers buffers — the caller still owns the
// handle and the open pipes and calls release_handle when done. WaitForSingleObject
// + GetExitCodeProcess both block on the per-P system stack. Mirrors the C#
// EmitMaxonSubprocessWaitExit. Slots: 0=handle, 1=timeout, 2=waitResult, 3=exitCode.
function emitX64SubprocessWaitExit(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_wait_exit", offset: code.count())
	// Blocks: 0 (entry), 1 (wait), 2 (no_kill), 3 (timeout), 4 (bad), 5 (done).
	var state = Win32HelperState.create(6, outgoingBytes: 32, localBytes: 32)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // timeout
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz bad (null handle)
	// WaitForSingleObject(handle.hProcess, timeout<=0 ? INFINITE : timeout)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: SubpOffHProcess)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperCmpRegImm(code, reg: X64Register.rdx, value: 0)
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 1)  // jg wait (timeout > 0)
	helperMovRegImm(code, dest: X64Register.rdx, value: 4294967295)  // INFINITE = 0xFFFFFFFF
	helperMarkBlock(state, code: code, blockId: 1)  // wait
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	code.append(b"\x89\xc0")  // mov eax, eax — WaitForSingleObject returns a DWORD; zero the high half
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // waitResult
	// WAIT_FAILED = 0xFFFFFFFF → bad.
	helperCmpRegImm(code, reg: X64Register.rax, value: 4294967295)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // je bad
	// On WAIT_TIMEOUT kill the job tree (so the child + descendants die) and
	// report -2. Skipped when the wait completed or there is no Job.
	helperCmpRegImm(code, reg: X64Register.rax, value: 258)  // WAIT_TIMEOUT = 0x102
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jne no_kill
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHJob)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz timeout (no Job → still report timeout)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)  // uExitCode for the killed tree
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.terminateJobObject))
	helperEmitJmp(code, state: state, targetBlock: 3)  // timeout
	helperMarkBlock(state, code: code, blockId: 2)  // no_kill (completed normally)
	// GetExitCodeProcess(handle.hProcess, &exitCode@slot3)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // clear exitCode slot (DWORD write below)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: SubpOffHProcess)
	helperLeaStackSlot(code, slotIndex: 3, dest: X64Register.rdx)  // &exitCode
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getExitCodeProcess))
	code.append(b"\x89\xc0")  // mov eax, eax — clear the dirty high half before the 64-bit test
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz bad
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)  // exit code (slot pre-zeroed → DWORD clean)
	helperEmitJmp(code, state: state, targetBlock: 5)  // done
	helperMarkBlock(state, code: code, blockId: 3)  // timeout
	helperMovRegImm(code, dest: X64Register.r8, value: -2)
	helperEmitJmp(code, state: state, targetBlock: 5)  // done
	helperMarkBlock(state, code: code, blockId: 4)  // bad
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_wait_failed", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 5)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessWaitExit'

// __subp_rli_append(resultBufAddr=rcx, resultCapAddr=rdx, resultLenAddr=rax,
//   n=r9, src=rsi) → (r8) 1 on success, 0 on alloc failure. Appends n bytes from
// `src` to the caller's growable result buffer, growing (doubling, with a +1 NUL
// reserve) when needed. The three *Addr args point at the caller's buf/cap/len
// slots so the (possibly reallocated) buf + cap are written back in place. The
// result buffer is __slab_alloc'd (matching read_line_inner). Factored out of
// __subp_read_line_inner because the pushback-drain and ReadFile-loop phases each
// append. Mirrors the C# __subp_rli_append. Slots: 0=bufAddr, 1=capAddr,
// 2=lenAddr, 3=n, 4=src, 5=oldBuf, 6=newBuf, 7=newCap, 8=len.
function emitX64SubprocessReadLineAppend(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_rli_append", offset: code.count())
	// Blocks: 0 (entry), 1 (grow_check), 2 (have_room), 3 (fail), 4 (done).
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 72)
	helperPrologue(code, frameSize: 112)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // bufAddr
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // capAddr
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // lenAddr
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r9)  // n
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rsi)  // src
	helperMarkBlock(state, code: code, blockId: 1)  // grow_check: while (len + n + 1 > cap) grow
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // lenAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // len
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rcx)  // cache len
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // capAddr
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: 0)  // cap
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // n
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)  // len + n
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)  // need = len + n + 1
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rdx)  // cmp need, cap
	helperEmitCondJump(code, state: state, opcode: 0x86, targetBlock: 2)  // jbe have_room (need <= cap)
	// Grow: newCap = cap * 2 (at least; the loop re-checks). Allocate, copy len
	// bytes, free old, write back buf + cap.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // bufAddr
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rax, disp: 0)  // old buf
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // oldBuf
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // capAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // cap
	helperShlRegImm(code, dest: X64Register.rcx, value: 1)  // newCap = cap << 1
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rcx)  // newCap
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")  // rcx = newCap → r8 = buf
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz fail
	helperStoreSlot(code, slotIndex: 6, src: X64Register.r8)  // newBuf
	// memcpy(newBuf, oldBuf, len) via rep movsb
	emitMovRegRegOp(code, dest: X64Register.rdi, src: X64Register.r8)  // dst
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rsi)  // oldBuf src
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)  // len
	code.append(b"\xf3\xa4")  // rep movsb
	// free old buf
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// write back *bufAddr = newBuf ; *capAddr = newCap
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // bufAddr
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rcx)  // newBuf
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // capAddr
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rcx)  // newCap
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)  // re-check (one doubling may not suffice)
	helperMarkBlock(state, code: code, blockId: 2)  // have_room
	// memcpy(buf + len, src, n); *lenAddr = len + n
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // bufAddr
	helperLoadIndirect(code, dest: X64Register.rdi, base: X64Register.rax, disp: 0)  // buf
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // lenAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // len
	emitAddRegRegParam(code, dest: X64Register.rdi, src: X64Register.rcx)  // dst = buf + len
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rsi)  // src
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // n
	code.append(b"\xf3\xa4")  // rep movsb
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // lenAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // len
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rdx)  // n
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rdx)  // len + n
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)  // *lenAddr = len + n
	helperMovRegImm(code, dest: X64Register.r8, value: 1)  // success
	helperEmitJmp(code, state: state, targetBlock: 4)  // done
	helperMarkBlock(state, code: code, blockId: 3)  // fail
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMarkBlock(state, code: code, blockId: 4)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessReadLineAppend'

// __subp_read_line_inner(handle=rcx, hReadOff=rdx, lineBufPtrOff=rax,
//   lineBufLenOff=r9, maxBytes=rsi) → (r8) a fresh __ManagedMemory holding one
// line's bytes INCLUDING the trailing LF (the stdlib strips LF + a preceding CR),
// or a zero-length MM on EOF / error. read_stdout_line / read_stderr_line are
// thin wrappers that pin the stdout- or stderr-side field offsets.
//
// Buffered-reader contract: the handle carries a per-stream pushback buffer
// (the line-buffer fields) holding bytes ReadFile delivered past the most recent
// '\n'. Phase 1 drains the pushback into the result, scanning for '\n'; if found
// it splits there and stashes the tail back. Phase 2 loops blocking ReadFile +
// append, scanning each chunk for '\n'; the first '\n' terminates, any bytes past
// it become the new pushback. EOF / maxBytes / a read error fall out with whatever
// accumulated. ReadFile blocks on the per-P system stack. The pushback + result +
// chunk buffers are __slab_alloc'd; the pushback is owned by the handle (freed by
// release_handle), the chunk is freed here, the result is copied into the MM and
// freed here. Mirrors the C# __subp_read_line_inner (anonymous-pipe / blocking
// variant). Slots: 0=handle, 1=hReadOff, 2=lineBufPtrOff, 3=lineBufLenOff,
// 4=maxBytes, 5=hRead, 6=pushbackPtrAddr, 7=pushbackLenAddr, 8=resultBuf,
// 9=resultCap, 10=resultLen, 11=pushbackPtr, 12=pushbackLen, 13=chunkBuf,
// 14=nRead, 15=newlineIdx, 16=mm, 17=tailLen.
function emitX64SubprocessReadLineInner(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_read_line_inner", offset: code.count())
	// Blocks: 0 (entry), 1 (eof_initial), 2 (pb_scan), 3 (pb_nl), 4 (pb_no_nl),
	// 5 (pb_done), 6 (rf_loop), 7 (chunk_scan), 8 (chunk_nl), 9 (chunk_no_nl),
	// 10 (finish), 11 (done), 12 (oom), 13 (rf_read), 14 (pb_alloc),
	// 15 (oom_no_chunk), 16 (oom_no_result).
	var state = Win32HelperState.create(17, outgoingBytes: 48, localBytes: 152)
	helperPrologue(code, frameSize: 208)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // hReadOff
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // lineBufPtrOff
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r9)  // lineBufLenOff
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rsi)  // maxBytes
	// hRead = *(handle + hReadOff). Compute the byte address then load.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // handle
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // hReadOff
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // hRead
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz eof_initial (no read pipe)
	// pushbackPtrAddr = handle + lineBufPtrOff ; pushbackLenAddr = handle + lineBufLenOff.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)  // pushbackPtrAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // pushback ptr
	helperStoreSlot(code, slotIndex: 11, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)  // pushbackLenAddr
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: 0)  // pushback len
	helperStoreSlot(code, slotIndex: 12, src: X64Register.rcx)
	// result buf = __slab_alloc(128); cap = 128; len = 0.
	helperMovRegImm(code, dest: X64Register.rcx, value: 128)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz eof_initial (alloc fail → empty)
	helperStoreSlot(code, slotIndex: 8, src: X64Register.r8)  // result buf
	helperMovRegImm(code, dest: X64Register.rax, value: 128)
	helperStoreSlot(code, slotIndex: 9, src: X64Register.rax)  // cap
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)  // len
	helperStoreSlot(code, slotIndex: 13, src: X64Register.rax)  // chunk buf = 0 (so an oom before the chunk alloc lands doesn't __slab_free garbage)
	// chunk buf = __slab_alloc(4096).
	helperMovRegImm(code, dest: X64Register.rcx, value: 4096)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	helperStoreSlot(code, slotIndex: 13, src: X64Register.r8)  // chunk buf
	// ---- Phase 1: drain pushback ----
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rax)  // pushback len
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz pb_done (empty pushback)
	// scan pushback[0..len) for '\n'. rcx = index.
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperMarkBlock(state, code: code, blockId: 2)  // pb_scan
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rax)  // pushback len
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 4)  // jae pb_no_nl (index >= len)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rax)  // pushback ptr
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rdx, base: X64Register.rax, disp: 0)  // pushback[index]
	helperCmpRegImm(code, reg: X64Register.rdx, value: 10)  // '\n'
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // je pb_nl
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 3)  // pb_nl (newline at rcx)
	helperStoreSlot(code, slotIndex: 15, src: X64Register.rcx)  // newlineIdx
	// append pushback[0..newlineIdx+1] to result.
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rcx)  // &resultBuf
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)  // &resultCap
	helperLeaStackSlot(code, slotIndex: 10, dest: X64Register.rax)  // &resultLen
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.r9)  // newlineIdx
	emitAddRegImmParam(code, dest: X64Register.r9, value: 1)  // n = newlineIdx + 1
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rsi)  // src = pushback ptr
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_rli_append")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	// compact pushback: tailLen = len - (newlineIdx + 1); memmove front; len = tailLen.
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rax)  // pushback len
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.rcx)  // newlineIdx
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rax, value: -1)  // tailLen = len - newlineIdx - 1
	helperStoreSlot(code, slotIndex: 12, src: X64Register.rax)  // pushback len = tailLen
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)  // jz finish (no tail)
	// memmove(pushback, pushback + newlineIdx + 1, tailLen) — dst < src, forward rep movsb safe.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)  // dst = pushback start
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rsi)  // pushback
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.rcx)  // newlineIdx
	emitAddRegRegParam(code, dest: X64Register.rsi, src: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rsi, value: 1)  // src = pushback + newlineIdx + 1
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rcx)  // count = tailLen
	code.append(b"\xf3\xa4")  // rep movsb
	helperEmitJmp(code, state: state, targetBlock: 10)  // finish
	helperMarkBlock(state, code: code, blockId: 4)  // pb_no_nl
	// append whole pushback, then empty it, then ReadFile.
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rax)  // pushback len
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz pb_done
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.r9)  // n = pushback len
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rsi)  // src = pushback
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_rli_append")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 12, src: X64Register.rax)  // pushback len = 0
	helperMarkBlock(state, code: code, blockId: 5)  // pb_done
	// ---- Phase 2: ReadFile loop ----
	helperMarkBlock(state, code: code, blockId: 6)  // rf_loop
	// if maxBytes > 0 and resultLen >= maxBytes → finish.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // maxBytes
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 13)  // jz rf_read (no cap)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)  // resultLen
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rax)  // cmp len, maxBytes
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 10)  // jae finish (len >= maxBytes)
	helperMarkBlock(state, code: code, blockId: 13)  // rf_read
	// nRead = 0 (zero high half); ReadFile(hRead, chunkBuf, 4096, &nRead, NULL).
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 14, src: X64Register.rax)  // nRead = 0
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)  // hRead
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rdx)  // chunk buf
	helperMovRegImm(code, dest: X64Register.r8, value: 4096)
	helperLeaStackSlot(code, slotIndex: 14, dest: X64Register.r9)  // &nRead
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpOverlapped = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.readFile))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	code.append(b"\x89\xc0")  // mov eax, eax — clear the dirty high half before the 64-bit test
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)  // jz finish (EOF / broken pipe)
	helperLoadSlot(code, slotIndex: 14, dest: X64Register.rax)  // nRead (slot pre-zeroed → high bytes clean)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)  // jz finish (0 bytes = EOF)
	// scan chunk[0..nRead) for '\n'. rcx = index.
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperMarkBlock(state, code: code, blockId: 7)  // chunk_scan
	helperLoadSlot(code, slotIndex: 14, dest: X64Register.rax)  // nRead
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 9)  // jae chunk_no_nl
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rax)  // chunk buf
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rdx, base: X64Register.rax, disp: 0)  // chunk[index]
	helperCmpRegImm(code, reg: X64Register.rdx, value: 10)  // '\n'
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 8)  // je chunk_nl
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 7)
	helperMarkBlock(state, code: code, blockId: 8)  // chunk_nl (newline at rcx)
	helperStoreSlot(code, slotIndex: 15, src: X64Register.rcx)  // newlineIdx
	// append chunk[0..newlineIdx+1] to result.
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.r9)  // newlineIdx
	emitAddRegImmParam(code, dest: X64Register.r9, value: 1)  // n = newlineIdx + 1
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rsi)  // src = chunk buf
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_rli_append")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	// tailLen = nRead - (newlineIdx + 1); if 0 → finish; else copy tail into a new
	// pushback (the old pushback was drained empty in Phase 1).
	helperLoadSlot(code, slotIndex: 14, dest: X64Register.rax)  // nRead
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.rcx)  // newlineIdx
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rax, value: -1)  // tailLen
	helperStoreSlot(code, slotIndex: 17, src: X64Register.rax)  // tailLen
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)  // jz finish (no tail)
	// Free any stale pushback (defensive — should be empty/null after Phase 1),
	// then __slab_alloc(tailLen) and memcpy the tail in.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)  // old pushback ptr
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 14)  // jz pb_alloc
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: 14)  // pb_alloc
	helperLoadSlot(code, slotIndex: 17, dest: X64Register.rcx)  // tailLen
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	helperStoreSlot(code, slotIndex: 11, src: X64Register.r8)  // pushback ptr = new buf
	// memcpy(pushback, chunk + newlineIdx + 1, tailLen)
	emitMovRegRegOp(code, dest: X64Register.rdi, src: X64Register.r8)  // dst
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rsi)  // chunk
	helperLoadSlot(code, slotIndex: 15, dest: X64Register.rcx)  // newlineIdx
	emitAddRegRegParam(code, dest: X64Register.rsi, src: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rsi, value: 1)  // src = chunk + newlineIdx + 1
	helperLoadSlot(code, slotIndex: 17, dest: X64Register.rcx)  // count = tailLen
	code.append(b"\xf3\xa4")  // rep movsb
	helperLoadSlot(code, slotIndex: 17, dest: X64Register.rax)  // pushback len = tailLen
	helperStoreSlot(code, slotIndex: 12, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 10)  // finish
	helperMarkBlock(state, code: code, blockId: 9)  // chunk_no_nl
	// append whole chunk, keep reading.
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 10, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 14, dest: X64Register.r9)  // n = nRead
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rsi)  // src = chunk buf
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_rli_append")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz oom
	helperEmitJmp(code, state: state, targetBlock: 6)  // rf_loop
	helperMarkBlock(state, code: code, blockId: 10)  // finish
	// Persist pushback ptr/len back to the handle struct.
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)  // pushbackPtrAddr
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)  // pushback ptr
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)  // pushbackLenAddr
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rcx)  // pushback len
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	// Free the chunk buffer.
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// Build the result MM = __managed_mem_create(resultLen + 1, 1); copy bytes; set length.
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)  // resultLen
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")
	helperStoreSlot(code, slotIndex: 16, src: X64Register.r8)  // mm
	helperLoadIndirect(code, dest: X64Register.rdi, base: X64Register.r8, disp: 0)  // dst = mm buffer
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rsi)  // result buf
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)  // resultLen
	code.append(b"\xf3\xa4")  // rep movsb
	helperLoadSlot(code, slotIndex: 16, dest: X64Register.rax)  // mm
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)  // resultLen
	helperStoreIndirect(code, base: X64Register.rax, disp: 8, src: X64Register.rcx)  // mm[8] = length
	// Free the result buffer (copied into the MM).
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperLoadSlot(code, slotIndex: 16, dest: X64Register.r8)  // return mm
	helperEmitJmp(code, state: state, targetBlock: 11)  // done
	helperMarkBlock(state, code: code, blockId: 12)  // oom
	// Allocation failed mid-flight. Set last_error, free what we hold, return an
	// empty MM (the caller's EOF/error signal). The pushback was either drained
	// (slot 11 may be live) or freshly set; free the chunk + result; leave the
	// pushback in the handle (it persists via slots 6/7 below? — no: oom skips the
	// finish writeback, so null the handle pushback fields here to avoid a dangling
	// pointer, freeing the pushback buf).
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_invalid_handle", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	// free chunk buf if live
	helperLoadSlot(code, slotIndex: 13, dest: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 15)  // jz oom_no_chunk
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: 15)  // oom_no_chunk
	// free result buf if live
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 16)  // jz oom_no_result
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: 16)  // oom_no_result
	// Persist whatever pushback we have back to the handle so release_handle frees
	// it (don't strand it). pushbackPtrAddr/LenAddr are valid (set in entry).
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)  // pushbackPtrAddr
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)  // pushback ptr
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)  // pushbackLenAddr
	helperLoadSlot(code, slotIndex: 12, dest: X64Register.rcx)  // pushback len
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)  // eof_initial (build empty MM)
	helperMarkBlock(state, code: code, blockId: 1)  // eof_initial: fresh length-0 MM
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")  // r8 = mm (length 0)
	helperMarkBlock(state, code: code, blockId: 11)  // done (r8 holds the MM)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessReadLineInner'

// maxon_subprocess_read_stdout_line(handle=rcx, maxBytes=rdx) — thin wrapper that
// pins the stdout-side field offsets and forwards to __subp_read_line_inner.
function emitX64SubprocessReadStdoutLine(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	emitX64SubpReadLineWrapper(code, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_read_stdout_line", hReadOff: SubpOffHStdoutRead, lineBufPtrOff: SubpOffHStdoutLineBufPtr, lineBufLenOff: SubpOffHStdoutLineBufLen)
end 'emitX64SubprocessReadStdoutLine'

// maxon_subprocess_read_stderr_line(handle=rcx, maxBytes=rdx) — stderr-side
// companion; same shape, stderr field offsets.
function emitX64SubprocessReadStderrLine(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	emitX64SubpReadLineWrapper(code, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_read_stderr_line", hReadOff: SubpOffHStderrRead, lineBufPtrOff: SubpOffHStderrLineBufPtr, lineBufLenOff: SubpOffHStderrLineBufLen)
end 'emitX64SubprocessReadStderrLine'

// Shared body for the (stdout|stderr) read-line wrappers: forward (handle, the
// three pinned field offsets, maxBytes) to __subp_read_line_inner per the
// internal ABI (handle=rcx, hReadOff=rdx, lineBufPtrOff=rax, lineBufLenOff=r9,
// maxBytes=rsi). The inner returns the MM in r8; we tail-return it.
function emitX64SubpReadLineWrapper(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, name String, hReadOff MachineWord, lineBufPtrOff MachineWord, lineBufLenOff MachineWord)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: name, offset: code.count())
	var state = Win32HelperState.create(1, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	// Stash the incoming maxBytes (param 1 = rdx); rdx/rax get overwritten below.
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // maxBytes
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // handle (p0)
	helperMovRegImm(code, dest: X64Register.rdx, value: hReadOff)  // hReadOff (p1)
	helperMovRegImm(code, dest: X64Register.rax, value: lineBufPtrOff)  // lineBufPtrOff (p2)
	helperMovRegImm(code, dest: X64Register.r9, value: lineBufLenOff)  // lineBufLenOff (p3)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rsi)  // maxBytes (p4)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__subp_read_line_inner")  // r8 = mm
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubpReadLineWrapper'

// __subp_build_cmdline_wide(argvBuf=rcx, argc=rdx) — build a UTF-16 command line
// from the NUL-separated UTF-8 argv blob and return it as a `__slab_alloc`'d
// wide buffer (NUL-terminated), or 0 on failure (and set __subp_last_error).
// Minimal first cut: space-join the args verbatim (no quoting) into a fixed
// 4096-byte slab scratch, then MultiByteToWideChar. Quoting/growth land in a
// later pass; every current spec fragment has short, space-free argv tokens.
// Slots: 0=argvBuf, 1=argc, 2=utf8buf, 3=len, 4=argIdx, 5=pos, 6=wide, 7=wchars,
// 8=elemSize.
function emitX64SubprocessBuildCmdlineWide(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_build_cmdline_wide", offset: code.count())
	var state = Win32HelperState.create(8, outgoingBytes: 48, localBytes: 72)
	helperPrologue(code, frameSize: 128)
	helperMarkBlock(state, code: code, blockId: 0)  // entry
	// argv arrives as the __ManagedMemory STRUCT pointer (the self-hosted
	// lowering does NOT unwrap managed args to their buffer like the C#
	// bootstrap does — see lowerBuiltinsSubprocessCall). The blob is an
	// `Array with Byte`, which the self-hosted backend lays out with an 8-byte
	// element stride (NOT packed 1-byte like the C# bootstrap), so the byte
	// walk below advances `pos` by the MM's element size at [argv+24], reading
	// the low byte of each element. Dereference [argv+0] for the buffer base.
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // argc
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 24)  // elemSize = MM[24]
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 0)  // buffer = MM[0]
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // argvBuf = buffer base
	// utf8buf = __slab_alloc(4096)
	helperMovRegImm(code, dest: X64Register.rcx, value: 4096)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz fail
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)  // utf8buf
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // len = 0
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // argIdx = 0
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // pos = 0
	helperMarkBlock(state, code: code, blockId: 1)  // arg_loop
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // argIdx
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // argc
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 4)  // jge args_done
	// if argIdx > 0, append a space separator
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz byte_loop (first arg)
	helperMovRegImm(code, dest: X64Register.rdx, value: 32)  // ' '
	emitX64SubpCmdlineAppendByte(code, lenSlot: 3, bufSlot: 2, valReg: X64Register.rdx)
	helperMarkBlock(state, code: code, blockId: 2)  // byte_loop: copy arg bytes until NUL
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // argvBuf
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)  // pos
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rdx, base: X64Register.rax, disp: 0)  // byte = argvBuf[pos]
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz byte_done
	emitX64SubpCmdlineAppendByte(code, lenSlot: 3, bufSlot: 2, valReg: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)  // elemSize
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)  // pos += elemSize
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 3)  // byte_done: skip NUL element, next arg
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)  // elemSize
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)  // pos += elemSize (skip NUL element)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)  // argIdx++
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)
	helperMarkBlock(state, code: code, blockId: 4)  // args_done: NUL-terminate utf8
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	emitX64SubpCmdlineAppendByte(code, lenSlot: 3, bufSlot: 2, valReg: X64Register.rdx)
	// wchars = MultiByteToWideChar(65001, 0, utf8buf, -1, NULL, 0). 6 args → the
	// Enter/Leave system-stack pair (frameSize 0x30 = shadow + 2 stack args). This
	// helper runs on the caller (green) thread, so the heavy kernel call must use
	// the per-P system stack; register args set after Enter (clobbers rax/r11).
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpWideCharStr = NULL
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // cchWideChar = 0
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz fail_free
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)  // wchars
	// wide = __slab_alloc(wchars * 2)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz fail_free
	helperStoreSlot(code, slotIndex: 6, src: X64Register.r8)  // wide
	// MultiByteToWideChar(65001, 0, utf8buf, -1, wide, wchars). 6 args → Enter/Leave
	// system-stack pair; the &wide buffer is an rbp-relative GT-stack slot read,
	// which stays valid across the RSP switch (only the outgoing args move).
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)  // lpWideCharStr = wide
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // cchWideChar = wchars
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	// free the utf8 scratch and return wide
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)  // return wide
	helperEmitJmp(code, state: state, targetBlock: 7)  // done
	helperMarkBlock(state, code: code, blockId: 5)  // fail_free: free utf8buf, then fail
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMarkBlock(state, code: code, blockId: 6)  // fail
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_argv", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMarkBlock(state, code: code, blockId: 7)  // done (r8 holds wide ptr or 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessBuildCmdlineWide'

// Append `valReg`'s low byte to the growable UTF-8 buffer held in the caller's
// local slots (`bufSlot` = buffer ptr, `lenSlot` = current length) and bump the
// length. The minimal builder pre-sizes the buffer, so this never grows it.
// Clobbers rax/rcx; preserves `valReg` is NOT guaranteed, so callers reload any
// loop state from slots afterward.
function emitX64SubpCmdlineAppendByte(code ByteArray, lenSlot VarSlot, bufSlot VarSlot, valReg X64Register)
	helperLoadSlot(code, slotIndex: bufSlot, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: lenSlot, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)  // rax = buf + len
	helperStoreByteRcx(code, base: X64Register.rax, disp: 0, src: valReg)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)  // len + 1
	helperStoreSlot(code, slotIndex: lenSlot, src: X64Register.rcx)
end 'emitX64SubpCmdlineAppendByte'

// __subp_open_nul_wide(access=rcx) → an inheritable HANDLE to the NUL device, or
// 0 on failure. Used for stdin=none (GENERIC_READ) and discard stdout/stderr
// (GENERIC_WRITE). Lays out an inheritable SECURITY_ATTRIBUTES on the stack and
// calls CreateFileW(L"NUL", access, FILE_SHARE_READ|WRITE, &SA, OPEN_EXISTING,
// 0, NULL). Slots: 0=access; SA at slots 4(nLength)/3(lpSD)/2(bInheritHandle),
// base = &slot4. Direct IAT call — correct on the main thread (sync path); the
// async path will route CreateFileW through the per-P system stack later.
function emitX64SubprocessOpenNulWide(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__subp_open_nul_wide", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 64, localBytes: 40)
	helperPrologue(code, frameSize: 112)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // access
	// SECURITY_ATTRIBUTES: nLength=24 @SA+0, lpSecurityDescriptor=0 @SA+8,
	// bInheritHandle=1 @SA+16. SA base is &slot4, so SA+0/SA+8/SA+16 land in
	// slots 4/3/2 (slot addresses descend as the index grows).
	helperMovRegImm(code, dest: X64Register.rax, value: 24)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// CreateFileW(L"NUL", access, 3, &SA, 3, 0, 0). 7 args (4 reg + 3 stack at
	// [rsp+0x20..+0x30]) → the Enter/Leave system-stack pair. frameSize 0x40 =
	// shadow(0x20) + 3 qwords, rounded up to a 16-byte multiple so RSP stays
	// 16-aligned at the call. This helper runs on the caller (green) thread, so
	// the kernel call goes on the per-P system stack; register args set after
	// Enter (clobbers rax/r11).
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__subp_nul_devname_w", rdataRelocs: rdataRelocs)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)  // access
	helperMovRegImm(code, dest: X64Register.r8, value: 3)  // FILE_SHARE_READ|FILE_SHARE_WRITE
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r9)  // &SA
	helperMovRegImm(code, dest: X64Register.rax, value: 3)  // OPEN_EXISTING
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)  // dwFlagsAndAttributes = 0
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // hTemplateFile = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileW))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	// INVALID_HANDLE_VALUE (-1) → 0; otherwise return the handle.
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // je bad
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // bad
	helperMovRegImm(code, dest: X64Register.r8, value: 0)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessOpenNulWide'

// maxon_managed_is_null(mm=rcx) — 1 when `mm` is null or an empty (length-0)
// __ManagedMemory, else 0. Receives the MM STRUCT pointer (the lowering does
// not unwrap), so emptiness is read from the length field at [mm+8]. Used by
// `Subprocess.resolveByName`: an empty PATH-resolution result reports null so
// the caller falls back to the bare name for the OS spawn primitive's own
// lookup. Overrides the always-non-null runtime.std stub.
function emitX64SubprocessManagedIsNull(code ByteArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_managed_is_null", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperPrologue(code, frameSize: 0)
	helperMarkBlock(state, code: code, blockId: 0)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz null (mm == 0)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)  // length
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz null (length 0)
	helperMovRegImm(code, dest: X64Register.r8, value: 0)  // not null
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // null
	helperMovRegImm(code, dest: X64Register.r8, value: 1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessManagedIsNull'

// Shared body for the int-returning struct accessors (get_pid + result_status_*
// + result_duration_ms). rcx = struct ptr; returns (r8) the i64 at
// [ptr+fieldOff], or `nullValue` when ptr is null.
function emitX64SubpIntFieldAccessor(code ByteArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, name String, fieldOff MachineWord, nullValue MachineWord)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: name, offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperPrologue(code, frameSize: 0)
	helperMarkBlock(state, code: code, blockId: 0)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz null
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.rcx, disp: fieldOff)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // null
	helperMovRegImm(code, dest: X64Register.r8, value: nullValue)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubpIntFieldAccessor'

// maxon_subprocess_kill(handle=rcx, force=rdx) — TerminateProcess(hProcess,
// force ? 9 : 15). Returns (r8) 0 on success, -1 (and sets __subp_last_error)
// on a null handle or TerminateProcess failure. TerminateProcess runs on the
// per-P system stack (it probes the TIB). Slots: 0=handle, 1=force.
function emitX64SubprocessKill(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_kill", offset: code.count())
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // force
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz bad
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: SubpOffHProcess)  // rcx = hProcess
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)  // force
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz soft
	helperMovRegImm(code, dest: X64Register.rdx, value: 9)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // soft
	helperMovRegImm(code, dest: X64Register.rdx, value: 15)
	helperMarkBlock(state, code: code, blockId: 2)  // call (rcx=hProcess, rdx=exitcode)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.terminateProcess))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz bad
	helperMovRegImm(code, dest: X64Register.r8, value: 0)  // success
	helperEmitJmp(code, state: state, targetBlock: 4)
	helperMarkBlock(state, code: code, blockId: 3)  // bad
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_invalid_handle", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 4)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessKill'

// maxon_subprocess_send_signal(handle=rcx, sig=rdx) — Windows maps SIGINT (2)
// and SIGBREAK (21) to GenerateConsoleCtrlEvent against the child's process
// group (needs the CREATE_NEW_PROCESS_GROUP spawn flag); every other signal is
// unsupported. Returns (r8) 0 on success, -1 otherwise. Slots: 0=handle, 1=sig.
function emitX64SubprocessSendSignal(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_send_signal", offset: code.count())
	var state = Win32HelperState.create(6, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // sig
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz unsupported
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // sig
	helperCmpRegImm(code, reg: X64Register.rcx, value: 2)  // SIGINT
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // je ctrl_c
	helperCmpRegImm(code, reg: X64Register.rcx, value: 21)  // SIGBREAK
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // je ctrl_break
	helperEmitJmp(code, state: state, targetBlock: 4)  // unsupported
	helperMarkBlock(state, code: code, blockId: 1)  // ctrl_c
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)  // CTRL_C_EVENT = 0
	helperEmitJmp(code, state: state, targetBlock: 3)  // emit
	helperMarkBlock(state, code: code, blockId: 2)  // ctrl_break
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)  // CTRL_BREAK_EVENT = 1
	helperMarkBlock(state, code: code, blockId: 3)  // emit (rcx = ctrl event)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // handle
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: SubpOffPid)  // rdx = pid (process group)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.generateConsoleCtrlEvent))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz unsupported
	helperMovRegImm(code, dest: X64Register.r8, value: 0)  // success
	helperEmitJmp(code, state: state, targetBlock: 5)  // done
	helperMarkBlock(state, code: code, blockId: 4)  // unsupported
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__subp_err_signal_unsupported", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__subp_last_error")
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 5)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessSendSignal'

// maxon_subprocess_last_error_message() — return (r8) a freshly-allocated
// __ManagedMemory copy of the cstring stashed in __subp_last_error, or an empty
// MM when no error is pending. The Subprocess.maxon lowering owns the returned
// MM's refcount, so it must be a real managed allocation (not the static rdata
// string). Slots: 0=src cstring, 1=len, 2=mm. Mirrors C#
// EmitMaxonSubprocessLastErrorMessage (rebuilt on the MM model).
function emitX64SubprocessLastErrorMessage(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_subprocess_last_error_message", offset: code.count())
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 24)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__subp_last_error")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz empty
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)  // src
	// strlen(src): scan rcx from src until a NUL byte.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rax)
	helperMarkBlock(state, code: code, blockId: 1)  // strlen_loop
	helperLoadByte(code, dest: X64Register.rdx, base: X64Register.rcx, disp: 0)
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz strlen_end
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 1)
	helperMarkBlock(state, code: code, blockId: 2)  // strlen_end: len = rcx - src
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	emitSubRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rcx)  // len
	// mm = __managed_mem_create(len + 1, 1)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)  // mm
	// memcpy(mm[0], src, len) via rep movsb
	helperLoadIndirect(code, dest: X64Register.rdi, base: X64Register.r8, disp: 0)  // dst = mm buffer
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rsi)  // src
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // len
	code.append(b"\xf3\xa4")  // rep movsb
	// mm[8] = len
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rax, disp: 8, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)  // return mm
	helperEmitJmp(code, state: state, targetBlock: 4)  // done
	helperMarkBlock(state, code: code, blockId: 3)  // empty: build a 1-byte, length-0 MM
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")  // r8 = mm
	helperMarkBlock(state, code: code, blockId: 4)  // done (r8 holds the MM)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessLastErrorMessage'

// Shared body for maxon_subprocess_result_stdout / _stderr. rcx = result struct
// ptr; returns (r8) a fresh __ManagedMemory copy of the captured bytes at
// [result+bufOff] of length [result+lenOff], or an empty MM when the result is
// null or the capture is empty. The copy is required because the lowering owns
// the returned MM's refcount; the original buffer is freed by result_release.
// Slots: 0=result, 1=srcbuf, 2=len, 3=mm. Mirrors C# EmitMaxonSubprocessResultStreamCopy.
function emitX64SubprocessResultStreamCopy(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, name String, bufOff MachineWord, lenOff MachineWord)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: name, offset: code.count())
	var state = Win32HelperState.create(4, outgoingBytes: 32, localBytes: 32)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz empty
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // result
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: bufOff)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)  // srcbuf
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: lenOff)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // len
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz empty (len 0)
	// mm = __managed_mem_create(len + 1, 1)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)  // mm
	// memcpy(mm[0], srcbuf, len) via rep movsb
	helperLoadIndirect(code, dest: X64Register.rdi, base: X64Register.r8, disp: 0)  // dst
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rsi)  // srcbuf
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // len
	code.append(b"\xf3\xa4")  // rep movsb
	// mm[8] = len
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rax, disp: 8, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)  // return mm
	helperEmitJmp(code, state: state, targetBlock: 3)  // done
	helperMarkBlock(state, code: code, blockId: 2)  // empty: 1-byte, length-0 MM
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__managed_mem_create")  // r8 = mm
	helperMarkBlock(state, code: code, blockId: 3)  // done (r8 holds the MM)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SubprocessResultStreamCopy'

// __gt_fault_diagnostic(): the redirect target the VEH thunk resumes the
// faulting thread at (its CONTEXT.Rip is rewritten to this function's absolute
// address). Runs on the faulting thread with a freshly chosen RSP and RBP=0, so
// it must NOT walk the frame chain (that's why it doesn't call mrt_panic). Reads
// the message + faulting RIP + bad VA the thunk stashed in globals, writes a
// clean panic line to stderr, and ExitProcess(1). Ports the C# bootstrap's
// EmitGtFaultDiagnostic (X86CodeEmitter.Runtime.cs), simplified to the internal
// runtime helpers this backend already links (mrt_write_cstr_stderr +
// mm_trace_print_hex). Hand-emitted (not a runtime.std body) so the redirect can
// publish its absolute address and so no DCE root is needed for it.
function emitX64GtFaultDiagnostic(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_fault_diagnostic", offset: code.count())
	// Stand up a fresh frame (RBP was redirected to 0). 0x30 outgoing/local space
	// keeps RSP 16-aligned for the ExitProcess IAT call and the direct helper calls.
	helperPrologue(code, frameSize: 0x30)
	// Write the panic message (e.g. "panic: nil pointer or invalid memory access").
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__gt_fault_msg")
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_write_cstr_stderr")
	// " at rip=" <hex faulting rip>
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_panic_msg_at_rip", rdataRelocs: rdataRelocs)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_write_cstr_stderr")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__gt_fault_rip")
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_hex")
	// " addr=" <hex bad VA> (meaningful for access violations; 0 otherwise)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_panic_msg_addr", rdataRelocs: rdataRelocs)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_write_cstr_stderr")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__gt_fault_last_addr")
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_hex")
	// Trailing newline.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_panic_msg_nl", rdataRelocs: rdataRelocs)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_write_cstr_stderr")
	// ExitProcess(1) — never returns.
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.exitProcess))
	helperEpilogue(code)
end 'emitX64GtFaultDiagnostic'

// __gt_fault_handler_thunk(EXCEPTION_POINTERS* p) — the vectored exception
// handler kernel32!AddVectoredExceptionHandler invokes on a hardware fault. Win64
// ABI: p in RCX, returns a LONG in EAX. Maps the OS exception code to a panic
// message, stashes the diagnostic info in globals, rewrites the faulting thread's
// CONTEXT (Rip/Rsp/Rbp) to resume at __gt_fault_diagnostic, and returns
// EXCEPTION_CONTINUE_EXECUTION (-1). Codes it does not convert return
// EXCEPTION_CONTINUE_SEARCH (0) so the OS default disposition still applies.
// Merges the C# bootstrap's EmitFaultHandlerProlog + shared __gt_fault_handler +
// EmitFaultHandlerEpilog into one thunk (this runtime has no separate shared
// handler module). Slots: 0 = EXCEPTION_POINTERS*, 1 = fault code, 2 = CONTEXT*.
function emitX64GtFaultThunk(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_fault_handler_thunk", offset: code.count())
	// Blocks: 0 dispatch, 1 nil, 2 div, 3 intovf, 4 stkovf, 5 stash+choose-rsp,
	// 6 write-context+resume, 7 continue-search.
	var state = Win32HelperState.create(8, outgoingBytes: 0, localBytes: 24)
	helperPrologue(code, frameSize: 0x20)

	// block 0: classify the exception code.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // EXCEPTION_POINTERS*
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: ExcPtrsOffExceptionRecord)
	code.append(b"\x8b\x00")  // mov eax, [rax] — ExceptionCode (DWORD, zero-extends)
	helperMovRegImm(code, dest: X64Register.rdx, value: ExcCodeAccessViolation)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // je nil
	helperMovRegImm(code, dest: X64Register.rdx, value: ExcCodeIntDivideByZero)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // je div
	helperMovRegImm(code, dest: X64Register.rdx, value: ExcCodeIntOverflow)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // je intovf
	helperMovRegImm(code, dest: X64Register.rdx, value: ExcCodeStackOverflow)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // je stkovf
	helperEmitJmp(code, state: state, targetBlock: 7)  // default → continue search

	// block 1: access violation → nil-deref message.
	helperMarkBlock(state, code: code, blockId: 1)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_panic_msg_nil_deref", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_fault_msg")
	helperMovRegImm(code, dest: X64Register.rax, value: FaultCodeNilDeref)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// block 2: integer divide-by-zero.
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_panic_msg_div_zero", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_fault_msg")
	helperMovRegImm(code, dest: X64Register.rax, value: FaultCodeDivZero)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// block 3: integer overflow.
	helperMarkBlock(state, code: code, blockId: 3)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_panic_msg_int_overflow", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_fault_msg")
	helperMovRegImm(code, dest: X64Register.rax, value: FaultCodeIntOverflow)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// block 4: stack overflow.
	helperMarkBlock(state, code: code, blockId: 4)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_panic_msg_stack_overflow", rdataRelocs: rdataRelocs)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_fault_msg")
	helperMovRegImm(code, dest: X64Register.rax, value: FaultCodeStackOverflow)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	// Fall through to stash.

	// block 5: re-entrancy guard, stash diagnostic info, then pick the resume RSP.
	helperMarkBlock(state, code: code, blockId: 5)
	// If a fault is already being diagnosed, this is a nested/teardown fault (e.g. a
	// benign access violation Windows raises during the diagnostic's ExitProcess
	// rundown). Don't convert it — return EXCEPTION_CONTINUE_SEARCH so the OS handles
	// it, avoiding a recursive diagnostic + double print. Otherwise claim the guard.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_fault_in_progress")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 7)  // jnz → continue search
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_fault_in_progress")
	// Stash the bad VA (EXCEPTION_RECORD.ExceptionInformation[1]) — meaningful for
	// access violations, a stale-but-harmless value for the other fault kinds.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // EXCEPTION_POINTERS*
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: ExcPtrsOffExceptionRecord)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: ExcRecOffExceptionInfo1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdx, name: "__gt_fault_last_addr")
	// CONTEXT* → slot 2; stash faulting Rip.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: ExcPtrsOffContextRecord)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // CONTEXT*
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: ContextOffRip)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdx, name: "__gt_fault_rip")
	// Default resume RSP = faulting RSP, 16-aligned downward (intact for nil-deref /
	// divide / overflow). r8 holds the chosen RSP from here to block 6.
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.rax, disp: ContextOffRsp)
	code.append(b"\x49\x83\xe0\xf0")  // and r8, ~0xF
	// Stack overflow needs a fresh RSP (the faulting one would re-fault): when a real
	// green thread is current (currentGt.stackBase != 0) resume 4 KB above its stack
	// base, matching the C# bootstrap. Non-stkovf, no-P, or mainThread → keep r8.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // fault code
	helperCmpRegImm(code, reg: X64Register.rcx, value: FaultCodeStackOverflow)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 6)  // jne → write context
	emitX64GtLoadCurrentP(code, dest: X64Register.r9, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.r9)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz (no P) → keep r8
	helperLoadIndirect(code, dest: X64Register.r9, base: X64Register.r9, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r9, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.r10)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz (mainThread) → keep r8
	emitAddRegImmParam(code, dest: X64Register.r10, value: 4096)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.r10)  // r8 = fresh RSP

	// block 6: rewrite CONTEXT.Rip = &__gt_fault_diagnostic (absolute), Rsp = r8,
	// Rbp = 0, then return EXCEPTION_CONTINUE_EXECUTION so the OS resumes there.
	helperMarkBlock(state, code: code, blockId: 6)
	// ABI alignment: the diagnostic is entered via the redirect, NOT a `call`, so no
	// 8-byte return address is on the stack. Win64 callees assume RSP ≡ 8 (mod 16) at
	// entry (post-call), so their `push rbp` lands a 16-aligned RBP and their own
	// calls are 16-aligned. r8 is currently 16-aligned (the faulting RSP rounded down,
	// or stackBase+4096), which would make the diagnostic's RBP and outgoing calls
	// MISaligned and fault any `movdqa [rbp]` deep in ExitProcess. Bias r8 by -8 so the
	// diagnostic sees the same RSP parity a real call would produce.
	code.append(b"\x49\x83\xe8\x08")  // sub r8, 8
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // CONTEXT*
	emitLeaFuncAddrOp(code, dest: X64Register.rcx, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__gt_fault_diagnostic")
	helperStoreIndirect(code, base: X64Register.rax, disp: ContextOffRip, src: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rax, disp: ContextOffRsp, src: X64Register.r8)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperStoreIndirect(code, base: X64Register.rax, disp: ContextOffRbp, src: X64Register.r9)
	helperMovRegImm(code, dest: X64Register.rax, value: VehContinueExecution)
	helperEpilogue(code)

	// block 7: unconverted exception → let the OS default disposition apply.
	helperMarkBlock(state, code: code, blockId: 7)
	helperMovRegImm(code, dest: X64Register.rax, value: VehContinueSearch)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64GtFaultThunk'

// __gt_morestack(): called from a function prologue (args still in registers,
// frame not yet allocated) when the GT stack would overflow. Allocates a stack
// 2× the current size, copies the old stack to the top of the new one, fixes
// the saved-RBP chain + the entry RSP by the relocation offset, updates the GT
// struct + TIB, frees the old stack, and returns onto the new (larger) stack so
// the prologue's guard now passes. All register saves go on the per-P system
// stack so the GT-stack guard only has to cover this switch sequence. Ports the
// C# EmitGtMorestack, reading the current P from TLS (via emitX64GtLoadCurrentP).
function emitX64GtMorestack(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_morestack", offset: code.count())
	var st = Win32HelperState.create(2, outgoingBytes: 0, localBytes: 0)
	helperMarkBlock(st, code: code, blockId: 0)

	// Step 1: P → r11; r10 = GT entry rsp; switch rsp to the system stack.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	emitMovRegRegOp(code, dest: X64Register.r10, src: X64Register.rsp)
	helperLoadIndirect(code, dest: X64Register.rsp, base: X64Register.r11, disp: POffSystemStackSP)

	// Step 2: save GT entry rsp + 13 registers on the system stack (14 pushes).
	code.append(b"\x41\x52")  // push r10 (GT entry rsp)
	code.append(b"\x55")  // push rbp
	code.append(b"\x53")  // push rbx
	code.append(b"\x41\x54\x41\x55\x41\x56\x41\x57")  // push r12,r13,r14,r15
	code.append(b"\x51\x52")  // push rcx, rdx
	code.append(b"\x41\x50\x41\x51")  // push r8, r9
	code.append(b"\x56\x57")  // push rsi, rdi
	code.append(b"\x50")  // push rax
	// Step 3: shadow space (rsp stays 16-aligned).
	code.append(b"\x48\x83\xec\x20")  // sub rsp, 0x20

	// rbx = currentGt ; r12 = old_base ; r13 = old_size
	emitX64GtLoadCurrentP(code, dest: X64Register.rbx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rbx, base: X64Register.rbx, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r12, base: X64Register.rbx, disp: GtOffStackBase)
	helperLoadIndirect(code, dest: X64Register.r13, base: X64Register.rbx, disp: GtOffStackSize)
	// r14 = new_size = old_size << 1. Strict 2× doubling, exactly like Go's
	// runtime.morestack (and the C# bootstrap): the deepest GT-reachable kernel
	// frames (MultiByteToWideChar's ~3.9 KB) run on the per-P system stack via
	// emitX64GtSystemStackEnter/Leave, so the GT stack only ever has to hold Maxon
	// frames plus a single Win32 helper's own frame — no special-case growth floor.
	emitMovRegRegOp(code, dest: X64Register.r14, src: X64Register.r13)
	code.append(b"\x49\xd1\xe6")  // shl r14, 1

	// Step 4: new_base = VirtualAlloc(NULL, new_size, MEM_COMMIT|RESERVE, PAGE_RW). r15 = new_base.
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r14)
	helperMovRegImm(code, dest: X64Register.r8, value: MemCommitReserve)
	helperMovRegImm(code, dest: X64Register.r9, value: PageReadWrite)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualAlloc))
	emitMovRegRegOp(code, dest: X64Register.r15, src: X64Register.rax)

	// Step 5: memcpy old stack → top of new stack. rdi=dst=new_base+new_size-old_size,
	// rsi=src=old_base, rcx=count=old_size. CLD; REP MOVSB.
	code.append(b"\xfc")  // cld
	emitMovRegRegOp(code, dest: X64Register.rdi, src: X64Register.r15)
	code.append(b"\x4c\x01\xf7")  // add rdi, r14 (new_size)
	code.append(b"\x4c\x29\xef")  // sub rdi, r13 (old_size)
	emitMovRegRegOp(code, dest: X64Register.rsi, src: X64Register.r12)
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r13)
	code.append(b"\xf3\xa4")  // rep movsb

	// Step 6: offset = (new_base+new_size) - (old_base+old_size). rax = offset.
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r15)
	code.append(b"\x4c\x01\xf0")  // add rax, r14
	code.append(b"\x4c\x29\xe8")  // sub rax, r13
	code.append(b"\x4c\x29\xe0")  // sub rax, r12  → rax = offset
	// Adjust rbp if within [old_base, old_top).
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r12)
	code.append(b"\x4c\x01\xe9")  // add rcx, r13 → rcx = old_top
	code.append(b"\x4c\x39\xe5")  // cmp rbp, r12
	helperEmitCondJump(code, state: st, opcode: 0x82, targetBlock: 1)  // jb skip_rbp
	code.append(b"\x48\x39\xcd")  // cmp rbp, rcx
	helperEmitCondJump(code, state: st, opcode: 0x83, targetBlock: 1)  // jae skip_rbp
	code.append(b"\x48\x01\xc5")  // add rbp, rax
	// skip_rbp: write adjusted rbp back to its saved slot [rsp+0x80].
	helperMarkBlock(st, code: code, blockId: 1)
	helperStoreIndirect(code, base: X64Register.rsp, disp: 0x80, src: X64Register.rbp)

	// Step 6b: walk the saved-RBP chain on the new stack, adjusting saved RBPs in
	// the old range. rcx=walker (rbp); r8=new_low; r9=new_high.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rbp)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.r15)
	code.append(b"\x4d\x01\xf0")  // add r8, r14
	code.append(b"\x4d\x29\xe8")  // sub r8, r13  → r8 = new_low
	emitMovRegRegOp(code, dest: X64Register.r9, src: X64Register.r15)
	code.append(b"\x4d\x01\xf1")  // add r9, r14  → r9 = new_high
	emitX64GtMorestackWalkBody(code)

	// Step 7: update GT struct + TIB for the new stack.
	helperStoreIndirect(code, base: X64Register.rbx, disp: GtOffStackBase, src: X64Register.r15)
	helperStoreIndirect(code, base: X64Register.rbx, disp: GtOffStackSize, src: X64Register.r14)
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r15)
	code.append(b"\x48\x81\xc1\xa0\x03\x00\x00")  // add rcx, 0x3A0 (GtStackGuardMargin)
	helperStoreIndirect(code, base: X64Register.rbx, disp: GtOffStackGuard, src: X64Register.rcx)
	// tib_stack_base = new_base + new_size ; tib_stack_limit = new_base.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r15)
	code.append(b"\x4c\x01\xf1")  // add rcx, r14
	helperStoreIndirect(code, base: X64Register.rbx, disp: GtOffTibStackBase, src: X64Register.rcx)
	code.append(b"\x65\x48\x89\x0c\x25\x08\x00\x00\x00")  // mov gs:[0x08], rcx
	helperStoreIndirect(code, base: X64Register.rbx, disp: GtOffTibStackLimit, src: X64Register.r15)
	code.append(b"\x65\x4c\x89\x3c\x25\x10\x00\x00\x00")  // mov gs:[0x10], r15

	// Step 8: VirtualFree(old_base, 0, MEM_RELEASE). Stash offset in rbp across the call.
	emitMovRegRegOp(code, dest: X64Register.rbp, src: X64Register.rax)
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r12)
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	helperMovRegImm(code, dest: X64Register.r8, value: MemRelease)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualFree))
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.rbp)  // rax = offset

	// Steps 9-12: tear down + return onto the new GT stack.
	code.append(b"\x48\x83\xc4\x20")  // add rsp, 0x20 (shadow)
	// new GT rsp = GT entry rsp ([rsp+0x68]) + offset → r10
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.rsp, disp: 0x68)
	code.append(b"\x49\x01\xc2")  // add r10, rax
	// pop 13 regs
	code.append(b"\x58")  // pop rax
	code.append(b"\x5f\x5e")  // pop rdi, rsi
	code.append(b"\x41\x59\x41\x58")  // pop r9, r8
	code.append(b"\x5a\x59")  // pop rdx, rcx
	code.append(b"\x41\x5f\x41\x5e\x41\x5d\x41\x5c")  // pop r15,r14,r13,r12
	code.append(b"\x5b")  // pop rbx
	code.append(b"\x5d")  // pop rbp
	code.append(b"\x48\x83\xc4\x08")  // add rsp, 8 (skip saved GT entry rsp slot)
	code.append(b"\x4c\x89\xd4")  // mov rsp, r10 (switch to new GT stack)
	code.append(b"\xc3")  // ret (return addr was copied to the new stack)
	helperFinalize(st, code: code)
end 'emitX64GtMorestack'

// Emit the RBP-chain walk with self-contained short (rel8) jumps. The walk is
// short and the displacements fit in a signed byte, so we hand-assemble the
// branches rather than threading another block-fixup state through.
function emitX64GtMorestackWalkBody(code ByteArray)
	// Layout (offsets within this fragment):
	//   L_head:
	//     test rcx,rcx        ; jz L_done
	//     cmp rcx,r8          ; jb L_done
	//     cmp rcx,r9          ; jae L_done
	//     mov r11,[rcx]       ; saved_rbp
	//     cmp r11,r12         ; jb L_next
	//     mov r10,r12; add r10,r13; cmp r11,r10 ; jae L_next
	//     add r11,rax; mov [rcx],r11
	//   L_next:
	//     mov rcx,[rcx]       ; jmp L_head
	//   L_done:
	let start = code.count()
	// test rcx,rcx
	code.append(b"\x48\x85\xc9")
	let jzDone1 = appendShortJccPlaceholder(code, opcode: 0x74)  // jz L_done
	// cmp rcx,r8 ; jb L_done
	code.append(b"\x4c\x39\xc1")
	let jbDone = appendShortJccPlaceholder(code, opcode: 0x72)
	// cmp rcx,r9 ; jae L_done
	code.append(b"\x4c\x39\xc9")
	let jaeDone = appendShortJccPlaceholder(code, opcode: 0x73)
	// mov r11,[rcx]
	code.append(b"\x4c\x8b\x19")
	// cmp r11,r12 ; jb L_next
	code.append(b"\x4d\x39\xe3")
	let jbNext = appendShortJccPlaceholder(code, opcode: 0x72)
	// mov r10,r12 ; add r10,r13 ; cmp r11,r10 ; jae L_next
	code.append(b"\x4d\x89\xe2")
	code.append(b"\x4d\x01\xea")
	code.append(b"\x4d\x39\xd3")
	let jaeNext = appendShortJccPlaceholder(code, opcode: 0x73)
	// add r11,rax ; mov [rcx],r11
	code.append(b"\x49\x01\xc3")
	code.append(b"\x4c\x89\x19")
	// L_next: mov rcx,[rcx]
	let lnext = code.count()
	code.append(b"\x48\x8b\x09")
	// jmp L_head (rel8 back)
	let jmpHeadFrom = code.count() + 2
	let backRel = start - jmpHeadFrom
	code.append(b"\xeb")
	code.push(backRel and 0xFF)
	// L_done:
	let ldone = code.count()
	patchShortJcc(code, at: jzDone1, target: ldone)
	patchShortJcc(code, at: jbDone, target: ldone)
	patchShortJcc(code, at: jaeDone, target: ldone)
	patchShortJcc(code, at: jbNext, target: lnext)
	patchShortJcc(code, at: jaeNext, target: lnext)
end 'emitX64GtMorestackWalkBody'

// Emit a green-thread stack-overflow guard at a function prologue (BEFORE the
// frame is allocated and BEFORE args are saved). When running on a green thread
// whose stack would overflow allocating `frameSize` bytes, calls __gt_morestack
// to grow + relocate the stack first. A no-op on the main OS thread / in non-
// async programs (P == 0, or mainThread.stackGuard == 0). Clobbers r10, r11 only
// (args in rcx/rdx/... are preserved; __gt_morestack preserves all registers).
// Used by the large-frame hand-emitted Win32 helpers (mrt_win32_stat/access).
function emitX64GtStackGuard(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, frameSize MachineWord)
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	code.append(b"\x4d\x85\xdb")  // test r11, r11
	let jzSkip = appendShortJccPlaceholder(code, opcode: 0x74)  // jz skip
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)  // r11 = currentGt
	emitMovRegRegOp(code, dest: X64Register.r10, src: X64Register.rsp)  // r10 = rsp
	code.append(b"\x49\x81\xea")  // sub r10, imm32 (frameSize + guard margin)
	writeDword(code, value: frameSize + GtStackGuardMargin)
	code.append(b"\x4d\x3b\x53\x50")  // cmp r10, [r11 + GtOffStackGuard(0x50)]
	let jaeSkip = appendShortJccPlaceholder(code, opcode: 0x73)  // jae skip (enough room)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_morestack")
	// skip:
	let skipTarget = code.count()
	patchShortJcc(code, at: jzSkip, target: skipTarget)
	patchShortJcc(code, at: jaeSkip, target: skipTarget)
end 'emitX64GtStackGuard'

// Append a 2-byte short Jcc (opcode + placeholder rel8); returns the offset of
// the rel8 byte for later patching by `patchShortJcc`.
function appendShortJccPlaceholder(code ByteArray, opcode MachineWord) returns CodeOffset
	code.push(opcode)
	let relOffset = code.count()
	code.push(0)
	return relOffset
end 'appendShortJccPlaceholder'

// Patch a short Jcc/jmp rel8 at `at` (the rel byte offset) to branch to `target`.
function patchShortJcc(code ByteArray, at CodeOffset, target CodeOffset)
	let rel = target - (at + 1)
	try code.set(at, value: rel and 0xFF) otherwise panic("patchShortJcc: set OOB")
end 'patchShortJcc'

// __gt_trampoline: the entry point a fresh green thread `ret`s into on its first
// context switch (NOT a normal call — no incoming args, no prologue). Loads the
// spawned function + arg buffer from the running GT, loads up to 7 args into the
// internal-ABI registers (count-guarded), calls the function, stores the result,
// marks the GT completed, and context-switches to the GT's waiter (or the main
// thread). Registers held across the user call: r12=gt (callee-saved), r11=func.
function emitX64GtTrampoline(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_trampoline", offset: code.count())
	// Blocks 0..2 are the original arg-load / call / context-switch structure.
	// Blocks 3..9 are the per-arg managed_mask decref skip points (one continuation
	// block per arg index 0..6 — see emitX64GtTrampolineArgDecref).
	// Blocks 10..13 are the all-threads-list unlink walk (loop/found/prev/done).
	var state = Win32HelperState.create(14, outgoingBytes: 0, localBytes: 0)
	helperMarkBlock(state, code: code, blockId: 0)

	// gt = P->currentGt  (context_switch set this to us before the ret)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r12, base: X64Register.r10, disp: POffCurrentGt)
	// We deliberately do NOT zero gt.ioYielded here. Matching the C# bootstrap, a
	// GT's ioYielded stays 1 from spawn through completion; stack-free safety comes
	// from the deferred-pendingWaiter discipline (the completing GT switches to
	// P.mainThread, and the worker loop re-enqueues the awaiter only AFTER that
	// switch), while the resume-point ioYielded=1 stores (worker loop / await / sleep)
	// are the off-stack signal an async-I/O completion spins on. Zeroing it here —
	// paired with the old per-P P.lastCompleted handshake — is what raced across
	// worker threads (an awaiter resuming on a different P freed the wrong GT's stack).
	// func = gt.func_ptr ; buf = gt.arg_buf ; count = [buf]
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r12, disp: GtOffFuncPtr)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r12, disp: GtOffArgBuf)
	helperLoadIndirect(code, dest: X64Register.r14, base: X64Register.r10, disp: 0)

	// Count-guarded arg loads: for i in 0..6, if count <= i skip to the call.
	// Buffer layout is [count | managed_mask | arg0 | arg1 | ...], args at +16.
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 0)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 1)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 2)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 3)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 4)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 5)
	emitX64GtTrampolineArgLoad(code, state: state, argIndex: 6)

	// done: call the user function (ptr in r11); result in r8, throw flag in rdx.
	helperMarkBlock(state, code: code, blockId: 1)
	emitCallIndirectOp(code, reg: X64Register.r11)
	// gt.result = r8 ; gt.threw = rdx (the multi-value error flag — meaningful
	// only for a throwing callee, ignored by a plain `await`). Capture rdx first,
	// before any code below clobbers it.
	helperStoreIndirect(code, base: X64Register.r12, disp: GtOffResult, src: X64Register.r8)
	helperStoreIndirect(code, base: X64Register.r12, disp: GtOffThrew, src: X64Register.rdx)
	// Drop the spawn-time refs on managed args (paired with the lowering's
	// per-arg `__mm_incref`). For each set bit in the arg buffer's managed_mask,
	// mm_decref the matching arg slot — AFTER the result/threw were captured into
	// the GT struct above (mm_decref clobbers rax/rcx/rdx), BEFORE the context
	// switch back. Without this the spawn-site incref leaks. r12=gt is callee-
	// saved and survives mm_decref; rbx holds the mask and r13 the count across
	// the loop (also callee-saved). The completed GT never resumes, so clobbering
	// rbx/r13 here is harmless.
	code.append(b"\x48\x83\xec\x20")  // sub rsp, 0x20 (mm_decref shadow space; rsp stays 16-aligned)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r12, disp: GtOffArgBuf)  // buf
	helperLoadIndirect(code, dest: X64Register.r13, base: X64Register.r10, disp: 0)  // count
	helperLoadIndirect(code, dest: X64Register.rbx, base: X64Register.r10, disp: 8)  // managed_mask
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 0)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 1)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 2)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 3)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 4)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 5)
	emitX64GtTrampolineArgDecref(code, state: state, callFixups: callFixups, argIndex: 6)
	// Free the async arg buffer (__slab_alloc'd by the async lowering — see
	// lowerAsyncCallReal, LowerMaxonToStd.maxon:3095 — and leaked until now; the C#
	// bootstrap frees it in the trampoline too). r12=gt is callee-saved and survives the
	// decref loop, so reload the buffer from it; we reuse the decref loop's 0x20 shadow
	// for the __slab_free call. The completed GT never reads gt.arg_buf again, and on
	// free-list reuse __gt_spawn overwrites it. The managed args inside the buffer were
	// already decref'd above; freeing the raw buffer only returns its slab chunk.
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r12, disp: GtOffArgBuf)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	code.append(b"\x48\x83\xc4\x20")  // add rsp, 0x20 (restore stack)

	// Completion bookkeeping: atomically drop the live-thread count and unlink this
	// GT from the global all-threads list (Go-style GMP). Ports C# EmitGtTrampoline's
	// completion tail. r12=gt is callee-saved and survives the kernel calls. We
	// reserve a 0x20 shadow frame for the Enter/Leave skip-path direct IAT call and
	// keep RSP 16-aligned (stack_top was 16-aligned after the `add rsp, 0x20` above).
	code.append(b"\x48\x83\xec\x20")  // sub rsp, 0x20 (shadow for EnterCriticalSection/LeaveCriticalSection)
	// LOCK DEC qword [__gt_live_count]
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_live_count", rdataRelocs: rdataRelocs)
	emitLockDecMemoryOp(code, addrReg: X64Register.rax)
	// EnterCriticalSection(&__sched_all_cs) — the list is shared across worker threads.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_all_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// Walk the singly-linked all-threads list: prev=null (rdx), cur=__gt_all_head (rcx);
	// stop at cur==null (defensive — not found) or cur==gt (r12); unlink when found.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__gt_all_head")  // cur
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (prev = null)
	// block 10: loop head.
	helperMarkBlock(state, code: code, blockId: 10)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 13)  // jz done (not found)
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.r12)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 11)  // je found
	// prev = cur ; cur = cur.all_next
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: GtOffAllNext)
	helperEmitJmp(code, state: state, targetBlock: 10)  // jmp loop
	// block 11: found — rax = gt.all_next ; if prev==null update head else prev.all_next = rax.
	helperMarkBlock(state, code: code, blockId: 11)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r12, disp: GtOffAllNext)
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 12)  // jnz prev_case
	// prev == null: __gt_all_head = gt.all_next
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_all_head")
	helperEmitJmp(code, state: state, targetBlock: 13)  // jmp done
	// block 12: prev_case — prev.all_next = gt.all_next
	helperMarkBlock(state, code: code, blockId: 12)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffAllNext, src: X64Register.rax)
	// block 13: done — LeaveCriticalSection(&__sched_all_cs), then release the shadow.
	helperMarkBlock(state, code: code, blockId: 13)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_all_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	code.append(b"\x48\x83\xc4\x20")  // add rsp, 0x20 (release shadow)

	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusCompleted)
	helperStoreIndirect(code, base: X64Register.r12, disp: GtOffStatus, src: X64Register.rax)
	// Stash gt.waiter into P.pendingWaiter — we must NOT context-switch directly to
	// the waiter (it may be suspended on another OS thread; cross-thread RSP/RBP swap
	// corrupts both stacks). The scheduler's __gt_process_pending_waiter re-enqueues
	// or wakes it after we've left gt's stack.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r12, disp: GtOffWaiter)  // rax = waiter (may be 0)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)  // rcx = P
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffPendingWaiter, src: X64Register.rax)
	// context_switch(from=gt, to=&P->mainThread) — back to this P's own scheduler.
	// The worker loop's __gt_process_pending_waiter then sets the waiter ready and
	// re-enqueues/wakes it, strictly AFTER we have left this GT's stack.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r12)
	emitX64GtLoadCurrentP(code, dest: X64Register.rdx, rdataRelocs: rdataRelocs)
	code.append(b"\x48\x81\xc2\x80\x00\x00\x00")  // add rdx, 0x80 (POffMainThread)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	// never returns here (gt is completed)
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
end 'emitX64GtTrampoline'

// One count-guarded arg load inside the trampoline: `if count(r14) <= argIndex:
// jump to the call (block 1); else load arg[argIndex] from buf(r10)+16+i*8 into
// the internal-ABI register for that position`.
function emitX64GtTrampolineArgLoad(code ByteArray, state Win32HelperState, argIndex VarSlot)
	helperCmpRegImm(code, reg: X64Register.r14, value: argIndex)
	helperEmitCondJump(code, state: state, opcode: 0x86, targetBlock: 1)  // jbe done
	helperLoadIndirect(code, dest: getCallConvGpr(argIndex), base: X64Register.r10, disp: 16 + argIndex * 8)
end 'emitX64GtTrampolineArgLoad'

// One count- and mask-guarded managed-arg decref inside the trampoline, mirroring
// the C# bootstrap's trampoline loop. With r13=count and rbx=managed_mask already
// loaded, this emits: `if count <= argIndex OR (mask & (1<<argIndex)) == 0 OR
// arg[argIndex] == 0: skip; else mm_decref(arg[argIndex])`. All three guards jump
// to the per-arg continuation block (argIndex+3), which is marked at the end so
// the next arg's checks (or the post-loop code) fall through there. The null guard
// mirrors user-emitted decref sites — a managed pointer can legitimately be NULL.
// mm_decref takes its arg in rcx (Win64) and clobbers rax/rcx/rdx/r8-r11; r12=gt,
// r13=count and rbx=mask are callee-saved and survive it, so buf is reloaded from
// r12 each iteration.
function emitX64GtTrampolineArgDecref(code ByteArray, state Win32HelperState, callFixups CallFixupArray, argIndex VarSlot)
	let contBlock = argIndex + 3
	// count <= argIndex → no arg here.
	helperCmpRegImm(code, reg: X64Register.r13, value: argIndex)
	helperEmitCondJump(code, state: state, opcode: 0x86, targetBlock: contBlock)  // jbe cont
	// (mask & (1<<argIndex)) == 0 → arg not managed. `test rax, imm32` (REX.W A9).
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.rbx)
	code.push(0x48)
	code.push(0xA9)
	writeDword(code, value: 1 shl argIndex)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: contBlock)  // jz cont
	// rcx = arg[argIndex] = buf[16 + argIndex*8]; reload buf from gt (clobbered by
	// any prior mm_decref).
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r12, disp: GtOffArgBuf)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: 16 + argIndex * 8)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: contBlock)  // jz cont (null)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	helperMarkBlock(state, code: code, blockId: contBlock)
end 'emitX64GtTrampolineArgDecref'

// Load the current OS thread's ProcContext* (P) into `dest` from TLS:
// `dest = gs:[__sched_tls_teb_offset]`. Replaces the old single-global
// `__gt_current_p` read so each worker OS thread sees its own P. `dest` must not
// be rbp/r13 (the gs:[reg] form would otherwise encode rip-relative). Clobbers
// only `dest`.
function emitX64GtLoadCurrentP(code ByteArray, dest X64Register, rdataRelocs RdataRelocationArray)
	if dest == X64Register.rbp or dest == X64Register.r13 'badReg'
		panic("emitX64GtLoadCurrentP: dest must not be rbp/r13 (gs:[reg] encoding)")
	end 'badReg'
	// dest = [__sched_tls_teb_offset]  (the precomputed gs: byte offset)
	emitGlobalLoadOp(code, dest: dest, name: "__sched_tls_teb_offset", size: 8, rdataRelocs: rdataRelocs)
	// dest = gs:[dest]  — the TLS slot holds P*. 0x65 = GS segment override.
	code.push(0x65)
	helperLoadIndirect(code, dest: dest, base: dest, disp: 0)
end 'emitX64GtLoadCurrentP'

// __slab_current_p_id() -> i64 : the per-P shard id of the calling OS thread,
// or -1 when no multi-P scheduler owns this thread. Overrides the runtime.std
// signature stub (which returns -1 unconditionally — the correct answer on
// wasm / arm64 and on any target before the GMP scheduler starts). The sharded
// slab allocator in runtime.std calls this to index its per-P mcache and to
// route cross-P frees onto the owning P's remote-free queue; a -1 result is
// mapped to shard 0 there, so the allocator degrades to single-shard behavior.
//
// Returns (r8, internal ABI):
//   __sched_tls_teb_offset == 0  → -1  (GMP scheduler never initialized; reading
//                                        gs:[0] would alias the TIB self-pointer)
//   P == NULL                    → -1  (raw OS thread with no adopted P)
//   else                         → P->id  (POffId)
function emitX64SlabCurrentPId(code ByteArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__slab_current_p_id", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperPrologue(code, frameSize: 0)
	helperMarkBlock(state, code: code, blockId: 0)
	// if __sched_tls_teb_offset == 0 → no scheduler → -1.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_tls_teb_offset")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz no_p
	// P = gs:[__sched_tls_teb_offset]; if P == NULL → -1.
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz no_p
	// r8 = P->id
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.rcx, disp: POffId)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 1)  // no_p
	helperMovRegImm(code, dest: X64Register.r8, value: -1)
	helperMarkBlock(state, code: code, blockId: 2)  // done
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SlabCurrentPId'

// __gt_trace_emit(tag=rcx, value=rdx, suffix=rax): print one async-trace line —
// `<tag><value><suffix?>\n` — to stderr, serialized by __at_trace_cs so worker
// threads don't interleave characters. Gated on the __at_trace_enabled global
// (baked from the AsyncTrace fragment flag): a normal build sees 0 and returns
// immediately. `tag`/`suffix` are cstr addresses (the caller LEAs an __at_tag_*
// string); pass suffix=0 to omit it. `value` is printed as a decimal integer.
// Internal ABI; clobbers volatiles. Slots: 0=tag, 1=value, 2=suffix.
function emitX64GtTraceEmit(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_trace_emit", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 24)
	helperPrologue(code, frameSize: 64)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // tag
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // value
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // suffix (0 = none)

	// block 0: if __at_trace_enabled == 0 → done.
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.r10, name: "__at_trace_enabled")
	helperTestReg(code, reg: X64Register.r10)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz done
	// EnterCriticalSection(&__at_trace_cs)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_trace_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// print tag, then value.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_tag")
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_i64")
	// optional suffix.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz no_suffix
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_tag")

	// block 1: newline, then LeaveCriticalSection.
	helperMarkBlock(state, code: code, blockId: 1)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_tag_nl", rdataRelocs: rdataRelocs)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_trace_print_tag")
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_trace_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))

	// block 2: done.
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtTraceEmit'

// __gt_current_trace_id() -> r8: the trace id of the GT currently running on
// this OS thread, or 0 when not on a green thread (no P, or the inline
// mainThread whose stackBase is 0). Lets .std runtime code (mrt_file_exists)
// label io_yield/io_resume lines with the right GT id without touching TLS.
function emitX64GtCurrentTraceId(code ByteArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_current_trace_id", offset: code.count())
	var state = Win32HelperState.create(2, outgoingBytes: 0, localBytes: 0)
	helperPrologue(code, frameSize: 0)
	helperMarkBlock(state, code: code, blockId: 0)
	// r8 = 0 (default: not on a GT)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.r10)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done (no P)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)  // gt
	// if gt.stackBase == 0 (mainThread) → done (r8 stays 0)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.r10, disp: GtOffTraceId)
	// done
	helperMarkBlock(state, code: code, blockId: 1)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtCurrentTraceId'

// __rt_oslock_acquire(addr=rcx) / __rt_oslock_release(addr=rcx): route the
// runtime's CRITICAL_SECTION acquire/release (`osLockAcquire`/`osLockRelease`,
// which wrap the hot `__slab_alloc`/`__slab_free` body) through the per-P system
// stack via emitX64GtIatCallOnSystemStack. A direct EnterCriticalSection is a
// user-mode fast path only while UNCONTENDED; when CONTENDED it makes a blocking
// kernel wait. Run from a green thread — whose RSP and TIB stack bounds point at
// a 2 KB GT stack — that kernel wait corrupts the stack (flaky 0xC0000005 on a
// worker). Concurrent async `Subprocess.run` is exactly this case: 4+ GTs doing
// allocation-heavy work on multiple worker Ps contend on `__slab_lock`. The
// wrapper self-gates: with no scheduler (P==0) or on the main OS thread it calls
// the IAT slot directly on the current (large) stack; on a GT it switches RSP to
// the per-P 64 KB system stack and repoints the TIB first, so the contended
// kernel wait runs on a real stack. The lock address is the internal ABI's first
// arg (rcx == getCallConvGpr(0)), which is also where EnterCriticalSection /
// LeaveCriticalSection read it (Win64), and the wrapper passes rcx straight
// through to the kernel call — no register move needed. The 0x20 frame supplies
// the shadow region (and keeps RSP 16-aligned) for the wrapper's skip-path direct
// IAT call. Windows-only: osLock* panics/no-ops on the other targets.
function emitX64RtOsLockAcquire(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__rt_oslock_acquire", offset: code.count())
	helperPrologue(code, frameSize: 32)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperEpilogue(code)
end 'emitX64RtOsLockAcquire'

function emitX64RtOsLockRelease(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__rt_oslock_release", offset: code.count())
	helperPrologue(code, frameSize: 32)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperEpilogue(code)
end 'emitX64RtOsLockRelease'

// __gt_process_pending_waiter(): handle a waiter a just-completed GT deferred into
// `P.pendingWaiter`. A completing GT can't context-switch directly to its waiter —
// the waiter may be suspended on a *different* OS thread, and a cross-thread RSP/RBP
// swap corrupts both stacks. Instead the trampoline stashes the waiter and switches
// to its own P's mainThread; the scheduler then calls this from each resume point.
// Regular-GT waiters are marked ready and re-enqueued (so they MIGRATE to whichever
// worker dequeues them); a parked main-thread waiter (stackBase==0) is left for its
// own spin-recheck (Step B.4 adds a SetEvent wake). Internal ABI; no args/result.
function emitX64GtProcessPendingWaiter(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_process_pending_waiter", offset: code.count())
	var state = Win32HelperState.create(2, outgoingBytes: 32, localBytes: 0)
	helperPrologue(code, frameSize: 32)
	helperMarkBlock(state, code: code, blockId: 0)
	// w = P.pendingWaiter; if null → done
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r11, disp: POffPendingWaiter)
	helperTestReg(code, reg: X64Register.r10)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done
	// P.pendingWaiter = 0
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r11, disp: POffPendingWaiter, src: X64Register.rax)
	// if w.stackBase == 0 (a parked main thread) → done (it spin-rechecks)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz done
	// regular GT: w.status = ready ; __gt_enqueue(w)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusReady)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rax)
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r10)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_enqueue")
	// done
	helperMarkBlock(state, code: code, blockId: 1)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtProcessPendingWaiter'

// __gt_await(promise=rcx) -> r8 (the awaited result). If the promise's GT has
// already completed, extract its result; otherwise mark the current GT waiting,
// record it as the promise's waiter, and drive the scheduler (process pending
// waiter + dequeue + context switch) until the promise completes. Then free the
// promise GT's stack and return its result. Local slots: 0=promise, 1=saved
// result. Uses only caller-saved registers so it needn't preserve r12-r15.
function emitX64GtAwait(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_await", offset: code.count())
	// Blocks 0..7 are the wait/extract/trace structure; blocks 8..9 are the
	// return-to-free-list path (free_full / free_done). frameSize 80 keeps slots
	// 0..5 clear of the 32-byte outgoing-arg region (rsp = rbp-80, outgoing at
	// rbp-80..rbp-48), so slot 4 (saved threw) survives the free-list call.
	var state = Win32HelperState.create(10, outgoingBytes: 32, localBytes: 48)
	helperPrologue(code, frameSize: 80)
	// slot 0 = promise ; slot 1 = result ; slot 2 = yielded flag (0=immediate, 1=yielded)
	// slot 3 = the dequeued GT we run in the loop (named for the resume-point ioYielded set)
	// slot 4 = saved threw flag (held across the return-to-free-list push)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// block 0 (entry): if promise.status == completed → extract (immediate, flag stays 0).
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusCompleted)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz extract
	// We have to wait → record this as an await-with-yield for the trace.
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// self = P->currentGt ; self.status = waiting ; promise.waiter = self
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.r11, disp: GtOffStatus, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffWaiter, src: X64Register.r11)

	// block 1 (loop): re-enqueue any deferred waiter, then g = dequeue(); if null →
	// recheck; else run g. process_pending_waiter handles a GT that completed on this
	// (or another) thread and stashed its waiter, migrating it back onto the queue.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	// Drain any IOCP/sync-worker completions and re-ready their waiter GTs (matches the
	// C# __gt_await call site). __io_init runs unconditionally at startup
	// (patchMrtStartCallIoInit), so the done queue is always live but stays empty until
	// async-I/O specs submit work — until then __io_check_completions dequeues nothing
	// and returns at once (one uncontended done-queue CS acquire).
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_check_completions")
	// Drive expired sleep timers so an awaiter blocked on a sleeping GT (rather than
	// a worker) still re-readies it — otherwise the await loop could spin forever.
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_timer_check")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz recheck
	// Save the dequeued GT we're about to run into slot 3 — context_switch clobbers
	// r8, and on resume we set THIS GT's ioYielded from the slot (the C# resume-point
	// discipline: name the GT we switched to via a local, never a shared per-P field).
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)
	// g.status = running
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rax)
	// context_switch(from=P->currentGt, to=g)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r8)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	// Resumed: set the GT we ran (slot 3) ioYielded=1 from the local slot so its
	// awaiter can free its stack. Handles the case where the GT we ran completed
	// directly. (ioYielded is the async-I/O off-stack signal; a no-op until I/O lands.)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)

	// block 2 (recheck): if promise.status != completed → loop.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusCompleted)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 1)  // jnz loop

	// block 3 (extract): result = promise.result, then wait for the GT to be off
	// its stack before freeing it.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffResult)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	// Emit `await #<id> [yield|immediate]` (slot 2 selects the suffix). r9 holds the
	// chosen suffix address across the branch (no calls between, so it survives).
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz immediate
	emitLeaRipRelOp(code, dest: X64Register.r9, rdataLabel: "__at_tag_await_yield", rdataRelocs: rdataRelocs)
	helperEmitJmp(code, state: state, targetBlock: 7)
	// block 6: immediate suffix.
	helperMarkBlock(state, code: code, blockId: 6)
	emitLeaRipRelOp(code, dest: X64Register.r9, rdataLabel: "__at_tag_await_imm", rdataRelocs: rdataRelocs)
	// block 7: emit the await line — __gt_trace_emit(tag=&"await #", value=id, suffix=r9).
	helperMarkBlock(state, code: code, blockId: 7)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_tag_await", rdataRelocs: rdataRelocs)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: GtOffTraceId)
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r9)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_trace_emit")

	// block 5 (wait_off): spin until promise.ioYielded == 1. ioYielded stays 1 from
	// spawn (we no longer zero it at trampoline entry), so for a plain async/await this
	// falls straight through; the runner also re-asserts it=1 from a local slot at each
	// context-switch resume point. Stack-free safety is guaranteed by the deferred-
	// pendingWaiter ordering, not this spin. PAUSE per spin (matters once async-I/O,
	// which zeroes ioYielded across a yield, is wired in).
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffIoYielded)
	helperTestReg(code, reg: X64Register.rax)
	code.append(b"\xf3\x90")  // pause
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz wait_off (spin)

	// VirtualFree(stack_base, 0, MEM_RELEASE) only if stack_base != 0 (main has none)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz skip_free
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (dwSize = 0)
	helperMovRegImm(code, dest: X64Register.r8, value: MemRelease)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualFree))

	// block 4 (skip_free): capture the promise's throw flag (the multi-value
	// error-return register). A plain `await` ignores it; a `try await` captures it
	// via StdCallOp.tryCall. Read here — after the VirtualFree above clobbered rdx,
	// and BEFORE the return-to-free-list below, which on its overflow path __slab_frees
	// the GT struct (after which gt.threw is no longer readable).
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffThrew)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // save threw

	// Return the promise GT struct to this P's free list (cap MaxFreeListLen=64;
	// beyond that __slab_free it). Ports C# EmitGtReturnToFreeList. This recycles the
	// awaited GT — previously the struct leaked ("never freed"). The per-P free list
	// is owner-only (no lock — matches C#); reuse via the __gt_spawn fast path. The
	// stack was already VirtualFree'd above. r11 = P (via TLS).
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	// if P.freeListLen >= MaxFreeListLen → free_full
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffFreeListLen)
	helperCmpRegImm(code, reg: X64Register.rax, value: MaxFreeListLen)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 8)  // jae free_full
	// not full: gt.next = P.freeListHead ; P.freeListHead = gt ; P.freeListLen++
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // gt = promise
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffFreeListHead)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffNext, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: POffFreeListHead, src: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffFreeListLen)
	code.append(b"\x48\x83\xc0\x01")  // add rax, 1
	helperStoreIndirect(code, base: X64Register.r11, disp: POffFreeListLen, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 9)  // jmp free_done

	// block 8: free_full — __slab_free(gt). Internal ABI (rcx = ptr).
	helperMarkBlock(state, code: code, blockId: 8)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")

	// block 9: free_done — return saved result in r8 and saved threw in rdx.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.r8)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtAwait'

// dest = &__gt_timer_heap[<slot idxSlot>] for the 16-byte cooperative-sleep timer
// entries, given the heap base address cached in slot `baseSlot`. Clobbers `scratch`.
// Collapses the `load index / shl 4 / load base / add` heap-element address arithmetic
// repeated across the timer min-heap emitters below.
function helperLoadTimerEntryAddr(code ByteArray, idxSlot VarSlot, baseSlot VarSlot, dest X64Register, scratch X64Register)
	helperLoadSlot(code, slotIndex: idxSlot, dest: dest)
	helperShlRegImm(code, dest: dest, value: 4)
	helperLoadSlot(code, slotIndex: baseSlot, dest: scratch)
	emitAddRegRegParam(code, dest: dest, src: scratch)
end 'helperLoadTimerEntryAddr'

// __gt_timer_add(gt=rcx, deadline=rdx): insert (deadline, gt) into the cooperative
// sleep timer min-heap under `__gt_timer_cs`, keyed by `deadline` (an absolute
// GetTickCount64 millisecond value). Sift-up restores the min-heap property. Ports
// the C# bootstrap's RuntimeEmitter.EmitGtTimerAdd. No result. Slots: 0=gt,
// 1=deadline, 2=i, 3=heap_base, 4=parent.
function emitX64GtTimerAdd(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_timer_add", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 40)
	helperPrologue(code, frameSize: 80)

	// block 0: entry — lock, append (deadline, gt) at heap[count], count++.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // gt
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // deadline
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_timer_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// i = count ; count++
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // i
	emitAddRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_timer_count")
	// heap_base → slot 3
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_timer_heap", rdataRelocs: rdataRelocs)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	// &heap[i] = heap_base + i*16 → rcx ; store {deadline, gt}
	helperLoadTimerEntryAddr(code, idxSlot: 2, baseSlot: 3, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[i]
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // deadline
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // gt
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)

	// block 1: sift_up — while i != 0 and heap[i].deadline < heap[parent].deadline, swap.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // i
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz done (at root)
	// parent = (i - 1) >> 1 → slot 4
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	code.append(b"\x48\xd1\xe8")  // shr rax, 1
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)
	// &heap[i] → rcx
	helperLoadTimerEntryAddr(code, idxSlot: 2, baseSlot: 3, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[i]
	// &heap[parent] → r10
	helperLoadTimerEntryAddr(code, idxSlot: 4, baseSlot: 3, dest: X64Register.r10, scratch: X64Register.rax)  // &heap[parent]
	// rdx = heap[i].deadline ; rax = heap[parent].deadline
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rcx, disp: 0)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: 0)
	emitCmpRegRegOp(code, lhs: X64Register.rdx, rhs: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 2)  // jae done (i >= parent)
	// swap deadline (offset 0): heap[i] gets parent.deadline, heap[parent] gets i.deadline
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: 0, src: X64Register.rdx)
	// swap gt (offset 8)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: 8)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r10, disp: 8, src: X64Register.rax)
	// i = parent ; loop
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// block 2: done — unlock.
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_timer_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtTimerAdd'

// __gt_timer_check(): pop every timer whose deadline has passed (now = GetTickCount64)
// and re-ready its GT — setting status=ready and, for a non-main GT, __gt_enqueue'ing
// it. Sift-down restores the min-heap after each pop. Driven from the worker loop,
// `__gt_await`, and the sleep park so a sleeping GT wakes cooperatively. Ports the C#
// bootstrap's RuntimeEmitter.EmitGtTimerCheck. No args, no result. Slots: 0=now,
// 1=heap_base, 2=gt, 3=i, 4=smallest, 5=left, 6=right.
function emitX64GtTimerCheck(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_timer_check", offset: code.count())
	var state = Win32HelperState.create(8, outgoingBytes: 32, localBytes: 56)
	helperPrologue(code, frameSize: 96)

	// block 0: entry — lock-free fast path on count==0, then lock + snapshot now/heap_base.
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)  // jz ret
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_timer_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz unlock
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getTickCount64))  // rax = now
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_timer_heap", rdataRelocs: rdataRelocs)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	// block 1: loop — if heap[0].deadline > now (or empty) stop; else pop the root.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz unlock
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // heap_base
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)  // heap[0].deadline
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)  // now
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x87, targetBlock: 6)  // ja unlock (deadline > now)
	// gt = heap[0].gt → slot 2
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// count--
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_timer_count")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz fire (heap now empty)
	// move heap[count] → heap[0]
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__gt_timer_count")
	helperShlRegImm(code, dest: X64Register.rcx, value: 4)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)  // &heap[count]
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.r10)  // &heap[0]
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreIndirect(code, base: X64Register.r10, disp: 0, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreIndirect(code, base: X64Register.r10, disp: 8, src: X64Register.rax)
	// i = 0
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// block 2: sift_down — pick the smaller child; if it beats heap[i], swap and descend.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // i
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rcx)  // 2*i
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)  // left = 2*i + 1
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rcx)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__gt_timer_count")
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 4)  // jae fire (no children)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rcx)  // smallest = left
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 1)  // right = left + 1
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rcx)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__gt_timer_count")
	emitCmpRegRegOp(code, lhs: X64Register.rcx, rhs: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 3)  // jae cmp_parent (no right child)
	// if heap[right].deadline < heap[left].deadline → smallest = right
	helperLoadTimerEntryAddr(code, idxSlot: 6, baseSlot: 1, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[right]
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rcx, disp: 0)  // right.deadline
	helperLoadTimerEntryAddr(code, idxSlot: 5, baseSlot: 1, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[left]
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)  // left.deadline
	emitCmpRegRegOp(code, lhs: X64Register.rdx, rhs: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 3)  // jae cmp_parent (right >= left)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rcx)  // smallest = right

	// block 3: cmp_parent — if heap[smallest] beats heap[i], swap and continue; else done.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadTimerEntryAddr(code, idxSlot: 4, baseSlot: 1, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[smallest]
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rcx, disp: 0)  // smallest.deadline
	helperLoadTimerEntryAddr(code, idxSlot: 3, baseSlot: 1, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[i]
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)  // i.deadline
	emitCmpRegRegOp(code, lhs: X64Register.rdx, rhs: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 4)  // jae fire (heap property restored)
	// swap heap[i] and heap[smallest]: rcx = &heap[i], r10 = &heap[smallest]
	helperLoadTimerEntryAddr(code, idxSlot: 3, baseSlot: 1, dest: X64Register.rcx, scratch: X64Register.rax)  // &heap[i]
	helperLoadTimerEntryAddr(code, idxSlot: 4, baseSlot: 1, dest: X64Register.r10, scratch: X64Register.rax)  // &heap[smallest]
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r10, disp: 0, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: 8)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r10, disp: 8, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // i = smallest
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 4: fire — status=ready; enqueue unless the GT is the main thread (stackBase==0).
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // gt
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffStatus, src: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz skip_enqueue
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // gt
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_enqueue")

	// block 5: skip_enqueue — loop back to drain the next expired timer.
	helperMarkBlock(state, code: code, blockId: 5)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// block 6: unlock.
	helperMarkBlock(state, code: code, blockId: 6)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_timer_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))

	// block 7: ret.
	helperMarkBlock(state, code: code, blockId: 7)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtTimerCheck'

// maxon_sleep(ms=rcx): suspend the current green thread for `ms` milliseconds as a
// cooperative yield. Computes deadline = GetTickCount64() + ms, marks self waiting,
// adds (deadline, self) to the timer heap, then yields to the scheduler until
// __gt_timer_check re-readies self. The main thread runs an inline scheduler loop
// (run other GTs / park on its wake event); a worker GT context-switches to its P's
// mainThread (the worker loop) and resumes when re-enqueued. Ports the C# bootstrap's
// X86CodeEmitter EmitSleep. Void. Slots: 0=ms, 1=deadline, 2=dequeued GT.
function emitX64MaxonSleep(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "maxon_sleep", offset: code.count())
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 24)
	helperPrologue(code, frameSize: 64)

	// block 0: entry — register the timer, decide main-thread vs worker-GT yield.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // ms
	// Lazy scheduler init so sleep works even with no `async` in the program.
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_init")
	// deadline = GetTickCount64() + ms
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getTickCount64))
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)  // deadline
	// self = P.currentGt ; self.status = waiting
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.r11, disp: GtOffStatus, src: X64Register.rax)
	// __gt_timer_add(self, deadline)
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.r11)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_timer_add")
	// Re-fetch self (timer_add clobbered r11); main thread iff self.stackBase == 0.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz mainthread_loop

	// block 1: worker-GT path — switch to P.mainThread (the worker loop), resume later.
	helperMarkBlock(state, code: code, blockId: 1)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)  // r10 = P
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r10, disp: POffMainThread + GtOffStatus, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)  // from = self
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r10)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: POffMainThread)  // to = &P.mainThread
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperEmitJmp(code, state: state, targetBlock: 4)  // resume

	// block 2: mainthread_loop — drive the scheduler until our timer fires.
	helperMarkBlock(state, code: code, blockId: 2)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_timer_check")
	// if self.status != waiting → resume
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusWaiting)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 4)  // jne resume
	// dequeue a runnable GT and run it while we wait
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")  // r8 = GT or 0
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz park
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rax)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)  // from = self
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // to = dequeued GT
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	// Resumed: set the dispatched GT's (slot 2) ioYielded=1 from the local slot
	// (C# resume-point discipline), so its awaiter can safely free its stack.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 2)  // loop

	// block 3: park — no runnable GT; wait briefly on our wake event, then re-check.
	helperMarkBlock(state, code: code, blockId: 3)
	emitX64GtLoadCurrentP(code, dest: X64Register.rax, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: POffWakeEvent)
	helperMovRegImm(code, dest: X64Register.rdx, value: 10)  // 10 ms (responsive for sleep timers)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitJmp(code, state: state, targetBlock: 2)  // loop

	// block 4: resume — the timer expired (and, for a worker GT, we were re-enqueued).
	helperMarkBlock(state, code: code, blockId: 4)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64MaxonSleep'

// Emit a ≤4-arg Win32 IAT call that, when the caller is running on a green
// thread's small stack, runs on the per-P 64 KB system stack instead (heavy
// kernel calls like GetFileAttributesExW probe the TIB stack bounds and fault
// on a 2 KB GT stack). Mirrors the C# bootstrap's EmitCallImportOnSystemStack,
// reading the current P from this OS thread's TLS slot. Args must already be in
// rcx/rdx/r8/r9; the result is left in rax on both paths. Uses a private block
// state for its own skip/done jumps.
function emitX64GtIatCallOnSystemStack(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, slotIndex MachineWord)
	var st = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperMarkBlock(st, code: code, blockId: 0)
	// Guard 1: no scheduler yet (P == 0) → call directly.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip
	// Guard 2: on the main OS thread (currentGt.stackBase == 0) → call directly.
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip
	// GT path: switch RSP to the per-P system stack for the kernel call.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)  // r11 = P
	code.append(b"\x41\x52")  // push r10 (save caller's r10 on the GT stack)
	code.append(b"\x49\x89\xe2")  // mov r10, rsp (r10 = GT rsp)
	helperLoadIndirect(code, dest: X64Register.rsp, base: X64Register.r11, disp: POffSystemStackSP)  // rsp = system stack top
	code.append(b"\x41\x52")  // push r10 (save GT rsp on the system stack)
	code.append(b"\x48\x83\xec\x28")  // sub rsp, 0x28 (shadow 0x20 + pad 0x08 → 16-aligned)
	// Repoint the TIB stack bounds at the system stack for the call.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffSystemStackSP)
	code.append(b"\x65\x48\x89\x04\x25\x08\x00\x00\x00")  // mov gs:[0x08], rax (StackBase)
	code.append(b"\x48\x2d\x00\x00\x01\x00")  // sub rax, 0x10000 (PSystemStackSize)
	code.append(b"\x65\x48\x89\x04\x25\x10\x00\x00\x00")  // mov gs:[0x10], rax (StackLimit)
	helperEmitIatCall(code, relocations: relocations, slotIndex: slotIndex)
	code.append(b"\x48\x83\xc4\x28")  // add rsp, 0x28
	// Restore the TIB to the GT's saved bounds (the call may have clobbered r11).
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)  // r11 = GT
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r11, disp: GtOffTibStackBase)
	code.append(b"\x65\x48\x89\x0c\x25\x08\x00\x00\x00")  // mov gs:[0x08], rcx
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r11, disp: GtOffTibStackLimit)
	code.append(b"\x65\x48\x89\x0c\x25\x10\x00\x00\x00")  // mov gs:[0x10], rcx
	code.append(b"\x41\x5a")  // pop r10 (r10 = GT rsp)
	code.append(b"\x4c\x89\xd4")  // mov rsp, r10 (restore GT rsp)
	code.append(b"\x41\x5a")  // pop r10 (restore caller's r10)
	helperEmitJmp(code, state: st, targetBlock: 2)  // jmp done
	// skip: direct kernel call on the current (large) stack.
	helperMarkBlock(st, code: code, blockId: 1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: slotIndex)
	// done.
	helperMarkBlock(st, code: code, blockId: 2)
	helperFinalize(st, code: code)
end 'emitX64GtIatCallOnSystemStack'

// System-stack switch for a Win32 import with >4 args (stack args). Unlike the
// ≤4-arg wrapper, the switch happens BEFORE the helper writes its outgoing stack
// args, so they land on the system stack (`[rsp+0x20..]`). Ports the C#
// EmitSystemStackEnter; pair with emitX64GtSystemStackLeave(frameSize). On a GT,
// switches RSP to the per-P system stack + repoints the TIB and SUBs frameSize+8;
// on the main thread, just SUBs frameSize. `frameSize` = shadow(0x20) + stack-arg
// bytes, rounded so RSP is 16-aligned at the call.
function emitX64GtSystemStackEnter(code ByteArray, rdataRelocs RdataRelocationArray, frameSize MachineWord)
	var st = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperMarkBlock(st, code: code, blockId: 0)
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip (no P)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip (main thread)
	// GT path: switch to the system stack and reserve the outgoing-arg frame.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)  // r11 = P
	code.append(b"\x41\x52")  // push r10 (save caller's r10 on the GT stack)
	code.append(b"\x49\x89\xe2")  // mov r10, rsp (GT rsp)
	helperLoadIndirect(code, dest: X64Register.rsp, base: X64Register.r11, disp: POffSystemStackSP)  // rsp = system stack top
	code.append(b"\x41\x52")  // push r10 (save GT rsp on the system stack)
	code.append(b"\x48\x81\xec")  // sub rsp, imm32 (frameSize + 8 pad → 16-aligned)
	writeDword(code, value: frameSize + 8)
	// Repoint the TIB at the system stack for the upcoming kernel call.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffSystemStackSP)
	code.append(b"\x65\x48\x89\x04\x25\x08\x00\x00\x00")  // mov gs:[0x08], rax
	code.append(b"\x48\x2d\x00\x00\x01\x00")  // sub rax, 0x10000 (PSystemStackSize)
	code.append(b"\x65\x48\x89\x04\x25\x10\x00\x00\x00")  // mov gs:[0x10], rax
	helperEmitJmp(code, state: st, targetBlock: 2)  // jmp done
	// skip (main thread / no scheduler): just reserve the frame on the current stack.
	helperMarkBlock(st, code: code, blockId: 1)
	code.append(b"\x48\x81\xec")  // sub rsp, imm32 (frameSize)
	writeDword(code, value: frameSize)
	// done.
	helperMarkBlock(st, code: code, blockId: 2)
	helperFinalize(st, code: code)
end 'emitX64GtSystemStackEnter'

// Tear down emitX64GtSystemStackEnter: on a GT, restore the TIB to the GT's
// bounds, undo the frame, switch RSP back to the GT stack, restore r10; on the
// main thread, just ADD frameSize. Preserves rax (the kernel call's result).
// Ports the C# EmitSystemStackLeave.
function emitX64GtSystemStackLeave(code ByteArray, rdataRelocs RdataRelocationArray, frameSize MachineWord)
	var st = Win32HelperState.create(3, outgoingBytes: 0, localBytes: 0)
	helperMarkBlock(st, code: code, blockId: 0)
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.r11)
	helperEmitCondJump(code, state: st, opcode: 0x84, targetBlock: 1)  // jz skip
	// GT path: restore the GT's TIB bounds, undo the frame, switch back.
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: POffCurrentGt)  // r11 = GT
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r11, disp: GtOffTibStackBase)
	code.append(b"\x65\x48\x89\x0c\x25\x08\x00\x00\x00")  // mov gs:[0x08], rcx
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r11, disp: GtOffTibStackLimit)
	code.append(b"\x65\x48\x89\x0c\x25\x10\x00\x00\x00")  // mov gs:[0x10], rcx
	code.append(b"\x48\x81\xc4")  // add rsp, imm32 (frameSize + 8)
	writeDword(code, value: frameSize + 8)
	code.append(b"\x41\x5a")  // pop r10 (GT rsp)
	code.append(b"\x4c\x89\xd4")  // mov rsp, r10 (restore GT rsp)
	code.append(b"\x41\x5a")  // pop r10 (restore caller's r10)
	helperEmitJmp(code, state: st, targetBlock: 2)  // jmp done
	// skip: just release the frame on the current stack.
	helperMarkBlock(st, code: code, blockId: 1)
	code.append(b"\x48\x81\xc4")  // add rsp, imm32 (frameSize)
	writeDword(code, value: frameSize)
	// done.
	helperMarkBlock(st, code: code, blockId: 2)
	helperFinalize(st, code: code)
end 'emitX64GtSystemStackLeave'

// __gt_spawn(func_ptr=rcx, arg_count=rdx, arg_buf=rax) -> r8 (promise = gt).
// Ensures the scheduler is initialised, allocates a GreenThread struct + a 2 KB
// VirtualAlloc'd stack, lays the initial stack out so the first context switch
// `ret`s into __gt_trampoline, and enqueues the GT as ready. Local slots:
//   0=func_ptr  1=arg_count  2=arg_buf  3=gt_ptr  4=stack_base
function emitX64GtSpawn(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_spawn", offset: code.count())
	// Blocks: 0=entry, 1=alloc_new (free-list miss), 2=got_gt (alloc join).
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 40)
	helperPrologue(code, frameSize: 80)
	helperMarkBlock(state, code: code, blockId: 0)

	// Save incoming args (func=rcx, count=rdx, buf=rax).
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// Lazy one-time scheduler init.
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_init")

	// Allocate the GreenThread struct: try the per-P free list first (touched only
	// by the owning worker — no lock — matching C# EmitGtSpawn), else __slab_alloc.
	// r11 = P (this OS thread's ProcContext, via TLS).
	emitX64GtLoadCurrentP(code, dest: X64Register.r11, rdataRelocs: rdataRelocs)
	// rax = P.freeListHead ; if null → alloc_new
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffFreeListHead)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz alloc_new
	// free-list hit: gt = head ; P.freeListHead = gt.next ; P.freeListLen--
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // gt = head
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: GtOffNext)  // gt.next
	helperStoreIndirect(code, base: X64Register.r11, disp: POffFreeListHead, src: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r11, disp: POffFreeListLen)
	code.append(b"\x48\x83\xe8\x01")  // sub rax, 1
	helperStoreIndirect(code, base: X64Register.r11, disp: POffFreeListLen, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 2)  // jmp got_gt

	// block 1: alloc_new — gt = __slab_alloc(GtStructSize)   (rcx=size, result r8)
	helperMarkBlock(state, code: code, blockId: 1)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStructSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)

	// block 2: got_gt — the GT struct is in slot 3 either way.
	helperMarkBlock(state, code: code, blockId: 2)

	// stack_base = VirtualAlloc(NULL, GtInitialStackSize, MEM_COMMIT|RESERVE, PAGE_RW)
	// Win64 ABI: rcx=lpAddress, rdx=dwSize, r8=flAllocationType, r9=flProtect → rax
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx (lpAddress = NULL)
	helperMovRegImm(code, dest: X64Register.rdx, value: GtInitialStackSize)
	helperMovRegImm(code, dest: X64Register.r8, value: MemCommitReserve)
	helperMovRegImm(code, dest: X64Register.r9, value: PageReadWrite)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualAlloc))
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	// Initialise GreenThread fields. r10 = gt for the duration.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r10)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStackBase, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: GtInitialStackSize)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStackSize, src: X64Register.rax)
	// stackguard = stack_base + GtStackGuardMargin
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	code.append(b"\x48\x05\xa0\x03\x00\x00")  // add rax, 0x3A0
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStackGuard, src: X64Register.rax)
	// tib_stack_base = stack_base + GtInitialStackSize ; tib_stack_limit = stack_base
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	code.append(b"\x48\x05\x00\x08\x00\x00")  // add rax, 0x800 (GtInitialStackSize)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffTibStackBase, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffTibStackLimit, src: X64Register.rax)
	// func_ptr, arg_buf
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffFuncPtr, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffArgBuf, src: X64Register.rax)
	// status=ready(0), result=0, waiter=0, next=0, threw=0
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffResult, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffWaiter, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffNext, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffThrew, src: X64Register.rax)
	// ioYielded = 1
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoYielded, src: X64Register.rax)

	// Initial stack layout. r11 = stack_top = stack_base + GtInitialStackSize.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.r11)
	code.append(b"\x49\x81\xc3\x00\x08\x00\x00")  // add r11, 0x800 (GtInitialStackSize)
	// Zero the 8 top slots: [stack_top - i*8] = 0 for i = 1..8.
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 8, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 16, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 24, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 32, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 40, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 48, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 56, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 64, src: X64Register.rax)
	// [stack_top - 8] = &__gt_trampoline (return address for the first context-switch ret).
	emitLeaFuncAddrOp(code, dest: X64Register.rax, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__gt_trampoline")
	helperStoreIndirect(code, base: X64Register.r11, disp: 0 - 8, src: X64Register.rax)
	// gt.rsp = stack_top - 64 ; gt.rbp = 0
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r11)
	code.append(b"\x48\x83\xe8\x40")  // sub rax, 64
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffRsp, src: X64Register.rax)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffRbp, src: X64Register.rax)

	// Assign a monotonic trace id (LOCK XADD __gt_trace_counter; id = prior + 1) and
	// store it on the GT, then emit `spawn #<id>`. __gt_trace_emit self-gates on
	// __at_trace_enabled, so this is a cheap no-op for non-trace builds.
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_trace_counter", rdataRelocs: rdataRelocs)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitLockXaddMemRegOp(code, addrReg: X64Register.rax, valReg: X64Register.rcx)  // rcx = prior count
	code.append(b"\x48\x83\xc1\x01")  // add rcx, 1
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffTraceId, src: X64Register.rcx)
	// __gt_trace_emit(tag=&"spawn #", value=id, suffix=0)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_tag_spawn", rdataRelocs: rdataRelocs)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: GtOffTraceId)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (no suffix)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_trace_emit")

	// Link the new GT onto the global all-threads list under __sched_all_cs (the
	// list is shared across worker OS threads), then atomically bump the live count.
	// Ports C# EmitGtSpawn (the all-threads link + LOCK INC __gt_live_count). The
	// EnterCriticalSection / LeaveCriticalSection go through the per-P system stack
	// (emitX64GtIatCallOnSystemStack) so they're safe when __gt_spawn runs on a GT's
	// small stack (nested async). The kernel calls clobber volatiles, so gt is
	// reloaded from slot 3 between them.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_all_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// gt.all_next = __gt_all_head ; __gt_all_head = gt
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r10)  // gt
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_all_head")
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffAllNext, src: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.r10, name: "__gt_all_head")
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_all_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	// LOCK INC qword [__gt_live_count]
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__gt_live_count", rdataRelocs: rdataRelocs)
	emitLockIncMemoryOp(code, addrReg: X64Register.rax)

	// __gt_enqueue(gt)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_enqueue")

	// Return the gt as the promise (r8).
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtSpawn'

// __gt_enqueue(g=rcx): append the green thread `g` to the tail of the global FIFO
// run queue under `__sched_global_queue_cs`, then (after releasing the lock) run
// the wake phase: scan P[1..num_procs-1] for an idle worker and SetEvent it, or —
// if none is idle and active_workers < max_procs — lazily CreateThread a worker on
// the next stopped P. This is what makes the scheduler genuinely multi-OS-thread
// while staying dormant for non-async programs (which never enqueue a GT). Ports
// the C# EmitGtEnqueue wake phase (global-queue subset). SetEvent/CreateThread go
// through the system-stack wrappers so they're safe when `g` was enqueued from a
// GT's small stack (nested async). Internal ABI; no result. Slots: 0=g,
// 1=num_procs, 2=loop index i, 3=P[i].
function emitX64GtEnqueue(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_enqueue", offset: code.count())
	var state = Win32HelperState.create(9, outgoingBytes: 32, localBytes: 32)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // save g
	// EnterCriticalSection(&__sched_global_queue_cs)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_global_queue_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // reload g
	// g.next = 0
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffNext, src: X64Register.rax)
	// rdx = run_queue_tail; if null → empty queue
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__gt_run_queue_tail")
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz empty
	// non-empty: tail.next = g ; run_queue_tail = g
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffNext, src: X64Register.rcx)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__gt_run_queue_tail")
	helperEmitJmp(code, state: state, targetBlock: 2)  // jmp leave
	// empty: run_queue_head = run_queue_tail = g
	helperMarkBlock(state, code: code, blockId: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__gt_run_queue_head")
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__gt_run_queue_tail")
	// leave: LeaveCriticalSection(&__sched_global_queue_cs), then the wake phase.
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_global_queue_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	// Full barrier between the queue-publish above and the idleFlag reads below —
	// closes the Dekker-style missed-wakeup race against a worker's park sequence
	// (store idleFlag=1 via XCHG; re-dequeue). MFENCE = 0F AE F0.
	code.append(b"\x0f\xae\xf0")
	// if __sched_shutdown_flag != 0 → done (don't wake/spawn during teardown)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_shutdown_flag")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 8)  // jnz done
	// num_procs → slot 1 ; i = 1 → slot 2
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_num_procs")
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// block 3: wake_loop — scan P[1..num_procs-1] for an idle worker.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // i
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)  // num_procs
	code.append(b"\x48\x39\xd0")  // cmp rax, rdx
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 5)  // jae spawn_phase
	// P[i] = __sched_procs[i]
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__sched_procs")
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // i
	code.append(b"\x48\x8d\x0c\xd1")  // lea rcx, [rcx + rdx*8]
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)
	// if P[i].idleFlag == 0 → wake_next
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: POffIdleFlag)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz wake_next
	// idle worker found: clear its idleFlag, SetEvent its wake event, done.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffIdleFlag, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: POffWakeEvent)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setEvent))
	helperEmitJmp(code, state: state, targetBlock: 8)  // jmp done

	// block 4: wake_next — i++ ; loop.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	code.append(b"\x48\x83\xc0\x01")  // add rax, 1
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// block 5: spawn_phase — no idle worker; spawn one if under the cap.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_active_workers")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__sched_max_procs")
	code.append(b"\x48\x39\xd0")  // cmp rax, rdx
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 8)  // jae done (at cap)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // i = 1

	// block 6: spawn_scan — find the first stopped P and CreateThread a worker on it.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // i
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)  // num_procs
	code.append(b"\x48\x39\xd0")  // cmp rax, rdx
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 8)  // jae done
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__sched_procs")
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // i
	code.append(b"\x48\x8d\x0c\xd1")  // lea rcx, [rcx + rdx*8]
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)
	// if P[i].status != 0 (already running) → spawn_next
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: POffStatus)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 7)  // jnz spawn_next
	// claim it: P[i].status = 1
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffStatus, src: X64Register.rax)
	// CreateThread(NULL, 0, &__sched_worker_loop, P[i], 0, NULL) on the system stack.
	// frameSize 0x30 = shadow(0x20) + 2 stack args at [rsp+0x20]/[rsp+0x28].
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx (lpThreadAttributes = NULL)
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (dwStackSize = 0)
	emitLeaFuncAddrOp(code, dest: X64Register.r8, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__sched_worker_loop")
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r9)  // lpParameter = P[i]
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rsp, disp: 0x20, src: X64Register.rax)  // dwCreationFlags = 0
	helperStoreIndirect(code, base: X64Register.rsp, disp: 0x28, src: X64Register.rax)  // lpThreadId = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createThread))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	// P[i].osThreadHandle = rax (the CreateThread HANDLE)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffOsThreadHandle, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 8)  // jmp done

	// block 7: spawn_next — i++ ; loop.
	helperMarkBlock(state, code: code, blockId: 7)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	code.append(b"\x48\x83\xc0\x01")  // add rax, 1
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)

	// block 8: done.
	helperMarkBlock(state, code: code, blockId: 8)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtEnqueue'

// __gt_dequeue() -> r8: pop the head green thread off the global FIFO run queue,
// or 0 if empty, under `__sched_global_queue_cs`. Internal ABI (result in r8).
// Slot 0 holds the popped GT across the LeaveCriticalSection call.
function emitX64GtDequeue(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_dequeue", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 8)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	// EnterCriticalSection(&__sched_global_queue_cs)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_global_queue_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// rax = run_queue_head; save it (the result, 0 if empty) to slot 0.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_run_queue_head")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz leave (empty)
	// run_queue_head = g.next
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: GtOffNext)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdx, name: "__gt_run_queue_head")
	// if new head != 0, queue not empty → leave; else clear tail too
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz leave
	// new head is null → clear tail
	helperMarkBlock(state, code: code, blockId: 1)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__gt_run_queue_tail")
	// leave: LeaveCriticalSection then return the saved GT in r8.
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_global_queue_cs", rdataRelocs: rdataRelocs)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtDequeue'

// __gt_init(): one-time scheduler init (idempotent via __gt_init_done). Ports the
// C# EmitSchedInit: allocates a TLS slot for the per-OS-thread ProcContext*, sizes
// the P array to GetSystemInfo's CPU count, VirtualAllocs the P* array and each P
// struct (untracked — they don't count toward the leak balance), gives each P an
// id / xorshift seed / auto-reset wake event / 64 KB system stack, then makes P[0]
// the current OS thread's P (TLS + currentGt → its inline mainThread + saved TIB
// bounds) and initializes the run-queue critical section. Worker OS threads (lazily
// CreateThread'd by __gt_enqueue) adopt P[1..] via __sched_worker_loop. Called at
// the first `async` spawn. Slots: 0=procs_array, 1=num_procs, 2=i, 3=P[i],
// 4..9=SYSTEM_INFO scratch (48 bytes, base at slot 9 = rbp-0x50).
function emitX64GtInit(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_init", offset: code.count())
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 80)
	helperPrologue(code, frameSize: 112)
	helperMarkBlock(state, code: code, blockId: 0)
	// if __gt_init_done != 0, skip to done
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_init_done")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 4)  // jnz done
	// TLS slot + precomputed gs: offset (teb_offset = index*8 + 0x1480).
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.tlsAlloc))  // rax = index
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_tls_index")
	code.append(b"\x48\xc1\xe0\x03")  // shl rax, 3
	code.append(b"\x48\x05\x80\x14\x00\x00")  // add rax, 0x1480
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_tls_teb_offset")
	// num_procs = GetSystemInfo(&sysinfo).dwNumberOfProcessors (DWORD at +0x20).
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rcx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getSystemInfo))
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rax)
	code.append(b"\x8b\x40\x20")  // mov eax, [rax+0x20] (zero-extends dwNumberOfProcessors)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_num_procs")
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_max_procs")
	// procs_array = VirtualAlloc(NULL, num_procs*8, COMMIT|RESERVE, PAGE_RW)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	code.append(b"\x48\xc1\xe2\x03")  // shl rdx, 3 (num_procs * 8)
	helperMovRegImm(code, dest: X64Register.r8, value: MemCommitReserve)
	helperMovRegImm(code, dest: X64Register.r9, value: PageReadWrite)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualAlloc))
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_procs")
	// i = 0
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// loop header: if i >= num_procs → after_loop.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	code.append(b"\x48\x39\xd0")  // cmp rax, rdx
	helperEmitCondJump(code, state: state, opcode: 0x83, targetBlock: 3)  // jae after_loop

	// loop body: allocate + initialize P[i].
	helperMarkBlock(state, code: code, blockId: 2)
	// P[i] = VirtualAlloc(NULL, PStructSize, COMMIT|RESERVE, PAGE_RW)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperMovRegImm(code, dest: X64Register.rdx, value: PStructSize)
	helperMovRegImm(code, dest: X64Register.r8, value: MemCommitReserve)
	helperMovRegImm(code, dest: X64Register.r9, value: PageReadWrite)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualAlloc))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	// procs[i] = P[i]
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // procs
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // i
	code.append(b"\x48\x8d\x0c\xd1")  // lea rcx, [rcx + rdx*8]
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	code.append(b"\x48\x89\x01")  // mov [rcx], rax
	// P[i].id = i ; P[i].rng = i + 1
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // P[i]
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // i
	helperStoreIndirect(code, base: X64Register.rax, disp: POffId, src: X64Register.rcx)
	code.append(b"\x48\x83\xc1\x01")  // add rcx, 1
	helperStoreIndirect(code, base: X64Register.rax, disp: POffRng, src: X64Register.rcx)
	// P[i].wakeEvent = CreateEventA(NULL, FALSE=auto-reset, FALSE, NULL)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createEventA))
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffWakeEvent, src: X64Register.rax)
	// P[i].systemStackSP = VirtualAlloc(NULL, PSystemStackSize, COMMIT|RESERVE, RW) + size
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperMovRegImm(code, dest: X64Register.rdx, value: PSystemStackSize)
	helperMovRegImm(code, dest: X64Register.r8, value: MemCommitReserve)
	helperMovRegImm(code, dest: X64Register.r9, value: PageReadWrite)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.virtualAlloc))
	code.append(b"\x48\x05\x00\x00\x01\x00")  // add rax, 0x10000 (PSystemStackSize)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffSystemStackSP, src: X64Register.rax)
	// P[i].mainThread.stackBase = 0 ; .stackGuard = 0 (treat the OS thread as non-GT)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffMainThread + GtOffStackBase, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: POffMainThread + GtOffStackGuard, src: X64Register.rax)
	// i++ ; loop
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	code.append(b"\x48\x83\xc0\x01")  // add rax, 1
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// after_loop: adopt P[0] as the current OS thread's processor.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // procs
	code.append(b"\x48\x8b\x01")  // mov rax, [rcx]  (P[0])
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)  // r8 = P[0]
	// (No `__gt_current_p` global store here: the x64 runtime reads the current P
	// from each OS thread's TLS slot — set via TlsSetValue below and in the worker
	// loop — so unlike the wasm runtime it keeps no `__gt_current_p` global mirror.)
	// P[0].status = 1 (active)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.r8, disp: POffStatus, src: X64Register.rcx)
	// P[0].currentGt = &P[0].mainThread
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	code.append(b"\x48\x05\x80\x00\x00\x00")  // add rax, 0x80
	helperStoreIndirect(code, base: X64Register.r8, disp: POffCurrentGt, src: X64Register.rax)
	// P[0].mainThread TIB StackBase/StackLimit ← gs:[0x08]/gs:[0x10] (the OS thread's
	// real stack bounds, restored when context-switching back to main).
	code.append(b"\x65\x48\x8b\x0c\x25\x08\x00\x00\x00")  // mov rcx, gs:[0x08]
	helperStoreIndirect(code, base: X64Register.r8, disp: POffMainThread + GtOffTibStackBase, src: X64Register.rcx)
	code.append(b"\x65\x48\x8b\x0c\x25\x10\x00\x00\x00")  // mov rcx, gs:[0x10]
	helperStoreIndirect(code, base: X64Register.r8, disp: POffMainThread + GtOffTibStackLimit, src: X64Register.rcx)
	// TlsSetValue(index, P[0])
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__sched_tls_index")
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.tlsSetValue))
	// __sched_active_workers = 1 (the main thread counts as a running worker)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__sched_active_workers")
	// InitializeCriticalSection(&__sched_global_queue_cs)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_global_queue_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	// InitializeCriticalSection(&__sched_all_cs) guards the all-threads list link/unlink.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__sched_all_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	// InitializeCriticalSection(&__gt_timer_cs) guards the cooperative-sleep timer heap.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__gt_timer_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	// InitializeCriticalSection(&__at_trace_cs) — serializes async-trace lines.
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_trace_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	// Install the CPU-fault handler (VEH): AddVectoredExceptionHandler(First=1,
	// Handler=&__gt_fault_handler_thunk). Mirrors the C# bootstrap's "Step 9" at the
	// tail of __gt_init — a hardware fault on any worker thread now prints a clean
	// diagnostic and exits 1 instead of a silent 0xC0000005. Runs on the main OS
	// thread (currentGt.stackBase == 0), so the IAT call uses the real OS stack.
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitLeaFuncAddrOp(code, dest: X64Register.rdx, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__gt_fault_handler_thunk")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.addVectoredExceptionHandler))
	// __gt_init_done = 1
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__gt_init_done")

	// done:
	helperMarkBlock(state, code: code, blockId: 4)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64GtInit'

// __gt_context_switch(from=rcx, to=rdx): save the current green thread's
// register state into `from`, restore `to`'s, and `ret` into `to`'s saved
// return address. Pure stack/register manipulation — ports byte-exact from C#
// (EmitGtContextSwitch) except `P*` is read from this OS thread's TLS slot
// (via emitX64GtLoadCurrentP) rather than a single global.
function emitX64GtContextSwitch(code ByteArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_context_switch", offset: code.count())

	// Save callee-saved registers on the current (from) stack. push order must
	// mirror the pop order below and the zeroed-slot layout `__gt_spawn` builds.
	code.append(b"\x53\x56\x57")  // push rbx, rsi, rdi
	code.append(b"\x41\x54\x41\x55\x41\x56\x41\x57")  // push r12, r13, r14, r15

	// from->rsp = rsp ; from->rbp = rbp
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffRsp, src: X64Register.rsp)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffRbp, src: X64Register.rbp)
	// rsp = to->rsp ; rbp = to->rbp  (now on the destination stack)
	helperLoadIndirect(code, dest: X64Register.rsp, base: X64Register.rdx, disp: GtOffRsp)
	helperLoadIndirect(code, dest: X64Register.rbp, base: X64Register.rdx, disp: GtOffRbp)

	// Save the Win32 TIB stack bounds (gs:[0x08]=StackBase, gs:[0x10]=StackLimit)
	// into `from`, then restore `to`'s. Without repointing these, any Win32 call
	// on a green-thread stack faults in the kernel stack-probe.
	code.append(b"\x65\x48\x8b\x04\x25\x08\x00\x00\x00")  // mov rax, gs:[0x08]
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffTibStackBase, src: X64Register.rax)
	code.append(b"\x65\x48\x8b\x04\x25\x10\x00\x00\x00")  // mov rax, gs:[0x10]
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffTibStackLimit, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rdx, disp: GtOffTibStackBase)
	code.append(b"\x65\x48\x89\x04\x25\x08\x00\x00\x00")  // mov gs:[0x08], rax
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rdx, disp: GtOffTibStackLimit)
	code.append(b"\x65\x48\x89\x04\x25\x10\x00\x00\x00")  // mov gs:[0x10], rax

	// P->currentGt = to   (P* read from this OS thread's TLS slot)
	emitX64GtLoadCurrentP(code, dest: X64Register.rax, rdataRelocs: rdataRelocs)
	helperStoreIndirect(code, base: X64Register.rax, disp: POffCurrentGt, src: X64Register.rdx)

	// Restore callee-saved registers from the new stack (reverse push order).
	code.append(b"\x41\x5f\x41\x5e\x41\x5d\x41\x5c")  // pop r15, r14, r13, r12
	code.append(b"\x5f\x5e\x5b")  // pop rdi, rsi, rbx
	code.append(b"\xc3")  // ret (into to's saved return addr)
end 'emitX64GtContextSwitch'

// __sched_worker_loop(P=rcx): entry point a worker OS thread starts on (a
// CreateThread callback, so the Win64 ABI applies — lpParameter = P* in rcx).
// Adopts P as this OS thread's processor (TLS slot + the inline mainThread's TIB
// bounds/status + active-worker count), then loops: process any waiter a
// completed GT deferred, check the shutdown flag, dequeue a ready GT and
// context-switch into it (resuming here when the GT yields/completes back), or —
// when the queue is empty — publish idle + park on the per-P auto-reset wake
// event. On shutdown it drops the active-worker count, marks P stopped, and
// returns 0. Ports the C# EmitSchedWorkerLoop, restricted to the global-queue
// subset this runtime uses (no runnext / local queue / work-steal / timer / I/O).
// The IAT calls (TlsSetValue / WaitForSingleObject) run on the worker's real OS
// stack — the worker's mainThread has stackBase==0, so no system-stack switch is
// needed. Slots: 0=P*, 1=GT to run.
function emitX64SchedWorkerLoop(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__sched_worker_loop", offset: code.count())
	var state = Win32HelperState.create(7, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)

	// block 0: adopt P as this OS thread's processor, then fall into the loop.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // P* (CreateThread arg)
	// TlsSetValue(__sched_tls_index, P) — so emitX64GtLoadCurrentP sees our P.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__sched_tls_index")
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.tlsSetValue))
	// P.mainThread.status = running.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.rax, disp: POffMainThread + GtOffStatus, src: X64Register.rcx)
	// P.mainThread TIB bounds ← this OS thread's real gs:[0x08]/gs:[0x10], so a
	// context switch back to mainThread restores the worker's own stack bounds.
	code.append(b"\x65\x48\x8b\x0c\x25\x08\x00\x00\x00")  // mov rcx, gs:[0x08]
	helperStoreIndirect(code, base: X64Register.rax, disp: POffMainThread + GtOffTibStackBase, src: X64Register.rcx)
	code.append(b"\x65\x48\x8b\x0c\x25\x10\x00\x00\x00")  // mov rcx, gs:[0x10]
	helperStoreIndirect(code, base: X64Register.rax, disp: POffMainThread + GtOffTibStackLimit, src: X64Register.rcx)
	// P.currentGt = &P.mainThread ; P.status = 1 (active).
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rax)
	code.append(b"\x48\x81\xc1\x80\x00\x00\x00")  // add rcx, 0x80 (POffMainThread)
	helperStoreIndirect(code, base: X64Register.rax, disp: POffCurrentGt, src: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: POffStatus, src: X64Register.rcx)
	// LOCK INC [__sched_active_workers].
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__sched_active_workers", rdataRelocs: rdataRelocs)
	emitLockIncMemoryOp(code, addrReg: X64Register.rax)
	// Trace `worker_start #<P.id>` (stripped by the runner's normalizer, but emitted
	// for fidelity to the real GMP scheduler).
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_tag_worker_start", rdataRelocs: rdataRelocs)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffId)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (no suffix)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_trace_emit")

	// block 1: loop_top.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	// Fire any expired sleep timers (re-enqueues their GTs) before looking for work.
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_timer_check")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_shutdown_flag")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 4)  // jnz exit
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")  // r8 = GT or 0
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz park
	helperStoreSlot(code, slotIndex: 1, src: X64Register.r8)
	// fall through to run_gt.

	// block 2: run_gt — slot 1 holds the GT to run.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffStatus, src: X64Register.rcx)
	// context_switch(from=&P.mainThread, to=GT).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	code.append(b"\x48\x81\xc1\x80\x00\x00\x00")  // add rcx, 0x80 (POffMainThread)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	// Resumed: the GT we dispatched (slot 1) switched off its stack back to here. Set
	// ITS ioYielded=1 from the local slot — the C# resume-point discipline (name the
	// GT we switched to via a local, not a shared per-P field), which is what makes it
	// correct under nested awaits and across worker threads. Signals an async-I/O
	// completion that the GT is off its stack and safe to enqueue/free.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)  // loop

	// block 3: park — publish idleFlag=1 with an atomic XCHG (a full StoreLoad
	// fence), then re-dequeue to close the missed-wakeup window against an
	// enqueuer that read idleFlag before our publish.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r11)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	code.append(b"\x49\x87\x4b\x30")  // xchg [r11+POffIdleFlag], rcx (XCHG-mem is implicitly LOCK'd)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")  // r8 = GT or 0
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz really_park
	// Work arrived in the race window: clear idleFlag and run it.
	helperStoreSlot(code, slotIndex: 1, src: X64Register.r8)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: POffIdleFlag, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 2)  // run_gt

	// block 5: really_park — recheck shutdown, then wait on the per-P wake event
	// (with a 100 ms timeout as a missed-wakeup safety net), then unmark idle.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_shutdown_flag")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 4)  // jnz exit
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: POffWakeEvent)
	// Park timeout: 2 ms when sleep timers are pending (so they fire promptly even if
	// no SetEvent wakes us), else a 100 ms missed-wakeup safety net. rcx (wakeEvent)
	// survives the count load below.
	helperMovRegImm(code, dest: X64Register.rdx, value: 100)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__gt_timer_count")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz do_wait (no timers → 100 ms)
	helperMovRegImm(code, dest: X64Register.rdx, value: 2)
	// block 6: do_wait.
	helperMarkBlock(state, code: code, blockId: 6)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: POffIdleFlag, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 1)  // loop

	// block 4: exit — trace `worker_exit #<P.id>`, drop the active-worker count,
	// mark P stopped, return 0.
	helperMarkBlock(state, code: code, blockId: 4)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__at_tag_worker_exit", rdataRelocs: rdataRelocs)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r10)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffId)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (no suffix)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_trace_emit")
	emitLeaRipRelOp(code, dest: X64Register.rax, rdataLabel: "__sched_active_workers", rdataRelocs: rdataRelocs)
	emitLockDecMemoryOp(code, addrReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: POffStatus, src: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (thread exit code 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64SchedWorkerLoop'

// =============================================================================
// Tier 4 async-I/O: the IOCP completion machinery. Hand-emitted x64 machine code
// porting the C# bootstrap's `EmitIoRuntime` subsystem (X86CodeEmitter.Runtime.cs)
// to the self-hosted ABI. A dedicated IOCP-poller OS thread (`__io_completion_loop`)
// drains GetQueuedCompletionStatus and completes the parked green thread; a sync-
// fallback worker thread (`__io_sync_worker_loop`) services non-overlappable ops off
// a CRITICAL_SECTION-guarded request queue; `__io_submit_read` / `__io_submit_write`
// issue overlapped ReadFile / WriteFile and yield the green thread until IOCP signals
// completion; `__io_check_completions` drains the done queue and re-readies waiters.
//
// INERT until async-I/O specs land: no emitted lowering submits async I/O yet (the
// subprocess runtime deliberately uses a blocking model, file I/O uses the direct
// `mrt_win32_*` helpers), so the submit/poll paths are never reached at runtime. They
// are emitted for C# parity / completeness and so the wiring is in place when the
// specs arrive. `__io_init`/`__io_shutdown` themselves DO run: they are wired into
// `mrt_start` unconditionally (patchMrtStartCallIoInit / patchMrtStartCallIoShutdown,
// mirroring C#'s `_start`), so the IOCP completion thread + sync worker are brought up
// and torn down for every program. `__io_check_completions` is called from `__gt_await`,
// but with the done queue always live and empty it dequeues nothing and returns at
// once — see emitX64GtAwait.
//
// Deliberate divergences from the C# reference, all driven by self-hosted realities:
//   * Allocations use `__slab_alloc`/`__slab_free` (the self-hosted raw allocator,
//     which zeroes like HEAP_ZERO_MEMORY) rather than C#'s `mm_raw_alloc`/`mm_raw_free`.
//   * `__io_init` omits the ConnectEx-pointer acquisition (WSAStartup + WSASocketW +
//     WSAIoctl): that is a networking detail requiring the ws2_32 import DLL, and
//     `__io_connectex_ptr` is consumed only by the ConnectEx networking path which is
//     out of scope here. The slot is still reserved for layout parity.
//   * The sync worker's network ops (net_connect/send/recv/close, dns_resolve) require
//     ws2_32 too and are never submitted by the self-hosted compiler; their op codes
//     route to `__gt_panic_io` (the same control-flow as C#'s unknown-op default).
// =============================================================================

// --- AsyncOpContext struct (issued OVERLAPPED + our fields), C# AsyncCtx* ---
let IoAsyncCtxSize = 0x38  // 56 bytes (OVERLAPPED=32 + waiter + custom_result + pad)
let IoAsyncCtxOffWaiter = 0x20  // waiter green thread
let IoAsyncCtxOffCustomResult = 0x28  // custom result (e.g. ConnectEx socket handle)

// --- SyncRequest struct (sync-worker request queue node), C# SyncReq* ---
let IoSyncReqSize = 0x28  // 40 bytes
let IoSyncReqOffOp = 0x00
let IoSyncReqOffArg0 = 0x08
let IoSyncReqOffArg1 = 0x10
let IoSyncReqOffWaiter = 0x18
let IoSyncReqOffNext = 0x20

// --- IoCompletion struct (done-queue node), C# IoComp* ---
let IoCompOffWaiter = 0x00
let IoCompOffResult = 0x08
let IoCompOffLen = 0x10
let IoCompOffError = 0x18
let IoCompOffNext = 0x20

// --- Sync op codes (C# SyncOp*) — filesystem ops are serviced; network ops panic ---
let IoSyncOpFileExists = 0
let IoSyncOpFileDelete = 1
let IoSyncOpFindFirst = 2
let IoSyncOpFindNext = 3
let IoSyncOpDirExists = 4
let IoSyncOpDirCreate = 5
let IoSyncOpGetCwd = 6
let IoSyncOpFileOpenRead = 7
let IoSyncOpFileOpenWrite = 8
let IoSyncOpCloseHandle = 9

// Network sync ops 13/14 — byte-compatible with the C# bootstrap (SyncOpNetClose=13,
// SyncOpDnsResolve=14). Serviced only when networking is linked (see the gated
// dispatch arms in `emitX64IoSyncWorkerLoop`); otherwise they panic like any
// unknown op, which is unreachable because no code submits them.
let IoSyncOpNetClose = 13
let IoSyncOpDnsResolve = 14
let IoSyncOpFileOpenWriteExec = 15
let IoSyncOpShutdown = 0xFF

// Number of sync-worker OS threads. Matches the C# bootstrap's IoSyncWorkerCount=1
// (the shutdown-sentinel count the mm-trace tests assert on follows from it).
let IoSyncWorkerCount = 1

// Top-level driver: emit every async-I/O IOCP runtime function. Registered in the
// emitX64GreenThreadRuntime dispatcher after the scheduler functions.
function emitX64IoRuntime(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, usesNetworking bool)
	emitX64IoCompleteGt(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoGetLastError(code, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoEnqueueSyncReq(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoDequeueSyncReq(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoEnqueueCompletion(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoDequeueCompletion(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoCheckCompletions(code, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoPanicIo(code, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoCompletionLoop(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoSyncWorkerLoop(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, usesNetworking: usesNetworking)
	emitX64IoSubmitOverlapped(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, ioFuncSlot: iatSlotIndex(IatSlot.readFile), funcName: "__io_submit_read")
	emitX64IoSubmitOverlapped(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, ioFuncSlot: iatSlotIndex(IatSlot.writeFile), funcName: "__io_submit_write")
	emitX64IoSubmitSync(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoInit(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoShutdown(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
end 'emitX64IoRuntime'

// __io_complete_gt(gt=rcx, result=rdx, len=rax, error=r9): write the I/O result
// fields directly into a parked green thread and re-enqueue it. Called from the IOCP
// poller thread and the sync worker thread to bypass the intermediate done queue.
// Ports C# EmitIoCompleteGt. Internal ABI: 4 params (rcx/rdx/rax/r9 → slots 0..3).
// Void. Slots: 0=gt, 1=result, 2=len, 3=error.
function emitX64IoCompleteGt(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_complete_gt", offset: code.count())
	// Blocks: 0=entry, 1=spin, 2=enqueue, 3=signal, 4=wake_p0, 5=skip.
	var state = Win32HelperState.create(6, outgoingBytes: 32, localBytes: 32)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	// Save the 4 internal-ABI params (rcx/rdx/rax/r9) into slots 0..3.
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // gt
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // result
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // len
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r9)  // error
	// gt.io_result_val = result ; gt.io_result_len = len ; gt.io_error_code = error.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // gt
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoResultVal, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoResultLen, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoErrorCode, src: X64Register.rdx)
	// gt.status = ready (0).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffStatus, src: X64Register.rax)
	// Only enqueue regular GTs (stackBase != 0). MainThread GTs (stackBase == 0) are
	// driven by inline scheduling loops and must NOT enter the global run queue.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz signal (mainThread)

	// block 1: spin — wait until the GT's context switch has saved its RSP/RBP. The
	// I/O submit path clears ioYielded before the switch; the worker loop / submit
	// resume point re-sets it to 1. Without this the poller could enqueue the GT
	// while its registers are mid-save, so another worker would load stale state.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // reload gt
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffIoYielded)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz enqueue
	code.append(b"\xf3\x90")  // pause
	helperEmitJmp(code, state: state, targetBlock: 1)  // spin

	// block 2: enqueue — __gt_enqueue(gt).
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_enqueue")

	// block 3: signal — wake parked threads. SetEvent(__io_done_event) if non-null so
	// the mainthread park loops / cleanup drain re-check immediately (else up to 50ms
	// latency per completion).
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz wake_p0
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setEvent))

	// block 4: wake_p0 — also SetEvent(procs[0].wakeEvent) so P[0]'s main thread, which
	// may be parked on its wakeEvent in __gt_await, re-checks.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__sched_procs")
	code.append(b"\x48\x8b\x00")  // mov rax, [rax] — procs[0] = P[0]*
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: POffWakeEvent)
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz skip
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setEvent))

	// block 5: skip — done.
	helperMarkBlock(state, code: code, blockId: 5)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoCompleteGt'

// __io_get_last_error() -> r8 : returns the current green thread's io_error_code.
// Used by the lowering to map raw OS error codes to method-specific error variants.
// Ports C# EmitIoGetLastError.
function emitX64IoGetLastError(code ByteArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_get_last_error", offset: code.count())
	var state = Win32HelperState.create(1, outgoingBytes: 0, localBytes: 0)
	helperPrologue(code, frameSize: 0)
	helperMarkBlock(state, code: code, blockId: 0)
	// r8 = P.currentGt.io_error_code.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.r10, disp: GtOffIoErrorCode)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoGetLastError'

// __io_enqueue_sync_req(req=rcx): append a SyncRequest to the sync-request queue
// under __io_sync_cs. Ports C# EmitIoEnqueueSyncReq. Void. Slot 0 = req.
function emitX64IoEnqueueSyncReq(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_enqueue_sync_req", offset: code.count())
	// Blocks: 0=entry, 1=nonempty, 2=done.
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // req
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	// if head == NULL: head = tail = req ; else tail.next = req ; tail = req.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_sync_req_head")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 1)  // jnz nonempty
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_sync_req_head")
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_sync_req_tail")
	helperEmitJmp(code, state: state, targetBlock: 2)  // done
	// block 1: nonempty — tail.next = req ; tail = req.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_tail")
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: IoSyncReqOffNext, src: X64Register.rdx)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdx, name: "__io_sync_req_tail")
	// block 2: done — leave the CS.
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoEnqueueSyncReq'

// __io_dequeue_sync_req() -> r8 : pop one SyncRequest under __io_sync_cs (or NULL).
// ResetEvent the req event INSIDE the CS when the queue empties so a submitter's
// SetEvent between our LeaveCS and ResetEvent can't be clobbered. Ports C#
// EmitIoDequeuesSyncReq. Slot 0 = dequeued node (spilled across the Win32 calls).
function emitX64IoDequeueSyncReq(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_dequeue_sync_req", offset: code.count())
	// Blocks: 0=entry, 1=unlock, 2=ret_check, 3=clear_next, 4=done.
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_sync_req_head")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)  // spill node (Win32 calls clobber rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz unlock (empty)
	// head = head.next.
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffNext)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__io_sync_req_head")
	// if new head == NULL: tail = NULL ; ResetEvent(req event) — all inside the CS.
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 1)  // jnz unlock
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__io_sync_req_tail")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.resetEvent))
	// block 1: unlock.
	helperMarkBlock(state, code: code, blockId: 1)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	// block 2: ret_check — reload the node; if non-null, clear its next ptr.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz done
	helperMarkBlock(state, code: code, blockId: 3)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: IoSyncReqOffNext, src: X64Register.rcx)
	// block 4: done — return the node in r8.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoDequeueSyncReq'

// __io_enqueue_completion(comp=rcx): append an IoCompletion to the done queue under
// __io_done_cs. Ports C# EmitIoEnqueueCompletion. Void. Slot 0 = comp.
function emitX64IoEnqueueCompletion(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_enqueue_completion", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // comp
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_done_head")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 1)  // jnz nonempty
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_done_head")
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_done_tail")
	helperEmitJmp(code, state: state, targetBlock: 2)  // done
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_tail")
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: IoCompOffNext, src: X64Register.rdx)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rdx, name: "__io_done_tail")
	helperMarkBlock(state, code: code, blockId: 2)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoEnqueueCompletion'

// __io_dequeue_completion() -> r8 : pop one IoCompletion under __io_done_cs (or NULL).
// Ports C# EmitIoDequeueCompletion. Slot 0 = dequeued node (spilled across the call).
function emitX64IoDequeueCompletion(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_dequeue_completion", offset: code.count())
	// Blocks: 0=entry, 1=unlock, 2=ret_check, 3=clear_next, 4=done.
	var state = Win32HelperState.create(5, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.enterCriticalSection))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_done_head")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)  // spill node
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz unlock
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoCompOffNext)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__io_done_head")
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 1)  // jnz unlock
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rcx, name: "__io_done_tail")
	helperMarkBlock(state, code: code, blockId: 1)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.leaveCriticalSection))
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz done
	helperMarkBlock(state, code: code, blockId: 3)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: IoCompOffNext, src: X64Register.rcx)
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoDequeueCompletion'

// __io_check_completions(): drain the done queue, writing each completion's result
// into its waiter GT and re-enqueueing the GT. Non-blocking. Wired into __gt_await
// and the cleanup drain. Assumes __io_init has run — it does, unconditionally, in
// mrt_start's entry block (patchMrtStartCallIoInit) before main and any green thread,
// so __io_done_event and the done-queue CRITICAL_SECTION are always live here. Ports
// C# EmitIoCheckCompletions (which makes the same assumption). Slots: 0=comp, 1=gt.
function emitX64IoCheckCompletions(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_check_completions", offset: code.count())
	// Blocks: 0=loop, 1=skip_enqueue, 2=ret.
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 16)
	helperPrologue(code, frameSize: 48)

	// block 0: loop — comp = __io_dequeue_completion(); if NULL → done.
	helperMarkBlock(state, code: code, blockId: 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_dequeue_completion")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz ret (queue empty)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.r8)  // comp
	// gt = comp.waiter.
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r8, disp: IoCompOffWaiter)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rcx)  // gt
	// gt.io_result_val = comp.result_val.
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r8, disp: IoCompOffResult)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoResultVal, src: X64Register.rdx)
	// gt.io_result_len = comp.result_len.
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r8, disp: IoCompOffLen)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoResultLen, src: X64Register.rdx)
	// gt.io_error_code = comp.error_code.
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r8, disp: IoCompOffError)
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoErrorCode, src: X64Register.rdx)
	// Free comp ( __slab_free(comp) ).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// gt.status = ready (0).
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)  // gt
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffStatus, src: X64Register.rax)
	// Only enqueue regular GTs (stackBase != 0).
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz skip_enqueue
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_enqueue")
	helperMarkBlock(state, code: code, blockId: 1)  // skip_enqueue
	helperEmitJmp(code, state: state, targetBlock: 0)  // loop

	// block 2: ret.
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoCheckCompletions'

// __gt_panic_io(): abort on an unknown sync op code (should never happen). Ports C#
// EmitIoPanicIo. LEAs the static message and tail-calls mrt_panic. No return.
function emitX64IoPanicIo(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__gt_panic_io", offset: code.count())
	var state = Win32HelperState.create(1, outgoingBytes: 32, localBytes: 0)
	helperPrologue(code, frameSize: 32)
	helperMarkBlock(state, code: code, blockId: 0)
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_panic_msg", rdataRelocs: rdataRelocs)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_panic")
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoPanicIo'

// __io_completion_loop(lpParameter=rcx, ignored) -> eax : the IOCP-poller OS thread
// entry point (a CreateThread callback, Win64 ABI). Loops on GetQueuedCompletionStatus;
// for each completion, recovers the AsyncOpContext from the OVERLAPPED, frees it, and
// drives __io_complete_gt to re-ready the waiter. Exits on the shutdown sentinel
// (overlapped == NULL). Runs on its own OS stack with no adopted P, so every Win32
// call is a plain direct IAT call. Ports C# EmitIoCompletionLoop. Local slots (rbp-):
//   slot 0 = bytes_transferred (GQCS writes a DWORD; we zero the qword first)
//   slot 1 = completion_key (unused, passed by ref) ; slot 2 = overlapped (ctx)
//   slot 3 = ctx (saved) ; slot 4 = gt
function emitX64IoCompletionLoop(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_completion_loop", offset: code.count())
	// Blocks: 0=top, 1=use_bytes, 2=exit.
	// Frame: 32 outgoing (shadow) + 8 (5th GQCS arg slot at [rsp+0x20]) + slots.
	var state = Win32HelperState.create(3, outgoingBytes: 40, localBytes: 48)
	helperPrologue(code, frameSize: 96)

	// block 0: top — GQCS(iocp, &bytes, &key, &overlapped, INFINITE).
	helperMarkBlock(state, code: code, blockId: 0)
	// Zero the bytes_transferred qword (GQCS writes only the low DWORD).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_iocp")
	helperLeaStackSlot(code, slotIndex: 0, dest: X64Register.rdx)  // &bytes
	helperLeaStackSlot(code, slotIndex: 1, dest: X64Register.r8)  // &key
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.r9)  // &overlapped
	helperMovRegImm(code, dest: X64Register.rax, value: 0xFFFFFFFF)  // INFINITE
	helperStoreIndirect(code, base: X64Register.rsp, disp: 0x20, src: X64Register.rax)  // [rsp+0x20] = INFINITE
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getQueuedCompletionStatus))
	// if overlapped == NULL → shutdown sentinel → exit.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // overlapped
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz exit
	// ctx = (AsyncOpContext*)overlapped ; gt = ctx.waiter.
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // ctx
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: IoAsyncCtxOffWaiter)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rdx)  // gt
	// If ctx.custom_result != 0, use it as the result instead of bytes_transferred.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // reload ctx
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: IoAsyncCtxOffCustomResult)
	helperTestReg(code, reg: X64Register.rdx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz use_bytes
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rdx)  // bytes = custom_result
	helperMarkBlock(state, code: code, blockId: 1)  // use_bytes
	// __slab_free(ctx).
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// __io_complete_gt(gt, result, len=result, error=0). Internal ABI: rcx/rdx/rax/r9.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)  // gt
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)  // result
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // len = result
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (error = 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_complete_gt")
	helperEmitJmp(code, state: state, targetBlock: 0)  // loop

	// block 2: exit — return 0 (eax).
	helperMarkBlock(state, code: code, blockId: 2)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (thread exit code 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoCompletionLoop'

// __io_sync_worker_loop(lpParameter=rcx, ignored) -> eax : the sync-fallback worker
// OS thread entry point (CreateThread callback, Win64 ABI). Waits on the request
// event, dequeues one SyncRequest, dispatches on its op code, and drives
// __io_complete_gt with the result. Exits on the Shutdown sentinel. Runs on its own
// OS stack with no adopted P → plain direct IAT calls. Ports C# EmitIoSyncWorkerLoop.
// The network ops (13 net_close / 14 dns_resolve) need ws2_32, so their op BODIES
// live in `emitX64NetworkingRuntime` (`__io_net_sync_close` / `__io_net_sync_dns`);
// here the dispatch only routes to them, and ONLY when `usesNetworking` (else those
// arms are omitted and 13/14 fall through to __gt_panic_io — unreachable, since no
// code submits a net sync op on a non-networking program). This keeps ws2 IAT
// relocations out of the always-emitted worker loop. Slots:
//   0=req, 1=result, 2=scratch (handle/buf), 3=captured Win32 error code.
function emitX64IoSyncWorkerLoop(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, usesNetworking bool)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_sync_worker_loop", offset: code.count())
	// Blocks: 0=top, then one per op + helpers. See the per-block comments.
	//   0=top  1=dispatch  2=op_done  3=shutdown
	//   10=file_exists 11=fe_no  12=file_delete  13=find_first  14=find_next
	//   15=fn_eof  16=dir_exists  17=de_no  18=dir_create  19=get_cwd
	//   20=cwd_ok  21=file_open_read  22=for_fail  23=file_open_write
	//   24=fow_fail  25=close_handle  26=open_common (IOCP-associate)  27=oc_fail
	//   28=net_close  29=dns_resolve  (only when usesNetworking)
	var state = Win32HelperState.create(30, outgoingBytes: 64, localBytes: 32)
	helperPrologue(code, frameSize: 96)

	// block 0: top — WaitForSingleObject(req event, INFINITE); dequeue; if NULL, re-wait.
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	helperMovRegImm(code, dest: X64Register.rdx, value: 0xFFFFFFFF)  // INFINITE
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_dequeue_sync_req")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 0)  // jz top (spurious wakeup)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.r8)  // req
	// Zero the captured-error slot; failure handlers overwrite it before op_done.
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rcx)

	// block 1: dispatch on op code.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffOp)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpShutdown)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // je shutdown
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFileExists)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFileDelete)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFindFirst)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 13)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFindNext)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 14)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpDirExists)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 16)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpDirCreate)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 18)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpGetCwd)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 19)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFileOpenRead)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 21)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFileOpenWrite)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 23)
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpFileOpenWriteExec)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 23)  // exec == write on Windows
	helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpCloseHandle)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 25)
	if usesNetworking 'netDispatch'
		// Network ops route to the ws2-calling bodies in emitX64NetworkingRuntime.
		helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpNetClose)
		helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 28)
		helperCmpRegImm(code, reg: X64Register.rcx, value: IoSyncOpDnsResolve)
		helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 29)
	end 'netDispatch'
	// Unknown / unsupported op → panic, matching the C# default arm. When
	// networking is unlinked, ops 13/14 reach here (but are never submitted).
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_panic_io")

	// block 10: fileExists — GetFileAttributesA(arg0) != INVALID and not a directory.
	helperMarkBlock(state, code: code, blockId: 10)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getFileAttributesA))
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFF)  // INVALID_FILE_ATTRIBUTES
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 11)  // je no
	code.append(b"\xa9\x10\x00\x00\x00")  // test eax, 0x10 (FILE_ATTRIBUTE_DIRECTORY)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 11)  // jnz no
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)  // op_done
	helperMarkBlock(state, code: code, blockId: 11)  // fe_no
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 12: fileDelete — DeleteFileA(arg0); on failure capture GetLastError.
	helperMarkBlock(state, code: code, blockId: 12)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.deleteFileA))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz op_done
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 13: findFirst — FindFirstFileA(pattern=arg0, &WIN32_FIND_DATA=arg1) → HANDLE.
	helperMarkBlock(state, code: code, blockId: 13)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: IoSyncReqOffArg1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findFirstFileA))
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFFFFFFFFFF)  // INVALID_HANDLE_VALUE (-1)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jne op_done
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 14: findNext — FindNextFileA(HANDLE=arg0, &data=arg1): nonzero=found,
	// 0+ERROR_NO_MORE_FILES(18)=eof (return 0), 0+other=error (return -1).
	helperMarkBlock(state, code: code, blockId: 14)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rax, disp: IoSyncReqOffArg1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findNextFileA))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz op_done (found)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	helperCmpRegImm(code, reg: X64Register.rax, value: 18)  // ERROR_NO_MORE_FILES
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 15)  // je eof
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // record real error
	helperMovRegImm(code, dest: X64Register.rax, value: 0xFFFFFFFFFFFFFFFF)  // -1
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 15)  // fn_eof
	code.append(b"\x48\x31\xc0")  // xor rax, rax (return 0)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 16: dirExists — GetFileAttributesA(arg0) & FILE_ATTRIBUTE_DIRECTORY.
	helperMarkBlock(state, code: code, blockId: 16)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getFileAttributesA))
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFF)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 17)  // je no
	code.append(b"\xa9\x10\x00\x00\x00")  // test eax, 0x10
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 17)  // jz no
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 17)  // de_no
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 18: dirCreate — CreateDirectoryA(arg0, NULL); on failure capture GetLastError.
	helperMarkBlock(state, code: code, blockId: 18)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (lpSecurityAttributes = NULL)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createDirectoryA))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz op_done
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 19: getCwd — buf = __slab_alloc(260); GetCurrentDirectoryA(260, buf) → buf ptr.
	helperMarkBlock(state, code: code, blockId: 19)
	helperMovRegImm(code, dest: X64Register.rcx, value: 260)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.r8)  // buf
	helperMovRegImm(code, dest: X64Register.rcx, value: 260)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)  // lpBuffer
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getCurrentDirectoryA))
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 20)  // jnz cwd_ok
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // free buf
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	code.append(b"\x48\x31\xc0")  // xor rax, rax (return 0)
	helperEmitJmp(code, state: state, targetBlock: 2)
	helperMarkBlock(state, code: code, blockId: 20)  // cwd_ok
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // result = buf
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 21: fileOpenRead — CreateFileA(GENERIC_READ, OPEN_EXISTING, OVERLAPPED) + IOCP.
	helperMarkBlock(state, code: code, blockId: 21)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)  // path
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x80000000)  // GENERIC_READ
	helperMovRegImm(code, dest: X64Register.r8, value: 1)  // FILE_SHARE_READ
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpSecurityAttributes = NULL)
	// [rsp+0x20]=OPEN_EXISTING(3) ; [rsp+0x28]=FILE_FLAG_OVERLAPPED(0x40000000) ; [rsp+0x30]=NULL.
	helperMovRegImm(code, dest: X64Register.rax, value: 3)
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x40000000)
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x30, srcReg: X64Register.rax)  // hTemplateFile = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileA))
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFFFFFFFFFF)  // INVALID_HANDLE_VALUE
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 22)  // je fail
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // handle
	helperEmitJmp(code, state: state, targetBlock: 26)  // open_common (IOCP-associate)
	helperMarkBlock(state, code: code, blockId: 22)  // for_fail
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperMovRegImm(code, dest: X64Register.rax, value: 0xFFFFFFFFFFFFFFFF)  // -1
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 23: fileOpenWrite / fileOpenWriteExec — CreateFileA(GENERIC_WRITE,
	// CREATE_ALWAYS, OVERLAPPED, share R|W) + IOCP. exec is identical on Windows.
	helperMarkBlock(state, code: code, blockId: 23)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)  // path
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x40000000)  // GENERIC_WRITE
	helperMovRegImm(code, dest: X64Register.r8, value: 3)  // FILE_SHARE_READ|WRITE
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperMovRegImm(code, dest: X64Register.rax, value: 2)  // CREATE_ALWAYS
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x40000000)  // FILE_FLAG_OVERLAPPED
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x30, srcReg: X64Register.rax)  // hTemplateFile = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileA))
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFFFFFFFFFF)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 24)  // je fail
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // handle
	helperEmitJmp(code, state: state, targetBlock: 26)  // open_common
	helperMarkBlock(state, code: code, blockId: 24)  // fow_fail
	emitX64IoSyncCaptureLastError(code, relocations: relocations)
	helperMovRegImm(code, dest: X64Register.rax, value: 0xFFFFFFFFFFFFFFFF)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 25: closeHandle — CloseHandle(arg0).
	helperMarkBlock(state, code: code, blockId: 25)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 26: open_common — associate the freshly-opened handle with the IOCP and
	// set FILE_SKIP_COMPLETION_PORT_ON_SUCCESS, then return the raw handle. Shared by
	// fileOpenRead / fileOpenWrite[Exec]. handle is in slot 2.
	helperMarkBlock(state, code: code, blockId: 26)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // handle
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__io_iocp")
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (completion key = 0)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createIoCompletionPort))
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // handle
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)  // FILE_SKIP_COMPLETION_PORT_ON_SUCCESS
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setFileCompletionNotificationModes))
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // result = handle
	helperEmitJmp(code, state: state, targetBlock: 2)

	if usesNetworking 'netBlocks'
		// block 28: net_close — delegate to __io_net_sync_close(handle=rcx) -> r8.
		// The body (closesocket) lives in emitX64NetworkingRuntime so its ws2 IAT
		// relocation is absent on non-networking programs.
		helperMarkBlock(state, code: code, blockId: 28)
		helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // req
		helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)  // handle
		helperEmitDirectCall(code, callFixups: callFixups, target: "__io_net_sync_close")
		emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)  // result = r8
		helperEmitJmp(code, state: state, targetBlock: 2)  // op_done

		// block 29: dns_resolve — delegate to __io_net_sync_dns(host=rcx) -> r8
		// (resolved IP, or -1 DNS fail, or -2 TEST-NET-1 sentinel). The body
		// (lazy WSAStartup + getaddrinfo) lives in emitX64NetworkingRuntime.
		helperMarkBlock(state, code: code, blockId: 29)
		helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // req
		helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rax, disp: IoSyncReqOffArg0)  // host cstring
		helperEmitDirectCall(code, callFixups: callFixups, target: "__io_net_sync_dns")
		emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)  // result = r8
		helperEmitJmp(code, state: state, targetBlock: 2)  // op_done
	end 'netBlocks'

	// block 2: op_done — complete the waiting green thread with the result.
	helperMarkBlock(state, code: code, blockId: 2)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)  // result
	// gt = req.waiter.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // req
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.rcx, disp: IoSyncReqOffWaiter)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rdx)  // gt
	// __slab_free(req).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	// __io_complete_gt(gt, result, len=result, error=captured). Internal ABI rcx/rdx/rax/r9.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // gt
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)  // result
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // len = result
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r9)  // error = captured
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_complete_gt")
	helperEmitJmp(code, state: state, targetBlock: 0)  // top

	// block 3: shutdown — free req, re-SetEvent so peer workers cascade-wake, exit.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setEvent))
	code.append(b"\x48\x31\xc0")  // xor rax, rax (thread exit code 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoSyncWorkerLoop'

// Inside the sync worker on a failure branch: capture GetLastError into the worker's
// error-code slot (slot 3) so __io_complete_gt passes it through to gt.io_error_code.
// RAX (the failing return) is preserved around the call via slot 1 (result). Ports the
// C# EmitSyncWorkerCaptureLastError. Caller must have slot 3 = error slot, slot 1 free.
function emitX64IoSyncCaptureLastError(code ByteArray, relocations RelocationArray)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)  // save failing rax
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // captured Win32 error
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // restore failing rax
end 'emitX64IoSyncCaptureLastError'

// __io_submit_sync(op=rcx, arg0=rdx, arg1=rax) -> r8 : submit a non-overlappable I/O
// request to the sync-worker queue and yield the current green thread until the worker
// completes it; returns the worker's result (gt.io_result_val). Ports C# EmitIoSubmitSync
// (without the AsyncTrace blocks). Internal ABI: 3 params rcx/rdx/rax → slots 0..2.
// Slots: 0=op, 1=arg0, 2=arg1, 3=req, 4=dequeued GT (mainthread loop).
function emitX64IoSubmitSync(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_submit_sync", offset: code.count())
	// Blocks: 0=entry, 1=worker_switch, 2=mainthread_loop, 3=mt_run, 4=mt_park,
	//   5=resume, 6=cancelled.
	var state = Win32HelperState.create(7, outgoingBytes: 32, localBytes: 48)
	helperPrologue(code, frameSize: 80)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // op
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // arg0
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // arg1
	// Cancel check: if self.cancel_flag != 0 → cancelled.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffCancelFlag)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 6)  // jnz cancelled
	// req = __slab_alloc(IoSyncReqSize) (zeroed).
	helperMovRegImm(code, dest: X64Register.rcx, value: IoSyncReqSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)  // req
	// Fill op/arg0/arg1/waiter ; next stays 0 from the zeroed alloc.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoSyncReqOffOp, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoSyncReqOffArg0, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoSyncReqOffArg1, src: X64Register.rdx)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoSyncReqOffWaiter, src: X64Register.rdx)
	// self.status = waiting ; self.ioYielded = 0 — BEFORE enqueue, so __io_complete_gt
	// spins until our context switch saves RSP/RBP.
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffStatus, src: X64Register.rax)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffIoYielded, src: X64Register.rax)
	// __io_enqueue_sync_req(req) ; SetEvent(req event).
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_enqueue_sync_req")
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setEvent))
	// If self == &P.mainThread (stackBase == 0) → mainthread_loop; else worker_switch.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz mainthread_loop

	// block 1: worker_switch — set mainThread running, context_switch(self → mainThread).
	helperMarkBlock(state, code: code, blockId: 1)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r10, disp: POffMainThread + GtOffStatus, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)  // from = self
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r10)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: POffMainThread)  // to = &P.mainThread
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperEmitJmp(code, state: state, targetBlock: 5)  // resume

	// block 2: mainthread_loop — drive the scheduler until the worker completes us.
	helperMarkBlock(state, code: code, blockId: 2)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_check_completions")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_timer_check")
	// if self.status != waiting → resume (worker completed our request).
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusWaiting)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 5)  // jne resume
	// g = __gt_dequeue(); if NULL → park.
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // jz park

	// block 3: mt_run — run the dequeued GT while we wait.
	helperMarkBlock(state, code: code, blockId: 3)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.r8)  // dequeued GT
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rcx)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)  // from = self
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)  // to = g
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	// On resume, signal the GT we ran has switched out: g.ioYielded = 1.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 2)  // re-check

	// block 4: mt_park — WaitForSingleObject(done event, 50ms), then re-loop.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperMovRegImm(code, dest: X64Register.rdx, value: 50)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 5: resume — return self.io_result_val in r8.
	helperMarkBlock(state, code: code, blockId: 5)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.r10, disp: GtOffIoResultVal)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 6: cancelled — store ERROR_OPERATION_ABORTED, return 0 without yielding.
	helperMarkBlock(state, code: code, blockId: 6)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x3EF)  // ERROR_OPERATION_ABORTED
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (return 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoSubmitSync'

// __io_submit_read / __io_submit_write (handle=rcx, buf=rdx, size=rax) -> r8 :
// issue an overlapped ReadFile / WriteFile and yield the current green thread until
// IOCP signals completion; return the bytes transferred. `ioFuncSlot` selects the IAT
// slot (ReadFile vs WriteFile); `funcName` is the recorded label. Ports C#
// EmitIoSubmitOverlappedCore. Internal ABI: 3 params rcx/rdx/rax → slots 0..2.
// Slots: 0=handle, 1=buf, 2=size, 3=ctx, 4=saved error / dequeued GT, 5=bytes(sync).
function emitX64IoSubmitOverlapped(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, ioFuncSlot MachineWord, funcName String)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: funcName, offset: code.count())
	// Blocks: 0=entry, 1=sync_err, 2=sync_done, 3=yield, 4=worker_switch,
	//   5=mainthread_loop, 6=mt_run, 7=mt_park, 8=resume, 9=cancelled.
	var state = Win32HelperState.create(10, outgoingBytes: 48, localBytes: 48)
	helperPrologue(code, frameSize: 96)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // handle
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // buf
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // size
	// Cancel check.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffCancelFlag)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 9)  // jnz cancelled
	// ctx = __slab_alloc(IoAsyncCtxSize) (zeroed OVERLAPPED + fields).
	helperMovRegImm(code, dest: X64Register.rcx, value: IoAsyncCtxSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)  // ctx
	// ctx.waiter = self.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoAsyncCtxOffWaiter, src: X64Register.rdx)
	// self.io_handle = handle ; self.status = waiting.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffIoHandle, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffStatus, src: X64Register.rax)
	// ReadFile/WriteFile(handle, buf, size, NULL, ctx) — 5 args (4 reg + ctx at
	// [rsp+0x20]) on the per-P system stack.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpBytesTransferred = NULL)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // lpOverlapped = ctx
	helperEmitIatCall(code, relocations: relocations, slotIndex: ioFuncSlot)
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	// TRUE → sync success (FILE_SKIP_COMPLETION): no IOCP completion arrives.
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz sync_done
	// FALSE → GetLastError; ERROR_IO_PENDING(997) → yield; else sync error.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getLastError))
	helperCmpRegImm(code, reg: X64Register.rax, value: 997)  // ERROR_IO_PENDING
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // je yield

	// block 1: sync_err — clear io_handle/status, store error, free ctx, return 0.
	helperMarkBlock(state, code: code, blockId: 1)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // save error code
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rcx)  // ready
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (return 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 2: sync_done — GetOverlappedResult to retrieve the byte count, then resume.
	helperMarkBlock(state, code: code, blockId: 2)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // zero bytes slot
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // hFile
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rdx)  // lpOverlapped = ctx
	helperLeaStackSlot(code, slotIndex: 5, dest: X64Register.r8)  // &bytesTransferred
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (bWait = FALSE)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getOverlappedResult))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)  // bytes
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoResultVal, src: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rax)  // ready
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperEmitJmp(code, state: state, targetBlock: 8)  // resume

	// block 3: yield — I/O pending. If self == mainThread → mainthread_loop else switch.
	helperMarkBlock(state, code: code, blockId: 3)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz mainthread_loop

	// block 4: worker_switch — self.ioYielded = 0 before switch; mainThread running;
	// context_switch(self → mainThread).
	helperMarkBlock(state, code: code, blockId: 4)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoYielded, src: X64Register.rax)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r10, disp: POffMainThread + GtOffStatus, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)  // from = self
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r10)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: POffMainThread)  // to = &P.mainThread
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperEmitJmp(code, state: state, targetBlock: 8)  // resume

	// block 5: mainthread_loop — drive the scheduler until our I/O completes.
	helperMarkBlock(state, code: code, blockId: 5)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_check_completions")
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusWaiting)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 8)  // jne resume
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)  // jz park

	// block 6: mt_run — run the dequeued GT.
	helperMarkBlock(state, code: code, blockId: 6)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rcx)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)  // from = self
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)  // to = g
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 5)  // re-loop

	// block 7: mt_park — WaitForSingleObject(done event, 50ms), then re-loop.
	helperMarkBlock(state, code: code, blockId: 7)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperMovRegImm(code, dest: X64Register.rdx, value: 50)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// block 8: resume — clear io_handle, return self.io_result_val in r8.
	helperMarkBlock(state, code: code, blockId: 8)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.r10, disp: GtOffIoResultVal)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 9: cancelled — store ERROR_OPERATION_ABORTED, return 0.
	helperMarkBlock(state, code: code, blockId: 9)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x3EF)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoSubmitOverlapped'

// __io_init(): initialize the IOCP, the two queues (CRITICAL_SECTION + Event each),
// and spawn the IOCP-poller + sync-fallback worker OS threads. Idempotent: __io_init
// is now wired into mrt_start's entry block (patchMrtStartCallIoInit) so it runs once
// unconditionally at startup, and an async program that later re-enters the subsystem
// just observes the guard. We use `__io_done_event != 0` as the "already initialized"
// sentinel — it's NULL until the first init stores the auto-reset event, mirroring the
// guard in __io_check_completions. Ports C# EmitIoInit, minus the ConnectEx-pointer
// acquisition (ws2_32, out of scope — see the section header). Void. Runs on the main
// OS thread at scheduler-startup time. Slots: 0=loop index (worker spawn).
// Blocks: 0=guard, 1=body, 2=ret.
function emitX64IoInit(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_init", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 16)
	helperPrologue(code, frameSize: 64)
	helperMarkBlock(state, code: code, blockId: 0)
	// Idempotency guard: if __io_done_event is already set, init has run — return now.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_done_event")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz ret
	helperMarkBlock(state, code: code, blockId: 1)
	// __io_iocp = CreateIoCompletionPort(INVALID_HANDLE_VALUE=-1, NULL, 0, 1).
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFFFFFFFFFF)
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	helperMovRegImm(code, dest: X64Register.r9, value: 1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createIoCompletionPort))
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_iocp")
	// InitializeCriticalSection(&__io_sync_cs) ; InitializeCriticalSection(&__io_done_cs).
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.initializeCriticalSection))
	// __io_sync_req_event = CreateEventA(NULL, TRUE manual-reset, FALSE, NULL).
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperMovRegImm(code, dest: X64Register.rdx, value: 1)  // bManualReset = TRUE
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createEventA))
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_sync_req_event")
	// __io_done_event = CreateEventA(NULL, FALSE auto-reset, FALSE, NULL).
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (bManualReset = FALSE)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createEventA))
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_done_event")
	// __io_completion_thread = CreateThread(NULL, 0, &__io_completion_loop, NULL, 0, NULL).
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	emitLeaFuncAddrOp(code, dest: X64Register.r8, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__io_completion_loop")
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpParameter = NULL)
	// r8 holds the thread-proc func ptr; zero the two stack arg slots via rax.
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // dwCreationFlags = 0
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)  // lpThreadId = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createThread))
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_completion_thread")
	// __io_sync_workers[0] = CreateThread(NULL, 0, &__io_sync_worker_loop, NULL, 0, NULL).
	// IoSyncWorkerCount == 1, so a single store (no loop needed).
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	emitLeaFuncAddrOp(code, dest: X64Register.r8, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__io_sync_worker_loop")
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createThread))
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_sync_workers")
	// block 2: ret — also the guard's early-out target.
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoInit'

// __io_shutdown(): post the IOCP shutdown sentinel + a Shutdown SyncRequest per worker,
// wait for the IOCP-poller and sync-worker threads to exit, then close all handles and
// delete both CRITICAL_SECTIONs. Wired into mrt_start's entry block before `osExit`
// (patchMrtStartCallIoShutdown) so it runs once unconditionally at process teardown.
// A leading guard makes it a safe no-op when __io_init never ran (e.g. a program that
// panics before startup init): `__io_done_event == 0` means the handles/CRITICAL_SECTIONs
// are zeroed, so waiting/closing them would fault. Ports C# EmitIoShutdown
// (IoSyncWorkerCount == 1, so the handle array is [completion, worker]). Void.
// Slots: 0=req (sentinel), 1/2 = handle array. Blocks: 0=guard, 1=body, 2=ret.
function emitX64IoShutdown(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_shutdown", offset: code.count())
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 32)
	helperPrologue(code, frameSize: 80)
	helperMarkBlock(state, code: code, blockId: 0)
	// Idempotency guard: if __io_done_event is 0, __io_init never ran — nothing to tear down.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_done_event")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)  // jz ret
	helperMarkBlock(state, code: code, blockId: 1)
	// PostQueuedCompletionStatus(iocp, 0, 0, NULL) — wake the completion thread.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_iocp")
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.postQueuedCompletionStatus))
	// Enqueue one Shutdown SyncRequest (req = __slab_alloc(IoSyncReqSize); req.op = Shutdown).
	helperMovRegImm(code, dest: X64Register.rcx, value: IoSyncReqSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.r8)  // req
	helperMovRegImm(code, dest: X64Register.rcx, value: IoSyncOpShutdown)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoSyncReqOffOp, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_enqueue_sync_req")
	// SetEvent(req event) wakes the worker parked on the manual-reset event.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setEvent))
	// Stash the two thread handles in adjacent slots 1/2 to form the WaitForMultiple-
	// Objects handle array. bWaitAll=TRUE below, so the array order is immaterial.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_completion_thread")
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_sync_workers")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// WaitForMultipleObjects(2, &handles, TRUE, INFINITE). helperSlotRbpOffset grows
	// more negative with index, so slot 2 is the lower-addressed end; &handles[0] is
	// that lower end = &slot 2. lea rdx, [slot 2]. (bWaitAll=TRUE, so which handle lands
	// at handles[0] vs handles[1] does not matter.)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1 + IoSyncWorkerCount)  // nCount = 2
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.rdx)  // &handles[0]
	helperMovRegImm(code, dest: X64Register.r8, value: 1)  // bWaitAll = TRUE
	helperMovRegImm(code, dest: X64Register.r9, value: 0xFFFFFFFF)  // INFINITE
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.waitForMultipleObjects))
	// CloseHandle(completion thread / sync worker / iocp / both events).
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_completion_thread")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_workers")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_iocp")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_sync_req_event")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	// DeleteCriticalSection(&__io_sync_cs / &__io_done_cs).
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_sync_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.deleteCriticalSection))
	emitLeaRipRelOp(code, dest: X64Register.rcx, rdataLabel: "__io_done_cs", rdataRelocs: rdataRelocs)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.deleteCriticalSection))
	// block 2: ret — also the guard's early-out target.
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoShutdown'

// =============================================================================
// Tier 4 networking runtime (`stdlib/TcpClient.maxon` / `stdlib/HttpClient.maxon`).
// Hand-emitted x64 machine code porting the C# bootstrap's net helpers
// (X86CodeEmitter.Runtime.cs: EmitNetTcpConnect / EmitIoSubmitSocketOverlapped /
// EmitNetClose / EmitNetSocketDestructor / EmitWsaEnsureInit / the sync-worker
// DNS+close ops) to the self-hosted ABI.
//
// x64-WINDOWS ONLY: the green-thread/IOCP runtime these hook into exists only on
// x64-windows; arm64/macos/linux have no `__gt_*`/`__io_*` runtime (C#'s kqueue
// path is out of scope), so on those targets the runtime.std `mrt_managed_socket_*`
// sentinel stubs remain and a socket call throws at runtime. (wasm32-wasi has its
// OWN networking runtime via WASI Preview2 wasi:sockets — see emitWasmSocketTcpConnect
// in Targets/Wasm/MirToWasm.maxon — so it is NOT a stub-only target.)
//
// REACHABILITY-GATED, unlike its siblings (subprocess/green-thread are emitted
// unconditionally as dead code). Emitted only when a program reaches a
// `mrt_managed_socket_*` helper (`usesNetworking` in concatX64FunctionChunks).
// The recorded labels override the runtime.std sentinel stubs via
// labelOffsetMap.upsert. These bodies are the SOLE carriers of ws2_32 IAT
// relocations — which is exactly what drives PeWriter to import ws2_32, so the
// emit gate and the import gate cannot disagree.
//
// errorReturn ABI (the highest-risk detail): a throwing helper places its
// primary result in R8 and the error flag in RDX on EVERY exit path. Success ⇒
// flag 0; each error path ⇒ flag = `__ManagedSocketError` ordinal + 1
// (bufferOutOfBounds 1, resolveFailed 2, connectFailed 3, sendFailed 4,
// recvFailed 5). `close` is non-throwing (void) so it just returns.
//
// Allocator split (crossing these corrupts the heap): AsyncOpContext + scratch →
// `__slab_alloc`/`__slab_free` (zeroed); the `__ManagedSocket` wrapper →
// `mm_alloc(8, &__destruct___ManagedSocket, 0)` (refcounted/drop-tracked); the
// host cstring from `mrt_cstr_from_mm` is `mm_alloc`-backed → `mm_decref` it.
//
// System stack: tcpConnect/send/recv run ON a green thread, so every WSA*/kernel32
// call is system-stack-wrapped (emitX64GtSystemStackEnter/Leave +
// emitX64GtIatCallOnSystemStack). The sync-worker DNS/close ops run on the raw
// sync-worker OS thread (no adopted P) → plain helperEmitIatCall (the system-stack
// wrappers take their P==0 "skip" path there anyway).
// =============================================================================

// Winsock error / option constants used below.
let WsaIoPending = 997  // WSA_IO_PENDING
let WsaFlagOverlapped = 1
let SioGetExtensionFunctionPointer = 0xC8000006
let SolSocket = 0xFFFF
let SoUpdateConnectContext = 0x7010
let AfInet = 2
let SockStream = 1
let IpprotoTcp = 6
let FileSkipCompletionPortOnSuccess = 1
let ErrorOperationAborted = 0x3EF
let TestNet1NetOrder = 0x010200C0  // 192.0.2.1 in network byte order

// __ManagedSocketError ordinals + 1 (the errorReturn flag values). See the
// runtime.std header and registerManagedSocketErrorEnum.
let SockFlagBufferOutOfBounds = 1
let SockFlagResolveFailed = 2
let SockFlagConnectFailed = 3
let SockFlagSendFailed = 4
let SockFlagRecvFailed = 5

// Top-level driver: emit every networking runtime function. Order matters only
// for label resolvability of LEA-func-addr targets within the pass — all labels
// resolve at the final resolveCallFixups, so any order works; we emit the leaf
// helpers first for readability.
function emitX64NetworkingRuntime(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	emitX64NetEnsureStarted(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64NetSyncDns(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64NetSyncClose(code, relocations: relocations, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64NetSocketDestructor(code, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64NetTcpConnect(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
	emitX64IoSubmitSocketOverlapped(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, isRecv: false, funcName: "mrt_managed_socket_send")
	emitX64IoSubmitSocketOverlapped(code, relocations: relocations, callFixups: callFixups, rdataRelocs: rdataRelocs, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap, isRecv: true, funcName: "mrt_managed_socket_recv")
	emitX64NetClose(code, callFixups: callFixups, funcLabelNames: funcLabelNames, funcLabelOffsets: funcLabelOffsets, funcLabelOffsetMap: funcLabelOffsetMap)
end 'emitX64NetworkingRuntime'

// __io_net_ensure_started() -> void : idempotent lazy Winsock init. Guarded by
// `__io_net_wsa_init`; runs WSAStartup + acquires the ConnectEx function pointer
// via WSAIoctl into `__io_connectex_ptr`. Called ONLY from the sync-worker DNS op
// (`__io_net_sync_dns`), which `__io_submit_sync` serializes onto the single
// sync-worker OS thread — so the guard runs on exactly one thread, no
// CRITICAL_SECTION needed. Ports C# EmitWsaEnsureInit + the ConnectEx-load block
// of EmitIoInit. Runs on the raw sync-worker thread (no adopted P) → plain IAT
// calls (the system-stack wrappers take their P==0 skip path).
// Local frame (rbp-relative slots): 0=tempSock, 1=connectex_ptr out, 2=bytesReturned,
//   3..4=GUID (16 bytes), 5..55=WSADATA (≥408 bytes). 56 slots * 8 = 448 bytes.
// NOTE on multi-slot struct bases: stack slots grow DOWNWARD (slot N =
// rbp-(N+1)*8), so a struct spanning slots [lo..hi] has its BASE (lowest
// address, where the OS writes byte 0) at the HIGHEST slot index. `&guid` is
// therefore slot 4 (not 3), and `&wsaData` is slot 55 (not 5).
function emitX64NetEnsureStarted(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_net_ensure_started", offset: code.count())
	// Blocks: 0=entry, 1=do_init, 2=ret.
	// frameSize must hold the local slots (WSADATA ≥408 + GUID/ptrs) AND leave
	// shadow/stack-arg room below; sized generously.
	var state = Win32HelperState.create(3, outgoingBytes: 0x48, localBytes: 448)
	helperPrologue(code, frameSize: 512)
	helperMarkBlock(state, code: code, blockId: 0)
	// if __io_net_wsa_init != 0 → ret (already started).
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_net_wsa_init")
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz do_init
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 1: do_init.
	helperMarkBlock(state, code: code, blockId: 1)
	// WSAStartup(0x0202, &wsaData). WSADATA spans slots 5..55; its base (lowest
	// address) is slot 55 — that is where WSAStartup begins writing the 408 bytes.
	helperMovRegImm(code, dest: X64Register.rcx, value: 0x0202)  // version 2.2
	helperLeaStackSlot(code, slotIndex: 55, dest: X64Register.rdx)  // &wsaData (base)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wsaStartup))
	// tempSock = WSASocketW(AF_INET, SOCK_STREAM, IPPROTO_TCP, NULL, 0, WSA_FLAG_OVERLAPPED).
	// 6 args → frame 0x30 (shadow 0x20 + 2 stack args 0x10). Sync worker: no P, plain call.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rcx, value: AfInet)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockStream)
	helperMovRegImm(code, dest: X64Register.r8, value: IpprotoTcp)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpProtocolInfo = NULL)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // g = 0
	helperMovRegImm(code, dest: X64Register.rax, value: WsaFlagOverlapped)
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)  // dwFlags
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wsaSocketW))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)  // tempSock
	// Store WSAID_CONNECTEX GUID into slots 3..4 (16 bytes). The GUID's base (byte
	// 0) is the lower address = slot 4, so the first qword goes to slot 4 and the
	// second to slot 3 (the higher address).
	emitMovRegImmGeneric(code, dest: X64Register.rax, value: 0x4660DDF325A207B9)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)  // GUID[0..8] at base
	emitMovRegImmGeneric(code, dest: X64Register.rax, value: 0x3E06748CE576E98E)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // GUID[8..16]
	// Zero connectex_ptr out (slot 1) + bytesReturned (slot 2).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// WSAIoctl(tempSock, SIO_GET_EXTENSION_FUNCTION_POINTER, &guid, 16,
	//   &connectex_ptr, 8, &bytesReturned, NULL, NULL). 9 args → frame 0x48
	//   (shadow 0x20 + 5 stack args 0x28).
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x48)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // tempSock
	helperMovRegImm(code, dest: X64Register.rdx, value: SioGetExtensionFunctionPointer)
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r8)  // &guid (base = slot 4)
	helperMovRegImm(code, dest: X64Register.r9, value: 16)  // cbInBuffer
	helperLeaStackSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // lpvOutBuffer = &connectex_ptr
	helperMovRegImm(code, dest: X64Register.rax, value: 8)
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)  // cbOutBuffer = 8
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 0x30, srcReg: X64Register.rax)  // lpcbBytesReturned
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x38, srcReg: X64Register.rax)  // lpOverlapped = NULL
	emitMovRspOffsetReg(code, offset: 0x40, srcReg: X64Register.rax)  // lpCompletionRoutine = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wsaIoctl))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x48)
	// __io_connectex_ptr = connectex_ptr out.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_connectex_ptr")
	// closesocket(tempSock).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeSocket))
	// __io_net_wsa_init = 1.
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__io_net_wsa_init")
	helperEmitJmp(code, state: state, targetBlock: 2)

	// block 2: ret.
	helperMarkBlock(state, code: code, blockId: 2)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetEnsureStarted'

// __io_net_sync_dns(host=rcx) -> r8 : DNS-resolve `host` on the sync-worker
// thread (getaddrinfo needs a full OS stack). Returns the resolved IPv4 (4-byte
// value in a qword), or -1 (DNS failure), or -2 (TEST-NET-1 192.0.2.1 sentinel,
// for deterministic connect-failure tests). Lazily starts Winsock first. Ports
// C# __io_sync_op_dns_resolve. Runs on the raw sync-worker thread (no P).
// Local slots: 0=host, 1=result(addrinfo**), 2=resolved IP, 3..8=hints (48 bytes).
function emitX64NetSyncDns(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_net_sync_dns", offset: code.count())
	// Blocks: 0=entry, 1=dns_ok, 2=not_testnet, 3=dns_fail.
	var state = Win32HelperState.create(4, outgoingBytes: 0x20, localBytes: 80)
	helperPrologue(code, frameSize: 96)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // host
	// Lazy WSAStartup + ConnectEx acquisition (idempotent, single-threaded here).
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_net_ensure_started")
	// Zero hints (48 bytes = slots 3..8).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)
	// hints.ai_family=AF_INET@+4, ai_socktype=SOCK_STREAM@+8, ai_protocol=IPPROTO_TCP@+12.
	// The 48-byte hints struct occupies slots 3..8. Stack slots grow DOWNWARD
	// (slot N = rbp-(N+1)*8), so the struct's BASE (lowest address) is slot 8
	// (-0x48); the struct spans [-0x48, -0x18). `&hints` and all field offsets are
	// therefore relative to slot 8, NOT slot 3 (slot 3 is the highest qword).
	let hintsOff = helperSlotRbpOffset(8 as VarSlot)
	helperStoreDwordImm(code, base: X64Register.rbp, disp: hintsOff + 4, value: AfInet)
	helperStoreDwordImm(code, base: X64Register.rbp, disp: hintsOff + 8, value: SockStream)
	helperStoreDwordImm(code, base: X64Register.rbp, disp: hintsOff + 12, value: IpprotoTcp)
	// getaddrinfo(host, NULL, &hints, &result). 4 reg args, plain call (no P).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // host
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (service = NULL)
	helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.r8)  // &hints (slot 8 = base)
	helperLeaStackSlot(code, slotIndex: 1, dest: X64Register.r9)  // &result
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getAddrInfo))
	// 0 = success → dns_ok; non-zero → dns_fail (-1).
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz dns_ok
	helperEmitJmp(code, state: state, targetBlock: 3)  // dns_fail

	// block 1: dns_ok — ip = *(*(result+0x20)+4) (ai_addr → sin_addr DWORD).
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // result (addrinfo*)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rax, disp: 0x20)  // ai_addr
	code.append(b"\x8b\x40\x04")  // mov eax, [rax+4] (sin_addr, zero-extends)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // resolved IP
	// freeaddrinfo(result).
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.freeAddrInfo))
	// TEST-NET-1 (192.0.2.1, net order 0x010200C0) → return -2.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: TestNet1NetOrder)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jne not_testnet
	helperMovRegImm(code, dest: X64Register.r8, value: 0xFFFFFFFFFFFFFFFE)  // -2
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 2: not_testnet — return resolved IP.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 3: dns_fail — return -1.
	helperMarkBlock(state, code: code, blockId: 3)
	helperMovRegImm(code, dest: X64Register.r8, value: 0xFFFFFFFFFFFFFFFF)  // -1
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetSyncDns'

// __io_net_sync_close(handle=rcx) -> r8 : closesocket(handle) on the sync-worker
// thread. Idempotent on a 0 handle. Ports C# __io_sync_op_net_close.
function emitX64NetSyncClose(code ByteArray, relocations RelocationArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__io_net_sync_close", offset: code.count())
	// Blocks: 0=entry, 1=skip.
	var state = Win32HelperState.create(2, outgoingBytes: 0x20, localBytes: 0)
	helperPrologue(code, frameSize: 32)
	helperMarkBlock(state, code: code, blockId: 0)
	// if handle == 0 → skip (return 0).
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz skip
	// closesocket(handle). rcx already = handle.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeSocket))
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (result 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
	// block 1: skip — return 0.
	helperMarkBlock(state, code: code, blockId: 1)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetSyncClose'

// __destruct___ManagedSocket(ptr=param0) -> i64 : mm_alloc destructor ABI.
// Delegates to mrt_managed_socket_close(ptr), returns 0. Ports C#
// EmitNetSocketDestructor. Internal ABI: param0 = rcx; result in r8.
function emitX64NetSocketDestructor(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "__destruct___ManagedSocket", offset: code.count())
	var state = Win32HelperState.create(1, outgoingBytes: 0x20, localBytes: 0)
	helperPrologue(code, frameSize: 32)
	helperMarkBlock(state, code: code, blockId: 0)
	// mrt_managed_socket_close(ptr). rcx already = ptr (param0). Non-throwing void.
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_managed_socket_close")
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (return 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetSocketDestructor'

// mrt_managed_socket_close(selfPtr=param0) -> void : explicit close. Idempotent.
// Reads _handle from [selfPtr+0], zeros the field FIRST (so the destructor won't
// double-close on a reused OS handle), then routes closesocket to the sync worker
// via __io_submit_sync(IoSyncOpNetClose). Non-throwing — overrides the runtime.std
// stub (which only zeroed the field). Ports C# EmitNetClose. Internal ABI:
// param0 = rcx; the runtime.std stub is `mrt_managed_socket_close 1 void`, so the
// caller does not read a result. Slots: 0=selfPtr, 1=handle.
function emitX64NetClose(code ByteArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_managed_socket_close", offset: code.count())
	// Blocks: 0=entry, 1=noop.
	var state = Win32HelperState.create(2, outgoingBytes: 0x20, localBytes: 16)
	helperPrologue(code, frameSize: 48)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // selfPtr
	// if selfPtr == 0 → noop.
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz noop
	// handle = *(selfPtr+0).
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)  // jz noop (already closed)
	// *(selfPtr+0) = 0 FIRST (destructor idempotency).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	// __io_submit_sync(IoSyncOpNetClose, handle, 0). Internal ABI rcx=op, rdx=arg0, rax=arg1.
	helperMovRegImm(code, dest: X64Register.rcx, value: IoSyncOpNetClose)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)  // handle
	code.append(b"\x48\x31\xc0")  // xor rax, rax (arg1 = 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_submit_sync")
	helperFinalize(state, code: code)
	helperEpilogue(code)
	// block 1: noop — nothing to do.
	helperMarkBlock(state, code: code, blockId: 1)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetClose'

// Shared body for mrt_managed_socket_send / mrt_managed_socket_recv (C#
// EmitIoSubmitSocketOverlapped). Both issue an overlapped WSASend/WSARecv on
// the green thread and yield until IOCP completes, then return the byte count
// (errorReturn ABI: result → R8, flag → RDX). `isRecv` selects WSARecv (+ a
// zeroed lpFlags DWORD) vs WSASend (dwFlags=0), the recvFailed vs sendFailed
// flag, and the buffer length source (recv: capacity; send: the `length` arg
// after an offset+length>capacity bounds check → bufferOutOfBounds).
//
// __ManagedMemory header (managed ptr is the header ptr): buffer@0, length@8,
// capacity@16. send/recv only read buffer@0 and capacity@16.
//
// Internal ABI params: send = (selfPtr rcx, mmPtr rdx, offset rax, length r9);
// recv = (selfPtr rcx, mmPtr rdx). Slots:
//   0=handle, 1=mmPtr, 2=offset(send)/cap(recv), 3=length(send)/cap(recv),
//   4=ctx, 5=saved-error / dequeued-GT / bytes(sync), 6=WSABUF.len(+pad),
//   7=WSABUF.buf, 8=recv flags DWORD.
// Blocks: 0=entry, 1=oob(send only), 2=sync_err, 3=sync_done, 4=yield,
//   5=worker_switch, 6=mainthread_loop, 7=mt_run, 8=mt_park, 9=resume, 10=cancelled.
function emitX64IoSubmitSocketOverlapped(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap, isRecv bool, funcName String)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: funcName, offset: code.count())
	var wsaSlot = iatSlotIndex(IatSlot.wsaSend)
	var osErrFlag = SockFlagSendFailed
	if isRecv 'recvSelect'
		wsaSlot = iatSlotIndex(IatSlot.wsaRecv)
		osErrFlag = SockFlagRecvFailed
	end 'recvSelect'
	var state = Win32HelperState.create(11, outgoingBytes: 0x40, localBytes: 80)
	helperPrologue(code, frameSize: 128)
	helperMarkBlock(state, code: code, blockId: 0)
	// Capture args. handle = *(selfPtr+0).
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.rcx, disp: 0)  // handle
	helperStoreSlot(code, slotIndex: 0, src: X64Register.r10)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // mmPtr
	if isRecv 'recvArgs'
		// recv: length/cap = *(mmPtr+16); buffer base = *(mmPtr+0).
		helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rdx, disp: 16)  // capacity
		helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)  // length used by WSABUF
		helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rdx, disp: 0)  // dataPtr
		// WSABUF = {ULONG len@0; CHAR* buf@8}. Base (byte 0) = slot 7 (lower addr);
		// buf@base+8 lives in slot 6. Store buf to slot 6.
		helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)  // WSABUF.buf = dataPtr
	end 'recvArgs' else 'sendArgs'
		// send: offset=rax (param2), length=r9 (param3). The offset+length>capacity
		// bounds check + WSABUF.buf computation happen after the cancel check (in
		// the `sendBoundsJump` block) so the cancel path doesn't run them.
		helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // offset
		helperStoreSlot(code, slotIndex: 3, src: X64Register.r9)  // length
	end 'sendArgs'
	// Cancel check (shared). self.cancel_flag != 0 → cancelled.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffCancelFlag)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 10)  // jnz cancelled
	if not isRecv 'sendBoundsJump'
		// (offset + length) > capacity → oob. Compute sum = offset + length.
		helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // offset
		helperLoadSlot(code, slotIndex: 3, dest: X64Register.r9)  // length
		emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.r9)  // rax = offset+length
		helperLoadSlot(code, slotIndex: 1, dest: X64Register.r11)  // mmPtr
		helperLoadIndirect(code, dest: X64Register.r11, base: X64Register.r11, disp: 16)  // capacity
		emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.r11)
		helperEmitCondJump(code, state: state, opcode: 0x87, targetBlock: 1)  // ja oob (unsigned >)
		// bufPtr = dataPtr + offset.
		helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // mmPtr
		helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rax, disp: 0)  // dataPtr
		helperLoadSlot(code, slotIndex: 2, dest: X64Register.r9)  // offset
		emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.r9)
		helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)  // WSABUF.buf = dataPtr+offset (slot 6 = base+8)
	end 'sendBoundsJump'
	// ctx = __slab_alloc(IoAsyncCtxSize) (zeroed OVERLAPPED + fields).
	helperMovRegImm(code, dest: X64Register.rcx, value: IoAsyncCtxSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 4, src: X64Register.r8)  // ctx
	// ctx.waiter = self ; self.io_handle = handle ; self.status = waiting.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoAsyncCtxOffWaiter, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)  // handle
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffIoHandle, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffStatus, src: X64Register.rax)
	// Build WSABUF {len@0, buf@8}: base = slot 7 (lower addr), buf already stored in
	// slot 6 (= base+8). Zero slot 7 (len qword incl. the 4 pad bytes) then write the
	// low 32 bits of the length into WSABUF.len at base+0.
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)  // zero len+pad
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // length/cap
	let wsabufLenOff = helperSlotRbpOffset(7 as VarSlot)
	helperStoreDwordRegLow(code, base: X64Register.rbp, disp: wsabufLenOff, src: X64Register.rax)  // WSABUF.len @0
	if isRecv 'recvFlags'
		// Zero the lpFlags DWORD (slot 8) for WSARecv.
		code.append(b"\x48\x31\xc0")  // xor rax, rax
		helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)
	end 'recvFlags'
	// WSASend/WSARecv(handle, &WSABUF, 1, NULL, dwFlags/&flags, ctx, NULL). 7 args
	// → frame 0x40 (shadow 0x20 + 3 stack args 0x18 + pad 0x08). On the system stack.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // socket handle
	helperLeaStackSlot(code, slotIndex: 7, dest: X64Register.rdx)  // &WSABUF (base = slot 7)
	helperMovRegImm(code, dest: X64Register.r8, value: 1)  // dwBufferCount
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpNumberOfBytes = NULL)
	if isRecv 'recvStackArgs'
		// [rsp+0x20] = &flags (DWORD 0 at slot 8).
		helperLeaStackSlot(code, slotIndex: 8, dest: X64Register.rax)
		emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)
	end 'recvStackArgs' else 'sendStackArgs'
		// [rsp+0x20] = dwFlags = 0.
		code.append(b"\x48\x31\xc0")  // xor rax, rax
		emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)
	end 'sendStackArgs'
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)  // ctx
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)  // lpOverlapped = ctx
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x30, srcReg: X64Register.rax)  // lpCompletionRoutine = NULL
	helperEmitIatCall(code, relocations: relocations, slotIndex: wsaSlot)
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	// 0 → sync success (FILE_SKIP_COMPLETION) → sync_done. Else SOCKET_ERROR.
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // jz sync_done
	// WSAGetLastError; 997 (WSA_IO_PENDING) → yield; else sync error. rax holds the
	// WSA error code on the fall-through. MUST explicitly jmp sync_err: block 1
	// (oob) is emitted next physically, so without this the genuine-sync-error path
	// would fall into oob — returning the wrong flag, skipping io-state cleanup, and
	// LEAKING the slab ctx (block 1 never frees it). sync_err's first op saves rax.
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.wsaGetLastError))
	helperCmpRegImm(code, reg: X64Register.rax, value: WsaIoPending)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)  // je yield
	helperEmitJmp(code, state: state, targetBlock: 2)  // else → sync_err (real OS error)

	// block 1: oob (send only) — bufferOutOfBounds. R8=0, RDX=flag.
	helperMarkBlock(state, code: code, blockId: 1)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (result 0)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagBufferOutOfBounds)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 2: sync_err — clear io_handle/status, store error, free ctx, return
	//   error flag (R8=0, RDX=osErrFlag).
	helperMarkBlock(state, code: code, blockId: 2)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // save Win32 error
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rcx)  // ready
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (result 0)
	helperMovRegImm(code, dest: X64Register.rdx, value: osErrFlag)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 3: sync_done — GetOverlappedResult for the byte count, then resume.
	helperMarkBlock(state, code: code, blockId: 3)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // zero bytes slot
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)  // hFile = socket
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)  // lpOverlapped = ctx
	helperLeaStackSlot(code, slotIndex: 5, dest: X64Register.r8)  // &bytesTransferred
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (bWait = FALSE)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getOverlappedResult))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rcx)  // bytes
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoResultVal, src: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rax)  // ready
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperEmitJmp(code, state: state, targetBlock: 9)  // resume

	// block 4: yield — I/O pending. self == mainThread (stackBase==0) → loop, else switch.
	helperMarkBlock(state, code: code, blockId: 4)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)  // jz mainthread_loop

	// block 5: worker_switch — ioYielded=0, mainThread running, switch self→mainThread.
	helperMarkBlock(state, code: code, blockId: 5)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoYielded, src: X64Register.rax)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r10, disp: POffMainThread + GtOffStatus, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)  // from = self
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r10)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: POffMainThread)  // to = &P.mainThread
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperEmitJmp(code, state: state, targetBlock: 9)  // resume

	// block 6: mainthread_loop — drive the scheduler until our I/O completes.
	helperMarkBlock(state, code: code, blockId: 6)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_check_completions")
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusWaiting)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 9)  // jne resume
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 8)  // jz park

	// block 7: mt_run — run the dequeued GT.
	helperMarkBlock(state, code: code, blockId: 7)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rcx)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)  // from = self
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rdx)  // to = g
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 6)  // re-loop

	// block 8: mt_park — WaitForSingleObject(done event, 50ms), then re-loop.
	helperMarkBlock(state, code: code, blockId: 8)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperMovRegImm(code, dest: X64Register.rdx, value: 50)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitJmp(code, state: state, targetBlock: 6)

	// block 9: resume — clear io_handle; if io_error_code != 0 → OS error; else
	//   success (R8 = bytes, RDX = 0). Do NOT map bytes==0 to an error (the
	//   stdlib decides connectionClosed).
	helperMarkBlock(state, code: code, blockId: 9)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rax)  // clear io_handle
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffIoErrorCode)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz sync_err (OS error path)
	// success: R8 = io_result_val (bytes), RDX = 0.
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.r10, disp: GtOffIoResultVal)
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (flag = 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 10: cancelled — ERROR_OPERATION_ABORTED, return osErrFlag (R8=0).
	helperMarkBlock(state, code: code, blockId: 10)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: ErrorOperationAborted)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	code.append(b"\x4d\x31\xc0")  // xor r8, r8 (result 0)
	helperMovRegImm(code, dest: X64Register.rdx, value: osErrFlag)
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64IoSubmitSocketOverlapped'

// mrt_managed_socket_tcp_connect(mmHostPtr=rcx, port=rdx) -> managed __ManagedSocket
// (errorReturn ABI: result → R8, flag → RDX). Resolves the host on the sync worker
// (DNS needs a full OS stack), then creates + binds the socket and connects via
// overlapped ConnectEx on the green thread. Ports C# EmitNetTcpConnect + the
// parser's cstr/flag work. Slots:
//   0=hostMm, 1=port, 2=socket, 3=ctx, 4=resolvedIP, 5=temp(fnptr/error/dequeuedGT),
//   6..7=bind sockaddr (16 bytes), 8..9=connect sockaddr (16 bytes), 10=mptr, 11=hostCstr.
// Blocks: 0=entry, 1=connect_err(sync ConnectEx fail), 2=sync_done, 3=yield,
//   4=worker_switch, 5=mainthread_loop, 6=mt_run, 7=mt_park, 8=resume,
//   9=async_fail, 10=async_fail_noclose, 11=sock_ok, 12=bind_ok, 13=sock_fail,
//   14=bind_fail, 15=dns_fail, 16=cancelled, 17=make_err (alloc placeholder + return).
function emitX64NetTcpConnect(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_managed_socket_tcp_connect", offset: code.count())
	var state = Win32HelperState.create(18, outgoingBytes: 0x40, localBytes: 128)
	helperPrologue(code, frameSize: 176)
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)  // hostMm
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)  // port
	// Cancel check.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffCancelFlag)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 16)  // jnz cancelled
	// hostCstr = mrt_cstr_from_mm(hostMm).
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_cstr_from_mm")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)  // result in r8
	helperStoreSlot(code, slotIndex: 11, src: X64Register.rax)  // hostCstr
	// __io_submit_sync(IoSyncOpDnsResolve, hostCstr, 0) → ip/-1/-2 in r8.
	helperMovRegImm(code, dest: X64Register.rcx, value: IoSyncOpDnsResolve)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdx)  // hostCstr (arg0)
	code.append(b"\x48\x31\xc0")  // xor rax, rax (arg1 = 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_submit_sync")
	helperStoreSlot(code, slotIndex: 4, src: X64Register.r8)  // resolved IP / -1 / -2
	// mm_decref(hostCstr) — it is mm_alloc-backed.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	// if resolvedIP < 0 → DNS/connect failure. -1 → resolveFailed, -2 → connectFailed.
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x88, targetBlock: 15)  // js dns_fail (signed < 0)

	// --- Socket creation + bind + overlapped ConnectEx ---
	// socket = WSASocketW(AF_INET, SOCK_STREAM, IPPROTO_TCP, NULL, 0, WSA_FLAG_OVERLAPPED).
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperMovRegImm(code, dest: X64Register.rcx, value: AfInet)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockStream)
	helperMovRegImm(code, dest: X64Register.r8, value: IpprotoTcp)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // g = 0
	helperMovRegImm(code, dest: X64Register.rax, value: WsaFlagOverlapped)
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wsaSocketW))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	// INVALID_SOCKET (-1) → sock_fail (connectFailed).
	helperMovRegImm(code, dest: X64Register.rcx, value: 0xFFFFFFFFFFFFFFFF)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 11)  // jne sock_ok
	helperEmitJmp(code, state: state, targetBlock: 13)  // sock_fail

	// block 1: connect_err — sync ConnectEx error. closesocket, clear io state,
	//   free ctx, connectFailed.
	helperMarkBlock(state, code: code, blockId: 1)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // save WSA error
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeSocket))
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 2: sync_done — ConnectEx returned TRUE (immediate completion). Store
	//   socket as io_result_val, status ready, free ctx, resume.
	helperMarkBlock(state, code: code, blockId: 2)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoResultVal, src: X64Register.rcx)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffStatus, src: X64Register.rax)  // ready
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)  // free ctx
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_free")
	helperEmitJmp(code, state: state, targetBlock: 8)  // resume

	// block 3: yield — ConnectEx IO_PENDING. self == mainThread → loop, else switch.
	helperMarkBlock(state, code: code, blockId: 3)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: GtOffStackBase)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)  // jz mainthread_loop

	// block 4: worker_switch.
	helperMarkBlock(state, code: code, blockId: 4)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.rcx, disp: GtOffIoYielded, src: X64Register.rax)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r10, disp: POffMainThread + GtOffStatus, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.r10, disp: POffCurrentGt)  // from = self
	emitMovRegRegOp(code, dest: X64Register.rdx, src: X64Register.r10)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: POffMainThread)  // to = &P.mainThread
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperEmitJmp(code, state: state, targetBlock: 8)  // resume

	// block 5: mainthread_loop.
	helperMarkBlock(state, code: code, blockId: 5)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_process_pending_waiter")
	helperEmitDirectCall(code, callFixups: callFixups, target: "__io_check_completions")
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffStatus)
	helperCmpRegImm(code, reg: X64Register.rax, value: GtStatusWaiting)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 8)  // jne resume
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_dequeue")
	helperTestReg(code, reg: X64Register.r8)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)  // jz park

	// block 6: mt_run.
	helperMarkBlock(state, code: code, blockId: 6)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.rcx, value: GtStatusRunning)
	helperStoreIndirect(code, base: X64Register.r8, disp: GtOffStatus, src: X64Register.rcx)
	emitX64GtLoadCurrentP(code, dest: X64Register.rcx, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: POffCurrentGt)  // from = self
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rdx)  // to = g
	helperEmitDirectCall(code, callFixups: callFixups, target: "__gt_context_switch")
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	helperStoreIndirect(code, base: X64Register.rax, disp: GtOffIoYielded, src: X64Register.rcx)
	helperEmitJmp(code, state: state, targetBlock: 5)  // re-loop

	// block 7: mt_park.
	helperMarkBlock(state, code: code, blockId: 7)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__io_done_event")
	helperMovRegImm(code, dest: X64Register.rdx, value: 50)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.waitForSingleObject))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// block 8: resume — clear io_handle, socket = io_result_val; on error or
	//   socket==0 → async_fail; else setsockopt(SO_UPDATE_CONNECT_CONTEXT) + wrap.
	helperMarkBlock(state, code: code, blockId: 8)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoHandle, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffIoResultVal)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // socket
	// io_error_code != 0 → async_fail.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.r10, disp: GtOffIoErrorCode)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 9)  // jnz async_fail
	// socket == 0 → async_fail.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 9)  // jz async_fail
	// setsockopt(socket, SOL_SOCKET, SO_UPDATE_CONNECT_CONTEXT, NULL, 0). 5 args → 0x30.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	helperMovRegImm(code, dest: X64Register.rdx, value: SolSocket)
	helperMovRegImm(code, dest: X64Register.r8, value: SoUpdateConnectContext)
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (optval = NULL)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // optlen = 0
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setSockOpt))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x30)
	// Wrap: mptr = mm_alloc(8, &__destruct___ManagedSocket, 0); *(mptr+0) = socket.
	helperMovRegImm(code, dest: X64Register.rcx, value: 8)
	emitLeaFuncAddrOp(code, dest: X64Register.rdx, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__destruct___ManagedSocket")
	code.append(b"\x48\x31\xc0")  // xor rax, rax (tag = 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)  // mptr in r8
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)  // *(mptr+0) = socket
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)  // R8 = mptr
	code.append(b"\x48\x31\xd2")  // xor rdx, rdx (flag = 0)
	helperFinalize(state, code: code)
	helperEpilogue(code)

	// block 9: async_fail — closesocket if non-zero, then connectFailed.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	helperTestReg(code, reg: X64Register.rcx)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)  // jz async_fail_noclose
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeSocket))
	// block 10: async_fail_noclose.
	helperMarkBlock(state, code: code, blockId: 10)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 11: sock_ok — save socket; register with IOCP; bind; ConnectEx.
	helperMarkBlock(state, code: code, blockId: 11)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)  // socket
	// CreateIoCompletionPort(socket, __io_iocp, 0, 0).
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rdx, name: "__io_iocp")
	code.append(b"\x4d\x31\xc0")  // xor r8, r8
	code.append(b"\x4d\x31\xc9")  // xor r9, r9
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.createIoCompletionPort))
	// SetFileCompletionNotificationModes(socket, FILE_SKIP_COMPLETION_PORT_ON_SUCCESS).
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: FileSkipCompletionPortOnSuccess)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.setFileCompletionNotificationModes))
	// Build bind sockaddr_in (slots 6..7, 16 bytes): INADDR_ANY:0, family=AF_INET.
	// Base (byte 0) = slot 7 (lower address); the struct spans [slot7, slot7+16).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)
	let bindOff = helperSlotRbpOffset(7 as VarSlot)
	helperStoreWordImm(code, base: X64Register.rbp, disp: bindOff, value: AfInet)  // sin_family @0
	// bind(socket, &bind_addr, 16).
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 7, dest: X64Register.rdx)  // &bind_addr (base)
	helperMovRegImm(code, dest: X64Register.r8, value: 16)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.bind))
	// 0 = success → bind_ok; else bind_fail.
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)  // jz bind_ok
	helperEmitJmp(code, state: state, targetBlock: 14)  // bind_fail

	// block 12: bind_ok — build connect sockaddr_in, alloc ctx, ConnectEx.
	helperMarkBlock(state, code: code, blockId: 12)
	// connect sockaddr_in (slots 8..9, 16 bytes): family=AF_INET, port=htons(port), addr=ip.
	// Base (byte 0) = slot 9 (lower address); the struct spans [slot9, slot9+16).
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)
	helperStoreSlot(code, slotIndex: 9, src: X64Register.rax)
	let connOff = helperSlotRbpOffset(9 as VarSlot)
	helperStoreWordImm(code, base: X64Register.rbp, disp: connOff, value: AfInet)  // sin_family @0
	// sin_port = htons(port) @2: load port, ROL AX,8, store word.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)  // port
	code.append(b"\x66\xc1\xc0\x08")  // rol ax, 8 (htons)
	helperStoreWordRegLow(code, base: X64Register.rbp, disp: connOff + 2, src: X64Register.rax)
	// sin_addr = resolved IP @4 (DWORD).
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperStoreDwordRegLow(code, base: X64Register.rbp, disp: connOff + 4, src: X64Register.rax)
	// ctx = __slab_alloc(IoAsyncCtxSize).
	helperMovRegImm(code, dest: X64Register.rcx, value: IoAsyncCtxSize)
	helperEmitDirectCall(code, callFixups: callFixups, target: "__slab_alloc")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.r8)  // ctx
	// ctx.waiter = self ; ctx.custom_result = socket ; self.io_handle = socket ; waiting.
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.rdx, base: X64Register.r10, disp: POffCurrentGt)
	helperStoreIndirect(code, base: X64Register.r8, disp: IoAsyncCtxOffWaiter, src: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)  // socket
	helperStoreIndirect(code, base: X64Register.r8, disp: IoAsyncCtxOffCustomResult, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffIoHandle, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: GtStatusWaiting)
	helperStoreIndirect(code, base: X64Register.rdx, disp: GtOffStatus, src: X64Register.rax)
	// ConnectEx(socket, &addr, 16, NULL, 0, NULL, ctx) via __io_connectex_ptr. 7 args
	// (4 reg + 3 stack) → frame 0x40. CALL through the function pointer.
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__io_connectex_ptr")
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)  // save fn ptr
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)  // socket
	helperLeaStackSlot(code, slotIndex: 9, dest: X64Register.rdx)  // &sockaddr_in (base = slot 9)
	helperMovRegImm(code, dest: X64Register.r8, value: 16)  // namelen
	code.append(b"\x4d\x31\xc9")  // xor r9, r9 (lpSendBuffer = NULL)
	code.append(b"\x48\x31\xc0")  // xor rax, rax
	emitMovRspOffsetReg(code, offset: 0x20, srcReg: X64Register.rax)  // dwSendDataLength = 0
	emitMovRspOffsetReg(code, offset: 0x28, srcReg: X64Register.rax)  // lpdwBytesSent = NULL
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)  // ctx
	emitMovRspOffsetReg(code, offset: 0x30, srcReg: X64Register.rax)  // lpOverlapped = ctx
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)  // fn ptr
	code.append(b"\xff\xd0")  // call rax
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 0x40)
	// TRUE (non-zero) → sync_done; FALSE → check WSAGetLastError.
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 2)  // jnz sync_done
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.wsaGetLastError))
	helperCmpRegImm(code, reg: X64Register.rax, value: WsaIoPending)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)  // je yield
	helperEmitJmp(code, state: state, targetBlock: 1)  // connect_err (rax = WSA error)

	// block 13: sock_fail — WSASocketW failed. connectFailed (no socket to close).
	helperMarkBlock(state, code: code, blockId: 13)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 14: bind_fail — closesocket, connectFailed.
	helperMarkBlock(state, code: code, blockId: 14)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.closeSocket))
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 15: dns_fail — resolvedIP -1 → resolveFailed, -2 → connectFailed.
	// No socket exists on this path, so set the flag directly and go straight to
	// make_err (do NOT route through bind_fail/sock_fail — bind_fail would
	// closesocket a garbage handle). Default the flag to resolveFailed, override
	// to connectFailed when the sentinel is exactly -2 (TEST-NET-1).
	helperMarkBlock(state, code: code, blockId: 15)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagResolveFailed)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 0xFFFFFFFFFFFFFFFE)  // -2 (TEST-NET-1)
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 17)  // jne make_err (resolveFailed)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)  // -2 → connectFailed
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 16: cancelled — ERROR_OPERATION_ABORTED, connectFailed.
	helperMarkBlock(state, code: code, blockId: 16)
	emitX64GtLoadCurrentP(code, dest: X64Register.r10, rdataRelocs: rdataRelocs)
	helperLoadIndirect(code, dest: X64Register.r10, base: X64Register.r10, disp: POffCurrentGt)
	helperMovRegImm(code, dest: X64Register.rax, value: ErrorOperationAborted)
	helperStoreIndirect(code, base: X64Register.r10, disp: GtOffIoErrorCode, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rdx, value: SockFlagConnectFailed)
	helperEmitJmp(code, state: state, targetBlock: 17)  // make_err

	// block 17: make_err — RDX already holds the error flag. Allocate a heap
	//   __ManagedSocket{_handle:0} so the scope-exit decref hits a real header
	//   (the destructor no-ops on handle 0), then R8 = mptr, RDX = flag, ret.
	helperMarkBlock(state, code: code, blockId: 17)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rdx)  // save flag (mm_alloc clobbers rdx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 8)
	emitLeaFuncAddrOp(code, dest: X64Register.rdx, callFixups: callFixups, rdataRelocs: rdataRelocs, funcName: "__destruct___ManagedSocket")
	code.append(b"\x48\x31\xc0")  // xor rax, rax (tag = 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)  // mptr in r8
	code.append(b"\x48\x31\xc9")  // xor rcx, rcx
	helperStoreIndirect(code, base: X64Register.rax, disp: 0, src: X64Register.rcx)  // _handle = 0
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)  // R8 = mptr
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rdx)  // RDX = flag
	helperFinalize(state, code: code)
	helperEpilogue(code)
end 'emitX64NetTcpConnect'

// =============================================================================
// 1. mrt_win32_translate_lasterror — calls GetLastError (IAT 27),
// then maps Win32 error codes to POSIX errno-style negative values.
// Stack layout:
//   slot 0 = masked Win32 error code
// Outgoing-arg area: 32 bytes (GetLastError takes 0 args; we still need
// shadow space).
// Block plan (ids):
//   0: entry
//   1: success                (-> ret 0)
//   2: check_enoent_2
//   3: check_enoent_3
//   4: ret_enoent             (-> ret -2)
//   5: check_eacces_5
//   6: check_eacces_32
//   7: ret_eacces             (-> ret -13)
//   8: check_eexist_80
//   9: check_eexist_183
//  10: ret_eexist             (-> ret -17)
//  11: ret_eio                (-> ret -5)
// =============================================================================
function emitX64Win32TranslateLasterror(code ByteArray, relocations RelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_translate_lasterror", offset: helperStart)

	// Frame: 1 slot (slot 0) + 32 bytes shadow.
	// localBytes = 8, outgoingBytes = 32. Total = 40, aligned to 16 = 48.
	let frameSize = 48
	var state = Win32HelperState.create(12, outgoingBytes: 32, localBytes: 8)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: entry — GetLastError; mask; storeSlot 0.
	helperMarkBlock(state, code: code, blockId: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	// rax &= 0xFFFFFFFF — use mov eax, eax (zero-extends to 64 bits in 2 bytes).
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)

	// if (slot 0 == 0) goto block 1 (success), else block 2.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ block 1
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	// jmp block 2
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 1: success — ret 0.
	helperMarkBlock(state, code: code, blockId: 1)
	helperReturnImm(code, value: 0)

	// Block 2: check_enoent_2.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 2)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: check_enoent_3.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 3)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: ret_enoent — ret -2.
	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -2)

	// Block 5: check_eacces_5.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 5)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: check_eacces_32.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 32)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 8)

	// Block 7: ret_eacces — ret -13.
	helperMarkBlock(state, code: code, blockId: 7)
	helperReturnImm(code, value: -13)

	// Block 8: check_eexist_80.
	helperMarkBlock(state, code: code, blockId: 8)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 80)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 9)

	// Block 9: check_eexist_183.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 183)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 11)

	// Block 10: ret_eexist — ret -17.
	helperMarkBlock(state, code: code, blockId: 10)
	helperReturnImm(code, value: -17)

	// Block 11: ret_eio — ret -5.
	helperMarkBlock(state, code: code, blockId: 11)
	helperReturnImm(code, value: -5)

	helperFinalize(state, code: code)
end 'emitX64Win32TranslateLasterror'

// =============================================================================
// 2. mrt_win32_write(wrapperBlock, bufPtr, count)
// Internal ABI: rcx=wrapper, rdx=bufPtr, rax=count.
// Stack:
//   slot 0 = wrapper
//   slot 1 = HANDLE
//   slot 2 = bytes-written DWORD (out-param to WriteFile)
//   slot 3 = WriteFile BOOL
// Outgoing-arg area: WriteFile takes 5 args → 32 + 8 = 40 → 48 bytes.
// Block plan:
//   0: entry
//   1: fail   (-> tailcall mrt_win32_translate_lasterror)
//   2: ok     (-> ret slot 2 masked)
// =============================================================================
function emitX64Win32Write(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_write", offset: helperStart)

	// 4 slots × 8 = 32 bytes locals + 48 outgoing = 80, aligned to 16 = 80.
	let frameSize = 80
	let outgoingBytes = 48
	var state = Win32HelperState.create(3, outgoingBytes: outgoingBytes, localBytes: 32)

	helperPrologue(code, frameSize: frameSize)

	// Save wrapper/buf/count into slots 0..(unused-but-keep-in-regs):
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	// Save bufPtr (rdx) and count (rax) into a stack home in case we need them
	// across the IAT call.
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	// HANDLE = wrapper[8].
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	// slot 2 = 0 (bytesWritten out-param).
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// Call WriteFile(handle, buf, count, &bytesWritten, NULL).
	// rcx=handle, rdx=buf, r8=count, r9=&bytesWritten, [rsp+32]=NULL.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.r8)
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.writeFile))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// if (slot 3 == 0) goto fail else ok.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 1: fail — tailcall translate_lasterror, return its result.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	// Callee returns its value in r8 (internal ABI). Use it directly.
	helperEpilogue(code)

	// Block 2: ok — return slot 2 masked to 32 bits.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	// mov eax, eax — zero-extends.
	code.append(b"\x89\xc0")
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Write'

// =============================================================================
// 3. mrt_win32_read — identical structure to write, calls ReadFile.
// =============================================================================
function emitX64Win32Read(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_read", offset: helperStart)

	let frameSize = 80
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 32)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rdx)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.r8)
	helperLeaStackSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.readFile))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	code.append(b"\x89\xc0")
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Read'

// =============================================================================
// 4. mrt_win32_close(wrapper) — dispatch on wrapper[0]:
//   kind 0 (file)      → CloseHandle(wrapper[8])
//   kind 1 (directory) → FindClose(wrapper[8])
// Always mm_decrefs the wrapper. Skips when wrapper == 0 or wrapper == -1.
// Block plan:
//   0: entry
//   1: check_neg_one
//   2: load_kind
//   3: close_find
//   4: close_handle
//   5: free_wrapper
//   6: done
// =============================================================================
function emitX64Win32Close(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_close", offset: helperStart)

	// 2 slots (slot 0 wrapper, slot 1 kind) = 16; outgoing 32. Total 48.
	let frameSize = 48
	var state = Win32HelperState.create(7, outgoingBytes: 32, localBytes: 16)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: entry.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	// if (wrapper == 0) goto done else check_neg_one.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: check_neg_one.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: load_kind.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 4)

	// Block 3: close_find — FindClose(wrapper[8]).
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findClose))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: close_handle — CloseHandle(wrapper[8]).
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rcx, base: X64Register.rcx, disp: 8)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.closeHandle))
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 5: free_wrapper — call mm_decref(wrapper).
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: done — return 0.
	helperMarkBlock(state, code: code, blockId: 6)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Close'

// =============================================================================
// 5. mrt_win32_lseek(wrapper, offset, whence)
// rcx=wrapper, rdx=offset, rax=whence.
// Stack:
//   slot 0 = wrapper
//   slot 1 = offset
//   slot 2 = whence
//   slot 3 = HANDLE
//   slot 4 = new position (LARGE_INTEGER out-param)
//   slot 5 = SetFilePointerEx BOOL
// Outgoing-arg area: 4-arg call = 32. Frame: 6*8 + 32 = 80.
// =============================================================================
function emitX64Win32Lseek(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_lseek", offset: helperStart)

	let frameSize = 80
	var state = Win32HelperState.create(3, outgoingBytes: 32, localBytes: 48)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	// SetFilePointerEx(handle, distance, &newPos, moveMethod).
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperLeaStackSlot(code, slotIndex: 4, dest: X64Register.r8)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.setFilePointerEx))
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Lseek'

// =============================================================================
// 6. mrt_win32_unlink(cStringPtr)
// rcx=cstr. Converts UTF-8 → UTF-16 via MultiByteToWideChar, calls DeleteFileW.
// Stack:
//   slot 0 = cstr ptr
//   slot 1 = DeleteFileW BOOL
//   slots 11..267 = wide path (1024 wchars × 2 = 2048 bytes)
// Outgoing-arg area for MBTWC = 6 args → 32 + 16 = 48; DeleteFileW = 1 arg → 32.
// Frame: 268*8 + 48 = 2192, aligned to 16 = 2192.
// =============================================================================
function emitX64Win32Unlink(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_unlink", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide, 1024).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// DeleteFileW(&wide).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.deleteFileW))
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Unlink'

// =============================================================================
// 7. mrt_win32_mkdir(cStringPtr, mode)
// rcx=cstr, rdx=mode (ignored). CreateDirectoryW(cstr, NULL).
// =============================================================================
function emitX64Win32Mkdir(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_mkdir", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(3, outgoingBytes: 48, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)

	// MultiByteToWideChar.
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))

	// CreateDirectoryW(&wide, NULL).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createDirectoryW))
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Mkdir'

// =============================================================================
// 8. mrt_win32_access(cStringPtr, mode)
// rcx=cstr, rdx=mode. Calls GetFileAttributesExW; if W_OK requested, checks
// FILE_ATTRIBUTE_READONLY.
// Stack:
//   slot 0 = cstr
//   slot 1 = mode
//   slot 2 = GetFileAttributesExW BOOL
//   slot 3 = scratch
//   slots 11..267 = wide path
//   slots 50..54  = WIN32_FILE_ATTRIBUTE_DATA (5 qwords)
// Block plan:
//   0: entry
//   1: fail
//   2: check_write
//   3: verify_writable
//   4: fail_eacces
//   5: ok
// =============================================================================
function emitX64Win32Access(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_access", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(6, outgoingBytes: 48, localBytes: 2144)

	emitX64GtStackGuard(code, callFixups: callFixups, rdataRelocs: rdataRelocs, frameSize: frameSize)
	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide, 1024). Run on the per-P system
	// stack (g0 model): its ~3.9 KB kernel frame stays off the GT stack, so the
	// guard only sizes this helper's own frame and __gt_morestack can grow strictly
	// 2× (Go-faithful) instead of needing a special-case floor. The &wide buffer
	// (slot 267) and the cstr (slot 0) stay rbp-relative on the GT stack; only the
	// outgoing args (rsp-relative) move to the system stack.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 48)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 48)

	// GetFileAttributesExW(&wide, GetFileExInfoStandard=0, &data).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.r8)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getFileAttributesExW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	// if (mode & 2) goto verify_writable else ok.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 2)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ goes to block 5 (ok), else fall through to block 3.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 3)

	helperMarkBlock(state, code: code, blockId: 3)
	// scratch = data.dwFileAttributes & 0xFFFFFFFF; if (scratch & 1) → eacces else ok.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	// mov eax, eax — zero-extend.
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → ok, JNZ → fail_eacces.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 4)

	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -13)

	helperMarkBlock(state, code: code, blockId: 5)
	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Access'

// =============================================================================
// 9. mrt_win32_stat(cStringPtr, statBufPtr)
// Translates Win32 file attributes to Linux struct stat layout.
// rcx=cstr, rdx=statBufPtr.
// Stack:
//   slot 0 = cstr
//   slot 1 = statBuf
//   slot 2 = GetFileAttributesExW BOOL
//   slot 3 = scratch
//   slots 11..267 = wide path
//   slots 50..54  = WIN32_FILE_ATTRIBUTE_DATA
// Block plan:
//   0: entry
//   1: fail
//   2: ok / mode-decision-prep
//   3: set_dir
//   4: set_reg
//   5: add_writable
//   6: mark_writable
//   7: write_mode (final writes + ret 0)
// =============================================================================
function emitX64Win32Stat(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_stat", offset: helperStart)

	let frameSize = 2192
	var state = Win32HelperState.create(8, outgoingBytes: 48, localBytes: 2144)

	emitX64GtStackGuard(code, callFixups: callFixups, rdataRelocs: rdataRelocs, frameSize: frameSize)
	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// MultiByteToWideChar. Run on the per-P system stack (g0 model): its ~3.9 KB
	// kernel frame stays off the GT stack so __gt_morestack can grow strictly 2×
	// (Go-faithful). The &wide buffer (slot 267) and cstr (slot 0) stay on the GT
	// stack (rbp-relative); only the rsp-relative outgoing args move.
	emitX64GtSystemStackEnter(code, rdataRelocs: rdataRelocs, frameSize: 48)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	emitX64GtSystemStackLeave(code, rdataRelocs: rdataRelocs, frameSize: 48)

	// GetFileAttributesExW.
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.r8)
	emitX64GtIatCallOnSystemStack(code, relocations: relocations, rdataRelocs: rdataRelocs, slotIndex: iatSlotIndex(IatSlot.getFileAttributesExW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 2)
	// statBuf[24] = 0 (st_mode zero).
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 24, src: X64Register.rax)

	// scratch = data[0] & 0xFFFFFFFF.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// if (scratch & 0x10) goto set_dir else set_reg.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0x10)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → set_reg, else set_dir.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 3)

	helperMarkBlock(state, code: code, blockId: 3)
	// set_dir: scratch = 16384.
	helperMovRegImm(code, dest: X64Register.rax, value: 16384)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 4)
	// set_reg: scratch = 32768.
	helperMovRegImm(code, dest: X64Register.rax, value: 32768)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 5)
	// if ((data[0] & 0xFFFFFFFF) & 1) == 0 goto mark_writable else write_mode.
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → mark_writable, JNZ → write_mode.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 7)

	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 128)
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 7)

	helperMarkBlock(state, code: code, blockId: 7)
	// statBuf[24] = slot 3.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 24, src: X64Register.rax)

	// size = (data[28]u32 << 32) | (data[32]u32).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 28)
	code.append(b"\x89\xc0")
	helperMovRegImm(code, dest: X64Register.rdx, value: 32)
	// shl rax, cl (rdx -> cl) — actually we need to mov rcx, rdx then shl rax, cl.
	emitMovRegRegOp(code, dest: X64Register.rcx, src: X64Register.rdx)
	emitShlRegClParam(code, reg: X64Register.rax)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 32)
	code.append(b"\x89\xc0")
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitOrRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 48, src: X64Register.rax)

	// mtime: data[20] (qword) - 116444736000000000 / 10000000 → statBuf[88].
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 20)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	// Divide by 10000000 — use idiv. Set up: cqo; idiv rcx where rcx=10000000.
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	// cqo: 0x48 0x99.
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 88, src: X64Register.rax)

	// ctime: data[4] (qword).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 4)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 104, src: X64Register.rax)

	// atime: data[12] (qword).
	helperLeaStackSlot(code, slotIndex: 54, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 12)
	helperMovRegImm(code, dest: X64Register.rcx, value: 116444736000000000)
	emitSubRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rcx, value: 10000000)
	code.append(b"\x48\x99")
	emitIdivRegOp(code, divisor: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 72, src: X64Register.rax)

	helperReturnImm(code, value: 0)

	helperFinalize(state, code: code)
end 'emitX64Win32Stat'

// =============================================================================
// 10. mrt_win32_getcwd(bufPtr, bufSize)
// Stack:
//   slot 0 = buf
//   slot 1 = bufSize
//   slot 2 = GetCurrentDirectoryW wchar count
//   slot 3 = WideCharToMultiByte byte count
//   slots 11..267 = wide buffer
// Block plan:
//   0: entry
//   1: check_too_big
//   2: fail
//   3: fail_oversized
//   4: convert
//   5: nul_terminate
// =============================================================================
function emitX64Win32Getcwd(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_getcwd", offset: helperStart)

	// WideCharToMultiByte = 8 args → 32 + 4*8 = 64.
	let frameSize = 2208
	var state = Win32HelperState.create(6, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)

	// GetCurrentDirectoryW(1024, &wide).
	helperMovRegImm(code, dest: X64Register.rcx, value: 1024)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rdx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getCurrentDirectoryW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → fail.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 1)

	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1024)
	// JG (signed greater) → fail_oversized.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 4)

	helperMarkBlock(state, code: code, blockId: 2)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 3)
	helperReturnImm(code, value: -36)

	helperMarkBlock(state, code: code, blockId: 4)
	// WideCharToMultiByte(65001, 0, &wide, wcharLen, buf, bufSize-1, NULL, NULL).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.r8)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r9)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 5)
	// buf[byteCount] = 0.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	// return buf.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Getcwd'

// =============================================================================
// 11. mrt_win32_open(cstr, flags, fileMode)
// rcx=cstr, rdx=flags, rax=fileMode (ignored).
// See runtime.std body for full details. Block plan:
//   0: entry
//   1: invalid_path  (-> ret -22)
//   2: check_dir_flag
//   3: file_branch
//   4: file_read
//   5: file_write
//   6: after_createfile
//   7: file_fail
//   8: file_ok
//   9: dir_branch
//  10: dir_fail
//  11: dir_ok
// =============================================================================
function emitX64Win32Open(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_open", offset: helperStart)

	// CreateFileW = 7 args → 32 + 24 = 56, aligned 64. Outgoing = 64.
	let frameSize = 2208
	var state = Win32HelperState.create(12, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	// param 2 (rax) is ignored.

	// MultiByteToWideChar(65001, 0, cstr, -1, &wide[267], 1024).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.multiByteToWideChar))
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 1)
	helperEmitJmp(code, state: state, targetBlock: 2)

	helperMarkBlock(state, code: code, blockId: 1)
	helperReturnImm(code, value: -22)

	helperMarkBlock(state, code: code, blockId: 2)
	// if (flags & 65536) goto dir_branch else file_branch.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65536)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → file_branch, JNZ → dir_branch.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 9)

	helperMarkBlock(state, code: code, blockId: 3)
	// if (flags & 1) → file_write, else file_read.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 1)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → file_read.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	helperMarkBlock(state, code: code, blockId: 4)
	// CreateFileW(path, GENERIC_READ=0x80000000, FILE_SHARE_READ=1, NULL, OPEN_EXISTING=3, FILE_ATTRIBUTE_NORMAL=0x80, NULL).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x80000000)
	helperMovRegImm(code, dest: X64Register.r8, value: 1)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 3)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x80)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)

	helperMarkBlock(state, code: code, blockId: 5)
	// CreateFileW(path, GENERIC_WRITE=0x40000000, FILE_SHARE_READ|FILE_SHARE_WRITE=3, NULL, CREATE_ALWAYS=2, FILE_ATTRIBUTE_NORMAL=0x80, NULL).
	// dwShareMode must allow concurrent readers: an editor (e.g. VS Code) holding
	// the target file open keeps a read handle on it, and dwShareMode=0 would make
	// CreateFileW fail with ERROR_SHARING_VIOLATION whenever such a handle exists.
	// Sharing read+write matches the read path's FILE_SHARE_READ and lets the
	// overwrite succeed regardless of an open editor.
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0x40000000)
	helperMovRegImm(code, dest: X64Register.r8, value: 3)
	helperMovRegImm(code, dest: X64Register.r9, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 2)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0x80)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.createFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 6)

	helperMarkBlock(state, code: code, blockId: 6)
	// if HANDLE == -1 → file_fail else file_ok.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 8)

	helperMarkBlock(state, code: code, blockId: 7)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 8)
	// Allocate 16-byte wrapper: rcx = 16; call mrt_alloc. Result in r8.
	helperMovRegImm(code, dest: X64Register.rcx, value: 16)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	// r8 = wrapper pointer; move to rax for storeSlot 2.
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	// wrapper[0] = 0, wrapper[8] = HANDLE.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 9)
	// Allocate 616-byte wrapper.
	helperMovRegImm(code, dest: X64Register.rcx, value: 616)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// FindFirstFileW(pattern=&wide[267], &wrapper[24]).
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rdx)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: 24)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findFirstFileW))
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: -1)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 11)

	helperMarkBlock(state, code: code, blockId: 10)
	// mm_decref(wrapper); return translate_lasterror.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mm_decref")
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	helperMarkBlock(state, code: code, blockId: 11)
	// wrapper[0] = 1, wrapper[8] = HANDLE, wrapper[16] = 1.
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.r8)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32Open'

// =============================================================================
// 12. mrt_win32_getdents64(wrapper, buf, bufSize)
// Most complex helper. Iterates FindNextFileW, packs Linux dirent64 entries
// into caller-supplied buffer.
// Stack layout per runtime.std:
//   slot 0 = wrapper
//   slot 1 = buf
//   slot 2 = bufSize
//   slot 3 = cursor
//   slot 4 = HANDLE
//   slot 5 = pending flag
//   slot 6 = FindNextFileW BOOL
//   slot 7 = utf-8 byte count
//   slot 8 = reclen
//   slot 9 = attribute word
//   slot 10 = name UTF-8 length
//   slot 11 = entry base (overlaps wide-buffer space but legal — see runtime.std)
//   stackAddr 267 = UTF-8 scratch buffer
// Block plan:
//   0: entry
//   1: emit_loop
//   2: call_find_next
//   3: check_no_more_files
//   4: end_of_iteration
//   5: find_next_error
//   6: mark_pending
//   7: process_entry
//   8: maybe_single_dot
//   9: check_double_dot
//  10: maybe_double_dot
//  11: check_second_dot
//  12: consume_entry
//  13: emit_entry
//  14: return_partial
//  15: write_entry
//  16: set_dir_type
//  17: set_reg_type
//  18: copy_name
// =============================================================================
function emitX64Win32Getdents64(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_getdents64", offset: helperStart)

	// WideCharToMultiByte = 8 args → outgoing 64. Frame: 2144 + 64 = 2208.
	let frameSize = 2208
	var state = Win32HelperState.create(19, outgoingBytes: 64, localBytes: 2144)

	helperPrologue(code, frameSize: frameSize)

	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 8)
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: emit_loop.
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 16)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 1)
	// JE → process_entry (block 7).
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 7)
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: call_find_next.
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rdx)
	emitAddRegImmParam(code, dest: X64Register.rdx, value: 24)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.findNextFileW))
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)

	helperLoadSlot(code, slotIndex: 6, dest: X64Register.rax)
	helperTestReg(code, reg: X64Register.rax)
	// JZ → check_no_more_files, JNZ → mark_pending.
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 3)
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 3: check_no_more_files.
	helperMarkBlock(state, code: code, blockId: 3)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getLastError))
	// mask to 32 bits.
	code.append(b"\x89\xc0")
	helperCmpRegImm(code, reg: X64Register.rax, value: 18)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: end_of_iteration.
	helperMarkBlock(state, code: code, blockId: 4)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)
	helperEpilogue(code)

	// Block 5: find_next_error.
	helperMarkBlock(state, code: code, blockId: 5)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_translate_lasterror")
	helperEpilogue(code)

	// Block 6: mark_pending.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 7)

	// Block 7: process_entry.
	helperMarkBlock(state, code: code, blockId: 7)
	// WideCharToMultiByte(65001, 0, &wrapper[68], -1, &scratch[267], 1024, 0, 0).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.r8)
	emitAddRegImmParam(code, dest: X64Register.r8, value: 68)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 1024)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	helperStoreSlot(code, slotIndex: 7, src: X64Register.rax)

	// if slot 7 == 2 → maybe_single_dot else check_double_dot.
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 2)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 8)
	helperEmitJmp(code, state: state, targetBlock: 9)

	// Block 8: maybe_single_dot.
	helperMarkBlock(state, code: code, blockId: 8)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 9: check_double_dot.
	helperMarkBlock(state, code: code, blockId: 9)
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 3)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 10)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 10: maybe_double_dot.
	helperMarkBlock(state, code: code, blockId: 10)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 11)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 11: check_second_dot.
	helperMarkBlock(state, code: code, blockId: 11)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rcx)
	helperLoadByte(code, dest: X64Register.rax, base: X64Register.rcx, disp: 1)
	helperCmpRegImm(code, reg: X64Register.rax, value: 46)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 12)
	helperEmitJmp(code, state: state, targetBlock: 13)

	// Block 12: consume_entry — wrapper[16] = 0; jump to emit_loop.
	helperMarkBlock(state, code: code, blockId: 12)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 13: emit_entry.
	helperMarkBlock(state, code: code, blockId: 13)
	// nameLen = byteCount - 1.
	helperLoadSlot(code, slotIndex: 7, dest: X64Register.rax)
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 10, src: X64Register.rax)
	// reclen = ((nameLen + 20) + 7) & ~7.
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	emitAddRegImmParam(code, dest: X64Register.rax, value: 27)
	helperMovRegImm(code, dest: X64Register.rcx, value: -8)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 8, src: X64Register.rax)

	// if (cursor + reclen > bufSize) → return_partial.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JG (signed) → return_partial.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 14)
	helperEmitJmp(code, state: state, targetBlock: 15)

	// Block 14: return_partial — return cursor.
	helperMarkBlock(state, code: code, blockId: 14)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.r8)
	helperEpilogue(code)

	// Block 15: write_entry.
	helperMarkBlock(state, code: code, blockId: 15)
	// entry = buf + cursor → slot 11.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 11, src: X64Register.rax)

	// entry[0] = 0; entry[8] = 0; entry[16] = reclen.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 8, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)

	// attribute = wrapper[24] & 0xFFFFFFFF.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 24)
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 9, src: X64Register.rax)
	// if (attribute & 0x10) → set_dir_type else set_reg_type.
	helperLoadSlot(code, slotIndex: 9, dest: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0x10)
	emitAndRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperTestReg(code, reg: X64Register.rax)
	helperEmitCondJump(code, state: state, opcode: 0x84, targetBlock: 17)
	helperEmitJmp(code, state: state, targetBlock: 16)

	// Block 16: set_dir_type — entry[18] = 4.
	helperMarkBlock(state, code: code, blockId: 16)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 4)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 18, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 18)

	// Block 17: set_reg_type — entry[18] = 8.
	helperMarkBlock(state, code: code, blockId: 17)
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 8)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 18, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 18)

	// Block 18: copy_name.
	helperMarkBlock(state, code: code, blockId: 18)
	// memcpy(entry+19, scratch, nameLen).
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rdi)
	emitAddRegImmParam(code, dest: X64Register.rdi, value: 19)
	helperLeaStackSlot(code, slotIndex: 267, dest: X64Register.rsi)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rcx)
	// rep movsb.
	code.append(b"\xf3\xa4")

	// entry[19+nameLen] = 0.
	helperLoadSlot(code, slotIndex: 11, dest: X64Register.rcx)
	emitAddRegImmParam(code, dest: X64Register.rcx, value: 19)
	helperLoadSlot(code, slotIndex: 10, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreByteRcx(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)

	// cursor += reclen.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 8, dest: X64Register.rcx)
	emitAddRegRegParam(code, dest: X64Register.rax, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)

	// wrapper[16] = 0.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 16, src: X64Register.rax)

	helperEmitJmp(code, state: state, targetBlock: 1)

	helperFinalize(state, code: code)
end 'emitX64Win32Getdents64'

// =============================================================================
// 13. mrt_win32_get_argc — 0 args, returns argc.
//
// Lazy-initialized cache. First call:
//   1. GetCommandLineW (IAT 12) → LPCWSTR
//   2. CommandLineToArgvW(cmdLine, &argc) (IAT 29) → LPWSTR*; argc in out-param
//   3. Store argc into `__mrt_win32_argc` global.
//   4. mrt_alloc(argc*8) → store into `__mrt_win32_argv_cache_ptr`.
//   5. For i in 0..argc:
//        - wstr = wargv[i]
//        - byteSize = WideCharToMultiByte(CP_UTF8, 0, wstr, -1, NULL, 0, NULL, NULL) (IAT 14)
//        - utf8buf = mrt_alloc(byteSize)
//        - argv_cache_ptr[i*8] = utf8buf
//        - WideCharToMultiByte(CP_UTF8, 0, wstr, -1, utf8buf, byteSize, NULL, NULL) (IAT 14)
//   6. LocalFree(wargv) (IAT 13)
//   7. Set `__mrt_win32_argv_init_done` = 1.
//
// Subsequent calls: short-circuit on the init flag and return cached argc.
//
// Stack:
//   slot 0 = cmdLineW       (LPCWSTR from GetCommandLineW)
//   slot 1 = argc           (out-param for CommandLineToArgvW; also holds final argc)
//   slot 2 = wargv          (LPWSTR* from CommandLineToArgvW)
//   slot 3 = i              (loop index)
//   slot 4 = byteSize       (WideCharToMultiByte query result)
//   slot 5 = utf8buf        (per-iteration UTF-8 buffer pointer)
//   slot 6 = wstr           (current wargv[i] pointer)
//
// Outgoing: WCTMB has 8 args → 32 shadow + 32 stack = 64 bytes.
// Frame: 7 slots * 8 = 56 + 64 outgoing = 120, aligned to 16 = 128.
//
// Block plan:
//   0: entry — check init flag; if set, jump to return_cached.
//   1: do_init — call GetCommandLineW + CommandLineToArgvW + store argc.
//   2: alloc_argv_array — call mrt_alloc(argc*8).
//   3: loop_head — if i >= argc, jump to loop_done.
//   4: loop_body — load wstr, query size, alloc buffer, store in cache, convert.
//   5: loop_done — LocalFree + set init_done.
//   6: return_cached — load argc into r8, epilogue.
// =============================================================================
function emitX64Win32GetArgc(code ByteArray, relocations RelocationArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_argc", offset: helperStart)

	let frameSize = 128
	var state = Win32HelperState.create(7, outgoingBytes: 64, localBytes: 56)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: check init flag.
	helperMarkBlock(state, code: code, blockId: 0)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_init_done")
	helperTestReg(code, reg: X64Register.rax)
	// JNZ → return_cached.
	helperEmitCondJump(code, state: state, opcode: 0x85, targetBlock: 6)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: do_init. Call GetCommandLineW (IAT 12) → rax = LPCWSTR.
	helperMarkBlock(state, code: code, blockId: 1)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getCommandLineW))
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rax)

	// CommandLineToArgvW(cmdLine, &argc) (IAT 29 — shell32 slot). rcx=cmdLine, rdx=&argc.
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperLeaStackSlot(code, slotIndex: 1, dest: X64Register.rdx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.commandLineToArgvW))
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)

	// Store argc to global. CommandLineToArgvW writes a 32-bit int into the
	// out-param; the upper 32 bits of the 8-byte slot are uninitialized stack
	// bytes. Mask via `mov eax, eax` (zero-extends 32 → 64) before storing.
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	code.append(b"\x89\xc0")
	// Re-write the slot so the rest of the helper can use the 8-byte load
	// without masking again.
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rax)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argc")
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: alloc argv array (argc * 8 bytes).
	helperMarkBlock(state, code: code, blockId: 2)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	// r8 = argv array → store as cache_ptr.
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")

	// i = 0.
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: loop head — if i >= argc, jump to loop_done.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JGE (signed greater-or-equal) → loop_done.
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 5)
	helperEmitJmp(code, state: state, targetBlock: 4)

	// Block 4: loop body.
	helperMarkBlock(state, code: code, blockId: 4)
	// wstr = wargv[i] = *(wargv + i*8). Compute address into rcx:
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	// Load *rcx → wstr.
	helperLoadIndirect(code, dest: X64Register.rax, base: X64Register.rcx, disp: 0)
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)

	// Query UTF-8 byte size:
	//   WCTMB(CP_UTF8=65001, 0, wstr, -1, NULL, 0, NULL, NULL)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// Mask the 32-bit return to a clean 64-bit before stashing.
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 4, src: X64Register.rax)

	// Allocate UTF-8 buffer: mrt_alloc(byteSize, 0, 0).
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rcx)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_alloc")
	emitMovRegRegOp(code, dest: X64Register.rax, src: X64Register.r8)
	helperStoreSlot(code, slotIndex: 5, src: X64Register.rax)

	// argv_cache_ptr[i*8] = utf8buf.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	helperStoreIndirect(code, base: X64Register.rcx, disp: 0, src: X64Register.rax)

	// Convert: WCTMB(65001, 0, wstr, -1, utf8buf, byteSize, NULL, NULL).
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLoadSlot(code, slotIndex: 6, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLoadSlot(code, slotIndex: 5, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 4, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))

	// i++.
	helperLoadSlot(code, slotIndex: 3, dest: X64Register.rax)
	emitAddRegImmParam(code, dest: X64Register.rax, value: 1)
	helperStoreSlot(code, slotIndex: 3, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 5: loop_done — LocalFree(wargv) + set init flag.
	helperMarkBlock(state, code: code, blockId: 5)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rcx)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.localFree))
	helperMovRegImm(code, dest: X64Register.rax, value: 1)
	helperStoreGlobal(code, rdataRelocs: rdataRelocs, src: X64Register.rax, name: "__mrt_win32_argv_init_done")
	helperEmitJmp(code, state: state, targetBlock: 6)

	// Block 6: return_cached — load argc, move to r8, epilogue.
	helperMarkBlock(state, code: code, blockId: 6)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.r8, name: "__mrt_win32_argc")
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetArgc'

// =============================================================================
// 14. mrt_win32_get_argv(index) — returns raw UTF-8 C-string pointer for
// argv[index], or 0 if index is out of bounds.
//
// Lazy-init via direct call to `mrt_win32_get_argc` (which performs the
// cache build and ignores its return value here). Then:
//   if (index < 0 || index >= argc) return 0
//   else return *(argv_cache_ptr + index*8)
//
// rcx = index. Returns raw pointer in r8.
//
// Stack:
//   slot 0 = index
// Outgoing: get_argc has 0 args → 32 shadow.
// Frame: 1 slot (8) + 32 outgoing = 40, aligned 16 = 48.
//
// Block plan:
//   0: entry — save index, call get_argc.
//   1: bounds_check — compare index to argc.
//   2: out_of_bounds (-> ret 0)
//   3: in_bounds — load argv_cache_ptr[index*8], return.
// =============================================================================
function emitX64Win32GetArgv(code ByteArray, callFixups CallFixupArray, rdataRelocs RdataRelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_argv", offset: helperStart)

	let frameSize = 48
	var state = Win32HelperState.create(4, outgoingBytes: 32, localBytes: 8)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: save index; call get_argc to ensure cache is built.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperEmitDirectCall(code, callFixups: callFixups, target: "mrt_win32_get_argc")
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: bounds check. Treat negative index as out-of-bounds; argc is
	// non-negative, so a signed `index >= argc` comparison covers both
	// "negative index" and "index >= argc" in one branch (any negative i64
	// is < 0 <= argc, so the JL below catches negatives too).
	helperMarkBlock(state, code: code, blockId: 1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperCmpRegImm(code, reg: X64Register.rax, value: 0)
	// JL → out_of_bounds.
	helperEmitCondJump(code, state: state, opcode: 0x8C, targetBlock: 2)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rcx, name: "__mrt_win32_argc")
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JGE → out_of_bounds.
	helperEmitCondJump(code, state: state, opcode: 0x8D, targetBlock: 2)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 2: out_of_bounds → return 0.
	helperMarkBlock(state, code: code, blockId: 2)
	helperReturnImm(code, value: 0)

	// Block 3: in_bounds — return *(cache_ptr + index*8).
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rcx)
	helperShlRegImm(code, dest: X64Register.rcx, value: 3)
	helperLoadGlobal(code, rdataRelocs: rdataRelocs, dest: X64Register.rax, name: "__mrt_win32_argv_cache_ptr")
	emitAddRegRegParam(code, dest: X64Register.rcx, src: X64Register.rax)
	helperLoadIndirect(code, dest: X64Register.r8, base: X64Register.rcx, disp: 0)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetArgv'

// =============================================================================
// 15. mrt_win32_get_executable_path(buf, bufSize) — writes UTF-8 path of the
// running executable into buf; returns bytes written (excluding NUL) or -34
// (-ERANGE) on truncation.
//
// Algorithm:
//   1. Stack-allocate a 4096-wchar (8192-byte) wide buffer.
//   2. GetModuleFileNameW(NULL, &wbuf, 4096) (IAT 15) → wcharCount.
//   3. WCTMB(CP_UTF8, 0, &wbuf, -1, NULL, 0, NULL, NULL) (IAT 14) → utf8ByteSize
//      (includes trailing NUL).
//   4. If utf8ByteSize > bufSize, return -34.
//   5. WCTMB(CP_UTF8, 0, &wbuf, -1, buf, bufSize, NULL, NULL) → bytes written
//      (including NUL).
//   6. Return bytesWritten - 1 (excluding the NUL).
//
// rcx = buf, rdx = bufSize. Returns count in r8.
//
// Stack:
//   slot 0 = buf
//   slot 1 = bufSize
//   slot 2 = utf8ByteSize (size query result)
//   slots 3..1026 = wide buffer (4096 wchars = 8192 bytes = 1024 slots).
// Outgoing: WCTMB has 8 args → 64 bytes.
// Frame: 3*8 + 8192 wide + 64 outgoing = 8280, aligned 16 = 8288.
//
// Block plan:
//   0: entry — save args.
//   1: get_module — GetModuleFileNameW into wide buf.
//   2: size_query — WCTMB to learn UTF-8 size.
//   3: check_fit — if utf8ByteSize > bufSize → too_big.
//   4: too_big (-> ret -34)
//   5: convert — WCTMB into caller buf; return bytes-1.
// =============================================================================
function emitX64Win32GetExecutablePath(code ByteArray, relocations RelocationArray, funcLabelNames StringArray, funcLabelOffsets CodeOffsetArray, funcLabelOffsetMap CodeLabelOffsetMap)
	let helperStart = code.count()
	recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, labelOffsetMap: funcLabelOffsetMap, name: "mrt_win32_get_executable_path", offset: helperStart)

	// localBytes layout: 3 fixed slots + 1024 wide-buf slots = 1027 * 8 = 8216.
	let frameSize = 8288
	let outgoingBytes = 64
	let localBytes = 8216
	var state = Win32HelperState.create(6, outgoingBytes: outgoingBytes, localBytes: localBytes)

	helperPrologue(code, frameSize: frameSize)

	// Block 0: save args.
	helperMarkBlock(state, code: code, blockId: 0)
	helperStoreSlot(code, slotIndex: 0, src: X64Register.rcx)
	helperStoreSlot(code, slotIndex: 1, src: X64Register.rdx)
	helperEmitJmp(code, state: state, targetBlock: 1)

	// Block 1: GetModuleFileNameW(NULL, &wbuf, 4096).
	helperMarkBlock(state, code: code, blockId: 1)
	helperMovRegImm(code, dest: X64Register.rcx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.rdx)
	helperMovRegImm(code, dest: X64Register.r8, value: 4096)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.getModuleFileNameW))
	// We ignore the wide-char count return; WCTMB with cchWideChar=-1 (NUL-
	// terminated) will measure from the buffer directly.
	helperEmitJmp(code, state: state, targetBlock: 2)

	// Block 2: query UTF-8 byte size (including trailing NUL).
	helperMarkBlock(state, code: code, blockId: 2)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// WCTMB returns a 32-bit int; mask to a clean 64-bit value before the
	// signed compare in block 3.
	code.append(b"\x89\xc0")
	helperStoreSlot(code, slotIndex: 2, src: X64Register.rax)
	helperEmitJmp(code, state: state, targetBlock: 3)

	// Block 3: if utf8ByteSize > bufSize → too_big.
	helperMarkBlock(state, code: code, blockId: 3)
	helperLoadSlot(code, slotIndex: 2, dest: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rcx)
	emitCmpRegRegOp(code, lhs: X64Register.rax, rhs: X64Register.rcx)
	// JG (signed greater) → too_big.
	helperEmitCondJump(code, state: state, opcode: 0x8F, targetBlock: 4)
	helperEmitJmp(code, state: state, targetBlock: 5)

	// Block 4: too_big.
	helperMarkBlock(state, code: code, blockId: 4)
	helperReturnImm(code, value: -34)

	// Block 5: convert into caller buf.
	helperMarkBlock(state, code: code, blockId: 5)
	helperMovRegImm(code, dest: X64Register.rcx, value: 65001)
	helperMovRegImm(code, dest: X64Register.rdx, value: 0)
	helperLeaStackSlot(code, slotIndex: 1026, dest: X64Register.r8)
	helperMovRegImm(code, dest: X64Register.r9, value: -1)
	helperLoadSlot(code, slotIndex: 0, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 32, srcReg: X64Register.rax)
	helperLoadSlot(code, slotIndex: 1, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 40, srcReg: X64Register.rax)
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)
	helperEmitIatCall(code, relocations: relocations, slotIndex: iatSlotIndex(IatSlot.wideCharToMultiByte))
	// WCTMB returns 32-bit; mask to 64-bit clean before subtracting 1.
	code.append(b"\x89\xc0")
	// Return bytes written - 1 (excluding the NUL WCTMB appends).
	emitSubRegImmParam(code, dest: X64Register.rax, value: 1)
	emitMovRegRegOp(code, dest: X64Register.r8, src: X64Register.rax)
	helperEpilogue(code)

	helperFinalize(state, code: code)
end 'emitX64Win32GetExecutablePath'

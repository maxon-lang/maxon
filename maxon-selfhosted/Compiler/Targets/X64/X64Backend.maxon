	helperStoreSlot(code, slotIndex: 21, src: X64Register.rax)  // SI.hStdInput
	helperMovRegImm(code, dest: X64Register.rax, value: 0)
	helperStoreSlot(code, slotIndex: 6, src: X64Register.rax)  // nothing to close

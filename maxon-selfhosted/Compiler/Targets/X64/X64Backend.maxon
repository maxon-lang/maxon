	emitMovRspOffsetReg(code, offset: 48, srcReg: X64Register.rax)  // lpEnvironment = NULL
	emitMovRspOffsetReg(code, offset: 56, srcReg: X64Register.rax)  // lpCurrentDirectory = NULL
	helperLeaStackSlot(code, slotIndex: 31, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 64, srcReg: X64Register.rax)  // lpStartupInfo = &SI
	helperLeaStackSlot(code, slotIndex: 56, dest: X64Register.rax)
	emitMovRspOffsetReg(code, offset: 72, srcReg: X64Register.rax)  // lpProcessInformation = &PI

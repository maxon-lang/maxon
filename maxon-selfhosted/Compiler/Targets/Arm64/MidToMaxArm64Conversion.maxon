// Mid-level dialect -> MaxArm64 dialect conversion.
// Uses the RegisterManager for greedy linear-scan register allocation
// instead of the naive spill-everything-to-stack approach.

// Sentinel matching RegisterManager's RM_NONE
let RM_NONE_ARM64 = -1

export function lowerMidToMaxArm64(module MlirModule, target Target) returns MlirModule
  logDebug(LogCategory.mlir, message: () gives "Lowering Mid to MaxArm64 dialect for {targetToString(target)}")
  var result = createMlirModule()
  let osDesc = makeOsDescriptor(target)

  for srcFunc in module.functions 'eachFunc'
    let funcName = String.from(srcFunc.name)
    let logLowering = not isRuntimeFunction(funcName)
    let dstFunc = lowerFunctionToArm64(srcFunc, osDesc: osDesc, logLowering: logLowering)
    result.functions.push(dstFunc)
  end 'eachFunc'

  return result
end 'lowerMidToMaxArm64'

function lowerFunctionToArm64(srcFunc MlirFunction, osDesc OsDescriptor, logLowering bool) returns MlirFunction
  var dstFunc = createMlirFunction(srcFunc.name, returnType: srcFunc.returnType)
  dstFunc.paramCount = srcFunc.paramCount

  // Phase 1: Compute variable stack space from memref slots.
  // Variable slots use the convention: [x29 - (slotIndex+1)*8]
  let maxParserSlot = computeMaxParserSlotInFunc(srcFunc)
  var varStackSize = 0
  if maxParserSlot >= 0 'hasVarSlots'
    varStackSize = (maxParserSlot + 1) * 8
  end 'hasVarSlots'

  // Also count temp slots needed by SysOps (they still use slot-based addressing)
  var sysOpTempCount = 0
  for srcBlock in srcFunc.region.blocks 'countSysTemps'
    for op in srcBlock.ops 'countOp'
      sysOpTempCount = sysOpTempCount + sysOpTempSlotCountArm64(op)
    end 'countOp'
  end 'countSysTemps'

  // Check for print ops which need stack buffer space
  var hasPrint = false
  for srcBlock in srcFunc.region.blocks 'checkPrint'
    for op in srcBlock.ops 'checkPrintOp'
      if isRuntimeOpArm64(op) 'foundPrint'
        hasPrint = true
      end 'foundPrint'
    end 'checkPrintOp'
  end 'checkPrint'

  // Total variable area includes parser slots + sysop temp slots
  let totalVarSlots = maxParserSlot + 1 + sysOpTempCount
  varStackSize = totalVarSlots * 8

  // Phase 2: Initialize register allocator.
  // ARM64 frame: [x29+0]=saved x29, [x29+8]=saved x30, [x29+16]=slot 0, [x29+24]=slot 1, ...
  // Spill slots start after the variable area at positive offsets from x29.
  let spillBase = 16 + varStackSize
  let gprPool = createArm64GprPool()
  let callerSaved = createArm64CallerSavedGprs()
  var regState = createRegState(spillBase, gprPool: gprPool, callerSavedGprs: callerSaved, target: RegTarget.arm64)

  // We still need ValueSlotMap for SysOp functions that use slot-based addressing
  var nextTempSlot = maxParserSlot + 1
  var valueSlots = ValueSlotMap{}

  // Phase 3: Lower all blocks WITHOUT prologue.
  var isFirstBlock = true
  var entryBlock = MlirBlock{id: 0, label: b"", ops: MlirOpArray{}, terminator: MlirOp.cf(CfOp.br(0)), hasTerminator: false}
  for srcBlock in srcFunc.region.blocks 'eachBlock'
    var dstBlock = addBlock(dstFunc.region, label: srcBlock.label)
    dstBlock.id = srcBlock.id

    if isFirstBlock 'isEntry'
      // Do NOT emit prologue here -- we'll insert it after all lowering.
      // Emit parameter saves: move params from AAPCS64 registers to their stack slots
      // and register them with the register allocator.
      emitParamSavesArm64RA(dstBlock, paramCount: srcFunc.paramCount)
      entryBlock = dstBlock
      isFirstBlock = false
    end 'isEntry' else 'notEntry'
      // Reset register state for new block
      rmResetForBlockTransition(regState, dstBlock: dstBlock)
    end 'notEntry'

    // Lower each op in the block
    for op in srcBlock.ops 'eachOp'
      let opsBefore = dstBlock.ops.count()
      nextTempSlot = lowerMlirOpArm64RA(op, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
      if logLowering 'logOp'
        logTrace(LogCategory.mlir, message: () gives "mid-to-arm64: {formatLoweringResult(sourceOp: op, dstBlock: dstBlock, opsBefore: opsBefore)}")
      end 'logOp'
      rmAdvanceOp(regState)
    end 'eachOp'

    // Lower terminator
    if srcBlock.hasTerminator 'hasTerm'
      let opsBefore = dstBlock.ops.count()
      lowerTerminatorArm64RA(srcBlock, dstBlock: dstBlock, regState: regState)
      if logLowering 'logTerm'
        logTrace(LogCategory.mlir, message: () gives "mid-to-arm64: {formatTerminatorResultWithBlocks(sourceOp: srcBlock.terminator, dstBlock: dstBlock, opsBefore: opsBefore, sourceBlocks: srcFunc.region.blocks, dstBlocks: dstFunc.region.blocks)}")
      end 'logTerm'
    end 'hasTerm'
  end 'eachBlock'

  // Phase 4: Compute final stack size and insert prologue at the front of the entry block.
  // ARM64 prologue does STP which adds 16 bytes for saved x29/x30. The stackSize passed
  // to prologue is the user data area (varStackSize + spillSize). The emitter adds 16.
  // Recompute varStackSize from actual nextTempSlot, since ensureValueInSlotArm64 may
  // have allocated additional temp slots beyond the pre-scanned sysOpTempCount.
  let actualVarStackSize = nextTempSlot * 8
  let spillSize = rmTotalStackSize(regState)
  var totalStackSize = actualVarStackSize + spillSize
  if hasPrint and totalStackSize == 0 'needPrintBuf'
    totalStackSize = 16
  end 'needPrintBuf'
  // Detect if function has calls -- if so, ensure we have a frame
  var hasCalls = false
  for blk in dstFunc.region.blocks 'scanCalls'
    for op in blk.ops 'scanOp'
      if isArm64CallDirectOp(op) 'foundCall'
        hasCalls = true
      end 'foundCall'
    end 'scanOp'
  end 'scanCalls'
  if hasCalls and totalStackSize == 0 'needCallFrame'
    totalStackSize = 16
  end 'needCallFrame'
  // Align to 16
  if totalStackSize mod 16 != 0 'align'
    totalStackSize = totalStackSize + (16 - (totalStackSize mod 16))
  end 'align'

  // Insert prologue at the front of the entry block
  if totalStackSize > 0 'insertPrologue'
    var newOps = MlirOpArray{}
    newOps.push(MlirOp.maxarm64(MaxArm64Op.prologue(totalStackSize)))
    for op in entryBlock.ops 'copyOps'
      newOps.push(op)
    end 'copyOps'
    entryBlock.ops = newOps
  end 'insertPrologue' else 'noPrologue'
    // Remove epilogue ops if no stack frame needed
    removeArm64EpilogueOps(dstFunc)
  end 'noPrologue'

  // Preserve region metadata
  dstFunc.region.nextBlockId = srcFunc.region.nextBlockId
  return dstFunc
end 'lowerFunctionToArm64'

// ============================================================
// Helper utilities
// ============================================================

// Check if an MlirOp is a branchLink (for detecting if function has calls)
function isArm64CallDirectOp(op MlirOp) returns bool
  var result = false
  match op 'check'
    maxhl to sys then break 'check'
    maxx64 then break 'check'
    maxarm64(arm64Op) then result = isArm64BranchLink(arm64Op)
  end 'check'
  return result
end 'isArm64CallDirectOp'

function isArm64BranchLink(op MaxArm64Op) returns bool
  return match op 'check'
    prologue to branch gives false
    branchLink gives true
    printLiteral to reloadFromStack gives false
  end 'check'
end 'isArm64BranchLink'

// Check if an MlirOp is an epilogue
function isArm64EpilogueOp(op MlirOp) returns bool
  var result = false
  match op 'check'
    maxhl to sys then break 'check'
    maxx64 then break 'check'
    maxarm64(arm64Op) then result = isArm64Epilogue(arm64Op)
  end 'check'
  return result
end 'isArm64EpilogueOp'

function isArm64Epilogue(op MaxArm64Op) returns bool
  return match op 'check'
    prologue gives false
    epilogue gives true
    movImm to reloadFromStack gives false
  end 'check'
end 'isArm64Epilogue'

// Remove epilogue ops from all blocks when no stack frame is needed
function removeArm64EpilogueOps(func MlirFunction)
  var bi = 0
  while bi < func.region.blocks.count() 'eachBlock'
    var block = try func.region.blocks.get(bi) otherwise 'err'
      panic("removeArm64EpilogueOps: block index {bi} out of bounds")
    end 'err'
    var newOps = MlirOpArray{}
    for op in block.ops 'eachOp'
      if not isArm64EpilogueOp(op) 'keep'
        newOps.push(op)
      end 'keep'
    end 'eachOp'
    block.ops = newOps
    bi = bi + 1
  end 'eachBlock'
end 'removeArm64EpilogueOps'

// Runtime ops (printLiteral, printInt) need stack buffer space for digit conversion
function isRuntimeOpArm64(op MlirOp) returns bool
  return match op 'check'
    maxhl to memref gives false
    runtime gives true
    sys to maxarm64 gives false
  end 'check'
end 'isRuntimeOpArm64'

// Count temp slots needed by SysOps only (non-sys ops use regalloc now)
function sysOpTempSlotCountArm64(op MlirOp) returns SlotIndex
  return match op 'check'
    maxhl to runtime gives 0
    sys(sysOp) gives sysTempCountArm64(sysOp)
    maxx64 to maxarm64 gives 0
  end 'check'
end 'sysOpTempSlotCountArm64'

function sysTempCountArm64(op SysOp) returns SlotIndex
  return match op 'check'
    syscall gives 1
    iatCall gives 1
    globalAddr gives 1
    stackAddr gives 1
    loadByte gives 1
    storeByte gives 0
    memcpy gives 0
    osExit gives 1
    osWrite gives 6
  end 'check'
end 'sysTempCountArm64'

// ============================================================
// Parameter saves
// ============================================================

// Save AAPCS64 parameter registers to their stack slots AND register with the allocator.
// AAPCS64: x0-x7 for first 8 integer arguments
function emitParamSavesArm64RA(dstBlock MlirBlock, paramCount ParamCount)
  if paramCount == 0 'noParams'
    return
  end 'noParams'

  // Save AAPCS64 register params to their stack slots.
  // Do NOT register with the register allocator — body SSA values start from valueId 0
  // which would conflict with param valueIds. The body's memref.load operations will
  // correctly register values with the allocator when they're needed.
  let regParams = [MaxArm64Register.x0, MaxArm64Register.x1, MaxArm64Register.x2, MaxArm64Register.x3, MaxArm64Register.x4, MaxArm64Register.x5, MaxArm64Register.x6, MaxArm64Register.x7]
  for(regIdx, reg) in regParams.enumerated() 'regParams'
    if regIdx >= paramCount 'done'
      break
    end 'done'
    // Store param to its variable slot
    dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(regIdx, reg)))
  end 'regParams'

  // Params 9+ would be on the stack (not yet supported for ARM64)
  if paramCount > 8 'tooManyParams'
    logError(LogCategory.codegen, message: () gives "ARM64 backend does not yet support more than 8 function parameters (got {paramCount})")
  end 'tooManyParams'
end 'emitParamSavesArm64RA'

// ============================================================
// Op dispatch
// ============================================================

// Lower a single mid-level op using register allocation.
function lowerMlirOpArm64RA(op MlirOp, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
  var result = nextTempSlot
  match op 'dispatch'
    arith(arithOp) then lowerArithOpArm64RA(arithOp, dstBlock: dstBlock, regState: regState)
    memref(memOp) then lowerMemRefOpArm64RA(memOp, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots)
    runtime(rtOp) then lowerRuntimeOpArm64RA(rtOp, dstBlock: dstBlock, regState: regState)
    func(funcOp) then lowerFuncOpArm64RA(funcOp, dstBlock: dstBlock, regState: regState)
    maxarm64(arm64Op) then dstBlock.ops.push(MlirOp.maxarm64(arm64Op))
    sys(sysOp) then result = lowerSysOpWithSpillArm64(sysOp, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
    maxhl then result = nextTempSlot
    cf then result = nextTempSlot
    maxx64 then result = nextTempSlot
  end 'dispatch'
  return result
end 'lowerMlirOpArm64RA'

// ============================================================
// Arith ops - register allocated
// ============================================================

function lowerArithOpArm64RA(op ArithOp, dstBlock MlirBlock, regState RegState)
  match op 'lower'
    const(c) then lowerArithConstArm64RA(c, dstBlock: dstBlock, regState: regState)
    unary(u) then lowerArithUnaryArm64RA(u, dstBlock: dstBlock, regState: regState)
    binary(b) then lowerArithBinaryArm64RA(b, dstBlock: dstBlock, regState: regState)
  end 'lower'
end 'lowerArithOpArm64RA'

function lowerArithConstArm64RA(op ArithConst, dstBlock MlirBlock, regState RegState)
  // Record constant and allocate a register for it
  rmEmitLoadImmediate(regState, valueId: op.resultId, value: op.value, dstBlock: dstBlock)
end 'lowerArithConstArm64RA'

function lowerArithUnaryArm64RA(op ArithUnaryOp, dstBlock MlirBlock, regState RegState)
  // Get operand into a register
  let operandOrd = rmEnsureInRegister(regState, valueId: op.operandId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  // Transfer to result (reuses the register)
  rmTransferValue(regState, oldValueId: op.operandId, regOrdinal: operandOrd, newValueId: op.resultId)
  let reg = ordinalToArm64(operandOrd)
  // Emit the unary operation (ARM64 2-operand: dest, src)
  match op.opcode 'emit'
    negI64 then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.negReg(reg, reg)))
    bitNotI64 then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.mvnReg(reg, reg)))
  end 'emit'
end 'lowerArithUnaryArm64RA'

function lowerArithBinaryArm64RA(op ArithBinaryOp, dstBlock MlirBlock, regState RegState)
  let resultId = op.resultId
  let leftId = op.leftId
  let rightId = op.rightId
  match op.opcode 'lower'
    addI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.add, dstBlock: dstBlock, regState: regState)
    subI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.sub, dstBlock: dstBlock, regState: regState)
    mulI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.mul, dstBlock: dstBlock, regState: regState)
    divI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.div, dstBlock: dstBlock, regState: regState)
    remI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.rem, dstBlock: dstBlock, regState: regState)
    andI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.bitAnd, dstBlock: dstBlock, regState: regState)
    orI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.bitOr, dstBlock: dstBlock, regState: regState)
    xorI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.bitXor, dstBlock: dstBlock, regState: regState)
    shlI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.shl, dstBlock: dstBlock, regState: regState)
    shrI64 then lowerBinaryOpArm64RA(resultId, leftId: leftId, rightId: rightId, opKind: Arm64BinKind.shr, dstBlock: dstBlock, regState: regState)
    cmpI64Eq to cmpF64Ge then lowerCmpOpArm64RA(leftId, rightId: rightId, dstBlock: dstBlock, regState: regState)
  end 'lower'
end 'lowerArithBinaryArm64RA'

// ARM64 binary operation kinds
enum Arm64BinKind
  add
  sub
  mul
  div
  rem
  bitAnd
  bitOr
  bitXor
  shl
  shr
end 'Arm64BinKind'

// Binary op: ensure both operands in registers, transfer LHS to result, emit 3-operand op
function lowerBinaryOpArm64RA(resultId ValueId, leftId ValueId, rightId ValueId, opKind Arm64BinKind, dstBlock MlirBlock, regState RegState)
  let rhsOrd = rmEnsureInRegister(regState, valueId: rightId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  let lhsOrd = rmEnsureInRegister(regState, valueId: leftId, dstBlock: dstBlock, protect1: rhsOrd, protect2: RM_NONE_ARM64)
  // Transfer LHS register to result (LHS register is reused as destination)
  rmTransferValue(regState, oldValueId: leftId, regOrdinal: lhsOrd, newValueId: resultId)
  let resultReg = ordinalToArm64(lhsOrd)
  let rhsReg = ordinalToArm64(rhsOrd)
  // Emit the 3-operand binary instruction: op dest, src1, src2
  match opKind 'emit'
    add then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.addRegs(resultReg, resultReg, rhsReg)))
    sub then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.subRegs(resultReg, resultReg, rhsReg)))
    mul then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.mulRegs(resultReg, resultReg, rhsReg)))
    div then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.sdivRegs(resultReg, resultReg, rhsReg)))
    rem then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.remRegs(resultReg, resultReg, rhsReg)))
    bitAnd then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.andRegs(resultReg, resultReg, rhsReg)))
    bitOr then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.orrRegs(resultReg, resultReg, rhsReg)))
    bitXor then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.eorRegs(resultReg, resultReg, rhsReg)))
    shl then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.lslRegs(resultReg, resultReg, rhsReg)))
    shr then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.asrRegs(resultReg, resultReg, rhsReg)))
  end 'emit'
end 'lowerBinaryOpArm64RA'

// Compare op: ensure both operands in registers, emit cmpRegs.
// No register needed for the result -- flags are consumed by condBr.
function lowerCmpOpArm64RA(leftId ValueId, rightId ValueId, dstBlock MlirBlock, regState RegState)
  let rhsOrd = rmEnsureInRegister(regState, valueId: rightId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  let lhsOrd = rmEnsureInRegister(regState, valueId: leftId, dstBlock: dstBlock, protect1: rhsOrd, protect2: RM_NONE_ARM64)
  let lhsReg = ordinalToArm64(lhsOrd)
  let rhsReg = ordinalToArm64(rhsOrd)
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.cmpRegs(lhsReg, rhsReg)))
end 'lowerCmpOpArm64RA'

// ============================================================
// MemRef ops - register allocated
// ============================================================

function lowerMemRefOpArm64RA(op MemRefOp, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap)
  match op 'lower'
    storeSlot(slotId, valueId) then lowerStoreSlotArm64RA(slotId, valueId: valueId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots)
    loadSlot(resultId, slotId) then lowerLoadSlotArm64RA(resultId, slotId: slotId, regState: regState, valueSlots: valueSlots)
  end 'lower'
end 'lowerMemRefOpArm64RA'

function lowerStoreSlotArm64RA(slotId VarSlot, valueId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap)
  // Ensure the value is in a register
  let valOrd = rmEnsureInRegister(regState, valueId: valueId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  let reg = ordinalToArm64(valOrd)
  // Emit store to the variable's stack slot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(slotId, reg)))
  // Record the stack home for this value
  // ARM64 slots are at positive offsets: [x29 + 16 + slotId * 8]
  let slotOffset = 16 + slotId * 8
  rmNoteStoreToStack(regState, valueId: valueId, stackOffset: slotOffset)
  // Also record in slot map for SysOps
  valueSlotMapSet(valueSlots, valueId: valueId, slot: slotId)
end 'lowerStoreSlotArm64RA'

function lowerLoadSlotArm64RA(resultId ValueId, slotId VarSlot, regState RegState, valueSlots ValueSlotMap)
  // Lazy load: just record that this value lives on the stack.
  // The value will be loaded when rmEnsureInRegister is called.
  // ARM64 slots are at positive offsets: [x29 + 16 + slotId * 8]
  let slotOffset = 16 + slotId * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  // Also record in slot map for SysOps
  valueSlotMapSet(valueSlots, valueId: resultId, slot: slotId)
end 'lowerLoadSlotArm64RA'

// ============================================================
// Runtime ops - register allocated
// ============================================================

function lowerRuntimeOpArm64RA(op RuntimeOp, dstBlock MlirBlock, regState RegState)
  match op 'lower'
    printLiteral(data) then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.printLiteral(data)))
    printInt(valueId) then lowerPrintIntArm64RA(valueId, dstBlock: dstBlock, regState: regState)
  end 'lower'
end 'lowerRuntimeOpArm64RA'

function lowerPrintIntArm64RA(valueId ValueId, dstBlock MlirBlock, regState RegState)
  // printInt expects the value in x0
  let x0Ord = arm64RegToOrdinal(MaxArm64Register.x0)
  let valOrd = rmEnsureInRegister(regState, valueId: valueId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  if valOrd != x0Ord 'moveToX0'
    rmSpillRegisterIfOccupied(regState, regOrdinal: x0Ord, dstBlock: dstBlock)
    let valReg = ordinalToArm64(valOrd)
    dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movRegReg(MaxArm64Register.x0, valReg)))
  end 'moveToX0'
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.printInt))
end 'lowerPrintIntArm64RA'

// ============================================================
// Func ops - register allocated
// ============================================================

function lowerFuncOpArm64RA(op FuncOp, dstBlock MlirBlock, regState RegState)
  match op 'lower'
    call(resultId, callee, argIds) then lowerCallOpArm64RA(resultId, callee: callee, argIds: argIds, dstBlock: dstBlock, regState: regState)
    ret then break 'lower'
  end 'lower'
end 'lowerFuncOpArm64RA'

function lowerCallOpArm64RA(resultId ValueId, callee ByteArray, argIds ValueIdArray, dstBlock MlirBlock, regState RegState)
  let argCount = argIds.count()

  if argCount > 8 'tooManyArgs'
    logError(LogCategory.codegen, message: () gives "ARM64 backend does not yet support more than 8 function arguments (got {argCount})")
  end 'tooManyArgs'

  // Spill all caller-saved registers before the call, then invalidate so that
  // arg loading reloads from stack homes (prevents clobber when moving args to CC regs).
  // Reset nextFreshIndex so allocations start from x0, naturally matching AAPCS64 CC regs.
  rmSpillAllCallerSaved(regState, dstBlock: dstBlock)
  rmInvalidateCallerSaved(regState)
  regState.nextFreshIndex = 0

  // AAPCS64: x0-x7 for first 8 integer arguments
  let callRegs = [MaxArm64Register.x0, MaxArm64Register.x1, MaxArm64Register.x2, MaxArm64Register.x3, MaxArm64Register.x4, MaxArm64Register.x5, MaxArm64Register.x6, MaxArm64Register.x7]

  // Load arguments into their AAPCS64 registers
  var i = 0
  while i < 8 and i < argCount 'loadArgs'
    let argId = try argIds.get(i) otherwise 'skipArg'
      i = i + 1
      continue
    end 'skipArg'
    let argOrd = rmEnsureInRegister(regState, valueId: argId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
    let argReg = ordinalToArm64(argOrd)
    let targetReg = try callRegs.get(i) otherwise MaxArm64Register.x0
    if argReg != targetReg 'needMov'
      dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movRegReg(targetReg, argReg)))
    end 'needMov'
    i = i + 1
  end 'loadArgs'

  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.branchLink(callee)))

  // After call: invalidate all caller-saved registers and assign result to x0
  rmInvalidateCallerSaved(regState)
  let x0Ord = arm64RegToOrdinal(MaxArm64Register.x0)
  rmAssign(regState, regOrdinal: x0Ord, valueId: resultId)
end 'lowerCallOpArm64RA'

// ============================================================
// Terminators - register allocated
// ============================================================

function lowerTerminatorArm64RA(srcBlock MlirBlock, dstBlock MlirBlock, regState RegState)
  match srcBlock.terminator 'dispatch'
    maxhl to arith then break 'dispatch'
    cf(cfOp) then lowerCfTerminatorArm64RA(cfOp, srcBlock: srcBlock, dstBlock: dstBlock, regState: regState)
    func(funcOp) then lowerFuncTerminatorArm64RA(funcOp, dstBlock: dstBlock, regState: regState)
    memref to sys then break 'dispatch'
    maxx64 then break 'dispatch'
    maxarm64(arm64Op) then dstBlock.terminator = MlirOp.maxarm64(arm64Op)
  end 'dispatch'
  dstBlock.hasTerminator = true
end 'lowerTerminatorArm64RA'

function lowerCfTerminatorArm64RA(op CfOp, srcBlock MlirBlock, dstBlock MlirBlock, regState RegState)
  match op 'lower'
    br(target) then dstBlock.terminator = MlirOp.maxarm64(MaxArm64Op.branch(target))
    condBr(condId, thenTarget, elseTarget) then lowerCondBrArm64RA(condId, thenTarget: thenTarget, elseTarget: elseTarget, srcBlock: srcBlock, dstBlock: dstBlock, regState: regState)
  end 'lower'
end 'lowerCfTerminatorArm64RA'

function lowerCondBrArm64RA(condId ValueId, thenTarget BlockId, elseTarget BlockId, srcBlock MlirBlock, dstBlock MlirBlock, regState RegState)
  let jumpKind = determineJumpKindInBlock(srcBlock)
  // Emit inverted conditional branch to else block, then unconditional branch to then block.
  match jumpKind 'emitJump'
    eq then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.ne, elseTarget)))
    ne then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.eq, elseTarget)))
    lt then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.ge, elseTarget)))
    le then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.gt, elseTarget)))
    gt then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.le, elseTarget)))
    ge then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.lt, elseTarget)))
    feq then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.ne, elseTarget)))
    fne then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.eq, elseTarget)))
    flt then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.ge, elseTarget)))
    fle then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.gt, elseTarget)))
    fgt then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.le, elseTarget)))
    fge then dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.lt, elseTarget)))
    boolTest then lowerBoolTestCondBrArm64RA(condId, elseTarget: elseTarget, dstBlock: dstBlock, regState: regState)
  end 'emitJump'
  // Unconditional branch to then block
  dstBlock.terminator = MlirOp.maxarm64(MaxArm64Op.branch(thenTarget))
end 'lowerCondBrArm64RA'

function lowerBoolTestCondBrArm64RA(condId ValueId, elseTarget BlockId, dstBlock MlirBlock, regState RegState)
  let valOrd = rmEnsureInRegister(regState, valueId: condId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  let reg = ordinalToArm64(valOrd)
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.cmpRegZero(reg)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.condBranch(MaxArm64CondCode.eq, elseTarget)))
end 'lowerBoolTestCondBrArm64RA'

function lowerFuncTerminatorArm64RA(op FuncOp, dstBlock MlirBlock, regState RegState)
  match op 'lower'
    ret(retValId) then lowerReturnOpArm64RA(retValId, dstBlock: dstBlock, regState: regState)
    call then break 'lower'
  end 'lower'
end 'lowerFuncTerminatorArm64RA'

function lowerReturnOpArm64RA(retValId ValueId, dstBlock MlirBlock, regState RegState)
  let x0Ord = arm64RegToOrdinal(MaxArm64Register.x0)
  // Ensure the return value is in a register
  let valOrd = rmEnsureInRegister(regState, valueId: retValId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  // Move to x0 if not already there
  if valOrd != x0Ord 'moveToX0'
    let valReg = ordinalToArm64(valOrd)
    dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movRegReg(MaxArm64Register.x0, valReg)))
  end 'moveToX0'
  dstBlock.terminator = MlirOp.maxarm64(MaxArm64Op.epilogue)
end 'lowerReturnOpArm64RA'

// ============================================================
// SysOps - bridge between regalloc and slot-based addressing
// ============================================================

// SysOp code emitters use x0, x1, x2 as scratch. Spill and clear them before
// the SysOp so the RM doesn't lose track of clobbered values.
function lowerSysOpWithSpillArm64(sysOp SysOp, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
  rmSpillRegisterIfOccupied(regState, regOrdinal: arm64RegToOrdinal(MaxArm64Register.x0), dstBlock: dstBlock)
  rmSpillRegisterIfOccupied(regState, regOrdinal: arm64RegToOrdinal(MaxArm64Register.x1), dstBlock: dstBlock)
  rmSpillRegisterIfOccupied(regState, regOrdinal: arm64RegToOrdinal(MaxArm64Register.x2), dstBlock: dstBlock)
  return lowerSysOpArm64RA(sysOp, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
end 'lowerSysOpWithSpillArm64'

// SysOps still use VarSlot-based addressing internally.
// We bridge by ensuring values are spilled to a known slot before the SysOp.
function lowerSysOpArm64RA(op SysOp, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
  match op 'lower'
    syscall(resultId, number, argIds) then return lowerSyscallArm64RA(resultId, number: number, argIds: argIds, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    iatCall(resultId, slotIndex, argIds) then return lowerIatCallArm64RA(resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    globalAddr(resultId, name) then return lowerGlobalAddrArm64RA(resultId, name: name, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    stackAddr(resultId, slotId) then return lowerStackAddrArm64RA(resultId, slotId: slotId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    storeByte(baseId, offsetId, byteId) then return lowerStoreByteArm64RA(baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    loadByte(resultId, baseId, offsetId) then return lowerLoadByteArm64RA(resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    memcpy(dstId, srcId, lenId) then return lowerMemcpyArm64RA(dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
    osExit(codeId) then return lowerOsExitArm64RA(codeId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
    osWrite(ptrId, lenId) then return lowerOsWriteArm64RA(ptrId, lenId: lenId, dstBlock: dstBlock, regState: regState, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
  end 'lower'
end 'lowerSysOpArm64RA'

// Ensure a value has a VarSlot (by spilling to a temp slot if needed).
// Returns the slot index.
function ensureValueInSlotArm64(valueId ValueId, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, dstBlock MlirBlock) returns VarSlot
  // Check if we already have a slot assignment
  if valueSlotMapHas(valueSlots, valueId: valueId) 'hasSlot'
    let existingSlot = valueSlotMapGet(valueSlots, valueId: valueId)
    // Re-store the current value to its existing slot
    let valOrd = rmEnsureInRegister(regState, valueId: valueId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
    let reg = ordinalToArm64(valOrd)
    dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(existingSlot, reg)))
    return existingSlot
  end 'hasSlot'
  // No slot yet -- assign a temp slot and spill
  let valOrd = rmEnsureInRegister(regState, valueId: valueId, dstBlock: dstBlock, protect1: RM_NONE_ARM64, protect2: RM_NONE_ARM64)
  let reg = ordinalToArm64(valOrd)
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(nextTempSlot, reg)))
  valueSlotMapSet(valueSlots, valueId: valueId, slot: nextTempSlot)
  let slotOffset = 16 + nextTempSlot * 8
  rmNoteStoreToStack(regState, valueId: valueId, stackOffset: slotOffset)
  return nextTempSlot
end 'ensureValueInSlotArm64'

function lowerSyscallArm64RA(resultId ValueId, number MachineWord, argIds ValueIdArray, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot
  var argSlots = VarSlotArray{}
  for argId in argIds 'mapArgs'
    let slot = ensureValueInSlotArm64(argId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
    if slot == tempSlot 'usedTemp'
      tempSlot = tempSlot + 1
    end 'usedTemp'
    argSlots.push(slot)
  end 'mapArgs'

  let resultSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.syscall(resultSlot, number, argSlots)))
  valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
  let slotOffset = 16 + resultSlot * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  // Invalidate all caller-saved after syscall
  rmInvalidateCallerSaved(regState)
  return tempSlot + 1
end 'lowerSyscallArm64RA'

function lowerIatCallArm64RA(resultId ValueId, slotIndex MachineWord, argIds ValueIdArray, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot
  var argSlots = VarSlotArray{}
  for argId in argIds 'mapArgs'
    let slot = ensureValueInSlotArm64(argId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
    if slot == tempSlot 'usedTemp'
      tempSlot = tempSlot + 1
    end 'usedTemp'
    argSlots.push(slot)
  end 'mapArgs'

  let resultSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.iatCall(resultSlot, slotIndex, argSlots)))
  valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
  let slotOffset = 16 + resultSlot * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  rmInvalidateCallerSaved(regState)
  return tempSlot + 1
end 'lowerIatCallArm64RA'

function lowerGlobalAddrArm64RA(resultId ValueId, name ByteArray, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  let tempSlot = nextTempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.globalAddr(tempSlot, name)))
  valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
  let slotOffset = 16 + tempSlot * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  return nextTempSlot + 1
end 'lowerGlobalAddrArm64RA'

function lowerStackAddrArm64RA(resultId ValueId, slotId VarSlot, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  let tempSlot = nextTempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.stackAddrOp(tempSlot, slotId)))
  valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
  let slotOffset = 16 + tempSlot * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  return nextTempSlot + 1
end 'lowerStackAddrArm64RA'

function lowerStoreByteArm64RA(baseId ValueId, offsetId ValueId, byteId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot
  let baseSlot = ensureValueInSlotArm64(baseId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if baseSlot == tempSlot 'usedTemp1'
    tempSlot = tempSlot + 1
  end 'usedTemp1'
  let offsetSlot = ensureValueInSlotArm64(offsetId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if offsetSlot == tempSlot 'usedTemp2'
    tempSlot = tempSlot + 1
  end 'usedTemp2'
  let byteSlot = ensureValueInSlotArm64(byteId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if byteSlot == tempSlot 'usedTemp3'
    tempSlot = tempSlot + 1
  end 'usedTemp3'
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.storeByteOp(baseSlot, offsetSlot, byteSlot)))
  return tempSlot
end 'lowerStoreByteArm64RA'

function lowerLoadByteArm64RA(resultId ValueId, baseId ValueId, offsetId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot
  let baseSlot = ensureValueInSlotArm64(baseId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if baseSlot == tempSlot 'usedTemp1'
    tempSlot = tempSlot + 1
  end 'usedTemp1'
  let offsetSlot = ensureValueInSlotArm64(offsetId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if offsetSlot == tempSlot 'usedTemp2'
    tempSlot = tempSlot + 1
  end 'usedTemp2'
  let resultSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.loadByteOp(resultSlot, baseSlot, offsetSlot)))
  valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
  let slotOffset = 16 + resultSlot * 8
  rmNoteValueOnStack(regState, valueId: resultId, stackOffset: slotOffset)
  return tempSlot + 1
end 'lowerLoadByteArm64RA'

function lowerMemcpyArm64RA(dstId ValueId, srcId ValueId, lenId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot
  let dstSlot = ensureValueInSlotArm64(dstId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if dstSlot == tempSlot 'usedTemp1'
    tempSlot = tempSlot + 1
  end 'usedTemp1'
  let srcSlot = ensureValueInSlotArm64(srcId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if srcSlot == tempSlot 'usedTemp2'
    tempSlot = tempSlot + 1
  end 'usedTemp2'
  let lenSlot = ensureValueInSlotArm64(lenId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if lenSlot == tempSlot 'usedTemp3'
    tempSlot = tempSlot + 1
  end 'usedTemp3'
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.memcpyOp(dstSlot, srcSlot, lenSlot)))
  return tempSlot
end 'lowerMemcpyArm64RA'

// OS-neutral exit: expand to syscall or iatCall based on OsDescriptor.
function lowerOsExitArm64RA(codeId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
  var tempSlot = nextTempSlot
  let codeSlot = ensureValueInSlotArm64(codeId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if codeSlot == tempSlot 'usedTemp'
    tempSlot = tempSlot + 1
  end 'usedTemp'
  match osDesc.exit 'strategy'
    syscall(num) then return lowerOsExitSyscallArm64RA(codeSlot, num: num, dstBlock: dstBlock, nextTempSlot: tempSlot)
    iatCall(slotIdx) then return lowerOsExitIatArm64RA(codeSlot, slotIdx: slotIdx, dstBlock: dstBlock, nextTempSlot: tempSlot)
  end 'strategy'
end 'lowerOsExitArm64RA'

function lowerOsExitSyscallArm64RA(codeSlot VarSlot, num MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
  var argSlots = VarSlotArray{}
  argSlots.push(codeSlot)
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.syscall(nextTempSlot, num, argSlots)))
  return nextTempSlot + 1
end 'lowerOsExitSyscallArm64RA'

function lowerOsExitIatArm64RA(codeSlot VarSlot, slotIdx MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
  var argSlots = VarSlotArray{}
  argSlots.push(codeSlot)
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.iatCall(nextTempSlot, slotIdx, argSlots)))
  return nextTempSlot + 1
end 'lowerOsExitIatArm64RA'

// OS-neutral write: expand to syscall or WinAPI or libcall based on OsDescriptor.
function lowerOsWriteArm64RA(ptrId ValueId, lenId ValueId, dstBlock MlirBlock, regState RegState, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
  var tempSlot = nextTempSlot
  let ptrSlot = ensureValueInSlotArm64(ptrId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if ptrSlot == tempSlot 'usedTemp1'
    tempSlot = tempSlot + 1
  end 'usedTemp1'
  let lenSlot = ensureValueInSlotArm64(lenId, regState: regState, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
  if lenSlot == tempSlot 'usedTemp2'
    tempSlot = tempSlot + 1
  end 'usedTemp2'
  match osDesc.write 'strategy'
    syscall(writeNum, fd) then return lowerOsWriteSyscallArm64RA(ptrSlot, lenSlot: lenSlot, writeNum: writeNum, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
    winApi(getHandleSlot, handleConstant, writeFileSlot) then return lowerOsWriteWinApiArm64RA(ptrSlot, lenSlot: lenSlot, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot, dstBlock: dstBlock, nextTempSlot: tempSlot)
    libcall(writeSlot, fd) then return lowerOsWriteLibcallArm64RA(ptrSlot, lenSlot: lenSlot, writeSlot: writeSlot, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
  end 'strategy'
end 'lowerOsWriteArm64RA'

function lowerOsWriteSyscallArm64RA(ptrSlot VarSlot, lenSlot VarSlot, writeNum MachineWord, fd MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
  // fd constant -> temp slot
  let fdSlot = nextTempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(MaxArm64Register.x0, fd)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(fdSlot, MaxArm64Register.x0)))
  // syscall(writeNum, fd, ptr, len)
  var argSlots = VarSlotArray{}
  argSlots.push(fdSlot)
  argSlots.push(ptrSlot)
  argSlots.push(lenSlot)
  let resultSlot = nextTempSlot + 1
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.syscall(resultSlot, writeNum, argSlots)))
  return nextTempSlot + 2
end 'lowerOsWriteSyscallArm64RA'

function lowerOsWriteWinApiArm64RA(ptrSlot VarSlot, lenSlot VarSlot, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
  var tempSlot = nextTempSlot

  // GetStdHandle(handleConstant)
  let handleConstSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(MaxArm64Register.x0, handleConstant)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(handleConstSlot, MaxArm64Register.x0)))
  tempSlot = tempSlot + 1
  var getHandleArgs = VarSlotArray{}
  getHandleArgs.push(handleConstSlot)
  let handleResultSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.iatCall(handleResultSlot, getHandleSlot, getHandleArgs)))
  tempSlot = tempSlot + 1

  // bytesWritten = 0 stored to a slot
  let writtenSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(MaxArm64Register.x0, 0)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(writtenSlot, MaxArm64Register.x0)))
  tempSlot = tempSlot + 1

  // Get address of bytesWritten slot
  let writtenAddrSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.stackAddrOp(writtenAddrSlot, writtenSlot)))
  tempSlot = tempSlot + 1

  // NULL for lpOverlapped
  let nullSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(MaxArm64Register.x0, 0)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(nullSlot, MaxArm64Register.x0)))
  tempSlot = tempSlot + 1

  // WriteFile(handle, ptr, len, &bytesWritten, NULL)
  var writeArgs = VarSlotArray{}
  writeArgs.push(handleResultSlot)
  writeArgs.push(ptrSlot)
  writeArgs.push(lenSlot)
  writeArgs.push(writtenAddrSlot)
  writeArgs.push(nullSlot)
  let writeResultSlot = tempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.iatCall(writeResultSlot, writeFileSlot, writeArgs)))
  tempSlot = tempSlot + 1

  return tempSlot
end 'lowerOsWriteWinApiArm64RA'

// OS write via libcall: write(fd, buf, len) through GOT/IAT slot.
// Used for macOS (libSystem.B.dylib).
function lowerOsWriteLibcallArm64RA(ptrSlot VarSlot, lenSlot VarSlot, writeSlot MachineWord, fd MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
  // fd constant -> temp slot
  let fdSlot = nextTempSlot
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(MaxArm64Register.x0, fd)))
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(fdSlot, MaxArm64Register.x0)))
  // iatCall write(fd, ptr, len)
  var argSlots = VarSlotArray{}
  argSlots.push(fdSlot)
  argSlots.push(ptrSlot)
  argSlots.push(lenSlot)
  let resultSlot = nextTempSlot + 1
  dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.iatCall(resultSlot, writeSlot, argSlots)))
  return nextTempSlot + 2
end 'lowerOsWriteLibcallArm64RA'

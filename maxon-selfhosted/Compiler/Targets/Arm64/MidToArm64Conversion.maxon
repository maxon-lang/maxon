// Mid dialect -> Arm64 dialect conversion.
// Pure instruction selection: emits virtual registers (Arm64VReg.virtual) only.
// Register allocation, prologue/epilogue, and stack frame sizing are handled
// by standalone passes that run after this one.

export function lowerMidToArm64(module MlirModule, target Target, globalData GlobalDataTable) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Lowering Mid to Arm64 dialect")
	let result = createMlirModule()

	let osDesc = makeOsDescriptor(target)

	for srcFunc in module.functions 'eachFunc'
		let funcName = srcFunc.name
		logTrace(LogCategory.mlir, message: () gives "mid-to-arm64: === lowering function: {funcName} ===")
		let dstFunc = lowerFunctionToArm64(srcFunc, osDesc: osDesc, allFunctions: module.functions, globalData: globalData)
		result.functions.push(dstFunc)
	end 'eachFunc'

	return result
end 'lowerMidToArm64'

function lowerFunctionToArm64(srcFunc MlirFunction, osDesc OsDescriptor, allFunctions MlirFunctionArray, globalData GlobalDataTable) returns MlirFunction
	var dstFunc = cloneFunctionShell(srcFunc)

	// Phase 1: Compute variable stack space from memref slots.
	let loadedSlots = scanLoadedSlotsArm64(srcFunc)
	var liveSlotCount = 0
	for slot in loadedSlots 'countLive'
		if slot + 1 > liveSlotCount 'updateMax'
			liveSlotCount = slot + 1
		end 'updateMax'
	end 'countLive'

	// Count temp slots needed by SysOps (they still use slot-based addressing).
	// Skip diverging blocks (panic paths) since their slots are dead.
	var sysOpTempCount = 0
	for srcBlock in srcFunc.blocks 'countSysTemps'
		if isMirDivergingBlock(srcBlock) 'skipDiverging'
			continue
		end 'skipDiverging'
		for op in srcBlock.ops 'countOp'
			sysOpTempCount = sysOpTempCount + sysOpTempSlotCountArm64(op)
		end 'countOp'
	end 'countSysTemps'

	// Block arguments are passed via virtual register moves (movRegReg),
	// not stack slots. The register allocator resolves these via SSA coloring
	// and parallel copy sequentialization.

	// Pre-compute an initial slot count estimate
	let precomputedSlotCount = liveSlotCount + sysOpTempCount

	// Temp slot allocator for SysOps
	var nextTempSlot = liveSlotCount

	// Value-to-slot map for SysOps that need slot-based addressing
	let valueSlots = ValueSlotMap.create()

	// Phase 2: Lower all blocks.
	for srcBlock in srcFunc.blocks 'eachBlock'
		var dstBlock = addBlock(dstFunc, label: srcBlock.label)
		dstBlock.id = srcBlock.id

		// Block arguments are defined by movRegReg ops emitted at predecessors.
		// No ldrFromSlot needed at block entry.

		// Lower each op in the block
		for op in srcBlock.ops 'eachOp'
			nextTempSlot = lowerMlirOpArm64(op, dstBlock: dstBlock, osDesc: osDesc, allFunctions: allFunctions, valueSlots: valueSlots, nextTempSlot: nextTempSlot, globalData: globalData, funcParamTypes: srcFunc.paramTypes)
		end 'eachOp'

		// Lower terminator
		if srcBlock.hasTerminator 'hasTerm'
			lowerTerminatorArm64(srcBlock, dstBlock: dstBlock, returnType: srcFunc.returnType)
			// Set the last emitted op as the block terminator so that the register
			// allocator can distinguish it from regular ops.
			setLastOpAsTerminatorArm64(dstBlock)
		end 'hasTerm'
	end 'eachBlock'

	// Remove unconditional branches that fall through to the next block.
	eliminateFallthroughJumps(dstFunc)

	// Record the actual total slot count after lowering.
	let actualSlotCount = nextTempSlot
	if actualSlotCount > precomputedSlotCount 'useActual'
		dstFunc.varSlotCount = actualSlotCount
	end 'useActual' else 'usePrecomputed'
		dstFunc.varSlotCount = precomputedSlotCount
	end 'usePrecomputed'

	// Preserve region metadata
	dstFunc.nextBlockId = srcFunc.nextBlockId
	return dstFunc
end 'lowerFunctionToArm64'

// ============================================================
// Slot scanning helpers
// ============================================================

// Scan which variable slots are read by memref.load ops.
function scanLoadedSlotsArm64(func MlirFunction) returns VarSlotArray
	let loaded = VarSlotArray.create()
	for block in func.blocks 'eachBlock'
		for op in block.ops 'eachOp'
			match op 'check'
				memref(memOp) then match memOp 'checkMem'
					loadSlot(_, slotId) then loaded.push(slotId)
					storeSlot then break 'checkMem'
				end 'checkMem'
				mir(mirOp) then match mirOp 'checkMir'
					stackSlotAddr(_, slotId) then loaded.push(slotId)
					movImm to store then break 'checkMir'
					globalAddr to loadByte then break 'checkMir'
				end 'checkMir'
				maxon to func then break 'check'
				runtime to sys then break 'check'
				x64 to arm64 then break 'check'
			end 'check'
		end 'eachOp'
	end 'eachBlock'
	return loaded
end 'scanLoadedSlotsArm64'

// Count temp slots needed by SysOps and MIR system ops
function sysOpTempSlotCountArm64(op MlirOp) returns SlotIndex
	return match op 'check'
		maxon to runtime gives 0
		sys(sysOp) gives sysTempCountArm64(sysOp)
		mir(mirOp) gives mirTempCountArm64(mirOp)
		x64 to arm64 gives 0
	end 'check'
end 'sysOpTempSlotCountArm64'

function sysTempCountArm64(op SysOp) returns SlotIndex
	return match op 'check'
		syscall gives 1
		iatCall gives 1
		globalAddr gives 1
		stackAddr gives 1
		loadByte gives 3
		storeByte gives 3
		memcpy gives 3
		osExit gives 1
		osWrite gives 6
		free gives 1
		osWriteErr gives 6
		loadFramePtr gives 1
		loadIndirect gives 2
		funcAddr gives 1
		storeIndirect gives 2
	end 'check'
end 'sysTempCountArm64'

function mirTempCountArm64(op MirOp) returns SlotIndex
	return match op 'check'
		syscall gives 1
		iatCall gives 1
		globalAddr gives 1
		stackSlotAddr gives 1
		storeByte gives 3
		loadByte gives 3
		memcpy gives 3
		osExit gives 1
		osWrite gives 6
		movImm to store gives 0
	end 'check'
end 'mirTempCountArm64'

// Pop the last op from the block and set it as the terminator.
function setLastOpAsTerminatorArm64(block MlirBlock)
	let termOp = try block.ops.pop() otherwise 'noOps'
		return
	end 'noOps'
	block.terminator = termOp
	block.hasTerminator = true
end 'setLastOpAsTerminatorArm64'

// ============================================================
// Op dispatch
// ============================================================

function lowerMlirOpArm64(op MlirOp, dstBlock MlirBlock, osDesc OsDescriptor, allFunctions MlirFunctionArray, valueSlots ValueSlotMap, nextTempSlot SlotIndex, globalData GlobalDataTable, funcParamTypes StdTypeArray) returns SlotIndex
	var result = nextTempSlot
	match op 'dispatch'
		mir(mirOp) then result = lowerMirOpArm64(mirOp, dstBlock: dstBlock, osDesc: osDesc, allFunctions: allFunctions, valueSlots: valueSlots, nextTempSlot: nextTempSlot, globalData: globalData, funcParamTypes: funcParamTypes)
		memref(memOp) then lowerMemRefOpArm64(memOp, dstBlock: dstBlock)
		runtime(rtOp) then lowerRuntimeOpArm64(rtOp, dstBlock: dstBlock)
		arm64(arm64Op) then dstBlock.ops.push(MlirOp.arm64(arm64Op))
		maxon to arith then break 'dispatch'
		cf then break 'dispatch'
		func then break 'dispatch'
		sys(sysOp) then result = lowerSysOpArm64(sysOp, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		x64 then break 'dispatch'
	end 'dispatch'
	return result
end 'lowerMlirOpArm64'

// ============================================================
// MIR op lowering — pure virtual register emission
// ============================================================

function lowerMirOpArm64(op MirOp, dstBlock MlirBlock, osDesc OsDescriptor, allFunctions MlirFunctionArray, valueSlots ValueSlotMap, nextTempSlot SlotIndex, globalData GlobalDataTable, funcParamTypes StdTypeArray) returns SlotIndex
	var result = nextTempSlot
	match op 'dispatch'
		movImm(resultId, value, isFloat) then lowerMovImmArm64(resultId, value: value, isFloat: isFloat, dstBlock: dstBlock, globalData: globalData)
		movReg(resultId, srcId) then lowerMovRegArm64(resultId, srcId: srcId, dstBlock: dstBlock)
		binOp(resultId, leftId, rightId, opcode) then lowerBinOpArm64(resultId, leftId: leftId, rightId: rightId, opcode: opcode, dstBlock: dstBlock)
		unaryOp(resultId, operandId, opcode) then lowerUnaryOpArm64(resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		cmp(resultId, leftId, rightId, predicate) then lowerCmpArm64(resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
		condBranch then result = nextTempSlot  // handled as terminator
		branch then result = nextTempSlot  // handled as terminator
		call(resultId, callee, argIds) then lowerCallArm64(resultId, callee: callee, argIds: argIds, dstBlock: dstBlock, allFunctions: allFunctions)
		indirectCall(resultId, calleeId, argIds) then lowerIndirectCallArm64(resultId, calleeId: calleeId, argIds: argIds, dstBlock: dstBlock)
		ret then result = nextTempSlot  // handled as terminator
		param(resultId, paramIndex, paramType) then lowerParamArm64(resultId, paramIndex: paramIndex, paramType: paramType, dstBlock: dstBlock, funcParamTypes: funcParamTypes)
		load(resultId, baseId, offset) then lowerLoadArm64(resultId, baseId: baseId, offset: offset, dstBlock: dstBlock)
		store(valueId, baseId, offset) then lowerStoreArm64(valueId, baseId: baseId, offset: offset, dstBlock: dstBlock)
		stackSlotAddr to loadByte then result = lowerMirSysOpArm64(op, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
	end 'dispatch'
	return result
end 'lowerMirOpArm64'

// ============================================================
// Constants & moves
// ============================================================

function lowerMovImmArm64(resultId ValueId, value ParsedInt, isFloat bool, dstBlock MlirBlock, globalData GlobalDataTable)
	if isFloat 'floatImm'
		lowerFloatConstArm64(resultId, rawBits: value, dstBlock: dstBlock, globalData: globalData)
	end 'floatImm' else 'intImm'
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(Arm64VReg.virtual(resultId), value: value)))
	end 'intImm'
end 'lowerMovImmArm64'

// Float constant: load directly into FP register via literal pool data island.
function lowerFloatConstArm64(resultId ValueId, rawBits ParsedInt, dstBlock MlirBlock, globalData GlobalDataTable)
	let label = registerFloatConstant(rawBits, globalData: globalData)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.fpLoadRdata(Arm64FpVReg.virtual(resultId), rdataLabel: label, precision: FloatPrecision.f64)))
end 'lowerFloatConstArm64'

function lowerMovRegArm64(resultId ValueId, srcId ValueId, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: Arm64VReg.virtual(srcId))))
end 'lowerMovRegArm64'

// ============================================================
// Binary operations
// ============================================================

function lowerBinOpArm64(resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode, dstBlock MlirBlock)
	match opcode 'lower'
		addI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.add, dstBlock: dstBlock)
		subI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.sub, dstBlock: dstBlock)
		mulI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.mul, dstBlock: dstBlock)
		divI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.div, dstBlock: dstBlock)
		remI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.rem, dstBlock: dstBlock)
		andI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitAnd, dstBlock: dstBlock)
		orI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitOr, dstBlock: dstBlock)
		xorI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitXor, dstBlock: dstBlock)
		shlI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.shl, dstBlock: dstBlock)
		shrI64 then lowerIntBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.shr, dstBlock: dstBlock)
		addF64 then lowerFloatBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.add, dstBlock: dstBlock)
		subF64 then lowerFloatBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.sub, dstBlock: dstBlock)
		mulF64 then lowerFloatBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.mul, dstBlock: dstBlock)
		divF64 then lowerFloatBinOpArm64(resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.div, dstBlock: dstBlock)
	end 'lower'
end 'lowerBinOpArm64'

// ARM64 binary operation kinds
enum Arm64BinKind
	add
	sub
	mul
	div
	rem
	bitAnd
	bitOr
	bitXor
	shl
	shr
end 'Arm64BinKind'

// ARM64 has 3-operand form: dest = src1 OP src2 (non-destructive).
function lowerIntBinOpArm64(resultId ValueId, leftId ValueId, rightId ValueId, kind Arm64BinKind, dstBlock MlirBlock)
	let dest = Arm64VReg.virtual(resultId)
	let lhs = Arm64VReg.virtual(leftId)
	let rhs = Arm64VReg.virtual(rightId)
	match kind 'emit'
		add then dstBlock.ops.push(MlirOp.arm64(Arm64Op.addRegs(dest, src1: lhs, src2: rhs)))
		sub then dstBlock.ops.push(MlirOp.arm64(Arm64Op.subRegs(dest, src1: lhs, src2: rhs)))
		mul then dstBlock.ops.push(MlirOp.arm64(Arm64Op.mulRegs(dest, src1: lhs, src2: rhs)))
		div then dstBlock.ops.push(MlirOp.arm64(Arm64Op.sdivRegs(dest, src1: lhs, src2: rhs)))
		rem then dstBlock.ops.push(MlirOp.arm64(Arm64Op.remRegs(dest, src1: lhs, src2: rhs)))
		bitAnd then dstBlock.ops.push(MlirOp.arm64(Arm64Op.andRegs(dest, src1: lhs, src2: rhs)))
		bitOr then dstBlock.ops.push(MlirOp.arm64(Arm64Op.orrRegs(dest, src1: lhs, src2: rhs)))
		bitXor then dstBlock.ops.push(MlirOp.arm64(Arm64Op.eorRegs(dest, src1: lhs, src2: rhs)))
		shl then dstBlock.ops.push(MlirOp.arm64(Arm64Op.lslRegs(dest, src1: lhs, src2: rhs)))
		shr then dstBlock.ops.push(MlirOp.arm64(Arm64Op.lsrRegs(dest, src1: lhs, src2: rhs)))
	end 'emit'
end 'lowerIntBinOpArm64'

// Float binary operation kinds
enum Arm64FloatBinKind
	add
	sub
	mul
	div
end 'Arm64FloatBinKind'

// Float binary op: both operands as FP virtuals, result in FP virtual.
// ARM64 FP ops are 3-operand non-destructive.
function lowerFloatBinOpArm64(resultId ValueId, leftId ValueId, rightId ValueId, kind Arm64FloatBinKind, dstBlock MlirBlock)
	let dest = Arm64FpVReg.virtual(resultId)
	let lhs = Arm64FpVReg.virtual(leftId)
	let rhs = Arm64FpVReg.virtual(rightId)
	match kind 'emit'
		add then dstBlock.ops.push(MlirOp.arm64(Arm64Op.fadd(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64)))
		sub then dstBlock.ops.push(MlirOp.arm64(Arm64Op.fsub(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64)))
		mul then dstBlock.ops.push(MlirOp.arm64(Arm64Op.fmul(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64)))
		div then dstBlock.ops.push(MlirOp.arm64(Arm64Op.fdiv(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64)))
	end 'emit'
end 'lowerFloatBinOpArm64'

// ============================================================
// Unary operations
// ============================================================

function lowerUnaryOpArm64(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock MlirBlock)
	match opcode 'lower'
		negI64 then lowerIntUnaryArm64(resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		bitNotI64 then lowerIntUnaryArm64(resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		fpToSiI64 then lowerFpToSiArm64(resultId, operandId: operandId, dstBlock: dstBlock)
		siToFpF64 then lowerSiToFpArm64(resultId, operandId: operandId, dstBlock: dstBlock)
	end 'lower'
end 'lowerUnaryOpArm64'

// ARM64 unary: 2-operand form dest = OP src
function lowerIntUnaryArm64(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock MlirBlock)
	let dest = Arm64VReg.virtual(resultId)
	let src = Arm64VReg.virtual(operandId)
	match opcode 'emit'
		negI64 then dstBlock.ops.push(MlirOp.arm64(Arm64Op.negReg(dest, src: src)))
		bitNotI64 then dstBlock.ops.push(MlirOp.arm64(Arm64Op.mvnReg(dest, src: src)))
		fpToSiI64 to siToFpF64 then panic("lowerIntUnaryArm64: unexpected float opcode")
	end 'emit'
end 'lowerIntUnaryArm64'

// Float-to-integer truncation: fcvtzs
function lowerFpToSiArm64(resultId ValueId, operandId ValueId, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.fcvtzs(Arm64VReg.virtual(resultId), src: Arm64FpVReg.virtual(operandId), precision: FloatPrecision.f64)))
end 'lowerFpToSiArm64'

// Integer-to-float conversion: scvtf
function lowerSiToFpArm64(resultId ValueId, operandId ValueId, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.scvtf(Arm64FpVReg.virtual(resultId), src: Arm64VReg.virtual(operandId), precision: FloatPrecision.f64)))
end 'lowerSiToFpArm64'

// ============================================================
// Compare
// ============================================================

function lowerCmpArm64(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock MlirBlock)
	match predicate 'kind'
		eq to ugt then lowerIntCmpArm64(resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
		feq to fge then lowerFloatCmpArm64(resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
	end 'kind'
end 'lowerCmpArm64'

function lowerIntCmpArm64(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.cmpRegs(Arm64VReg.virtual(leftId), src2: Arm64VReg.virtual(rightId))))
	let condCode = mirPredicateToArm64CondCode(predicate)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.cset(Arm64VReg.virtual(resultId), condition: condCode)))
end 'lowerIntCmpArm64'

function lowerFloatCmpArm64(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.fcmp(Arm64FpVReg.virtual(leftId), src2: Arm64FpVReg.virtual(rightId), precision: FloatPrecision.f64)))
	let condCode = mirPredicateToArm64CondCode(predicate)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.cset(Arm64VReg.virtual(resultId), condition: condCode)))
end 'lowerFloatCmpArm64'

function mirPredicateToArm64CondCode(predicate MirCmpPredicate) returns Arm64CondCode
	return match predicate 'map'
		eq gives Arm64CondCode.eq
		ne gives Arm64CondCode.ne
		lt gives Arm64CondCode.lt
		le gives Arm64CondCode.le
		gt gives Arm64CondCode.gt
		ge gives Arm64CondCode.ge
		ugt gives Arm64CondCode.hi
		feq gives Arm64CondCode.eq
		fne gives Arm64CondCode.ne
		flt gives Arm64CondCode.lt
		fle gives Arm64CondCode.le
		fgt gives Arm64CondCode.gt
		fge gives Arm64CondCode.ge
	end 'map'
end 'mirPredicateToArm64CondCode'

// ============================================================
// Call
// ============================================================

// Internal calling convention: GPR args in x0-x7, FP args in d0-d7.
// GPR and FP use separate index counters.
function getArm64CallConvGpr(index VarSlot) returns Arm64Register
	let regs = [Arm64Register.x0, Arm64Register.x1, Arm64Register.x2, Arm64Register.x3, Arm64Register.x4, Arm64Register.x5, Arm64Register.x6, Arm64Register.x7]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getArm64CallConvGpr: param index {index} exceeds register count")
	end 'outOfRange'
end 'getArm64CallConvGpr'

function getArm64CallConvFp(index VarSlot) returns Arm64FloatRegister
	let regs = [Arm64FloatRegister.d0, Arm64FloatRegister.d1, Arm64FloatRegister.d2, Arm64FloatRegister.d3, Arm64FloatRegister.d4, Arm64FloatRegister.d5, Arm64FloatRegister.d6, Arm64FloatRegister.d7]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getArm64CallConvFp: FP param index {index} exceeds register count")
	end 'outOfRange'
end 'getArm64CallConvFp'


function lowerCallArm64(resultId ValueId, callee String, argIds ValueIdArray, dstBlock MlirBlock, allFunctions MlirFunctionArray)
	// Look up callee's param types to route float args to D registers
	let paramTypes = lookupFuncParamTypes(callee, allFunctions: allFunctions)

	// Move args to calling convention registers with separate GPR/FP counters
	var argIdx = 0
	var gprIdx = 0
	var fpIdx = 0
	while argIdx < argIds.count() 'moveArgs'
		let argId = try argIds.get(argIdx) otherwise 'skipArg'
			argIdx = argIdx + 1
			continue
		end 'skipArg'
		let paramType = try paramTypes.get(argIdx) otherwise StdType.i64
		match paramType 'routeArg'
			f64 then if fpIdx < 8 'fpRegArg'
			let fpReg = getArm64CallConvFp(fpIdx)
			dstBlock.ops.push(MlirOp.arm64(Arm64Op.fmovRegReg(arm64PhysFpReg(fpReg), src: Arm64FpVReg.virtual(argId), precision: FloatPrecision.f64)))
			fpIdx = fpIdx + 1
		end 'fpRegArg'
		i64 then if gprIdx < 8 'gprRegArg'
			let ccReg = getArm64CallConvGpr(gprIdx)
			dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(arm64PhysReg(ccReg), src: Arm64VReg.virtual(argId))))
			gprIdx = gprIdx + 1
		end 'gprRegArg'
	end 'routeArg'
	argIdx = argIdx + 1
	end 'moveArgs'

	// Emit the call
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.branchLink(callee)))

	// Move return value from X0/D0 to virtual result
	let calleeReturnType = lookupFuncReturnTypeArm64(callee, allFunctions: allFunctions)
	if calleeReturnType == "f64" 'floatResult'
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.fmovRegReg(Arm64FpVReg.virtual(resultId), src: arm64PhysFpReg(Arm64FloatRegister.d0), precision: FloatPrecision.f64)))
	end 'floatResult' else 'intResult'
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x0))))
	end 'intResult'
end 'lowerCallArm64'

function lowerIndirectCallArm64(resultId ValueId, calleeId ValueId, argIds ValueIdArray, dstBlock MlirBlock)
	// Move args to calling convention registers
	var argIdx = 0
	while argIdx < argIds.count() and argIdx < 8 'moveArgs'
		let argId = try argIds.get(argIdx) otherwise 'skipArg'
			argIdx = argIdx + 1
			continue
		end 'skipArg'
		let ccReg = getArm64CallConvGpr(argIdx)
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(arm64PhysReg(ccReg), src: Arm64VReg.virtual(argId))))
		argIdx = argIdx + 1
	end 'moveArgs'
	if argIds.count() > 8 'tooManyArgs'
		panic("lowerIndirectCallArm64: more than 8 arguments not yet supported (got {argIds.count()})")
	end 'tooManyArgs'

	// Indirect call through the callee virtual register
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.branchLinkReg(Arm64VReg.virtual(calleeId))))

	// Move return value from X0
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x0))))
end 'lowerIndirectCallArm64'

function lookupFuncReturnTypeArm64(callee String, allFunctions MlirFunctionArray) returns String
	for func in allFunctions 'search'
		if func.name == callee 'found'
			return func.returnType
		end 'found'
	end 'search'
	panic("lookupFuncReturnTypeArm64: callee not found — compiler bug")
end 'lookupFuncReturnTypeArm64'

// ============================================================
// Param
// ============================================================

// Move from calling convention register to virtual register.
// Float params arrive in D registers, int params in X registers.
function lowerParamArm64(resultId ValueId, paramIndex VarSlot, paramType StdType, dstBlock MlirBlock, funcParamTypes StdTypeArray)
	let slotIdx = computeParamSlotIndex(paramIndex, paramTypes: funcParamTypes)
	match paramType 'typeDispatch'
		f64 then if slotIdx < 8 'fpRegParam'
		let fpReg = getArm64CallConvFp(slotIdx)
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.fmovRegReg(Arm64FpVReg.virtual(resultId), src: arm64PhysFpReg(fpReg), precision: FloatPrecision.f64)))
	end 'fpRegParam'
	i64 then if slotIdx < 8 'gprRegParam'
		let ccReg = getArm64CallConvGpr(slotIdx)
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(ccReg))))
	end 'gprRegParam'
end 'typeDispatch'
end 'lowerParamArm64'


// ============================================================
// Memory (load/store indirect)
// ============================================================

function lowerLoadArm64(resultId ValueId, baseId ValueId, offset MachineWord, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.loadIndirect(Arm64VReg.virtual(resultId), baseReg: Arm64VReg.virtual(baseId), offset: offset, size: 8)))
end 'lowerLoadArm64'

function lowerStoreArm64(valueId ValueId, baseId ValueId, offset MachineWord, dstBlock MlirBlock)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.storeIndirect(Arm64VReg.virtual(baseId), offset: offset, srcReg: Arm64VReg.virtual(valueId), size: 8)))
end 'lowerStoreArm64'

// ============================================================
// MemRef ops (slot-based)
// ============================================================

function lowerMemRefOpArm64(op MemRefOp, dstBlock MlirBlock)
	match op 'lower'
		storeSlot(slotId, valueId) then dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(slotId, src: Arm64VReg.virtual(valueId))))
		loadSlot(resultId, slotId) then dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: slotId)))
	end 'lower'
end 'lowerMemRefOpArm64'

// ============================================================
// Runtime ops
// ============================================================

function lowerRuntimeOpArm64(op RuntimeOp, dstBlock MlirBlock)
	match op 'lower'
		printLiteral(data) then dstBlock.ops.push(MlirOp.arm64(Arm64Op.printLiteral(data)))
		printInt(valueId) then lowerPrintIntArm64(valueId, dstBlock: dstBlock)
		drop(valueId) then break 'lower'  // runtime.drop is a no-op
	end 'lower'
end 'lowerRuntimeOpArm64'

function lowerPrintIntArm64(valueId ValueId, dstBlock MlirBlock)
	// printInt expects the value in X0
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(arm64PhysReg(Arm64Register.x0), src: Arm64VReg.virtual(valueId))))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.printInt))
end 'lowerPrintIntArm64'

// ============================================================
// Terminators
// ============================================================

function lowerTerminatorArm64(srcBlock MlirBlock, dstBlock MlirBlock, returnType String)
	match srcBlock.terminator 'dispatch'
		maxon to arith then break 'dispatch'
		cf(cfOp) then lowerCfTerminatorArm64(cfOp, srcBlock: srcBlock, dstBlock: dstBlock)
		func(funcOp) then lowerFuncTerminatorArm64(funcOp, dstBlock: dstBlock, returnType: returnType)
		memref to sys then break 'dispatch'
		mir(mirOp) then lowerMirTerminatorArm64(mirOp, srcBlock: srcBlock, dstBlock: dstBlock, returnType: returnType)
		x64 then break 'dispatch'
		arm64(arm64Op) then dstBlock.ops.push(MlirOp.arm64(arm64Op))
	end 'dispatch'
end 'lowerTerminatorArm64'

function lowerCfTerminatorArm64(op CfOp, srcBlock MlirBlock, dstBlock MlirBlock)
	match op 'lower'
		br(target, _) then lowerBrWithArgsArm64(target, dstBlock: dstBlock)
		condBr(condId, thenTarget, _, elseTarget, _) then lowerCondBrArm64(condId, thenTarget: thenTarget, elseTarget: elseTarget, srcBlock: srcBlock, dstBlock: dstBlock)
	end 'lower'
end 'lowerCfTerminatorArm64'

function lowerFuncTerminatorArm64(op FuncOp, dstBlock MlirBlock, returnType String)
	match op 'lower'
		ret(retValId) then lowerReturnArm64(retValId, dstBlock: dstBlock, returnType: returnType)
		call to param then break 'lower'
	end 'lower'
end 'lowerFuncTerminatorArm64'

function lowerMirTerminatorArm64(op MirOp, srcBlock MlirBlock, dstBlock MlirBlock, returnType String)
	match op 'lower'
		condBranch(condId, thenTarget, _, elseTarget, _) then lowerCondBrArm64(condId, thenTarget: thenTarget, elseTarget: elseTarget, srcBlock: srcBlock, dstBlock: dstBlock)
		branch(target, _) then lowerBrWithArgsArm64(target, dstBlock: dstBlock)
		ret(retValId) then lowerReturnArm64(retValId, dstBlock: dstBlock, returnType: returnType)
		movImm to cmp then break 'lower'
		call to indirectCall then break 'lower'
		param to loadByte then break 'lower'
	end 'lower'
end 'lowerMirTerminatorArm64'

// Return: move value to X0 (or D0 for float), emit epilogue+ret.
function lowerReturnArm64(retValId ValueId, dstBlock MlirBlock, returnType String)
	if returnType == "f64" 'floatReturn'
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.fmovRegReg(arm64PhysFpReg(Arm64FloatRegister.d0), src: Arm64FpVReg.virtual(retValId), precision: FloatPrecision.f64)))
	end 'floatReturn' else 'intReturn'
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(arm64PhysReg(Arm64Register.x0), src: Arm64VReg.virtual(retValId))))
	end 'intReturn'
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.epilogue))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ret))
end 'lowerReturnArm64'

// ============================================================
// Branch helpers
// ============================================================

// Block arguments are NOT handled by the ISel. The SSA register allocator's
// destroySSA pass inserts properly-sequentialized parallel copies at CFG edges
// using CopyResolution. The ISel just emits jumps.

function lowerBrWithArgsArm64(target BlockId, dstBlock MlirBlock)
	// Block arg passing is handled by the register allocator's destroySSA pass.
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.branch(target)))
end 'lowerBrWithArgsArm64'

function lowerCondBrArm64(condId ValueId, thenTarget BlockId, elseTarget BlockId, srcBlock MlirBlock, dstBlock MlirBlock)
	// Block arg passing is handled by the register allocator's destroySSA pass.
	let jumpKind = determineJumpKindForCond(srcBlock, condId: condId)
	// Emit inverted conditional branch to else block, then unconditional branch to then block.
	match jumpKind 'emitJump'
		eq then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.ne, targetBlock: elseTarget)))
		ne then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget)))
		lt then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.ge, targetBlock: elseTarget)))
		le then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.gt, targetBlock: elseTarget)))
		gt then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.le, targetBlock: elseTarget)))
		ge then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.lt, targetBlock: elseTarget)))
		ugt then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.ls, targetBlock: elseTarget)))
		feq then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.ne, targetBlock: elseTarget)))
		fne then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget)))
		flt then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.ge, targetBlock: elseTarget)))
		fle then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.gt, targetBlock: elseTarget)))
		fgt then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.le, targetBlock: elseTarget)))
		fge then dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.lt, targetBlock: elseTarget)))
		boolTest then lowerBoolTestCondBrArm64(condId, elseTarget: elseTarget, dstBlock: dstBlock)
	end 'emitJump'
	// Unconditional branch to then block
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.branch(thenTarget)))
end 'lowerCondBrArm64'

function lowerBoolTestCondBrArm64(condId ValueId, elseTarget BlockId, dstBlock MlirBlock)
	if not tryReplaceLastWithFlagSettingArm64(dstBlock, condId: condId) 'needsCmp'
		let vr = Arm64VReg.virtual(condId)
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.cmpRegZero(vr)))
	end 'needsCmp'
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget)))
end 'lowerBoolTestCondBrArm64'

// Check if the last op in the block is an add/sub/and whose dest matches condId.
// If so, replace it with the S-variant (adds/subs/ands) and return true.
function tryReplaceLastWithFlagSettingArm64(block MlirBlock, condId ValueId) returns bool
	let opCount = block.ops.count()
	if opCount == 0 'empty'
		return false
	end 'empty'
	let lastOp = try block.ops.get(opCount - 1) otherwise 'noOp'
		return false
	end 'noOp'
	return match lastOp 'check'
		arm64(a64Op) gives tryReplaceArm64OpWithFlagSetting(block, opIndex: opCount - 1, a64Op: a64Op, condId: condId)
		maxon to mir gives false
		x64 gives false
	end 'check'
end 'tryReplaceLastWithFlagSettingArm64'

function tryReplaceArm64OpWithFlagSetting(block MlirBlock, opIndex Index, a64Op Arm64Op, condId ValueId) returns bool
	return match a64Op 'replace'
		addRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(block, opIndex: opIndex, dest: dest, condId: condId, replacement: MlirOp.arm64(Arm64Op.addsRegs(dest, src1: src1, src2: src2)))
		subRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(block, opIndex: opIndex, dest: dest, condId: condId, replacement: MlirOp.arm64(Arm64Op.subsRegs(dest, src1: src1, src2: src2)))
		andRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(block, opIndex: opIndex, dest: dest, condId: condId, replacement: MlirOp.arm64(Arm64Op.andsRegs(dest, src1: src1, src2: src2)))
		prologue to ldrFromSlot gives false
		addsRegs gives false
		subsRegs to remRegs gives false
		negReg to mvnReg gives false
		andsRegs to nullSafeLoad gives false
	end 'replace'
end 'tryReplaceArm64OpWithFlagSetting'

function trySwapArm64ThreeAddr(block MlirBlock, opIndex Index, dest Arm64VReg, condId ValueId, replacement MlirOp) returns bool
	if not arm64VRegMatchesCondId(dest, condId: condId) 'noMatch'
		return false
	end 'noMatch'
	block.ops.set(opIndex, value: replacement)
	return true
end 'trySwapArm64ThreeAddr'

function arm64VRegMatchesCondId(vreg Arm64VReg, condId ValueId) returns bool
	return match vreg 'check'
		virtual(vid) gives vid == condId
		physical gives false
	end 'check'
end 'arm64VRegMatchesCondId'

// ============================================================
// SysOps — slot-based lowering (no register allocation)
// ============================================================

function lowerSysOpArm64(op SysOp, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	var result = nextTempSlot
	match op 'lower'
		syscall(resultId, number, argIds) then result = lowerSyscallArm64(resultId, number: number, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		iatCall(resultId, slotIndex, argIds) then result = lowerIatCallArm64(resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		globalAddr(resultId, name) then result = lowerGlobalAddrArm64(resultId, name: name, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		stackAddr(resultId, slotId) then result = lowerStackAddrArm64(resultId, slotId: slotId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		storeByte(baseId, offsetId, byteId) then result = lowerStoreByteArm64(baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		loadByte(resultId, baseId, offsetId) then result = lowerLoadByteArm64(resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		memcpy(dstId, srcId, lenId) then result = lowerMemcpyArm64(dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		osExit(codeId) then result = lowerOsExitArm64(codeId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		osWrite(ptrId, lenId) then result = lowerOsWriteArm64(ptrId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		free then break 'lower'
		osWriteErr(ptrId, lenId) then result = lowerOsWriteErrArm64(ptrId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		loadFramePtr(resultId) then result = lowerLoadFramePtrArm64(resultId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		loadIndirect(resultId, addrId, offset) then result = lowerLoadIndirectArm64(resultId, addrId: addrId, offset: offset, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		funcAddr(resultId, name) then result = lowerFuncAddrArm64(resultId, name: name, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		storeIndirect(addrId, offset, valueId) then result = lowerStoreIndirectArm64(addrId, offset: offset, valueId: valueId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
	end 'lower'
	return result
end 'lowerSysOpArm64'

// MIR system-like ops (stackSlotAddr, globalAddr, syscall, etc.)
function lowerMirSysOpArm64(op MirOp, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	var result = nextTempSlot
	match op 'lower'
		stackSlotAddr(resultId, slotId) then result = lowerStackAddrArm64(resultId, slotId: slotId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		globalAddr(resultId, name) then result = lowerGlobalAddrArm64(resultId, name: name, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		syscall(resultId, number, argIds) then result = lowerMirSyscallArm64(resultId, number: number, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		iatCall(resultId, slotIndex, argIds) then result = lowerMirIatCallArm64(resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		osExit(codeId) then result = lowerOsExitArm64(codeId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		osWrite(ptrId, lenId) then result = lowerOsWriteArm64(ptrId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		memcpy(dstId, srcId, lenId) then result = lowerMirMemcpyArm64(dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		storeByte(baseId, offsetId, byteId) then result = lowerMirStoreByteArm64(baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		loadByte(resultId, baseId, offsetId) then result = lowerMirLoadByteArm64(resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		movImm to store then break 'lower'
	end 'lower'
	return result
end 'lowerMirSysOpArm64'

// Ensure a value is stored to a VarSlot. For SysOps that need slot-based addressing,
// we store the virtual register value into a temp slot.
function ensureValueInSlotArm64(valueId ValueId, valueSlots ValueSlotMap, nextTempSlot SlotIndex, dstBlock MlirBlock) returns VarSlot
	if valueSlotMapHas(valueSlots, valueId: valueId) 'hasSlot'
		let existingSlot = valueSlotMapGet(valueSlots, valueId: valueId)
		// Re-store current value to its existing slot
		dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(existingSlot, src: Arm64VReg.virtual(valueId))))
		return existingSlot
	end 'hasSlot'
	// No slot yet — assign a temp slot and store
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(nextTempSlot, src: Arm64VReg.virtual(valueId))))
	valueSlotMapSet(valueSlots, valueId: valueId, slot: nextTempSlot)
	return nextTempSlot
end 'ensureValueInSlotArm64'

// SysOp syscall: args come from ValueId (SysOp dialect uses ValueId args)
function lowerSyscallArm64(resultId ValueId, number MachineWord, argIds ValueIdArray, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let argSlots = VarSlotArray.create()
	for argId in argIds 'mapArgs'
		let slot = ensureValueInSlotArm64(argId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
		if slot == tempSlot 'usedTemp'
			tempSlot = tempSlot + 1
		end 'usedTemp'
		argSlots.push(slot)
	end 'mapArgs'
	let resultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.syscall(resultSlot, number: number, argSlots: argSlots)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot)))
	return tempSlot + 1
end 'lowerSyscallArm64'

function lowerIatCallArm64(resultId ValueId, slotIndex MachineWord, argIds ValueIdArray, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let argSlots = VarSlotArray.create()
	for argId in argIds 'mapArgs'
		let slot = ensureValueInSlotArm64(argId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
		if slot == tempSlot 'usedTemp'
			tempSlot = tempSlot + 1
		end 'usedTemp'
		argSlots.push(slot)
	end 'mapArgs'
	let resultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.iatCall(resultSlot, slotIndex: slotIndex, argSlots: argSlots)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot)))
	return tempSlot + 1
end 'lowerIatCallArm64'

function lowerMirSyscallArm64(resultId ValueId, number MachineWord, argIds ValueIdArray, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	return lowerSyscallArm64(resultId, number: number, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerMirSyscallArm64'

function lowerMirIatCallArm64(resultId ValueId, slotIndex MachineWord, argIds ValueIdArray, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	return lowerIatCallArm64(resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerMirIatCallArm64'

function lowerGlobalAddrArm64(resultId ValueId, name String, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	let tempSlot = nextTempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.globalAddr(tempSlot, name: name)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
	// Also load the result into a virtual register so regular ops can use it
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: tempSlot)))
	return nextTempSlot + 1
end 'lowerGlobalAddrArm64'

function lowerStackAddrArm64(resultId ValueId, slotId VarSlot, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	// Ensure the result slot doesn't overlap with the target slot
	var tempSlot = nextTempSlot
	if tempSlot <= slotId 'conflict'
		tempSlot = slotId + 1
	end 'conflict'
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.stackAddrOp(tempSlot, targetSlot: slotId)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
	// Also load the result into a virtual register so regular ops can use it
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: tempSlot)))
	return tempSlot + 1
end 'lowerStackAddrArm64'

function lowerStoreByteArm64(baseId ValueId, offsetId ValueId, byteId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let baseSlot = ensureValueInSlotArm64(baseId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if baseSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let offsetSlot = ensureValueInSlotArm64(offsetId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if offsetSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let byteSlot = ensureValueInSlotArm64(byteId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if byteSlot == tempSlot 'usedTemp3'
		tempSlot = tempSlot + 1
	end 'usedTemp3'
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.storeByteOp(baseSlot, offsetSlot: offsetSlot, byteSlot: byteSlot)))
	return tempSlot
end 'lowerStoreByteArm64'

function lowerLoadByteArm64(resultId ValueId, baseId ValueId, offsetId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let baseSlot = ensureValueInSlotArm64(baseId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if baseSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let offsetSlot = ensureValueInSlotArm64(offsetId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if offsetSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let resultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.loadByteOp(resultSlot, baseSlot: baseSlot, offsetSlot: offsetSlot)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	// Also load the result into a virtual register so regular ops can use it
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot)))
	return tempSlot + 1
end 'lowerLoadByteArm64'

function lowerMemcpyArm64(dstId ValueId, srcId ValueId, lenId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let dstSlot = ensureValueInSlotArm64(dstId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if dstSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let srcSlot = ensureValueInSlotArm64(srcId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if srcSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let lenSlot = ensureValueInSlotArm64(lenId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if lenSlot == tempSlot 'usedTemp3'
		tempSlot = tempSlot + 1
	end 'usedTemp3'
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.memcpyOp(dstSlot, srcSlot: srcSlot, lenSlot: lenSlot)))
	return tempSlot
end 'lowerMemcpyArm64'

// MIR storeByte/loadByte/memcpy: same slot-based lowering, args are ValueId
function lowerMirStoreByteArm64(baseId ValueId, offsetId ValueId, byteId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	return lowerStoreByteArm64(baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerMirStoreByteArm64'

function lowerMirLoadByteArm64(resultId ValueId, baseId ValueId, offsetId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	return lowerLoadByteArm64(resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerMirLoadByteArm64'

function lowerMirMemcpyArm64(dstId ValueId, srcId ValueId, lenId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	return lowerMemcpyArm64(dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerMirMemcpyArm64'

// ============================================================
// OS-neutral exit/write
// ============================================================

function lowerOsExitArm64(codeId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	var tempSlot = nextTempSlot
	let codeSlot = ensureValueInSlotArm64(codeId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if codeSlot == tempSlot 'usedTemp'
		tempSlot = tempSlot + 1
	end 'usedTemp'
	match osDesc.exit 'strategy'
		syscall(num) then return lowerOsExitSyscallArm64(codeSlot, num: num, dstBlock: dstBlock, nextTempSlot: tempSlot)
		iatCall(slotIdx) then return lowerOsExitIatArm64(codeSlot, slotIdx: slotIdx, dstBlock: dstBlock, nextTempSlot: tempSlot)
	end 'strategy'
end 'lowerOsExitArm64'

function lowerOsExitSyscallArm64(codeSlot VarSlot, num MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
	let argSlots = VarSlotArray.create()
	argSlots.push(codeSlot)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.syscall(nextTempSlot, number: num, argSlots: argSlots)))
	return nextTempSlot + 1
end 'lowerOsExitSyscallArm64'

function lowerOsExitIatArm64(codeSlot VarSlot, slotIdx MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
	let argSlots = VarSlotArray.create()
	argSlots.push(codeSlot)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.iatCall(nextTempSlot, slotIndex: slotIdx, argSlots: argSlots)))
	return nextTempSlot + 1
end 'lowerOsExitIatArm64'

function lowerOsWriteArm64(ptrId ValueId, lenId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	return lowerOsWriteWithStrategyArm64(ptrId, lenId: lenId, strategy: osDesc.write, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerOsWriteArm64'

function lowerOsWriteSyscallArm64(ptrSlot VarSlot, lenSlot VarSlot, writeNum MachineWord, fd MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
	// fd constant -> temp slot
	let fdSlot = nextTempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: fd)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(fdSlot, src: arm64PhysReg(Arm64Register.x0))))
	// syscall(writeNum, fd, ptr, len)
	let argSlots = VarSlotArray.create()
	argSlots.push(fdSlot)
	argSlots.push(ptrSlot)
	argSlots.push(lenSlot)
	let resultSlot = nextTempSlot + 1
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.syscall(resultSlot, number: writeNum, argSlots: argSlots)))
	return nextTempSlot + 2
end 'lowerOsWriteSyscallArm64'

function lowerOsWriteWinApiArm64(ptrSlot VarSlot, lenSlot VarSlot, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot

	// GetStdHandle(handleConstant)
	let handleConstSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: handleConstant)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(handleConstSlot, src: arm64PhysReg(Arm64Register.x0))))
	tempSlot = tempSlot + 1
	let getHandleArgs = VarSlotArray.create()
	getHandleArgs.push(handleConstSlot)
	let handleResultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.iatCall(handleResultSlot, slotIndex: getHandleSlot, argSlots: getHandleArgs)))
	tempSlot = tempSlot + 1

	// bytesWritten = 0 stored to a slot
	let writtenSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: 0)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(writtenSlot, src: arm64PhysReg(Arm64Register.x0))))
	tempSlot = tempSlot + 1

	// Get address of bytesWritten slot
	let writtenAddrSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.stackAddrOp(writtenAddrSlot, targetSlot: writtenSlot)))
	tempSlot = tempSlot + 1

	// NULL for lpOverlapped
	let nullSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: 0)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(nullSlot, src: arm64PhysReg(Arm64Register.x0))))
	tempSlot = tempSlot + 1

	// WriteFile(handle, ptr, len, &bytesWritten, NULL)
	let writeArgs = VarSlotArray.create()
	writeArgs.push(handleResultSlot)
	writeArgs.push(ptrSlot)
	writeArgs.push(lenSlot)
	writeArgs.push(writtenAddrSlot)
	writeArgs.push(nullSlot)
	let writeResultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.iatCall(writeResultSlot, slotIndex: writeFileSlot, argSlots: writeArgs)))
	tempSlot = tempSlot + 1

	return tempSlot
end 'lowerOsWriteWinApiArm64'

// OS write via libcall: write(fd, buf, len) through GOT/IAT slot.
// Used for macOS (libSystem.B.dylib).
function lowerOsWriteLibcallArm64(ptrSlot VarSlot, lenSlot VarSlot, writeSlot MachineWord, fd MachineWord, dstBlock MlirBlock, nextTempSlot SlotIndex) returns SlotIndex
	// fd constant -> temp slot
	let fdSlot = nextTempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: fd)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(fdSlot, src: arm64PhysReg(Arm64Register.x0))))
	// iatCall write(fd, ptr, len)
	let argSlots = VarSlotArray.create()
	argSlots.push(fdSlot)
	argSlots.push(ptrSlot)
	argSlots.push(lenSlot)
	let resultSlot = nextTempSlot + 1
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.iatCall(resultSlot, slotIndex: writeSlot, argSlots: argSlots)))
	return nextTempSlot + 2
end 'lowerOsWriteLibcallArm64'

function lowerOsWriteErrArm64(ptrId ValueId, lenId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	return lowerOsWriteWithStrategyArm64(ptrId, lenId: lenId, strategy: osDesc.writeErr, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
end 'lowerOsWriteErrArm64'

function lowerOsWriteWithStrategyArm64(ptrId ValueId, lenId ValueId, strategy WriteStrategy, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let ptrSlot = ensureValueInSlotArm64(ptrId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if ptrSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let lenSlot = ensureValueInSlotArm64(lenId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if lenSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	match strategy 'dispatch'
		syscall(writeNum, fd) then return lowerOsWriteSyscallArm64(ptrSlot, lenSlot: lenSlot, writeNum: writeNum, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
		winApi(getHandleSlot, handleConstant, writeFileSlot) then return lowerOsWriteWinApiArm64(ptrSlot, lenSlot: lenSlot, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot, dstBlock: dstBlock, nextTempSlot: tempSlot)
		libcall(writeSlot, fd) then return lowerOsWriteLibcallArm64(ptrSlot, lenSlot: lenSlot, writeSlot: writeSlot, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
	end 'dispatch'
end 'lowerOsWriteWithStrategyArm64'

function lowerLoadFramePtrArm64(resultId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x29))))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	return nextTempSlot
end 'lowerLoadFramePtrArm64'

function lowerLoadIndirectArm64(resultId ValueId, addrId ValueId, offset MachineWord, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let addrSlot = ensureValueInSlotArm64(addrId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if addrSlot == tempSlot 'usedTemp'
		tempSlot = tempSlot + 1
	end 'usedTemp'
	// loadIndirect needs the base address in a register
	let addrVReg = Arm64VReg.virtual(addrId)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(addrVReg, slotIndex: addrSlot)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.loadIndirect(Arm64VReg.virtual(resultId), baseReg: addrVReg, offset: offset, size: 8)))
	let resultSlot = tempSlot
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.strToSlot(resultSlot, src: Arm64VReg.virtual(resultId))))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	return tempSlot + 1
end 'lowerLoadIndirectArm64'

function lowerStoreIndirectArm64(addrId ValueId, offset MachineWord, valueId ValueId, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let addrSlot = ensureValueInSlotArm64(addrId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if addrSlot == tempSlot 'usedAddrTemp'
		tempSlot = tempSlot + 1
	end 'usedAddrTemp'
	let valSlot = ensureValueInSlotArm64(valueId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if valSlot == tempSlot 'usedValTemp'
		tempSlot = tempSlot + 1
	end 'usedValTemp'
	let addrVReg = Arm64VReg.virtual(addrId)
	let valVReg = Arm64VReg.virtual(valueId)
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(addrVReg, slotIndex: addrSlot)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.ldrFromSlot(valVReg, slotIndex: valSlot)))
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.storeIndirect(addrVReg, offset: offset, srcReg: valVReg, size: 8)))
	return tempSlot
end 'lowerStoreIndirectArm64'

function lowerFuncAddrArm64(resultId ValueId, name String, dstBlock MlirBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	dstBlock.ops.push(MlirOp.arm64(Arm64Op.leaFuncAddr(Arm64VReg.virtual(resultId), funcName: name)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	return nextTempSlot
end 'lowerFuncAddrArm64'

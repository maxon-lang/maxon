// Arm64 Dialect — ARM64 machine instructions.

export enum Arm64FloatRegister
	d0 = 0
	d1 = 1
	d2 = 2
	d3 = 3
	d4 = 4
	d5 = 5
	d6 = 6
	d7 = 7
	d8 = 8
	d9 = 9
	d10 = 10
	d11 = 11
	d12 = 12
	d13 = 13
	d14 = 14
	d15 = 15
	d16 = 16
	d17 = 17
	d18 = 18
	d19 = 19
	d20 = 20
	d21 = 21
	d22 = 22
	d23 = 23
	d24 = 24
	d25 = 25
	d26 = 26
	d27 = 27
	d28 = 28
	d29 = 29
	d30 = 30
	d31 = 31
end 'Arm64FloatRegister'

export enum Arm64Register
	x0 = 0
	x1 = 1
	x2 = 2
	x3 = 3
	x4 = 4
	x5 = 5
	x6 = 6
	x7 = 7
	x8 = 8
	x9 = 9
	x10 = 10
	x11 = 11
	x12 = 12
	x13 = 13
	x14 = 14
	x15 = 15
	x16 = 16
	x17 = 17
	x18 = 18
	x19 = 19
	x20 = 20
	x21 = 21
	x22 = 22
	x23 = 23
	x24 = 24
	x25 = 25
	x26 = 26
	x27 = 27
	x28 = 28
	x29 = 29
	x30 = 30
	sp = 31
end 'Arm64Register'

export union Arm64CondCode
	eq = 0
	ne = 1
	hi = 8
	ls = 9
	ge = 10
	lt = 11
	gt = 12
	le = 13
end 'Arm64CondCode'

// Virtual register enums — all VRegs are initially physical.
export union Arm64VReg
	physical(reg Arm64Register)
	virtual(id ValueId)
end 'Arm64VReg'

export union Arm64FpVReg
	physical(reg Arm64FloatRegister)
	virtual(id ValueId)
end 'Arm64FpVReg'

export function arm64VRegToString(vreg Arm64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "v{id}"
	end 'fmt'
end 'arm64VRegToString'

export function arm64FpVRegToString(vreg Arm64FpVReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "vf{id}"
	end 'fmt'
end 'arm64FpVRegToString'

// Wrap a physical register as a VReg (used during transition period)
export function arm64PhysReg(reg Arm64Register) returns Arm64VReg
	return Arm64VReg.physical(reg)
end 'arm64PhysReg'

export function arm64PhysFpReg(reg Arm64FloatRegister) returns Arm64FpVReg
	return Arm64FpVReg.physical(reg)
end 'arm64PhysFpReg'

// ARM64 register constraint bitmask constants (bit N = register xN ordinal)
export let A64_REG_NONE = 0
export let A64_REG_X0 = 1
export let A64_REG_X1 = 2
export let A64_CALLER_SAVED = 65535

export type Arm64OpMeta
	export let latency as Latency
	export let isMemory as bool
	export let isStore as bool
	export let isCall as bool
	export let setsFlags as bool
	export let pattern as OpPattern
	export let implicitGprReads as RegMask
	export let implicitGprDefs as RegMask
end 'Arm64OpMeta'

export union Arm64Op
	// Control flow / bookkeeping
	prologue(stackSize StackSize) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	epilogue = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 0}
	// Simple ALU
	movImm(dest Arm64VReg, value MachineWord) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.constImm, implicitGprReads: 0, implicitGprDefs: 0}
	strToSlot(slotIndex VarSlot, src Arm64VReg) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	ldrFromSlot(dest Arm64VReg, slotIndex VarSlot) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	addRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	addsRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	subRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	subsRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	mulRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	sdivRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 12, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	remRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 12, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	negReg(dest Arm64VReg, src Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.defUse, implicitGprReads: 0, implicitGprDefs: 0}
	mvnReg(dest Arm64VReg, src Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.defUse, implicitGprReads: 0, implicitGprDefs: 0}
	andRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	andsRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	orrRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	eorRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	lslRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	asrRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	lsrRegs(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	cmpRegs(src1 Arm64VReg, src2 Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.twoUse, implicitGprReads: 0, implicitGprDefs: 0}
	cmpRegZero(src Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.singleUseNodef, implicitGprReads: 0, implicitGprDefs: 0}
	condBranch(condition Arm64CondCode, targetBlock BlockId) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	branch(targetBlock BlockId) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	branchLink(target String) = Arm64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 65535}
	ret = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 0}
	// StdSystemOp lowering
	syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray) = Arm64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 1}
	iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray) = Arm64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 1, implicitGprDefs: 1}
	globalAddr(resultSlot VarSlot, name String) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	stackAddrOp(resultSlot VarSlot, targetSlot VarSlot) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	// Register allocator ops
	movRegReg(dest Arm64VReg, src Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.movRegReg, implicitGprReads: 0, implicitGprDefs: 0}
	spillToStack(offset MachineWord, src Arm64VReg) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	reloadFromStack(dest Arm64VReg, offset MachineWord) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Call support ops
	branchLinkReg(reg Arm64VReg) = Arm64OpMeta{latency: 5, isMemory: true, isStore: false, isCall: true, setsFlags: false, pattern: OpPattern.callIndirect, implicitGprReads: 0, implicitGprDefs: 65535}
	subSpImm(value StackSize) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	addSpImm(value StackSize) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 0, implicitGprDefs: 0}
	strToSpOffset(offset StackSize, src Arm64VReg) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	// FP ops
	fmovRegReg(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpMov, implicitGprReads: 0, implicitGprDefs: 0}
	spillFpToStack(offset MachineWord, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleUse, implicitGprReads: 0, implicitGprDefs: 0}
	reloadFpFromStack(dest Arm64FpVReg, offset MachineWord, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	fmovToFloat(dest Arm64FpVReg, src Arm64VReg, precision FloatPrecision) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.gprToFp, implicitGprReads: 0, implicitGprDefs: 0}
	fmovToGpr(dest Arm64VReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpToGpr, implicitGprReads: 0, implicitGprDefs: 0}
	fpLoadRdata(dest Arm64FpVReg, rdataLabel String, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	fadd(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fsub(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fmul(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fdiv(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 15, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fmin(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fmax(dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpThreeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	fsqrt(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 20, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	fabs(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	fneg(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	fcmp(src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: true, pattern: OpPattern.fpTwoUse, implicitGprReads: 0, implicitGprDefs: 0}
	scvtf(dest Arm64FpVReg, src Arm64VReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.gprToFp, implicitGprReads: 0, implicitGprDefs: 0}
	fcvtzs(dest Arm64VReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpToGpr, implicitGprReads: 0, implicitGprDefs: 0}
	fcvt(dest Arm64FpVReg, src Arm64FpVReg, destPrecision FloatPrecision) = Arm64OpMeta{latency: 3, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	frintm(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	frintp(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	frintz(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	frintn(dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpDefUse, implicitGprReads: 0, implicitGprDefs: 0}
	// FP indirect memory ops
	fpStoreIndirect(baseReg Arm64VReg, offset MachineWord, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.baseUseFpUse, implicitGprReads: 0, implicitGprDefs: 0}
	fpLoadIndirect(dest Arm64FpVReg, baseReg Arm64VReg, offset MachineWord, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseFpDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Indirect memory ops (GPR)
	storeIndirect(baseReg Arm64VReg, offset MachineWord, srcReg Arm64VReg, width StoreWidth) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.baseUseSrcUse, implicitGprReads: 0, implicitGprDefs: 0}
	loadIndirect(destReg Arm64VReg, baseReg Arm64VReg, offset MachineWord, width StoreWidth, signed bool) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseDest, implicitGprReads: 0, implicitGprDefs: 0}
	// Global variable ops
	globalLoad(dest Arm64VReg, name String, size MachineWord) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	globalStore(name String, src Arm64VReg, size MachineWord) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUse, implicitGprReads: 0, implicitGprDefs: 0}
	globalLoadFloat(dest Arm64FpVReg, name String, precision FloatPrecision) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleDef, implicitGprReads: 0, implicitGprDefs: 0}
	globalStoreFloat(name String, src Arm64FpVReg, precision FloatPrecision) = Arm64OpMeta{latency: 3, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.fpSingleUse, implicitGprReads: 0, implicitGprDefs: 0}
	// LEA ops
	leaFromStack(dest Arm64VReg, stackOffset MachineWord) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	leaRdata(dest Arm64VReg, rdataLabel String) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	leaFuncAddr(dest Arm64VReg, funcName String) = Arm64OpMeta{latency: 2, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	// Conditional ops
	cset(dest Arm64VReg, condition Arm64CondCode) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.singleDef, implicitGprReads: 0, implicitGprDefs: 0}
	csel(dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg, condition Arm64CondCode) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.csel, implicitGprReads: 0, implicitGprDefs: 0}
	// Width conversion ops
	sxtw(dest Arm64VReg, src Arm64VReg) = Arm64OpMeta{latency: 1, isMemory: false, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.defUse, implicitGprReads: 0, implicitGprDefs: 0}
	// Null-safe load
	nullSafeLoad(dest Arm64VReg, baseReg Arm64VReg, offset MachineWord) = Arm64OpMeta{latency: 4, isMemory: true, isStore: false, isCall: false, setsFlags: false, pattern: OpPattern.baseUseDest, implicitGprReads: 0, implicitGprDefs: 0}
	// Atomic memory ops emitted as ARMv8 LL/SC sequences. Scratch registers
	// x16, x17 (and x18 for atomicXaddMem) are outside the regalloc pool so
	// no implicit defs need to be tracked. The full LL/SC retry loop is
	// emitted inline by the code emitter using a hardcoded backward branch.
	atomicIncMem(addrReg Arm64VReg) = Arm64OpMeta{latency: 8, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUseNodef, implicitGprReads: 0, implicitGprDefs: 0}
	atomicDecMem(addrReg Arm64VReg) = Arm64OpMeta{latency: 8, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.singleUseNodef, implicitGprReads: 0, implicitGprDefs: 0}
	atomicXaddMem(resultReg Arm64VReg, addrReg Arm64VReg, valReg Arm64VReg) = Arm64OpMeta{latency: 8, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.threeAddr, implicitGprReads: 0, implicitGprDefs: 0}
	// Phase D2 entry-point bookkeeping: stash kernel-supplied argc/argv from
	// x0/x1 (AArch64 ELF entry convention) into `__mrt_argc` / `__mrt_argv`.
	// Only emitted on Linux/macOS for `mrt_start` / `mrt_start_with_coverage`
	// via the prologue pass. On Windows the body is empty; on WASI it is
	// never inserted. Reads x0/x1, writes to memory; scratches x16.
	stashEntryArgv = Arm64OpMeta{latency: 2, isMemory: true, isStore: true, isCall: false, setsFlags: false, pattern: OpPattern.passThrough, implicitGprReads: 3, implicitGprDefs: 0}
end 'Arm64Op'

export typealias Arm64OpArray = Array with Arm64Op

function arm64SlotOffset(slotIndex VarSlot) returns StackSize
	return 16 + slotIndex * 8
end 'arm64SlotOffset'

export function arm64OpToString(op Arm64Op, blocks IrBlockArray) returns String
	return match op 'toString'
		prologue(stackSize) gives "arm64.prologue stack_size={stackSize}"
		epilogue gives "arm64.epilogue\n    arm64.ret"
		movImm(dest, value) gives "arm64.mov {arm64VRegToString(dest)}, #{value}"
		strToSlot(slotIndex, src) gives "arm64.str {arm64VRegToString(src)}, [x29, #{arm64SlotOffset(slotIndex)}]"
		ldrFromSlot(dest, slotIndex) gives "arm64.ldr {arm64VRegToString(dest)}, [x29, #{arm64SlotOffset(slotIndex)}]"
		addRegs(dest, src1, src2) gives "arm64.add {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		addsRegs(dest, src1, src2) gives "arm64.adds {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		subRegs(dest, src1, src2) gives "arm64.sub {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		subsRegs(dest, src1, src2) gives "arm64.subs {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		mulRegs(dest, src1, src2) gives "arm64.mul {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		sdivRegs(dest, src1, src2) gives "arm64.sdiv {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		remRegs(dest, src1, src2) gives "arm64.msub {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		negReg(dest, src) gives "arm64.neg {arm64VRegToString(dest)}, {arm64VRegToString(src)}"
		mvnReg(dest, src) gives "arm64.mvn {arm64VRegToString(dest)}, {arm64VRegToString(src)}"
		andRegs(dest, src1, src2) gives "arm64.and {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		andsRegs(dest, src1, src2) gives "arm64.ands {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		orrRegs(dest, src1, src2) gives "arm64.orr {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		eorRegs(dest, src1, src2) gives "arm64.eor {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		lslRegs(dest, src1, src2) gives "arm64.lslv {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		asrRegs(dest, src1, src2) gives "arm64.asrv {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		lsrRegs(dest, src1, src2) gives "arm64.lsrv {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		cmpRegs(src1, src2) gives "arm64.cmp {arm64VRegToString(src1)}, {arm64VRegToString(src2)}"
		cmpRegZero(src) gives "arm64.cmp {arm64VRegToString(src)}, #0"
		condBranch(condition, targetBlock) gives "arm64.b.{condition.name} {resolveBlockLabel(targetBlock, blocks: blocks)}"
		branch(targetBlock) gives "arm64.b {resolveBlockLabel(targetBlock, blocks: blocks)}"
		branchLink(linkTarget) gives "arm64.bl {linkTarget}"
		ret gives "arm64.ret"
		syscall(_, number, argSlots) gives "arm64.syscall {number}({formatVarSlotArgs(argSlots)})"
		iatCall(_, slotIndex, _) gives "arm64.call_import slot_{slotIndex}"
		globalAddr(_, name) gives "arm64.adrp_add_rdata x0, {name}"
		stackAddrOp(_, targetSlot) gives "arm64.add x0, x29, #{arm64SlotOffset(targetSlot)}"
		storeByteOp gives "arm64.strb w2, [x0, #0]"
		loadByteOp gives "arm64.ldrb w0, [x0, #0]"
		memcpyOp gives "arm64.memcpy"
		movRegReg(dest, src) gives "arm64.mov {arm64VRegToString(dest)}, {arm64VRegToString(src)}"
		spillToStack(offset, src) gives "arm64.str {arm64VRegToString(src)}, [x29, #{offset}]"
		reloadFromStack(dest, offset) gives "arm64.ldr {arm64VRegToString(dest)}, [x29, #{offset}]"
		branchLinkReg(reg) gives "arm64.blr {arm64VRegToString(reg)}"
		subSpImm(value) gives "arm64.sub sp, sp, #{value}"
		addSpImm(value) gives "arm64.add sp, sp, #{value}"
		strToSpOffset(offset, src) gives "arm64.str {arm64VRegToString(src)}, [sp, #{offset}]"
		fmovRegReg(dest, src, _) gives "arm64.fmov {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		spillFpToStack(offset, src, _) gives "arm64.str {arm64FpVRegToString(src)}, [x29, #{offset}]"
		reloadFpFromStack(dest, offset, _) gives "arm64.ldr {arm64FpVRegToString(dest)}, [x29, #{offset}]"
		fmovToFloat(dest, src, _) gives "arm64.fmov {arm64FpVRegToString(dest)}, {arm64VRegToString(src)}"
		fmovToGpr(dest, src, _) gives "arm64.fmov {arm64VRegToString(dest)}, {arm64FpVRegToString(src)}"
		fpLoadRdata(dest, label, _) gives "arm64.ldr {arm64FpVRegToString(dest)}, [rdata+{label}]"
		fadd(dest, src1, src2, _) gives "arm64.fadd {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fsub(dest, src1, src2, _) gives "arm64.fsub {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fmul(dest, src1, src2, _) gives "arm64.fmul {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fdiv(dest, src1, src2, _) gives "arm64.fdiv {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fmin(dest, src1, src2, _) gives "arm64.fmin {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fmax(dest, src1, src2, _) gives "arm64.fmax {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		fsqrt(dest, src, _) gives "arm64.fsqrt {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		fabs(dest, src, _) gives "arm64.fabs {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		fneg(dest, src, _) gives "arm64.fneg {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		fcmp(src1, src2, _) gives "arm64.fcmp {arm64FpVRegToString(src1)}, {arm64FpVRegToString(src2)}"
		scvtf(dest, src, _) gives "arm64.scvtf {arm64FpVRegToString(dest)}, {arm64VRegToString(src)}"
		fcvtzs(dest, src, _) gives "arm64.fcvtzs {arm64VRegToString(dest)}, {arm64FpVRegToString(src)}"
		fcvt(dest, src, _) gives "arm64.fcvt {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		frintm(dest, src, _) gives "arm64.frintm {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		frintp(dest, src, _) gives "arm64.frintp {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		frintz(dest, src, _) gives "arm64.frintz {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		frintn(dest, src, _) gives "arm64.frintn {arm64FpVRegToString(dest)}, {arm64FpVRegToString(src)}"
		fpStoreIndirect(baseReg, offset, src, _) gives "arm64.str {arm64FpVRegToString(src)}, [{arm64VRegToString(baseReg)}, #{offset}]"
		fpLoadIndirect(dest, baseReg, offset, _) gives "arm64.ldr {arm64FpVRegToString(dest)}, [{arm64VRegToString(baseReg)}, #{offset}]"
		storeIndirect(baseReg, offset, srcReg, width) gives "arm64.str {arm64VRegToString(srcReg)}, [{arm64VRegToString(baseReg)}, #{offset}] ({storeWidthBytes(width)}b)"
		loadIndirect(destReg, baseReg, offset, width, signed) gives "arm64.{arm64LoadIndirectMnemonic(width, signed: signed)} {arm64VRegToString(destReg)}, [{arm64VRegToString(baseReg)}, #{offset}] ({storeWidthBytes(width)}b)"
		globalLoad(dest, name, _) gives "arm64.ldr {arm64VRegToString(dest)}, [{name}]"
		globalStore(name, src, _) gives "arm64.str {arm64VRegToString(src)}, [{name}]"
		globalLoadFloat(dest, name, _) gives "arm64.ldr {arm64FpVRegToString(dest)}, [{name}]"
		globalStoreFloat(name, src, _) gives "arm64.str {arm64FpVRegToString(src)}, [{name}]"
		leaFromStack(dest, offset) gives "arm64.add {arm64VRegToString(dest)}, x29, #{offset}"
		leaRdata(dest, label) gives "arm64.adrp+add {arm64VRegToString(dest)}, {label}"
		leaFuncAddr(dest, funcName) gives "arm64.adrp+add {arm64VRegToString(dest)}, {funcName}"
		cset(dest, condition) gives "arm64.cset {arm64VRegToString(dest)}, {condition.name}"
		csel(dest, src1, src2, condition) gives "arm64.csel {arm64VRegToString(dest)}, {arm64VRegToString(src1)}, {arm64VRegToString(src2)}, {condition.name}"
		sxtw(dest, src) gives "arm64.sxtw {arm64VRegToString(dest)}, {arm64VRegToString(src)}"
		nullSafeLoad(dest, baseReg, offset) gives "arm64.null_safe_load {arm64VRegToString(dest)}, [{arm64VRegToString(baseReg)}, #{offset}]"
		atomicIncMem(addrReg) gives "arm64.atomic_inc [{arm64VRegToString(addrReg)}]"
		atomicDecMem(addrReg) gives "arm64.atomic_dec [{arm64VRegToString(addrReg)}]"
		atomicXaddMem(resultReg, addrReg, valReg) gives "arm64.atomic_xadd {arm64VRegToString(resultReg)}, [{arm64VRegToString(addrReg)}], {arm64VRegToString(valReg)}"
		stashEntryArgv gives "arm64.stash_entry_argv [__mrt_argc],x0; [__mrt_argv],x1"
	end 'toString'
end 'arm64OpToString'

// Pick the mnemonic that matches the opcode the ARM64 emitter actually
// generates per (width, signed). The `signed` flag is ignored at qword
// width because a 64-bit LDR fills the register naturally; at word
// width it picks LDRSW vs plain LDR (Wn → Xn zero-extends); narrower
// widths pick LDRSB/LDRSH vs LDRB/LDRH.
function arm64LoadIndirectMnemonic(width StoreWidth, signed bool) returns String
	return match width 'w'
		byte gives "ldrsb" if signed else "ldrb"
		halfword gives "ldrsh" if signed else "ldrh"
		word gives "ldrsw" if signed else "ldr"
		qword gives "ldr"
	end 'w'
end 'arm64LoadIndirectMnemonic'

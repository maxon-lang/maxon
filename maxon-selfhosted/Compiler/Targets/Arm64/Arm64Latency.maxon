// ARM64-specific latency table for the instruction scheduler.
// Per-instruction latency is defined by the Arm64OpMeta backing on each Arm64Op case.

// ARM64 latency table: 26 allocatable GPRs (x0-x15, x19-x28),
// 32 FP/SIMD regs (d0-d31), pressure threshold at 80%.
export function createArm64LatencyTable() returns TargetLatencyTable
	return TargetLatencyTable{
		defaultLatency: 1,
		intDivLatency: 12,
		fpDivLatency: 15,
		gprCount: 26,
		fpCount: 32,
		pressureThreshold: 20
	}
end 'createArm64LatencyTable'

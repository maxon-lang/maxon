// MaxArm64 Dialect — ARM64 machine instructions.

export enum MaxArm64FloatRegister
	d0 = 0
	d1 = 1
	d2 = 2
	d3 = 3
	d4 = 4
	d5 = 5
	d6 = 6
	d7 = 7
	d31 = 31
end 'MaxArm64FloatRegister'

export enum MaxArm64Register
	x0 = 0
	x1 = 1
	x2 = 2
	x3 = 3
	x4 = 4
	x5 = 5
	x6 = 6
	x7 = 7
	x8 = 8
	x9 = 9
	x10 = 10
	x11 = 11
	x12 = 12
	x13 = 13
	x14 = 14
	x15 = 15
	x16 = 16
	x29 = 29
	x30 = 30
	sp = 31
end 'MaxArm64Register'

export enum MaxArm64CondCode
	eq = 0
	ne = 1
	ge = 10
	lt = 11
	gt = 12
	le = 13
end 'MaxArm64CondCode'

export union MaxArm64Op
	prologue(stackSize StackSize)
	epilogue
	movImm(dest MaxArm64Register, value MachineWord)
	strToSlot(slotIndex VarSlot, src MaxArm64Register)
	ldrFromSlot(dest MaxArm64Register, slotIndex VarSlot)
	addRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	subRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	mulRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	sdivRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	remRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	negReg(dest MaxArm64Register, src MaxArm64Register)
	mvnReg(dest MaxArm64Register, src MaxArm64Register)
	andRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	orrRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	eorRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	lslRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	asrRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
	cmpRegs(src1 MaxArm64Register, src2 MaxArm64Register)
	cmpRegZero(src MaxArm64Register)
	condBranch(condition MaxArm64CondCode, targetBlock BlockId)
	branch(targetBlock BlockId)
	branchLink(target ByteArray)
	printLiteral(data ByteArray)
	printInt
	ret
	// SysOp lowering: Linux ARM64 syscall (svc #0)
	syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray)
	// SysOp lowering: indirect call through IAT slot
	iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray)
	// SysOp lowering: data island + ADR for named global data
	globalAddr(resultSlot VarSlot, name ByteArray)
	// SysOp lowering: address of a stack slot
	stackAddrOp(resultSlot VarSlot, targetSlot VarSlot)
	// SysOp lowering: strb byte at base+offset
	storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot)
	// SysOp lowering: ldrb byte from base+offset
	loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot)
	// SysOp lowering: byte-by-byte copy
	memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot)
	// Register allocator ops
	movRegReg(dest MaxArm64Register, src MaxArm64Register)
	spillToStack(offset MachineWord, src MaxArm64Register)
	reloadFromStack(dest MaxArm64Register, offset MachineWord)
	// Call support ops
	branchLinkReg(reg MaxArm64Register)
	subSpImm(value StackSize)
	addSpImm(value StackSize)
	strToSpOffset(offset StackSize, src MaxArm64Register)
	// FP ops
	fmovRegReg(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	spillFpToStack(offset MachineWord, src MaxArm64FloatRegister, precision FloatPrecision)
	reloadFpFromStack(dest MaxArm64FloatRegister, offset MachineWord, precision FloatPrecision)
	fmovToFloat(dest MaxArm64FloatRegister, src MaxArm64Register, precision FloatPrecision)
	fmovToGpr(dest MaxArm64Register, src MaxArm64FloatRegister, precision FloatPrecision)
	fpLoadRdata(dest MaxArm64FloatRegister, rdataLabel ByteArray, precision FloatPrecision)
	fadd(dest MaxArm64FloatRegister, src1 MaxArm64FloatRegister, src2 MaxArm64FloatRegister, precision FloatPrecision)
	fsub(dest MaxArm64FloatRegister, src1 MaxArm64FloatRegister, src2 MaxArm64FloatRegister, precision FloatPrecision)
	fmul(dest MaxArm64FloatRegister, src1 MaxArm64FloatRegister, src2 MaxArm64FloatRegister, precision FloatPrecision)
	fdiv(dest MaxArm64FloatRegister, src1 MaxArm64FloatRegister, src2 MaxArm64FloatRegister, precision FloatPrecision)
	fsqrt(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	fabs(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	fneg(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	fcmp(src1 MaxArm64FloatRegister, src2 MaxArm64FloatRegister, precision FloatPrecision)
	scvtf(dest MaxArm64FloatRegister, src MaxArm64Register, precision FloatPrecision)
	fcvtzs(dest MaxArm64Register, src MaxArm64FloatRegister, precision FloatPrecision)
	fcvt(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, destPrecision FloatPrecision)
	frintm(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	frintp(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	frintz(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	frintn(dest MaxArm64FloatRegister, src MaxArm64FloatRegister, precision FloatPrecision)
	// FP indirect memory ops
	fpStoreIndirect(baseReg MaxArm64Register, offset MachineWord, src MaxArm64FloatRegister, precision FloatPrecision)
	fpLoadIndirect(dest MaxArm64FloatRegister, baseReg MaxArm64Register, offset MachineWord, precision FloatPrecision)
	// Indirect memory ops (GPR)
	storeIndirect(baseReg MaxArm64Register, offset MachineWord, srcReg MaxArm64Register, size MachineWord)
	loadIndirect(destReg MaxArm64Register, baseReg MaxArm64Register, offset MachineWord, size MachineWord)
	// Global variable ops
	globalLoad(dest MaxArm64Register, name ByteArray, size MachineWord)
	globalStore(name ByteArray, src MaxArm64Register, size MachineWord)
	globalLoadFloat(dest MaxArm64FloatRegister, name ByteArray, precision FloatPrecision)
	globalStoreFloat(name ByteArray, src MaxArm64FloatRegister, precision FloatPrecision)
	// LEA ops
	leaFromStack(dest MaxArm64Register, stackOffset MachineWord)
	leaRdata(dest MaxArm64Register, rdataLabel ByteArray)
	leaFuncAddr(dest MaxArm64Register, funcName ByteArray)
	// Conditional ops
	cset(dest MaxArm64Register, condition MaxArm64CondCode)
	csel(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register, condition MaxArm64CondCode)
	// Width conversion ops
	sxtw(dest MaxArm64Register, src MaxArm64Register)
	// Null-safe load
	nullSafeLoad(dest MaxArm64Register, baseReg MaxArm64Register, offset MachineWord)
end 'MaxArm64Op'

export typealias MaxArm64OpArray = Array with MaxArm64Op

function arm64SlotOffset(slotIndex VarSlot) returns StackSize
	return 16 + slotIndex * 8
end 'arm64SlotOffset'

export function maxArm64OpToString(op MaxArm64Op, blocks MlirBlockArray) returns String
	return match op 'toString'
		prologue(stackSize) gives "arm64.prologue stack_size={stackSize}"
		epilogue gives "arm64.epilogue\n    arm64.ret"
		movImm(dest, value) gives "arm64.mov {dest.name}, #{value}"
		strToSlot(slotIndex, src) gives "arm64.str {src.name}, [x29, #{arm64SlotOffset(slotIndex)}]"
		ldrFromSlot(dest, slotIndex) gives "arm64.ldr {dest.name}, [x29, #{arm64SlotOffset(slotIndex)}]"
		addRegs(dest, src1, src2) gives "arm64.add {dest.name}, {src1.name}, {src2.name}"
		subRegs(dest, src1, src2) gives "arm64.sub {dest.name}, {src1.name}, {src2.name}"
		mulRegs(dest, src1, src2) gives "arm64.mul {dest.name}, {src1.name}, {src2.name}"
		sdivRegs(dest, src1, src2) gives "arm64.sdiv {dest.name}, {src1.name}, {src2.name}"
		remRegs(dest, src1, src2) gives "arm64.msub {dest.name}, {src1.name}, {src2.name}"
		negReg(dest, src) gives "arm64.neg {dest.name}, {src.name}"
		mvnReg(dest, src) gives "arm64.mvn {dest.name}, {src.name}"
		andRegs(dest, src1, src2) gives "arm64.and {dest.name}, {src1.name}, {src2.name}"
		orrRegs(dest, src1, src2) gives "arm64.orr {dest.name}, {src1.name}, {src2.name}"
		eorRegs(dest, src1, src2) gives "arm64.eor {dest.name}, {src1.name}, {src2.name}"
		lslRegs(dest, src1, src2) gives "arm64.lslv {dest.name}, {src1.name}, {src2.name}"
		asrRegs(dest, src1, src2) gives "arm64.asrv {dest.name}, {src1.name}, {src2.name}"
		cmpRegs(src1, src2) gives "arm64.cmp {src1.name}, {src2.name}"
		cmpRegZero(src) gives "arm64.cmp {src.name}, #0"
		condBranch(condition, targetBlock) gives "arm64.b.{condition.name} {resolveBlockLabel(targetBlock, blocks: blocks)}"
		branch(targetBlock) gives "arm64.b {resolveBlockLabel(targetBlock, blocks: blocks)}"
		branchLink(linkTarget) gives "arm64.bl {String.from(linkTarget)}"
		printLiteral(data) gives "arm64.print_literal \"{String.from(data)}\""
		printInt gives "arm64.print_int"
		ret gives "arm64.ret"
		syscall(_, number, argSlots) gives "arm64.syscall {number}({formatVarSlotArgs(argSlots)})"
		iatCall(_, slotIndex, _) gives "arm64.call_import slot_{slotIndex}"
		globalAddr(_, name) gives "arm64.adrp_add_rdata x0, {String.from(name)}"
		stackAddrOp(_, targetSlot) gives "arm64.add x0, x29, #{arm64SlotOffset(targetSlot)}"
		storeByteOp gives "arm64.strb w2, [x0, #0]"
		loadByteOp gives "arm64.ldrb w0, [x0, #0]"
		memcpyOp gives "arm64.memcpy"
		movRegReg(dest, src) gives "arm64.mov {dest.name}, {src.name}"
		spillToStack(offset, src) gives "arm64.str {src.name}, [x29, #{offset}]"
		reloadFromStack(dest, offset) gives "arm64.ldr {dest.name}, [x29, #{offset}]"
		branchLinkReg(reg) gives "arm64.blr {reg.name}"
		subSpImm(value) gives "arm64.sub sp, sp, #{value}"
		addSpImm(value) gives "arm64.add sp, sp, #{value}"
		strToSpOffset(offset, src) gives "arm64.str {src.name}, [sp, #{offset}]"
		fmovRegReg(dest, src, _) gives "arm64.fmov {dest.name}, {src.name}"
		spillFpToStack(offset, src, _) gives "arm64.str {src.name}, [x29, #{offset}]"
		reloadFpFromStack(dest, offset, _) gives "arm64.ldr {dest.name}, [x29, #{offset}]"
		fmovToFloat(dest, src, _) gives "arm64.fmov {dest.name}, {src.name}"
		fmovToGpr(dest, src, _) gives "arm64.fmov {dest.name}, {src.name}"
		fpLoadRdata(dest, label, _) gives "arm64.ldr {dest.name}, [rdata+{String.from(label)}]"
		fadd(dest, src1, src2, _) gives "arm64.fadd {dest.name}, {src1.name}, {src2.name}"
		fsub(dest, src1, src2, _) gives "arm64.fsub {dest.name}, {src1.name}, {src2.name}"
		fmul(dest, src1, src2, _) gives "arm64.fmul {dest.name}, {src1.name}, {src2.name}"
		fdiv(dest, src1, src2, _) gives "arm64.fdiv {dest.name}, {src1.name}, {src2.name}"
		fsqrt(dest, src, _) gives "arm64.fsqrt {dest.name}, {src.name}"
		fabs(dest, src, _) gives "arm64.fabs {dest.name}, {src.name}"
		fneg(dest, src, _) gives "arm64.fneg {dest.name}, {src.name}"
		fcmp(src1, src2, _) gives "arm64.fcmp {src1.name}, {src2.name}"
		scvtf(dest, src, _) gives "arm64.scvtf {dest.name}, {src.name}"
		fcvtzs(dest, src, _) gives "arm64.fcvtzs {dest.name}, {src.name}"
		fcvt(dest, src, _) gives "arm64.fcvt {dest.name}, {src.name}"
		frintm(dest, src, _) gives "arm64.frintm {dest.name}, {src.name}"
		frintp(dest, src, _) gives "arm64.frintp {dest.name}, {src.name}"
		frintz(dest, src, _) gives "arm64.frintz {dest.name}, {src.name}"
		frintn(dest, src, _) gives "arm64.frintn {dest.name}, {src.name}"
		fpStoreIndirect(baseReg, offset, src, _) gives "arm64.str {src.name}, [{baseReg.name}, #{offset}]"
		fpLoadIndirect(dest, baseReg, offset, _) gives "arm64.ldr {dest.name}, [{baseReg.name}, #{offset}]"
		storeIndirect(baseReg, offset, srcReg, size) gives "arm64.str {srcReg.name}, [{baseReg.name}, #{offset}] ({size}b)"
		loadIndirect(destReg, baseReg, offset, size) gives "arm64.ldr {destReg.name}, [{baseReg.name}, #{offset}] ({size}b)"
		globalLoad(dest, name, _) gives "arm64.ldr {dest.name}, [{String.from(name)}]"
		globalStore(name, src, _) gives "arm64.str {src.name}, [{String.from(name)}]"
		globalLoadFloat(dest, name, _) gives "arm64.ldr {dest.name}, [{String.from(name)}]"
		globalStoreFloat(name, src, _) gives "arm64.str {src.name}, [{String.from(name)}]"
		leaFromStack(dest, offset) gives "arm64.add {dest.name}, x29, #{offset}"
		leaRdata(dest, label) gives "arm64.adrp+add {dest.name}, {String.from(label)}"
		leaFuncAddr(dest, funcName) gives "arm64.adrp+add {dest.name}, {String.from(funcName)}"
		cset(dest, condition) gives "arm64.cset {dest.name}, {condition.name}"
		csel(dest, src1, src2, condition) gives "arm64.csel {dest.name}, {src1.name}, {src2.name}, {condition.name}"
		sxtw(dest, src) gives "arm64.sxtw {dest.name}, {src.name}"
		nullSafeLoad(dest, baseReg, offset) gives "arm64.null_safe_load {dest.name}, [{baseReg.name}, #{offset}]"
	end 'toString'
end 'maxArm64OpToString'

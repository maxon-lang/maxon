// MaxArm64 Dialect — ARM64 machine instructions.

export union MaxArm64Register
    x0
    x1
    x2
    x3
    x4
    x5
    x6
    x7
    x8
    x29
    x30
    sp
end 'MaxArm64Register'

export union MaxArm64CondCode
    eq
    ne
    lt
    le
    gt
    ge
end 'MaxArm64CondCode'

export union MaxArm64Op
    prologue(stackSize StackSize)
    epilogue
    movImm(dest MaxArm64Register, value MachineWord)
    strToSlot(slotIndex VarSlot, src MaxArm64Register)
    ldrFromSlot(dest MaxArm64Register, slotIndex VarSlot)
    addRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    subRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    mulRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    sdivRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    remRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    negReg(dest MaxArm64Register, src MaxArm64Register)
    mvnReg(dest MaxArm64Register, src MaxArm64Register)
    andRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    orrRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    eorRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    lslRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    asrRegs(dest MaxArm64Register, src1 MaxArm64Register, src2 MaxArm64Register)
    cmpRegs(src1 MaxArm64Register, src2 MaxArm64Register)
    cmpRegZero(src MaxArm64Register)
    condBranch(condition MaxArm64CondCode, targetBlock BlockId)
    branch(targetBlock BlockId)
    branchLink(target ByteArray)
    printLiteral(data ByteArray)
    printInt
    ret
    // SysOp lowering: Linux ARM64 syscall (svc #0)
    syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray)
    // SysOp lowering: indirect call through IAT slot
    iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray)
    // SysOp lowering: data island + ADR for named global data
    globalAddr(resultSlot VarSlot, name ByteArray)
    // SysOp lowering: address of a stack slot
    stackAddrOp(resultSlot VarSlot, targetSlot VarSlot)
    // SysOp lowering: strb byte at base+offset
    storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot)
    // SysOp lowering: ldrb byte from base+offset
    loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot)
    // SysOp lowering: byte-by-byte copy
    memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot)
end 'MaxArm64Op'

export typealias MaxArm64OpArray = Array with MaxArm64Op

export function printArm64Register(reg MaxArm64Register) returns String
    return match reg 'print'
        MaxArm64Register.x0 gives "x0"
        MaxArm64Register.x1 gives "x1"
        MaxArm64Register.x2 gives "x2"
        MaxArm64Register.x3 gives "x3"
        MaxArm64Register.x4 gives "x4"
        MaxArm64Register.x5 gives "x5"
        MaxArm64Register.x6 gives "x6"
        MaxArm64Register.x7 gives "x7"
        MaxArm64Register.x8 gives "x8"
        MaxArm64Register.x29 gives "x29"
        MaxArm64Register.x30 gives "x30"
        MaxArm64Register.sp gives "sp"
    end 'print'
end 'printArm64Register'

function printArm64CondCode(cond MaxArm64CondCode) returns String
    return match cond 'print'
        MaxArm64CondCode.eq gives "eq"
        MaxArm64CondCode.ne gives "ne"
        MaxArm64CondCode.lt gives "lt"
        MaxArm64CondCode.le gives "le"
        MaxArm64CondCode.gt gives "gt"
        MaxArm64CondCode.ge gives "ge"
    end 'print'
end 'printArm64CondCode'

function arm64SlotOffset(slotIndex VarSlot) returns StackSize
    return (slotIndex + 1) * 8
end 'arm64SlotOffset'

export function printMaxArm64Op(op MaxArm64Op, blocks MlirBlockArray) returns String
    return match op 'print'
        prologue(stackSize) gives "arm64.prologue stack_size={stackSize}"
        MaxArm64Op.epilogue gives "arm64.epilogue"
        movImm(dest, value) gives "arm64.mov {printArm64Register(dest)}, #{value}"
        strToSlot(slotIndex, src) gives "arm64.str {printArm64Register(src)}, [x29, #-{arm64SlotOffset(slotIndex)}]"
        ldrFromSlot(dest, slotIndex) gives "arm64.ldr {printArm64Register(dest)}, [x29, #-{arm64SlotOffset(slotIndex)}]"
        addRegs(dest, src1, src2) gives "arm64.add {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        subRegs(dest, src1, src2) gives "arm64.sub {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        mulRegs(dest, src1, src2) gives "arm64.mul {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        sdivRegs(dest, src1, src2) gives "arm64.sdiv {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        remRegs(dest, src1, src2) gives "arm64.msub {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        negReg(dest, src) gives "arm64.neg {printArm64Register(dest)}, {printArm64Register(src)}"
        mvnReg(dest, src) gives "arm64.mvn {printArm64Register(dest)}, {printArm64Register(src)}"
        andRegs(dest, src1, src2) gives "arm64.and {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        orrRegs(dest, src1, src2) gives "arm64.orr {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        eorRegs(dest, src1, src2) gives "arm64.eor {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        lslRegs(dest, src1, src2) gives "arm64.lslv {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        asrRegs(dest, src1, src2) gives "arm64.asrv {printArm64Register(dest)}, {printArm64Register(src1)}, {printArm64Register(src2)}"
        cmpRegs(src1, src2) gives "arm64.cmp {printArm64Register(src1)}, {printArm64Register(src2)}"
        cmpRegZero(src) gives "arm64.cmp {printArm64Register(src)}, #0"
        condBranch(condition, targetBlock) gives printArm64CondBranch(condition, targetBlock: targetBlock, blocks: blocks)
        branch(targetBlock) gives printArm64Branch(targetBlock, blocks: blocks)
        branchLink(linkTarget) gives "arm64.bl {String.from(linkTarget)}"
        printLiteral(data) gives "arm64.print_literal \"{String.from(data)}\""
        MaxArm64Op.printInt gives "arm64.print_int"
        MaxArm64Op.ret gives "arm64.ret"
        syscall(_, number, argSlots) gives "arm64.syscall {number}({formatVarSlotArgs(argSlots)})"
        iatCall(_, slotIndex, _) gives "arm64.call_import slot_{slotIndex}"
        globalAddr(_, name) gives "arm64.adrp_add_rdata {printArm64Register(MaxArm64Register.x0)}, {String.from(name)}"
        stackAddrOp(_, targetSlot) gives "arm64.add x0, x29, #-{arm64SlotOffset(targetSlot)}"
        storeByteOp gives "arm64.strb w2, [x0, #0]"
        loadByteOp gives "arm64.ldrb w0, [x0, #0]"
        memcpyOp gives "arm64.memcpy"
    end 'print'
end 'printMaxArm64Op'

function printArm64CondBranch(condition MaxArm64CondCode, targetBlock BlockId, blocks MlirBlockArray) returns String
    let condStr = printArm64CondCode(condition)
    let label = resolveBlockLabel(targetBlock, blocks: blocks)
    return "arm64.b.{condStr} {label}"
end 'printArm64CondBranch'

function printArm64Branch(targetBlock BlockId, blocks MlirBlockArray) returns String
    let label = resolveBlockLabel(targetBlock, blocks: blocks)
    return "arm64.b {label}"
end 'printArm64Branch'

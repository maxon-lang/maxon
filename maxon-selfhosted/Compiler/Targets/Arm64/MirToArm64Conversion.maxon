// Mid dialect -> Arm64 dialect conversion.
// Pure instruction selection: emits virtual registers (Arm64VReg.virtual) only.
// Register allocation, prologue/epilogue, and stack frame sizing are handled
// by standalone passes that run after this one.

export function lowerMirToArm64(module MirModule, target Target, globalData GlobalDataTable, stdlibFunctions ObjectFunctionArray) returns TargetModule
	logDebug(LogCategory.ir, message: () gives "Lowering Mid to Arm64 dialect")
	let osDesc = makeOsDescriptor(target)

	var targetModule = TargetModule.create(CpuArch.arm64)

	for func in module.functions 'eachFunc'
		logTrace(LogCategory.ir, message: () gives "mid-to-arm64: === lowering function: {func.name} ===")
		lowerFunctionToArm64(module, targetModule: targetModule, srcFunc: func, osDesc: osDesc, allFunctions: module.functions, globalData: globalData, stdlibFunctions: stdlibFunctions)
	end 'eachFunc'

	return targetModule
end 'lowerMirToArm64'

function lowerFunctionToArm64(module MirModule, targetModule TargetModule, srcFunc IrFunction, osDesc OsDescriptor, allFunctions IrFunctionArray, globalData GlobalDataTable, stdlibFunctions ObjectFunctionArray)
	// Phase 1: Compute variable stack space from memref slots.
	let loadedSlots = scanLoadedSlots(module, func: srcFunc)
	var liveSlotCount = 0
	for slot in loadedSlots 'countLive'
		if slot + 1 > liveSlotCount 'updateMax'
			liveSlotCount = slot + 1
		end 'updateMax'
	end 'countLive'

	var sysOpTempCount = 0
	for blockRef in srcFunc.blockRefs 'countSysTemps'
		let block = try module.blocks.get(blockRef) otherwise 'skip'
			continue
		end 'skip'
		if isMirDivergingBlock(module, block: block) 'skipDiverging'
			continue
		end 'skipDiverging'
		for packed in block.opRefs 'countOp'
			sysOpTempCount = sysOpTempCount + sysOpTempSlotCountArm64(module, opIdx: packed)
		end 'countOp'
	end 'countSysTemps'

	let precomputedSlotCount = liveSlotCount + sysOpTempCount
	var nextTempSlot = liveSlotCount
	var valueSlots = ValueSlotMap.create()

	// Create the destination IrFunction and its blocks up front.
	var targetFunc = IrFunction.clone(srcFunc)
	var blockByBlockId = IrBlockArray.create()
	for srcBlockRef in srcFunc.blockRefs 'createBlocks'
		let srcBlock = try module.blocks.get(srcBlockRef) otherwise 'skipCreate'
			continue
		end 'skipCreate'
		let dstIdx = targetModule.blocks.count()
		var dstBlock = IrBlock.create(srcBlock.id, label: srcBlock.label)
		for srcArg in srcBlock.blockArgs 'copyArgs'
			dstBlock.blockArgs.push(IrBlockArg.create(srcArg.valueId, argType: srcArg.argType))
		end 'copyArgs'
		targetModule.blocks.push(dstBlock)
		targetFunc.blockRefs.append(dstIdx)
		while blockByBlockId.count() <= srcBlock.id 'growMap'
			blockByBlockId.push(IrBlock.create(0, label: ""))
		end 'growMap'
		blockByBlockId.set(srcBlock.id, value: dstBlock)
	end 'createBlocks'

	// Phase 2: Lower all blocks.
	for blockRef in srcFunc.blockRefs 'eachBlock'
		let srcBlock = try module.blocks.get(blockRef) otherwise 'skipOp'
			continue
		end 'skipOp'
		var dstBlock = try blockByBlockId.get(srcBlock.id) otherwise 'noDst'
			continue
		end 'noDst'

		let condBrJumpKind = determineJumpKindInBlock(module, block: srcBlock)

		// Stash outgoing branch args on the target block's edges.
		if srcBlock.hasTerminator 'stashEdges'
			stashBranchEdgesArm64(module, srcTerminator: srcBlock.terminator, dstBlock: dstBlock)
		end 'stashEdges'

		// Lower each op in the source block
		for packed in srcBlock.opRefs 'eachOp'
			nextTempSlot = lowerIrOpArm64(module, target: targetModule, opIdx: packed, dstBlock: dstBlock, osDesc: osDesc, allFunctions: allFunctions, valueSlots: valueSlots, nextTempSlot: nextTempSlot, globalData: globalData, funcParamTypes: srcFunc.paramTypes, stdlibFunctions: stdlibFunctions)
		end 'eachOp'

		// Lower terminator
		if srcBlock.hasTerminator 'hasTerm'
			lowerTerminatorArm64(module, target: targetModule, srcTerminator: srcBlock.terminator, dstBlock: dstBlock, returnType: srcFunc.returnType, jumpKind: condBrJumpKind)
			setLastOpAsTerminatorArm64(dstBlock)
		end 'hasTerm'
	end 'eachBlock'

	// Remove unconditional branches that fall through to the next block.
	eliminateFallthroughJumpsArm64(targetModule, func: targetFunc)

	// Record the actual total slot count after lowering.
	let actualSlotCount = nextTempSlot
	if actualSlotCount > precomputedSlotCount 'useActual'
		targetFunc.varSlotCount = actualSlotCount
	end 'useActual' else 'usePrecomputed'
		targetFunc.varSlotCount = precomputedSlotCount
	end 'usePrecomputed'

	targetModule.functions.push(targetFunc)
end 'lowerFunctionToArm64'

// Populate dstBlock.branchEdges with the outgoing branch arg lists from the
// MIR terminator. The register allocator's SSA destruction pass uses these
// for parallel-copy resolution at CFG edges.
function stashBranchEdgesArm64(module MirModule, srcTerminator OpIndex, dstBlock IrBlock)
	let mirOp = try module.ops.get(srcTerminator) otherwise 'noMir'
		return
	end 'noMir'
	stashMirEdgesArm64(mirOp, dstBlock: dstBlock)
end 'stashBranchEdgesArm64'

function stashMirEdgesArm64(op MirOp, dstBlock IrBlock)
	match op 'extract'
		branch(target, argIds) then dstBlock.branchEdges.push(BranchEdge.create(target, argIds: argIds))
		condBranch(_, thenTarget, thenArgs, elseTarget, elseArgs) then stashCondBrEdgesArm64(dstBlock, thenTarget: thenTarget, thenArgs: thenArgs, elseTarget: elseTarget, elseArgs: elseArgs)
		movImm to cmp then break 'extract'
		call to loadByte then break 'extract'
	end 'extract'
end 'stashMirEdgesArm64'

function stashCondBrEdgesArm64(dstBlock IrBlock, thenTarget BlockId, thenArgs ValueIdArray, elseTarget BlockId, elseArgs ValueIdArray)
	dstBlock.branchEdges.push(BranchEdge.create(thenTarget, argIds: thenArgs))
	dstBlock.branchEdges.push(BranchEdge.create(elseTarget, argIds: elseArgs))
end 'stashCondBrEdgesArm64'

// Target-phase fallthrough elimination for Arm64. Runs after the trailing
// branch has been promoted into block.terminator by setLastOpAsTerminatorArm64.
// When the terminator is an unconditional branch to the next block in layout
// order, we eliminate it. We look at the last op in opRefs:
//   - If it's a conditional branch, promote it to the terminator slot so the
//     cond-br pattern detection in destroySSA still recognizes this block as
//     having a conditional branch.
//   - Otherwise (a regular ALU op or empty), just clear hasTerminator. The
//     block has no real terminator anymore, but still has its branchEdges
//     attached for parallel-copy resolution at the fall-through edge.
// Outgoing block arguments are tracked in block.branchEdges independently of
// the terminator op, so dropping the redundant branch is always safe for the
// register allocator.
function eliminateFallthroughJumpsArm64(module TargetModule, func IrFunction)
	let blockCount = func.blockRefs.count()
	var i = 0
	while i < blockCount - 1 'eachBlock'
		let blockRef = try func.blockRefs.get(i) otherwise 'skipBlock'
			i = i + 1
			continue
		end 'skipBlock'
		var block = try module.blocks.get(blockRef) otherwise 'skipBlock2'
			i = i + 1
			continue
		end 'skipBlock2'
		if not block.hasTerminator 'noTerm'
			i = i + 1
			continue
		end 'noTerm'
		let nextBlockRef = try func.blockRefs.get(i + 1) otherwise 'skipNext'
			i = i + 1
			continue
		end 'skipNext'
		let nextBlock = try module.blocks.get(nextBlockRef) otherwise 'skipNext2'
			i = i + 1
			continue
		end 'skipNext2'
		let termOp = try module.arm64Ops.get(block.terminator) otherwise 'noTerm2'
			i = i + 1
			continue
		end 'noTerm2'
		let targetId = match termOp 'check'
			branch(blk) gives blk
			prologue to condBranch gives -1
			branchLink to nullSafeLoad gives -1
		end 'check'

		if targetId >= 0 and targetId == nextBlock.id 'isFallthrough'
			block.hasTerminator = false
			// Only promote a trailing conditional branch back into the terminator
			// slot. Promoting an arbitrary ALU op here would let it execute AFTER
			// any parallel-copy moves the SSA destruction pass appends, breaking
			// the moves' values.
			let lastIdx = block.opRefs.count() - 1
			if lastIdx >= 0 'hasOps'
				let lastPacked = try block.opRefs.get(lastIdx) otherwise 'noLast'
					i = i + 1
					continue
				end 'noLast'
				if terminatorIsConditionalBranch(module, packed: lastPacked) 'isCondBr'
					try block.opRefs.removeLast() otherwise ignore
					block.terminator = lastPacked
					block.hasTerminator = true
				end 'isCondBr'
			end 'hasOps'
		end 'isFallthrough'
		i = i + 1
	end 'eachBlock'
end 'eliminateFallthroughJumpsArm64'

// ============================================================
// Slot scanning helpers
// ============================================================

// Count temp slots needed by MIR system ops
function sysOpTempSlotCountArm64(module MirModule, opIdx OpIndex) returns SlotIndex
	let mirOp = try module.ops.get(opIdx) otherwise 'noResult'
		return 0
	end 'noResult'
	return mirTempCountArm64(mirOp)
end 'sysOpTempSlotCountArm64'

function mirTempCountArm64(op MirOp) returns SlotIndex
	return match op 'check'
		syscall gives 1
		iatCall gives 1
		globalAddr gives 1
		funcAddr gives 1
		loadFramePtr gives 1
		stackSlotAddr gives 1
		storeByte gives 3
		loadByte gives 3
		memcpy gives 3
		osExit gives 1
		osWrite gives 6
		osWriteErr gives 6
		movImm to storeSlot gives 0
	end 'check'
end 'mirTempCountArm64'

// Pop the last op from the block and set it as the terminator.
function setLastOpAsTerminatorArm64(block IrBlock)
	let lastPacked = try block.opRefs.removeLast() otherwise 'noOps'
		return
	end 'noOps'
	block.terminator = lastPacked
	block.hasTerminator = true
end 'setLastOpAsTerminatorArm64'

// ============================================================
// Op dispatch
// ============================================================

function lowerIrOpArm64(module MirModule, target TargetModule, opIdx OpIndex, dstBlock IrBlock, osDesc OsDescriptor, allFunctions IrFunctionArray, valueSlots ValueSlotMap, nextTempSlot SlotIndex, globalData GlobalDataTable, funcParamTypes StdTypeArray, stdlibFunctions ObjectFunctionArray) returns SlotIndex
	var result = nextTempSlot
	let mirOp = try module.ops.get(opIdx) otherwise 'noMir'
		return result
	end 'noMir'
	result = lowerMirOpArm64(target, op: mirOp, dstBlock: dstBlock, osDesc: osDesc, allFunctions: allFunctions, valueSlots: valueSlots, nextTempSlot: nextTempSlot, globalData: globalData, funcParamTypes: funcParamTypes, stdlibFunctions: stdlibFunctions)
	return result
end 'lowerIrOpArm64'

// ============================================================
// MIR op lowering — pure virtual register emission
// ============================================================

function lowerMirOpArm64(target TargetModule, op MirOp, dstBlock IrBlock, osDesc OsDescriptor, allFunctions IrFunctionArray, valueSlots ValueSlotMap, nextTempSlot SlotIndex, globalData GlobalDataTable, funcParamTypes StdTypeArray, stdlibFunctions ObjectFunctionArray) returns SlotIndex
	var result = nextTempSlot
	match op 'dispatch'
		movImm(resultId, value, isFloat) then lowerMovImmArm64(target, resultId: resultId, value: value, isFloat: isFloat, dstBlock: dstBlock, globalData: globalData)
		movReg(resultId, srcId) then appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: Arm64VReg.virtual(srcId)))
		binOp(resultId, leftId, rightId, opcode) then lowerBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, opcode: opcode, dstBlock: dstBlock)
		unaryOp(resultId, operandId, opcode) then lowerUnaryOpArm64(target, resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		cmp(resultId, leftId, rightId, predicate) then lowerCmpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
		condBranch then result = nextTempSlot  // handled as terminator
		branch then result = nextTempSlot  // handled as terminator
		call(resultId, callee, argIds) then lowerCallArm64(target, resultId: resultId, callee: callee, argIds: argIds, dstBlock: dstBlock, allFunctions: allFunctions, stdlibFunctions: stdlibFunctions)
		indirectCall(resultId, calleeId, argIds) then lowerIndirectCallArm64(target, resultId: resultId, calleeId: calleeId, argIds: argIds, dstBlock: dstBlock)
		ret then result = nextTempSlot  // handled as terminator
		param(resultId, paramIndex, paramType) then lowerParamArm64(target, resultId: resultId, paramIndex: paramIndex, paramType: paramType, dstBlock: dstBlock, funcParamTypes: funcParamTypes)
		load(resultId, baseId, offset) then appendArm64Op(target, block: dstBlock, op: Arm64Op.loadIndirect(Arm64VReg.virtual(resultId), baseReg: Arm64VReg.virtual(baseId), offset: offset, size: 8))
		store(valueId, baseId, offset) then appendArm64Op(target, block: dstBlock, op: Arm64Op.storeIndirect(Arm64VReg.virtual(baseId), offset: offset, srcReg: Arm64VReg.virtual(valueId), size: 8))
		loadSlot(resultId, slotId) then appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: slotId))
		storeSlot(slotId, valueId) then appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(slotId, src: Arm64VReg.virtual(valueId)))
		stackSlotAddr to loadByte then result = lowerMirSysOpArm64(target, op: op, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
	end 'dispatch'
	return result
end 'lowerMirOpArm64'

// ============================================================
// Constants & moves
// ============================================================

function lowerMovImmArm64(target TargetModule, resultId ValueId, value ParsedInt, isFloat bool, dstBlock IrBlock, globalData GlobalDataTable)
	if isFloat 'floatImm'
		lowerFloatConstArm64(target, resultId: resultId, rawBits: value, dstBlock: dstBlock, globalData: globalData)
	end 'floatImm' else 'intImm'
		appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(Arm64VReg.virtual(resultId), value: value))
	end 'intImm'
end 'lowerMovImmArm64'

// Float constant: load directly into FP register via literal pool data island.
function lowerFloatConstArm64(target TargetModule, resultId ValueId, rawBits ParsedInt, dstBlock IrBlock, globalData GlobalDataTable)
	let label = registerFloatConstant(rawBits, globalData: globalData)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.fpLoadRdata(Arm64FpVReg.virtual(resultId), rdataLabel: label, precision: FloatPrecision.f64))
end 'lowerFloatConstArm64'

// ============================================================
// Binary operations
// ============================================================

function lowerBinOpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode, dstBlock IrBlock)
	match opcode 'lower'
		addI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.add, dstBlock: dstBlock)
		subI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.sub, dstBlock: dstBlock)
		mulI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.mul, dstBlock: dstBlock)
		divI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.div, dstBlock: dstBlock)
		remI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.rem, dstBlock: dstBlock)
		andI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitAnd, dstBlock: dstBlock)
		orI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitOr, dstBlock: dstBlock)
		xorI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.bitXor, dstBlock: dstBlock)
		shlI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.shl, dstBlock: dstBlock)
		shrI64 then lowerIntBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64BinKind.shr, dstBlock: dstBlock)
		addF64 then lowerFloatBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.add, dstBlock: dstBlock)
		subF64 then lowerFloatBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.sub, dstBlock: dstBlock)
		mulF64 then lowerFloatBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.mul, dstBlock: dstBlock)
		divF64 then lowerFloatBinOpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, kind: Arm64FloatBinKind.div, dstBlock: dstBlock)
	end 'lower'
end 'lowerBinOpArm64'

// ARM64 binary operation kinds
union Arm64BinKind
	add
	sub
	mul
	div
	rem
	bitAnd
	bitOr
	bitXor
	shl
	shr
end 'Arm64BinKind'

// ARM64 has 3-operand form: dest = src1 OP src2 (non-destructive).
function lowerIntBinOpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, kind Arm64BinKind, dstBlock IrBlock)
	let dest = Arm64VReg.virtual(resultId)
	let lhs = Arm64VReg.virtual(leftId)
	let rhs = Arm64VReg.virtual(rightId)
	match kind 'emit'
		add then appendArm64Op(target, block: dstBlock, op: Arm64Op.addRegs(dest, src1: lhs, src2: rhs))
		sub then appendArm64Op(target, block: dstBlock, op: Arm64Op.subRegs(dest, src1: lhs, src2: rhs))
		mul then appendArm64Op(target, block: dstBlock, op: Arm64Op.mulRegs(dest, src1: lhs, src2: rhs))
		div then appendArm64Op(target, block: dstBlock, op: Arm64Op.sdivRegs(dest, src1: lhs, src2: rhs))
		rem then appendArm64Op(target, block: dstBlock, op: Arm64Op.remRegs(dest, src1: lhs, src2: rhs))
		bitAnd then appendArm64Op(target, block: dstBlock, op: Arm64Op.andRegs(dest, src1: lhs, src2: rhs))
		bitOr then appendArm64Op(target, block: dstBlock, op: Arm64Op.orrRegs(dest, src1: lhs, src2: rhs))
		bitXor then appendArm64Op(target, block: dstBlock, op: Arm64Op.eorRegs(dest, src1: lhs, src2: rhs))
		shl then appendArm64Op(target, block: dstBlock, op: Arm64Op.lslRegs(dest, src1: lhs, src2: rhs))
		shr then appendArm64Op(target, block: dstBlock, op: Arm64Op.lsrRegs(dest, src1: lhs, src2: rhs))
	end 'emit'
end 'lowerIntBinOpArm64'

// Float binary operation kinds
union Arm64FloatBinKind
	add
	sub
	mul
	div
end 'Arm64FloatBinKind'

// Float binary op: both operands as FP virtuals, result in FP virtual.
// ARM64 FP ops are 3-operand non-destructive.
function lowerFloatBinOpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, kind Arm64FloatBinKind, dstBlock IrBlock)
	let dest = Arm64FpVReg.virtual(resultId)
	let lhs = Arm64FpVReg.virtual(leftId)
	let rhs = Arm64FpVReg.virtual(rightId)
	match kind 'emit'
		add then appendArm64Op(target, block: dstBlock, op: Arm64Op.fadd(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64))
		sub then appendArm64Op(target, block: dstBlock, op: Arm64Op.fsub(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64))
		mul then appendArm64Op(target, block: dstBlock, op: Arm64Op.fmul(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64))
		div then appendArm64Op(target, block: dstBlock, op: Arm64Op.fdiv(dest, src1: lhs, src2: rhs, precision: FloatPrecision.f64))
	end 'emit'
end 'lowerFloatBinOpArm64'

// ============================================================
// Unary operations
// ============================================================

function lowerUnaryOpArm64(target TargetModule, resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock IrBlock)
	match opcode 'lower'
		negI64 then lowerIntUnaryArm64(target, resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		bitNotI64 then lowerIntUnaryArm64(target, resultId: resultId, operandId: operandId, opcode: opcode, dstBlock: dstBlock)
		fpToSiI64 then appendArm64Op(target, block: dstBlock, op: Arm64Op.fcvtzs(Arm64VReg.virtual(resultId), src: Arm64FpVReg.virtual(operandId), precision: FloatPrecision.f64))
		siToFpF64 then appendArm64Op(target, block: dstBlock, op: Arm64Op.scvtf(Arm64FpVReg.virtual(resultId), src: Arm64VReg.virtual(operandId), precision: FloatPrecision.f64))
	end 'lower'
end 'lowerUnaryOpArm64'

// ARM64 unary: 2-operand form dest = OP src
function lowerIntUnaryArm64(target TargetModule, resultId ValueId, operandId ValueId, opcode MirUnaryOpcode, dstBlock IrBlock)
	let dest = Arm64VReg.virtual(resultId)
	let src = Arm64VReg.virtual(operandId)
	match opcode 'emit'
		negI64 then appendArm64Op(target, block: dstBlock, op: Arm64Op.negReg(dest, src: src))
		bitNotI64 then appendArm64Op(target, block: dstBlock, op: Arm64Op.mvnReg(dest, src: src))
		fpToSiI64 to siToFpF64 then panic("lowerIntUnaryArm64: unexpected float opcode")
	end 'emit'
end 'lowerIntUnaryArm64'

// ============================================================
// Compare
// ============================================================

function lowerCmpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
	match predicate 'kind'
		eq to ugt then lowerIntCmpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
		feq to fge then lowerFloatCmpArm64(target, resultId: resultId, leftId: leftId, rightId: rightId, predicate: predicate, dstBlock: dstBlock)
	end 'kind'
end 'lowerCmpArm64'

function lowerIntCmpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.cmpRegs(Arm64VReg.virtual(leftId), src2: Arm64VReg.virtual(rightId)))
	let condCode = mirPredicateToArm64CondCode(predicate)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.cset(Arm64VReg.virtual(resultId), condition: condCode))
end 'lowerIntCmpArm64'

function lowerFloatCmpArm64(target TargetModule, resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate, dstBlock IrBlock)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.fcmp(Arm64FpVReg.virtual(leftId), src2: Arm64FpVReg.virtual(rightId), precision: FloatPrecision.f64))
	let condCode = mirPredicateToArm64CondCode(predicate)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.cset(Arm64VReg.virtual(resultId), condition: condCode))
end 'lowerFloatCmpArm64'

function mirPredicateToArm64CondCode(predicate MirCmpPredicate) returns Arm64CondCode
	return match predicate 'map'
		eq gives Arm64CondCode.eq
		ne gives Arm64CondCode.ne
		lt gives Arm64CondCode.lt
		le gives Arm64CondCode.le
		gt gives Arm64CondCode.gt
		ge gives Arm64CondCode.ge
		ugt gives Arm64CondCode.hi
		feq gives Arm64CondCode.eq
		fne gives Arm64CondCode.ne
		flt gives Arm64CondCode.lt
		fle gives Arm64CondCode.le
		fgt gives Arm64CondCode.gt
		fge gives Arm64CondCode.ge
	end 'map'
end 'mirPredicateToArm64CondCode'

// ============================================================
// Call
// ============================================================

// Internal calling convention: GPR args in x0-x7, FP args in d0-d7.
// GPR and FP use separate index counters.
function getArm64CallConvGpr(index VarSlot) returns Arm64Register
	let regs = [Arm64Register.x0, Arm64Register.x1, Arm64Register.x2, Arm64Register.x3, Arm64Register.x4, Arm64Register.x5, Arm64Register.x6, Arm64Register.x7]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getArm64CallConvGpr: param index {index} exceeds register count")
	end 'outOfRange'
end 'getArm64CallConvGpr'

function getArm64CallConvFp(index VarSlot) returns Arm64FloatRegister
	let regs = [Arm64FloatRegister.d0, Arm64FloatRegister.d1, Arm64FloatRegister.d2, Arm64FloatRegister.d3, Arm64FloatRegister.d4, Arm64FloatRegister.d5, Arm64FloatRegister.d6, Arm64FloatRegister.d7]
	return try regs.get(index) otherwise 'outOfRange'
		panic("getArm64CallConvFp: FP param index {index} exceeds register count")
	end 'outOfRange'
end 'getArm64CallConvFp'

function lowerCallArm64(target TargetModule, resultId ValueId, callee String, argIds ValueIdArray, dstBlock IrBlock, allFunctions IrFunctionArray, stdlibFunctions ObjectFunctionArray)
	// Look up callee's param types to route float args to D registers
	let paramTypes = lookupFuncParamTypes(callee, allFunctions: allFunctions, stdlibFunctions: stdlibFunctions)

	// Move args to calling convention registers with separate GPR/FP counters
	var argIdx = 0
	var gprIdx = 0
	var fpIdx = 0
	while argIdx < argIds.count() 'moveArgs'
		let argId = try argIds.get(argIdx) otherwise 'skipArg'
			argIdx = argIdx + 1
			continue
		end 'skipArg'
		let paramType = try paramTypes.get(argIdx) otherwise StdType.i64
		if stdTypeIsFloat(paramType) and fpIdx < 8 'fpRegArg'
			let fpReg = getArm64CallConvFp(fpIdx)
			appendArm64Op(target, block: dstBlock, op: Arm64Op.fmovRegReg(arm64PhysFpReg(fpReg), src: Arm64FpVReg.virtual(argId), precision: FloatPrecision.f64))
			fpIdx = fpIdx + 1
		end 'fpRegArg' else if gprIdx < 8 'gprRegArg'
			let ccReg = getArm64CallConvGpr(gprIdx)
			appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(arm64PhysReg(ccReg), src: Arm64VReg.virtual(argId)))
			gprIdx = gprIdx + 1
		end 'gprRegArg'
		argIdx = argIdx + 1
	end 'moveArgs'

	// Emit the call
	appendArm64Op(target, block: dstBlock, op: Arm64Op.branchLink(callee))

	// Move return value from X0/D0 to virtual result. Void-returning callees
	// have no result to capture.
	let calleeReturnType = lookupFuncReturnStdType(callee, allFunctions: allFunctions, stdlibFunctions: stdlibFunctions)
	match calleeReturnType 'capture'
		void then break 'capture'
		value(inner) then emitArm64CallResultCapture(target, resultId: resultId, dstBlock: dstBlock, resultType: inner)
	end 'capture'
end 'lowerCallArm64'

function emitArm64CallResultCapture(target TargetModule, resultId ValueId, dstBlock IrBlock, resultType StdType)
	if stdTypeIsFloat(resultType) 'floatResult'
		appendArm64Op(target, block: dstBlock, op: Arm64Op.fmovRegReg(Arm64FpVReg.virtual(resultId), src: arm64PhysFpReg(Arm64FloatRegister.d0), precision: FloatPrecision.f64))
	end 'floatResult' else 'intResult'
		appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x0)))
	end 'intResult'
end 'emitArm64CallResultCapture'

function lowerIndirectCallArm64(target TargetModule, resultId ValueId, calleeId ValueId, argIds ValueIdArray, dstBlock IrBlock)
	// Move args to calling convention registers
	var argIdx = 0
	while argIdx < argIds.count() and argIdx < 8 'moveArgs'
		let argId = try argIds.get(argIdx) otherwise 'skipArg'
			argIdx = argIdx + 1
			continue
		end 'skipArg'
		let ccReg = getArm64CallConvGpr(argIdx)
		appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(arm64PhysReg(ccReg), src: Arm64VReg.virtual(argId)))
		argIdx = argIdx + 1
	end 'moveArgs'
	if argIds.count() > 8 'tooManyArgs'
		panic("lowerIndirectCallArm64: more than 8 arguments not yet supported (got {argIds.count()})")
	end 'tooManyArgs'

	// Indirect call through the callee virtual register
	appendArm64Op(target, block: dstBlock, op: Arm64Op.branchLinkReg(Arm64VReg.virtual(calleeId)))

	// Move return value from X0
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x0)))
end 'lowerIndirectCallArm64'

// ============================================================
// Param
// ============================================================

// Move from calling convention register to virtual register.
// Float params arrive in D registers, int params in X registers.
function lowerParamArm64(target TargetModule, resultId ValueId, paramIndex VarSlot, paramType StdType, dstBlock IrBlock, funcParamTypes StdTypeArray)
	let slotIdx = computeParamSlotIndex(paramIndex, paramTypes: funcParamTypes)
	if stdTypeIsFloat(paramType) and slotIdx < 8 'fpRegParam'
		let fpReg = getArm64CallConvFp(slotIdx)
		appendArm64Op(target, block: dstBlock, op: Arm64Op.fmovRegReg(Arm64FpVReg.virtual(resultId), src: arm64PhysFpReg(fpReg), precision: FloatPrecision.f64))
	end 'fpRegParam' else if slotIdx < 8 'gprRegParam'
		let ccReg = getArm64CallConvGpr(slotIdx)
		appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(ccReg)))
	end 'gprRegParam'
end 'lowerParamArm64'

// ============================================================
// Memory (load/store indirect)
// ============================================================

// ============================================================
// Terminators
// ============================================================

function lowerTerminatorArm64(module MirModule, target TargetModule, srcTerminator OpIndex, dstBlock IrBlock, returnType StdReturnType, jumpKind JumpKind)
	let mirOp = try module.ops.get(srcTerminator) otherwise 'noMir'
		return
	end 'noMir'
	lowerMirTerminatorArm64(target, op: mirOp, dstBlock: dstBlock, returnType: returnType, jumpKind: jumpKind)
end 'lowerTerminatorArm64'

function lowerMirTerminatorArm64(targetMod TargetModule, op MirOp, dstBlock IrBlock, returnType StdReturnType, jumpKind JumpKind)
	match op 'lower'
		condBranch(condId, thenTarget, _, elseTarget, _) then lowerCondBrArm64(targetMod, condId: condId, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock, jumpKind: jumpKind)
		branch(target, _) then lowerBrWithArgsArm64(targetMod, target: target, dstBlock: dstBlock)
		ret(retValId) then lowerReturnArm64(targetMod, retValId: retValId, dstBlock: dstBlock, returnType: returnType)
		movImm to cmp then break 'lower'
		call to indirectCall then break 'lower'
		param to loadByte then break 'lower'
	end 'lower'
end 'lowerMirTerminatorArm64'

// Return: move value to X0 (or D0 for float), then emit epilogue+ret.
// Void-returning functions still get the move so that the implicit 0 returned
// by the parser lands in the canonical return register — keeps the dead
// `mov x0, 0` visible instead of letting regalloc pick an arbitrary register.
function lowerReturnArm64(target TargetModule, retValId ValueId, dstBlock IrBlock, returnType StdReturnType)
	if stdReturnTypeIsFloat(returnType) 'floatReturn'
		appendArm64Op(target, block: dstBlock, op: Arm64Op.fmovRegReg(arm64PhysFpReg(Arm64FloatRegister.d0), src: Arm64FpVReg.virtual(retValId), precision: FloatPrecision.f64))
	end 'floatReturn' else 'intReturn'
		appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(arm64PhysReg(Arm64Register.x0), src: Arm64VReg.virtual(retValId)))
	end 'intReturn'
	appendArm64Op(target, block: dstBlock, op: Arm64Op.epilogue)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ret)
end 'lowerReturnArm64'

// ============================================================
// Branch helpers
// ============================================================

// Block arguments are NOT handled by the ISel. The SSA register allocator's
// destroySSA pass inserts properly-sequentialized parallel copies at CFG edges
// using CopyResolution. The ISel just emits jumps.

function lowerBrWithArgsArm64(targetMod TargetModule, target BlockId, dstBlock IrBlock)
	// Block arg passing is handled by the register allocator's destroySSA pass.
	appendArm64Op(targetMod, block: dstBlock, op: Arm64Op.branch(target))
end 'lowerBrWithArgsArm64'

function lowerCondBrArm64(target TargetModule, condId ValueId, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock, jumpKind JumpKind)
	// Block arg passing is handled by the register allocator's destroySSA pass.
	// Emit inverted conditional branch to else block, then unconditional branch to then block.
	match jumpKind 'emitJump'
		eq then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.ne, targetBlock: elseTarget))
		ne then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget))
		lt then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.ge, targetBlock: elseTarget))
		le then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.gt, targetBlock: elseTarget))
		gt then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.le, targetBlock: elseTarget))
		ge then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.lt, targetBlock: elseTarget))
		ugt then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.ls, targetBlock: elseTarget))
		feq then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.ne, targetBlock: elseTarget))
		fne then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget))
		flt then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.ge, targetBlock: elseTarget))
		fle then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.gt, targetBlock: elseTarget))
		fgt then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.le, targetBlock: elseTarget))
		fge then appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.lt, targetBlock: elseTarget))
		boolTest then lowerBoolTestCondBrArm64(target, condId: condId, elseTarget: elseTarget, dstBlock: dstBlock)
	end 'emitJump'
	// Unconditional branch to then block
	appendArm64Op(target, block: dstBlock, op: Arm64Op.branch(thenTarget))
end 'lowerCondBrArm64'

function lowerBoolTestCondBrArm64(target TargetModule, condId ValueId, elseTarget BlockId, dstBlock IrBlock)
	if not tryReplaceLastWithFlagSettingArm64(target, block: dstBlock, condId: condId) 'needsCmp'
		let vr = Arm64VReg.virtual(condId)
		appendArm64Op(target, block: dstBlock, op: Arm64Op.cmpRegZero(vr))
	end 'needsCmp'
	appendArm64Op(target, block: dstBlock, op: Arm64Op.condBranch(Arm64CondCode.eq, targetBlock: elseTarget))
end 'lowerBoolTestCondBrArm64'

// Check if the last op in the block is an add/sub/and whose dest matches condId.
// If so, replace it with the S-variant (adds/subs/ands) and return true.
function tryReplaceLastWithFlagSettingArm64(module TargetModule, block IrBlock, condId ValueId) returns bool
	let opCount = block.opRefs.count()
	if opCount == 0 'empty'
		return false
	end 'empty'
	let lastPacked = try block.opRefs.get(opCount - 1) otherwise 'noOp'
		return false
	end 'noOp'
	let a64Op = try module.arm64Ops.get(lastPacked) otherwise 'noOp2'
		return false
	end 'noOp2'
	return tryReplaceArm64OpWithFlagSetting(module, block: block, opIndex: opCount - 1, a64Op: a64Op, condId: condId)
end 'tryReplaceLastWithFlagSettingArm64'

function tryReplaceArm64OpWithFlagSetting(module TargetModule, block IrBlock, opIndex Index, a64Op Arm64Op, condId ValueId) returns bool
	return match a64Op 'replace'
		addRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(module, block: block, opIndex: opIndex, dest: dest, condId: condId, replacement: Arm64Op.addsRegs(dest, src1: src1, src2: src2))
		subRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(module, block: block, opIndex: opIndex, dest: dest, condId: condId, replacement: Arm64Op.subsRegs(dest, src1: src1, src2: src2))
		andRegs(dest, src1, src2) gives trySwapArm64ThreeAddr(module, block: block, opIndex: opIndex, dest: dest, condId: condId, replacement: Arm64Op.andsRegs(dest, src1: src1, src2: src2))
		prologue to ldrFromSlot gives false
		addsRegs gives false
		subsRegs to remRegs gives false
		negReg to mvnReg gives false
		andsRegs to nullSafeLoad gives false
	end 'replace'
end 'tryReplaceArm64OpWithFlagSetting'

function trySwapArm64ThreeAddr(module TargetModule, block IrBlock, opIndex Index, dest Arm64VReg, condId ValueId, replacement Arm64Op) returns bool
	if not arm64VRegMatchesCondId(dest, condId: condId) 'noMatch'
		return false
	end 'noMatch'
	// Push the replacement op to get a new packed ref, then remove+insert
	let newIdx = module.arm64Ops.count()
	module.arm64Ops.push(replacement)
	try block.opRefs.remove(at: opIndex) otherwise 'removeFailed'
		return false
	end 'removeFailed'
	try block.opRefs.insert(at: opIndex, value: newIdx) otherwise 'insertFailed'
		return false
	end 'insertFailed'
	return true
end 'trySwapArm64ThreeAddr'

function arm64VRegMatchesCondId(vreg Arm64VReg, condId ValueId) returns bool
	return match vreg 'check'
		virtual(vid) gives vid == condId
		physical gives false
	end 'check'
end 'arm64VRegMatchesCondId'

// ============================================================
// SysOps — slot-based lowering (no register allocation)
// ============================================================

// MIR system-like ops (stackSlotAddr, globalAddr, syscall, etc.)
function lowerMirSysOpArm64(target TargetModule, op MirOp, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	var result = nextTempSlot
	match op 'lower'
		stackSlotAddr(resultId, slotId) then result = lowerStackAddrArm64(target, resultId: resultId, slotId: slotId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		globalAddr(resultId, name) then result = lowerGlobalAddrArm64(target, resultId: resultId, name: name, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		funcAddr(resultId, name) then result = lowerFuncAddrArm64(target, resultId: resultId, name: name, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		loadFramePtr(resultId) then result = lowerLoadFramePtrArm64(target, resultId: resultId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		syscall(resultId, number, argIds) then result = lowerSyscallArm64(target, resultId: resultId, number: number, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		iatCall(resultId, slotIndex, argIds) then result = lowerIatCallArm64(target, resultId: resultId, slotIndex: slotIndex, argIds: argIds, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		osExit(codeId) then result = lowerOsExitArm64(target, codeId: codeId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot, osDesc: osDesc)
		osWrite(ptrId, lenId) then result = lowerOsWriteWithStrategyArm64(target, ptrId: ptrId, lenId: lenId, strategy: osDesc.write, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		osWriteErr(ptrId, lenId) then result = lowerOsWriteWithStrategyArm64(target, ptrId: ptrId, lenId: lenId, strategy: osDesc.writeErr, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		memcpy(dstId, srcId, lenId) then result = lowerMemcpyArm64(target, dstId: dstId, srcId: srcId, lenId: lenId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		storeByte(baseId, offsetId, byteId) then result = lowerStoreByteArm64(target, baseId: baseId, offsetId: offsetId, byteId: byteId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		loadByte(resultId, baseId, offsetId) then result = lowerLoadByteArm64(target, resultId: resultId, baseId: baseId, offsetId: offsetId, dstBlock: dstBlock, valueSlots: valueSlots, nextTempSlot: nextTempSlot)
		movImm to storeSlot then break 'lower'
	end 'lower'
	return result
end 'lowerMirSysOpArm64'

// Ensure a value is stored to a VarSlot. For SysOps that need slot-based addressing,
// we store the virtual register value into a temp slot.
function ensureValueInSlotArm64(target TargetModule, valueId ValueId, valueSlots ValueSlotMap, nextTempSlot SlotIndex, dstBlock IrBlock) returns VarSlot
	if valueSlotMapHas(valueSlots, valueId: valueId) 'hasSlot'
		let existingSlot = valueSlotMapGet(valueSlots, valueId: valueId)
		// Re-store current value to its existing slot
		appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(existingSlot, src: Arm64VReg.virtual(valueId)))
		return existingSlot
	end 'hasSlot'
	// No slot yet — assign a temp slot and store
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(nextTempSlot, src: Arm64VReg.virtual(valueId)))
	valueSlotMapSet(valueSlots, valueId: valueId, slot: nextTempSlot)
	return nextTempSlot
end 'ensureValueInSlotArm64'

// Slot-based syscall lowering used by lowerMirSysOpArm64 for MIR syscall ops.
function lowerSyscallArm64(target TargetModule, resultId ValueId, number MachineWord, argIds ValueIdArray, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	var argSlots = VarSlotArray.create()
	for argId in argIds 'mapArgs'
		let slot = ensureValueInSlotArm64(target, valueId: argId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
		if slot == tempSlot 'usedTemp'
			tempSlot = tempSlot + 1
		end 'usedTemp'
		argSlots.push(slot)
	end 'mapArgs'
	let resultSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.syscall(resultSlot, number: number, argSlots: argSlots))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot))
	return tempSlot + 1
end 'lowerSyscallArm64'

function lowerIatCallArm64(target TargetModule, resultId ValueId, slotIndex MachineWord, argIds ValueIdArray, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	var argSlots = VarSlotArray.create()
	for argId in argIds 'mapArgs'
		let slot = ensureValueInSlotArm64(target, valueId: argId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
		if slot == tempSlot 'usedTemp'
			tempSlot = tempSlot + 1
		end 'usedTemp'
		argSlots.push(slot)
	end 'mapArgs'
	let resultSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.iatCall(resultSlot, slotIndex: slotIndex, argSlots: argSlots))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot))
	return tempSlot + 1
end 'lowerIatCallArm64'

function lowerGlobalAddrArm64(target TargetModule, resultId ValueId, name String, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	let tempSlot = nextTempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.globalAddr(tempSlot, name: name))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
	// Also load the result into a virtual register so regular ops can use it
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: tempSlot))
	return nextTempSlot + 1
end 'lowerGlobalAddrArm64'

function lowerStackAddrArm64(target TargetModule, resultId ValueId, slotId VarSlot, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	// Ensure the result slot doesn't overlap with the target slot
	var tempSlot = nextTempSlot
	if tempSlot <= slotId 'conflict'
		tempSlot = slotId + 1
	end 'conflict'
	appendArm64Op(target, block: dstBlock, op: Arm64Op.stackAddrOp(tempSlot, targetSlot: slotId))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: tempSlot)
	// Also load the result into a virtual register so regular ops can use it
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: tempSlot))
	return tempSlot + 1
end 'lowerStackAddrArm64'

function lowerStoreByteArm64(target TargetModule, baseId ValueId, offsetId ValueId, byteId ValueId, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let baseSlot = ensureValueInSlotArm64(target, valueId: baseId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if baseSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let offsetSlot = ensureValueInSlotArm64(target, valueId: offsetId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if offsetSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let byteSlot = ensureValueInSlotArm64(target, valueId: byteId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if byteSlot == tempSlot 'usedTemp3'
		tempSlot = tempSlot + 1
	end 'usedTemp3'
	appendArm64Op(target, block: dstBlock, op: Arm64Op.storeByteOp(baseSlot, offsetSlot: offsetSlot, byteSlot: byteSlot))
	return tempSlot
end 'lowerStoreByteArm64'

function lowerLoadByteArm64(target TargetModule, resultId ValueId, baseId ValueId, offsetId ValueId, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let baseSlot = ensureValueInSlotArm64(target, valueId: baseId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if baseSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let offsetSlot = ensureValueInSlotArm64(target, valueId: offsetId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if offsetSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let resultSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.loadByteOp(resultSlot, baseSlot: baseSlot, offsetSlot: offsetSlot))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: resultSlot)
	// Also load the result into a virtual register so regular ops can use it
	appendArm64Op(target, block: dstBlock, op: Arm64Op.ldrFromSlot(Arm64VReg.virtual(resultId), slotIndex: resultSlot))
	return tempSlot + 1
end 'lowerLoadByteArm64'

function lowerMemcpyArm64(target TargetModule, dstId ValueId, srcId ValueId, lenId ValueId, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let dstSlot = ensureValueInSlotArm64(target, valueId: dstId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if dstSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let srcSlot = ensureValueInSlotArm64(target, valueId: srcId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if srcSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	let lenSlot = ensureValueInSlotArm64(target, valueId: lenId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if lenSlot == tempSlot 'usedTemp3'
		tempSlot = tempSlot + 1
	end 'usedTemp3'
	appendArm64Op(target, block: dstBlock, op: Arm64Op.memcpyOp(dstSlot, srcSlot: srcSlot, lenSlot: lenSlot))
	return tempSlot
end 'lowerMemcpyArm64'

// ============================================================
// OS-neutral exit/write
// ============================================================

function lowerOsExitArm64(target TargetModule, codeId ValueId, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex, osDesc OsDescriptor) returns SlotIndex
	var tempSlot = nextTempSlot
	let codeSlot = ensureValueInSlotArm64(target, valueId: codeId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if codeSlot == tempSlot 'usedTemp'
		tempSlot = tempSlot + 1
	end 'usedTemp'
	match osDesc.exit 'strategy'
		syscall(num) then return lowerOsExitSyscallArm64(target, codeSlot: codeSlot, num: num, dstBlock: dstBlock, nextTempSlot: tempSlot)
		iatCall(slotIdx) then return lowerOsExitIatArm64(target, codeSlot: codeSlot, slotIdx: slotIdx, dstBlock: dstBlock, nextTempSlot: tempSlot)
	end 'strategy'
end 'lowerOsExitArm64'

function lowerOsExitSyscallArm64(target TargetModule, codeSlot VarSlot, num MachineWord, dstBlock IrBlock, nextTempSlot SlotIndex) returns SlotIndex
	var argSlots = VarSlotArray.create()
	argSlots.push(codeSlot)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.syscall(nextTempSlot, number: num, argSlots: argSlots))
	return nextTempSlot + 1
end 'lowerOsExitSyscallArm64'

function lowerOsExitIatArm64(target TargetModule, codeSlot VarSlot, slotIdx MachineWord, dstBlock IrBlock, nextTempSlot SlotIndex) returns SlotIndex
	var argSlots = VarSlotArray.create()
	argSlots.push(codeSlot)
	appendArm64Op(target, block: dstBlock, op: Arm64Op.iatCall(nextTempSlot, slotIndex: slotIdx, argSlots: argSlots))
	return nextTempSlot + 1
end 'lowerOsExitIatArm64'

function lowerOsWriteSyscallArm64(target TargetModule, ptrSlot VarSlot, lenSlot VarSlot, writeNum MachineWord, fd MachineWord, dstBlock IrBlock, nextTempSlot SlotIndex) returns SlotIndex
	// fd constant -> temp slot
	let fdSlot = nextTempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: fd))
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(fdSlot, src: arm64PhysReg(Arm64Register.x0)))
	// syscall(writeNum, fd, ptr, len)
	var argSlots = VarSlotArray.create()
	argSlots.push(fdSlot)
	argSlots.push(ptrSlot)
	argSlots.push(lenSlot)
	let resultSlot = nextTempSlot + 1
	appendArm64Op(target, block: dstBlock, op: Arm64Op.syscall(resultSlot, number: writeNum, argSlots: argSlots))
	return nextTempSlot + 2
end 'lowerOsWriteSyscallArm64'

function lowerOsWriteWinApiArm64(target TargetModule, ptrSlot VarSlot, lenSlot VarSlot, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord, dstBlock IrBlock, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot

	// GetStdHandle(handleConstant)
	let handleConstSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: handleConstant))
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(handleConstSlot, src: arm64PhysReg(Arm64Register.x0)))
	tempSlot = tempSlot + 1
	var getHandleArgs = VarSlotArray.create()
	getHandleArgs.push(handleConstSlot)
	let handleResultSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.iatCall(handleResultSlot, slotIndex: getHandleSlot, argSlots: getHandleArgs))
	tempSlot = tempSlot + 1

	// bytesWritten = 0 stored to a slot
	let writtenSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: 0))
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(writtenSlot, src: arm64PhysReg(Arm64Register.x0)))
	tempSlot = tempSlot + 1

	// Get address of bytesWritten slot
	let writtenAddrSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.stackAddrOp(writtenAddrSlot, targetSlot: writtenSlot))
	tempSlot = tempSlot + 1

	// NULL for lpOverlapped
	let nullSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: 0))
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(nullSlot, src: arm64PhysReg(Arm64Register.x0)))
	tempSlot = tempSlot + 1

	// WriteFile(handle, ptr, len, &bytesWritten, NULL)
	var writeArgs = VarSlotArray.create()
	writeArgs.push(handleResultSlot)
	writeArgs.push(ptrSlot)
	writeArgs.push(lenSlot)
	writeArgs.push(writtenAddrSlot)
	writeArgs.push(nullSlot)
	let writeResultSlot = tempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.iatCall(writeResultSlot, slotIndex: writeFileSlot, argSlots: writeArgs))
	tempSlot = tempSlot + 1

	return tempSlot
end 'lowerOsWriteWinApiArm64'

// OS write via libcall: write(fd, buf, len) through GOT/IAT slot.
// Used for macOS (libSystem.B.dylib).
function lowerOsWriteLibcallArm64(target TargetModule, ptrSlot VarSlot, lenSlot VarSlot, writeSlot MachineWord, fd MachineWord, dstBlock IrBlock, nextTempSlot SlotIndex) returns SlotIndex
	// fd constant -> temp slot
	let fdSlot = nextTempSlot
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movImm(arm64PhysReg(Arm64Register.x0), value: fd))
	appendArm64Op(target, block: dstBlock, op: Arm64Op.strToSlot(fdSlot, src: arm64PhysReg(Arm64Register.x0)))
	// iatCall write(fd, ptr, len)
	var argSlots = VarSlotArray.create()
	argSlots.push(fdSlot)
	argSlots.push(ptrSlot)
	argSlots.push(lenSlot)
	let resultSlot = nextTempSlot + 1
	appendArm64Op(target, block: dstBlock, op: Arm64Op.iatCall(resultSlot, slotIndex: writeSlot, argSlots: argSlots))
	return nextTempSlot + 2
end 'lowerOsWriteLibcallArm64'

function lowerOsWriteWithStrategyArm64(target TargetModule, ptrId ValueId, lenId ValueId, strategy WriteStrategy, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	var tempSlot = nextTempSlot
	let ptrSlot = ensureValueInSlotArm64(target, valueId: ptrId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if ptrSlot == tempSlot 'usedTemp1'
		tempSlot = tempSlot + 1
	end 'usedTemp1'
	let lenSlot = ensureValueInSlotArm64(target, valueId: lenId, valueSlots: valueSlots, nextTempSlot: tempSlot, dstBlock: dstBlock)
	if lenSlot == tempSlot 'usedTemp2'
		tempSlot = tempSlot + 1
	end 'usedTemp2'
	match strategy 'dispatch'
		syscall(writeNum, fd) then return lowerOsWriteSyscallArm64(target, ptrSlot: ptrSlot, lenSlot: lenSlot, writeNum: writeNum, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
		winApi(getHandleSlot, handleConstant, writeFileSlot) then return lowerOsWriteWinApiArm64(target, ptrSlot: ptrSlot, lenSlot: lenSlot, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot, dstBlock: dstBlock, nextTempSlot: tempSlot)
		libcall(writeSlot, fd) then return lowerOsWriteLibcallArm64(target, ptrSlot: ptrSlot, lenSlot: lenSlot, writeSlot: writeSlot, fd: fd, dstBlock: dstBlock, nextTempSlot: tempSlot)
	end 'dispatch'
end 'lowerOsWriteWithStrategyArm64'

function lowerLoadFramePtrArm64(target TargetModule, resultId ValueId, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	appendArm64Op(target, block: dstBlock, op: Arm64Op.movRegReg(Arm64VReg.virtual(resultId), src: arm64PhysReg(Arm64Register.x29)))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	return nextTempSlot
end 'lowerLoadFramePtrArm64'

function lowerFuncAddrArm64(target TargetModule, resultId ValueId, name String, dstBlock IrBlock, valueSlots ValueSlotMap, nextTempSlot SlotIndex) returns SlotIndex
	appendArm64Op(target, block: dstBlock, op: Arm64Op.leaFuncAddr(Arm64VReg.virtual(resultId), funcName: name))
	valueSlotMapSet(valueSlots, valueId: resultId, slot: nextTempSlot)
	return nextTempSlot
end 'lowerFuncAddrArm64'

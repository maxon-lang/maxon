// WASM backend: converts MIR module directly to a .wasm binary file.
// Branches from MIR, bypassing the register-based pipeline stages
// (target lowering, register allocation, scheduling, prologue/epilogue).
// WASM is a stack machine with structured control flow and infinite locals.

// --- WASI Preview2 import indices (must match import section order) ---
//
// The emitted artifact is a CORE module that imports WASI **Preview2** interface
// functions (component-model `wasi:*` interfaces), which a post-build
// `wasm-tools component embed` + `component new` step (see BackendDispatch
// `wrapWasmComponent`) lifts/lowers into a runnable component. Each import's
// module name is the full versioned interface id (e.g. "wasi:io/streams@0.2.6")
// and the field name is the interface function (e.g.
// "[method]output-stream.write"); `component new` matches these against the
// world in vendor/wasi-wit and synthesizes the canon adapters + shim/fixup
// trampoline. Preview1 (`wasi_snapshot_preview1`, flat fd/iovec/errno) is gone.
//
// Resource handles are i32; lists/strings are (ptr,len); methods that return a
// non-scalar / >1-value result take a trailing return-area pointer the callee
// writes into (canonical ABI). See the per-call-site emitters for the layouts.

// wasi:cli/exit.exit-with-code(status-code: u8 as i32) -> () (never). Replaces
// proc_exit; carries the arbitrary process exit code (the plain `exit` func only
// signals ok/err). @unstable — needs `-S cli-exit-with-code=y` at runtime.
let wasiExit = 0

// wasi:cli/stdout.get-stdout() -> output-stream(handle i32).
let wasiGetStdout = 1

// wasi:cli/stderr.get-stderr() -> output-stream(handle i32).
let wasiGetStderr = 2

// wasi:cli/stdin.get-stdin() -> input-stream(handle i32).
let wasiGetStdin = 3

// wasi:io/streams [method]output-stream.blocking-write-and-flush(self i32,
//   contents (ptr i32,len i32), ret-area i32) -> (). Result<_,stream-error>.
let wasiOutBlockingWriteFlush = 4

// wasi:io/streams [method]input-stream.blocking-read(self i32, len i64,
//   ret-area i32) -> (). Result<list<u8>,stream-error>; list at ret+4/+8.
let wasiInBlockingRead = 5

// wasi:io/streams [resource-drop]output-stream(handle i32) -> ().
let wasiOutStreamDrop = 6

// wasi:io/streams [resource-drop]input-stream(handle i32) -> ().
let wasiInStreamDrop = 7

// wasi:cli/environment.get-arguments(ret-area i32) -> (). list<string>.
let wasiGetArguments = 8

// wasi:clocks/monotonic-clock.subscribe-duration(when i64) -> pollable(i32).
let wasiMonotonicSubscribeDuration = 9

// wasi:io/poll [method]pollable.block(self i32) -> ().
let wasiPollableBlock = 10

// wasi:io/poll [resource-drop]pollable(handle i32) -> ().
let wasiPollableDrop = 11

// wasi:filesystem/preopens.get-directories(ret-area i32) -> ().
//   list<(descriptor(handle i32), string(ptr,len))>.
let wasiGetDirectories = 12

// wasi:filesystem/types [method]descriptor.open-at(self i32, path-flags i32,
//   path(ptr,len), open-flags i32, descriptor-flags i32, ret-area i32) -> ().
//   Result<descriptor,error-code>.
let wasiDescriptorOpenAt = 13

// wasi:filesystem/types [method]descriptor.read(self i32, length i64,
//   offset i64, ret-area i32) -> (). Result<(list<u8>,bool),error-code>.
let wasiDescriptorRead = 14

// wasi:filesystem/types [method]descriptor.write(self i32, buffer(ptr,len),
//   offset i64, ret-area i32) -> (). Result<filesize(u64),error-code>.
let wasiDescriptorWrite = 15

// wasi:filesystem/types [method]descriptor.stat(self i32, ret-area i32) -> ().
//   Result<descriptor-stat,error-code>.
let wasiDescriptorStat = 16

// wasi:filesystem/types [method]descriptor.stat-at(self i32, path-flags i32,
//   path(ptr,len), ret-area i32) -> (). Result<descriptor-stat,error-code>.
let wasiDescriptorStatAt = 17

// wasi:filesystem/types [method]descriptor.unlink-file-at(self i32,
//   path(ptr,len), ret-area i32) -> (). Result<_,error-code>.
let wasiDescriptorUnlinkFileAt = 18

// wasi:filesystem/types [method]descriptor.create-directory-at(self i32,
//   path(ptr,len), ret-area i32) -> (). Result<_,error-code>.
let wasiDescriptorCreateDirectoryAt = 19

// wasi:filesystem/types [method]descriptor.read-directory(self i32, ret-area
//   i32) -> (). Result<directory-entry-stream,error-code>.
let wasiDescriptorReadDirectory = 20

// wasi:filesystem/types [method]directory-entry-stream.read-directory-entry(
//   self i32, ret-area i32) -> (). Result<option<directory-entry>,error-code>.
let wasiReadDirectoryEntry = 21

// wasi:filesystem/types [resource-drop]descriptor(handle i32) -> ().
let wasiDescriptorDrop = 22

// wasi:filesystem/types [resource-drop]directory-entry-stream(handle i32) -> ().
let wasiDirEntryStreamDrop = 23

// --- wasi:sockets (Project 2 networking) ---
// wasi:sockets/instance-network.instance-network() -> network(handle i32).
let wasiInstanceNetwork = 24

// wasi:sockets/tcp-create-socket.create-tcp-socket(family i32, ret-area i32)
//   -> (). Result<tcp-socket,error-code>.
let wasiCreateTcpSocket = 25

// wasi:sockets/tcp [method]tcp-socket.start-connect(self i32, network i32,
//   remote-addr..., ret-area i32) -> (). Result<_,error-code>.
let wasiTcpStartConnect = 26

// wasi:sockets/tcp [method]tcp-socket.finish-connect(self i32, ret-area i32)
//   -> (). Result<(input-stream,output-stream),error-code>.
let wasiTcpFinishConnect = 27

// wasi:sockets/tcp [method]tcp-socket.subscribe(self i32) -> pollable(i32).
let wasiTcpSubscribe = 28

// wasi:sockets/tcp [method]tcp-socket.shutdown(self i32, shutdown-type i32,
//   ret-area i32) -> (). Result<_,error-code>.
let wasiTcpShutdown = 29

// wasi:sockets/tcp [resource-drop]tcp-socket(handle i32) -> ().
let wasiTcpSocketDrop = 30

// wasi:sockets/network [resource-drop]network(handle i32) -> ().
let wasiNetworkDrop = 31

// wasi:sockets/ip-name-lookup.resolve-addresses(network i32, name(ptr,len),
//   ret-area i32) -> (). Result<resolve-address-stream,error-code>.
let wasiResolveAddresses = 32

// wasi:sockets/ip-name-lookup [method]resolve-address-stream.resolve-next-address(
//   self i32, ret-area i32) -> (). Result<option<ip-address>,error-code>.
let wasiResolveNextAddress = 33

// wasi:sockets/ip-name-lookup [resource-drop]resolve-address-stream(handle i32).
let wasiResolveStreamDrop = 34

// wasi:io/poll.poll(in: list<borrow<pollable>> (ptr i32, len i32), ret-area i32)
//   -> (). Result list<u32> written to the return area (ptr@+0, len@+4). Used by
// the TCP connect helper to wait on the socket's connect-completion pollable AND a
// monotonic-clock timeout pollable simultaneously, so an unroutable peer (e.g.
// TEST-NET-1 192.0.2.1) bounds at the timer instead of the multi-second OS connect
// timeout that a bare `pollable.block` on the socket alone would incur.
let wasiPoll = 35

// wasi:clocks/monotonic-clock.now() -> instant(i64). The monotonic clock's
// current value in NANOSECONDS; backs stdlib/Clock.maxon via the osClockMs op
// (divided to milliseconds at the call site). Appended after wasiPoll so the
// preceding WASI import ordinals stay fixed.
let wasiMonotonicNow = 36

// Binaryen Asyncify primitive imports (resolved + internalized by `wasm-opt
// --asyncify`). Declared right after the WASI imports (the last of which is
// `wasiMonotonicNow` at 36), so they occupy function indices 37-40 and
// module-defined functions start at `wasiImportCount`.
let asyncifyStartUnwindIdx = 37
let asyncifyStopUnwindIdx = 38
let asyncifyStartRewindIdx = 39
let asyncifyStopRewindIdx = 40

let wasiImportCount = 41

// The green-thread runtime calls the asyncify primitives by these Std-IR names;
// `emitDirectCall` routes them to the fixed import indices above instead of a
// module-function lookup. (Declared `void` with an i64 data arg in the runtime;
// the import is `(i32) -> ()`, so the arg is wrapped at the call site.)
function isAsyncifyImportCall(callee String) returns bool
	return callee == "asyncify_start_unwind" or callee == "asyncify_stop_unwind" or callee == "asyncify_start_rewind" or callee == "asyncify_stop_rewind"
end 'isAsyncifyImportCall'

// The four dead asyncify primitive stub functions (defined in runtime_wasm.std
// for parse-time signature resolution) that must be dropped from the emitted
// module so they don't collide with the functions Binaryen's `--asyncify` pass
// generates under the same names. See `emitWasmModule`.
function asyncifyStubFuncNames() returns StringArray
	var names = StringArray.create()
	names.push("asyncify_start_unwind")
	names.push("asyncify_stop_unwind")
	names.push("asyncify_start_rewind")
	names.push("asyncify_stop_rewind")
	return names
end 'asyncifyStubFuncNames'

function asyncifyImportIndex(callee String) returns Wasm32Index
	if callee == "asyncify_start_unwind" 'su'
		return asyncifyStartUnwindIdx as Wasm32Index
	end 'su'
	if callee == "asyncify_stop_unwind" 'stu'
		return asyncifyStopUnwindIdx as Wasm32Index
	end 'stu'
	if callee == "asyncify_start_rewind" 'sr'
		return asyncifyStartRewindIdx as Wasm32Index
	end 'sr'
	if callee == "asyncify_stop_rewind" 'str'
		return asyncifyStopRewindIdx as Wasm32Index
	end 'str'
	panic("asyncifyImportIndex: not an asyncify import call: {callee}")
end 'asyncifyImportIndex'

// Preopen-directory handling on wasm32-wasi is descriptor-based under Preview2
// (see the wasiPreopenDescBase cache below): the spec runner invokes the test
// binary with `--dir=. --dir=..::../`, so wasi:filesystem/preopens
// .get-directories() returns element 0 = `.` (cwd) and element 1 = `..`
// (parent). `emitResolvePreopenDesc` picks the parent descriptor when the
// requested path starts with "..", otherwise the cwd descriptor. This is a
// deliberately simple two-way split — a future stage could match the longest
// preopen-path prefix — but the spec runner's preopen layout is fixed and this
// covers every test in the corpus.

// --- Linear memory layout ---
// We reserve a block of linear memory for various runtime needs. The layout is:
//   0..1024              scratch (path-rewrite byte + argv cache + sleep/return areas)
//   1024..dataOffset     global data (string literals, top-level vars, stdlib data)
//   dataOffset..         stack slots (per-function frames)
//
// Heap allocations no longer live at a fixed offset: the slab allocator
// (runtime.std) calls osAllocPages, which lowers to `memory.grow` and returns
// the byte offset of pages appended above the initial memory. The legacy
// `__data_heap` bump arena that used to occupy 1024..65536 was abandoned when
// mrt_alloc became a thin wrapper around mm_alloc.
//
// Offset 0 doubles as a one-byte scratch where the directory-open helper writes
// a '.' when rewriting an empty path to the cwd (see emitWasmDirectoryOpenSearch),
// avoiding a mutation of the caller's __ManagedMemory.
//
// argv cache (zero-initialized, lazily populated by emitArgvCacheEnsure from
// the Preview2 get-arguments list on the first osGetArgc/osGetArgv/
// osGetExecutablePath invocation):
//   16..20 (i32): argc (the get-arguments list length)
//   20..24 (i32): scratch: sum of argument byte lengths (pass-1 accumulator)
//   24..28 (i32): init flag (0 = uninitialized, 1 = cache built)
//   28..32 (i32): pointer to the mm-allocated argv buffer; the first argc*4
//                 bytes hold a pointer array (argv[i] = i32.load(bufPtr+i*4)),
//                 the rest holds NUL-terminated copies of each argument

let iovecBase = 0
let argvCacheArgcBase = 16
let argvCacheBufSizeBase = 20
let argvCacheInitFlagBase = 24
let argvCacheBufPtrBase = 28

// --- osSleep scratch slot ---
// Preview2 sleep stashes the single i32 pollable handle returned by
// monotonic-clock.subscribe-duration here so it survives the pollable.block /
// pollable-drop sequence without needing a spare local at the call site (see
// emitOsSleep). Far smaller than the preview1 poll_oneoff subscription struct.
let wasiSleepSubBase = 144  // 4 bytes [144..148)

// --- WASI Preview2 preopen descriptor cache ---
// Preview1 used fixed dirfd numbers (3 = cwd, 4 = parent). Preview2 is
// descriptor-relative: the base directory is a `descriptor` handle obtained
// once from wasi:filesystem/preopens.get-directories(). The spec runner
// preopens two directories (`--dir=. --dir=..::../`), so get-directories()
// returns a list whose element 0 is the cwd `.` and element 1 is the parent
// `..`. We cache both descriptor handles here so every path-relative fs helper
// reuses them without re-listing: a path beginning with ".." resolves against
// the parent descriptor (with the "../" prefix stripped), everything else
// against the cwd descriptor. `wasiPreopenDescReady` is a separate guard word
// because handle 0 is itself a valid descriptor — a sentinel in the handle
// slot would be ambiguous. All i32, in the free gap before the return area.
let wasiPreopenDescBase = 228  // 4 bytes [228..232): cached cwd descriptor handle
let wasiPreopenDescReady = 232  // 4 bytes [232..236): 0 = not loaded, 1 = loaded
let wasiPreopenParentDescBase = 236  // 4 bytes [236..240): cached parent ("..") descriptor handle

// --- WASI Preview2 sequential read/write offset cache ---
// Preview2 `descriptor.read`/`descriptor.write` are STATELESS — each takes an
// explicit byte offset — but the maxon File API is sequential (read/write
// advance an implicit cursor). We cache the cursor for the MOST-RECENTLY-USED
// descriptor handle in two cells: when a read/write targets the cached handle we
// reuse its offset; otherwise we reset the offset to 0 and adopt the new handle.
// On a successful read/write we add the byte count to the cached offset. This is
// correct for sequential access to one file at a time (the spec corpus pattern);
// a future fd→offset table would generalize to interleaved handles. A separate
// `wasiFileCurValid` guard is needed because handle 0 is a valid descriptor.
let wasiFileCurHandle = 512  // 8 bytes [512..520): cached descriptor handle (i64)
let wasiFileCurOffset = 520  // 8 bytes [520..528): cached byte offset (i64)
let wasiFileCurValid = 528  // 4 bytes [528..532): 0 = no cached handle

// --- wasi:sockets connect scratch (Project 2 networking) ---
// The TCP connect helper makes a sequence of non-reentrant wasi:sockets calls
// whose canonical-ABI return areas must NOT alias the shared `wasiRetAreaBase`
// region in ways that overwrite a value still needed (e.g. start-connect's
// result must survive while the poll machinery runs). Carve a dedicated socket
// scratch block in the free [532..1024) gap. All addresses are 8-aligned so the
// canonical ABI's alignment requirement on return-area pointers is satisfied
// (wasmtime traps on a misaligned result pointer). Layout:
//   536..600 (64 bytes): general socket call return area (resolve/create/finish)
//   600..608 (8 bytes):  poll-list arg buffer = two i32 pollable handles
//   608..640 (32 bytes): poll() result list<u32> return area
let wasiSockRetAreaBase = 536  // [536..600): result<...> return area for socket calls
let wasiSockPollListBase = 600  // [600..608): list<borrow<pollable>> = [sockPoll i32, timerPoll i32]
let wasiSockPollRetBase = 608  // [608..640): poll() result return area (list ptr@+0, len@+4)

// --- WASI Preview2 canonical-ABI return area ---
// Preview2 interface functions whose result is non-scalar or has >1 value write
// their result into a caller-supplied return-area pointer (canonical ABI). A
// single shared static area suffices because every WASI runtime call is
// non-reentrant in the single-threaded wasm model. 256 bytes covers the largest
// return shape we decode (descriptor-stat is ~64 bytes; list/result headers are
// 8-12). Distinct from the scratch slots above so a return-area write can't
// clobber an in-flight iovec/filestat.
let wasiRetAreaBase = 256  // [256..512)
let scratchEnd = 1024

// Initial memory pages: enough for scratch + global data + reasonable stack.
// The slab allocator grows linear memory on demand via memory.grow, so this
// only needs to cover what's laid out at module-init time.
// 16 pages = 1 MiB.
let initialMemoryPages = 16

typealias GlobalDataOffsetMap = Map with (String, Wasm32Offset)
typealias FuncNameIndexMap = Map with (String, Wasm32Index)

// Per-function map from a MIR block id to its position in func.blockRefs.
// Populated once at function entry; queried by every branch / cond_branch
// emission to resolve a target's dispatch index in O(1).
typealias BlockIndexMap = Map with (BlockId, Wasm32Index)

// One contiguous chunk of bytes placed into the wasm data section. The
// layout pass produces these once so both the offset map and the active
// data segments use identical addresses without recomputing offsets.
type WasmDataChunk
	export var offset as Wasm32Offset
	export var bytes as ByteArray

	export static function create(offset Wasm32Offset, bytes ByteArray) returns WasmDataChunk
		return Self{offset: offset, bytes: bytes}
	end 'create'
end 'WasmDataChunk'

typealias WasmDataChunkArray = Array with WasmDataChunk

// Bundled per-function metadata for module-level functions. `returnTypes`
// is keyed by index into the parallel `funcNames` array; `nameIndex` maps
// a function name back to that same index. `pushFunc` keeps the two in
// sync. The index turns callee resolution (lookupReturnsVoid /
// lookupReturnType / findFunctionIndex) from a linear scan into a single
// hash lookup, which matters because each call op triggers up to two of
// those lookups during emission.
// Lookup failure for function-index queries. Callees that are imports or
// haven't been registered yet propagate this; the few callers that should
// treat unknown names as a fallback (lookupReturnInfo, throws) catch and
// supply a default.
enum WasmFuncSigError implements Error
	notFound
end 'WasmFuncSigError'

type WasmFuncSigs
	export var returnTypes as StdReturnTypeArray
	export var throwsTypeNames as ThrowsClauseArray
	export var nameIndex as FuncNameIndexMap

	export static function create() returns WasmFuncSigs
		return Self{returnTypes: StdReturnTypeArray.create(), throwsTypeNames: ThrowsClauseArray.create(), nameIndex: FuncNameIndexMap.create()}
	end 'create'

	// Append `name`, its return type, and its throws clause at the next
	// index. Caller must also push the same name onto the parallel
	// funcNames StringArray (used by the type/import sections that walk
	// functions in order); this method records the index lookup.
	// `ThrowsClause.none` means the callee is non-throwing.
	export function pushFunc(name String, returnType StdReturnType, throwsTypeName ThrowsClause = ThrowsClause.none)
		let idx = self.returnTypes.count() as Wasm32Index
		self.returnTypes.push(returnType)
		self.throwsTypeNames.push(throwsTypeName)
		self.nameIndex.upsert(name, value: idx)
	end 'pushFunc'

	// O(1) lookup of a function's index in the funcNames table.
	export function indexOf(name String) returns Wasm32Index throws WasmFuncSigError
		return try self.nameIndex.get(name) otherwise throw WasmFuncSigError.notFound
	end 'indexOf'

	// O(1) check: does the named callee throw? Unknown callees (imports,
	// not-yet-registered) are treated as non-throwing. Named `calleeThrows`
	// rather than `throws` so it can be invoked — `throws` is a keyword.
	export function calleeThrows(name String) returns bool
		let idx = try self.indexOf(name) otherwise return false
		let tn = try self.throwsTypeNames.get(idx) otherwise ThrowsClause.none
		return match tn 'kind'
			none gives false
			throwing gives true
		end 'kind'
	end 'calleeThrows'
end 'WasmFuncSigs'

// ============================================================
// Public entry point
// ============================================================

// A WASM call fixup: offset within function body where a 5-byte fixed-width
// ULEB128 function index needs to be patched after final function ordering.
export type WasmCallFixup
	export var bodyOffset as CodeOffset
	export var targetName as String

	export static function create(bodyOffset CodeOffset, targetName String) returns WasmCallFixup
		return Self{bodyOffset: bodyOffset, targetName: targetName}
	end 'create'
end 'WasmCallFixup'

export typealias WasmCallFixupArray = Array with WasmCallFixup

// Phase 11.4: per-function fixup for an `opCallIndirect`'s embedded
// type-section index. WASM encodes the type index inline in the function
// body, so a stdlib-cached body has to defer the actual index until
// the user-build assembles the final wasm type section (the indices a
// user pipeline assigns may not match the ones the stdlib pipeline used
// when it lowered the body). `signatureBytes` is the encoded
// `writeFuncType` blob; the user-build looks it up against its own
// typeIndexMap (or registers it if missing) and writes the resolved
// index into the body at `bodyOffset` as a fixed-width 5-byte ULEB128.
export type WasmTypeFixup
	export var bodyOffset as CodeOffset
	export var signatureBytes as ByteArray

	export static function create(bodyOffset CodeOffset, signatureBytes ByteArray) returns WasmTypeFixup
		return Self{bodyOffset: bodyOffset, signatureBytes: signatureBytes}
	end 'create'
end 'WasmTypeFixup'

export typealias WasmTypeFixupArray = Array with WasmTypeFixup

// Per-function fixup for an `opI32Const` emitted by `emitFuncAddr` when the
// target function's wasm-table index isn't known at stdlib-cache lowering
// time. The cache writes a 5-byte fixed-width sleb128 placeholder and
// records the byte offset; the user-build patches it once the final table
// layout is known. Mirrors `WasmCallFixup` but for funcAddr emission so
// stdlib functions can legally take the address of another stdlib function
// (e.g. `mm_alloc(40, destructor: funcAddr __destruct___ManagedMemory, 0)`).
export type WasmFuncAddrFixup
	export var bodyOffset as CodeOffset
	export var targetName as String

	export static function create(bodyOffset CodeOffset, targetName String) returns WasmFuncAddrFixup
		return Self{bodyOffset: bodyOffset, targetName: targetName}
	end 'create'
end 'WasmFuncAddrFixup'

export typealias WasmFuncAddrFixupArray = Array with WasmFuncAddrFixup

// Per-function record of a `globalAddr` emission whose target linear-memory
// offset the cache-build doesn't yet know. The cache build assigns a
// stdlib-only offset that the user pipeline must re-resolve once user data
// shifts the merged layout; without this fixup, stdlib bodies read garbage
// for string-literal pointers like `"true"` baked into `__bool_fromString`.
// The cache emits a 5-byte fixed-width sleb128 placeholder; the user-build
// patches it with the final globalDataOffsets[targetName] value.
export type WasmGlobalAddrFixup
	export var bodyOffset as CodeOffset
	export var targetName as String

	export static function create(bodyOffset CodeOffset, targetName String) returns WasmGlobalAddrFixup
		return Self{bodyOffset: bodyOffset, targetName: targetName}
	end 'create'
end 'WasmGlobalAddrFixup'

export typealias WasmGlobalAddrFixupArray = Array with WasmGlobalAddrFixup

// Per-function WASM emission result for caching. `throwsTypeName` mirrors
// IrFunction.throwsTypeName as a `ThrowsClause`: `none` means non-throwing,
// `throwing(name)` carries the bare error-enum name. Throwing functions
// append an extra i64 result to their wasm signature (the error flag) and
// use `errorReturn` rather than plain `return`.
export type WasmObjectFunction
	export var name as String
	export var returnType as StdReturnType
	export var paramCount as ParamCount
	export var paramTypes as StdTypeArray
	export var throwsTypeName as ThrowsClause
	export var body as ByteArray
	export var callFixups as WasmCallFixupArray
	// Fixups for inline type-section indices of `call_indirect` ops. The
	// stdlib-cache wasm path writes a placeholder index at lower time and
	// patches it at user-build module-assembly time once the type section
	// is finalized — same shape as `callFixups` for direct calls.
	export var typeFixups as WasmTypeFixupArray
	// Fixups for `i32.const <tableIdx>` bytes emitted by funcAddr ops whose
	// target wasn't in the stdlib-cache function table. The user-build
	// resolves the table index from its full funcNames list and patches in
	// place. Empty for stdlib functions that never take a function address.
	export var funcAddrFixups as WasmFuncAddrFixupArray
	// Fixups for `i64.const <linMemOffset>` bytes emitted by globalAddr ops.
	// Stdlib bodies bake stdlib-only data offsets at cache time; the user
	// pipeline merges its own globalData ahead of the stdlib chunks, so the
	// cached offsets need re-resolution against the final layout. Without
	// this patch, stdlib functions that take the address of a string literal
	// (e.g. `__bool_fromString`'s `"true"` constant) load garbage bytes and
	// report `input == "true"` as false for matching input.
	export var globalAddrFixups as WasmGlobalAddrFixupArray

	export static function create(name String, returnType StdReturnType, paramCount ParamCount, paramTypes StdTypeArray, throwsTypeName ThrowsClause = ThrowsClause.none) returns WasmObjectFunction
		return Self{
			name: name,
			returnType: returnType,
			paramCount: paramCount,
			paramTypes: paramTypes,
			throwsTypeName: throwsTypeName,
			body: ByteArray.create(),
			callFixups: WasmCallFixupArray.create(),
			typeFixups: WasmTypeFixupArray.create(),
			funcAddrFixups: WasmFuncAddrFixupArray.create(),
			globalAddrFixups: WasmGlobalAddrFixupArray.create()
		}
	end 'create'
end 'WasmObjectFunction'

export typealias WasmObjectFunctionArray = Array with WasmObjectFunction

// Compile a MIR module to a .wasm binary and write it to outputPath.
export function compileWasm(module MirModule, globalData GlobalDataTable, outputPath FilePath, stdlibCache StdlibCacheData)
	let wasmBytes = emitWasmModule(module, globalData: globalData, stdlibCache: stdlibCache)
	try File.writeBinary(outputPath, content: wasmBytes) otherwise panic("Failed to write WASM file: {outputPath}")
end 'compileWasm'

// Emit WASM bytecode per-function for stdlib cache building.
// Each function body is emitted with 5-byte fixed-width ULEB128 for call
// instructions, and call fixups are recorded for post-hoc patching.
export function emitWasmPerFunction(module MirModule, globalData GlobalDataTable) returns WasmObjectFunctionArray
	var result = WasmObjectFunctionArray.create()

	// Build funcNames + funcSigs for the stdlib module (same as emitWasmModule)
	var funcNames = StringArray.create()
	var funcSigs = WasmFuncSigs.create()

	for func in module.functions 'collectNames'
		funcNames.push(func.name)
		funcSigs.pushFunc(func.name, returnType: func.returnType, throwsTypeName: func.throwsTypeName)
	end 'collectNames'

	// Compute global data offsets (same layout as `layoutWasmGlobalData`).
	// Both rdata blobs (values/names) AND writable .data entries
	// (dataSectionEntries) must contribute offsets here, otherwise
	// `globalAddr <name>` panics on functions that touch a writable
	// allocator global (`__mm_alloc_count`, slab state, etc.).
	var globalDataOffsets = GlobalDataOffsetMap.create()
	var dataOffset = scratchEnd as Wasm32Offset

	for i in 0 upto globalData.values.count() 'computeOffsets'
		let name = try globalData.names.get(i) otherwise panic("emitWasmPerFunction: globalData.names.get({i}) failed — names/values arrays out of sync")
		let data = try globalData.values.get(i) otherwise panic("emitWasmPerFunction: globalData.values.get({i}) failed — names/values arrays out of sync")
		try globalDataOffsets.insert(name, value: dataOffset) otherwise panic("emitWasmPerFunction: duplicate global data name '{name}' at offset {dataOffset}")
		dataOffset = (dataOffset + data.count()) as Wasm32Offset
	end 'computeOffsets'
	for entry in globalData.dataSectionEntries 'dataEntries'
		try globalDataOffsets.insert(entry.name, value: dataOffset) otherwise panic("emitWasmPerFunction: duplicate data section entry '{entry.name}' at offset {dataOffset}")
		dataOffset = (dataOffset + entry.initialBytes.count()) as Wasm32Offset
		while dataOffset mod 8 != 0 'align'
			dataOffset = dataOffset + 1
		end 'align'
	end 'dataEntries'
	let stackBase = alignUp(dataOffset, alignment: 16) as Wasm32Offset

	// Emit each function body with fixable call indices
	var lowering = WasmFunctionLowering.create(module, funcNames: funcNames, funcSigs: funcSigs, globalDataOffsets: globalDataOffsets, stackBase: stackBase, fixedCalls: true)
	for func in module.functions 'eachFunc'
		var objFunc = WasmObjectFunction.create(func.name, returnType: func.returnType, paramCount: func.paramCount, paramTypes: func.paramTypes, throwsTypeName: func.throwsTypeName)

		let body = lowering.lowerFunction(func, fixups: objFunc.callFixups, tyFixups: objFunc.typeFixups, addrFixups: objFunc.funcAddrFixups, gaddrFixups: objFunc.globalAddrFixups)
		objFunc.body = body

		result.push(objFunc)
	end 'eachFunc'

	return result
end 'emitWasmPerFunction'

// Compute which stdlib WASM functions are needed by analyzing user MIR call
// ops AND every `funcAbs64InRdata` reloc target. The reloc seeds matter
// because layout-copy / destroy / witness thunks aren't reached through a
// direct `call` op — they're invoked indirectly through descriptors loaded
// from rdata. Without seeding from relocs, those thunks would be missing
// from the wasm function table and `patchFuncAbs64InRdataForWasm` would
// trip the panic-on-miss check. Mirrors the native targets, which already
// use `appendFuncAbs64Seeds` for the same reason at link time.
function computeNeededWasmStdlibFunctions(module MirModule, globalData GlobalDataTable, stdlibCache StdlibCacheData) returns StdlibFuncNameSet
	var seeds = StringArray.create()

	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")

			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("invariant: opIdx from block.opRefs not in module.ops")

				match op 'extractCallee'
					call(_, callee, _) then seeds.push(callee)
					movImm to branch then break 'extractCallee'
					indirectCall to globalAddr then break 'extractCallee'
					funcAddr(_, name) then seeds.push(name)
					loadFramePtr to loadByte then break 'extractCallee'
					osAllocPages to osLockRelease then break 'extractCallee'
					tryCall(_, callee, _, _) then seeds.push(callee)
					witnessTryCall then break 'extractCallee'
					errorReturn then break 'extractCallee'
				end 'extractCallee'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'

	appendFuncAbs64Seeds(seeds, relocs: globalData.pendingRdataRelocs)

	// The synthetic `wasi:cli/run@0.2.6#run` export the emitter appends after all
	// module/stdlib bodies calls `mrt_start`, but no MIR call op does, so seed it
	// explicitly so findFunctionIndex resolves it. (cabi_realloc is self-contained
	// — a memory.grow bump allocator — so it needs no runtime function seed.)
	seeds.push("mrt_start")

	return computeNeededStdlibFunctionsWasm(seeds, stdlibCache: stdlibCache)
end 'computeNeededWasmStdlibFunctions'

// Compute transitive closure over WASM stdlib function dependencies.
export function computeNeededStdlibFunctionsWasm(seeds StringArray, stdlibCache StdlibCacheData) returns StdlibFuncNameSet
	var funcNameToIndex = StdlibFuncIndexMap.create()

	for (iter, func) in stdlibCache.wasmFunctions.withIterator() 'buildIndex'
		funcNameToIndex.upsert(func.name, value: iter.index())
	end 'buildIndex'

	var needed = StdlibFuncNameSet.create()
	var worklist = StringArray.create()

	for name in seeds 'seed'
		if funcNameToIndex.contains(name) and not needed.contains(name) 'isStdlib'
			needed.insert(name)
			worklist.push(name)
		end 'isStdlib'
	end 'seed'

	var wi = 0

	while wi < worklist.count() 'walkDeps'
		let nameRef = try worklist.get(wi) otherwise panic("invariant: wi < worklist.count() but worklist.get failed")
		let name = "{nameRef}"
		wi = wi + 1

		// `name` was only added to worklist via `funcNameToIndex.contains(...)` checks above,
		// so the lookup is mechanically guaranteed to succeed.
		let funcIdx = try funcNameToIndex.get(name) otherwise panic("invariant: name in worklist passed contains() but get() failed")

		let func = try stdlibCache.wasmFunctions.get(funcIdx) otherwise panic("invariant: funcIdx from funcNameToIndex not in stdlibCache.wasmFunctions")

		var newDeps = StringArray.create()

		for fixup in func.callFixups 'eachDep'
			if funcNameToIndex.contains(fixup.targetName) and not needed.contains(fixup.targetName) 'newDep'
				needed.insert(fixup.targetName)
				newDeps.push(fixup.targetName)
			end 'newDep'
		end 'eachDep'

		// Cache v29: funcAddr fixups also seed dependencies — a body that
		// takes the address of another stdlib function (e.g. __managed_mem_create
		// referencing __destruct___ManagedMemory) must keep that function alive
		// in the reachable set so its table slot exists and the funcAddr patch
		// resolves to a real index.
		for addrFix in func.funcAddrFixups 'eachAddrDep'
			if funcNameToIndex.contains(addrFix.targetName) and not needed.contains(addrFix.targetName) 'newAddrDep'
				needed.insert(addrFix.targetName)
				newDeps.push(addrFix.targetName)
			end 'newAddrDep'
		end 'eachAddrDep'

		for dep in newDeps 'addDeps'
			worklist.push(dep)
		end 'addDeps'
	end 'walkDeps'

	return needed
end 'computeNeededStdlibFunctionsWasm'

// ============================================================
// Module assembly
// ============================================================

// Wasm twin of `patchFuncAbs64InRdata`. Every `funcAbs64InRdata` reloc
// queued by `BuildLayoutDescriptors` and `BuildWitnessTables` names an
// 8-byte slot in an rdata blob (a layout descriptor's copy/destroy slot or
// a witness table's method slot). Native writers patch the slot with the
// target function's absolute code VA; the wasm equivalent is the function-
// table index that `call_indirect` consumes — both ends agree on the slot
// offset, only the value differs. Without this patch the slots stay zero
// on disk and any runtime dispatch loads zero, picking table[0] which
// has the wrong signature and trips wasm's "indirect call type mismatch".
//
// `funcSigs.nameIndex` maps a function name to its position in the wasm
// function table — `pushFunc` keeps the index in lockstep with `funcNames`
// during the collect phase. `computeNeededWasmStdlibFunctions` seeds
// reachability from these reloc targets, so by the time we patch, every
// reloc target must already be in the table. `indexOf` throws on miss; we
// translate that to a panic to mirror the native `lookupFuncCodeOffset`
// contract.
function patchFuncAbs64InRdataForWasm(globalData GlobalDataTable, funcSigs WasmFuncSigs)
	for reloc in globalData.pendingRdataRelocs 'eachReloc'
		match reloc.kind 'k'
			ripRelDisp32 to covdataArm64Adr then break 'k'
			funcAbs64InRdata(funcName, rdataLabel, offsetInLabel) then patchOneFuncAbs64InRdataWasm(globalData, funcName: funcName, rdataLabel: rdataLabel, offsetInLabel: offsetInLabel, funcSigs: funcSigs)
		end 'k'
	end 'eachReloc'
end 'patchFuncAbs64InRdataForWasm'

function patchOneFuncAbs64InRdataWasm(globalData GlobalDataTable, funcName String, rdataLabel String, offsetInLabel ByteOffset, funcSigs WasmFuncSigs)
	let blobIdx = try globalData.nameIndex.get(rdataLabel) otherwise panic("patchOneFuncAbs64InRdataWasm: nameIndex missing rdata label '{rdataLabel}'")
	let tableIdx = try funcSigs.indexOf(funcName) otherwise panic("patchOneFuncAbs64InRdataWasm: no function-table entry named '{funcName}' (BuildLayoutDescriptors / BuildWitnessTables emitted a reloc to a function not present in the wasm function table)")
	// ByteArray is a heap-managed reference so `.get()` aliases the
	// canonical bytes stored in `globalData.values` — `patchQword` mutates
	// in place and no write-back is needed.
	var blob = try globalData.values.get(blobIdx) otherwise panic("patchOneFuncAbs64InRdataWasm: values.get failed for blob '{rdataLabel}'")
	patchQword(blob, offset: offsetInLabel, value: tableIdx)
end 'patchOneFuncAbs64InRdataWasm'

// Lay out the wasm linear-memory image of the global data table starting at
// `baseOffset`. Each rdata entry (string literals, named globals) and each
// data-section entry (top-level `var` and static-field globals) gets its
// offset recorded in `offsets`. Data-section entries are padded to 8-byte
// alignment between entries to match `buildDataPreludeSection` on the native
// backends. The returned chunks let the write phase emit active data
// segments at exactly the offsets the lowering phase already saw, and the
// returned end offset feeds the stack-base calculation.
function layoutWasmGlobalData(globalData GlobalDataTable, baseOffset Wasm32Offset, offsets GlobalDataOffsetMap) returns (WasmDataChunkArray, Wasm32Offset)
	var chunks = WasmDataChunkArray.create()
	var dataOffset = baseOffset
	for i in 0 upto globalData.values.count() 'rdata'
		let name = try globalData.names.get(i) otherwise panic("layoutWasmGlobalData: globalData.names.get({i}) failed — names/values arrays out of sync")
		let data = try globalData.values.get(i) otherwise panic("layoutWasmGlobalData: globalData.values.get({i}) failed — names/values arrays out of sync")
		try offsets.insert(name, value: dataOffset) otherwise panic("layoutWasmGlobalData: duplicate global data name '{name}' at offset {dataOffset}")
		chunks.push(WasmDataChunk.create(dataOffset, bytes: data))
		dataOffset = (dataOffset + data.count()) as Wasm32Offset
	end 'rdata'
	for entry in globalData.dataSectionEntries 'dataEntries'
		try offsets.insert(entry.name, value: dataOffset) otherwise panic("layoutWasmGlobalData: duplicate data section entry '{entry.name}' at offset {dataOffset}")
		chunks.push(WasmDataChunk.create(dataOffset, bytes: entry.initialBytes))
		dataOffset = (dataOffset + entry.initialBytes.count()) as Wasm32Offset
		// Pad to 8-byte alignment so the next entry starts aligned (matches
		// `buildDataPreludeSection`). Wasm linear memory is zero-initialized,
		// so the gap doesn't need an explicit segment.
		while dataOffset mod 8 != 0 'align'
			dataOffset = dataOffset + 1
		end 'align'
	end 'dataEntries'
	return (chunks, dataOffset)
end 'layoutWasmGlobalData'

function emitWasmModule(module MirModule, globalData GlobalDataTable, stdlibCache StdlibCacheData) returns ByteArray
	var wasm = ByteArray.create()
	writeModuleHeader(wasm)

	// Drop the dead asyncify primitive stub functions before any positional
	// emission. They exist in the runtime IR only so the Std parser / type
	// resolution can look up the (arity, void-return) shape of the
	// `asyncify_*` call sites; every actual call is intercepted by
	// `emitDirectCall` and routed to the fixed import index, so the stub
	// bodies are never reached. Binaryen's `--asyncify` pass internalizes the
	// `asyncify.*` imports by generating module functions named exactly
	// `asyncify_start_unwind` / `asyncify_stop_unwind` / `asyncify_start_rewind`
	// / `asyncify_stop_rewind`; leaving our identically-named dead stubs in the
	// module makes that rename collide (module-utils.cpp rename assertion). We
	// filter them here — after the MIR pipeline, before emission — so every
	// downstream positional invariant (function/table/type indices) stays
	// consistent and the wasm-opt names are free.
	module.dropFunctionsByName(asyncifyStubFuncNames())

	// Build function table: map function names to indices.
	// Imported functions come first, then module functions.
	var funcNames = StringArray.create()
	var funcCount = 0 as Wasm32Index
	var funcSigs = WasmFuncSigs.create()

	// Determine which stdlib WASM functions are needed (reachability from
	// user calls + funcAbs64InRdata reloc targets — see helper for why both
	// matter on wasm).
	let neededStdlib = computeNeededWasmStdlibFunctions(module, globalData: globalData, stdlibCache: stdlibCache)

	// Walk module functions first, then needed stdlib functions, pushing
	// each into both the parallel funcNames array and the funcSigs index
	// in lockstep so the final ordering matches what the type/import
	// sections expect and lookup helpers see a fully populated index.
	for func in module.functions 'collectModule'
		funcNames.push(func.name)
		funcSigs.pushFunc(func.name, returnType: func.returnType, throwsTypeName: func.throwsTypeName)
		funcCount = funcCount + 1
	end 'collectModule'

	for func in stdlibCache.wasmFunctions 'collectStdlib'
		if neededStdlib.contains(func.name) 'isNeeded'
			funcNames.push(func.name)
			funcSigs.pushFunc(func.name, returnType: func.returnType, throwsTypeName: func.throwsTypeName)
			funcCount = funcCount + 1
		end 'isNeeded'
	end 'collectStdlib'

	// --- Type section ---
	// We need function types for:
	// 1. The Preview2 WASI imports (indices 0..34) — their canonical-ABI
	//    flattened core shapes, declared positionally just below.
	// 2. The Binaryen Asyncify primitives (types 35..38).
	// 3. Each module function.
	// 4. Stage F (closures): every distinct indirect-call signature used
	//    by `call_indirect` in any user function body. Direct-call types
	//    above are interned into `typeIndexMap` first so a matching
	//    indirect call reuses the same entry.
	var types = ByteArrayArray.create()
	var typeIndexMap = WasmTypeIndexMap.create()

	// --- WASI Preview2 import types (indices 0..34) ---
	// These occupy fixed positional type slots so the function section's
	// `wasiImportCount + i` indexing keeps module-function-0 at type index
	// wasiImportCount. Signatures are the CANONICAL-ABI flattened core shapes
	// (resource handles = i32; list/string params = (ptr i32, len i32); a
	// non-scalar / >1-value result is written to a trailing return-area i32
	// pointer so the core func itself returns nothing). Order MUST match the
	// `wasi*` index constants and the import declarations below.
	let i64v = makeByteArray1(wasmTypeI64)
	let i32v = makeByteArray1(wasmTypeI32)
	let novals = ByteArray.create()
	// 0  exit(status i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 1  get-stdout() -> i32
	pushWasiType(types, i32Count: 0, extra: novals, results: i32v)
	// 2  get-stderr() -> i32
	pushWasiType(types, i32Count: 0, extra: novals, results: i32v)
	// 3  get-stdin() -> i32
	pushWasiType(types, i32Count: 0, extra: novals, results: i32v)
	// 4  output-stream.blocking-write-and-flush(self i32, ptr i32, len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 4, extra: novals, results: novals)
	// 5  input-stream.blocking-read(self i32, len i64, ret i32) -> ()
	pushWasiType(types, i32Count: 1, extra: makeByteArray2(wasmTypeI64, b: wasmTypeI32), results: novals)
	// 6  [drop]output-stream(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 7  [drop]input-stream(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 8  get-arguments(ret i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 9  monotonic-clock.subscribe-duration(when i64) -> pollable i32
	pushWasiType(types, i32Count: 0, extra: i64v, results: i32v)
	// 10 pollable.block(self i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 11 [drop]pollable(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 12 preopens.get-directories(ret i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 13 descriptor.open-at(self i32, path-flags i32, ptr i32, len i32, open-flags i32, desc-flags i32, ret i32) -> ()
	pushWasiType(types, i32Count: 7, extra: novals, results: novals)
	// 14 descriptor.read(self i32, length i64, offset i64, ret i32) -> ()
	pushWasiType(types, i32Count: 1, extra: makeByteArray3i(wasmTypeI64, b: wasmTypeI64, c: wasmTypeI32), results: novals)
	// 15 descriptor.write(self i32, ptr i32, len i32, offset i64, ret i32) -> ()
	pushWasiType(types, i32Count: 3, extra: makeByteArray2(wasmTypeI64, b: wasmTypeI32), results: novals)
	// 16 descriptor.stat(self i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 17 descriptor.stat-at(self i32, path-flags i32, ptr i32, len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 5, extra: novals, results: novals)
	// 18 descriptor.unlink-file-at(self i32, ptr i32, len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 4, extra: novals, results: novals)
	// 19 descriptor.create-directory-at(self i32, ptr i32, len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 4, extra: novals, results: novals)
	// 20 descriptor.read-directory(self i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 21 directory-entry-stream.read-directory-entry(self i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 22 [drop]descriptor(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 23 [drop]directory-entry-stream(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 24 instance-network() -> network i32
	pushWasiType(types, i32Count: 0, extra: novals, results: i32v)
	// 25 create-tcp-socket(family i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 26 tcp-socket.start-connect(self i32, network i32, ip-socket-address..., ret i32) -> ()
	//    ip-socket-address is a variant {ipv4|ipv6}; the canonical ABI flattens it
	//    to the LARGER arm (ipv6): disc i32 + 11 i32 payload (port, flow-info,
	//    8x address words, scope-id). Flattened core sig is 15 i32: self, network,
	//    disc, p0..p10 (11), ret-area. For an ipv4 connect we set disc=0,
	//    payload[0]=port, payload[1..4]=address octets, the rest 0.
	pushWasiType(types, i32Count: 15, extra: novals, results: novals)
	// 27 tcp-socket.finish-connect(self i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 28 tcp-socket.subscribe(self i32) -> pollable i32
	pushWasiType(types, i32Count: 1, extra: novals, results: i32v)
	// 29 tcp-socket.shutdown(self i32, shutdown-type i32, ret i32) -> ()
	pushWasiType(types, i32Count: 3, extra: novals, results: novals)
	// 30 [drop]tcp-socket(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 31 [drop]network(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 32 resolve-addresses(network i32, ptr i32, len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 4, extra: novals, results: novals)
	// 33 resolve-next-address(self i32, ret i32) -> ()
	pushWasiType(types, i32Count: 2, extra: novals, results: novals)
	// 34 [drop]resolve-address-stream(i32) -> ()
	pushWasiType(types, i32Count: 1, extra: novals, results: novals)
	// 35 poll(list-ptr i32, list-len i32, ret i32) -> ()
	pushWasiType(types, i32Count: 3, extra: novals, results: novals)
	// 36 monotonic-clock.now() -> instant i64
	pushWasiType(types, i32Count: 0, extra: novals, results: i64v)

	// Types 37-40: the Binaryen Asyncify primitives the wasm green-thread runtime
	// imports (resolved by `wasm-opt --asyncify`). Pointers are i32 on wasm32. Each
	// gets its own positional slot so module-function types stay at `wasiImportCount
	// + i` (37 & 39 and 38 & 40 share a shape but not a slot).
	// Type 37: (i32) -> () — asyncify.start_unwind(data_ptr)
	var asyncifyUnwindArgType = ByteArray.create()
	writeFuncType(asyncifyUnwindArgType, paramTypes: makeByteArray1(wasmTypeI32), resultTypes: ByteArray.create())
	types.push(asyncifyUnwindArgType)
	// Type 38: () -> () — asyncify.stop_unwind()
	var asyncifyStopUnwindType = ByteArray.create()
	writeFuncType(asyncifyStopUnwindType, paramTypes: ByteArray.create(), resultTypes: ByteArray.create())
	types.push(asyncifyStopUnwindType)
	// Type 39: (i32) -> () — asyncify.start_rewind(data_ptr)
	var asyncifyRewindArgType = ByteArray.create()
	writeFuncType(asyncifyRewindArgType, paramTypes: makeByteArray1(wasmTypeI32), resultTypes: ByteArray.create())
	types.push(asyncifyRewindArgType)
	// Type 40: () -> () — asyncify.stop_rewind()
	var asyncifyStopRewindType = ByteArray.create()
	writeFuncType(asyncifyStopRewindType, paramTypes: ByteArray.create(), resultTypes: ByteArray.create())
	types.push(asyncifyStopRewindType)

	// Types for module functions (type index = wasiImportCount + i for each)
	for func in module.functions 'buildTypes'
		let funcThrows = match func.throwsTypeName 'kind'
			none gives false
			throwing gives true
		end 'kind'
		let typeBytes = buildFuncTypeEntry(func.paramCount, paramTypes: func.paramTypes, returnType: func.returnType, throws: funcThrows)
		// Module-function types occupy fixed positions in the type table
		// because the function section indexes into them positionally;
		// we still record them in the dedup map so a downstream indirect
		// call with the same signature picks up the existing entry.
		let myIdx = types.count() as Wasm32Index
		types.push(typeBytes)
		if not typeIndexMap.contains(typeBytes) 'recordDedup'
			typeIndexMap.upsert(typeBytes, value: myIdx)
		end 'recordDedup'
	end 'buildTypes'

	// Types for pre-compiled stdlib functions
	for func in stdlibCache.wasmFunctions 'buildStdlibTypes'
		if not neededStdlib.contains(func.name) 'skip'
			continue
		end 'skip'

		let funcThrows = match func.throwsTypeName 'kind'
			none gives false
			throwing gives true
		end 'kind'
		let typeBytes = buildFuncTypeEntry(func.paramCount, paramTypes: func.paramTypes, returnType: func.returnType, throws: funcThrows)
		let myIdx = types.count() as Wasm32Index
		types.push(typeBytes)
		if not typeIndexMap.contains(typeBytes) 'recordDedup'
			typeIndexMap.upsert(typeBytes, value: myIdx)
		end 'recordDedup'
	end 'buildStdlibTypes'

	// Stage F (closures): collect indirect-call signatures from every
	// user function body and intern them into typeIndexMap. New types get
	// appended to the type table. Stdlib functions don't take addresses
	// today, so we only scan user code — but the dedup map also covers
	// stdlib direct-call types above so an indirect call with a matching
	// shape would still find an entry.
	collectIndirectCallTypes(module, types: types, typeIndexMap: typeIndexMap)

	// Phase 11.4: cached stdlib functions can also contain indirect-call
	// type fixups (witness-method dispatch). Register their signatures
	// against the type section now so the section is sealed with every
	// needed entry; the stdlib body patcher below resolves the indices
	// out of `typeIndexMap`. Only walk needed bodies so an unreferenced
	// stdlib function doesn't bloat the type table.
	for func in stdlibCache.wasmFunctions 'seedStdlibIndirectTypes'
		if not neededStdlib.contains(func.name) 'skip'
			continue
		end 'skip'
		for tyFix in func.typeFixups 'eachFixup'
			_ = lookupOrRegisterIndirectType(types, typeIndexMap: typeIndexMap, signatureBytes: tyFix.signatureBytes)
		end 'eachFixup'
	end 'seedStdlibIndirectTypes'

	// --- Synthetic Preview2 component-adapter types ---
	// The component model's CABI requires two extra core exports that have no
	// MIR function: `cabi_realloc` (the canonical-ABI allocator used by the
	// component glue when lifting/lowering lists & strings across the call
	// boundary) and the `wasi:cli/run@0.2.6#run` entry point that REPLACES the
	// preview1 `_start`. We synthesize both as emitter-built raw bodies appended
	// after every module + stdlib body, so they occupy the last two wasm
	// function indices. Their two func types are appended here, AFTER all
	// module/stdlib/indirect types, so the existing positional `wasiImportCount
	// + i` module-type indexing is untouched. Index math:
	//   cabiReallocTypeIdx = types.count() (before pushing)   runTypeIdx = +1
	//   cabiReallocFuncIdx  = wasiImportCount + funcCount      runFuncIdx  = +1
	// (real functions span wasiImportCount .. wasiImportCount+funcCount-1; these
	//  two follow immediately and are NOT call_indirect targets, so they stay
	//  out of the table / element section — table size remains funcCount.)
	let cabiReallocTypeIdx = types.count() as Wasm32Index
	var cabiReallocType = ByteArray.create()
	writeFuncType(cabiReallocType, paramTypes: makeByteArray4(wasmTypeI32, b: wasmTypeI32, c: wasmTypeI32, d: wasmTypeI32), resultTypes: makeByteArray1(wasmTypeI32))
	types.push(cabiReallocType)
	let runTypeIdx = types.count() as Wasm32Index
	var runType = ByteArray.create()
	writeFuncType(runType, paramTypes: ByteArray.create(), resultTypes: makeByteArray1(wasmTypeI32))
	types.push(runType)

	let cabiReallocFuncIdx = (wasiImportCount + funcCount) as Wasm32Index
	let runFuncIdx = (wasiImportCount + funcCount + 1) as Wasm32Index

	writeTypeSection(wasm, types: types)

	// --- Import section (WASI Preview2 interface functions) ---
	// Each import's module name is the full versioned component-model interface
	// id; the field name is the interface function (or `[method]Type.fn` /
	// `[resource-drop]Type`). `wasm-tools component new` matches these against the
	// world in vendor/wasi-wit and synthesizes the canon lift/lower adapters. The
	// typeIndex MUST equal the import index (positional), matching the type block.
	var imports = ByteArray.create()
	var importCount = 0 as Wasm32Index
	let modCliExit = b"wasi:cli/exit@0.2.6"
	let modCliStdout = b"wasi:cli/stdout@0.2.6"
	let modCliStderr = b"wasi:cli/stderr@0.2.6"
	let modCliStdin = b"wasi:cli/stdin@0.2.6"
	let modCliEnv = b"wasi:cli/environment@0.2.6"
	let modIoStreams = b"wasi:io/streams@0.2.6"
	let modIoPoll = b"wasi:io/poll@0.2.6"
	let modClock = b"wasi:clocks/monotonic-clock@0.2.6"
	let modFsPreopens = b"wasi:filesystem/preopens@0.2.6"
	let modFsTypes = b"wasi:filesystem/types@0.2.6"
	let modSockInstNet = b"wasi:sockets/instance-network@0.2.6"
	let modSockTcpCreate = b"wasi:sockets/tcp-create-socket@0.2.6"
	let modSockTcp = b"wasi:sockets/tcp@0.2.6"
	let modSockNet = b"wasi:sockets/network@0.2.6"
	let modSockNameLookup = b"wasi:sockets/ip-name-lookup@0.2.6"

	importCount = addFuncImport(imports, moduleName: modCliExit, fieldName: b"exit-with-code", typeIndex: 0, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modCliStdout, fieldName: b"get-stdout", typeIndex: 1, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modCliStderr, fieldName: b"get-stderr", typeIndex: 2, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modCliStdin, fieldName: b"get-stdin", typeIndex: 3, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoStreams, fieldName: b"[method]output-stream.blocking-write-and-flush", typeIndex: 4, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoStreams, fieldName: b"[method]input-stream.blocking-read", typeIndex: 5, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoStreams, fieldName: b"[resource-drop]output-stream", typeIndex: 6, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoStreams, fieldName: b"[resource-drop]input-stream", typeIndex: 7, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modCliEnv, fieldName: b"get-arguments", typeIndex: 8, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modClock, fieldName: b"subscribe-duration", typeIndex: 9, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoPoll, fieldName: b"[method]pollable.block", typeIndex: 10, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoPoll, fieldName: b"[resource-drop]pollable", typeIndex: 11, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsPreopens, fieldName: b"get-directories", typeIndex: 12, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.open-at", typeIndex: 13, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.read", typeIndex: 14, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.write", typeIndex: 15, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.stat", typeIndex: 16, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.stat-at", typeIndex: 17, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.unlink-file-at", typeIndex: 18, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.create-directory-at", typeIndex: 19, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]descriptor.read-directory", typeIndex: 20, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[method]directory-entry-stream.read-directory-entry", typeIndex: 21, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[resource-drop]descriptor", typeIndex: 22, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modFsTypes, fieldName: b"[resource-drop]directory-entry-stream", typeIndex: 23, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockInstNet, fieldName: b"instance-network", typeIndex: 24, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcpCreate, fieldName: b"create-tcp-socket", typeIndex: 25, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcp, fieldName: b"[method]tcp-socket.start-connect", typeIndex: 26, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcp, fieldName: b"[method]tcp-socket.finish-connect", typeIndex: 27, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcp, fieldName: b"[method]tcp-socket.subscribe", typeIndex: 28, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcp, fieldName: b"[method]tcp-socket.shutdown", typeIndex: 29, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockTcp, fieldName: b"[resource-drop]tcp-socket", typeIndex: 30, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockNet, fieldName: b"[resource-drop]network", typeIndex: 31, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockNameLookup, fieldName: b"resolve-addresses", typeIndex: 32, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockNameLookup, fieldName: b"[method]resolve-address-stream.resolve-next-address", typeIndex: 33, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modSockNameLookup, fieldName: b"[resource-drop]resolve-address-stream", typeIndex: 34, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modIoPoll, fieldName: b"poll", typeIndex: 35, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: modClock, fieldName: b"now", typeIndex: 36, countRef: importCount)

	// Imports 37-40: the Binaryen Asyncify primitives. Module name "asyncify" is the
	// namespace `wasm-opt --asyncify` recognizes; it rewrites the green-thread
	// runtime's calls to these into direct calls to the functions it generates
	// (which spill/restore a coroutine's call stack to linear memory), then drops
	// the imports — so the final module has no unresolved imports.
	let asyncifyModule = b"asyncify"
	importCount = addFuncImport(imports, moduleName: asyncifyModule, fieldName: b"start_unwind", typeIndex: 37, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: asyncifyModule, fieldName: b"stop_unwind", typeIndex: 38, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: asyncifyModule, fieldName: b"start_rewind", typeIndex: 39, countRef: importCount)
	importCount = addFuncImport(imports, moduleName: asyncifyModule, fieldName: b"stop_rewind", typeIndex: 40, countRef: importCount)

	var importSection = ByteArray.create()
	writeUleb128(importSection, value: importCount)
	importSection.append(imports)
	writeImportSection(wasm, imports: importSection)

	// --- Function section ---
	// Map each module function to its type index
	var typeIndices = WasmFuncIndexArray.create()
	for i in 0 upto funcCount 'eachFunc'
		let typeIdx = (wasiImportCount + i) as Wasm32Index
		typeIndices.push(typeIdx)
	end 'eachFunc'
	// The two synthetic Preview2 adapter functions (cabi_realloc, run) follow
	// the real functions positionally; declare their type indices here so the
	// function section's index space matches the code section appended below.
	typeIndices.push(cabiReallocTypeIdx)
	typeIndices.push(runTypeIdx)
	writeFunctionSection(wasm, typeIndices: typeIndices)

	// --- Table section ---
	// Stage F (closures): emit a single funcref table sized to hold every
	// module function (user + stdlib). The element section below populates
	// it with each function's wasm index in order, so call_indirect can
	// fetch a callee by table index. Table index N in our scheme maps to
	// wasm function index `wasiImportCount + N` — i.e., the table is just
	// the contiguous module-function range, with imports excluded.
	writeTableSection(wasm, initialSize: funcCount)

	// --- Memory section ---
	// 1 page = 64 KiB. Reserve enough pages for scratch + heap + global data + stack.
	writeMemorySection(wasm, initialPages: initialMemoryPages as Wasm32Index)

	// --- Export section ---
	var exports = ByteArray.create()
	var exportCount = 0 as Wasm32Index

	// Export the component canonical-ABI allocator and the Preview2 run entry
	// point. These replace the preview1 `_start` export: `wasm-tools component
	// new` lifts the core module against the `maxon:app/command` world, which
	// requires `cabi_realloc` for list/string marshalling and an export named
	// exactly `wasi:cli/run@0.2.6#run` (() -> i32, 0 = ok) as the entry point.
	exportCount = addFuncExport(exports, name: b"cabi_realloc", funcIndex: cabiReallocFuncIdx, countRef: exportCount)
	exportCount = addFuncExport(exports, name: b"wasi:cli/run@0.2.6#run", funcIndex: runFuncIdx, countRef: exportCount)

	// Export memory
	exportCount = addMemoryExport(exports, name: b"memory", memIndex: 0, countRef: exportCount)

	var exportSection = ByteArray.create()
	writeUleb128(exportSection, value: exportCount)
	exportSection.append(exports)
	writeExportSection(wasm, exports: exportSection)

	// --- Element section ---
	// Stage F (closures): populate the function table with one entry per
	// module function in the same order as the function section. Table
	// index N gets wasm function index `wasiImportCount + N`. funcAddr
	// emits `i32.const N`; call_indirect reads through the table to
	// recover the absolute index. Entries appear in user-then-stdlib
	// order, matching the function section, so funcTableIndices below
	// can use the same `i` counter.
	var tableEntries = WasmFuncIndexArray.create()
	for i in 0 upto funcCount 'collectTableEntries'
		tableEntries.push((wasiImportCount + i) as Wasm32Index)
	end 'collectTableEntries'
	writeElementSection(wasm, funcIndices: tableEntries)

	// Merge all stdlib global data entries (WASM uses globalDataOffsets, not rdata relocs)
	for i in 0 upto stdlibCache.globalData.names.count() 'mergeStdlibData'
		let gName = try stdlibCache.globalData.names.get(i) otherwise panic("emitWasmModule.mergeStdlibData: stdlibCache.globalData.names.get({i}) failed")
		let existing = lookupGlobalData(globalData, name: gName)
		if existing.count() == 0 'notPresent'
			let gData = try stdlibCache.globalData.values.get(i) otherwise panic("emitWasmModule.mergeStdlibData: stdlibCache.globalData.values.get({i}) failed — names/values out of sync")
			addNamedGlobalData(globalData, name: gName, data: gData)
		end 'notPresent'
	end 'mergeStdlibData'

	// Phase 11.3 (wasm): patch every `funcAbs64InRdata` reloc into its
	// witness/layout rdata blob with the target function's wasm table index.
	// Native targets store an absolute code VA in the same 8-byte slot; wasm
	// has no addressable code section, so the slot holds the function-table
	// index that `call_indirect` reads. Without this patch, the witness
	// slots stay zero on disk and a runtime dispatch loads zero, making
	// `call_indirect` trap with "indirect call type mismatch" against
	// table[0]. Runs before `layoutWasmGlobalData` so the patched bytes
	// land in the data segments verbatim.
	patchFuncAbs64InRdataForWasm(globalData, funcSigs: funcSigs)

	// --- Compute memory layout for global data and stack ---
	// Global data lives immediately after the iovec scratch (1024..). Stack
	// slots follow global data. Top-level / static-field globals (top-level
	// `var counter = 42`, etc.) live in `dataSectionEntries` and follow the
	// rdata payloads — `layoutWasmGlobalData` mirrors the native
	// `buildDataPreludeSection` layout so MirOp.globalAddr resolves
	// `__data_<name>` symbols against `globalDataOffsets`. Heap allocations
	// do not occupy a fixed range; the slab allocator grows linear memory on
	// demand via osAllocPages → memory.grow.
	var globalDataOffsets = GlobalDataOffsetMap.create()
	let (dataChunks, dataEnd) = layoutWasmGlobalData(globalData, baseOffset: scratchEnd as Wasm32Offset, offsets: globalDataOffsets)
	let stackBase = alignUp(dataEnd as ByteCount, alignment: 16) as Wasm32Offset

	// --- Code section ---
	var bodies = ByteArrayArray.create()
	var lowering = WasmFunctionLowering.create(module, funcNames: funcNames, funcSigs: funcSigs, globalDataOffsets: globalDataOffsets, stackBase: stackBase, fixedCalls: false)
	// Stage F (closures): hand the type-index map and table-index map to
	// the lowering so emitFuncAddr / emitIndirectCall don't have to walk
	// up to module scope. The table-index map mirrors the element section
	// emitted above — one entry per module function, in the same order.
	lowering.typeIndices = typeIndexMap
	for i in 0 upto funcCount 'recordTableIdx'
		let name = try funcNames.get(i) otherwise panic("invariant: i < funcCount but funcNames.get failed")
		lowering.funcTableIndices.upsert(name, value: i as Wasm32Index)
	end 'recordTableIdx'
	var noFixups = WasmCallFixupArray.create()
	var noTypeFixups = WasmTypeFixupArray.create()
	var noAddrFixups = WasmFuncAddrFixupArray.create()
	var noGlobalAddrFixups = WasmGlobalAddrFixupArray.create()
	for func in module.functions 'emitBodies'
		let body = lowering.lowerFunction(func, fixups: noFixups, tyFixups: noTypeFixups, addrFixups: noAddrFixups, gaddrFixups: noGlobalAddrFixups)
		bodies.push(body)
	end 'emitBodies'

	// Append pre-compiled stdlib function bodies with patched call indices
	for func in stdlibCache.wasmFunctions 'emitStdlibBodies'
		if not neededStdlib.contains(func.name) 'skip'
			continue
		end 'skip'

		// Clone the body and patch call fixups with resolved function indices
		var body = ByteArray.create()
		body.append(func.body)

		for fixup in func.callFixups 'patchCalls'
			let funcIdx = findFunctionIndex(funcSigs, name: fixup.targetName, importCount: wasiImportCount)
			patchUleb128Fixed5(body, offset: fixup.bodyOffset, value: funcIdx)
		end 'patchCalls'

		// Patch indirect-call type-section indices. The fixup carries the
		// encoded function-type signature; if the user pipeline's type
		// section already has an index for that shape, reuse it. Otherwise
		// register a fresh index (appending to `types`). This keeps the
		// type table compact and ensures the index written into the body
		// resolves at runtime to the right call_indirect signature.
		for tyFix in func.typeFixups 'patchTypes'
			let resolvedTypeIdx = lookupOrRegisterIndirectType(types, typeIndexMap: typeIndexMap, signatureBytes: tyFix.signatureBytes)
			patchUleb128Fixed5(body, offset: tyFix.bodyOffset, value: resolvedTypeIdx)
		end 'patchTypes'

		// Patch funcAddr table indices for stdlib functions that took the
		// address of another function (e.g. `__managed_mem_create` baking
		// the address of `__destruct___ManagedMemory` into the mm header).
		// The fixup recorded `targetName`; we resolve it against the
		// user-build's funcTableIndices map populated immediately before
		// this loop walks the stdlib bodies.
		for addrFix in func.funcAddrFixups 'patchAddrs'
			let tableIdx = try lowering.funcTableIndices.get(addrFix.targetName) otherwise panic("emitWasmModule: funcAddr fixup target '{addrFix.targetName}' missing from user-build table (stdlib body '{func.name}' references it but it isn't in the final module)")
			patchSleb128Fixed5(body, offset: addrFix.bodyOffset, value: tableIdx as ParsedInt)
		end 'patchAddrs'

		// Patch globalAddr linear-memory offsets. The stdlib cache baked
		// stdlib-only offsets which don't match the merged image once user
		// globalData is layered in first; resolve each fixup against the
		// final globalDataOffsets map.
		for gAddrFix in func.globalAddrFixups 'patchGlobalAddrs'
			let resolved = try globalDataOffsets.get(gAddrFix.targetName) otherwise panic("emitWasmModule: globalAddr fixup target '{gAddrFix.targetName}' missing from final globalDataOffsets (stdlib body '{func.name}' references it but it isn't in the merged data section)")
			patchSleb128Fixed5(body, offset: gAddrFix.bodyOffset, value: resolved as ParsedInt)
		end 'patchGlobalAddrs'

		bodies.push(body)
	end 'emitStdlibBodies'

	// --- Synthetic Preview2 adapter bodies (last two function indices) ---
	// cabi_realloc(old_ptr i32, old_size i32, align i32, new_size i32) -> i32:
	// the component canonical-ABI allocator the host calls when lifting/lowering
	// list<u8>/string return payloads across the call boundary. We ignore
	// old_ptr/old_size/align and allocate FRESH linear-memory pages per call via
	// memory.grow: ret = memory.grow(ceil(new_size/64KiB)) << 16. This is
	// deliberately NOT the slab allocator (mrt_alloc) — cabi_realloc must resolve
	// for EVERY program (including ones that link no allocator) and runs from
	// component glue OUTSIDE any maxon stack frame. memory.grow returns the
	// previous page count, so the returned region is brand-new memory that can
	// never collide with the static data, the maxon stack, or the slab heap.
	// The returned buffers are transient (each call site memcpys the bytes out
	// immediately), and programs are short-lived, so the per-call page is not
	// reclaimed — acceptable. On OOM memory.grow returns -1; the host then traps
	// on the bad pointer, which surfaces as a clean failure.
	var cabiReallocBody = ByteArray.create()
	writeUleb128(cabiReallocBody, value: 0)  // 0 locals
	// pages = (new_size + 65535) >> 16.
	cabiReallocBody.push(opLocalGet)
	writeUleb128(cabiReallocBody, value: 3)
	cabiReallocBody.push(opI32Const)
	writeSleb128(cabiReallocBody, value: 65535)
	cabiReallocBody.push(0x6A)  // i32.add
	cabiReallocBody.push(opI32Const)
	writeSleb128(cabiReallocBody, value: 16)
	cabiReallocBody.push(0x76)  // i32.shr_u
	// memory.grow(pages) -> previous page count; << 16 = byte base.
	cabiReallocBody.push(0x40)
	cabiReallocBody.push(0x00)  // memory.grow
	cabiReallocBody.push(opI32Const)
	writeSleb128(cabiReallocBody, value: 16)
	cabiReallocBody.push(0x74)  // i32.shl
	cabiReallocBody.push(opEnd)
	bodies.push(cabiReallocBody)

	// wasi:cli/run@0.2.6#run() -> i32: the component-model entry point that
	// replaces preview1 `_start`. It calls the runtime entry (mrt_start, which
	// runs `main` and, on a normal exit, invokes exit-with-code) then returns 0
	// (= ok) for the run result. A non-zero program ExitCode propagates via the
	// exit-with-code import emitOsExit already routes to, not via this result.
	var runBody = ByteArray.create()
	writeUleb128(runBody, value: 0)
	runBody.push(opCall)
	writeUleb128(runBody, value: findFunctionIndex(funcSigs, name: "mrt_start", importCount: wasiImportCount))
	runBody.push(opI32Const)
	writeSleb128(runBody, value: 0)
	runBody.push(opEnd)
	bodies.push(runBody)

	writeCodeSection(wasm, bodies: bodies)

	// --- Data section ---
	// Emit one active data segment per chunk produced by the layout pass so
	// the on-disk offsets match what the lowering phase recorded in
	// `globalDataOffsets`. Linear memory between/after segments stays zero,
	// which covers both the heap arena's bump counter and the alignment
	// padding between data-section entries.
	if dataChunks.count() > 0 'hasData'
		var segments = ByteArray.create()
		for chunk in dataChunks 'eachChunk'
			writeActiveDataSegment(segments, offset: chunk.offset, data: chunk.bytes)
		end 'eachChunk'
		writeDataSection(wasm, segments: segments, segmentCount: dataChunks.count() as Wasm32Index)
	end 'hasData'

	// --- Name section (custom section for debug info) ---
	// Encodes module name and function names so wasmtime / Chrome devtools /
	// wasm-objdump can show them in stack traces and listings. Per the
	// WebAssembly Name Section spec, subsections must appear in increasing
	// id order: 0 = module name, 1 = function names, 2 = local names.
	var nameSection = ByteArray.create()
	writeWasmName(nameSection, name: b"name")

	// Subsection 0: module name.
	var moduleNamePayload = ByteArray.create()
	writeWasmName(moduleNamePayload, name: b"maxon")
	nameSection.push(0)
	writeUleb128(nameSection, value: moduleNamePayload.count() as Wasm32Index)
	nameSection.append(moduleNamePayload)

	// Subsection 1: function names. This is a `namemap` (a vec of (index, name)
	// pairs); the leading count is the number of PAIRS written, not the total
	// function-index space. We name the 5 WASI imports below plus every
	// module-defined function (`funcCount`). Declaring `wasiImportCount + funcCount`
	// instead over-counts by the unnamed WASI imports, so a strict parser
	// (Binaryen's `wasm-opt`) reads past the subsection to EOF — wasmtime tolerates
	// it, but the asyncify post-process pass does not.
	// +2 accounts for the synthetic cabi_realloc / run adapter functions named
	// after the module-function loop; a miscount makes wasm-opt's asyncify pass
	// read the namemap past its bound (see note above).
	let namedWasiImports = 5
	let syntheticNamedFuncs = 2
	var funcNameMap = ByteArray.create()
	let totalFuncCount = (namedWasiImports + funcCount + syntheticNamedFuncs) as Wasm32Index
	writeUleb128(funcNameMap, value: totalFuncCount)
	// Names for the first five Preview2 WASI imports (indices 0..4), matching
	// the import table emitted above: exit, stdout/stderr/stdin accessors, and
	// the blocking stdout writer. Debug-only aliases for backtraces.
	writeUleb128(funcNameMap, value: 0)
	writeWasmName(funcNameMap, name: b"exit")
	writeUleb128(funcNameMap, value: 1)
	writeWasmName(funcNameMap, name: b"get_stdout")
	writeUleb128(funcNameMap, value: 2)
	writeWasmName(funcNameMap, name: b"get_stderr")
	writeUleb128(funcNameMap, value: 3)
	writeWasmName(funcNameMap, name: b"get_stdin")
	writeUleb128(funcNameMap, value: 4)
	writeWasmName(funcNameMap, name: b"blocking_write_and_flush")
	for i in 0 upto funcCount 'nameFuncs'
		let name = try funcNames.get(i) otherwise "unknown"
		writeUleb128(funcNameMap, value: (wasiImportCount + i) as Wasm32Index)
		writeWasmName(funcNameMap, name: name.toByteArray())
	end 'nameFuncs'
	// Name the two synthetic adapter functions appended to the code section.
	writeUleb128(funcNameMap, value: cabiReallocFuncIdx)
	writeWasmName(funcNameMap, name: b"cabi_realloc")
	writeUleb128(funcNameMap, value: runFuncIdx)
	writeWasmName(funcNameMap, name: b"run")
	nameSection.push(1)
	writeUleb128(nameSection, value: funcNameMap.count() as Wasm32Index)
	nameSection.append(funcNameMap)

	writeSection(wasm, sectionId: 0, contents: nameSection)

	return wasm
end 'emitWasmModule'

// ============================================================
// WasmFunctionLowering — per-function emission state
// ============================================================

// Stage F (closures): map "type-section signature bytes" → typeIndex
// for type-section dedup. Direct-call types and indirect-call types
// share entries — we never emit the same `(params...) -> result` twice.
typealias WasmTypeIndexMap = Map with (ByteArray, Wasm32Index)

// Stage F (closures): map "function name" → table index. Every user
// function lands in the function table at a stable index so `funcAddr`
// emits a deterministic `i32.const <tableIdx>`. The table index is the
// position within `module.functions` (0-based); the linker patches the
// element-section entries with the absolute wasm function index
// (`wasiImportCount + tableIdx + offset_into_module_funcs`) at module
// emission time.
typealias WasmFuncTableIndexMap = Map with (String, Wasm32Index)

// CopyEmitter implementation for the wasm backend. Wasm has a single location
// kind (locals), value id == local index, and no register allocation — so the
// "ordinals" the shared sequencer manipulates are wasm local indices directly.
// A move is `local.get src; local.set dst`; the local.get/local.set opcodes are
// type-agnostic (the declared local type fixes i64 vs f64), so the GPR and FP
// move emitters are identical. Wasm has no exchange instruction, so hasXchg is
// false and emitXchg is never reached (swaps route through the 3-mov scratch
// path). The two scratch ordinals are the reserved i64/f64 cycle-break locals.
//
// Captures `body` by reference (ByteArray is a reference type — it is the same
// buffer the lowering emits into), so copies interleave correctly with the
// surrounding dispatch/branch bytes.
type WasmCopyEmitter implements CopyEmitter
	var body as ByteArray
	var gprScratch as Wasm32Index
	var fpScratch as Wasm32Index

	static function create(body ByteArray, gprScratch Wasm32Index, fpScratch Wasm32Index) returns WasmCopyEmitter
		return Self{body: body, gprScratch: gprScratch, fpScratch: fpScratch}
	end 'create'

	function emitMovReg(destOrd RegOrdinal, srcOrd RegOrdinal)
		emitWasmLocalCopy(self.body, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovReg'

	function emitMovFp(destOrd RegOrdinal, srcOrd RegOrdinal)
		emitWasmLocalCopy(self.body, destOrd: destOrd, srcOrd: srcOrd)
	end 'emitMovFp'

	function emitXchg(ord1 RegOrdinal, ord2 RegOrdinal)
		panic("wasm: emitXchg unreachable (hasXchg=false)")
	end 'emitXchg'

	function gprCycleBreakOrd() returns RegOrdinal
		return self.gprScratch
	end 'gprCycleBreakOrd'

	function fpCycleBreakOrd() returns RegOrdinal
		return self.fpScratch
	end 'fpCycleBreakOrd'

	function hasXchg() returns bool
		return false
	end 'hasXchg'
end 'WasmCopyEmitter'

// Emit `local.get srcOrd; local.set destOrd` into a wasm function body — the
// wasm move primitive shared by both register classes.
function emitWasmLocalCopy(body ByteArray, destOrd RegOrdinal, srcOrd RegOrdinal)
	body.push(opLocalGet)
	writeUleb128(body, value: srcOrd as Wasm32Index)
	body.push(opLocalSet)
	writeUleb128(body, value: destOrd as Wasm32Index)
end 'emitWasmLocalCopy'

type WasmFunctionLowering
	// Module-level state (constant across all functions)
	var module as MirModule
	var funcNames as StringArray
	var funcSigs as WasmFuncSigs
	var globalDataOffsets as GlobalDataOffsetMap
	var stackBase as Wasm32Offset
	var fixedCalls as bool
	// Stage F (closures): name → table index map for funcAddr lowering.
	// Empty in stdlib-cache mode (fixedCalls = true) — stdlib doesn't take
	// function addresses today, so we save the work. Populated by
	// emitWasmModule before each user function is lowered.
	export var funcTableIndices as WasmFuncTableIndexMap
	// Stage F (closures): signature-bytes → typeIndex map shared by every
	// indirect-call site. Pre-populated with the module's own function
	// types so direct callees and indirect callees with matching shapes
	// share entries. Pre-populated in emitWasmModule before any function
	// body is lowered.
	export var typeIndices as WasmTypeIndexMap

	// Per-function state (re-initialized in lowerFunction)
	var func as IrFunction
	var body as ByteArray
	var isVoidReturn as bool
	// True iff the current function has a non-empty `throws` clause; the
	// emitted wasm signature carries an extra trailing i64 result and any
	// `errorReturn` op pushes that flag before `return`.
	var funcThrows as bool
	var dispatchLocal as Wasm32Index
	var loopDepth as Wasm32Index
	// Accumulator for call fixups in fixedCalls mode. The caller passes one
	// in via lowerFunction so each emitted function gets its own array.
	var callFixups as WasmCallFixupArray
	// Same pattern for indirect-call type-index fixups. In fixedCalls mode
	// the type indices a user-build assigns may differ from the ones the
	// stdlib pipeline used, so we write a placeholder and record the
	// signature bytes here; emitWasmModule walks these at link time.
	var typeFixups as WasmTypeFixupArray
	// Same pattern for funcAddr-emitted i32.const bytes whose target
	// function isn't in the stdlib-cache funcTableIndices map. In fixedCalls
	// mode emitFuncAddr writes a 5-byte fixed-width sleb128 placeholder and
	// records the body offset + target name here; the user-build patches
	// these once the final table layout is known.
	var funcAddrFixups as WasmFuncAddrFixupArray
	// Same pattern for globalAddr-emitted i64.const bytes that hold a linear-
	// memory offset. In fixedCalls mode the stdlib cache assigns offsets
	// against the stdlib-only data layout, but the user pipeline puts its own
	// data first; we write a 10-byte fixed-width sleb128 placeholder and
	// patch in the resolved offset at module-assembly time. Without this
	// fixup, stdlib functions that take the address of a baked string
	// literal (e.g. `__bool_fromString`'s `"true"`) read whatever bytes
	// happen to land at the stdlib-relative offset in the merged image.
	var globalAddrFixups as WasmGlobalAddrFixupArray
	// Per-function blockId → index map. Populated at the top of
	// lowerFunction by walking func.blockRefs once, so every emitted
	// branch resolves its target block index in O(1) instead of scanning
	// the block list per-branch.
	var blockIndex as BlockIndexMap
	// Per-function float bitset; populated at lowerFunction entry by
	// findFloatValueIds and read by emitIndirectCall when synthesizing
	// the call-site signature for type-section dedup.
	var funcFloatSet as BoolArray
	// True iff any of osGetArgc/osGetArgv/osGetExecutablePath appears in
	// the current function. When set, three additional i32 scratch locals
	// are reserved at the tail of the locals declaration (after any dispatch
	// local) and the indices below are populated. The three op lowerings
	// consume these as the argv-cache scratch register, NUL-scan pointer,
	// and byte-length counter; reserving them up front avoids per-op local
	// declarations (which WASM doesn't support — locals must be declared in
	// the function prelude).
	var hasArgvOp as bool
	var argvScratchLocal as Wasm32Index
	var argvScanLocal as Wasm32Index
	var argvLenLocal as Wasm32Index
	// Two cycle-break scratch locals reserved at the very tail of the locals
	// declaration (after dispatch + argv scratch) for multi-block functions,
	// so value-id↔local identity for 0..maxValueId is preserved. The shared
	// parallel-copy sequencer stages a value here when breaking a phi-move
	// cycle. They must be separately typed: a float cycle staged through an
	// i64-typed local is a wasm validation error, so one local is i64 (used
	// for GPR-class / integer phis) and one is f64 (FP-class / float phis).
	// The class partition in sequentializeParallelCopy guarantees a class
	// only ever touches its own scratch. Zero for single-block functions
	// (which never branch and so have no phi edges).
	var gprCycleScratchLocal as Wasm32Index
	var fpCycleScratchLocal as Wasm32Index
	// Identity register coloring (assignment[i] == i), sized maxValueId+1 and
	// rebuilt per function. Lets the wasm backend feed buildEdgeMoves the same
	// way the native backends do, except getAssignedReg returns the value id
	// itself — which is exactly the wasm local index for that value.
	var identityColoring as ColoringResult

	static function create(module MirModule, funcNames StringArray, funcSigs WasmFuncSigs, globalDataOffsets GlobalDataOffsetMap, stackBase Wasm32Offset, fixedCalls bool) returns WasmFunctionLowering
		return Self{
			module: module,
			funcNames: funcNames,
			funcSigs: funcSigs,
			globalDataOffsets: globalDataOffsets,
			stackBase: stackBase,
			fixedCalls: fixedCalls,
			funcTableIndices: WasmFuncTableIndexMap.create(),
			typeIndices: WasmTypeIndexMap.create(),
			callFixups: WasmCallFixupArray.create(),
			typeFixups: WasmTypeFixupArray.create(),
			funcAddrFixups: WasmFuncAddrFixupArray.create(),
			globalAddrFixups: WasmGlobalAddrFixupArray.create(),
			func: IrFunction.createFromStd("", returnType: StdReturnType.void, paramCount: 0, paramTypes: StdTypeArray.create(), returnLine: 0),
			body: ByteArray.create(),
			isVoidReturn: true,
			funcThrows: false,
			dispatchLocal: 0 as Wasm32Index,
			loopDepth: 0,
			blockIndex: BlockIndexMap.create(),
			funcFloatSet: BoolArray.create(),
			hasArgvOp: false,
			argvScratchLocal: 0 as Wasm32Index,
			argvScanLocal: 0,
			argvLenLocal: 0,
			gprCycleScratchLocal: 0,
			fpCycleScratchLocal: 0,
			identityColoring: ColoringResult.create(0)
		}
	end 'create'

	// ============================================================
	// Function body emission
	// ============================================================

	function lowerFunction(srcFunc IrFunction, fixups WasmCallFixupArray, tyFixups WasmTypeFixupArray, addrFixups WasmFuncAddrFixupArray, gaddrFixups WasmGlobalAddrFixupArray) returns ByteArray
		// Replace mrt_panic with a simplified WASM version that writes the
		// message cstring to stderr then traps (wasmtime provides the backtrace).
		if srcFunc.name == "mrt_panic" 'isPanic'
			return emitWasmPanic()
		end 'isPanic'
		// Replace mrt_panic_print_frame with a no-op (no stack traces in WASM).
		if srcFunc.name == "mrt_panic_print_frame" 'isPrintFrame'
			return emitWasmNopVoidFunc()
		end 'isPrintFrame'
		// Phase 15c Stream 3.3: file/directory I/O. The runtime.std bodies
		// reference Linux-only `osFile*` / `osDir*` ops, so intercept here
		// and emit the WASI-backed bodies instead.
		if srcFunc.name == "mrt_file_open_read" 'isFileOpenRead'
			return emitWasmFileOpenRead()
		end 'isFileOpenRead'
		if srcFunc.name == "mrt_file_open_write" 'isFileOpenWrite'
			return emitWasmFileOpenWrite()
		end 'isFileOpenWrite'
		if srcFunc.name == "mrt_file_open_write_executable" 'isFileOpenWriteExec'
			return emitWasmFileOpenWrite()
		end 'isFileOpenWriteExec'
		if srcFunc.name == "mrt_file_read" 'isFileRead'
			return emitWasmFileRead()
		end 'isFileRead'
		if srcFunc.name == "mrt_file_write" 'isFileWrite'
			return emitWasmFileWrite()
		end 'isFileWrite'
		if srcFunc.name == "mrt_file_close" 'isFileClose'
			return emitWasmFileClose()
		end 'isFileClose'
		// The real existence-check I/O lives in `mrt_file_exists_impl` (the
		// `mrt_file_exists` wrapper around it adds the async io_yield/io_resume
		// trace); intercept the impl so the wrapper still lowers normally and
		// emits its trace, while the actual `osFileAccess`/`osFileStat` body is
		// replaced by the Preview2 `descriptor.stat-at` version.
		if srcFunc.name == "mrt_file_exists_impl" 'isFileExists'
			return emitWasmFileExists()
		end 'isFileExists'
		if srcFunc.name == "mrt_file_delete" 'isFileDelete'
			return emitWasmFileDelete()
		end 'isFileDelete'
		if srcFunc.name == "mrt_file_stat" 'isFileStat'
			return emitWasmFileStat(funcSigs)
		end 'isFileStat'
		if srcFunc.name == "mrt_file_stat_field" 'isFileStatField'
			return emitWasmFileStatField()
		end 'isFileStatField'
		if srcFunc.name == "mrt_file_stat_free" 'isFileStatFree'
			return emitWasmFileStatFree(funcSigs)
		end 'isFileStatFree'
		if srcFunc.name == "mrt_file_size" 'isFileSize'
			return emitWasmFileSize()
		end 'isFileSize'
		if srcFunc.name == "mrt_directory_open_search" 'isDirOpenSearch'
			return emitWasmDirectoryOpenSearch(funcSigs)
		end 'isDirOpenSearch'
		if srcFunc.name == "mrt_directory_create" 'isDirCreate'
			return emitWasmDirectoryCreate()
		end 'isDirCreate'
		if srcFunc.name == "mrt_directory_current_path" 'isDirCurrentPath'
			return emitWasmDirectoryCurrentPath(funcSigs)
		end 'isDirCurrentPath'
		if srcFunc.name == "mrt_directory_next" 'isDirNext'
			return emitWasmDirectoryNext(funcSigs)
		end 'isDirNext'
		if srcFunc.name == "mrt_directory_filename" 'isDirFilename'
			return emitWasmDirectoryFilename(funcSigs)
		end 'isDirFilename'
		if srcFunc.name == "mrt_directory_close" 'isDirClose'
			return emitWasmDirectoryClose(funcSigs)
		end 'isDirClose'
		if srcFunc.name == "mrt_directory_exists" 'isDirExists'
			return emitWasmDirectoryExists()
		end 'isDirExists'
		// Project 2 networking: the runtime.std `mrt_managed_socket_*` bodies are
		// sentinel-erroring stubs (no per-target socket primitive). Intercept them
		// here and emit the wasi:sockets-backed bodies, mirroring how the
		// `mrt_file_*` helpers are replaced above. The errorReturn ABI is honored
		// exactly: a throwing helper returns TWO i64s (resultValue, errorFlag) on
		// every path (flag 0 = success). __ManagedSocketError flag values:
		// bufferOutOfBounds=1, resolveFailed=2, connectFailed=3, sendFailed=4,
		// recvFailed=5.
		if srcFunc.name == "mrt_managed_socket_tcp_connect" 'isSockConnect'
			return emitWasmSocketTcpConnect(funcSigs)
		end 'isSockConnect'
		if srcFunc.name == "mrt_managed_socket_send" 'isSockSend'
			return emitWasmSocketSend()
		end 'isSockSend'
		if srcFunc.name == "mrt_managed_socket_recv" 'isSockRecv'
			return emitWasmSocketRecv()
		end 'isSockRecv'
		if srcFunc.name == "mrt_managed_socket_close" 'isSockClose'
			return emitWasmSocketClose(funcSigs)
		end 'isSockClose'

		func = srcFunc
		body = ByteArray.create()
		isVoidReturn = stdReturnTypeIsVoid(srcFunc.returnType)
		funcThrows = match srcFunc.throwsTypeName 'kind'
			none gives false
			throwing gives true
		end 'kind'
		callFixups = fixups
		typeFixups = tyFixups
		funcAddrFixups = addrFixups
		globalAddrFixups = gaddrFixups

		// Build the per-function blockId → blockRefs-index map up front.
		// Without this, every emitted branch / cond_branch did a linear
		// scan over the function's block list, making branch emission
		// quadratic in block count for branch-heavy functions.
		blockIndex = BlockIndexMap.create()
		for i in 0 upto srcFunc.blockRefs.count() 'indexBlocks'
			let blockRef = try srcFunc.blockRefs.get(i) otherwise panic("invariant: i < srcFunc.blockRefs.count() but get failed")
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from srcFunc.blockRefs not in module.blocks")
			blockIndex.upsert(block.id, value: i as MachineWord)
		end 'indexBlocks'

		// Count the maximum ValueId used, to allocate locals.
		// Parameters are already locals 0..paramCount-1.
		// Additional locals start at paramCount.
		let maxValueId = findMaxValueId()
		let localCount = maxValueId + 1

		// Scan for float value IDs to declare them as f64 instead of i64.
		// Stored on the lowering instance so emitIndirectCall can read it
		// to derive the call-site signature for type-section dedup.
		funcFloatSet = findFloatValueIds()
		let floatSet = funcFloatSet

		// Build locals declaration: groups of (count, type).
		// Each local is declared individually to preserve ValueId-to-local-index mapping.
		// Locals: paramCount..maxValueId are i64 or f64 based on floatSet.
		// For multi-block functions, one additional i32 dispatch local at the end.
		let isMultiBlock = srcFunc.blockRefs.count() > 1
		var localGroups = ByteArray.create()
		var groupCount = 0 as MachineWord
		var currentType = 0 as MachineWord
		var currentCount = 0 as MachineWord
		for localIdx in srcFunc.paramCount upto localCount 'declareLocals'
			let typeCode = getLocalType(floatSet, localIdx: localIdx as MachineWord)
			if currentCount == 0 'first'
				currentType = typeCode
				currentCount = 1
			end 'first' else if typeCode == currentType 'same'
				currentCount = currentCount + 1
			end 'same' else 'different'
				writeUleb128(localGroups, value: currentCount)
				localGroups.push(currentType)
				groupCount = groupCount + 1
				currentType = typeCode
				currentCount = 1
			end 'different'
		end 'declareLocals'
		if currentCount > 0 'flushLast'
			writeUleb128(localGroups, value: currentCount)
			localGroups.push(currentType)
			groupCount = groupCount + 1
		end 'flushLast'
		// Reserved locals live past the value-local region (0..maxValueId), in
		// a fixed order so each block's index stays stable: dispatch, then the
		// argv scratch trio, then the two phi cycle-break scratch locals. A
		// single running cursor assigns them, so adding a region never requires
		// recomputing the others' offsets.
		var nextLocal = (maxValueId + 1) as Wasm32Index

		if isMultiBlock 'addDispatch'
			dispatchLocal = nextLocal
			nextLocal = nextLocal + 1
			writeUleb128(localGroups, value: 1)
			localGroups.push(wasmTypeI32)
			groupCount = groupCount + 1
		end 'addDispatch'

		// Reserve three i32 scratch locals when any of osGetArgc / osGetArgv /
		// osGetExecutablePath appear in this function. emitArgvCacheEnsure /
		// the bounds-check + NUL-scan sequences in the three op lowerings
		// consume them as the argv-cache scratch register, NUL-scan pointer,
		// and byte-length counter.
		hasArgvOp = scanForArgvOps()
		if hasArgvOp 'reserveArgvScratch'
			argvScratchLocal = nextLocal
			argvScanLocal = nextLocal + 1
			argvLenLocal = nextLocal + 2
			nextLocal = nextLocal + 3
			writeUleb128(localGroups, value: 3)
			localGroups.push(wasmTypeI32)
			groupCount = groupCount + 1
		end 'reserveArgvScratch'

		// Reserve the two phi cycle-break scratch locals (one i64, one f64)
		// the shared parallel-copy sequencer stages through. Only multi-block
		// functions branch, so only they can have phi edges that cycle.
		if isMultiBlock 'reservePhiScratch'
			gprCycleScratchLocal = nextLocal
			fpCycleScratchLocal = nextLocal + 1
			nextLocal = nextLocal + 2
			writeUleb128(localGroups, value: 1)
			localGroups.push(wasmTypeI64)
			writeUleb128(localGroups, value: 1)
			localGroups.push(wasmTypeF64)
			groupCount = groupCount + 2
		end 'reservePhiScratch'

		writeUleb128(body, value: groupCount)
		body.append(localGroups)

		// Identity coloring so buildEdgeMoves resolves each value id to itself
		// (== its wasm local index). Sized to cover every value id in use.
		identityColoring = ColoringResult.identity((maxValueId + 1) as RegInt)

		// Emit instructions for each block.
		if srcFunc.blockRefs.count() == 1 'singleBlock'
			let blockRef = try srcFunc.blockRefs.get(0) otherwise 'noBlock'
				body.push(opUnreachable)
				body.push(opEnd)
				return body
			end 'noBlock'
			let block = try module.blocks.get(blockRef) otherwise 'noBlock2'
				body.push(opUnreachable)
				body.push(opEnd)
				return body
			end 'noBlock2'
			emitBlockOps(block)
		end 'singleBlock' else 'multiBlock'
			emitStructuredCfg()
		end 'multiBlock'

		// For non-void functions, push a dummy return value before `end`.
		// All real paths should `return` before reaching here, but WASM validation
		// requires the stack to match the return type at the `end` instruction.
		// Throwing functions also have a trailing i64 error flag in their
		// signature (the multi-value-return error ABI), so push a second
		// dummy i64 in that case.
		match srcFunc.returnType 'dummy'
			void then break 'dummy'
			value(inner) then emitWasmDummyReturn(inner)
		end 'dummy'

		if funcThrows 'throwsDummy'
			body.push(opI64Const)
			writeSleb128(body, value: 0)
		end 'throwsDummy'

		body.push(opEnd)
		return body
	end 'lowerFunction'

	// Pad the end of a non-void function with a dummy value matching the return
	// type, so WASM validation sees the expected stack on fallthrough.
	function emitWasmDummyReturn(returnType StdType)
		if stdTypeIsFloat(returnType) 'floatType'
			body.push(opF64Const)
			writeQword(body, value: 0)
		end 'floatType' else 'intType'
			body.push(opI64Const)
			writeSleb128(body, value: 0)
		end 'intType'
	end 'emitWasmDummyReturn'

	// ============================================================
	// Single-block emission (straight-line code)
	// ============================================================

	function emitBlockOps(block IrBlock)
		for packed in block.opRefs 'eachOp'
			emitPackedOp(packed)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			emitPackedOp(block.terminatorIndex())
		end 'hasTerm'
	end 'emitBlockOps'

	// ============================================================
	// Structured CFG emission (multi-block functions)
	// ============================================================

	// For MVP: use a loop+br_table dispatch pattern.
	// Each block gets an index. A loop wraps the switch, and br_table
	// dispatches to the current block. This handles any CFG shape.
	function emitStructuredCfg()
		let blockCount = func.blockRefs.count()
		if blockCount == 0 'empty'
			return
		end 'empty'

		// dispatchLocal was assigned during the locals declaration in
		// lowerFunction (the local right after all value locals).

		// Outer loop: re-enters after each block to dispatch to next
		body.push(opLoop)
		body.push(wasmTypeVoid)

		// Nested blocks for br_table targets (one per block + default)
		// br_table pops the dispatch local and branches to the Nth enclosing block.
		// We wrap blockCount blocks around the dispatch, so br_table index i
		// jumps to block i.
		for _ in 0 upto blockCount 'nestBlocks'
			body.push(opBlock)
			body.push(wasmTypeVoid)
		end 'nestBlocks'

		// br_table dispatch: local.get $dispatch, br_table [0, 1, 2, ...], default=0
		body.push(opLocalGet)
		writeUleb128(body, value: dispatchLocal)
		body.push(opBrTable)
		writeUleb128(body, value: blockCount as Wasm32Index)
		for i in 0 upto blockCount 'tableEntries'
			writeUleb128(body, value: i as Wasm32Index)
		end 'tableEntries'
		writeUleb128(body, value: 0)

		// Emit each block after its corresponding `end` (of the nested block).
		// Block 0 is the innermost, so its code comes first after the br_table.
		for i in 0 upto blockCount 'emitBlocks'
			body.push(opEnd)

			let blockRef = try func.blockRefs.get(i) otherwise panic("invariant: i < blockCount but func.blockRefs.get failed")
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")

			// Emit block arguments (phi nodes): they're already set by predecessor branches.
			// The predecessor stores values into the block arg locals before setting dispatch.

			// Emit ops
			for packed in block.opRefs 'eachOp'
				emitPackedOp(packed)
			end 'eachOp'

			// Emit terminator
			if block.hasTerminatorOp() 'hasTerm'
				loopDepth = (blockCount - 1 - i) as MachineWord
				emitPackedTerminator(block.terminatorIndex())
			end 'hasTerm'

			// After the terminator sets the dispatch local and branches,
			// we need to br back to the outer loop.
			// (The terminator itself emits the br to the loop.)
		end 'emitBlocks'

		// End the outer loop
		body.push(opEnd)
	end 'emitStructuredCfg'

	// ============================================================
	// Terminator emission for structured CFG
	// ============================================================

	function emitPackedTerminator(opIdx OpIndex)
		let mirOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
		emitMirTerminator(mirOp)
	end 'emitPackedTerminator'

	function emitMirTerminator(op MirOp)
		match op 'dispatch'
			condBranch(condId, thenBlock, thenArgs, elseBlock, elseArgs) then emitWasmCondBranch(condId, thenBlock: thenBlock, thenArgs: thenArgs, elseBlock: elseBlock, elseArgs: elseArgs)
			branch(targetBlock, args) then emitWasmBranch(targetBlock, args: args)
			ret(retValId) then emitWasmRet(retValId)
			movImm to cmp then emitMirOp(op)
			call to witnessCall then emitMirOp(op)
			param to loadByte then emitMirOp(op)
			osAllocPages to osLockRelease then emitMirOp(op)
			// tryCall and errorReturn dispatch to the same emitters as the
			// in-body op path; routing through emitMirOp keeps the
			// pop-order / multi-value-return logic in one place.
			tryCall to errorReturn then emitMirOp(op)
		end 'dispatch'
	end 'emitMirTerminator'

	function emitWasmCondBranch(condId ValueId, thenBlock BlockId, thenArgs ValueIdArray, elseBlock BlockId, elseArgs ValueIdArray)
		let thenIdx = findBlockIndex(thenBlock)
		let elseIdx = findBlockIndex(elseBlock)

		// if condId: take the then edge, else: take the else edge.
		//
		// The block-arg (phi) stores for each edge MUST live inside that edge's
		// arm — they are only valid on the path actually taken. Emitting both
		// sets unconditionally before the `if` clobbers the not-taken target's
		// phi local: e.g. `cond_br %c then=Bexit() else=Bheader(%v)` would write
		// %v into the loop-header phi even when exiting, leaving the post-loop
		// read of that phi holding the loop's would-be next value instead of its
		// final one (observed as String.trim's backward grapheme scan landing
		// one position short, eating a non-matching boundary character).
		body.push(opLocalGet)
		writeUleb128(body, value: condId as Wasm32Index)
		body.push(opI32WrapI64)

		body.push(opIf)
		body.push(wasmTypeVoid)

		// then arm: resolve then-edge phi copies, set dispatch to thenIdx
		emitEdgePhiCopies(thenArgs, targetBlock: thenBlock)
		emitSetDispatch(thenIdx)

		body.push(opElse)

		// else arm: resolve else-edge phi copies, set dispatch to elseIdx
		emitEdgePhiCopies(elseArgs, targetBlock: elseBlock)
		emitSetDispatch(elseIdx)

		body.push(opEnd)

		// br back to the loop. The if/else adds 1 to nesting when active, but
		// after the if/end we're back at the same depth as block code.
		// loopDepth is the distance from block code to the loop.
		body.push(opBr)
		writeUleb128(body, value: loopDepth)
	end 'emitWasmCondBranch'

	function emitWasmBranch(targetBlock BlockId, args ValueIdArray)
		let targetIdx = findBlockIndex(targetBlock)

		// Resolve block-arg (phi) copies for this single edge
		emitEdgePhiCopies(args, targetBlock: targetBlock)

		emitSetDispatch(targetIdx)

		// br back to the loop
		body.push(opBr)
		writeUleb128(body, value: loopDepth)
	end 'emitWasmBranch'

	// Emit `dispatch = blockIdx` — the structured-CFG dispatcher reads this
	// local at the top of the outer loop to jump to the next block.
	function emitSetDispatch(blockIdx MachineWord)
		body.push(opI32Const)
		writeSleb128(body, value: blockIdx)
		body.push(opLocalSet)
		writeUleb128(body, value: dispatchLocal)
	end 'emitSetDispatch'

	function emitWasmRet(retValId ValueId)
		if not isVoidReturn 'hasReturn'
			body.push(opLocalGet)
			writeUleb128(body, value: retValId as Wasm32Index)
		end 'hasReturn'
		body.push(opReturn)
	end 'emitWasmRet'

	// Resolve the SSA phi copies for one CFG edge: move each source value into
	// the destination block's corresponding block-arg local. These are a
	// parallel copy — a source local can coincide with another arg's
	// destination (e.g. a back-edge passing `(endPos, gStart)` to a header
	// whose args reuse those very locals), so emitting the moves naively
	// one-by-one would clobber a not-yet-read source and silently corrupt the
	// phi (observed historically as String.trim's backward scan landing one
	// grapheme short). Routing through the shared parallel-copy sequencer —
	// the same code the native backends use — guarantees correct topological
	// ordering and cycle-breaking through the reserved scratch locals.
	//
	// The caller emits this strictly inside the arm of the taken edge, so an
	// edge's copies never land on a path that doesn't take that edge.
	function emitEdgePhiCopies(srcArgs ValueIdArray, targetBlock BlockId)
		let succBlock = findBlock(targetBlock)
		let moves = buildEdgeMoves(succBlock, srcArgIds: srcArgs, coloring: identityColoring)
		if moves.count() == 0 'noMoves'
			return
		end 'noMoves'
		let emitter = WasmCopyEmitter.create(body, gprScratch: gprCycleScratchLocal, fpScratch: fpCycleScratchLocal)
		sequentializeParallelCopy(moves, emitter: emitter)
	end 'emitEdgePhiCopies'

	// Look up the IrBlock for a blockId via the per-function index map.
	function findBlock(blockId BlockId) returns IrBlock
		let idx = findBlockIndex(blockId)
		let blockRef = try func.blockRefs.get(idx) otherwise panic("invariant: blockIndex returned {idx} but func.blockRefs.get failed")
		return try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
	end 'findBlock'

	// ============================================================
	// MirOp emission
	// ============================================================

	function emitPackedOp(opIdx OpIndex)
		let mirOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
		emitMirOp(mirOp)
	end 'emitPackedOp'

	function emitMemRefStoreSlot(slotId VarSlot, valueId ValueId)
		// Store to linear memory at stackBase + slotId * 8
		let slotOffset = (stackBase + (slotId * 8)) as Wasm32Offset
		body.push(opI32Const)
		writeSleb128(body, value: slotOffset)
		body.push(opLocalGet)
		writeUleb128(body, value: valueId as Wasm32Index)
		body.push(opI64Store)
		body.push(0x03)
		writeUleb128(body, value: 0)
	end 'emitMemRefStoreSlot'

	function emitMemRefLoadSlot(resultId ValueId, slotId VarSlot)
		// Load from linear memory at stackBase + slotId * 8
		let slotOffset = (stackBase + (slotId * 8)) as Wasm32Offset
		body.push(opI32Const)
		writeSleb128(body, value: slotOffset)
		body.push(opI64Load)
		body.push(0x03)
		writeUleb128(body, value: 0)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitMemRefLoadSlot'

	function emitMirOp(op MirOp)
		match op 'dispatch'
			movImm(resultId, value, isFloat) then emitMovImm(resultId, value: value, isFloat: isFloat)
			movReg(resultId, srcId) then emitMovReg(resultId, srcId: srcId)
			binOp(resultId, leftId, rightId, opcode) then emitBinOp(resultId, leftId: leftId, rightId: rightId, opcode: opcode)
			unaryOp(resultId, operandId, opcode) then emitUnaryOp(resultId, operandId: operandId, opcode: opcode)
			cmp(resultId, leftId, rightId, predicate) then emitCmp(resultId, leftId: leftId, rightId: rightId, predicate: predicate)
			condBranch then panic("wasm: condBranch in single-block function")
			branch then nop()
			call(resultId, callee, argIds) then emitCall(resultId, callee: callee, argIds: argIds)
			indirectCall(resultId, calleeId, argIds, isVoid, isThrowing, errorFlagId) then emitIndirectCall(resultId, calleeId: calleeId, argIds: argIds, isVoid: isVoid, isThrowing: isThrowing, errorFlagId: errorFlagId)
			witnessCall(resultId, witnessAddrId, methodIndex, isVoid, argIds) then emitWitnessCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds)
			ret(retValId) then emitRet(retValId)
			param(resultId, paramIndex, _) then emitParam(resultId, paramIndex: paramIndex)
			load(resultId, baseId, offset, width, signed, isFloat) then emitLoad(resultId, baseId: baseId, offset: offset, width: width, signed: signed, isFloat: isFloat)
			store(valueId, baseId, offset, width, isFloat) then emitStore(valueId, baseId: baseId, offset: offset, width: width, isFloat: isFloat)
			loadSlot(resultId, slotId) then emitMemRefLoadSlot(resultId, slotId: slotId)
			storeSlot(slotId, valueId) then emitMemRefStoreSlot(slotId, valueId: valueId)
			stackSlotAddr(resultId, slotId) then emitStackSlotAddr(resultId, slotId: slotId)
			globalAddr(resultId, name) then emitGlobalAddr(resultId, name: name)
			funcAddr(resultId, name) then emitFuncAddr(resultId, name: name)
			loadFramePtr(resultId) then emitLoadFramePtr(resultId)
			osExit(codeId) then emitOsExit(codeId)
			osSleep(msId) then emitOsSleep(msId)
			osWrite(ptrId, lenId) then emitOsWrite(ptrId, lenId: lenId, fd: 1)
			osWriteErr(ptrId, lenId) then emitOsWrite(ptrId, lenId: lenId, fd: 2)
			osRead(resultId, ptrId, lenId) then emitOsRead(resultId, ptrId: ptrId, lenId: lenId)
			osOpenWrite then panic("wasm: osOpenWrite not yet implemented (Phase 3)")
			osWriteFd then panic("wasm: osWriteFd not yet implemented (Phase 3)")
			osClose then panic("wasm: osClose not yet implemented (Phase 3)")
			osGetEnv then panic("wasm: osGetEnv not yet implemented (Phase 3)")
			osGetArgc(resultId) then emitOsGetArgc(resultId)
			osClockMs(resultId) then emitOsClockMs(resultId)
			osGetArgv(resultId, indexId) then emitOsGetArgv(resultId, indexId: indexId)
			osGetExecutablePath(resultId, bufPtrId, bufSizeId) then emitOsGetExecutablePath(resultId, bufPtrId: bufPtrId, bufSizeId: bufSizeId)
			memcpy(dstId, srcId, lenId) then emitMemcpy(dstId, srcId: srcId, lenId: lenId)
			storeByte(baseId, offsetId, byteId) then emitStoreByte(baseId, offsetId: offsetId, byteId: byteId)
			loadByte(resultId, baseId, offsetId) then emitLoadByte(resultId, baseId: baseId, offsetId: offsetId)
			osAllocPages(resultId, sizeId) then emitOsAllocPages(resultId, sizeId: sizeId)
			osAllocPagesLarge(resultId, sizeId) then emitOsAllocPages(resultId, sizeId: sizeId)
			osFreePages then nop()
			// Phase 15c Stream 4.1: Linux file-I/O ops are not legal on Wasm.
			// Wasm bodies are hand-emitted at this layer (no runtime.std
			// referent) and never invoke the std osFile*/osDir* ops.
			// Reaching this panic would mean a Linux body leaked into a
			// Wasm build.
			osFileOpen then panic("wasm: osFileOpen op should not reach MirToWasm — Linux-only")
			osFileRead then panic("wasm: osFileRead op should not reach MirToWasm — Linux-only")
			osFileWrite then panic("wasm: osFileWrite op should not reach MirToWasm — Linux-only")
			osFileClose then panic("wasm: osFileClose op should not reach MirToWasm — Linux-only")
			osFileLseek then panic("wasm: osFileLseek op should not reach MirToWasm — Linux-only")
			osFileStat then panic("wasm: osFileStat op should not reach MirToWasm — Linux-only")
			osFileAccess then panic("wasm: osFileAccess op should not reach MirToWasm — Linux-only")
			osFileUnlink then panic("wasm: osFileUnlink op should not reach MirToWasm — Linux-only")
			osDirGetdents64 then panic("wasm: osDirGetdents64 op should not reach MirToWasm — Linux-only")
			osDirGetcwd then panic("wasm: osDirGetcwd op should not reach MirToWasm — Linux-only")
			osDirMkdir then panic("wasm: osDirMkdir op should not reach MirToWasm — Linux-only")
			atomicInc(addrId) then emitAtomicAddOne(addrId, isSubtract: false)
			atomicDec(addrId) then emitAtomicAddOne(addrId, isSubtract: true)
			atomicXadd(resultId, addrId, valId) then emitAtomicXadd(resultId, addrId: addrId, valId: valId)
			atomicCas(resultId, addrId, oldId, newId) then emitAtomicCas(resultId, addrId: addrId, oldId: oldId, newId: newId)
			osLockInit then nop()
			osLockAcquire then nop()
			osLockRelease then nop()
			tryCall(resultId, callee, argIds, errorFlagId) then emitTryCall(resultId, callee: callee, argIds: argIds, errorFlagId: errorFlagId)
			witnessTryCall(resultId, witnessAddrId, methodIndex, isVoid, argIds, errorFlagId) then emitWitnessTryCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds, errorFlagId: errorFlagId)
			errorReturn(retValId, errorFlagId) then emitErrorReturn(retValId, errorFlagId: errorFlagId)
		end 'dispatch'
	end 'emitMirOp'

	// ============================================================
	// Individual instruction emitters
	// ============================================================

	function emitMovImm(resultId ValueId, value ParsedInt, isFloat bool)
		if isFloat 'float'
			// Encode f64 as i64 reinterpret
			body.push(opF64Const)
			// Write 8 bytes of the f64 encoding (value is the raw bits)
			writeQword(body, value: value as MachineWord)
		end 'float' else 'int'
			body.push(opI64Const)
			writeSleb128(body, value: value)
		end 'int'
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitMovImm'

	function emitMovReg(resultId ValueId, srcId ValueId)
		body.push(opLocalGet)
		writeUleb128(body, value: srcId as Wasm32Index)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitMovReg'

	function emitBinOp(resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode)
		body.push(opLocalGet)
		writeUleb128(body, value: leftId as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: rightId as Wasm32Index)

		let wasmOp = match opcode 'pickOp'
			addI64 gives opI64Add
			subI64 gives opI64Sub
			mulI64 gives opI64Mul
			divI64 gives opI64DivS
			remI64 gives opI64RemS
			andI64 gives opI64And
			orI64 gives opI64Or
			xorI64 gives opI64Xor
			shlI64 gives opI64Shl
			shrI64 gives opI64ShrU
			addF64 gives opF64Add
			subF64 gives opF64Sub
			mulF64 gives opF64Mul
			divF64 gives opF64Div
			minF64 gives opF64Min
			maxF64 gives opF64Max
		end 'pickOp'

		body.push(wasmOp)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitBinOp'

	function emitUnaryOp(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode)
		body.push(opLocalGet)
		writeUleb128(body, value: operandId as Wasm32Index)

		match opcode 'pickOp'
			negI64 then emitI64Negate()
			bitNotI64 then emitI64BitNot()
			fpToSiI64 then body.push(opI64TruncF64S)
			bitcastF64ToI64 then body.push(opI64ReinterpretF64)
			bitcastI64ToF64 then body.push(opF64ReinterpretI64)
			siToFpF64 then body.push(opF64ConvertI64S)
			sqrtF64 then body.push(opF64Sqrt)
			floorF64 then body.push(opF64Floor)
			ceilF64 then body.push(opF64Ceil)
			roundF64 then body.push(opF64Nearest)
			absF64 then body.push(opF64Abs)
		end 'pickOp'

		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitUnaryOp'

	// i64 negate: multiply by -1 (WASM has no swap, so 0-x would need a temp local)
	function emitI64Negate()
		body.push(opI64Const)
		writeSleb128(body, value: -1)
		body.push(opI64Mul)
	end 'emitI64Negate'

	// i64 bitwise not: xor with -1
	function emitI64BitNot()
		body.push(opI64Const)
		writeSleb128(body, value: -1)
		body.push(opI64Xor)
	end 'emitI64BitNot'

	function emitCmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate)
		body.push(opLocalGet)
		writeUleb128(body, value: leftId as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: rightId as Wasm32Index)

		let wasmOp = match predicate 'pickOp'
			eq gives opI64Eq
			ne gives opI64Ne
			lt gives opI64LtS
			le gives opI64LeS
			gt gives opI64GtS
			ge gives opI64GeS
			ugt gives opI64GtU
			feq gives opF64Eq
			fne gives opF64Ne
			flt gives opF64Lt
			fle gives opF64Le
			fgt gives opF64Gt
			fge gives opF64Ge
		end 'pickOp'

		body.push(wasmOp)
		// cmp produces i32 (0 or 1), extend to i64
		body.push(opI64ExtendI32U)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitCmp'

	function emitCall(resultId ValueId, callee String, argIds ValueIdArray)
		emitDirectCall(callee, argIds: argIds)
		// The asyncify primitives are void imports (intercepted by
		// emitDirectCall) and never throw. They have no module function entry
		// in `funcSigs` (the dead Std-IR stubs are filtered out of the emitted
		// module to avoid colliding with Binaryen's own generated functions), so
		// the funcSigs-driven result handling below would mis-treat them as
		// value-returning. Short-circuit: nothing to pop, nothing to store.
		if isAsyncifyImportCall(callee) 'asyncifyVoid'
			return
		end 'asyncifyVoid'
		// A plain `call` (as opposed to `tryCall`) ignores any error the
		// callee raises — mirroring the native ABI where the error flag lands
		// in a dedicated register (RDX/X1) that a non-`try` caller simply
		// never reads. On wasm the dual-value error ABI returns BOTH the
		// primary value AND the error flag on the operand stack (primary
		// first, error flag last/top), so a throwing callee reached through a
		// plain `call` leaves the error flag on top. Drop it here so the
		// primary value is what gets stored — without this the `local.set`
		// below would capture the error flag and leave the real value
		// dangling, corrupting the result. The for-loop desugaring of
		// `for ... in x.withIterator()` is the canonical case: `withIterator`
		// is `throws` but the loop reaches it through a plain `call`.
		if funcSigs.calleeThrows(callee) 'discardErrorFlag'
			body.push(opDrop)
		end 'discardErrorFlag'
		// Store result only if the callee returns a value.
		if not lookupReturnsVoid(callee) 'hasReturnValue'
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'hasReturnValue' else 'voidReturn'
			emitVoidResultAliasIfNeeded(resultId, argIds: argIds)
		end 'voidReturn'
	end 'emitCall'

	// Lower MirOp.tryCall: like emitCall, but the callee is throwing so its
	// wasm signature appends a trailing i64 (error flag). Wasm pushes
	// results in declared order (primary first, error flag last), so we pop
	// the error flag first (top of stack) into errorFlagId, then the
	// primary result (if non-void) into resultId. Throwing void callees
	// still push the error flag.
	function emitTryCall(resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId)
		emitDirectCall(callee, argIds: argIds)
		body.push(opLocalSet)
		writeUleb128(body, value: errorFlagId as Wasm32Index)
		if not lookupReturnsVoid(callee) 'hasReturnValue'
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'hasReturnValue' else 'voidReturn'
			emitVoidResultAliasIfNeeded(resultId, argIds: argIds)
		end 'voidReturn'
	end 'emitTryCall'

	// Mutating-method self-assignment (`arr = arr.push(...)`): wasm emit
	// step for the shared decision in voidResultAliasReceiverId. Without
	// this, the resultId local stays at its zero-init default (or a stale
	// earlier value), and the next use of `arr` dereferences garbage —
	// observed as `Array.push: set OOB` and similar runtime panics on wasm.
	function emitVoidResultAliasIfNeeded(resultId ValueId, argIds ValueIdArray)
		let receiverId = try voidResultAliasReceiverId(resultId, argIds: argIds) otherwise return
		body.push(opLocalGet)
		writeUleb128(body, value: receiverId as Wasm32Index)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitVoidResultAliasIfNeeded'

	// Shared call-site arg push + `call` opcode emission. Used by both
	// emitCall and emitTryCall; result-stack handling differs and is done
	// by the caller.
	function emitDirectCall(callee String, argIds ValueIdArray)
		// Asyncify primitives are imports at fixed indices — handle them before the
		// module-function lookup (which would panic on these names). start_unwind /
		// start_rewind take a single i32 data pointer (the runtime passes it as i64,
		// so wrap); stop_unwind / stop_rewind take no args. All return void.
		if isAsyncifyImportCall(callee) 'asyncifyCall'
			for argId in argIds 'pushWrapped'
				body.push(opLocalGet)
				writeUleb128(body, value: argId as Wasm32Index)
				body.push(opI32WrapI64)
			end 'pushWrapped'
			body.push(opCall)
			writeUleb128(body, value: asyncifyImportIndex(callee))
			return
		end 'asyncifyCall'

		for argId in argIds 'pushArgs'
			body.push(opLocalGet)
			writeUleb128(body, value: argId as Wasm32Index)
		end 'pushArgs'

		let funcIdx = findFunctionIndex(funcSigs, name: callee, importCount: wasiImportCount)
		body.push(opCall)

		if fixedCalls 'useFixed'
			// Cache-building mode: use fixed-width ULEB128 and record fixup for patching
			callFixups.push(WasmCallFixup.create(body.count(), targetName: callee))
			writeUleb128Fixed5(body, value: funcIdx)
		end 'useFixed' else 'useVariable'
			writeUleb128(body, value: funcIdx)
		end 'useVariable'
	end 'emitDirectCall'

	// Lower MirOp.errorReturn: push the primary return value (skipped for
	// void-returning throwing functions, matching the X64/Arm64 backends),
	// then push the error flag, then `return`. The function's wasm
	// signature was built with a trailing i64 result, so the engine pops
	// these in reverse order at the call site.
	function emitErrorReturn(retValId ValueId, errorFlagId ValueId)
		if not isVoidReturn 'hasPrimary'
			body.push(opLocalGet)
			writeUleb128(body, value: retValId as Wasm32Index)
		end 'hasPrimary'
		body.push(opLocalGet)
		writeUleb128(body, value: errorFlagId as Wasm32Index)
		body.push(opReturn)
	end 'emitErrorReturn'

	// Look up a callee's StdReturnType, by name. Imports and unknown
	// callees fall back to `value(StdType.i64)` — the WASM type table
	// always pushes a result for those, and the int return shape is
	// indistinguishable from a typed callee that returns i64. O(1) via
	// funcSigs.nameIndex.
	function lookupReturnInfo(callee String) returns StdReturnType
		let idx = try funcSigs.indexOf(callee) otherwise return StdReturnType.value(StdType.i64)
		return try funcSigs.returnTypes.get(idx) otherwise StdReturnType.value(StdType.i64)
	end 'lookupReturnInfo'

	// Convenience: true when the callee is registered AND returns void. The
	// `notFound` and `value(...)` cases both return false so unknown callees
	// stay treated as result-producing.
	function lookupReturnsVoid(callee String) returns bool
		return stdReturnTypeIsVoid(lookupReturnInfo(callee))
	end 'lookupReturnsVoid'

	function lookupReturnType(callee String) returns StdType
		return match lookupReturnInfo(callee) 'unwrap'
			void gives StdType.i64
			value(inner) gives inner
		end 'unwrap'
	end 'lookupReturnType'

	function emitRet(retValId ValueId)
		if not isVoidReturn 'hasReturn'
			body.push(opLocalGet)
			writeUleb128(body, value: retValId as Wasm32Index)
		end 'hasReturn'
		body.push(opReturn)
	end 'emitRet'

	function emitParam(resultId ValueId, paramIndex VarSlot)
		// Parameters are locals 0..paramCount-1.
		// If resultId != paramIndex, copy param to result local.
		if resultId != paramIndex 'needsCopy'
			body.push(opLocalGet)
			writeUleb128(body, value: paramIndex as Wasm32Index)
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'needsCopy'
		// If resultId == paramIndex, the param is already in the right local.
	end 'emitParam'

	// Load `width` bytes from [base+offset] into resultId. Float loads bypass
	// the integer matrix and use f64.load (only qword is meaningful at the
	// float type today). For integer loads `signed` selects between sign-
	// and zero-extending opcodes at narrow widths.
	function emitLoad(resultId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool)
		body.push(opLocalGet)
		writeUleb128(body, value: baseId as Wasm32Index)
		body.push(opI32WrapI64)
		let (loadOpcode, alignment) = selectWasmLoadOpcode(width, signed: signed, isFloat: isFloat)
		body.push(loadOpcode)
		body.push(alignment)
		writeUleb128(body, value: offset)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitLoad'

	function emitStore(valueId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, isFloat bool)
		body.push(opLocalGet)
		writeUleb128(body, value: baseId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opLocalGet)
		writeUleb128(body, value: valueId as Wasm32Index)
		let (storeOpcode, alignment) = selectWasmStoreOpcode(width, isFloat: isFloat)
		body.push(storeOpcode)
		body.push(alignment)
		writeUleb128(body, value: offset)
	end 'emitStore'

	// Choose the wasm load opcode + alignment-log2 immediate for a given
	// access width. Float loads bypass the integer matrix (signed is moot
	// for f64.load). Alignment is encoded as log2(natural-alignment): 0
	// for byte, 1 for halfword, 2 for word, 3 for qword.
	function selectWasmLoadOpcode(width StoreWidth, signed bool, isFloat bool) returns (MachineWord, MachineWord)
		if isFloat 'fp'
			return (opF64Load, 0x03)
		end 'fp'
		return match width 'w'
			qword gives(opI64Load, 0x03)
			word gives(opI64Load32S if signed else opI64Load32U, 0x02)
			halfword gives(opI64Load16S if signed else opI64Load16U, 0x01)
			byte gives(opI64Load8S if signed else opI64Load8U, 0x00)
		end 'w'
	end 'selectWasmLoadOpcode'

	// Mirror of `selectWasmLoadOpcode` for stores. Stores only need a width:
	// each `i64.storeN` writes the low N bytes of its i64 operand.
	function selectWasmStoreOpcode(width StoreWidth, isFloat bool) returns (MachineWord, MachineWord)
		if isFloat 'fp'
			return (opF64Store, 0x03)
		end 'fp'
		return match width 'w'
			qword gives(opI64Store, 0x03)
			word gives(opI64Store32, 0x02)
			halfword gives(opI64Store16, 0x01)
			byte gives(opI64Store8, 0x00)
		end 'w'
	end 'selectWasmStoreOpcode'

	function emitStackSlotAddr(resultId ValueId, slotId VarSlot)
		// Stack slots map to linear memory. Each slot is 8 bytes.
		// Stack area starts after global data.
		let slotOffset = (stackBase + (slotId * 8)) as Wasm32Offset
		body.push(opI64Const)
		writeSleb128(body, value: slotOffset)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitStackSlotAddr'

	function emitGlobalAddr(resultId ValueId, name String)
		body.push(opI64Const)
		if fixedCalls 'cacheMode'
			// Stdlib-cache build: the user pipeline merges its globalData
			// before the stdlib chunks, so cache-time offsets won't match
			// the final image. Record a fixup that the user-build patches
			// against the final globalDataOffsets map. Use a 5-byte fixed-
			// width sleb128 — linear-memory offsets are non-negative and
			// fit in 28 bits comfortably.
			globalAddrFixups.push(WasmGlobalAddrFixup.create(body.count(), targetName: name))
			writeSleb128Fixed5(body, value: 0 as ParsedInt)
		end 'cacheMode' else 'userMode'
			let offset = try globalDataOffsets.get(name) otherwise panic("wasm: unknown global address '{name}' — not registered in globalDataOffsets")
			writeSleb128(body, value: offset as ParsedInt)
		end 'userMode'
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitGlobalAddr'

	function emitOsExit(codeId ValueId)
		body.push(opLocalGet)
		writeUleb128(body, value: codeId as Wasm32Index)
		// Truncate i64 to i32 for wasi:cli/exit.exit-with-code(status-code: u8).
		// The canonical ABI passes the u8 zero-extended in an i32; wasmtime masks
		// to the low 8 bits, so the maxon ExitCode (0..255) round-trips.
		body.push(opI32WrapI64)
		body.push(opCall)
		writeUleb128(body, value: wasiExit as Wasm32Index)
	end 'emitOsExit'

	// Store an i64 constant at a fixed absolute linear-memory address with
	// 8-byte alignment. Used by `emitOsSleep` to zero / initialize the
	// per-subscription fields; centralizes the const-address + i64-store
	// instruction triple so the subscription layout reads as data rather
	// than as nine repetitions of the same five-instruction recipe.
	function emitWasmStoreI64Const(addr MachineWord, value MachineWord)
		body.push(opI32Const)
		writeSleb128(body, value: addr as ParsedInt)
		body.push(opI64Const)
		writeSleb128(body, value: value as ParsedInt)
		body.push(opI64Store)
		body.push(0x03)
		writeUleb128(body, value: 0)
	end 'emitWasmStoreI64Const'

	// `osSleep ms` on WASI. Block the current thread for `msId` milliseconds via
	// Preview2's monotonic clock: wasi:clocks/monotonic-clock.subscribe-duration(
	// when ns) -> pollable; [method]pollable.block(self) blocks until it is ready;
	// then [resource-drop]pollable releases the handle. Far simpler than the
	// preview1 poll_oneoff subscription struct it replaces. The pollable handle is
	// stashed in the sleep scratch slot so we don't need a spare local at this
	// call site.
	function emitOsSleep(msId ValueId)
		// handle = subscribe-duration(ms * 1_000_000); stash at wasiSleepSubBase.
		body.push(opI32Const)
		writeSleb128(body, value: wasiSleepSubBase as ParsedInt)
		body.push(opLocalGet)
		writeUleb128(body, value: msId as Wasm32Index)
		body.push(opI64Const)
		writeSleb128(body, value: 1000000)
		body.push(opI64Mul)
		body.push(opCall)
		writeUleb128(body, value: wasiMonotonicSubscribeDuration as Wasm32Index)
		body.push(opI32Store)
		body.push(0x02)
		writeUleb128(body, value: 0)

		// pollable.block(handle).
		body.push(opI32Const)
		writeSleb128(body, value: wasiSleepSubBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opCall)
		writeUleb128(body, value: wasiPollableBlock as Wasm32Index)

		// [resource-drop]pollable(handle).
		body.push(opI32Const)
		writeSleb128(body, value: wasiSleepSubBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opCall)
		writeUleb128(body, value: wasiPollableDrop as Wasm32Index)
	end 'emitOsSleep'

	// `osClockMs` on WASI: read wasi:clocks/monotonic-clock.now() — the
	// monotonic instant in NANOSECONDS — and divide (unsigned) by 1_000_000 to
	// produce the milliseconds the Clock stdlib expects. The result lands in
	// resultId. monotonic-clock is monotonic per the WASI contract, so the
	// `Clock.elapsedMs` skew guard never trips.
	function emitOsClockMs(resultId ValueId)
		// now() -> i64 nanoseconds.
		body.push(opCall)
		writeUleb128(body, value: wasiMonotonicNow as Wasm32Index)
		// ns / 1_000_000 = ms.
		body.push(opI64Const)
		writeSleb128(body, value: 1000000)
		body.push(opI64DivU)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitOsClockMs'

	function emitOsWrite(ptrId ValueId, lenId ValueId, fd MachineWord)
		// Preview2 write: get the stdout/stderr output-stream handle, then
		// blocking-write-and-flush(self, contents_ptr, contents_len, ret_area).
		// The result<_, stream-error> is written to the return area (disc i32 @0)
		// and ignored here (matches the old "drop errno" fire-and-forget write).
		// fd 1 = stdout, anything else = stderr.
		body.push(opCall)
		if fd == 1 'stdout'
			writeUleb128(body, value: wasiGetStdout as Wasm32Index)
		end 'stdout' else 'stderr'
			writeUleb128(body, value: wasiGetStderr as Wasm32Index)
		end 'stderr'
		// stack: [stream-handle]. Push contents ptr, contents len, ret area.
		body.push(opLocalGet)
		writeUleb128(body, value: ptrId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opLocalGet)
		writeUleb128(body, value: lenId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opI32Const)
		writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
		body.push(opCall)
		writeUleb128(body, value: wasiOutBlockingWriteFlush as Wasm32Index)
		// Drop the output-stream handle (owned; would leak, but stdout/stderr are
		// process-lived — the host reclaims on exit). A future pass can cache the
		// handle once and drop on shutdown.
	end 'emitOsWrite'

	// Preview2 read from stdin. get-stdin() -> input-stream; then
	// [method]input-stream.blocking-read(self, len, retArea) returns
	// result<list<u8>, stream-error> into the return area: disc i32@+0 (0=ok),
	// on ok the list is (ptr i32@+4, len i32@+8). The host writes the bytes into
	// a fresh buffer at the list ptr (allocated via cabi_realloc); we memory.copy
	// them into the caller buffer (ptrId) up to lenId, and return the byte count.
	// On error or empty (eof / closed), we return 0. `fd` is ignored (Preview2
	// only models the three CLI streams; this path is only used for stdin).
	function emitOsRead(resultId ValueId, ptrId ValueId, lenId ValueId)
		// blocking-read(get-stdin(), len i64, retArea).
		body.push(opCall)
		writeUleb128(body, value: wasiGetStdin as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: lenId as Wasm32Index)  // max bytes (i64)
		body.push(opI32Const)
		writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
		body.push(opCall)
		writeUleb128(body, value: wasiInBlockingRead as Wasm32Index)

		// Default result = 0 (covers the error / empty path).
		body.push(opI64Const)
		writeSleb128(body, value: 0)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)

		// if disc (i32 @ retArea+0) == 0 (ok): copy list bytes into the caller buffer.
		body.push(opI32Const)
		writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI32Eqz)  // disc == 0 ?
		body.push(opIf)
		body.push(0x40)  // void block type

		// nbytes = list len (i32 @ retArea+8); memory.copy(dst=ptrId, src=list ptr @+4, nbytes).
		body.push(opLocalGet)
		writeUleb128(body, value: ptrId as Wasm32Index)
		body.push(opI32WrapI64)  // dst (i32)
		body.push(opI32Const)
		writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)  // src = list ptr
		body.push(opI32Const)
		writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)  // len = list len
		body.push(0xFC)
		body.push(0x0A)
		body.push(0x00)
		body.push(0x00)  // memory.copy dst=0 src=0

		// resultId = list len (zero-extended).
		body.push(opI32Const)
		writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI64ExtendI32U)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)

		body.push(opEnd)  // end if
	end 'emitOsRead'

	// osGetArgc: emits the WASI argv-cache ensure sequence, then loads the
	// cached argc (i32) and zero-extends to i64 into resultId. Consumes
	// argvScratchLocal/argvScanLocal/argvLenLocal as the cache-build scratch
	// registers. The cache is shared across every osGetArgc/osGetArgv/
	// osGetExecutablePath emission in the module; the first call performs
	// get-arguments + mrt_alloc + the per-argument copy, subsequent calls fall
	// through the early-out branch in emitArgvCacheEnsure.
	function emitOsGetArgc(resultId ValueId)
		emitArgvCacheEnsure(body, funcSigs: funcSigs, scratchLocal: argvScratchLocal, idxLocal: argvScanLocal, dstLocal: argvLenLocal)

		body.push(opI32Const)
		writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI64ExtendI32U)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitOsGetArgc'

	// osGetArgv(indexId): returns the raw C-string pointer to argv[index] as
	// an i64, or 0 when index is out of bounds. The OOB-returns-0 contract
	// matches the unified `mrt_command_line_arg` body in runtime.std, which
	// dispatches on the 0 sentinel to take the empty-MM path. Bounds check
	// rejects both `index < 0` (signed comparison) and `index >= argc`
	// (unsigned after i32-wrap so wraparound from a large unsigned i64
	// can't fool the upper bound).
	function emitOsGetArgv(resultId ValueId, indexId ValueId)
		emitArgvCacheEnsure(body, funcSigs: funcSigs, scratchLocal: argvScratchLocal, idxLocal: argvScanLocal, dstLocal: argvLenLocal)

		// (block (result i64) ... end) — both branches produce an i64 that
		// lands in resultId via the local.set after the block end.
		body.push(opBlock)
		body.push(wasmTypeI64)

		// Inner void block we br_if into for the OOB path. Falling out of
		// the inner block lands in the happy path; brIf to label 0 exits
		// the inner block into the OOB tail of the outer block.
		body.push(opBlock)
		body.push(wasmTypeVoid)

		// if index < 0 then OOB
		body.push(opLocalGet)
		writeUleb128(body, value: indexId as Wasm32Index)
		body.push(opI64Const)
		writeSleb128(body, value: 0)
		body.push(opI64LtS)
		body.push(opBrIf)
		writeUleb128(body, value: 0)

		// if (u32)index >= argc then OOB
		body.push(opLocalGet)
		writeUleb128(body, value: indexId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opI32Const)
		writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI32GeU)
		body.push(opBrIf)
		writeUleb128(body, value: 0)

		// Happy path: argv[idx] = i32.load(buf_ptr + idx*4). Extend to i64,
		// br out of the outer (result i64) block.
		body.push(opI32Const)
		writeSleb128(body, value: argvCacheBufPtrBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opLocalGet)
		writeUleb128(body, value: indexId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opI32Const)
		writeSleb128(body, value: 2)
		body.push(opI32Shl)
		body.push(opI32Add)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI64ExtendI32U)
		body.push(opBr)
		writeUleb128(body, value: 1)

		// End inner void block. OOB path lands here; push 0 and fall through
		// out of the outer (result i64) block.
		body.push(opEnd)

		body.push(opI64Const)
		writeSleb128(body, value: 0)

		// End outer block. Result (the argv[idx] pointer or 0) is on the stack.
		body.push(opEnd)

		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitOsGetArgv'

	// osGetExecutablePath(bufPtrId, bufSizeId): WASI doesn't have an
	// `executable_path` syscall — POSIX convention is argv[0]. We fetch
	// argv[0] from the WASI argv cache, NUL-scan to compute the byte length,
	// then memcpy into the caller-supplied buffer if it fits. Returns the
	// byte count written on success (NUL excluded), or -34 (-ERANGE) when
	// argc == 0 or the buffer is too small. argvScanLocal holds the scan
	// pointer; argvLenLocal accumulates the byte count.
	function emitOsGetExecutablePath(resultId ValueId, bufPtrId ValueId, bufSizeId ValueId)
		emitArgvCacheEnsure(body, funcSigs: funcSigs, scratchLocal: argvScratchLocal, idxLocal: argvScanLocal, dstLocal: argvLenLocal)

		// (block (result i64) ... end) — every path produces an i64 result.
		body.push(opBlock)
		body.push(wasmTypeI64)

		// If argc == 0 then -34 (ERANGE-style sentinel: no executable path
		// available). br to label 0 — falls into the i64-typed end with the
		// -34 already on the stack.
		body.push(opI32Const)
		writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI32Eqz)
		body.push(opIf)
		body.push(wasmTypeVoid)
		body.push(opI64Const)
		writeSleb128(body, value: -34)
		body.push(opBr)
		writeUleb128(body, value: 1)
		body.push(opEnd)

		// argv[0] (i32) = i32.load(buf_ptr + 0*4). Store into argvScanLocal —
		// the scan pointer that the NUL-scan loop advances.
		body.push(opI32Const)
		writeSleb128(body, value: argvCacheBufPtrBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opLocalSet)
		writeUleb128(body, value: argvScanLocal)

		// Initialize argvLenLocal = 0
		body.push(opI32Const)
		writeSleb128(body, value: 0)
		body.push(opLocalSet)
		writeUleb128(body, value: argvLenLocal)

		// NUL-scan loop: while *scan != 0 { scan++; len++; }
		body.push(opBlock)
		body.push(wasmTypeVoid)
		body.push(opLoop)
		body.push(wasmTypeVoid)

		body.push(opLocalGet)
		writeUleb128(body, value: argvScanLocal)
		body.push(opI32Load8U)
		body.push(0x00)
		writeUleb128(body, value: 0)
		body.push(opI32Eqz)
		body.push(opBrIf)
		writeUleb128(body, value: 1)

		body.push(opLocalGet)
		writeUleb128(body, value: argvScanLocal)
		body.push(opI32Const)
		writeSleb128(body, value: 1)
		body.push(opI32Add)
		body.push(opLocalSet)
		writeUleb128(body, value: argvScanLocal)

		body.push(opLocalGet)
		writeUleb128(body, value: argvLenLocal)
		body.push(opI32Const)
		writeSleb128(body, value: 1)
		body.push(opI32Add)
		body.push(opLocalSet)
		writeUleb128(body, value: argvLenLocal)

		body.push(opBr)
		writeUleb128(body, value: 0)
		body.push(opEnd)
		body.push(opEnd)

		// Truncation check: if (u64)byteLen > bufSize then -34.
		body.push(opLocalGet)
		writeUleb128(body, value: argvLenLocal)
		body.push(opI64ExtendI32U)
		body.push(opLocalGet)
		writeUleb128(body, value: bufSizeId as Wasm32Index)
		body.push(opI64GtU)
		body.push(opIf)
		body.push(wasmTypeVoid)
		body.push(opI64Const)
		writeSleb128(body, value: -34)
		body.push(opBr)
		writeUleb128(body, value: 1)
		body.push(opEnd)

		// memory.copy dst=bufPtr src=argv[0] len=byteLen. bufPtr is i64 in
		// the maxon-side local; wrap to i32 for the wasm address. argv[0]'s
		// current value lives in the scan pointer's STARTING address — but
		// the scan loop has advanced argvScanLocal to the NUL. Re-read
		// argv[0] from the cache instead of stashing it before the scan
		// to keep the local count low and the source-of-truth single.
		body.push(opLocalGet)
		writeUleb128(body, value: bufPtrId as Wasm32Index)
		body.push(opI32WrapI64)

		body.push(opI32Const)
		writeSleb128(body, value: argvCacheBufPtrBase as ParsedInt)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)
		body.push(opI32Load)
		body.push(0x02)
		writeUleb128(body, value: 0)

		body.push(opLocalGet)
		writeUleb128(body, value: argvLenLocal)
		body.push(0xFC)
		writeUleb128(body, value: 10)
		body.push(0x00)
		body.push(0x00)

		// Push byteLen as i64 — falls through to the outer end.
		body.push(opLocalGet)
		writeUleb128(body, value: argvLenLocal)
		body.push(opI64ExtendI32U)

		body.push(opEnd)

		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitOsGetExecutablePath'

	function emitMemcpy(dstId ValueId, srcId ValueId, lenId ValueId)
		// Use WASM memory.copy (bulk memory proposal, supported by wasmtime).
		// memory.copy dst src len — all i32 addresses.
		body.push(opLocalGet)
		writeUleb128(body, value: dstId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opLocalGet)
		writeUleb128(body, value: srcId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opLocalGet)
		writeUleb128(body, value: lenId as Wasm32Index)
		body.push(opI32WrapI64)
		// memory.copy opcode: 0xFC 0x0A 0x00 0x00
		body.push(0xFC)
		writeUleb128(body, value: 10)
		body.push(0x00)
		body.push(0x00)
	end 'emitMemcpy'

	function emitStoreByte(baseId ValueId, offsetId ValueId, byteId ValueId)
		// addr = base + offset (both i64, wrap to i32)
		body.push(opLocalGet)
		writeUleb128(body, value: baseId as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: offsetId as Wasm32Index)
		body.push(opI64Add)
		body.push(opI32WrapI64)

		// value
		body.push(opLocalGet)
		writeUleb128(body, value: byteId as Wasm32Index)
		body.push(opI32WrapI64)

		body.push(opI32Store8)
		body.push(0x00)
		writeUleb128(body, value: 0)
	end 'emitStoreByte'

	function emitLoadByte(resultId ValueId, baseId ValueId, offsetId ValueId)
		// addr = base + offset (both i64, wrap to i32)
		body.push(opLocalGet)
		writeUleb128(body, value: baseId as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: offsetId as Wasm32Index)
		body.push(opI64Add)
		body.push(opI32WrapI64)

		body.push(opI32Load8U)
		body.push(0x00)
		writeUleb128(body, value: 0)

		// Extend i32 to i64
		body.push(opI64ExtendI32U)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitLoadByte'

	function emitLoadFramePtr(resultId ValueId)
		// WASM has no frame pointer. Return 0 to terminate stack walks.
		body.push(opI64Const)
		writeSleb128(body, value: 0)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitLoadFramePtr'

	// `local.get localId` then truncate the i64 down to the i32 that wasm
	// memory ops require. Maxon ValueIds always live in i64 locals, so every
	// memory access has to wrap.
	function emitLocalAsI32(localId ValueId)
		body.push(opLocalGet)
		writeUleb128(body, value: localId as Wasm32Index)
		body.push(opI32WrapI64)
	end 'emitLocalAsI32'

	// `local.set localId` — pops the wasm stack into the named local.
	function emitLocalSet(localId ValueId)
		body.push(opLocalSet)
		writeUleb128(body, value: localId as Wasm32Index)
	end 'emitLocalSet'

	// i64.load with align=3 (8 bytes) and zero immediate offset. The memory
	// address is expected to already be on the wasm stack as i32.
	function emitI64LoadAtZero()
		body.push(opI64Load)
		body.push(0x03)
		writeUleb128(body, value: 0)
	end 'emitI64LoadAtZero'

	// i64.store with align=3 (8 bytes) and zero immediate offset. Both address
	// (i32) and value (i64) are expected to already be on the wasm stack.
	function emitI64StoreAtZero()
		body.push(opI64Store)
		body.push(0x03)
		writeUleb128(body, value: 0)
	end 'emitI64StoreAtZero'

	// Slab-allocator OS primitive on WASM: grow linear memory by ceil(size/64KiB)
	// pages and return the byte offset of the newly-allocated region. The slab
	// runtime always passes 64KiB-multiple sizes (64MiB arenas, 8KiB-aligned
	// OS-direct blocks ≥ 32KiB), but we round up defensively. memory.grow
	// returns -1 (i32) on OOM; we widen to i64 so the test stays in the i64
	// world used by every Maxon ValueId, then trap via `unreachable` —
	// convertWasmtimeStderr surfaces this as a recognizable runtime trap.
	function emitOsAllocPages(resultId ValueId, sizeId ValueId)
		// pages = (size + 65535) >> 16
		body.push(opLocalGet)
		writeUleb128(body, value: sizeId as Wasm32Index)
		body.push(opI64Const)
		writeSleb128(body, value: 65535)
		body.push(opI64Add)
		body.push(opI64Const)
		writeSleb128(body, value: 16)
		body.push(opI64ShrU)
		body.push(opI32WrapI64)

		// memory.grow with memory index 0
		body.push(opMemoryGrow)
		body.push(0x00)

		// Sign-extend the i32 result so -1 (OOM) widens to -1 i64; positive
		// prev-page-counts widen to themselves (top bit unused for the address
		// range we care about).
		body.push(opI64ExtendI32S)
		emitLocalSet(resultId)

		// if (resultId == -1i64) unreachable
		body.push(opLocalGet)
		writeUleb128(body, value: resultId as Wasm32Index)
		body.push(opI64Const)
		writeSleb128(body, value: -1)
		body.push(opI64Eq)
		body.push(opIf)
		body.push(wasmTypeVoid)
		body.push(opUnreachable)
		body.push(opEnd)

		// resultId = prevPages * 65536 (the byte offset of the freshly-grown region)
		body.push(opLocalGet)
		writeUleb128(body, value: resultId as Wasm32Index)
		body.push(opI64Const)
		writeSleb128(body, value: 16)
		body.push(opI64Shl)
		emitLocalSet(resultId)
	end 'emitOsAllocPages'

	// Single-threaded RMW on a 64-bit word: *addr = *addr <op> 1.
	// wasm32-wasi MVP has no concurrency so a plain load/op/store is correct;
	// the LOCK prefix on x86 and the LDAXR/STLXR loop on ARM64 are only there
	// to guard against contention that cannot exist here.
	// TODO(wasm-threads): swap for the 0xFE-prefixed atomic-rmw ops if the
	// threads target ever lands.
	function emitAtomicAddOne(addrId ValueId, isSubtract bool)
		// store-address operand goes first on the wasm stack
		emitLocalAsI32(addrId)
		// load current value at *addr
		emitLocalAsI32(addrId)
		emitI64LoadAtZero()
		body.push(opI64Const)
		writeSleb128(body, value: 1)
		body.push(opI64Sub if isSubtract else opI64Add)
		emitI64StoreAtZero()
	end 'emitAtomicAddOne'

	// Fetch-and-add: resultId receives the prior value (mm_decref tests
	// `prior == 1` to detect the last reference), then write prior+val back.
	function emitAtomicXadd(resultId ValueId, addrId ValueId, valId ValueId)
		// resultId = *addr
		emitLocalAsI32(addrId)
		emitI64LoadAtZero()
		emitLocalSet(resultId)
		// *addr = resultId + val
		emitLocalAsI32(addrId)
		body.push(opLocalGet)
		writeUleb128(body, value: resultId as Wasm32Index)
		body.push(opLocalGet)
		writeUleb128(body, value: valId as Wasm32Index)
		body.push(opI64Add)
		emitI64StoreAtZero()
	end 'emitAtomicXadd'

	// Compare-and-swap: result = (*addr == old) ? 1 : 0, and on a match write
	// `new`. wasm32-wasi MVP is single-threaded, so a plain compare + conditional
	// store is correct; the x86 LOCK CMPXCHG and ARM64 LL/SC loop only exist to
	// guard against contention that cannot occur here.
	// TODO(wasm-threads): swap for the 0xFE-prefixed atomic.rmw.cmpxchg op if the
	// threads target ever lands.
	function emitAtomicCas(resultId ValueId, addrId ValueId, oldId ValueId, newId ValueId)
		// result = i64.extend_u(i64.eq(*addr, old))  -> 1 on match, 0 otherwise
		emitLocalAsI32(addrId)
		emitI64LoadAtZero()
		body.push(opLocalGet)
		writeUleb128(body, value: oldId as Wasm32Index)
		body.push(opI64Eq)
		body.push(opI64ExtendI32U)
		emitLocalSet(resultId)

		// *addr = select(new, *addr, result) — keeps the old word on a mismatch.
		// wasm `select` pops [val1, val2, cond] and yields val1 when cond != 0.
		emitLocalAsI32(addrId)
		body.push(opLocalGet)
		writeUleb128(body, value: newId as Wasm32Index)
		emitLocalAsI32(addrId)
		emitI64LoadAtZero()
		emitLocalAsI32(resultId)
		body.push(opSelect)
		emitI64StoreAtZero()
	end 'emitAtomicCas'

	function emitFuncAddr(resultId ValueId, name String)
		// Stage F (closures): emit the function's table index as an i32,
		// extended to i64 so the value lives in an i64 local matching the
		// closure ABI. `funcTableIndices` is populated by emitWasmModule
		// before any function body is lowered, so every user function has
		// a stable index here.
		//
		// Stdlib-cache mode (`fixedCalls = true`) starts with an empty
		// `funcTableIndices` map — the user-build assembles the final table.
		// Phase 4 (managed-memory migration) introduced stdlib bodies that
		// take function addresses (`mm_alloc(40, destructor: funcAddr ...)` in
		// the migrated `__managed_mem_create`/`slice`), so we emit a 5-byte
		// fixed-width sleb128 placeholder and record a fixup the user-build
		// patches with the resolved table index.
		body.push(opI32Const)
		if fixedCalls 'cacheMode'
			let tableIdx = try funcTableIndices.get(name) otherwise -1 as MachineWord
			if tableIdx == (-1 as MachineWord) 'recordFixup'
				funcAddrFixups.push(WasmFuncAddrFixup.create(body.count(), targetName: name))
				writeSleb128Fixed5(body, value: 0 as ParsedInt)
			end 'recordFixup' else 'haveIdx'
				writeSleb128Fixed5(body, value: tableIdx)
			end 'haveIdx'
		end 'cacheMode' else 'userMode'
			// User-build pipeline: table is finalized, miss is a bug for a
			// real funcAddr op but tolerated for fallback paths like
			// `mrt_panic_print_frame` that emit zero on miss.
			let tableIdx = try funcTableIndices.get(name) otherwise 0 as MachineWord
			writeSleb128(body, value: tableIdx)
		end 'userMode'
		body.push(opI64ExtendI32U)
		body.push(opLocalSet)
		writeUleb128(body, value: resultId as Wasm32Index)
	end 'emitFuncAddr'

	// Stage F (closures): build the wasm functype encoding for an
	// indirect call site. argIds drive the param types (i64 vs f64 from
	// the per-function floatSet); resultId's type comes from the same
	// bitset. The bytes returned are exactly what `writeFuncType` would
	// produce, so they can be used as-is for type-section dedup keys.
	// Human-readable rendering of an indirect-call signature for panic
	// messages. Mirrors `buildIndirectCallTypeBytes`'s float/int decision
	// but produces "(i64, f64) -> i64" instead of opaque wasm bytes, so a
	// "type not pre-registered" diagnostic actually says WHICH shape is
	// missing.
	function describeIndirectCallShape(resultId ValueId, argIds ValueIdArray) returns String
		var s = "("
		for i in 0 upto argIds.count() 'eachArg'
			if i > 0 'sep'
				s.append(", ")
			end 'sep'
			let argId = try argIds.get(i) otherwise panic("describeIndirectCallShape: argIds.get OOB at {i}")
			if isFloatLocal(funcFloatSet, localIdx: argId as MachineWord) 'isFloat'
				s.append("f64")
			end 'isFloat' else 'isInt'
				s.append("i64")
			end 'isInt'
		end 'eachArg'
		s.append(") -> ")
		if isFloatLocal(funcFloatSet, localIdx: resultId) 'floatRes'
			s.append("f64")
		end 'floatRes' else 'intRes'
			s.append("i64")
		end 'intRes'
		return s
	end 'describeIndirectCallShape'

	function buildIndirectCallTypeBytes(resultId ValueId, isVoid bool, argIds ValueIdArray, throws bool) returns ByteArray
		var params = ByteArray.create()
		for argId in argIds 'eachArg'
			if isFloatLocal(funcFloatSet, localIdx: argId as MachineWord) 'isFloat'
				params.push(wasmTypeF64)
			end 'isFloat' else 'isInt'
				params.push(wasmTypeI64)
			end 'isInt'
		end 'eachArg'
		var results = ByteArray.create()
		// `isVoid` covers void interface methods (e.g. `interface Printer
		// { function show() }`); for non-void callees the wasm `call_indirect`
		// type must declare exactly one i64/f64 result so it matches what
		// the callee actually pushes. Closures always return a value today
		// (the body's `gives <expr>` desugars to a non-void return), so
		// emitIndirectCall passes isVoid=false.
		if not isVoid 'hasResult'
			if isFloatLocal(funcFloatSet, localIdx: resultId) 'floatRes'
				results.push(wasmTypeF64)
			end 'floatRes' else 'intRes'
				results.push(wasmTypeI64)
			end 'intRes'
		end 'hasResult'
		// Throwing witness methods append a trailing i64 error flag, matching
		// the dual-value-return error ABI encoded by buildFuncTypeEntry.
		if throws 'errorFlagResult'
			results.push(wasmTypeI64)
		end 'errorFlagResult'
		var funcType = ByteArray.create()
		writeFuncType(funcType, paramTypes: params, resultTypes: results)
		return funcType
	end 'buildIndirectCallTypeBytes'

	// witnessCall = fused (load fn-ptr from witness table) + (call_indirect).
	// The loaded function table-index never lands in a local: we leave it on
	// the Wasm stack between the load and the call_indirect, taking
	// advantage of the stack-machine model. Pressure-reduction motive
	// inherited from the X64 lowering, even though Wasm itself doesn't have
	// a register pressure problem. `isVoid` lets void interface methods
	// (e.g. `interface Printer { function show() }`) declare a no-result
	// signature — call_indirect type-matches against the actual callee,
	// which pushes nothing onto the stack, so a phantom i64 result would
	// trap with "indirect call type mismatch".
	function emitWitnessCall(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray)
		emitWitnessCallStackSetup(witnessAddrId, methodIndex: methodIndex, argIds: argIds)
		emitWitnessCallIndirect(resultId, isVoid: isVoid, argIds: argIds, throws: false)

		// Void method bodies push nothing; skip the local.set so the
		// stack stays balanced. The dead resultId still has a wasm local
		// reserved (sized by findMaxValueId) but is simply never written.
		if not isVoid 'storeResult'
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'storeResult'
	end 'emitWitnessCall'

	// Lower MirOp.witnessTryCall: same fused witness-table load + call_indirect
	// as emitWitnessCall, but the dispatched method is `throws`, so its wasm
	// signature appends a trailing i64 (error flag). Wasm pushes results in
	// declared order (primary first, error flag last), so pop the error flag
	// first into errorFlagId, then the primary result (if non-void) into
	// resultId. Mirrors emitTryCall's pop order on the direct-call path.
	function emitWitnessTryCall(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray, errorFlagId ValueId)
		emitWitnessCallStackSetup(witnessAddrId, methodIndex: methodIndex, argIds: argIds)
		emitWitnessCallIndirect(resultId, isVoid: isVoid, argIds: argIds, throws: true)

		// Error flag is on top of stack (declared last); pop it first.
		body.push(opLocalSet)
		writeUleb128(body, value: errorFlagId as Wasm32Index)
		if not isVoid 'storeResult'
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'storeResult'
	end 'emitWitnessTryCall'

	// Push call_indirect operands for a witness dispatch: args first (stack
	// order: args before callee index), then the fn-ptr loaded from the
	// witness table straight onto the stack (no intermediate local).
	function emitWitnessCallStackSetup(witnessAddrId ValueId, methodIndex MachineWord, argIds ValueIdArray)
		for argId in argIds 'pushArgs'
			body.push(opLocalGet)
			writeUleb128(body, value: argId as Wasm32Index)
		end 'pushArgs'

		// The closure ABI carries function pointers as i64 (table index
		// extended); narrow to the i32 that call_indirect expects.
		let offset = WITNESS_OFFSET_METHODS + 8 * methodIndex
		body.push(opLocalGet)
		writeUleb128(body, value: witnessAddrId as Wasm32Index)
		body.push(opI32WrapI64)
		body.push(opI64Load)
		body.push(0x03)
		writeUleb128(body, value: offset)
		body.push(opI32WrapI64)
	end 'emitWitnessCallStackSetup'

	// Shared call_indirect type-resolution + opcode emission for the two
	// witness-dispatch emitters. The witness-table load + args must already
	// be on the wasm stack (see emitWitnessCallStackSetup).
	function emitWitnessCallIndirect(resultId ValueId, isVoid bool, argIds ValueIdArray, throws bool)
		let typeBytes = buildIndirectCallTypeBytes(resultId, isVoid: isVoid, argIds: argIds, throws: throws)
		body.push(opCallIndirect)
		if fixedCalls 'useFixed'
			typeFixups.push(WasmTypeFixup.create(body.count(), signatureBytes: typeBytes))
			writeUleb128Fixed5(body, value: 0)
		end 'useFixed' else 'useVariable'
			let typeIdx = try typeIndices.get(typeBytes) otherwise panic("emitWitnessCallIndirect: type not pre-registered for indirect call in '{func.name}' (resultId={resultId} argCount={argIds.count()} shape={describeIndirectCallShape(resultId, argIds: argIds)}); emitWasmModule must walk every MirOp.witnessCall/witnessTryCall in advance and seed typeIndices for the (params,result) shape. See `collectIndirectCallTypes`")
			writeUleb128(body, value: typeIdx)
		end 'useVariable'
		writeUleb128(body, value: 0)
	end 'emitWitnessCallIndirect'

	function emitIndirectCall(resultId ValueId, calleeId ValueId, argIds ValueIdArray, isVoid bool, isThrowing bool, errorFlagId ValueId)
		// Push args first (matches the wasm call_indirect stack order:
		// args before callee index). This mirrors emitCall's arg push.
		for argId in argIds 'pushArgs'
			body.push(opLocalGet)
			writeUleb128(body, value: argId as Wasm32Index)
		end 'pushArgs'

		// Push callee table index. The closure ABI carries the function
		// pointer as i64 (table index extended via emitFuncAddr); narrow
		// it back to the i32 that call_indirect expects.
		body.push(opLocalGet)
		writeUleb128(body, value: calleeId as Wasm32Index)
		body.push(opI32WrapI64)

		// Look up the type-section index for this call signature, dedup-
		// shared with direct-call types via the pre-populated map. The
		// shape (void result / trailing error flag) must match the table
		// target's own declared type, or call_indirect traps with "indirect
		// call type mismatch"; the green-thread runtime's `__gt_invoke`
		// dispatches a coroutine entry whose return shape varies, so it
		// emits void/throwing indirect calls. In `fixedCalls` mode (stdlib-
		// cache emission), the user-build will own the final type-section
		// layout; we record a typeFixup and write a 5-byte placeholder that
		// gets patched at module-assembly time.
		let typeBytes = buildIndirectCallTypeBytes(resultId, isVoid: isVoid, argIds: argIds, throws: isThrowing)
		body.push(opCallIndirect)
		if fixedCalls 'useFixed'
			typeFixups.push(WasmTypeFixup.create(body.count(), signatureBytes: typeBytes))
			writeUleb128Fixed5(body, value: 0)
		end 'useFixed' else 'useVariable'
			let typeIdx = try typeIndices.get(typeBytes) otherwise panic("emitIndirectCall: type not pre-registered for indirect call in '{func.name}' (resultId={resultId} argCount={argIds.count()} shape={describeIndirectCallShape(resultId, argIds: argIds)}); emitWasmModule must walk every MirOp.indirectCall in advance and seed typeIndices for the (params,result) shape. See `collectIndirectCallTypes` for the existing pre-pass")
			writeUleb128(body, value: typeIdx)
		end 'useVariable'
		writeUleb128(body, value: 0)

		// Pop the call_indirect results into locals. Wasm pushes results in
		// declared order (primary first, error flag last), so for a throwing
		// call pop the error flag FIRST, then the primary result. A void call
		// pushes nothing, so there is no local.set at all.
		if isThrowing 'storeFlag'
			body.push(opLocalSet)
			writeUleb128(body, value: errorFlagId as Wasm32Index)
		end 'storeFlag'
		if not isVoid 'storeResult'
			body.push(opLocalSet)
			writeUleb128(body, value: resultId as Wasm32Index)
		end 'storeResult'
	end 'emitIndirectCall'

	// ============================================================
	// Per-function analysis helpers
	// ============================================================

	// O(1) blockId → blockRefs-index lookup against the per-function
	// `blockIndex` map populated at the top of lowerFunction. A branch
	// terminator referencing a block not in this function is a compiler
	// invariant violation, so an unknown id traps rather than silently
	// resolving to block 0.
	function findBlockIndex(blockId BlockId) returns MachineWord
		return try blockIndex.get(blockId) otherwise panic("findBlockIndex: branch targets blockId {blockId} not in func.blockRefs")
	end 'findBlockIndex'

	function findMaxValueId() returns MachineWord
		return scanMaxMirValueId(module, func: func)
	end 'findMaxValueId'

	// Returns true iff the current function contains any of osGetArgc,
	// osGetArgv, or osGetExecutablePath. lowerFunction calls this once to
	// decide whether to reserve the three i32 scratch locals used by their
	// lowerings.
	function scanForArgvOps() returns bool
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
			for packed in block.opRefs 'eachOp'
				let op = try module.ops.get(packed) otherwise panic("invariant: opIdx not in module.ops")
				let found = match op 'check'
					movImm to osGetEnv gives false
					osGetArgc gives true
					osClockMs gives false
					osGetArgv gives true
					osGetExecutablePath gives true
					memcpy to errorReturn gives false
				end 'check'
				if found 'gotIt'
					return true
				end 'gotIt'
			end 'eachOp'
		end 'eachBlock'
		return false
	end 'scanForArgvOps'

	// ============================================================
	// Float value tracking
	// ============================================================

	// Scan a function to find which ValueIds hold float (f64) values.
	// Returns a BoolArray where index i is true if ValueId i is float.
	// Block-argument value ids (introduced by mem2reg's phi-to-blockArg
	// rewrite) carry their StdType on IrBlock.blockArgs, so we mark those
	// directly. MIR-op outputs are marked by walking each op once: opcodes
	// determine float-ness deterministically, and movReg propagates from
	// source — which is always defined before the move because a movReg's
	// source is either an earlier MIR op result or a block argument we've
	// already seeded.
	function findFloatValueIds() returns BoolArray
		let maxId = findMaxValueId()
		var result = BoolArray.create()
		for _ in 0 upto maxId + 1 'init'
			result.push(false)
		end 'init'
		// Seed block-arg locals from their declared StdType. This must run
		// before the op walk so movRegs / branch-arg copies into a block
		// arg's id pick up its known type.
		for blockRef in func.blockRefs 'seedBlockArgs'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
			for blockArg in block.blockArgs 'eachArg'
				if stdTypeIsFloat(blockArg.argType) 'isFloat'
					try result.set(blockArg.valueId as MachineWord, value: true) otherwise panic("invariant: floatSet.set OOB for blockArg")
				end 'isFloat'
			end 'eachArg'
		end 'seedBlockArgs'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
			for packed in block.opRefs 'eachOp'
				markFloatPackedOp(packed, floatSet: result)
			end 'eachOp'
			if block.hasTerminatorOp() 'hasTerm'
				markFloatPackedOp(block.terminatorIndex(), floatSet: result)
			end 'hasTerm'
		end 'eachBlock'
		return result
	end 'findFloatValueIds'

	function markFloatPackedOp(opIdx OpIndex, floatSet BoolArray)
		let mirOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
		markFloatMirOp(mirOp, floatSet: floatSet)
	end 'markFloatPackedOp'

	function markFloatMirOp(op MirOp, floatSet BoolArray)
		match op 'dispatch'
			movImm(resultId, _, isFloat) then markIf(floatSet, id: resultId as MachineWord, condition: isFloat)
			binOp(resultId, _, _, opcode) then markIfFloatBinOp(floatSet, id: resultId as MachineWord, opcode: opcode)
			unaryOp(resultId, _, opcode) then markIfFloatUnaryOp(floatSet, id: resultId as MachineWord, opcode: opcode)
			call(resultId, callee, _) then markIfFloatCall(floatSet, id: resultId as MachineWord, callee: callee)
			param(resultId, _, paramType) then markIf(floatSet, id: resultId as MachineWord, condition: stdTypeIsFloat(paramType))
			movReg(resultId, srcId) then markIfSource(floatSet, id: resultId as MachineWord, srcId: srcId)
			cmp to branch then break 'dispatch'
			indirectCall then break 'dispatch'
			witnessCall then break 'dispatch'
			ret then break 'dispatch'
			load(resultId, _, _, _, _, isFloat) then markIf(floatSet, id: resultId as MachineWord, condition: isFloat)
			store to loadByte then break 'dispatch'
			osAllocPages to osLockRelease then break 'dispatch'
			tryCall(resultId, callee, _, _) then markIfFloatCall(floatSet, id: resultId as MachineWord, callee: callee)
			// witnessTryCall dispatches through a witness table, so the result
			// float-ness isn't derivable from a callee name (like witnessCall).
			witnessTryCall then break 'dispatch'
			errorReturn then break 'dispatch'
		end 'dispatch'
	end 'markFloatMirOp'

	function markIfFloatCall(floatSet BoolArray, id MachineWord, callee String)
		let retType = lookupReturnType(callee)
		if stdTypeIsFloat(retType) 'isFloat'
			try floatSet.set(id, value: true) otherwise panic("invariant: floatSet.set OOB")
		end 'isFloat'
	end 'markIfFloatCall'
end 'WasmFunctionLowering'

// O(1) lookup of a function's WASM index, given its name and the
// imports-prefix offset (imports occupy 0..importCount-1, module funcs
// follow). The funcSigs nameIndex doesn't track the import prefix, so the
// caller adjusts here. Lives at file scope rather than as a method on
// WasmFunctionLowering because emitWasmModule and the stdlib-body fixup
// loop both call it without holding a lowering instance.
function findFunctionIndex(funcSigs WasmFuncSigs, name String, importCount Wasm32Index) returns Wasm32Index
	let idx = try funcSigs.indexOf(name) otherwise panic("wasm: function not found: {name}")
	return (importCount + idx) as Wasm32Index
end 'findFunctionIndex'

// ============================================================
// Simplified WASM panic: write cstring to stderr, then trap.
// Replaces the native mrt_panic which does stack walking (wasmtime provides backtraces instead).
// ============================================================

// mrt_panic(msg_ptr: i64) -> void
// Scans for null terminator to get length, writes to stderr via Preview2's
// output-stream.blocking-write-and-flush, then traps.
function emitWasmPanic() returns ByteArray
	var body = ByteArray.create()
	// Locals: param 0 = msg_ptr (i64)
	// Extra locals: 1 i64 (loop counter/length), 1 i32 (temp)
	writeUleb128(body, value: 2)
	writeUleb128(body, value: 1)
	body.push(wasmTypeI64)
	writeUleb128(body, value: 1)
	body.push(wasmTypeI32)

	// local 0 = msg_ptr (param), local 1 = len (i64), local 2 = temp (i32)

	// Compute string length: scan for null byte
	// len = 0
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: 1)

	// loop: while msg_ptr[len] != 0
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLoop)
	body.push(wasmTypeVoid)

	// load byte at msg_ptr + len
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: 1)
	body.push(opI64Add)
	body.push(opI32WrapI64)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: 2)

	// if byte == 0, break
	body.push(opLocalGet)
	writeUleb128(body, value: 2)
	body.push(opI32Eqz)
	body.push(opBrIf)
	writeUleb128(body, value: 1)

	// len = len + 1
	body.push(opLocalGet)
	writeUleb128(body, value: 1)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opI64Add)
	body.push(opLocalSet)
	writeUleb128(body, value: 1)

	// continue loop
	body.push(opBr)
	writeUleb128(body, value: 0)

	body.push(opEnd)
	body.push(opEnd)

	// Now write msg_ptr (local 0, len bytes in local 1) to stderr via Preview2:
	// blocking-write-and-flush(get-stderr(), msg_ptr, msg_len, retArea). The
	// result<_, stream-error> is written to the return area and ignored (this is
	// the panic path; we trap immediately after).
	body.push(opCall)
	writeUleb128(body, value: wasiGetStderr as Wasm32Index)
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)  // msg_ptr
	body.push(opLocalGet)
	writeUleb128(body, value: 1)
	body.push(opI32WrapI64)  // msg_len
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiOutBlockingWriteFlush as Wasm32Index)

	// Trap — panic is not a clean exit. Wasmtime will show a backtrace with function names.
	body.push(opUnreachable)
	body.push(opEnd)
	return body
end 'emitWasmPanic'

// No-op void function body (0 locals, just end).
function emitWasmNopVoidFunc() returns ByteArray
	var body = ByteArray.create()
	writeUleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmNopVoidFunc'

// Emit the bytecode that ensures the argv cache (scratch slots starting at
// argvCacheInitFlagBase) is populated. Invoked from the WASM op lowerings of
// osGetArgc / osGetArgv / osGetExecutablePath; the first call materializes the
// cache, subsequent calls take the early-out branch.
//
// Preview1 had args_sizes_get / args_get, which wrote a contiguous (pointer
// array + NUL-terminated string data) blob directly. Preview2 replaces those
// with wasi:cli/environment.get-arguments(ret-area) -> list<string>, where the
// strings are (ptr, len) pairs with NO NUL terminators. The downstream
// consumers (osGetArgv returns a raw C-string pointer; mrt_command_line_arg
// and osGetExecutablePath NUL-scan it) still expect the legacy layout, so we
// rebuild it: allocate one process-lived buffer holding an argc-entry i32
// pointer array followed by NUL-terminated copies of each argument, and store
// each copy's address into the pointer array. osGetArgv then reads
// argv[i] = i32.load(bufPtr + i*4) exactly as before.
//
// `scratchLocal` holds the destination buffer pointer; `idxLocal` is the loop
// counter; `dstLocal` is the running string-copy write pointer. All three are
// caller-supplied i32 locals that must not alias any i64 param/local — see the
// argvScratchLocal / argvScanLocal / argvLenLocal reservation in lowerFunction
// (those scratch locals are free here, before any consumer logic runs).
//
// A non-zero list length of 0 (no arguments) leaves argc = 0 and an empty
// pointer array, so osGetArgv returns 0 (OOB) for every index — matching the
// spec runner's "treat argv access failures as empty" convention.
function emitArgvCacheEnsure(body ByteArray, funcSigs WasmFuncSigs, scratchLocal MachineWord, idxLocal MachineWord, dstLocal MachineWord)
	let listStringStride = 8  // each list<string> element = (ptr i32, len i32)

	// if (load i32 from argvCacheInitFlagBase) != 0: skip everything.
	body.push(opBlock)
	body.push(wasmTypeVoid)

	body.push(opI32Const)
	writeSleb128(body, value: argvCacheInitFlagBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opBrIf)
	writeUleb128(body, value: 0)

	// get-arguments(retArea) — writes list (ptr i32 @+0, len i32 @+4).
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiGetArguments as Wasm32Index)

	// argc = *(i32)(retArea + 4); cache it at argvCacheArgcBase.
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)

	// Pass 1: sum the argument byte lengths into argvCacheBufSizeBase. The
	// list pointer/length stay live in the return area (mrt_alloc below only
	// calls the slab allocator / memory.grow, never a WASI import that would
	// overwrite the return area), so both passes re-read listPtr from retArea+0.
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheBufSizeBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	// idx = 0
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: idxLocal)
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLoop)
	body.push(wasmTypeVoid)
	// if (idx >= argc) break.
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32GeU)
	body.push(opBrIf)
	writeUleb128(body, value: 1)
	// bufSize += *(i32)(listPtr + idx*stride + 4)  (element len).
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheBufSizeBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheBufSizeBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	emitArgvElementFieldAddr(body, idxLocal: idxLocal, stride: listStringStride, fieldOffset: 4)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Add)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	// idx++ ; continue.
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: idxLocal)
	body.push(opBr)
	writeUleb128(body, value: 0)
	body.push(opEnd)
	body.push(opEnd)

	// Allocate bufSize = argc*4 (pointer array) + sum(lengths) + argc (one NUL
	// per argument) bytes. mrt_alloc takes an i64 and returns the address i64.
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Shl)  // argc*4
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheBufSizeBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Add)  // + sum(lengths)
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Add)  // + argc (NUL terminators)
	body.push(opI64ExtendI32U)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: scratchLocal)

	// cache[argvCacheBufPtrBase] = bufPtr.
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheBufPtrBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: scratchLocal)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)

	// dst = bufPtr + argc*4 (string data begins after the pointer array).
	body.push(opLocalGet)
	writeUleb128(body, value: scratchLocal)
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Shl)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: dstLocal)

	// Pass 2: for each argument, store dst into pointer array[idx], memory.copy
	// its bytes from the list string, append a NUL, and advance dst past both.
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: idxLocal)
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLoop)
	body.push(wasmTypeVoid)
	// if (idx >= argc) break.
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheArgcBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32GeU)
	body.push(opBrIf)
	writeUleb128(body, value: 1)
	// pointerArray[idx] = dst : *(i32)(bufPtr + idx*4) = dst.
	body.push(opLocalGet)
	writeUleb128(body, value: scratchLocal)
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Shl)
	body.push(opI32Add)
	body.push(opLocalGet)
	writeUleb128(body, value: dstLocal)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	// memory.copy(dst, srcPtr = *(i32)(listPtr + idx*stride + 0), len = *(i32)(... + 4)).
	body.push(opLocalGet)
	writeUleb128(body, value: dstLocal)  // dst
	emitArgvElementFieldAddr(body, idxLocal: idxLocal, stride: listStringStride, fieldOffset: 0)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)  // src
	emitArgvElementFieldAddr(body, idxLocal: idxLocal, stride: listStringStride, fieldOffset: 4)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)  // len
	body.push(0xFC)
	body.push(0x0A)
	body.push(0x00)
	body.push(0x00)  // memory.copy
	// dst += len.
	body.push(opLocalGet)
	writeUleb128(body, value: dstLocal)
	emitArgvElementFieldAddr(body, idxLocal: idxLocal, stride: listStringStride, fieldOffset: 4)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: dstLocal)
	// *(u8)dst = 0 (NUL terminator); dst += 1.
	body.push(opLocalGet)
	writeUleb128(body, value: dstLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Store8)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: dstLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: dstLocal)
	// idx++ ; continue.
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: idxLocal)
	body.push(opBr)
	writeUleb128(body, value: 0)
	body.push(opEnd)
	body.push(opEnd)

	// Mark cache initialized so subsequent calls skip everything above.
	body.push(opI32Const)
	writeSleb128(body, value: argvCacheInitFlagBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)

	body.push(opEnd)
end 'emitArgvCacheEnsure'

// Push the address of field `fieldOffset` within list-element `idxLocal` of the
// get-arguments `list<string>`, i.e. listPtr + idxLocal*stride + fieldOffset,
// where listPtr = *(i32)(retArea + 0). Used by emitArgvCacheEnsure to read each
// argument string's (ptr, len) pair from the return area.
function emitArgvElementFieldAddr(body ByteArray, idxLocal MachineWord, stride MachineWord, fieldOffset MachineWord)
	// listPtr
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	// + idx*stride
	body.push(opLocalGet)
	writeUleb128(body, value: idxLocal)
	body.push(opI32Const)
	writeSleb128(body, value: stride as ParsedInt)
	body.push(opI32Mul)
	body.push(opI32Add)
	// + fieldOffset
	if fieldOffset != 0 'addField'
		body.push(opI32Const)
		writeSleb128(body, value: fieldOffset as ParsedInt)
		body.push(opI32Add)
	end 'addField'
end 'emitArgvElementFieldAddr'

// ============================================================
// Phase 15c Stream 3.3: WASI file/directory I/O helpers
// ============================================================
//
// Every helper below is invoked from `lowerFunction` for the matching
// public `mrt_file_*` / `mrt_directory_*` runtime function name. The
// runtime.std bodies reference Linux-only `osFile*` / `osDir*` ops,
// so the bodies emitted here completely replace them for the wasm path.
//
// Common conventions across all helpers:
//   - Maxon i64 params get wrapped to i32 with `i32.wrap_i64` before
//     being passed to a WASI import (WASI uses 32-bit linear-memory
//     pointers under wasm32).
//   - `__ManagedMemory` parameters carry the buffer pointer at offset
//     0 (i64) and the byte length at offset 8 (i64). We load those
//     and wrap to i32 before passing to a WASI call expecting
//     (buf_ptr, buf_len) i32 pair.
//   - Throwing helpers (file_open_read, file_read, file_write,
//     file_open_write, file_open_write_executable, file_size,
//     file_delete, file_stat, directory_open_search, directory_create,
//     directory_next, directory_current_path) return (i64 primary,
//     i64 error_flag) via the wasm multi-value-return ABI. The error
//     flag is 0 on success, or `ordinal + 1` on failure where the
//     ordinal is into the `__ManagedFileError` / `__ManagedDirectoryError`
//     enum. The stub bodies used the same mapping so we match exactly.
//   - Path-based calls resolve their base `descriptor` via
//     `emitResolvePreopenDesc` (cwd or parent preopen, see that helper).
//
// Preview2 filesystem calls return `result<T, error-code>` (NOT a Preview1
// errno); `emitWasmMapWasiErrorCode` maps the error-code enum ordinal to the
// Maxon error-flag wire value.

// Preview2 error-code mapping. The error-code enum's ordinals differ from
// Preview1 errno: in types.wit, `access` (EACCES) is ordinal 0 and `no-entry`
// (ENOENT) is ordinal 20.
//
// Canonical-ABI memory layout of `result<T, error-code>`:
//   - The result discriminant is a single byte (`u8`, 2 cases) at +0:
//     0 = ok, 1 = err.
//   - The payload follows at the result's alignment, which is the max of
//     align(T) and align(error-code). error-code is a 36-case enum, stored as
//     a 1-byte ordinal. So the err payload (the error-code byte) sits at
//     +errOffset, where errOffset = align(result):
//        result<descriptor, _>      align 4 -> errOffset 4
//        result<filesize|stat, _>   align 8 -> errOffset 8
//        result<_unit_, _>          align 1 -> errOffset 1
//   Both the disc and the error-code are read as BYTES — reading the disc as a
//   full i32 would fold stale padding bytes [1..align) into the value and
//   falsely report an error on an ok result (the host writes only the 1-byte
//   disc, leaving padding untouched).
//
// Caller convention: nothing is on the wasm stack on entry; this helper loads
// the disc and (on err) the error-code from the shared return area itself.
// `tempLocal` is a caller-declared i32 scratch used to stash the disc/error so
// we can branch on it. The mapped i64 flag (0 = ok, 1 = notFound,
// 2 = accessDenied, else catchallFlag) is left on the stack.
//
// On entry stack: []. On exit stack: [flag i64].
function emitWasmMapWasiErrorCode(body ByteArray, tempLocal MachineWord, errOffset MachineWord, catchallFlag MachineWord)
	// Load the 1-byte result disc and stash it so we can branch on it inside
	// the result block (block typing forbids consuming a value pushed before
	// the block).
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: tempLocal)

	body.push(opBlock)
	body.push(wasmTypeI64)

	// disc == 0 → ok, push flag 0.
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: tempLocal)
	// Branch to the err handler if disc != 0.
	body.push(opBrIf)
	writeUleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opBr)
	writeUleb128(body, value: 1)
	body.push(opEnd)

	// Err path. The error-code byte sits at wasiRetAreaBase + errOffset. Load
	// and stash it (reusing tempLocal now that disc has served its purpose).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + errOffset) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: tempLocal)

	// Tier 1: no-entry (ordinal 20) → notFound (flag 1).
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: tempLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 20)
	body.push(opI32Ne)
	body.push(opBrIf)
	writeUleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opBr)
	writeUleb128(body, value: 1)
	body.push(opEnd)

	// Tier 2: access (ordinal 0) → accessDenied (flag 2).
	body.push(opBlock)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: tempLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Ne)
	body.push(opBrIf)
	writeUleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: 2)
	body.push(opBr)
	writeUleb128(body, value: 1)
	body.push(opEnd)

	// Fallthrough: catchall flag.
	body.push(opI64Const)
	writeSleb128(body, value: catchallFlag as ParsedInt)

	body.push(opEnd)
end 'emitWasmMapWasiErrorCode'

// Lazily resolve and cache the preopen `descriptor` handles, leaving the cwd
// handle in the caller-supplied i32 local `descLocal`.
//
// Preview1 used fixed dirfd numbers (3 = cwd, 4 = parent). Preview2 is
// descriptor-relative: wasi:filesystem/preopens.get-directories() returns
// list<(descriptor, string)> of the preopened directories. The spec runner
// preopens `--dir=. --dir=..::../`, so element 0 is the cwd `.` and element 1
// is the parent `..`.
//
// The list result is written to the return area as (ptr i32 @+0, len i32 @+4).
// Each element is tuple<descriptor(handle i32 @+0), string(ptr i32 @+4, len i32
// @+8)> = 12 bytes. We cache element 0's handle as the cwd descriptor and
// element 1's handle as the parent descriptor (falling back to the cwd handle
// if only one directory was preopened, so a path with ".." degrades gracefully
// rather than reading past the list). The handles are process-lived (like the
// stdout stream handle); we never drop them.
//
// `descLocal` is a caller-declared i32 used both as the result and as scratch
// for the list pointer. After this helper runs it holds the cwd descriptor
// handle.
function emitEnsurePreopenDesc(body ByteArray, descLocal MachineWord)
	// if (wasiPreopenDescReady == 0) { populate } ; descLocal = cached handle.
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenDescReady as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)

	// get-directories(retArea) — writes list (ptr @+0, len @+4).
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiGetDirectories as Wasm32Index)

	// listPtr = *(i32*)(retArea + 0).
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: descLocal)

	// cache cwd handle = *(i32*)(listPtr + 0) (element 0's descriptor field).
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenDescBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: descLocal)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)

	// cache parent handle: default to the cwd handle (element 0), then override
	// with element 1's descriptor (*(i32*)(listPtr + 12)) when len >= 2.
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenParentDescBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: descLocal)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	// if (*(i32*)(retArea + 4) >= 2) parentDesc = *(i32*)(listPtr + 12).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32GeU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenParentDescBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: descLocal)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 12)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opEnd)

	// Mark ready.
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenDescReady as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)

	body.push(opEnd)

	// descLocal = cached descriptor handle.
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenDescBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: descLocal)
end 'emitEnsurePreopenDesc'

// Preview2 path resolution: ensure the preopen descriptors are cached, then
// choose the base descriptor for `pathBuf`/`pathLen` and leave it in `descLocal`.
//
// If the path starts with "..", the parent preopen descriptor is selected and
// the leading "../" (or bare "..") prefix is stripped so the remainder is
// relative to the parent directory — Preview2 rejects a ".." component that
// would escape a descriptor's own preopen with `not-permitted`, so we must
// re-root onto the parent preopen instead. Otherwise the cwd descriptor is used
// and the path is left unchanged.
//
// Caller convention: `pathBufLocal`/`pathLenLocal` are i32 locals holding the
// path pointer/length and MUST be in scope; both are rewritten in place when a
// ".." prefix is stripped. `descLocal` is a caller-supplied i32 local that
// receives the chosen descriptor handle. After this helper runs all three
// locals reflect the post-resolution state.
function emitResolvePreopenDesc(body ByteArray, pathBufLocal MachineWord, pathLenLocal MachineWord, descLocal MachineWord)
	// Populate the preopen cache and default descLocal to the cwd descriptor.
	emitEnsurePreopenDesc(body, descLocal: descLocal)

	// Only paths of length >= 2 can begin with "..".
	body.push(opLocalGet)
	writeUleb128(body, value: pathLenLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32GeU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// Check pathBuf[0] == '.'
	body.push(opLocalGet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// Check pathBuf[1] == '.'
	body.push(opLocalGet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 1)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// Re-root onto the parent preopen descriptor.
	body.push(opI32Const)
	writeSleb128(body, value: wasiPreopenParentDescBase as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: descLocal)
	// Advance pathBuf by 2 and shrink pathLen by 2 (the "..").
	body.push(opLocalGet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opLocalGet)
	writeUleb128(body, value: pathLenLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Sub)
	body.push(opLocalSet)
	writeUleb128(body, value: pathLenLocal)
	// If next byte is '/', consume it too.
	body.push(opLocalGet)
	writeUleb128(body, value: pathLenLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32GeU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2F)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: pathBufLocal)
	body.push(opLocalGet)
	writeUleb128(body, value: pathLenLocal)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Sub)
	body.push(opLocalSet)
	writeUleb128(body, value: pathLenLocal)
	body.push(opEnd)
	body.push(opEnd)
	body.push(opEnd)
	body.push(opEnd)
	body.push(opEnd)
end 'emitResolvePreopenDesc'

// Push `mm.buffer` (i32) onto the wasm stack. `mmLocal` holds the
// __ManagedMemory pointer as an i64. The buffer pointer lives at mm[0]
// as a stored i64 (qword across all targets, even though wasm32 only
// uses the low 32 bits). Reads `*(i64*)(mm)` and wraps to i32.
function emitMmBufferPtr(body ByteArray, mmLocal MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: mmLocal)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)
end 'emitMmBufferPtr'

// Push `mm.length` (i32 from a i64 length field) onto the wasm stack.
// `mmLocal` holds the __ManagedMemory pointer as an i64.
function emitMmLengthI32(body ByteArray, mmLocal MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: mmLocal)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 8)
	body.push(opI32WrapI64)
end 'emitMmLengthI32'

// Sync the sequential-I/O offset cache to `fdLocal` (an i64 descriptor handle)
// and push the current byte offset (i64) onto the stack for use as the
// descriptor.read/write `offset` argument. If the cache is empty or holds a
// different handle, reset the offset to 0 and adopt this handle. See the
// wasiFileCur* layout comment.
function emitFileSyncOffset(body ByteArray, fdLocal MachineWord)
	// reset = (wasiFileCurValid == 0) | (wasiFileCurHandle != fdLocal)
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurValid as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Eqz)  // (valid == 0)
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurHandle as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: fdLocal)
	body.push(opI64Ne)  // (cachedHandle != fd)
	body.push(opI32Or)
	body.push(opIf)
	body.push(0x40)
	// curHandle = fd ; curOffset = 0 ; valid = 1.
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurHandle as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: fdLocal)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)
	// curOffset = 0 (i64 store at the fixed 8-aligned offset-cache address).
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurOffset as ParsedInt)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurValid as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opEnd)
	// push current offset (i64).
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurOffset as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
end 'emitFileSyncOffset'

// Advance the cached sequential-I/O offset by the i32 byte count held in local
// `countLocal`. Call after a successful read/write. The address is pushed before
// the value so i64.store gets its (addr i32, value i64) operands in order.
function emitFileAdvanceOffset(body ByteArray, countLocal MachineWord)
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurOffset as ParsedInt)  // addr
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurOffset as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)  // curOffset (i64)
	body.push(opLocalGet)
	writeUleb128(body, value: countLocal)
	body.push(opI64ExtendI32U)  // (i64)count
	body.push(opI64Add)  // curOffset + count
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)
end 'emitFileAdvanceOffset'

// Invalidate the sequential-I/O offset cache (set wasiFileCurValid = 0).
//
// Preview2 recycles descriptor handle INDICES: when a descriptor is dropped,
// the host is free to hand the same integer index back to the next `open-at`.
// The offset cache keys on the handle value, so a freshly opened file that
// happens to reuse a just-closed handle index would otherwise inherit the old
// file's stale cursor (e.g. a write that advanced the cursor to 11 would make
// the next reader of the recycled handle start reading at offset 11, past the
// data, yielding 0 bytes). Invalidating on every open AND close forces the
// next read/write to reset the cursor to 0 for the (logically new) handle.
function emitInvalidateFileOffsetCache(body ByteArray)
	body.push(opI32Const)
	writeSleb128(body, value: wasiFileCurValid as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
end 'emitInvalidateFileOffsetCache'

// Helper: declare N i32 locals as a single group in the locals header.
// Returns the count written to the body.
function emitWasmLocalGroupI32(body ByteArray, count MachineWord)
	writeUleb128(body, value: 1)
	writeUleb128(body, value: count)
	body.push(wasmTypeI32)
end 'emitWasmLocalGroupI32'

// Helper: declare locals as two groups (i32 first, then i64) so a body
// that needs both types can lay them out in a known order. Indices
// counting from N (where N is the function's paramCount):
//   N .. N+i32Count-1  are i32
//   N+i32Count .. N+i32Count+i64Count-1  are i64
//
// Either count may be 0, but at least one must be nonzero — wasm
// requires `local_count >= 1` only if you emit a local group, and we
// always emit one group per nonzero count.
function emitWasmMixedLocals(body ByteArray, i32Count MachineWord, i64Count MachineWord)
	var groups = 0 as MachineWord
	if i32Count > 0 'hasI32'
		groups = groups + 1
	end 'hasI32'
	if i64Count > 0 'hasI64'
		groups = groups + 1
	end 'hasI64'
	writeUleb128(body, value: groups)
	if i32Count > 0 'writeI32'
		writeUleb128(body, value: i32Count)
		body.push(wasmTypeI32)
	end 'writeI32'
	if i64Count > 0 'writeI64'
		writeUleb128(body, value: i64Count)
		body.push(wasmTypeI64)
	end 'writeI64'
end 'emitWasmMixedLocals'

// mrt_file_open_read(__ManagedMemory path) throws -> __ManagedFile.
//
// Wasm body:
//   1. call descriptor.open-at(preopenDesc, path-flags=symlink-follow, mm.buffer,
//                     mm.length, open-flags=0 (read), %flags=read, ret-area)
//   2. on result disc != 0: errorReturn -1 with mapped flag (default openFailed=3).
//   3. on success: load the descriptor handle, store into __ManagedFile struct
//      (an 8-byte single-i64-field block returned by mrt_alloc); return ptr.
//
// `__ManagedFile` is a 1-field struct allocated like every other Maxon
// struct — by the caller (the lowering of `__ManagedFile.openRead`).
// Looking at the Windows body, mrt_file_open_read returns the HANDLE
// (or sentinel -1) directly as i64; the user-visible `__ManagedFile.handle`
// field reads that value via `loadIndirect`. So we follow the same
// convention here: return the i64 fd value, NOT a heap pointer.
function emitWasmFileOpenRead() returns ByteArray
	var body = ByteArray.create()
	// Local layout:
	//   local 0 = path (param, i64)
	//   local 1 = errCode scratch (i32)
	//   local 2 = pathBuf (i32)
	//   local 3 = pathLen (i32)
	//   local 4 = desc (i32 — base preopen descriptor)
	//   local 5 = flag (i64; 0 on success, mapped ordinal on failure)
	emitWasmMixedLocals(body, i32Count: 4, i64Count: 1)
	let localErrCode = 1
	let localPathBuf = 2
	let localPathLen = 3
	let localDesc = 4
	let localFlag = 5

	emitMmBufferPtr(body, mmLocal: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// Preview2: descriptor.open-at(self, path-flags=symlink-follow (1), pathBuf,
	// pathLen, open-flags=0, %flags=descriptor-flags::read (1), ret-area).
	// open-flags = 0 (no create/truncate); descriptor-flags read = bit 0 = 1.
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorOpenAt as Wasm32Index)

	// Map the result disc → flag (catchall = 3, openFailed wire value).
	// result<descriptor, error-code> has align 4 → error-code byte at +4.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 4, catchallFlag: 3)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// If flag == 0, return (i64(descriptor @ret+4), 0); else return (-1, flag).
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// A freshly opened file logically starts at offset 0 — invalidate the
	// shared offset cache so a recycled handle index can't inherit a stale
	// cursor from a previously-closed file.
	emitInvalidateFileOffsetCache(body)
	// Success: load the new descriptor handle from ret-area+4.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI64ExtendI32U)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)

	// Error path.
	body.push(opI64Const)
	writeSleb128(body, value: -1)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileOpenRead'

// mrt_file_open_write(__ManagedMemory path) throws -> __ManagedFile.
// Same as open_read but creating + truncating the file.
//
// Preview2 open-flags enum (vendor/wasi-wit/deps/filesystem/types.wit):
//   create   (bit 0) = 1
//   directory(bit 1) = 2
//   exclusive(bit 2) = 4
//   truncate (bit 3) = 8
// openWrite truncates on open (Windows CREATE_ALWAYS semantics), so
// open-flags = create (1) | truncate (8) = 9, and descriptor-flags =
// descriptor-flags::write (bit 1) = 2.
function emitWasmFileOpenWrite() returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 4, i64Count: 1)
	let localErrCode = 1
	let localPathBuf = 2
	let localPathLen = 3
	let localDesc = 4
	let localFlag = 5

	emitMmBufferPtr(body, mmLocal: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// descriptor.open-at(self, path-flags=symlink-follow (1), pathBuf, pathLen,
	//                    open-flags=create|truncate (9), %flags=write (2), ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 9)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorOpenAt as Wasm32Index)

	// result<descriptor, error-code> has align 4 → error-code byte at +4.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 4, catchallFlag: 3)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// A freshly opened (create|truncate) file logically starts at offset 0 —
	// invalidate the shared offset cache so a recycled handle index can't
	// inherit a stale cursor from a previously-closed file.
	emitInvalidateFileOffsetCache(body)
	// Success: load the new descriptor handle from ret-area+4.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI64ExtendI32U)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)

	// Error.
	body.push(opI64Const)
	writeSleb128(body, value: -1)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileOpenWrite'

// mrt_file_read(__ManagedFile self, __ManagedMemory managed, size n)
//   throws -> bytes read.
//
// `self` is the descriptor handle (i64) directly (NOT a struct pointer — see
// emitWasmFileOpenRead's comment). `managed` is an __ManagedMemory whose
// buffer should receive the data. `n` is the byte count to attempt.
//
// Calls descriptor.read(self, length=n, offset=<sequential cursor>, ret-area),
// copies the returned list bytes into mm.buffer, and returns the byte count
// (or 0 + the mapped error flag on failure).
function emitWasmFileRead() returns ByteArray
	var body = ByteArray.create()
	// Locals: 2 i32 scratch (errCode temp, byte count) + 1 i64 (flag).
	emitWasmMixedLocals(body, i32Count: 2, i64Count: 1)
	let localFd = 0
	let localMm = 1
	let localN = 2
	let localErrno = 3
	let localCount = 4
	let localFlag = 5

	// Preview2 descriptor.read(self, length i64, offset i64, retArea) ->
	// result<(list<u8>, bool eof), error-code>. self=localFd; length=localN;
	// offset from the sequential cache. Result in the return area: disc i32@+0
	// (0=ok); on ok the tuple is list(ptr i32@+4, len i32@+8) then bool@+12.
	body.push(opLocalGet)
	writeUleb128(body, value: localFd)  // self handle (i64 -> the import takes i32; wrap)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localN)  // length (i64)
	emitFileSyncOffset(body, fdLocal: localFd)  // pushes current offset (i64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorRead as Wasm32Index)

	// Map the result discriminant/error-code (catchall = readFailed wire 4).
	// result<(list<u8>, bool), error-code> has align 4 → error-code byte at +4.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrno, errOffset: 4, catchallFlag: 4)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// Default count = 0.
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localCount)

	// On success: copy the returned list bytes into mm.buffer, advance offset.
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// count = list len (i32 @ retArea+8).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localCount)
	// memory.copy(dst=mm.buffer, src=list ptr @+4, len=count).
	emitMmBufferPtr(body, mmLocal: localMm)  // dst
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)  // src
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)  // len
	body.push(0xFC)
	body.push(0x0A)
	body.push(0x00)
	body.push(0x00)  // memory.copy
	// advance the sequential offset by count.
	emitFileAdvanceOffset(body, countLocal: localCount)
	// return (count, 0).
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)
	body.push(opI64ExtendI32U)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)
	// Error: return (0, flag).
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileRead'

// mrt_file_write(__ManagedFile self, __ManagedMemory managed) throws -> bytes written.
function emitWasmFileWrite() returns ByteArray
	var body = ByteArray.create()
	// Locals: 2 i32 scratch (errCode temp, byte count) + 1 i64 (flag).
	emitWasmMixedLocals(body, i32Count: 2, i64Count: 1)
	let localFd = 0
	let localMm = 1
	let localErrno = 2
	let localCount = 3
	let localFlag = 4

	// count = mm.length (i32). Stash for the offset-advance + return value.
	emitMmLengthI32(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localCount)

	// Preview2 descriptor.write(self, buffer(ptr i32, len i32), offset i64, ret)
	// -> result<filesize, error-code>. self=localFd; buffer=mm.buffer + count;
	// offset from the sequential cache.
	body.push(opLocalGet)
	writeUleb128(body, value: localFd)
	body.push(opI32WrapI64)
	emitMmBufferPtr(body, mmLocal: localMm)  // buffer ptr
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)  // buffer len
	emitFileSyncOffset(body, fdLocal: localFd)  // offset (i64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorWrite as Wasm32Index)

	// Map the result discriminant (catchall = writeFailed wire 5).
	// result<filesize, error-code> has align 8 → error-code byte at +8.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrno, errOffset: 8, catchallFlag: 5)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// On success: advance offset by count, return (count, 0).
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitFileAdvanceOffset(body, countLocal: localCount)
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)
	body.push(opI64ExtendI32U)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)
	// Error: return (0, flag).
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileWrite'

// mrt_file_close(__ManagedFile self) -> 0. Non-throwing.
//
// Preview2: [resource-drop]descriptor(self) consumes (drops) the descriptor
// handle. The import has no result, so there is no errno to discard.
//
// Skip the 0 and -1 sentinels, mirroring the runtime.std mrt_file_close: an
// explicit `.close()` stores -1 back into the handle field, and the
// __ManagedFile destructor then re-invokes close on that same field. A failed
// open also leaves the -1 sentinel. Dropping a sentinel handle would trap
// ("unknown handle index 4294967295") since -1 wraps to the invalid i32
// 0xFFFFFFFF, so only drop a real (non-sentinel) handle.
function emitWasmFileClose() returns ByteArray
	var body = ByteArray.create()
	writeUleb128(body, value: 0)
	// if (self != 0 && self != -1) descriptor-drop((i32)self).
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opI64Eqz)
	body.push(opI32Eqz)  // (self != 0)
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: -1)
	body.push(opI64Ne)  // (self != -1)
	body.push(opI32And)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// descriptor-drop(handle) — releases the descriptor resource.
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorDrop as Wasm32Index)
	// The dropped handle's index may be recycled by the next open — drop its
	// cached cursor so a reopened file can't inherit this file's offset.
	emitInvalidateFileOffsetCache(body)
	body.push(opEnd)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmFileClose'

// mrt_file_exists(__ManagedMemory path) -> 1 if regular file exists else 0.
// Non-throwing.
//
// Preview2: descriptor.stat-at(self, path-flags=1 (symlink-follow), path(ptr,
// len), ret-area) writes result<descriptor-stat, error-code> to the return
// area. On err (disc != 0) the path doesn't exist → 0. On ok, descriptor-stat
// begins at ret-area+8 (the variant payload is 8-aligned, so it follows the
// i32 disc plus padding). Its first field `%type` (descriptor-type enum) is at
// +8; regular-file is ordinal 6 in types.wit. Return 1 iff type == 6.
function emitWasmFileExists() returns ByteArray
	var body = ByteArray.create()
	// Locals: 3 i32 (pathBuf, pathLen, desc).
	emitWasmLocalGroupI32(body, count: 3)
	let localMm = 0
	let localPathBuf = 1
	let localPathLen = 2
	let localDesc = 3

	emitMmBufferPtr(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// stat-at(desc, path-flags=1, path_ptr, path_len, ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorStatAt as Wasm32Index)

	// If disc != 0 (err), return 0. The result disc is a single byte at +0
	// (read as a byte so stale padding in the 8-aligned stat result can't
	// fold into the value and trip a false error).
	body.push(opBlock)
	body.push(wasmTypeI64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opBr)
	writeUleb128(body, value: 1)
	body.push(opEnd)
	// descriptor-stat.%type byte at ret-area+8; regular-file == ordinal 6.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 6)
	body.push(opI32Eq)
	body.push(opI64ExtendI32U)
	body.push(opEnd)
	body.push(opEnd)
	return body
end 'emitWasmFileExists'

// mrt_file_delete(__ManagedMemory path) throws -> 0.
//
// Preview2: descriptor.unlink-file-at(self, path(ptr,len), ret-area). The
// result<_, error-code> is written to the return area (disc i32 @+0,
// error-code i32 @+4); the call itself is void.
function emitWasmFileDelete() returns ByteArray
	var body = ByteArray.create()
	// Locals: 4 i32 (errCode, pathBuf, pathLen, desc) + 1 i64 (flag).
	emitWasmMixedLocals(body, i32Count: 4, i64Count: 1)
	let localMm = 0
	let localErrCode = 1
	let localPathBuf = 2
	let localPathLen = 3
	let localDesc = 4
	let localFlag = 5

	emitMmBufferPtr(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// unlink-file-at(desc, path_ptr, path_len, ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorUnlinkFileAt as Wasm32Index)

	// Load the result disc, then map error-code (catchall = deleteFailed wire 7).
	// result<_, error-code> has align 1 → error-code byte at +1.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 1, catchallFlag: 7)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// Return (0, flag).
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileDelete'

// mrt_file_stat(__ManagedMemory path) throws -> i64 buffer ptr (48 bytes).
//
// Preview2: descriptor.stat-at(self, path-flags=symlink-follow (1), path(ptr,
// len), ret-area) writes result<descriptor-stat, error-code>. The payload is
// 8-aligned, so descriptor-stat begins at ret-area+8 (after the i32 disc +
// padding). descriptor-stat field offsets within the payload (record fields,
// all 8-aligned because of the u64/datetime members):
//   %type                       (descriptor-type enum, u8) +0   -> ret+8
//   link-count                  (u64)                       +8   -> ret+16
//   size                        (filesize u64)              +16  -> ret+24
//   data-access-timestamp       (option<datetime>)          +24  -> ret+32
//   data-modification-timestamp (option<datetime>)          +48  -> ret+56
//   status-change-timestamp     (option<datetime>)          +72  -> ret+80
// An option<datetime> is { disc u8 @+0, datetime @+8 } and datetime is
// { seconds u64 @+0, nanoseconds u32 @+8 }, so each timestamp's seconds field
// is at optionOffset + 8: atime ret+40, mtime ret+64, ctime ret+88.
// Preview2 datetimes are already in SECONDS (unlike preview1's nanosecond
// fd_filestat), so no /1e9 division is needed.
//
// Maxon's 48-byte stat layout:
//   0:  size i64
//   8:  mtime i64 (seconds)
//   16: ctime i64
//   24: atime i64
//   32: isDirectory i64
//   40: isReadOnly i64
//
// We allocate a raw 48-byte buffer via mrt_alloc (kept reachable for stat-only
// programs — see the note below), call stat-at into the shared return area,
// then repack.
function emitWasmFileStat(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	// Local layout (param at local 0; explicit locals follow):
	//   local 0 = path (param i64)
	//   local 1 = errCode scratch (i32)
	//   local 2 = bufPtr (i32 — destination 48-byte buf)
	//   local 3 = pathBuf (i32)
	//   local 4 = pathLen (i32)
	//   local 5 = desc  (i32 — base preopen descriptor)
	//   local 6 = mm (i64)
	//   local 7 = flag (i64)
	emitWasmMixedLocals(body, i32Count: 5, i64Count: 2)
	let localPath = 0
	let localErrCode = 1
	let localBuf = 2
	let localPathBuf = 3
	let localPathLen = 4
	let localDesc = 5
	let localMm = 6
	let localFlag = 7

	emitMmBufferPtr(body, mmLocal: localPath)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localPath)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// stat-at(desc, path-flags=symlink-follow (1), pathBuf, pathLen, ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorStatAt as Wasm32Index)

	// Map the result disc → flag (catchall = statFailed wire 8).
	// result<descriptor-stat, error-code> has align 8 → error-code byte at +8.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 8, catchallFlag: 8)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// On error: return (0, flag).
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opReturn)
	body.push(opEnd)

	// Success path. Allocate a raw 48-byte buffer — the same representation as
	// the Linux runtime.std mrt_file_stat (mrt_file_stat_field reads it at
	// [buf+idx*8] and mrt_file_stat_free mm_decref's it). Using mrt_alloc here
	// rather than __managed_mem_create keeps the stat path from depending on a
	// function the MIR-level reachability never records: the runtime.std
	// mrt_file_stat body this replaces uses mrt_alloc, so __managed_mem_create
	// would be absent from the module for a stat-only program and trip
	// findFunctionIndex at emit time. (mrt_alloc is already pervasively
	// reachable, so it is always in the module.)
	body.push(opI64Const)
	writeSleb128(body, value: 48)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opLocalTee)
	writeUleb128(body, value: localMm)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localBuf)

	// buf[0]  = descriptor-stat.size (u64 @ ret+24).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 24) as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)

	// buf[8]  = mtime seconds (data-modification-timestamp.datetime.seconds @ ret+64).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 64) as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 8)

	// buf[16] = ctime seconds (status-change-timestamp.datetime.seconds @ ret+88).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 88) as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 16)

	// buf[24] = atime seconds (data-access-timestamp.datetime.seconds @ ret+40).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 40) as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 24)

	// buf[32] = (descriptor-type == directory (3)) ? 1 : 0  (isDirectory).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 3)
	body.push(opI32Eq)
	body.push(opI64ExtendI32U)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 32)

	// buf[40] = 0 (isReadOnly — WASI has no concept).
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 40)

	// Return (mm, 0). The function body ends here; the error path
	// already executed `return` so the validator doesn't need a
	// fall-through arm.
	body.push(opLocalGet)
	writeUleb128(body, value: localMm)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmFileStat'

// mrt_file_stat_field(buffer, idx) -> i64. Non-throwing.
// Just reads buffer[idx*8] as i64.
function emitWasmFileStatField() returns ByteArray
	var body = ByteArray.create()
	writeUleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: 1)
	body.push(opI32WrapI64)
	body.push(opI32Const)
	writeSleb128(body, value: 3)
	body.push(opI32Shl)
	body.push(opI32Add)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmFileStatField'

// mrt_file_stat_free(buffer) -> 0. Non-throwing. Decrefs the mm buffer.
function emitWasmFileStatFree(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	writeUleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: 0)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mm_decref", importCount: wasiImportCount))
	// mm_decref is void — no drop.
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmFileStatFree'

// mrt_file_size(__ManagedFile self) throws -> file size in bytes.
//
// Preview2: descriptor.stat(self, ret-area) writes result<descriptor-stat,
// error-code> to the return area. `self` is the descriptor handle (i64 widened
// from the i32 handle by openRead/openWrite). The descriptor-stat payload is
// 8-aligned and so begins at ret-area+8 (after the i32 disc + padding); within
// it `%type` is +0, `link-count` +8, `size` (filesize u64) +16. So `size` is at
// ret-area + 8 + 16 = ret-area + 24. This avoids perturbing the file position.
function emitWasmFileSize() returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 1, i64Count: 1)
	let localFd = 0
	let localErrCode = 1
	let localFlag = 2

	body.push(opLocalGet)
	writeUleb128(body, value: localFd)
	body.push(opI32WrapI64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorStat as Wasm32Index)

	// Map the result disc → flag (catchall = sizeFailed wire 6).
	// result<descriptor-stat, error-code> has align 8 → error-code byte at +8.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 8, catchallFlag: 6)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// Success: load descriptor-stat.size (u64) from ret-area+24.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 24) as ParsedInt)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)
	// Error.
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmFileSize'

// ----- Directory helpers -----

// Per-opened-directory state block. Preview2 is descriptor/resource based
// rather than buffer based: instead of a preview1 fd plus a manually-walked
// fd_readdir buffer, we hold two Preview2 resource handles — the directory
// `descriptor` (from descriptor.open-at) and the `directory-entry-stream`
// (from descriptor.read-directory). Both must be resource-dropped on close.
//
// The host owns the entry-name memory returned by read-directory-entry and
// may reuse it on the next call, so we eagerly copy each current entry's name
// into our own mm-allocated `nameBuf`; `filename()` then reads it from there.
//
// Block layout (still 48 bytes so the __ManagedDirectory single-field struct
// and any size assumptions elsewhere are unchanged):
//   [0..8]    dirDesc      (i64 — directory descriptor handle, own<descriptor>)
//   [8..16]   streamHandle (i64 — directory-entry-stream handle, own resource)
//   [16..24]  hasCurrent   (i64 — byte length of the current entry name; 0 = none/EOF)
//   [24..32]  nameBuf      (i64 — mm-allocated buffer holding the current name bytes)
//   [32..48]  reserved     (kept zero; preserves the 48-byte block size)
let wasmDirBlockSize = 48
let wasmDirBlockOffDirDesc = 0
let wasmDirBlockOffStream = 8
let wasmDirBlockOffHasCurrent = 16
let wasmDirBlockOffNameBuf = 24

// mrt_directory_open_search(__ManagedMemory path) throws -> __ManagedDirectory ptr.
//
// Preview2:
// 1. Normalize the Windows-style `<path>/*` pattern the stdlib builds down to
//    a bare directory path ("" → ".").
// 2. descriptor.open-at(preopenDesc, path-flags=symlink-follow (1), pathBuf,
//    pathLen, open-flags=directory (2), %flags=read (1), retArea) → the
//    directory `descriptor`. open-flags::directory makes this fail on a
//    non-directory, mirroring the old preview1 O_DIRECTORY.
// 3. descriptor.read-directory(dirDesc, retArea) → directory-entry-stream.
// 4. Allocate the 48-byte block, store dirDesc + streamHandle, zero hasCurrent
//    and nameBuf.
// 5. Self-call mrt_directory_next once so filename() returns the first real
//    entry before next() is called (FindFirstFileW-style contract).
// 6. Return the block pointer as the directory handle.
function emitWasmDirectoryOpenSearch(funcSigs WasmFuncSigs) returns ByteArray
	// `Directory.list` on every target expects the openSearch result to
	// already be positioned at the FIRST entry, with `filename()` returning
	// the name of that first entry before any call to `next()` (this matches
	// the Windows FindFirstFileW semantics from which the stdlib API was
	// derived). To preserve that contract on wasm we call mrt_directory_next
	// at the end of open, populating block.hasCurrent so filename() reads
	// the first non-dot entry. If the directory is empty (or only contains
	// '.' / '..'), next() returns 0 with hasCurrent=0; filename() then
	// returns an empty mm which the stdlib filters out.
	var body = ByteArray.create()
	// Locals (param at 0; explicit locals follow):
	//   local 0 = path (param i64)
	//   local 1 = errCode scratch (i32)
	//   local 2 = pathBuf  (i32 — wrapped mm.buffer pointer)
	//   local 3 = pathLen  (i32 — possibly stripped of trailing "/*")
	//   local 4 = desc     (i32 — preopen descriptor, then the dir descriptor)
	//   local 5 = block ptr (i64)
	//   local 6 = streamHandle (i64 — directory-entry-stream)
	//   local 7 = flag (i64)
	emitWasmMixedLocals(body, i32Count: 4, i64Count: 3)
	let localPath = 0
	let localErrCode = 1
	let localPathBuf = 2
	let localPathLen = 3
	let localDesc = 4
	let localBlock = 5
	let localStream = 6
	let localFlag = 7

	// Cache mm.buffer (i32) and mm.length (i32) in locals so we can
	// strip a trailing "/*" or "\*" pattern without disturbing the
	// original __ManagedMemory. The shared Directory.list helper builds
	// the pattern as `<path><sep>*` for compatibility with the Windows
	// FindFirstFile API; Preview2 open-at expects a bare directory
	// path, so we strip the last two bytes if the path ends in '*'.
	emitMmBufferPtr(body, mmLocal: localPath)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localPath)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// If pathLen >= 2 and pathBuf[pathLen-1] == '*', pathLen -= 2.
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32GeU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Add)
	body.push(opI32Const)
	writeSleb128(body, value: -1)
	body.push(opI32Add)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2A)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Sub)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)
	body.push(opEnd)
	body.push(opEnd)

	// Drop a trailing '/' from the (possibly-stripped) path so wasmtime
	// doesn't reject "./" or "foo/" with EINVAL. This is iterative
	// (one strip is enough — Directory.list always builds patterns with
	// at most one trailing separator before the '*').
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32GeU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Add)
	body.push(opI32Const)
	writeSleb128(body, value: -1)
	body.push(opI32Add)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2F)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Sub)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)
	body.push(opEnd)
	body.push(opEnd)

	// Special-case `.` or empty path: open-at with an empty path is rejected by
	// wasmtime, but the preopen descriptor itself IS the cwd. We rewrite a
	// length-0 path (after stripping `/*` and `/`) into ".". Write '.' into the
	// offset-0 scratch byte to avoid mutating the caller's __ManagedMemory.
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI32Const)
	writeSleb128(body, value: iovecBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Store8)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: iovecBase as ParsedInt)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)
	body.push(opEnd)

	// descriptor.open-at(preopenDesc, path-flags=symlink-follow (1), pathBuf,
	//                    pathLen, open-flags=directory (2), %flags=read (1),
	//                    retArea). open-flags::directory makes open fail on a
	//                    non-directory; %flags=read suffices to read entries.
	// Resolve "../" paths onto the parent preopen (after the pattern/separator
	// normalization above so the ".." check sees the final bare path).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorOpenAt as Wasm32Index)

	// Map the open result disc → flag (catchall = 3, openFailed wire value).
	// result<descriptor, error-code> has align 4 → error-code byte at +4.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 4, catchallFlag: 3)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// On open error: return (-1, flag).
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: -1)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opReturn)
	body.push(opEnd)

	// Stash the directory descriptor handle (ret-area+4 on ok) into localDesc;
	// it is consumed both by read-directory below and stored into the block.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localDesc)

	// descriptor.read-directory(dirDesc, retArea) → directory-entry-stream.
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorReadDirectory as Wasm32Index)

	// Map the read-directory result disc → flag (catchall = 3 as well).
	// result<directory-entry-stream, error-code> has align 4 → error-code byte at +4.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 4, catchallFlag: 3)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	// On read-directory error: drop the just-opened directory descriptor (no
	// block was allocated yet) and return (-1, flag).
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opI64Eqz)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorDrop as Wasm32Index)
	body.push(opI64Const)
	writeSleb128(body, value: -1)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opReturn)
	body.push(opEnd)

	// streamHandle = directory-entry-stream handle (ret-area+4 on ok).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI64ExtendI32U)
	body.push(opLocalSet)
	writeUleb128(body, value: localStream)

	// Allocate the state block (mrt_alloc zero-fills, so the reserved tail and
	// hasCurrent/nameBuf start at 0 — we still set them explicitly below).
	body.push(opI64Const)
	writeSleb128(body, value: wasmDirBlockSize as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opLocalSet)
	writeUleb128(body, value: localBlock)

	// block.dirDesc = dirDesc (i32 handle extended to i64).
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI64ExtendI32U)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffDirDesc as ParsedInt)

	// block.streamHandle = streamHandle.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localStream)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffStream as ParsedInt)

	// block.hasCurrent = 0
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffHasCurrent as ParsedInt)

	// block.nameBuf = 0 (no current entry name copied yet).
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffNameBuf as ParsedInt)

	// Eagerly advance to the first real entry so `filename()` works on the
	// very first call (matches the Windows FindFirstFile semantics the
	// stdlib's Directory.list helper assumes). Self-call to
	// mrt_directory_next; it returns (i64 found, i64 flag) — drop both since
	// the open itself succeeded and we don't propagate next()'s inner
	// failures from openSearch.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_directory_next", importCount: wasiImportCount))
	body.push(opDrop)
	body.push(opDrop)

	// Return (block, 0). The error paths already returned, so the body just
	// falls off the bottom with the success pair on the stack.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryOpenSearch'

// mrt_directory_create(__ManagedMemory path) throws -> 0.
//
// Preview2: descriptor.create-directory-at(self, path(ptr,len), ret-area). The
// result<_, error-code> is written to the return area (disc i32 @+0,
// error-code i32 @+4); the call itself is void.
function emitWasmDirectoryCreate() returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 4, i64Count: 1)
	let localMm = 0
	let localErrCode = 1
	let localPathBuf = 2
	let localPathLen = 3
	let localDesc = 4
	let localFlag = 5

	emitMmBufferPtr(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// create-directory-at(desc, path_ptr, path_len, ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorCreateDirectoryAt as Wasm32Index)

	// Load the result disc, then map error-code (catchall = createFailed wire 6).
	// result<_, error-code> has align 1 → error-code byte at +1.
	emitWasmMapWasiErrorCode(body, tempLocal: localErrCode, errOffset: 1, catchallFlag: 6)
	body.push(opLocalSet)
	writeUleb128(body, value: localFlag)

	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalGet)
	writeUleb128(body, value: localFlag)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryCreate'

// mrt_directory_current_path() throws -> __ManagedMemory of UTF-8 cwd.
//
// WASI doesn't actually expose a `getcwd` equivalent — preview1 has no
// such call. The convention under wasmtime is that the current working
// directory IS the preopen mapped to fd 3 (typically `.`). We return
// the literal string ".".
function emitWasmDirectoryCurrentPath(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	// Locals: 1 i64 (mm result) + 1 i32 (scratch ptr).
	writeUleb128(body, value: 2)
	writeUleb128(body, value: 1)
	body.push(wasmTypeI64)
	writeUleb128(body, value: 1)
	body.push(wasmTypeI32)
	let localMm = 0
	let localBuf = 1

	// Allocate __ManagedMemory(count=1, elemSize=1) — 1 byte for ".".
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "__managed_mem_create", importCount: wasiImportCount))
	body.push(opLocalTee)
	writeUleb128(body, value: localMm)

	// Load mm.buffer (qword at mm[0], wrap to i32 for wasm32).
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localBuf)

	// Write '.' (0x2E) at buf[0].
	body.push(opLocalGet)
	writeUleb128(body, value: localBuf)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Store8)
	body.push(0x00)
	writeUleb128(body, value: 0)

	// mm.length = 1.
	body.push(opLocalGet)
	writeUleb128(body, value: localMm)
	body.push(opI32WrapI64)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 8)

	// Return (mm, 0).
	body.push(opLocalGet)
	writeUleb128(body, value: localMm)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryCurrentPath'

// mrt_directory_next(__ManagedDirectory self) throws -> 1 if entry, 0 if end.
//
// Preview2: pull the next entry from the block's directory-entry-stream via
// [method]directory-entry-stream.read-directory-entry(streamHandle, retArea)
// → result<option<directory-entry>, error-code>. We loop, skipping the `.`
// and `..` pseudo-entries (Preview2 hosts already omit them, but we filter
// for parity with the other targets), until a real entry is found or the
// stream is exhausted.
//
// retArea layout for result<option<directory-entry>, error-code>
// (canonical-ABI memory lowering; option<directory-entry> has alignment 4
// because of the `name: string` ptr/len, so the result payload sits at +4):
//   +0  result disc i32   (0 = ok, else err → treated as EOF)
//   +4  option flag i32   (0 = none → EOF, 1 = some)
//   +8  entry.%type u8     (descriptor-type; unused here)
//   +12 entry.name.ptr i32 (into host-owned memory, valid only until the
//                           next read-directory-entry call)
//   +16 entry.name.len i32
//
// The host name memory is ephemeral, so on a real entry we copy the name
// bytes into a fresh mm-allocated buffer stored in block.nameBuf; filename()
// reads from there. We decref any previously-stored nameBuf first so repeated
// next() calls don't leak.
function emitWasmDirectoryNext(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	// Locals (param at 0; explicit locals follow). The function is structured
	// as a flat loop with a single `result` local; after the loop ends we push
	// (result, 0) for the throwing-function ABI.
	//   local 0 = block (param i64)
	//   local 1 = blockI32 (i32)
	//   local 2 = streamHandle (i32)
	//   local 3 = namePtr (i32 — host name buffer ptr, ephemeral)
	//   local 4 = name0   (i32 — first name byte, dot filter)
	//   local 5 = name1   (i32 — second name byte, dot filter)
	//   local 6 = newBuf  (i64 — freshly allocated mm name buffer)
	//   local 7 = nameLen (i64)
	//   local 8 = result  (i64; final value: 0 EOF or 1 found-entry)
	emitWasmMixedLocals(body, i32Count: 5, i64Count: 3)
	let localBlock = 0
	let localBlockI32 = 1
	let localStream = 2
	let localNamePtr = 3
	let localName0 = 4
	let localName1 = 5
	let localNewBuf = 6
	let localNameLen = 7
	let localResult = 8

	// blockI32 = (i32)block
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlockI32)

	// streamHandle = (i32) block.streamHandle
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffStream as ParsedInt)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localStream)

	// result = 0 (EOF as default; overwritten if we find a real entry).
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localResult)

	// Outer block (exit target — break here once we've decided EOF or
	// real-entry-found).
	body.push(opBlock)
	body.push(wasmTypeVoid)

	// Inner loop — each iteration pulls at most one entry. `br 0` repeats the
	// loop (skip a dot entry); `br 1` exits the outer block.
	body.push(opLoop)
	body.push(wasmTypeVoid)

	// read-directory-entry(streamHandle, retArea).
	body.push(opLocalGet)
	writeUleb128(body, value: localStream)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiReadDirectoryEntry as Wasm32Index)

	// If result disc (@+0) != 0 (err), treat as EOF: break with result = 0.
	// The result of read-directory-entry is `result<option<directory-entry>,
	// error-code>` (align 4): disc byte @+0, option-present byte @+4,
	// directory-entry.type @+8, name.ptr @+12, name.len @+16. The disc and
	// option-present flags are single bytes; read them as bytes so stale
	// padding in the 3 bytes following each can't fold in and misfire.
	// Levels: 0 = this `if`, 1 = the loop, 2 = the outer block.
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opBr)
	writeUleb128(body, value: 2)
	body.push(opEnd)

	// If option flag (@+4) == 0 (none), the stream is exhausted: break EOF.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opBr)
	writeUleb128(body, value: 2)
	body.push(opEnd)

	// Present entry. nameLen = entry.name.len (@+16); namePtr = name.ptr (@+12).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 16) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI64ExtendI32U)
	body.push(opLocalSet)
	writeUleb128(body, value: localNameLen)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 12) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localNamePtr)

	// Read the first two name bytes for the dot-filter. These reads are only
	// performed after the nameLen guards below, so we load them lazily inside
	// each guard to avoid OOB reads on short host buffers. name0 = namePtr[0].
	body.push(opLocalGet)
	writeUleb128(body, value: localNamePtr)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localName0)

	// Skip '.' (nameLen == 1 && name0 == '.'): continue the loop (br 1).
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opI64Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localName0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Eq)
	body.push(opBrIf)
	writeUleb128(body, value: 1)
	body.push(opEnd)

	// Skip '..' (nameLen == 2 && name0 == '.' && name1 == '.'): continue.
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI64Const)
	writeSleb128(body, value: 2)
	body.push(opI64Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localNamePtr)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 1)
	body.push(opLocalSet)
	writeUleb128(body, value: localName1)
	body.push(opLocalGet)
	writeUleb128(body, value: localName0)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localName1)
	body.push(opI32Const)
	writeSleb128(body, value: 0x2E)
	body.push(opI32Eq)
	body.push(opBrIf)
	writeUleb128(body, value: 2)
	body.push(opEnd)
	body.push(opEnd)

	// Real entry. Free the previously-copied name buffer (if any) so repeated
	// next() calls don't leak, then copy this entry's name into a fresh one.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffNameBuf as ParsedInt)
	body.push(opLocalTee)
	writeUleb128(body, value: localNewBuf)
	body.push(opI64Eqz)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localNewBuf)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mm_decref", importCount: wasiImportCount))
	body.push(opEnd)

	// newBuf = mrt_alloc(nameLen).
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opLocalSet)
	writeUleb128(body, value: localNewBuf)

	// memory.copy(dst = newBuf, src = namePtr, len = nameLen).
	body.push(opLocalGet)
	writeUleb128(body, value: localNewBuf)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localNamePtr)
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI32WrapI64)
	body.push(0xFC)
	writeUleb128(body, value: 10)
	body.push(0x00)
	body.push(0x00)

	// block.nameBuf = newBuf.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opLocalGet)
	writeUleb128(body, value: localNewBuf)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffNameBuf as ParsedInt)

	// block.hasCurrent = nameLen (filename() reads this many bytes from nameBuf).
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffHasCurrent as ParsedInt)

	// result = 1, then break out of the loop (br 1 to the outer block).
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opLocalSet)
	writeUleb128(body, value: localResult)
	body.push(opBr)
	writeUleb128(body, value: 1)

	body.push(opEnd)
	body.push(opEnd)

	// Push (result, 0 flag) as the function return.
	body.push(opLocalGet)
	writeUleb128(body, value: localResult)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryNext'

// mrt_directory_filename(__ManagedDirectory self) -> __ManagedMemory.
//
// Reads the current entry's name (after a successful `next`). The invariant
// set by mrt_directory_next: block.hasCurrent holds the nameLen of the current
// entry, and block.nameBuf points at an mm-allocated buffer holding exactly
// those `nameLen` name bytes (a persistent copy of the host-owned name, which
// the read-directory-entry call only kept valid until its next invocation).
function emitWasmDirectoryFilename(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	// Locals: 2 i64 (mm, namelen) + 3 i32 (blockI32, srcBuf, mmBuf).
	writeUleb128(body, value: 2)
	writeUleb128(body, value: 2)
	body.push(wasmTypeI64)
	writeUleb128(body, value: 3)
	body.push(wasmTypeI32)
	let localBlock = 0
	let localMm = 1
	let localNameLen = 2
	let localBlockI32 = 3
	let localSrcBuf = 4
	let localMmBuf = 5

	// blockI32 = (i32)block
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlockI32)

	// nameLen = block.hasCurrent
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffHasCurrent as ParsedInt)
	body.push(opLocalSet)
	writeUleb128(body, value: localNameLen)

	// srcBuf = block.nameBuf (i32 — persistent name copy from next()).
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffNameBuf as ParsedInt)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localSrcBuf)

	// mm = __managed_mem_create(nameLen, 1).
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI64Const)
	writeSleb128(body, value: 1)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "__managed_mem_create", importCount: wasiImportCount))
	body.push(opLocalTee)
	writeUleb128(body, value: localMm)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localMmBuf)

	// memory.copy(mmBuf, srcBuf, nameLen).
	body.push(opLocalGet)
	writeUleb128(body, value: localMmBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localSrcBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI32WrapI64)
	body.push(0xFC)
	writeUleb128(body, value: 10)
	body.push(0x00)
	body.push(0x00)

	// mm.length = nameLen (already set by __managed_mem_create with count=nameLen,
	// elemSize=1: count*elemSize = nameLen. Need to set length field too.)
	body.push(opLocalGet)
	writeUleb128(body, value: localMm)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localNameLen)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 8)

	body.push(opLocalGet)
	writeUleb128(body, value: localMm)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryFilename'

// mrt_directory_close(__ManagedDirectory self) -> 0.
//
// Preview2: resource-drop the directory-entry-stream and the directory
// descriptor (both no-result imports), then decref the persistent name buffer
// (if one was copied) and the state block.
function emitWasmDirectoryClose(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	// Locals: 1 i32 (blockI32) + 1 i64 (nameBuf scratch — holds the i64 handle).
	emitWasmMixedLocals(body, i32Count: 1, i64Count: 1)
	let localBlock = 0
	let localBlockI32 = 1
	let localNameBuf = 2

	// If self == 0 return 0.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)

	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI32WrapI64)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlockI32)

	// [resource-drop]directory-entry-stream(block.streamHandle). No result.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffStream as ParsedInt)
	body.push(opI32WrapI64)
	body.push(opCall)
	writeUleb128(body, value: wasiDirEntryStreamDrop as Wasm32Index)

	// [resource-drop]descriptor(block.dirDesc). No result.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffDirDesc as ParsedInt)
	body.push(opI32WrapI64)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorDrop as Wasm32Index)

	// mm_decref(block.nameBuf) if a name was copied (nameBuf != 0). Void return.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlockI32)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: wasmDirBlockOffNameBuf as ParsedInt)
	body.push(opLocalTee)
	writeUleb128(body, value: localNameBuf)
	body.push(opI64Eqz)
	body.push(opI32Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opLocalGet)
	writeUleb128(body, value: localNameBuf)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mm_decref", importCount: wasiImportCount))
	body.push(opEnd)

	// mm_decref(block itself). Void return; no drop.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mm_decref", importCount: wasiImportCount))

	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryClose'

// mrt_directory_exists(__ManagedMemory path) -> 1 if path is a directory else 0.
// Non-throwing.
//
// Preview2: descriptor.stat-at(preopenDesc, path-flags=symlink-follow (1),
// path(ptr,len), ret-area) writes result<descriptor-stat, error-code>. On err
// (disc != 0) the path doesn't exist → 0. On ok, descriptor-stat begins at
// ret-area+8 (the variant payload is 8-aligned, after the i32 disc plus pad).
// Its first field `%type` (descriptor-type enum) is at +8; directory is
// ordinal 3 in types.wit. Return 1 iff type == 3. Mirrors emitWasmFileExists.
function emitWasmDirectoryExists() returns ByteArray
	var body = ByteArray.create()
	// Locals: 3 i32 (pathBuf, pathLen, desc).
	emitWasmLocalGroupI32(body, count: 3)
	let localMm = 0
	let localPathBuf = 1
	let localPathLen = 2
	let localDesc = 3

	emitMmBufferPtr(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathBuf)
	emitMmLengthI32(body, mmLocal: localMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localPathLen)

	// stat-at(desc, path-flags=1, path_ptr, path_len, ret-area).
	emitResolvePreopenDesc(body, pathBufLocal: localPathBuf, pathLenLocal: localPathLen, descLocal: localDesc)
	body.push(opLocalGet)
	writeUleb128(body, value: localDesc)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localPathLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiDescriptorStatAt as Wasm32Index)

	// If disc != 0 (err), return 0. The result disc is a single byte at +0
	// (read as a byte so stale padding in the 8-aligned stat result can't
	// fold into the value and trip a false error).
	body.push(opBlock)
	body.push(wasmTypeI64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opBr)
	writeUleb128(body, value: 1)
	body.push(opEnd)
	// descriptor-stat.%type byte at ret-area+8; directory == ordinal 3.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 3)
	body.push(opI32Eq)
	body.push(opI64ExtendI32U)
	body.push(opEnd)
	body.push(opEnd)
	return body
end 'emitWasmDirectoryExists'

// ============================================================
// wasi:sockets networking helpers (Project 2)
//
// `__ManagedSocket` is a single-i64-handle struct (`_handle`@0). On native
// targets `_handle` holds the OS socket directly; wasi:sockets needs FOUR
// resource handles per live connection (network, tcp-socket, input-stream,
// output-stream), so on wasm `_handle` instead points at a separately-allocated
// 40-byte handle block (5 i64 slots) carved by `mrt_alloc`:
//   block+0  = network handle   (i32 zero-extended to i64)
//   block+8  = tcp-socket handle (i32 zero-extended)
//   block+16 = input-stream handle (i32 zero-extended)
//   block+24 = output-stream handle (i32 zero-extended)
//   block+32 = reserved (alignment / future use)
//
// The `__ManagedSocket` wrapper itself is an 8-byte `mrt_alloc` block holding
// the handle-block pointer at offset 0. `__ManagedSocket` is NOT drop-tracked
// (see `maxonTypeIsDropTrackedRec`), so no destructor runs on scope exit — the
// user frees by calling `.close()`, which drops the four wasi resources and
// `mm_decref`s both the handle block and (left to scope) the wrapper. `mrt_alloc`
// (a thin `mm_alloc(size,0,0)` wrapper) is pervasively reachable, so the
// reachability closure always keeps it without needing a stub-body funcAddr seed.
//
// errorReturn ABI: every helper that `throws` returns TWO i64 values
// (resultValue, errorFlag); flag 0 = success. __ManagedSocketError flag values
// (ordinal + 1): bufferOutOfBounds=1, resolveFailed=2, connectFailed=3,
// sendFailed=4, recvFailed=5. The non-throwing `close` returns a single i64 (0).
// ============================================================

// __ManagedSocket handle-block field offsets (within the mrt_alloc(40) block).
let wasmSockBlockOffNetwork = 0
let wasmSockBlockOffSocket = 8
let wasmSockBlockOffInStream = 16
let wasmSockBlockOffOutStream = 24
let wasmSockHandleBlockSize = 40

// __ManagedSocketError errorReturn flag values (ordinal + 1).
let wasmSockFlagBufferOutOfBounds = 1
let wasmSockFlagResolveFailed = 2
let wasmSockFlagConnectFailed = 3
let wasmSockFlagSendFailed = 4
let wasmSockFlagRecvFailed = 5

// wasi:sockets/network error-code ordinal for `would-block` — the result a
// not-yet-ready async resolve / connect surfaces. We spin on it rather than
// treating it as a terminal error.
let wasmWasiErrWouldBlock = 8

// Emit a two-i64 error return `(0, flag)` followed by `opReturn`. Used on every
// throwing-helper failure path. The wasm `return` pops both i64s as the
// function's multi-value result.
// Drop the WASI resource handle held in i32 local `handleLocal` via `dropImport`
// (a `[resource-drop]` import index). Used on the connect error paths to release
// handles that haven't been stored into the persistent __ManagedSocket block yet
// (the block + close() own them only on the success path).
function emitWasmSockDropLocal(body ByteArray, handleLocal MachineWord, dropImport MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: handleLocal)
	body.push(opCall)
	writeUleb128(body, value: dropImport as Wasm32Index)
end 'emitWasmSockDropLocal'

// Release the live WASI resources on a connect error path, then errorReturn.
// `dropNet`/`dropResStream`/`dropSock` say which of the network/resolve-stream/
// tcp-socket handles (locals 4/5/6 in emitWasmSocketTcpConnect) are live at this
// exit — only those are dropped so we never drop an unacquired handle. This
// keeps a failed connect from leaking host resource-table entries (a success
// stores the handles in the block and close() drops them instead).
function emitWasmSockConnectFail(body ByteArray, flag MachineWord, dropNet bool, dropResStream bool, dropSock bool)
	if dropResStream 'rs'
		emitWasmSockDropLocal(body, handleLocal: 5, dropImport: wasiResolveStreamDrop)
	end 'rs'
	if dropSock 'sk'
		emitWasmSockDropLocal(body, handleLocal: 6, dropImport: wasiTcpSocketDrop)
	end 'sk'
	if dropNet 'nt'
		emitWasmSockDropLocal(body, handleLocal: 4, dropImport: wasiNetworkDrop)
	end 'nt'
	emitWasmSockErrorReturn(body, flag: flag)
end 'emitWasmSockConnectFail'

function emitWasmSockErrorReturn(body ByteArray, flag MachineWord)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: flag as ParsedInt)
	body.push(opReturn)
end 'emitWasmSockErrorReturn'

// mrt_managed_socket_tcp_connect(host_mm i64, port i64) throws -> i64 (ptr to a
// fresh __ManagedSocket). Resolves the host, creates an ipv4 tcp-socket, and
// connects, returning (wrapperPtr, 0) on success or (0, flag) on failure.
//
// Locals (params 0,1 are host_mm, port):
//   2  (i32) hostBuf ptr      3 (i32) hostLen
//   4  (i32) network handle   5 (i32) resolveStream handle
//   6  (i32) tcpSocket handle 7 (i32) octet0  8 octet1  9 octet2  10 octet3
//   11 (i32) sockPoll handle  12 (i32) timerPoll handle  13 (i32) retry counter
//   14 (i32) inStream handle  15 (i32) outStream handle
//   16 (i64) blockPtr         17 (i64) wrapperPtr
function emitWasmSocketTcpConnect(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 14, i64Count: 2)
	let localHostMm = 0
	let localHostBuf = 2
	let localHostLen = 3
	let localNet = 4
	let localResStream = 5
	let localSock = 6
	let localOct0 = 7
	let localOct1 = 8
	let localOct2 = 9
	let localOct3 = 10
	let localSockPoll = 11
	let localTimerPoll = 12
	let localRetry = 13
	let localInStream = 14
	let localOutStream = 15
	let localBlock = 16
	let localWrapper = 17

	// hostBuf = host_mm.buffer; hostLen = host_mm.length.
	emitMmBufferPtr(body, mmLocal: localHostMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localHostBuf)
	emitMmLengthI32(body, mmLocal: localHostMm)
	body.push(opLocalSet)
	writeUleb128(body, value: localHostLen)

	// net = instance-network() -> network handle (direct i32 return).
	body.push(opCall)
	writeUleb128(body, value: wasiInstanceNetwork as Wasm32Index)
	body.push(opLocalSet)
	writeUleb128(body, value: localNet)

	// resolve-addresses(net, hostBuf, hostLen, retArea). result<resolve-address-
	// stream, error-code>: disc byte @+0, stream handle @+4 (align 4).
	body.push(opLocalGet)
	writeUleb128(body, value: localNet)
	body.push(opLocalGet)
	writeUleb128(body, value: localHostBuf)
	body.push(opLocalGet)
	writeUleb128(body, value: localHostLen)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiResolveAddresses as Wasm32Index)
	// disc != 0 → resolveFailed.
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockConnectFail(body, flag: wasmSockFlagResolveFailed, dropNet: true, dropResStream: false, dropSock: false)
	body.push(opEnd)
	// resStream = stream handle @ retArea+4.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localResStream)

	// Busy-spin resolve-next-address until it returns a real result. The resolver
	// is async: until ready it returns error-code would-block (8); we re-poll
	// rather than blocking (a bare block would need the resolve stream's pollable,
	// an extra import). On a real terminal error (e.g. name-unresolvable) or `none`
	// we map to resolveFailed; on `some(ipv4)` we read the octets. result<option<
	// ip-address>,error-code> (align 2): result-disc byte @+0; on ok option-present
	// byte @+2 (0=none); ip-address variant-disc byte @+4 (0=ipv4); ipv4 octet
	// bytes @+6..+9. On err the error-code byte sits at @+2. (Offsets verified
	// empirically against wasmtime's canonical-ABI lowering.) The retry cap is a
	// safety valve; in practice the resolver settles in well under a thousand
	// iterations for a literal IP and tens of thousands for a failing DNS lookup.
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localRetry)
	body.push(opBlock)
	body.push(wasmTypeVoid)  // $resolveDone (br 1 from inside the loop)
	body.push(opLoop)
	body.push(wasmTypeVoid)  // $resolveRetry (br 0 continues)
	// resolve-next-address(resStream, retArea).
	body.push(opLocalGet)
	writeUleb128(body, value: localResStream)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiResolveNextAddress as Wasm32Index)
	// disc = result-disc byte @+0.
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Eqz)
	body.push(opBrIf)
	writeUleb128(body, value: 1)  // disc == 0 (ok) → break to $resolveDone
	// err: if error-code byte @+2 != would-block, it is terminal → resolveFailed.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 2) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: wasmWasiErrWouldBlock as ParsedInt)
	body.push(opI32Ne)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockConnectFail(body, flag: wasmSockFlagResolveFailed, dropNet: true, dropResStream: true, dropSock: false)
	body.push(opEnd)
	// would-block: bump retry, bail out to resolveFailed if the cap is exceeded.
	body.push(opLocalGet)
	writeUleb128(body, value: localRetry)
	body.push(opI32Const)
	writeSleb128(body, value: 1)
	body.push(opI32Add)
	body.push(opLocalTee)
	writeUleb128(body, value: localRetry)
	body.push(opI32Const)
	writeSleb128(body, value: 100000000)
	body.push(opI32GtU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockConnectFail(body, flag: wasmSockFlagResolveFailed, dropNet: true, dropResStream: true, dropSock: false)
	body.push(opEnd)
	body.push(opBr)
	writeUleb128(body, value: 0)  // continue $resolveRetry
	body.push(opEnd)  // end $resolveRetry loop
	body.push(opEnd)  // end $resolveDone block

	// ok result: require option-present (byte @+2 != 0) and ipv4 variant (byte
	// @+4 == 0). Anything else (none, or ipv6) → resolveFailed.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 2) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Eqz)  // present == 0 (none)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockConnectFail(body, flag: wasmSockFlagResolveFailed, dropNet: true, dropResStream: true, dropSock: false)
	body.push(opEnd)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)  // variant-disc != 0 (not ipv4)
	body.push(wasmTypeVoid)
	emitWasmSockConnectFail(body, flag: wasmSockFlagResolveFailed, dropNet: true, dropResStream: true, dropSock: false)
	body.push(opEnd)
	// Read the four ipv4 octets at retArea+6..+9 into locals (they must survive
	// the create-tcp-socket / start-connect calls that reuse the return area).
	emitWasmSockLoadOctet(body, dstLocal: localOct0, byteOffset: wasiSockRetAreaBase + 6)
	emitWasmSockLoadOctet(body, dstLocal: localOct1, byteOffset: wasiSockRetAreaBase + 7)
	emitWasmSockLoadOctet(body, dstLocal: localOct2, byteOffset: wasiSockRetAreaBase + 8)
	emitWasmSockLoadOctet(body, dstLocal: localOct3, byteOffset: wasiSockRetAreaBase + 9)
	// Drop the resolve-address-stream resource now that the address is captured.
	body.push(opLocalGet)
	writeUleb128(body, value: localResStream)
	body.push(opCall)
	writeUleb128(body, value: wasiResolveStreamDrop as Wasm32Index)

	// sock = create-tcp-socket(family=0 ipv4, retArea). result<tcp-socket,error-
	// code> (align 4): disc byte @+0, socket handle @+4.
	body.push(opI32Const)
	writeSleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiCreateTcpSocket as Wasm32Index)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// create-tcp-socket failed: only the network handle is live here (the resolve
	// stream was dropped above; no socket exists yet).
	emitWasmSockConnectFail(body, flag: wasmSockFlagConnectFailed, dropNet: true, dropResStream: false, dropSock: false)
	body.push(opEnd)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localSock)

	// start-connect(sock, net, ip-socket-address..., retArea). The ip-socket-
	// address variant is flattened to 11 i32 payload slots (sized for the larger
	// ipv6 arm): disc(1), then [port, octet0..3, 6×pad]. wasi:sockets takes the
	// port in HOST byte order (NOT network order), so the i64 port is wrapped to
	// i32 and passed directly. Core sig (15 i32): sock, net, disc, port, o0..o3,
	// pad×6, retArea. result<_,error-code>: disc byte @+0.
	body.push(opLocalGet)
	writeUleb128(body, value: localSock)
	body.push(opLocalGet)
	writeUleb128(body, value: localNet)
	body.push(opI32Const)
	writeSleb128(body, value: 0)  // variant disc = ipv4
	body.push(opLocalGet)
	writeUleb128(body, value: 1)  // port (param 1, i64)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localOct0)
	body.push(opLocalGet)
	writeUleb128(body, value: localOct1)
	body.push(opLocalGet)
	writeUleb128(body, value: localOct2)
	body.push(opLocalGet)
	writeUleb128(body, value: localOct3)
	for _ in 0 upto 6 'pad'
		body.push(opI32Const)
		writeSleb128(body, value: 0)
	end 'pad'
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiTcpStartConnect as Wasm32Index)
	// disc != 0 → connectFailed. The socket leaks here (no .close() owner yet);
	// acceptable for the error path, which the spec exercises with an immediate
	// resolve/connect failure and no successful handle to track.
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// start-connect failed: network + tcp-socket are both live.
	emitWasmSockConnectFail(body, flag: wasmSockFlagConnectFailed, dropNet: true, dropResStream: false, dropSock: true)
	body.push(opEnd)

	// Wait for connect completion, bounded by a timer so an unroutable peer (e.g.
	// TEST-NET-1 192.0.2.1) does not stall for the multi-second OS connect timeout.
	// sockPoll = tcp-socket.subscribe(sock); timerPoll = monotonic-clock.
	// subscribe-duration(2s). poll([sockPoll, timerPoll]) blocks until EITHER is
	// ready; then finish-connect reports success or the connect error.
	body.push(opLocalGet)
	writeUleb128(body, value: localSock)
	body.push(opCall)
	writeUleb128(body, value: wasiTcpSubscribe as Wasm32Index)
	body.push(opLocalSet)
	writeUleb128(body, value: localSockPoll)
	body.push(opI64Const)
	writeSleb128(body, value: 2000000000)  // 2s in nanoseconds
	body.push(opCall)
	writeUleb128(body, value: wasiMonotonicSubscribeDuration as Wasm32Index)
	body.push(opLocalSet)
	writeUleb128(body, value: localTimerPoll)
	// poll-list buffer = [sockPoll, timerPoll].
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockPollListBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: localSockPoll)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockPollListBase as ParsedInt)
	body.push(opLocalGet)
	writeUleb128(body, value: localTimerPoll)
	body.push(opI32Store)
	body.push(0x02)
	writeUleb128(body, value: 4)
	// poll(listPtr, listLen=2, retArea).
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockPollListBase as ParsedInt)
	body.push(opI32Const)
	writeSleb128(body, value: 2)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockPollRetBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiPoll as Wasm32Index)
	// Drop both pollables (the poll result list ptr is owned by the canonical-ABI
	// allocator and not freed here; it is process-lived scratch, matching the
	// emitOsWrite stdout-handle-leak convention).
	body.push(opLocalGet)
	writeUleb128(body, value: localSockPoll)
	body.push(opCall)
	writeUleb128(body, value: wasiPollableDrop as Wasm32Index)
	body.push(opLocalGet)
	writeUleb128(body, value: localTimerPoll)
	body.push(opCall)
	writeUleb128(body, value: wasiPollableDrop as Wasm32Index)

	// finish-connect(sock, retArea). result<tuple<input-stream,output-stream>,
	// error-code> (align 4): disc byte @+0; on ok inStream @+4, outStream @+8.
	// disc != 0 (error, including the timer-bounded would-block) → connectFailed.
	body.push(opLocalGet)
	writeUleb128(body, value: localSock)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiTcpFinishConnect as Wasm32Index)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// finish-connect failed: network + tcp-socket are both live.
	emitWasmSockConnectFail(body, flag: wasmSockFlagConnectFailed, dropNet: true, dropResStream: false, dropSock: true)
	body.push(opEnd)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localInStream)
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localOutStream)

	// Success: alloc the 40-byte handle block, store the four wasi handles
	// (zero-extended), alloc the 8-byte __ManagedSocket wrapper, store the block
	// pointer at wrapper+0, and return (wrapperPtr, 0).
	body.push(opI64Const)
	writeSleb128(body, value: wasmSockHandleBlockSize as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opLocalSet)
	writeUleb128(body, value: localBlock)
	emitWasmSockStoreHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffNetwork, handleLocal: localNet)
	emitWasmSockStoreHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffSocket, handleLocal: localSock)
	emitWasmSockStoreHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffInStream, handleLocal: localInStream)
	emitWasmSockStoreHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffOutStream, handleLocal: localOutStream)
	body.push(opI64Const)
	writeSleb128(body, value: 8)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mrt_alloc", importCount: wasiImportCount))
	body.push(opLocalTee)
	writeUleb128(body, value: localWrapper)
	// wrapper._handle = blockPtr  (i64 store at [wrapper+0]).
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)
	// return (wrapperPtr, 0).
	body.push(opLocalGet)
	writeUleb128(body, value: localWrapper)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmSocketTcpConnect'

// Load a single ipv4 octet byte at `byteOffset` (zero-extended i32) into a local.
function emitWasmSockLoadOctet(body ByteArray, dstLocal MachineWord, byteOffset MachineWord)
	body.push(opI32Const)
	writeSleb128(body, value: byteOffset as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: dstLocal)
end 'emitWasmSockLoadOctet'

// Store an i32 wasi resource handle (from `handleLocal`) zero-extended into the
// i64 slot at `block + fieldOffset`.
function emitWasmSockStoreHandle(body ByteArray, blockLocal MachineWord, fieldOffset MachineWord, handleLocal MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: blockLocal)
	body.push(opI32WrapI64)
	body.push(opLocalGet)
	writeUleb128(body, value: handleLocal)
	body.push(opI64ExtendI32U)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: fieldOffset as ParsedInt)
end 'emitWasmSockStoreHandle'

// Load the i32 wasi resource handle stored (zero-extended) at the handle block's
// `fieldOffset`, leaving it on the stack as an i32. `blockLocal` holds the
// handle-block pointer (i64) read from the __ManagedSocket wrapper's `_handle`@0.
function emitWasmSockLoadBlockHandle(body ByteArray, blockLocal MachineWord, fieldOffset MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: blockLocal)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: fieldOffset as ParsedInt)
	body.push(opI32WrapI64)
end 'emitWasmSockLoadBlockHandle'

// mrt_managed_socket_send(self i64, managed i64, offset i64, length i64) throws
// -> i64 (bytes sent). Writes `length` bytes starting at managed.buffer+offset
// to the connection's output-stream. Bounds-checks offset+length against
// managed.capacity (bufferOutOfBounds=1); a stream-error → sendFailed=4.
//
// Locals (params 0..3 = self, managed, offset, length):
//   4 (i32) outStream  5 (i32) bufPtr  6 (i64) blockPtr
function emitWasmSocketSend() returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 2, i64Count: 1)
	let localSelf = 0
	let localManaged = 1
	let localOffset = 2
	let localLength = 3
	let localOutStream = 4
	let localBufPtr = 5
	let localBlock = 6

	// block = self._handle (i64 @ [self+0]).
	body.push(opLocalGet)
	writeUleb128(body, value: localSelf)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlock)

	// Bounds check: (offset + length) > managed.capacity → bufferOutOfBounds.
	// __ManagedMemory capacity is the i64 field @ [managed+16].
	body.push(opLocalGet)
	writeUleb128(body, value: localOffset)
	body.push(opLocalGet)
	writeUleb128(body, value: localLength)
	body.push(opI64Add)
	body.push(opLocalGet)
	writeUleb128(body, value: localManaged)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 16)
	body.push(opI64GtU)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockErrorReturn(body, flag: wasmSockFlagBufferOutOfBounds)
	body.push(opEnd)

	// outStream = block.outStream (i32).
	emitWasmSockLoadBlockHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffOutStream)
	body.push(opLocalSet)
	writeUleb128(body, value: localOutStream)

	// bufPtr = managed.buffer (i32 from i64 @ [managed+0]) + offset.
	emitMmBufferPtr(body, mmLocal: localManaged)
	body.push(opLocalGet)
	writeUleb128(body, value: localOffset)
	body.push(opI32WrapI64)
	body.push(opI32Add)
	body.push(opLocalSet)
	writeUleb128(body, value: localBufPtr)

	// output-stream.blocking-write-and-flush(outStream, bufPtr, length, retArea).
	// result<_, stream-error> (align 4): disc byte @+0.
	body.push(opLocalGet)
	writeUleb128(body, value: localOutStream)
	body.push(opLocalGet)
	writeUleb128(body, value: localBufPtr)
	body.push(opLocalGet)
	writeUleb128(body, value: localLength)
	body.push(opI32WrapI64)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiOutBlockingWriteFlush as Wasm32Index)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	emitWasmSockErrorReturn(body, flag: wasmSockFlagSendFailed)
	body.push(opEnd)

	// Success: return (length, 0).
	body.push(opLocalGet)
	writeUleb128(body, value: localLength)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmSocketSend'

// mrt_managed_socket_recv(self i64, managed i64) throws -> i64 (bytes received).
// Reads up to managed.capacity bytes from the connection's input-stream into
// managed.buffer. 0 bytes is allowed (the stdlib maps an empty read to
// connectionClosed); a stream-error → recvFailed=5.
//
// Locals (params 0,1 = self, managed):
//   2 (i32) inStream  3 (i32) count  4 (i64) blockPtr  5 (i64) capacity
function emitWasmSocketRecv() returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 2, i64Count: 2)
	let localSelf = 0
	let localManaged = 1
	let localInStream = 2
	let localCount = 3
	let localBlock = 4
	let localCap = 5

	// block = self._handle.
	body.push(opLocalGet)
	writeUleb128(body, value: localSelf)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlock)
	// inStream = block.inStream.
	emitWasmSockLoadBlockHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffInStream)
	body.push(opLocalSet)
	writeUleb128(body, value: localInStream)
	// capacity = managed.capacity (i64 @ [managed+16]).
	body.push(opLocalGet)
	writeUleb128(body, value: localManaged)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 16)
	body.push(opLocalSet)
	writeUleb128(body, value: localCap)

	// input-stream.blocking-read(inStream, capacity, retArea). result<list<u8>,
	// stream-error> (align 4): result-disc byte @+0; on ok list ptr @+4, len @+8.
	// On err, the stream-error variant disc is at @+4 (the error payload offset):
	// 0 = last-operation-failed (a real read failure → recvFailed), 1 = closed
	// (the peer half-closed cleanly → surface as 0 bytes so the stdlib maps it to
	// connectionClosed, not recvFailed). Both offsets verified empirically against
	// wasmtime's canonical-ABI lowering.
	body.push(opLocalGet)
	writeUleb128(body, value: localInStream)
	body.push(opLocalGet)
	writeUleb128(body, value: localCap)
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opCall)
	writeUleb128(body, value: wasiInBlockingRead as Wasm32Index)
	// result-disc != 0 → error path.
	body.push(opI32Const)
	writeSleb128(body, value: wasiSockRetAreaBase as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opIf)
	body.push(wasmTypeVoid)
	// stream-error variant disc @+4: closed (1) → return (0, 0) (connectionClosed
	// is the stdlib's job); anything else → recvFailed.
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load8U)
	body.push(0x00)
	writeUleb128(body, value: 0)
	body.push(opI32Const)
	writeSleb128(body, value: 1)  // closed
	body.push(opI32Eq)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opReturn)
	body.push(opEnd)
	emitWasmSockErrorReturn(body, flag: wasmSockFlagRecvFailed)
	body.push(opEnd)

	// count = list len (i32 @ retArea+8).
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 8) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localCount)
	// memory.copy(dst=managed.buffer, src=list ptr @retArea+4, len=count).
	emitMmBufferPtr(body, mmLocal: localManaged)  // dst
	body.push(opI32Const)
	writeSleb128(body, value: (wasiSockRetAreaBase + 4) as ParsedInt)
	body.push(opI32Load)
	body.push(0x02)
	writeUleb128(body, value: 0)  // src
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)  // len
	body.push(0xFC)
	body.push(0x0A)
	body.push(0x00)
	body.push(0x00)  // memory.copy

	// Success: return (count, 0). 0 bytes is allowed; the stdlib decides
	// connectionClosed.
	body.push(opLocalGet)
	writeUleb128(body, value: localCount)
	body.push(opI64ExtendI32U)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opEnd)
	return body
end 'emitWasmSocketRecv'

// mrt_managed_socket_close(self i64) -> void. Non-throwing, idempotent.
// Drops the four wasi resources (output-stream, input-stream, tcp-socket,
// network), mm_decref's the handle block, and zeroes self._handle so a repeat
// call (or the absence of a destructor) is a no-op. Guards self == 0 and an
// already-zeroed _handle. The runtime.std stub is `1 void`, so the body must
// leave NO value on the stack at any return point.
//
// Locals (param 0 = self):
//   1 (i64) blockPtr
function emitWasmSocketClose(funcSigs WasmFuncSigs) returns ByteArray
	var body = ByteArray.create()
	emitWasmMixedLocals(body, i32Count: 0, i64Count: 1)
	let localSelf = 0
	let localBlock = 1

	// if self == 0 → return (defensive: never deref a null wrapper).
	body.push(opLocalGet)
	writeUleb128(body, value: localSelf)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opReturn)
	body.push(opEnd)

	// block = self._handle (i64 @ [self+0]).
	body.push(opLocalGet)
	writeUleb128(body, value: localSelf)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: 0)
	body.push(opLocalSet)
	writeUleb128(body, value: localBlock)

	// if block == 0 → already closed; return (idempotent).
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opI64Eqz)
	body.push(opIf)
	body.push(wasmTypeVoid)
	body.push(opReturn)
	body.push(opEnd)

	// Zero self._handle FIRST so a concurrent/repeat close can't double-drop.
	body.push(opLocalGet)
	writeUleb128(body, value: localSelf)
	body.push(opI32WrapI64)
	body.push(opI64Const)
	writeSleb128(body, value: 0)
	body.push(opI64Store)
	body.push(0x03)
	writeUleb128(body, value: 0)

	// Drop the wasi resources in reverse acquisition order: output-stream,
	// input-stream, tcp-socket, network.
	emitWasmSockDropHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffOutStream, dropImport: wasiOutStreamDrop)
	emitWasmSockDropHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffInStream, dropImport: wasiInStreamDrop)
	emitWasmSockDropHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffSocket, dropImport: wasiTcpSocketDrop)
	emitWasmSockDropHandle(body, blockLocal: localBlock, fieldOffset: wasmSockBlockOffNetwork, dropImport: wasiNetworkDrop)

	// mm_decref the handle block (refcount 1 → freed). Void return; no drop.
	body.push(opLocalGet)
	writeUleb128(body, value: localBlock)
	body.push(opCall)
	writeUleb128(body, value: findFunctionIndex(funcSigs, name: "mm_decref", importCount: wasiImportCount))

	body.push(opEnd)
	return body
end 'emitWasmSocketClose'

// Drop the wasi resource handle (i32, zero-extended) stored at block+fieldOffset
// via the given resource-drop import.
function emitWasmSockDropHandle(body ByteArray, blockLocal MachineWord, fieldOffset MachineWord, dropImport MachineWord)
	body.push(opLocalGet)
	writeUleb128(body, value: blockLocal)
	body.push(opI32WrapI64)
	body.push(opI64Load)
	body.push(0x03)
	writeUleb128(body, value: fieldOffset as ParsedInt)
	body.push(opI32WrapI64)
	body.push(opCall)
	writeUleb128(body, value: dropImport as Wasm32Index)
end 'emitWasmSockDropHandle'

// ============================================================
// Utility functions
// ============================================================

function nop()
end 'nop'

// Helper to create a ByteArray with 1 element.
function makeByteArray1(v MachineWord) returns ByteArray
	var arr = ByteArray.create()
	arr.push(v)
	return arr
end 'makeByteArray1'

// Helper to create a ByteArray with 2 elements.
function makeByteArray2(a MachineWord, b MachineWord) returns ByteArray
	var arr = ByteArray.create()
	arr.push(a)
	arr.push(b)
	return arr
end 'makeByteArray2'

// Helper to create a ByteArray with 3 elements.
function makeByteArray3i(a MachineWord, b MachineWord, c MachineWord) returns ByteArray
	var arr = ByteArray.create()
	arr.push(a)
	arr.push(b)
	arr.push(c)
	return arr
end 'makeByteArray3i'

// Helper to create a ByteArray with 4 elements.
function makeByteArray4(a MachineWord, b MachineWord, c MachineWord, d MachineWord) returns ByteArray
	var arr = ByteArray.create()
	arr.push(a)
	arr.push(b)
	arr.push(c)
	arr.push(d)
	return arr
end 'makeByteArray4'

// Append a Preview2 import func type to `types`: `count` repeated `wasmTypeI32`
// params with `extra` appended verbatim (for the occasional i64 param), and
// `results` value types. Most WASI Preview2 lowered imports are all-i32 with an
// i32 or empty result, so this keeps the 35-entry type block readable. `extra`
// is the trailing non-i32 params (e.g. an i64 length/offset) appended AFTER the
// `i32Count` leading i32s; pass an empty array when there are none.
function pushWasiType(types ByteArrayArray, i32Count MachineWord, extra ByteArray, results ByteArray)
	var params = ByteArray.create()
	for _ in 0 upto i32Count 'i32s'
		params.push(wasmTypeI32)
	end 'i32s'
	params.append(extra)
	var ty = ByteArray.create()
	writeFuncType(ty, paramTypes: params, resultTypes: results)
	types.push(ty)
end 'pushWasiType'

function markIfSource(floatSet BoolArray, id MachineWord, srcId MachineWord)
	// Sentinel: floatSet is grown lazily; absent entries default to false ("not marked as float").
	let srcIsFloat = try floatSet.get(srcId) otherwise false
	if srcIsFloat 'mark'
		try floatSet.set(id, value: true) otherwise panic("invariant: floatSet.set OOB")
	end 'mark'
end 'markIfSource'

function markIf(floatSet BoolArray, id MachineWord, condition bool)
	if condition 'mark'
		try floatSet.set(id, value: true) otherwise panic("invariant: floatSet.set OOB")
	end 'mark'
end 'markIf'

function setFloatBit(floatSet BoolArray, id MachineWord)
	try floatSet.set(id, value: true) otherwise panic("invariant: floatSet.set OOB")
end 'setFloatBit'

function markIfFloatBinOp(floatSet BoolArray, id MachineWord, opcode MirBinOpcode)
	match opcode 'check'
		addF64 to divF64 then setFloatBit(floatSet, id: id)
		minF64 to maxF64 then setFloatBit(floatSet, id: id)
		addI64 to shrI64 then break 'check'
	end 'check'
end 'markIfFloatBinOp'

function markIfFloatUnaryOp(floatSet BoolArray, id MachineWord, opcode MirUnaryOpcode)
	match opcode 'check'
		siToFpF64 to absF64 then setFloatBit(floatSet, id: id)
		negI64 to fpToSiI64 then break 'check'
		bitcastF64ToI64 then break 'check'
		bitcastI64ToF64 then setFloatBit(floatSet, id: id)
	end 'check'
end 'markIfFloatUnaryOp'

function getLocalType(floatSet BoolArray, localIdx MachineWord) returns MachineWord
	if isFloatLocal(floatSet, localIdx: localIdx) 'isFloat'
		return wasmTypeF64
	end 'isFloat'
	return wasmTypeI64
end 'getLocalType'

function stdTypeToWasmType(t StdType) returns MachineWord
	if stdTypeIsFloat(t) 'isFloat'
		return wasmTypeF64
	end 'isFloat'
	return wasmTypeI64
end 'stdTypeToWasmType'

// Stage F (closures): scan every user-function body for indirect-call
// ops, derive each call site's wasm signature, and intern it into
// `typeIndexMap`. New types get appended to `types` and assigned the
// next available type-section index. Pre-existing entries (matching a
// direct-call type) are reused — the dedup is what keeps stdlib's
// "(i64, i64) -> i64" type entry from being duplicated when a closure
// happens to have the same shape.
function collectIndirectCallTypes(module MirModule, types ByteArrayArray, typeIndexMap WasmTypeIndexMap)
	for func in module.functions 'eachFunc'
		// Build a per-function float bitset so signature derivation
		// classifies each ValueId correctly.
		let floatSet = computeFloatValueIdsForFunc(module, func: func)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("invariant: opIdx from block.opRefs not in module.ops")
				match op 'check'
					indirectCall(resultId, _, argIds, isVoid, isThrowing, _) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: isThrowing)
					witnessCall(resultId, _, _, isVoid, argIds) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: false)
					witnessTryCall(resultId, _, _, isVoid, argIds, _) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: true)
					movImm to call then break 'check'
					ret to loadByte then break 'check'
					osAllocPages to osLockRelease then break 'check'
					// tryCall / errorReturn are not indirect calls (no signature to
					// register); witnessTryCall sits between them in the MirOp union
					// and is handled explicitly above, so the band is split here.
					tryCall then break 'check'
					errorReturn then break 'check'
				end 'check'
			end 'eachOp'
			if block.hasTerminatorOp() 'hasTerm'
				let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("invariant: terminatorIndex not in module.ops")
				match termOp 'checkTerm'
					indirectCall(resultId, _, argIds, isVoid, isThrowing, _) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: isThrowing)
					witnessCall(resultId, _, _, isVoid, argIds) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: false)
					witnessTryCall(resultId, _, _, isVoid, argIds, _) then registerIndirectCallType(types, typeIndexMap: typeIndexMap, floatSet: floatSet, resultId: resultId, isVoid: isVoid, argIds: argIds, throws: true)
					movImm to call then break 'checkTerm'
					ret to loadByte then break 'checkTerm'
					osAllocPages to osLockRelease then break 'checkTerm'
					// See the body-loop note: split the tryCall..errorReturn band so
					// the explicit witnessTryCall arm doesn't overlap a range.
					tryCall then break 'checkTerm'
					errorReturn then break 'checkTerm'
				end 'checkTerm'
			end 'hasTerm'
		end 'eachBlock'
	end 'eachFunc'
end 'collectIndirectCallTypes'

// Look up a wasm function-type signature in the type-section dedup map;
// register a fresh entry when missing. Used by both the local user-pipeline
// pre-pass and the stdlib-cache fixup walker, which both need the type
// section finalized before `writeTypeSection`. Returns the resolved
// index (existing or newly-assigned).
function lookupOrRegisterIndirectType(types ByteArrayArray, typeIndexMap WasmTypeIndexMap, signatureBytes ByteArray) returns Wasm32Index
	let existing = try typeIndexMap.get(signatureBytes) otherwise 'register'
		let newIdx = types.count() as Wasm32Index
		types.push(signatureBytes)
		typeIndexMap.upsert(signatureBytes, value: newIdx)
		return newIdx
	end 'register'
	return existing as Wasm32Index
end 'lookupOrRegisterIndirectType'

function registerIndirectCallType(types ByteArrayArray, typeIndexMap WasmTypeIndexMap, floatSet BoolArray, resultId ValueId, isVoid bool, argIds ValueIdArray, throws bool)
	var params = ByteArray.create()
	for argId in argIds 'eachArg'
		if isFloatLocal(floatSet, localIdx: argId as MachineWord) 'isFloat'
			params.push(wasmTypeF64)
		end 'isFloat' else 'isInt'
			params.push(wasmTypeI64)
		end 'isInt'
	end 'eachArg'
	var results = ByteArray.create()
	// Void witness/indirect calls (interface methods declared with no
	// returns clause) MUST register a no-result signature; wasm's
	// `call_indirect` traps with "indirect call type mismatch" if the
	// expected type carries a result the actual callee doesn't push.
	if not isVoid 'hasResult'
		if isFloatLocal(floatSet, localIdx: resultId) 'floatRes'
			results.push(wasmTypeF64)
		end 'floatRes' else 'intRes'
			results.push(wasmTypeI64)
		end 'intRes'
	end 'hasResult'
	// Throwing witness dispatch appends a trailing i64 error flag — the
	// signature must match buildIndirectCallTypeBytes(throws: true) emitted
	// at the witnessTryCall site, or call_indirect traps on a type mismatch.
	if throws 'errorFlagResult'
		results.push(wasmTypeI64)
	end 'errorFlagResult'
	var funcType = ByteArray.create()
	writeFuncType(funcType, paramTypes: params, resultTypes: results)
	if typeIndexMap.contains(funcType) 'alreadyInterned'
		return
	end 'alreadyInterned'
	let newIdx = types.count()
	types.push(funcType)
	typeIndexMap.upsert(funcType, value: newIdx)
end 'registerIndirectCallType'

// Module-level twin of WasmFunctionLowering.findFloatValueIds —
// duplicated so collectIndirectCallTypes can run at emitWasmModule
// scope without instantiating a lowering for each function. The body
// mirrors findFloatValueIds exactly: seed block-arg floats, then walk
// ops marking results based on opcode / source.
function computeFloatValueIdsForFunc(module MirModule, func IrFunction) returns BoolArray
	let maxId = scanMaxMirValueId(module, func: func)
	var floatSet = BoolArray.create()
	for _ in 0 upto maxId + 1 'init'
		floatSet.push(false)
	end 'init'
	// Seed param locals from func.paramTypes — mem2reg's func.param ops
	// would normally seed these via markFloatMirOp, but during type
	// collection we may run before their results are observed (the param
	// op lives in the entry block's opRefs, which we walk below, so this
	// step just ensures correctness if a pre-mem2reg call ever lands
	// here).
	for pi in 0 upto func.paramCount 'eachParam'
		let pt = try func.paramTypes.get(pi) otherwise panic("invariant: pi < func.paramCount but paramTypes.get failed")
		if stdTypeIsFloat(pt) 'isFloat'
			try floatSet.set(pi as MachineWord, value: true) otherwise panic("invariant: floatSet.set OOB for param")
		end 'isFloat'
	end 'eachParam'
	for blockRef in func.blockRefs 'seedBlockArgs'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		for blockArg in block.blockArgs 'eachArg'
			if stdTypeIsFloat(blockArg.argType) 'isFloat'
				try floatSet.set(blockArg.valueId as MachineWord, value: true) otherwise panic("invariant: floatSet.set OOB for blockArg")
			end 'isFloat'
		end 'eachArg'
	end 'seedBlockArgs'
	for blockRef in func.blockRefs 'walkOps'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		for packed in block.opRefs 'eachOp'
			let mirOp = try module.ops.get(packed) otherwise panic("invariant: opIdx from block.opRefs not in module.ops")
			markFloatMirOpStandalone(mirOp, floatSet: floatSet)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("invariant: terminatorIndex not in module.ops")
			markFloatMirOpStandalone(termOp, floatSet: floatSet)
		end 'hasTerm'
	end 'walkOps'
	return floatSet
end 'computeFloatValueIdsForFunc'

// Module-scope twin of WasmFunctionLowering.markFloatMirOp — same dispatch
// minus the `call` arm, which would need the lowering's `lookupReturnType`
// helper. Indirect-call type collection runs at module scope before any
// function body is lowered, so direct calls don't need to be classified
// here (the result of a direct call is local-only and doesn't drive
// indirect-call signature dedup).
function markFloatMirOpStandalone(op MirOp, floatSet BoolArray)
	match op 'dispatch'
		movImm(resultId, _, isFloat) then markIf(floatSet, id: resultId, condition: isFloat)
		movReg(resultId, srcId) then markIfSource(floatSet, id: resultId as MachineWord, srcId: srcId)
		binOp(resultId, _, _, opcode) then markIfFloatBinOp(floatSet, id: resultId as MachineWord, opcode: opcode)
		unaryOp(resultId, _, opcode) then markIfFloatUnaryOp(floatSet, id: resultId as MachineWord, opcode: opcode)
		param(resultId, _, paramType) then markIf(floatSet, id: resultId as MachineWord, condition: stdTypeIsFloat(paramType))
		cmp to ret then break 'dispatch'
		load to loadByte then break 'dispatch'
		osAllocPages to osLockRelease then break 'dispatch'
		tryCall to errorReturn then break 'dispatch'
	end 'dispatch'
end 'markFloatMirOpStandalone'

// Build a WASM func type entry from parameter/return metadata. Throwing
// functions append an extra i64 result (the error flag) to encode the
// dual-value-return error ABI in wasm's native multi-value return.
function buildFuncTypeEntry(paramCount ParamCount, paramTypes StdTypeArray, returnType StdReturnType, throws bool) returns ByteArray
	var funcType = ByteArray.create()
	var params = ByteArray.create()

	for i in 0 upto paramCount 'eachParam'
		let paramType = try paramTypes.get(i) otherwise panic("unreachable: param index out of bounds")
		let wasmType = stdTypeToWasmType(paramType)
		params.push(wasmType)
	end 'eachParam'

	var results = ByteArray.create()

	match returnType 'writeResult'
		void then break 'writeResult'
		value(inner) then results.push(stdTypeToWasmType(inner))
	end 'writeResult'

	if throws 'errorFlagResult'
		results.push(wasmTypeI64)
	end 'errorFlagResult'

	writeFuncType(funcType, paramTypes: params, resultTypes: results)
	return funcType
end 'buildFuncTypeEntry'

// `floatSet` is sized to `findMaxValueId()+1`, covering every valueId in
// the function. Callers pass live valueIds from MIR ops, so OOB is a bug.
function isFloatLocal(floatSet BoolArray, localIdx MachineWord) returns bool
	return try floatSet.get(localIdx) otherwise panic("isFloatLocal: floatSet.get({localIdx}) OOB; sized to maxValueId+1")
end 'isFloatLocal'

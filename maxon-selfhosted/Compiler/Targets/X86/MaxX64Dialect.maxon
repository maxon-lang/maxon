// MaxX64 Dialect — x86-64 machine instructions.

export enum FloatPrecision
	f64
	f32
end 'FloatPrecision'

export enum X64XmmRegister
	xmm0 = 0
	xmm1 = 1
	xmm2 = 2
	xmm3 = 3
	xmm4 = 4
	xmm5 = 5
	xmm6 = 6
	xmm7 = 7
	xmm8 = 8
	xmm9 = 9
	xmm10 = 10
	xmm11 = 11
	xmm12 = 12
	xmm13 = 13
	xmm14 = 14
	xmm15 = 15
end 'X64XmmRegister'

export enum X64SetccCondition
	e = 0
	ne = 1
	g = 2
	ge = 3
	l = 4
	le = 5
	a = 6
	ae = 7
	b = 8
	be = 9
end 'X64SetccCondition'

export enum X64CmovCondition
	e = 0
	ne = 1
	g = 2
	ge = 3
	l = 4
	le = 5
	a = 6
	ae = 7
	b = 8
	be = 9
end 'X64CmovCondition'

export enum X64Register
	rax
	rcx
	rdx
	rbx
	rsp
	rbp
	rsi
	rdi
	r8
	r9
	r10
	r11
end 'X64Register'

export enum X64JumpCondition
	b = 130
	be = 134
	e = 132
	ne = 133
	ae = 131
	a = 135
	l = 140
	le = 142
	ge = 141
	g = 143
	p = 138
	np = 139
end 'X64JumpCondition'

export union X64VReg
	physical(reg X64Register)
	virtual(id ValueId)
end 'X64VReg'

export union X64FpVReg
	physical(reg X64XmmRegister)
	virtual(id ValueId)
end 'X64FpVReg'

export function x64VRegToString(vreg X64VReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "v{id}"
	end 'fmt'
end 'x64VRegToString'

export function x64FpVRegToString(vreg X64FpVReg) returns String
	return match vreg 'fmt'
		physical(reg) gives reg.name
		virtual(id) gives "vf{id}"
	end 'fmt'
end 'x64FpVRegToString'

// Convenience wrappers for creating VRegs from physical registers
export function physReg(reg X64Register) returns X64VReg
	return X64VReg.physical(reg)
end 'physReg'

export function physFpReg(reg X64XmmRegister) returns X64FpVReg
	return X64FpVReg.physical(reg)
end 'physFpReg'

export union MaxX64Op
	prologue(stackSize StackSize)
	epilogue
	ret
	movRegImm(dest X64VReg, value MachineWord)
	movSlot(slotIndex VarSlot, srcReg X64VReg)
	loadSlot(destReg X64VReg, slotIndex VarSlot)
	addRegReg(destReg X64VReg, srcReg X64VReg)
	subRegReg(destReg X64VReg, srcReg X64VReg)
	imulRegReg(destReg X64VReg, srcReg X64VReg)
	idivRcx
	iremRcx
	negReg(reg X64VReg)
	bitNotReg(reg X64VReg)
	andRegReg(destReg X64VReg, srcReg X64VReg)
	orRegReg(destReg X64VReg, srcReg X64VReg)
	xorRegReg(destReg X64VReg, srcReg X64VReg)
	shlRegCl(reg X64VReg)
	sarRegCl(reg X64VReg)
	cmpRaxRcx
	testRaxRax
	condJump(condition X64JumpCondition, targetBlock BlockId)
	jmp(targetBlock BlockId)
	movF64Slot(slotIndex VarSlot)
	loadF64Slot(slotIndex VarSlot)
	movF64Rdata(rdataOffset CodeOffset)
	ucomisd
	printLiteral(data ByteArray)
	printInt
	subRspImm(value StackSize)
	addRspImm(value StackSize)
	movRspOffsetReg(offset StackSize, srcReg X64VReg)
	loadRegRbpOffset(destReg X64VReg, offset StackSize)
	callDirect(target ByteArray)
	// SysOp lowering: x86-64 syscall instruction
	syscall(resultSlot VarSlot, number MachineWord, argSlots VarSlotArray)
	// SysOp lowering: indirect call through IAT slot
	iatCall(resultSlot VarSlot, slotIndex MachineWord, argSlots VarSlotArray)
	// SysOp lowering: data island + LEA for named global data
	globalAddr(resultSlot VarSlot, name ByteArray)
	// SysOp lowering: LEA rax, [rbp - offset] for stack slot address
	stackAddrOp(resultSlot VarSlot, targetSlot VarSlot)
	// SysOp lowering: mov byte [base + offset], value
	storeByteOp(baseSlot VarSlot, offsetSlot VarSlot, byteSlot VarSlot)
	// SysOp lowering: movzx rax, byte [base + offset]
	loadByteOp(resultSlot VarSlot, baseSlot VarSlot, offsetSlot VarSlot)
	// SysOp lowering: rep movsb (memcpy)
	memcpyOp(dstSlot VarSlot, srcSlot VarSlot, lenSlot VarSlot)
	// Register allocator ops
	movRegReg(destReg X64VReg, srcReg X64VReg)
	cmpRegReg(lhsReg X64VReg, rhsReg X64VReg)
	testRegReg(reg1 X64VReg, reg2 X64VReg)
	cqo
	idivReg(divisorReg X64VReg)
	spillToStack(offset MachineWord, srcReg X64VReg)
	reloadFromStack(destReg X64VReg, offset MachineWord)
	xorRegRegSelf(reg X64VReg)
	// Call support ops
	callIndirect(reg X64VReg)
	xchgRegReg(reg1 X64VReg, reg2 X64VReg)
	// XMM FP ops
	movXmmXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	spillXmmToStack(offset MachineWord, src X64FpVReg, precision FloatPrecision)
	reloadXmmFromStack(dest X64FpVReg, offset MachineWord, precision FloatPrecision)
	movXmmRipRel(dest X64FpVReg, rdataLabel ByteArray, precision FloatPrecision)
	addXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	subXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	mulXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	divXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	sqrtXmm(dest X64FpVReg, src X64FpVReg, precision FloatPrecision)
	roundXmm(dest X64FpVReg, src X64FpVReg, mode MachineWord, precision FloatPrecision)
	ucomisXmm(src1 X64FpVReg, src2 X64FpVReg, precision FloatPrecision)
	cvtSi2Float(dest X64FpVReg, src X64VReg, precision FloatPrecision)
	cvttFloat2Si(dest X64VReg, src X64FpVReg, precision FloatPrecision)
	cvtSd2Ss(dest X64FpVReg, src X64FpVReg)
	cvtSs2Sd(dest X64FpVReg, src X64FpVReg)
	movqXmmToGpr(dest X64VReg, src X64FpVReg)
	andMaskRipRel(dest X64FpVReg, rdataLabel ByteArray, precision FloatPrecision)
	// Indirect memory ops
	storeIndirect(baseReg X64VReg, offset MachineWord, srcReg X64VReg, size MachineWord)
	loadIndirect(destReg X64VReg, baseReg X64VReg, offset MachineWord, size MachineWord)
	storeIndirectXmm(baseReg X64VReg, offset MachineWord, src X64FpVReg, precision FloatPrecision)
	loadIndirectXmm(dest X64FpVReg, baseReg X64VReg, offset MachineWord, precision FloatPrecision)
	// Global variable ops
	globalLoad(dest X64VReg, name ByteArray, size MachineWord)
	globalStore(name ByteArray, src X64VReg, size MachineWord)
	globalLoadXmm(dest X64FpVReg, name ByteArray, precision FloatPrecision)
	globalStoreXmm(name ByteArray, src X64FpVReg, precision FloatPrecision)
	// LEA ops
	leaFromStack(dest X64VReg, stackOffset MachineWord)
	leaRipRelative(dest X64VReg, rdataLabel ByteArray)
	leaFuncAddr(dest X64VReg, funcName ByteArray)
	// Conditional ops
	setcc(dest X64VReg, condition X64SetccCondition)
	cmov(dest X64VReg, src X64VReg, condition X64CmovCondition)
	// Width conversion ops
	movsxd(dest X64VReg, src X64VReg)
	movzx32(dest X64VReg, src X64VReg)
	// Null-safe load
	nullSafeLoad(dest X64VReg, baseReg X64VReg, offset MachineWord)
	// Memcopy/BulkZero
	repMovsb
	repStosq
end 'MaxX64Op'

export typealias MaxX64OpArray = Array with MaxX64Op

function slotOffset(slotIndex VarSlot) returns StackSize
	return(slotIndex + 1) * 8
end 'slotOffset'

function formatSignedOffset(offset MachineWord) returns String
	// MachineWord is unsigned; negative offsets wrap to large values (> i64.max).
	if offset > 9223372036854775807 'negative'
		let pos = 0 - offset
		return "-{pos}"
	end 'negative'
	return "+{offset}"
end 'formatSignedOffset'

export function formatVarSlotArgs(argSlots VarSlotArray) returns String
	var result = ""
	for i in 0 upto argSlots.count() 'each'
		let slot = try argSlots.get(i) otherwise 'skip'
			continue
		end 'skip'
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}slot_{slot}"
	end 'each'
	return result
end 'formatVarSlotArgs'

export function maxX64OpToString(op MaxX64Op, blocks MlirBlockArray) returns String
	return match op 'toString'
		prologue(stackSize) gives "x86.prologue stack_size={stackSize}"
		epilogue gives "x86.epilogue"
		ret gives "x86.ret"
		movRegImm(dest, value) gives "x86.mov {x64VRegToString(dest)}, {value}"
		movSlot(slotIndex, srcReg) gives "x86.mov [rbp-{slotOffset(slotIndex)}], {x64VRegToString(srcReg)}"
		loadSlot(destReg, slotIndex) gives "x86.mov {x64VRegToString(destReg)}, [rbp-{slotOffset(slotIndex)}]"
		addRegReg(destReg, srcReg) gives "x86.add {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		subRegReg(destReg, srcReg) gives "x86.sub {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		imulRegReg(destReg, srcReg) gives "x86.imul {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		idivRcx gives "x86.idiv rcx"
		iremRcx gives "x86.idiv rcx"
		negReg(reg) gives "x86.neg {x64VRegToString(reg)}"
		bitNotReg(reg) gives "x86.not {x64VRegToString(reg)}"
		andRegReg(destReg, srcReg) gives "x86.and {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		orRegReg(destReg, srcReg) gives "x86.or {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		xorRegReg(destReg, srcReg) gives "x86.xor {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		shlRegCl(reg) gives "x86.shl {x64VRegToString(reg)}, cl"
		sarRegCl(reg) gives "x86.sar {x64VRegToString(reg)}, cl"
		cmpRaxRcx gives "x86.cmp rax, rcx"
		testRaxRax gives "x86.test rax, rax"
		condJump(condition, targetBlock) gives "x86.j{condition.name} {resolveBlockLabel(targetBlock, blocks: blocks)}"
		jmp(targetBlock) gives "x86.jmp {resolveBlockLabel(targetBlock, blocks: blocks)}"
		movF64Slot(slotIndex) gives "x86.movsd [rbp-{slotOffset(slotIndex)}], xmm0"
		loadF64Slot(slotIndex) gives "x86.movsd xmm0, [rbp-{slotOffset(slotIndex)}]"
		movF64Rdata(rdataOffset) gives "x86.movsd xmm0, [rip+__float_{rdataOffset}]"
		ucomisd gives "x86.ucomisd xmm0, xmm1"
		printLiteral(data) gives "x86.print_literal \"{String.from(data)}\""
		printInt gives "x86.print_int"
		subRspImm(value) gives "x86.sub rsp, {value}"
		addRspImm(value) gives "x86.add rsp, {value}"
		movRspOffsetReg(offset, srcReg) gives "x86.mov [rsp+{offset}], {x64VRegToString(srcReg)}"
		loadRegRbpOffset(destReg, offset) gives "x86.mov {x64VRegToString(destReg)}, [rbp-{offset}]"
		callDirect(target) gives "x86.call {String.from(target)}"
		syscall(_, number, argSlots) gives "x86.syscall {number}({formatVarSlotArgs(argSlots)})"
		iatCall(_, slotIndex, _) gives "x86.call_import slot_{slotIndex}"
		globalAddr(_, name) gives "x86.lea_rdata {X64Register.rax.name}, [{String.from(name)}]"
		stackAddrOp(_, targetSlot) gives "x86.lea rax, [rbp-{slotOffset(targetSlot)}]"
		storeByteOp(_, _, _) gives "x86.mov byte ptr [rax+0], cl"
		loadByteOp(_, _, _) gives "x86.movzx rax, byte ptr [rax+0]"
		memcpyOp(_, _, _) gives "x86.rep_movsb"
		movRegReg(destReg, srcReg) gives "x86.mov {x64VRegToString(destReg)}, {x64VRegToString(srcReg)}"
		cmpRegReg(lhsReg, rhsReg) gives "x86.cmp {x64VRegToString(lhsReg)}, {x64VRegToString(rhsReg)}"
		testRegReg(reg1, reg2) gives "x86.test {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		cqo gives "x86.cqo"
		idivReg(divisorReg) gives "x86.idiv {x64VRegToString(divisorReg)}"
		spillToStack(offset, srcReg) gives "x86.mov [rbp{formatSignedOffset(offset)}], {x64VRegToString(srcReg)}"
		reloadFromStack(destReg, offset) gives "x86.mov {x64VRegToString(destReg)}, [rbp{formatSignedOffset(offset)}]"
		xorRegRegSelf(reg) gives "x86.xor {x64VRegToString(reg)}, {x64VRegToString(reg)}"
		callIndirect(reg) gives "x86.call {x64VRegToString(reg)}"
		xchgRegReg(reg1, reg2) gives "x86.xchg {x64VRegToString(reg1)}, {x64VRegToString(reg2)}"
		movXmmXmm(dest, src, _) gives "x86.movsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		spillXmmToStack(offset, src, _) gives "x86.movsd [rbp{formatSignedOffset(offset)}], {x64FpVRegToString(src)}"
		reloadXmmFromStack(dest, offset, _) gives "x86.movsd {x64FpVRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		movXmmRipRel(dest, label, _) gives "x86.movsd {x64FpVRegToString(dest)}, [rip+{String.from(label)}]"
		addXmm(dest, src, _) gives "x86.addsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		subXmm(dest, src, _) gives "x86.subsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		mulXmm(dest, src, _) gives "x86.mulsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		divXmm(dest, src, _) gives "x86.divsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		sqrtXmm(dest, src, _) gives "x86.sqrtsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		roundXmm(dest, src, mode, _) gives "x86.roundsd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}, {mode}"
		ucomisXmm(src1, src2, _) gives "x86.ucomisd {x64FpVRegToString(src1)}, {x64FpVRegToString(src2)}"
		cvtSi2Float(dest, src, _) gives "x86.cvtsi2sd {x64FpVRegToString(dest)}, {x64VRegToString(src)}"
		cvttFloat2Si(dest, src, _) gives "x86.cvttsd2si {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSd2Ss(dest, src) gives "x86.cvtsd2ss {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		cvtSs2Sd(dest, src) gives "x86.cvtss2sd {x64FpVRegToString(dest)}, {x64FpVRegToString(src)}"
		movqXmmToGpr(dest, src) gives "x86.movq {x64VRegToString(dest)}, {x64FpVRegToString(src)}"
		andMaskRipRel(dest, label, _) gives "x86.andpd {x64FpVRegToString(dest)}, [rip+{String.from(label)}]"
		storeIndirect(baseReg, offset, srcReg, size) gives "x86.mov [{x64VRegToString(baseReg)}+{offset}], {x64VRegToString(srcReg)} ({size}b)"
		loadIndirect(destReg, baseReg, offset, size) gives "x86.mov {x64VRegToString(destReg)}, [{x64VRegToString(baseReg)}+{offset}] ({size}b)"
		storeIndirectXmm(baseReg, offset, src, _) gives "x86.movsd [{x64VRegToString(baseReg)}+{offset}], {x64FpVRegToString(src)}"
		loadIndirectXmm(dest, baseReg, offset, _) gives "x86.movsd {x64FpVRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		globalLoad(dest, name, _) gives "x86.mov {x64VRegToString(dest)}, [rip+{String.from(name)}]"
		globalStore(name, src, _) gives "x86.mov [rip+{String.from(name)}], {x64VRegToString(src)}"
		globalLoadXmm(dest, name, _) gives "x86.movsd {x64FpVRegToString(dest)}, [rip+{String.from(name)}]"
		globalStoreXmm(name, src, _) gives "x86.movsd [rip+{String.from(name)}], {x64FpVRegToString(src)}"
		leaFromStack(dest, offset) gives "x86.lea {x64VRegToString(dest)}, [rbp{formatSignedOffset(offset)}]"
		leaRipRelative(dest, label) gives "x86.lea {x64VRegToString(dest)}, [rip+{String.from(label)}]"
		leaFuncAddr(dest, funcName) gives "x86.lea {x64VRegToString(dest)}, [rip+{String.from(funcName)}]"
		setcc(dest, condition) gives "x86.set{condition.name} {x64VRegToString(dest)}"
		cmov(dest, src, condition) gives "x86.cmov{condition.name} {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movsxd(dest, src) gives "x86.movsxd {x64VRegToString(dest)}, {x64VRegToString(src)}"
		movzx32(dest, src) gives "x86.mov {x64VRegToString(dest)}d, {x64VRegToString(src)}d"
		nullSafeLoad(dest, baseReg, offset) gives "x86.null_safe_load {x64VRegToString(dest)}, [{x64VRegToString(baseReg)}+{offset}]"
		repMovsb gives "x86.rep movsb"
		repStosq gives "x86.rep stosq"
	end 'toString'
end 'maxX64OpToString'

// MaxX64 dialect ops to machine code bytes.
// Block-based emitter: walks MlirModule -> functions -> blocks -> ops.
// OS-specific stubs are parameterized by OsDescriptor.

typealias CodeOffsetArray = Array with CodeOffset

// Block jump fixup: records where a jump instruction needs its target patched.
type BlockJumpFixup
    export var codeOffset CodeOffset
    export var targetBlockId BlockId
end 'BlockJumpFixup'
typealias BlockJumpFixupArray = Array with BlockJumpFixup

// --- Byte emission helpers (identical to X86CodeEmitter) ---

function emitPrologue(code ByteArray, stackSize StackSize)
    // push rbp; mov rbp, rsp
    code.append(b"\x55\x48\x89\xe5")
    // sub rsp, stackSize (only if non-zero)
    if stackSize > 0 'hasSub'
        code.append(b"\x48\x83\xec")
        code.push(stackSize and 0xFF)
    end 'hasSub'
end 'emitPrologue'

function emitEpilogue(code ByteArray)
    // mov rsp, rbp; pop rbp; ret
    code.append(b"\x48\x89\xec\x5d\xc3")
end 'emitEpilogue'

function emitMovRegImm(code ByteArray, value MachineWord)
    // Use 32-bit sign-extended form if value fits in signed 32-bit range
    if value >= 0 - 2147483648 and value <= 2147483647 'small'
        // mov rax, imm32 (sign-extended)  =>  48 C7 C0 <dword>
        code.append(b"\x48\xc7\xc0")
        writeDword(code, value: value)
    end 'small' else 'large'
        // mov rax, imm64  =>  48 B8 <qword>
        code.append(b"\x48\xb8")
        writeQword(code, value: value)
    end 'large'
end 'emitMovRegImm'

// Store RAX to stack slot: mov [rbp - (slotIndex+1)*8], rax
function emitMovSlot(code ByteArray, slotIndex VarSlot)
    let offset = (slotIndex + 1) * 8
    // mov [rbp - offset], rax  =>  48 89 45 <disp8>
    code.append(b"\x48\x89\x45")
    code.push((0 - offset) and 0xFF)
end 'emitMovSlot'

// Load stack slot to a register: mov REG, [rbp - (slotIndex+1)*8]
function emitLoadSlotToReg(code ByteArray, slotIndex VarSlot, dest X64Register)
    let offset = (slotIndex + 1) * 8
    match dest 'pickReg'
        X64Register.rax then emitLoadSlotRax(code, offset: offset)
        X64Register.rcx then emitLoadSlotRcx(code, offset: offset)
        X64Register.rdx then emitLoadSlotRax(code, offset: offset)
        X64Register.rbx then emitLoadSlotRax(code, offset: offset)
        X64Register.rsp then emitLoadSlotRax(code, offset: offset)
        X64Register.rbp then emitLoadSlotRax(code, offset: offset)
        X64Register.rsi then emitLoadSlotRax(code, offset: offset)
        X64Register.rdi then emitLoadSlotRax(code, offset: offset)
        X64Register.r8 then emitLoadSlotRax(code, offset: offset)
        X64Register.r9 then emitLoadSlotRax(code, offset: offset)
        X64Register.r10 then emitLoadSlotRax(code, offset: offset)
        X64Register.r11 then emitLoadSlotRax(code, offset: offset)
    end 'pickReg'
end 'emitLoadSlotToReg'

function emitLoadSlotRax(code ByteArray, offset VarSlot)
    // mov rax, [rbp - offset]  =>  48 8B 45 <disp8>
    code.append(b"\x48\x8b\x45")
    code.push((0 - offset) and 0xFF)
end 'emitLoadSlotRax'

function emitLoadSlotRcx(code ByteArray, offset VarSlot)
    // mov rcx, [rbp - offset]  =>  48 8B 4D <disp8>
    code.append(b"\x48\x8b\x4d")
    code.push((0 - offset) and 0xFF)
end 'emitLoadSlotRcx'

function emitAddRegReg(code ByteArray)
    // add rax, rcx  =>  48 01 C8
    code.append(b"\x48\x01\xc8")
end 'emitAddRegReg'

function emitSubRegReg(code ByteArray)
    // sub rax, rcx  =>  48 29 C8  (rax = rax - rcx)
    code.append(b"\x48\x29\xc8")
end 'emitSubRegReg'

function emitImulRegReg(code ByteArray)
    // imul rax, rcx  =>  48 0F AF C1
    code.append(b"\x48\x0f\xaf\xc1")
end 'emitImulRegReg'

// CQO + IDIV RCX: sign-extend RAX into RDX:RAX, then divide. Quotient in RAX.
function emitIdivRcx(code ByteArray)
    // cqo  =>  48 99
    // idiv rcx  =>  48 F7 F9
    code.append(b"\x48\x99\x48\xf7\xf9")
end 'emitIdivRcx'

// CQO + IDIV RCX + MOV RAX,RDX: same as idiv but moves remainder to RAX.
function emitIremRcx(code ByteArray)
    // cqo; idiv rcx; mov rax, rdx
    code.append(b"\x48\x99\x48\xf7\xf9\x48\x89\xd0")
end 'emitIremRcx'

function emitNegReg(code ByteArray)
    // neg rax  =>  48 F7 D8
    code.append(b"\x48\xf7\xd8")
end 'emitNegReg'

function emitBitNotReg(code ByteArray)
    // not rax  =>  48 F7 D0
    code.append(b"\x48\xf7\xd0")
end 'emitBitNotReg'

function emitAndRegReg(code ByteArray)
    // and rax, rcx  =>  48 21 C8
    code.append(b"\x48\x21\xc8")
end 'emitAndRegReg'

function emitOrRegReg(code ByteArray)
    // or rax, rcx  =>  48 09 C8
    code.append(b"\x48\x09\xc8")
end 'emitOrRegReg'

function emitXorRegReg(code ByteArray)
    // xor rax, rcx  =>  48 31 C8
    code.append(b"\x48\x31\xc8")
end 'emitXorRegReg'

function emitShlRegCl(code ByteArray)
    // shl rax, cl  =>  48 D3 E0
    code.append(b"\x48\xd3\xe0")
end 'emitShlRegCl'

function emitSarRegCl(code ByteArray)
    // sar rax, cl  =>  48 D3 F8
    code.append(b"\x48\xd3\xf8")
end 'emitSarRegCl'

// cmp rax, rcx (sets flags based on rax - rcx)
function emitCmpRaxRcx(code ByteArray)
    // cmp rax, rcx  =>  48 39 C8
    code.append(b"\x48\x39\xc8")
end 'emitCmpRaxRcx'

function emitTestRaxRax(code ByteArray)
    // test rax, rax  =>  48 85 C0  (sets ZF if rax == 0)
    code.append(b"\x48\x85\xc0")
end 'emitTestRaxRax'

// ucomisd xmm0, xmm1 (compare float in xmm0 vs xmm1)
function emitUcomisd(code ByteArray)
    // movq xmm0, rcx; movq xmm1, rax; ucomisd xmm0, xmm1
    code.append(b"\x66\x48\x0f\x6e\xc1\x66\x48\x0f\x6e\xc8\x66\x0f\x2e\xc1")
end 'emitUcomisd'

// Map X64JumpCondition to its x86 Jcc opcode byte (second byte of 0F xx).
typealias CondJumpOpcode = int(0x80 to 0x8F)

function conditionToOpcode(cond X64JumpCondition) returns CondJumpOpcode
    match cond 'map'
        X64JumpCondition.e then return 0x84
        X64JumpCondition.ne then return 0x85
        X64JumpCondition.l then return 0x8C
        X64JumpCondition.le then return 0x8E
        X64JumpCondition.g then return 0x8F
        X64JumpCondition.ge then return 0x8D
        X64JumpCondition.b then return 0x82
        X64JumpCondition.be then return 0x86
        X64JumpCondition.a then return 0x87
        X64JumpCondition.ae then return 0x83
        X64JumpCondition.p then return 0x8A
        X64JumpCondition.np then return 0x8B
    end 'map'
end 'conditionToOpcode'

// Emit a 2-byte conditional jump (0F xx) with rel32 placeholder, record block fixup.
function emitCondJumpBlock(code ByteArray, blockFixups BlockJumpFixupArray, opcode CondJumpOpcode, targetBlock BlockId)
    code.push(0x0F)
    code.push(opcode)
    blockFixups.push(BlockJumpFixup{codeOffset: code.count(), targetBlockId: targetBlock})
    writeDword(code, value: 0)
end 'emitCondJumpBlock'

// Emit unconditional jump with rel32 placeholder, record block fixup.
function emitJmpBlock(code ByteArray, blockFixups BlockJumpFixupArray, targetBlock BlockId)
    // jmp rel32  =>  E9 <rel32>
    code.push(0xE9)
    blockFixups.push(BlockJumpFixup{codeOffset: code.count(), targetBlockId: targetBlock})
    writeDword(code, value: 0)
end 'emitJmpBlock'

// Resolve block jump fixups using the block offset table.
function resolveBlockFixups(code ByteArray, blockOffsets CodeOffsetArray, blockFixups BlockJumpFixupArray)
    for fixup in blockFixups 'resolve'
        let targetOffset = try blockOffsets.get(fixup.targetBlockId) otherwise 0
        let jumpEnd = fixup.codeOffset + 4
        let rel = targetOffset - jumpEnd
        patchDword(code, offset: fixup.codeOffset, value: rel)
    end 'resolve'
end 'resolveBlockFixups'

// Emit a relative call: call <rel32>
function emitRelativeCall(code ByteArray, targetOffset CodeOffset)
    code.push(0xE8)
    let callEnd = code.count() + 4
    let rel = targetOffset - callEnd
    code.push(rel and 0xFF)
    code.push((rel shr 8) and 0xFF)
    code.push((rel shr 16) and 0xFF)
    code.push((rel shr 24) and 0xFF)
end 'emitRelativeCall'

// --- Runtime Stubs (OS-neutral) ---

// i64_to_string(value_in_rcx, buffer_in_rdx) -> length in RAX
function emitI64ToString(code ByteArray) returns CodeOffset
    let offset = code.count()

    // Prologue: push rbp; mov rbp, rsp; sub rsp, 0x30
    // Save args: [rbp-8] = rcx, [rbp-16] = rdx
    // test rcx, rcx; jnz not_zero
    // Zero case: mov byte[rdx]='0'; mov byte[rdx+1]=0; mov rax,1; jmp epilogue
    code.append(b"\x55\x48\x89\xe5\x48\x83\xec\x30\x48\x89\x4d\xf8\x48\x89\x55\xf0\x48\x85\xc9\x75\x13\xc6\x02\x30\xc6\x42\x01\x00\x48\xc7\xc0\x01\x00\x00\x00\xe9")
    let jmpToEpilogueFixup1 = code.count()
    writeDword(code, value: 0)

    // Zero is_negative; test rcx; jns positive
    // neg rcx; save; mov rax,1; save flag
    code.append(b"\x48\xc7\x45\xe8\x00\x00\x00\x00\x48\x85\xc9\x79\x12\x48\xf7\xd9\x48\x89\x4d\xf8\x48\xc7\xc0\x01\x00\x00\x00\x48\x89\x45\xe8")

    // positive: mov r9, rdx; add r9, 20; mov byte [r9], 0
    code.append(b"\x49\x89\xd1\x49\x83\xc1\x14\x41\xc6\x01\x00")

    // digit_loop:
    let digitLoopOffset = code.count()

    // dec r9; mov rax,[rbp-8]; mov rcx,10; xor rdx,rdx; div rcx
    // mov [rbp-8],rax; add rdx,0x30; mov byte [r9],dl; cmp qword [rbp-8],0
    code.append(b"\x49\xff\xc9\x48\x8b\x45\xf8\x48\xc7\xc1\x0a\x00\x00\x00\x48\x31\xd2\x48\xf7\xf1\x48\x89\x45\xf8\x48\x83\xc2\x30\x41\x88\x11\x48\x83\x7d\xf8\x00")
    // jnz digit_loop
    code.push(0x75)
    let jnzTarget = digitLoopOffset - (code.count() + 1)
    code.push(jnzTarget and 0xFF)

    // Check is_negative; jz no_sign; dec r9; mov byte [r9], '-'
    // Compute length = (buffer+20) - r9; save length
    // Copy: mov rsi,r9; mov rdi,[rbp-16]; mov rcx,[rbp-24]; rep movsb
    // Return length in rax
    code.append(b"\x48\x8b\x45\xe8\x48\x85\xc0\x74\x07\x49\xff\xc9\x41\xc6\x01\x2d\x48\x8b\x45\xf0\x48\x83\xc0\x14\x4c\x29\xc8\x48\x89\x45\xe8\x4c\x89\xce\x48\x8b\x7d\xf0\x48\x8b\x4d\xe8\xf3\xa4\x48\x8b\x45\xe8")

    // epilogue label (patch jump from zero case)
    let epilogueOffset = code.count()
    let jmpRel = epilogueOffset - (jmpToEpilogueFixup1 + 4)
    patchDword(code, offset: jmpToEpilogueFixup1, value: jmpRel)

    // Epilogue: mov rsp, rbp; pop rbp; ret
    code.append(b"\x48\x89\xec\x5d\xc3")

    return offset
end 'emitI64ToString'

// --- Print Operations ---

// Emit printLiteral: jump over data island, then call write_stdout
function emitPrintLiteral(code ByteArray, data ByteArray, writeStdoutOffset CodeOffset)
    let dataLen = data.count()
    if dataLen == 0 'empty'
        return
    end 'empty'

    // jmp over data island: jmp rel32
    code.push(0xE9)
    let jmpFixup = code.count()
    writeDword(code, value: 0)

    // Data island
    let dataOffset = code.count()
    code.append(data)

    // Patch jump
    let afterData = code.count()
    patchDword(code, offset: jmpFixup, value: afterData - (jmpFixup + 4))

    // lea rcx, [rip + offset_to_data]
    code.append(b"\x48\x8d\x0d")
    let leaEnd = code.count() + 4
    let leaRel = dataOffset - leaEnd
    writeDword(code, value: leaRel)

    // mov rdx, dataLen
    code.append(b"\x48\xc7\xc2")
    writeDword(code, value: dataLen)

    // call write_stdout
    emitRelativeCall(code, targetOffset: writeStdoutOffset)
end 'emitPrintLiteral'

// Emit printInt: value assumed in RAX, convert to string then print
function emitPrintInt(code ByteArray, writeStdoutOffset CodeOffset, i64ToStringOffset CodeOffset)
    // mov rcx, rax; lea rdx, [rsp]
    code.append(b"\x48\x89\xc1\x48\x8d\x14\x24")

    // call i64_to_string (returns length in rax)
    emitRelativeCall(code, targetOffset: i64ToStringOffset)

    // mov rdx, rax (length); lea rcx, [rsp] (buffer ptr)
    code.append(b"\x48\x89\xc2\x48\x8d\x0c\x24")

    // call write_stdout
    emitRelativeCall(code, targetOffset: writeStdoutOffset)
end 'emitPrintInt'

// --- OS-parameterized stubs ---

// Emit _start: optional shadow space, call main, then exit via OsDescriptor strategy
function emitX86Start(code ByteArray, osDesc OsDescriptor, relocations RelocationArray, callFixups CallFixupArray) returns CodeOffset
    // Shadow space (Windows x64 ABI requires it)
    if osDesc.startShadowSpace > 0 'hasShadow'
        // sub rsp, shadowSpace
        code.append(b"\x48\x83\xec")
        code.push(osDesc.startShadowSpace and 0xFF)
    end 'hasShadow'

    // call main (relative call, patched by label resolution)
    code.push(0xE8)
    let mainCallFixupOffset = code.count()
    var mainName = ByteArray{}
    mainName.push(109)
    mainName.push(97)
    mainName.push(105)
    mainName.push(110)
    callFixups.push(CallFixup{codeOffset: mainCallFixupOffset, targetName: mainName})
    code.append(b"\x00\x00\x00\x00")

    // Exit using the OS-specified strategy
    match osDesc.exit 'exitStrategy'
        syscall(num) then emitX86ExitSyscall(code, syscallNumber: num)
        iatCall(slotIdx) then emitX86ExitIat(code, relocations: relocations, slotIndex: slotIdx)
    end 'exitStrategy'

    // int3 (unreachable)
    code.push(0xCC)
    return mainCallFixupOffset
end 'emitX86Start'

// Exit via syscall (Linux): mov edi, eax; mov eax, N; syscall
function emitX86ExitSyscall(code ByteArray, syscallNumber MachineWord)
    // mov edi, eax; mov eax, syscallNumber
    code.append(b"\x89\xc7\xb8")
    writeDword(code, value: syscallNumber)
    // syscall
    code.append(b"\x0f\x05")
end 'emitX86ExitSyscall'

// Exit via IAT (Windows): mov ecx, eax; call [rip+disp32]
function emitX86ExitIat(code ByteArray, relocations RelocationArray, slotIndex MachineWord)
    // mov ecx, eax; call [rip+disp32]
    code.append(b"\x89\xc1\xff\x15")
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: slotIndex})
    code.append(b"\x00\x00\x00\x00")
end 'emitX86ExitIat'

// Emit write_stdout stub parameterized by OsDescriptor
function emitX86WriteStdout(code ByteArray, osDesc OsDescriptor, relocations RelocationArray) returns CodeOffset
    let offset = code.count()
    match osDesc.write 'writeStrategy'
        syscall(writeNum, fd) then emitX86WriteStdoutSyscall(code, writeNumber: writeNum, fd: fd)
        winApi(getHandleSlot, handleConstant, writeFileSlot) then emitX86WriteStdoutWinApi(code, relocations: relocations, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot)
    end 'writeStrategy'
    return offset
end 'emitX86WriteStdout'

// write_stdout via syscall (Linux): args in rcx=ptr, rdx=len
function emitX86WriteStdoutSyscall(code ByteArray, writeNumber MachineWord, fd MachineWord)
    // Prologue; mov rsi, rcx; mov edi, fd
    code.append(b"\x55\x48\x89\xe5\x48\x89\xce\xbf")
    writeDword(code, value: fd)
    // mov eax, writeNumber; syscall; epilogue
    code.push(0xB8)
    writeDword(code, value: writeNumber)
    code.append(b"\x0f\x05\x5d\xc3")
end 'emitX86WriteStdoutSyscall'

// write_stdout via Win32 API (GetStdHandle + WriteFile through IAT)
function emitX86WriteStdoutWinApi(code ByteArray, relocations RelocationArray, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
    // Prologue; save args; zero bytesWritten; mov ecx, handleConstant
    code.append(b"\x55\x48\x89\xe5\x48\x83\xec\x40\x48\x89\x4d\xf8\x48\x89\x55\xf0\x48\xc7\x45\xe0\x00\x00\x00\x00\x48\xc7\xc1")
    writeDword(code, value: handleConstant)

    // call [rip+disp32] GetStdHandle
    code.append(b"\xff\x15")
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: getHandleSlot})
    writeDword(code, value: 0)

    // Save handle; load WriteFile args; mov qword [rsp+0x20], 0
    code.append(b"\x48\x89\x45\xe8\x48\x8b\x4d\xe8\x48\x8b\x55\xf8\x4c\x8b\x45\xf0\x4c\x8d\x4d\xe0\x48\xc7\x44\x24\x20\x00\x00\x00\x00")

    // call [rip+disp32] WriteFile
    code.append(b"\xff\x15")
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: writeFileSlot})
    writeDword(code, value: 0)

    // Epilogue: mov rsp, rbp; pop rbp; ret
    code.append(b"\x48\x89\xec\x5d\xc3")
end 'emitX86WriteStdoutWinApi'

// --- Call fixup resolution (inter-function) ---

// Emit call rel32 placeholder -- resolved after all functions are emitted.
function emitCallFixup(code ByteArray, callFixups CallFixupArray, target ByteArray)
    logTrace(LogCategory.codegen, message: "Call fixup to '{String.from(target)}' at offset {code.count()}")
    code.push(0xE8)
    let fixupOffset = code.count()
    callFixups.push(CallFixup{codeOffset: fixupOffset, targetName: target})
    code.append(b"\x00\x00\x00\x00")
end 'emitCallFixup'

function resolveCallFixups(code ByteArray, labelNames ByteArrayArray, labelOffsets CodeOffsetArray, callFixups CallFixupArray)
    logTrace(LogCategory.codegen, message: "Resolving {callFixups.count()} call fixups")
    for fixup in callFixups 'resolve'
        let targetOffset = lookupLabel(labelNames, labelOffsets: labelOffsets, name: fixup.targetName)
        let callEnd = fixup.codeOffset + 4
        let rel = targetOffset - callEnd
        patchDword(code, offset: fixup.codeOffset, value: rel)
    end 'resolve'
end 'resolveCallFixups'

function lookupLabel(labelNames ByteArrayArray, labelOffsets CodeOffsetArray, name ByteArray) returns CodeOffset
    for (i, labelName) in labelNames.enumerated() 'search'
        if bytesEqual(labelName, b: name) 'found'
            return try labelOffsets.get(i) otherwise 0
        end 'found'
    end 'search'
    logError(LogCategory.codegen, message: "Unresolved label '{String.from(name)}' -- call will jump to offset 0")
    return 0
end 'lookupLabel'

function recordLabel(labelNames ByteArrayArray, labelOffsets CodeOffsetArray, name ByteArray, offset CodeOffset)
    logTrace(LogCategory.codegen, message: "Label '{String.from(name)}' at code offset {offset}")
    labelNames.push(name)
    labelOffsets.push(offset)
end 'recordLabel'

// --- Main entry point ---

// Emit x86-64 machine code from a block-based MlirModule containing MaxX64Ops.
export function emitX86(module MlirModule, target TargetTriple, osDesc OsDescriptor) returns CodeResult
    logDebug(LogCategory.codegen, message: "Emitting block-based machine code ({tripleToString(target)})")
    var code = ByteArray{}
    code.reserve(1024)
    var relocations = RelocationArray{}
    var callFixups = CallFixupArray{}

    let mainCallFixupOffset = emitX86Start(code, osDesc: osDesc, relocations: relocations, callFixups: callFixups)

    logTrace(LogCategory.codegen, message: "Emitting runtime stubs at offset {code.count()}")
    let writeStdoutOff = emitX86WriteStdout(code, osDesc: osDesc, relocations: relocations)
    let i64ToStringOff = emitI64ToString(code)

    // Function label tables for inter-function call resolution
    var funcLabelNames = ByteArrayArray{}
    var funcLabelOffsets = CodeOffsetArray{}

    // Emit all functions
    for func in module.functions 'eachFunc'
        // Record function name -> code offset
        recordLabel(funcLabelNames, labelOffsets: funcLabelOffsets, name: func.name, offset: code.count())

        // Block offset table for this function (indexed by BlockId)
        var blockOffsets = CodeOffsetArray{}
        for bAlloc in 0 upto func.region.nextBlockId 'alloc'
            blockOffsets.push(0)
        end 'alloc'

        // Block jump fixups collected during emission, resolved per function
        var blockFixups = BlockJumpFixupArray{}

        // Emit all blocks in order
        for block in func.region.blocks 'eachBlock'
            // Record this block's code offset
            blockOffsets.set(block.id, value: code.count())

            // Emit all ops in the block
            for op in block.ops 'emitOps'
                emitMaxX64MlirOp(op, code: code, blockFixups: blockFixups, callFixups: callFixups, writeStdoutOff: writeStdoutOff, i64ToStringOff: i64ToStringOff)
            end 'emitOps'

            // Emit terminator if present (should already be lowered to maxx64 ops
            // pushed into block.ops by MidToMaxX64, but handle hasTerminator for safety)
            if block.hasTerminator 'hasTerm'
                emitMaxX64MlirOp(block.terminator, code: code, blockFixups: blockFixups, callFixups: callFixups, writeStdoutOff: writeStdoutOff, i64ToStringOff: i64ToStringOff)
            end 'hasTerm'
        end 'eachBlock'

        // Resolve block jump fixups for this function
        resolveBlockFixups(code, blockOffsets: blockOffsets, blockFixups: blockFixups)
    end 'eachFunc'

    // Resolve inter-function call fixups
    resolveCallFixups(code, labelNames: funcLabelNames, labelOffsets: funcLabelOffsets, callFixups: callFixups)

    logDebug(LogCategory.codegen, message: "Emitted {code.count()} bytes of machine code")
    return CodeResult{code: code, mainCallFixupOffset: mainCallFixupOffset, relocations: relocations}
end 'emitX86'

// Emit bytes for a single MlirOp (should be maxx64 at this stage).
function emitMaxX64MlirOp(op MlirOp, code ByteArray, blockFixups BlockJumpFixupArray, callFixups CallFixupArray, writeStdoutOff CodeOffset, i64ToStringOff CodeOffset)
    match op 'dispatch'
        maxx64(x64Op) then emitMaxX64Op(x64Op, code: code, blockFixups: blockFixups, callFixups: callFixups, writeStdoutOff: writeStdoutOff, i64ToStringOff: i64ToStringOff)
        arith(arithOp) then break 'dispatch'
        cf(cfOp) then break 'dispatch'
        func(funcOp) then break 'dispatch'
        memref(memOp) then break 'dispatch'
        runtime(rtOp) then break 'dispatch'
        maxarm64(armOp) then break 'dispatch'
        maxhl(hlOp) then break 'dispatch'
    end 'dispatch'
end 'emitMaxX64MlirOp'

// Emit bytes for a single MaxX64Op.
function emitMaxX64Op(op MaxX64Op, code ByteArray, blockFixups BlockJumpFixupArray, callFixups CallFixupArray, writeStdoutOff CodeOffset, i64ToStringOff CodeOffset)
    match op 'emit'
        prologue(stackSize) then emitPrologue(code, stackSize: stackSize)
        MaxX64Op.epilogue then emitEpilogue(code)
        movRegImm(dest, value) then emitMovRegImm(code, value: value)
        movSlot(slotIndex, srcReg) then emitMovSlot(code, slotIndex: slotIndex)
        loadSlot(destReg, slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: destReg)
        addRegReg(destReg, srcReg) then emitAddRegReg(code)
        subRegReg(destReg, srcReg) then emitSubRegReg(code)
        imulRegReg(destReg, srcReg) then emitImulRegReg(code)
        MaxX64Op.idivRcx then emitIdivRcx(code)
        MaxX64Op.iremRcx then emitIremRcx(code)
        negReg(reg) then emitNegReg(code)
        bitNotReg(reg) then emitBitNotReg(code)
        andRegReg(destReg, srcReg) then emitAndRegReg(code)
        orRegReg(destReg, srcReg) then emitOrRegReg(code)
        xorRegReg(destReg, srcReg) then emitXorRegReg(code)
        shlRegCl(reg) then emitShlRegCl(code)
        sarRegCl(reg) then emitSarRegCl(code)
        MaxX64Op.cmpRaxRcx then emitCmpRaxRcx(code)
        MaxX64Op.testRaxRax then emitTestRaxRax(code)
        condJump(condition, targetBlock) then emitCondJumpBlock(code, blockFixups: blockFixups, opcode: conditionToOpcode(condition), targetBlock: targetBlock)
        jmp(targetBlock) then emitJmpBlock(code, blockFixups: blockFixups, targetBlock: targetBlock)
        movF64Slot(slotIndex) then emitMovSlot(code, slotIndex: slotIndex)
        loadF64Slot(slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: X64Register.rax)
        movF64Rdata(rdataOffset) then emitMovRegImm(code, value: rdataOffset)
        MaxX64Op.ucomisd then emitUcomisd(code)
        printLiteral(data) then emitPrintLiteral(code, data: data, writeStdoutOffset: writeStdoutOff)
        MaxX64Op.printInt then emitPrintInt(code, writeStdoutOffset: writeStdoutOff, i64ToStringOffset: i64ToStringOff)
        callDirect(target) then emitCallFixup(code, callFixups: callFixups, target: target)
    end 'emit'
end 'emitMaxX64Op'

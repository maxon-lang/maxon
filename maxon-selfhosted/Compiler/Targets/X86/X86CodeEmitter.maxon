// X86 dialect ops to machine code bytes.
// OS-specific stubs are parameterized by OsDescriptor — no separate OS files needed.

export typealias X86OpArray = Array with X86Op
typealias CodeOffsetArray = Array with CodeOffset

function emitPrologue(code ByteBuffer, stackSize StackSize)
    // push rbp
    code.push(0x55)
    // mov rbp, rsp
    code.push(0x48)
    code.push(0x89)
    code.push(0xE5)
    // sub rsp, stackSize (only if non-zero)
    if stackSize > 0 'hasSub'
        code.push(0x48)
        code.push(0x83)
        code.push(0xEC)
        code.push(stackSize and 0xFF)
    end 'hasSub'
end 'emitPrologue'

function emitEpilogue(code ByteBuffer)
    // mov rsp, rbp
    code.push(0x48)
    code.push(0x89)
    code.push(0xEC)
    // pop rbp
    code.push(0x5D)
    // ret
    code.push(0xC3)
end 'emitEpilogue'

function emitMovRegImm(code ByteBuffer, value MachineWord)
    // mov rax, imm32 (sign-extended)
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC0)
    // imm32 little-endian
    code.push(value and 0xFF)
    code.push((value shr 8) and 0xFF)
    code.push((value shr 16) and 0xFF)
    code.push((value shr 24) and 0xFF)
end 'emitMovRegImm'

// Store RAX to stack slot: mov [rbp - (slotIndex+1)*8], rax
function emitMovSlot(code ByteBuffer, slotIndex VarSlot)
    let offset = (slotIndex + 1) * 8
    // mov [rbp - offset], rax  =>  48 89 45 <disp8>
    code.push(0x48)
    code.push(0x89)
    code.push(0x45)
    code.push((0 - offset) and 0xFF)
end 'emitMovSlot'

// Load stack slot to a register: mov REG, [rbp - (slotIndex+1)*8]
function emitLoadSlotToReg(code ByteBuffer, slotIndex VarSlot, dest X86Register)
    let offset = (slotIndex + 1) * 8
    match dest 'pickReg'
        X86Register.rax then emitLoadSlotRax(code, offset: offset)
        X86Register.rcx then emitLoadSlotRcx(code, offset: offset)
        X86Register.rdx then emitLoadSlotRax(code, offset: offset)
        X86Register.rbx then emitLoadSlotRax(code, offset: offset)
        X86Register.rsp then emitLoadSlotRax(code, offset: offset)
        X86Register.rbp then emitLoadSlotRax(code, offset: offset)
        X86Register.rsi then emitLoadSlotRax(code, offset: offset)
        X86Register.rdi then emitLoadSlotRax(code, offset: offset)
        X86Register.r8 then emitLoadSlotRax(code, offset: offset)
        X86Register.r9 then emitLoadSlotRax(code, offset: offset)
        X86Register.r10 then emitLoadSlotRax(code, offset: offset)
        X86Register.r11 then emitLoadSlotRax(code, offset: offset)
    end 'pickReg'
end 'emitLoadSlotToReg'

function emitLoadSlotRax(code ByteBuffer, offset VarSlot)
    // mov rax, [rbp - offset]  =>  48 8B 45 <disp8>
    code.push(0x48)
    code.push(0x8B)
    code.push(0x45)
    code.push((0 - offset) and 0xFF)
end 'emitLoadSlotRax'

function emitLoadSlotRcx(code ByteBuffer, offset VarSlot)
    // mov rcx, [rbp - offset]  =>  48 8B 4D <disp8>
    code.push(0x48)
    code.push(0x8B)
    code.push(0x4D)
    code.push((0 - offset) and 0xFF)
end 'emitLoadSlotRcx'

// Save RAX to RCX before loading second operand
function emitMovRcxRax(code ByteBuffer)
    // mov rcx, rax  =>  48 89 C1
    code.push(0x48)
    code.push(0x89)
    code.push(0xC1)
end 'emitMovRcxRax'

function emitAddRegReg(code ByteBuffer)
    // add rax, rcx  =>  48 01 C8
    code.push(0x48)
    code.push(0x01)
    code.push(0xC8)
end 'emitAddRegReg'

function emitSubRegReg(code ByteBuffer)
    // After push/pop: rcx=left, rax=right. We want left-right.
    // xchg rax, rcx  =>  48 91
    code.push(0x48)
    code.push(0x91)
    // sub rax, rcx  =>  48 29 C8  (now rax=left - right)
    code.push(0x48)
    code.push(0x29)
    code.push(0xC8)
end 'emitSubRegReg'

function emitImulRegReg(code ByteBuffer)
    // imul rax, rcx  =>  48 0F AF C1
    code.push(0x48)
    code.push(0x0F)
    code.push(0xAF)
    code.push(0xC1)
end 'emitImulRegReg'

// cmp rcx, rax (compare left in rcx against right in rax)
function emitCmpRaxRcx(code ByteBuffer)
    // cmp rcx, rax  =>  48 39 C1
    code.push(0x48)
    code.push(0x39)
    code.push(0xC1)
end 'emitCmpRaxRcx'

// ucomisd xmm0, xmm1 (compare float in xmm0 vs xmm1)
// After push/pop: rcx=left raw bits, rax=right raw bits
// We need to move them to xmm registers first
function emitUcomisd(code ByteBuffer)
    // movq xmm0, rcx  =>  66 48 0F 6E C1
    code.push(0x66)
    code.push(0x48)
    code.push(0x0F)
    code.push(0x6E)
    code.push(0xC1)
    // movq xmm1, rax  =>  66 48 0F 6E C8
    code.push(0x66)
    code.push(0x48)
    code.push(0x0F)
    code.push(0x6E)
    code.push(0xC8)
    // ucomisd xmm0, xmm1  =>  66 0F 2E C1
    code.push(0x66)
    code.push(0x0F)
    code.push(0x2E)
    code.push(0xC1)
end 'emitUcomisd'

// Conditional and unconditional jumps with label fixup
type JumpFixup
    export var codeOffset CodeOffset
    export var targetLabel ByteArray
end 'JumpFixup'
typealias JumpFixupArray = Array with JumpFixup
typealias CondJumpOpcode = int(0x80 to 0x8F)

// Map a JumpCondition union to its x86 Jcc opcode byte (second byte of 0F xx).
function conditionToOpcode(cond JumpCondition) returns CondJumpOpcode
    match cond 'map'
        JumpCondition.e then return 0x84
        JumpCondition.ne then return 0x85
        JumpCondition.l then return 0x8C
        JumpCondition.le then return 0x8E
        JumpCondition.g then return 0x8F
        JumpCondition.ge then return 0x8D
        JumpCondition.b then return 0x82
        JumpCondition.be then return 0x86
        JumpCondition.a then return 0x87
        JumpCondition.ae then return 0x83
        JumpCondition.p then return 0x8A
        JumpCondition.np then return 0x8B
    end 'map'
end 'conditionToOpcode'

// Emit a 2-byte conditional jump (0F xx) with rel32 fixup.
function emitCondJump(code ByteBuffer, jumpFixups JumpFixupArray, opcode CondJumpOpcode, targetLabel ByteArray)
    code.push(0x0F)
    code.push(opcode)
    jumpFixups.push(JumpFixup{codeOffset: code.count(), targetLabel: targetLabel})
    writeDword(code, value: 0)
end 'emitCondJump'

function emitJmp(code ByteBuffer, jumpFixups JumpFixupArray, targetLabel ByteArray)
    // jmp rel32  =>  E9 <rel32>
    code.push(0xE9)
    jumpFixups.push(JumpFixup{codeOffset: code.count(), targetLabel: targetLabel})
    writeDword(code, value: 0)
end 'emitJmp'

function resolveJumpFixups(code ByteBuffer, labelNames ByteArrayArray, labelOffsets CodeOffsetArray, jumpFixups JumpFixupArray)
    for fixup in jumpFixups 'resolve'
        let targetOffset = lookupLabel(labelNames, labelOffsets: labelOffsets, name: fixup.targetLabel)
        let jumpEnd = fixup.codeOffset + 4
        let rel = targetOffset - jumpEnd
        patchDword(code, offset:fixup.codeOffset, value: rel)
    end 'resolve'
end 'resolveJumpFixups'

// Emit a relative call: call <rel32>
function emitRelativeCall(code ByteBuffer, targetOffset CodeOffset)
    code.push(0xE8)
    let callEnd = code.count() + 4
    let rel = targetOffset - callEnd
    code.push(rel and 0xFF)
    code.push((rel shr 8) and 0xFF)
    code.push((rel shr 16) and 0xFF)
    code.push((rel shr 24) and 0xFF)
end 'emitRelativeCall'


// --- Runtime Stubs (OS-neutral) ---

// i64_to_string(value_in_rcx, buffer_in_rdx) -> length in RAX
// Stack: [rbp-8]=value, [rbp-16]=buffer, [rbp-24]=is_negative/length
function emitI64ToString(code ByteBuffer) returns CodeOffset
    let offset = code.count()

    // Prologue: push rbp; mov rbp, rsp; sub rsp, 0x30
    code.push(0x55)
    code.push(0x48)
    code.push(0x89)
    code.push(0xE5)
    code.push(0x48)
    code.push(0x83)
    code.push(0xEC)
    code.push(0x30)

    // Save args: [rbp-8] = rcx (value), [rbp-16] = rdx (buffer)
    code.push(0x48)
    code.push(0x89)
    code.push(0x4D)
    code.push(0xF8)
    code.push(0x48)
    code.push(0x89)
    code.push(0x55)
    code.push(0xF0)

    // Special case: value == 0
    // test rcx, rcx
    code.push(0x48)
    code.push(0x85)
    code.push(0xC9)
    // jnz not_zero (skip 19 bytes: mov byte[rdx]='0'(3) + mov byte[rdx+1]=0(4) + mov rax,1(7) + jmp epilogue(5))
    code.push(0x75)
    code.push(0x13)
    // mov byte [rdx], '0'
    code.push(0xC6)
    code.push(0x02)
    code.push(0x30)
    // mov byte [rdx+1], 0
    code.push(0xC6)
    code.push(0x42)
    code.push(0x01)
    code.push(0x00)
    // mov rax, 1
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC0)
    code.push(0x01)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    // jmp epilogue (will be patched)
    code.push(0xE9)
    let jmpToEpilogueFixup1 = code.count()
    writeDword(code, value: 0)

    // Zero is_negative: mov qword [rbp-24], 0
    code.push(0x48)
    code.push(0xC7)
    code.push(0x45)
    code.push(0xE8)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // test rcx, rcx
    code.push(0x48)
    code.push(0x85)
    code.push(0xC9)
    // jns positive (skip 18 bytes: neg + save + mov_rax_1 + save_flag)
    code.push(0x79)
    code.push(0x12)

    // neg rcx
    code.push(0x48)
    code.push(0xF7)
    code.push(0xD9)
    // mov [rbp-8], rcx (update saved value)
    code.push(0x48)
    code.push(0x89)
    code.push(0x4D)
    code.push(0xF8)
    // mov rax, 1 (is_negative = 1)
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC0)
    code.push(0x01)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    // mov [rbp-24], rax
    code.push(0x48)
    code.push(0x89)
    code.push(0x45)
    code.push(0xE8)

    // positive: r9 = buffer + 20
    // mov r9, rdx
    code.push(0x49)
    code.push(0x89)
    code.push(0xD1)
    // add r9, 20
    code.push(0x49)
    code.push(0x83)
    code.push(0xC1)
    code.push(0x14)
    // mov byte [r9], 0 (null terminator)
    code.push(0x41)
    code.push(0xC6)
    code.push(0x01)
    code.push(0x00)

    // digit_loop:
    let digitLoopOffset = code.count()

    // dec r9
    code.push(0x49)
    code.push(0xFF)
    code.push(0xC9)
    // mov rax, [rbp-8] (value/quotient)
    code.push(0x48)
    code.push(0x8B)
    code.push(0x45)
    code.push(0xF8)
    // mov rcx, 10
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC1)
    code.push(0x0A)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    // xor rdx, rdx
    code.push(0x48)
    code.push(0x31)
    code.push(0xD2)
    // div rcx (unsigned: rax=quotient, rdx=remainder)
    code.push(0x48)
    code.push(0xF7)
    code.push(0xF1)
    // mov [rbp-8], rax (store quotient)
    code.push(0x48)
    code.push(0x89)
    code.push(0x45)
    code.push(0xF8)
    // add rdx, 0x30 ('0')
    code.push(0x48)
    code.push(0x83)
    code.push(0xC2)
    code.push(0x30)
    // mov byte [r9], dl
    code.push(0x41)
    code.push(0x88)
    code.push(0x11)
    // cmp qword [rbp-8], 0
    code.push(0x48)
    code.push(0x83)
    code.push(0x7D)
    code.push(0xF8)
    code.push(0x00)
    // jnz digit_loop
    code.push(0x75)
    let jnzTarget = digitLoopOffset - (code.count() + 1)
    code.push(jnzTarget and 0xFF)

    // Check is_negative: mov rax, [rbp-24]; test rax, rax; jz no_sign
    code.push(0x48)
    code.push(0x8B)
    code.push(0x45)
    code.push(0xE8)
    code.push(0x48)
    code.push(0x85)
    code.push(0xC0)
    // jz no_sign (skip 7 bytes: dec r9 + mov byte [r9], '-')
    code.push(0x74)
    code.push(0x07)
    // dec r9
    code.push(0x49)
    code.push(0xFF)
    code.push(0xC9)
    // mov byte [r9], '-'
    code.push(0x41)
    code.push(0xC6)
    code.push(0x01)
    code.push(0x2D)

    // no_sign: compute length = (buffer + 20) - r9
    // mov rax, [rbp-16] (buffer)
    code.push(0x48)
    code.push(0x8B)
    code.push(0x45)
    code.push(0xF0)
    // add rax, 20
    code.push(0x48)
    code.push(0x83)
    code.push(0xC0)
    code.push(0x14)
    // sub rax, r9 => length
    code.push(0x4C)
    code.push(0x29)
    code.push(0xC8)

    // Save length: mov [rbp-24], rax
    code.push(0x48)
    code.push(0x89)
    code.push(0x45)
    code.push(0xE8)

    // Copy digits from r9 to buffer: rsi=r9, rdi=buffer, rcx=length
    // mov rsi, r9
    code.push(0x4C)
    code.push(0x89)
    code.push(0xCE)
    // mov rdi, [rbp-16]
    code.push(0x48)
    code.push(0x8B)
    code.push(0x7D)
    code.push(0xF0)
    // mov rcx, [rbp-24] (length)
    code.push(0x48)
    code.push(0x8B)
    code.push(0x4D)
    code.push(0xE8)
    // rep movsb
    code.push(0xF3)
    code.push(0xA4)

    // Return length in rax
    code.push(0x48)
    code.push(0x8B)
    code.push(0x45)
    code.push(0xE8)

    // epilogue label (patch jump from zero case)
    let epilogueOffset = code.count()
    let jmpRel = epilogueOffset - (jmpToEpilogueFixup1 + 4)
    patchDword(code, offset:jmpToEpilogueFixup1, value: jmpRel)

    // Epilogue: mov rsp, rbp; pop rbp; ret
    code.push(0x48)
    code.push(0x89)
    code.push(0xEC)
    code.push(0x5D)
    code.push(0xC3)

    return offset
end 'emitI64ToString'

// --- Print Operations ---

// Emit printLiteral: jump over data island, then call write_stdout
function emitPrintLiteral(code ByteBuffer, data ByteArray, writeStdoutOffset CodeOffset)
    let dataLen = data.count()
    if dataLen == 0 'empty'
        return
    end 'empty'

    // jmp over data island: jmp rel32
    code.push(0xE9)
    let jmpFixup = code.count()
    writeDword(code, value: 0)

    // Data island
    let dataOffset = code.count()
    var dataIdx = 0
    while dataIdx < dataLen 'copyData'
        code.push(try data.get(dataIdx) otherwise 0)
        dataIdx = dataIdx + 1
    end 'copyData'

    // Patch jump
    let afterData = code.count()
    patchDword(code, offset:jmpFixup, value: afterData - (jmpFixup + 4))

    // lea rcx, [rip + offset_to_data]
    code.push(0x48)
    code.push(0x8D)
    code.push(0x0D)
    let leaEnd = code.count() + 4
    let leaRel = dataOffset - leaEnd
    writeDword(code, value: leaRel)

    // mov rdx, dataLen
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC2)
    writeDword(code, value: dataLen)

    // call write_stdout
    emitRelativeCall(code, targetOffset: writeStdoutOffset)
end 'emitPrintLiteral'

// Emit printInt: value assumed in RAX, convert to string then print
// Uses stack buffer at [rbp-<high offset>] for the conversion buffer
function emitPrintInt(code ByteBuffer, writeStdoutOffset CodeOffset, i64ToStringOffset CodeOffset)
    // Save rax (the value) to rcx for i64_to_string arg1
    // mov rcx, rax
    code.push(0x48)
    code.push(0x89)
    code.push(0xC1)

    // lea rdx, [rsp] (use current stack top as buffer - we have space from prologue)
    code.push(0x48)
    code.push(0x8D)
    code.push(0x14)
    code.push(0x24)

    // call i64_to_string (returns length in rax)
    emitRelativeCall(code, targetOffset: i64ToStringOffset)

    // Now rax = length, buffer at rsp
    // mov rdx, rax (length)
    code.push(0x48)
    code.push(0x89)
    code.push(0xC2)

    // lea rcx, [rsp] (buffer ptr)
    code.push(0x48)
    code.push(0x8D)
    code.push(0x0C)
    code.push(0x24)

    // call write_stdout
    emitRelativeCall(code, targetOffset: writeStdoutOffset)
end 'emitPrintInt'

// --- Main entry point ---

// Emit X86 code for any OS target using OsDescriptor
export function emitX86(stdOps StdOpArray, target TargetTriple, osDesc OsDescriptor) returns CodeResult
    let x86Ops = lowerStdOpsToX86(stdOps, target: target)
    logDebug(LogCategory.codegen, message: "Emitting machine code for {x86Ops.count()} X86 ops ({tripleToString(target)})")
    var code = ByteBuffer{}
    code.reserve(1024)
    var relocations = RelocationArray{}
    var callFixups = CallFixupArray{}
    var jumpFixups = JumpFixupArray{}

    let mainCallFixupOffset = emitX86Start(code, osDesc: osDesc, relocations: relocations, callFixups: callFixups)

    logTrace(LogCategory.codegen, message: "Emitting runtime stubs at offset {code.count()}")
    let writeStdoutOff = emitX86WriteStdout(code, osDesc: osDesc, relocations: relocations)
    let i64ToStringOff = emitI64ToString(code)

    return emitX86Core(x86Ops, code: code, relocations: relocations, callFixups: callFixups, jumpFixups: jumpFixups, mainCallFixupOffset: mainCallFixupOffset, writeStdoutOff: writeStdoutOff, i64ToStringOff: i64ToStringOff)
end 'emitX86'

// --- OS-parameterized stubs ---

// Emit _start: optional shadow space, call main, then exit via OsDescriptor strategy
function emitX86Start(code ByteBuffer, osDesc OsDescriptor, relocations RelocationArray, callFixups CallFixupArray) returns CodeOffset
    // Shadow space (Windows x64 ABI requires it)
    if osDesc.startShadowSpace > 0 'hasShadow'
        // sub rsp, shadowSpace
        code.push(0x48)
        code.push(0x83)
        code.push(0xEC)
        code.push(osDesc.startShadowSpace and 0xFF)
    end 'hasShadow'

    // call main (relative call, patched by label resolution)
    code.push(0xE8)
    let mainCallFixupOffset = code.count()
    var mainName = ByteArray{}
    mainName.push(109)
    mainName.push(97)
    mainName.push(105)
    mainName.push(110)
    callFixups.push(CallFixup{codeOffset: mainCallFixupOffset, targetName: mainName})
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // Exit using the OS-specified strategy
    match osDesc.exit 'exitStrategy'
        syscall(num) then emitX86ExitSyscall(code, syscallNumber: num)
        iatCall(slotIdx) then emitX86ExitIat(code, relocations: relocations, slotIndex: slotIdx)
    end 'exitStrategy'

    // int3 (unreachable)
    code.push(0xCC)
    return mainCallFixupOffset
end 'emitX86Start'

// Exit via syscall (Linux): mov edi, eax; mov eax, N; syscall
function emitX86ExitSyscall(code ByteBuffer, syscallNumber MachineWord)
    // mov edi, eax (return value -> first arg)
    code.push(0x89)
    code.push(0xC7)
    // mov eax, syscallNumber
    code.push(0xB8)
    code.push(syscallNumber and 0xFF)
    code.push((syscallNumber shr 8) and 0xFF)
    code.push((syscallNumber shr 16) and 0xFF)
    code.push((syscallNumber shr 24) and 0xFF)
    // syscall
    code.push(0x0F)
    code.push(0x05)
end 'emitX86ExitSyscall'

// Exit via IAT (Windows): mov ecx, eax; call [rip+disp32]
function emitX86ExitIat(code ByteBuffer, relocations RelocationArray, slotIndex MachineWord)
    // mov ecx, eax (return value -> first arg for ExitProcess)
    code.push(0x89)
    code.push(0xC1)
    // call [rip+disp32] (indirect through IAT)
    code.push(0xFF)
    code.push(0x15)
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: slotIndex})
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
end 'emitX86ExitIat'

// Emit write_stdout stub parameterized by OsDescriptor
function emitX86WriteStdout(code ByteBuffer, osDesc OsDescriptor, relocations RelocationArray) returns CodeOffset
    let offset = code.count()
    match osDesc.write 'writeStrategy'
        syscall(writeNum, fd) then emitX86WriteStdoutSyscall(code, writeNumber: writeNum, fd: fd)
        winApi(getHandleSlot, handleConstant, writeFileSlot) then emitX86WriteStdoutWinApi(code, relocations: relocations, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot)
    end 'writeStrategy'
    return offset
end 'emitX86WriteStdout'

// write_stdout via syscall (Linux): args in rcx=ptr, rdx=len
function emitX86WriteStdoutSyscall(code ByteBuffer, writeNumber MachineWord, fd MachineWord)
    // Prologue
    code.push(0x55)
    code.push(0x48)
    code.push(0x89)
    code.push(0xE5)

    // System V ABI: rdi=fd, rsi=buf, rdx=count, rax=syscall#
    // mov rsi, rcx (buf)
    code.push(0x48)
    code.push(0x89)
    code.push(0xCE)
    // mov edi, fd
    code.push(0xBF)
    code.push(fd and 0xFF)
    code.push((fd shr 8) and 0xFF)
    code.push((fd shr 16) and 0xFF)
    code.push((fd shr 24) and 0xFF)
    // mov eax, writeNumber
    code.push(0xB8)
    code.push(writeNumber and 0xFF)
    code.push((writeNumber shr 8) and 0xFF)
    code.push((writeNumber shr 16) and 0xFF)
    code.push((writeNumber shr 24) and 0xFF)
    // syscall
    code.push(0x0F)
    code.push(0x05)

    // Epilogue
    code.push(0x5D)
    code.push(0xC3)
end 'emitX86WriteStdoutSyscall'

// write_stdout via Win32 API (GetStdHandle + WriteFile through IAT)
function emitX86WriteStdoutWinApi(code ByteBuffer, relocations RelocationArray, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
    // Prologue: push rbp; mov rbp, rsp; sub rsp, 0x40
    code.push(0x55)
    code.push(0x48)
    code.push(0x89)
    code.push(0xE5)
    code.push(0x48)
    code.push(0x83)
    code.push(0xEC)
    code.push(0x40)

    // Save args: [rbp-8] = rcx (ptr), [rbp-16] = rdx (len)
    code.push(0x48)
    code.push(0x89)
    code.push(0x4D)
    code.push(0xF8)
    code.push(0x48)
    code.push(0x89)
    code.push(0x55)
    code.push(0xF0)

    // Zero bytesWritten: mov qword [rbp-32], 0
    code.push(0x48)
    code.push(0xC7)
    code.push(0x45)
    code.push(0xE0)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // GetStdHandle(handleConstant): mov ecx, handleConstant
    code.push(0x48)
    code.push(0xC7)
    code.push(0xC1)
    code.push(handleConstant and 0xFF)
    code.push((handleConstant shr 8) and 0xFF)
    code.push((handleConstant shr 16) and 0xFF)
    code.push((handleConstant shr 24) and 0xFF)

    // call [rip+disp32] GetStdHandle
    code.push(0xFF)
    code.push(0x15)
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: getHandleSlot})
    writeDword(code, value: 0)

    // Save handle: mov [rbp-24], rax
    code.push(0x48)
    code.push(0x89)
    code.push(0x45)
    code.push(0xE8)

    // WriteFile(handle, buffer, length, &bytesWritten, NULL)
    // arg1: mov rcx, [rbp-24] (handle)
    code.push(0x48)
    code.push(0x8B)
    code.push(0x4D)
    code.push(0xE8)
    // arg2: mov rdx, [rbp-8] (buffer ptr)
    code.push(0x48)
    code.push(0x8B)
    code.push(0x55)
    code.push(0xF8)
    // arg3: mov r8, [rbp-16] (length)
    code.push(0x4C)
    code.push(0x8B)
    code.push(0x45)
    code.push(0xF0)
    // arg4: lea r9, [rbp-32] (&bytesWritten)
    code.push(0x4C)
    code.push(0x8D)
    code.push(0x4D)
    code.push(0xE0)
    // arg5: mov qword [rsp+0x20], 0 (lpOverlapped = NULL)
    code.push(0x48)
    code.push(0xC7)
    code.push(0x44)
    code.push(0x24)
    code.push(0x20)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // call [rip+disp32] WriteFile
    code.push(0xFF)
    code.push(0x15)
    relocations.push(Relocation{codeOffset: code.count(), slotIndex: writeFileSlot})
    writeDword(code, value: 0)

    // Epilogue: mov rsp, rbp; pop rbp; ret
    code.push(0x48)
    code.push(0x89)
    code.push(0xEC)
    code.push(0x5D)
    code.push(0xC3)
end 'emitX86WriteStdoutWinApi'

// Core X86 instruction emission loop — OS-neutral
function emitX86Core(x86Ops X86OpArray, code ByteBuffer, relocations RelocationArray, callFixups CallFixupArray, jumpFixups JumpFixupArray, mainCallFixupOffset CodeOffset, writeStdoutOff CodeOffset, i64ToStringOff CodeOffset) returns CodeResult
    var labelNames = ByteArrayArray{}
    var labelOffsets = CodeOffsetArray{}

    // Emit all function bodies
    logTrace(LogCategory.codegen, message: "{x86Ops.count()} x86 ops to emit")
    for op in x86Ops 'opLoop'
        match op 'emit'
            funcLabel(name) then recordLabel(labelNames, labelOffsets: labelOffsets, name: name, offset: code.count())
            callDirect(target) then emitCallFixup(code, callFixups: callFixups, target: target)
            prologue(stackSize) then emitPrologue(code, stackSize: stackSize)
            epilogue then emitEpilogue(code)
            movRegImm(dest, value) then emitMovRegImm(code, value: value)
            movSlot(slotIndex, srcReg) then emitMovSlot(code, slotIndex: slotIndex)
            loadSlot(destReg, slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: destReg)
            addRegReg(destReg, srcReg) then emitAddRegReg(code)
            subRegReg(destReg, srcReg) then emitSubRegReg(code)
            imulRegReg(destReg, srcReg) then emitImulRegReg(code)
            cmpRaxRcx then emitCmpRaxRcx(code)
            condJump(condition, targetLabel) then emitCondJump(code, jumpFixups: jumpFixups, opcode: conditionToOpcode(condition), targetLabel: targetLabel)
            jmp(targetLabel) then emitJmp(code, jumpFixups: jumpFixups, targetLabel: targetLabel)
            label(name) then recordLabel(labelNames, labelOffsets: labelOffsets, name: name, offset: code.count())
            movF64Slot(slotIndex) then emitMovSlot(code, slotIndex: slotIndex)
            loadF64Slot(slotIndex) then emitLoadSlotToReg(code, slotIndex: slotIndex, dest: X86Register.rax)
            movF64Rdata(rdataOffset) then emitMovRegImm(code, value: rdataOffset)
            ucomisd then emitUcomisd(code)
            printLiteral(data) then emitPrintLiteral(code, data: data, writeStdoutOffset: writeStdoutOff)
            printInt then emitPrintInt(code, writeStdoutOffset: writeStdoutOff, i64ToStringOffset: i64ToStringOff)
        end 'emit'
    end 'opLoop'

    // Resolve all call and jump fixups using recorded labels
    resolveCallFixups(code, labelNames: labelNames, labelOffsets: labelOffsets, callFixups: callFixups)
    resolveJumpFixups(code, labelNames: labelNames, labelOffsets: labelOffsets, jumpFixups: jumpFixups)

    logDebug(LogCategory.codegen, message: "Emitted {code.count()} bytes of machine code")
    return CodeResult{code: code, mainCallFixupOffset: mainCallFixupOffset, relocations: relocations}
end 'emitX86Core'

function recordLabel(labelNames ByteArrayArray, labelOffsets CodeOffsetArray, name ByteArray, offset CodeOffset)
    logTrace(LogCategory.codegen, message: "Label '{String.from(name)}' at code offset {offset}")
    labelNames.push(name)
    labelOffsets.push(offset)
end 'recordLabel'

// Emit call rel32 placeholder — resolved after all functions are emitted.
// Safe for zero-arg calls where stack is aligned by caller's prologue.
function emitCallFixup(code ByteBuffer, callFixups CallFixupArray, target ByteArray)
    logTrace(LogCategory.codegen, message: "Call fixup to '{String.from(target)}' at offset {code.count()}")
    code.push(0xE8)
    let fixupOffset = code.count()
    callFixups.push(CallFixup{codeOffset: fixupOffset, targetName: target})
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
end 'emitCallFixup'

function resolveCallFixups(code ByteBuffer, labelNames ByteArrayArray, labelOffsets CodeOffsetArray, callFixups CallFixupArray)
    logTrace(LogCategory.codegen, message: "Resolving {callFixups.count()} call fixups")
    for fixup in callFixups 'resolve'
        let targetOffset = lookupLabel(labelNames, labelOffsets: labelOffsets, name: fixup.targetName)
        let callEnd = fixup.codeOffset + 4
        let rel = targetOffset - callEnd
        patchDword(code, offset: fixup.codeOffset, value: rel)
    end 'resolve'
end 'resolveCallFixups'


function lookupLabel(labelNames ByteArrayArray, labelOffsets CodeOffsetArray, name ByteArray) returns CodeOffset
    var i = 0
    while i < labelNames.count() 'search'
        let labelName = try labelNames.get(i) otherwise 'next'
            i = i + 1
            continue
        end 'next'
        if bytesEqual(labelName, b: name) 'found'
            return try labelOffsets.get(i) otherwise 0
        end 'found'
        i = i + 1
    end 'search'
    logError(LogCategory.codegen, message: "Unresolved label '{String.from(name)}' -- call will jump to offset 0")
    return 0
end 'lookupLabel'

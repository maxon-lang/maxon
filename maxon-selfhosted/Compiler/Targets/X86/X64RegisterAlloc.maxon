// XMM FP helpers
function ax64MovXmmXmm(state RegState, dest X64FpVReg, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let srcPhysFpOrd = match src 'checkPhysSrc'
		physical(reg) gives reg.rawValue
		virtual gives RM_NONE
	end 'checkPhysSrc'
	let destVirtFpId = x64FpVRegId(dest)
	if srcPhysFpOrd != RM_NONE and destVirtFpId >= 0 'physToVirt'
		let occ = rmGetOr(state.fpContents, index: srcPhysFpOrd, fallback: RM_NONE)
		if occ == destVirtFpId 'alreadyAssigned'
			return
		end 'alreadyAssigned'
		if occ != RM_NONE 'hasOcc'
			rmSpillFpIfOccupied(state, fpOrdinal: srcPhysFpOrd, dstBlock: dstBlock)
		end 'hasOcc'
		rmAssignFp(state, fpOrdinal: srcPhysFpOrd, valueId: destVirtFpId)
		return
	end 'physToVirt'
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	if s != d 'needFpMov'
		dstBlock.ops.push(MlirOp.x64(X64Op.movXmmXmm(x64FpPhysFromOrd(d), x64FpPhysFromOrd(s), precision)))
	end 'needFpMov'
end 'ax64MovXmmXmm'

function ax64SpillXmmToStack(state RegState, offset MachineWord, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.x64(X64Op.spillXmmToStack(offset, x64FpPhysFromOrd(s), precision)))
end 'ax64SpillXmmToStack'

function ax64ReloadXmmFromStack(state RegState, dest X64FpVReg, offset MachineWord, precision FloatPrecision, dstBlock MlirBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.x64(X64Op.reloadXmmFromStack(x64FpPhysFromOrd(d), offset, precision)))
end 'ax64ReloadXmmFromStack'

function ax64MovXmmRipRel(state RegState, dest X64FpVReg, rdataLabel ByteArray, precision FloatPrecision, dstBlock MlirBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.x64(X64Op.movXmmRipRel(x64FpPhysFromOrd(d), rdataLabel, precision)))
end 'ax64MovXmmRipRel'

function ax64FpTwoAddr(state RegState, dest X64FpVReg, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock, op FpTwoAddrOp)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = x64ResolveFpUse(state, vreg: dest, dstBlock: dstBlock)
	let dp = x64FpPhysFromOrd(d)
	let sp = x64FpPhysFromOrd(s)
	match op 'emit'
		add then dstBlock.ops.push(MlirOp.x64(X64Op.addXmm(dp, sp, precision)))
		sub then dstBlock.ops.push(MlirOp.x64(X64Op.subXmm(dp, sp, precision)))
		mul then dstBlock.ops.push(MlirOp.x64(X64Op.mulXmm(dp, sp, precision)))
		div then dstBlock.ops.push(MlirOp.x64(X64Op.divXmm(dp, sp, precision)))
	end 'emit'
end 'ax64FpTwoAddr'

function ax64SqrtXmm(state RegState, dest X64FpVReg, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.x64(X64Op.sqrtXmm(x64FpPhysFromOrd(d), x64FpPhysFromOrd(s), precision)))
end 'ax64SqrtXmm'


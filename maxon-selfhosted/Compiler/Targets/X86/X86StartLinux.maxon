// Linux-specific X86 runtime stubs: _start wrapper and write_stdout via syscalls.

// Linux _start: call main, then exit syscall (rax=60, rdi=return value)
export function emitStartLinux(code ByteBuffer, callFixups CallFixupArray) returns CodeOffset
    // call main
    code.push(0xE8)
    let mainCallFixupOffset = code.count()
    var mainName = ByteArray{}
    mainName.push(109)
    mainName.push(97)
    mainName.push(105)
    mainName.push(110)
    callFixups.push(CallFixup{codeOffset: mainCallFixupOffset, targetName: mainName})
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // mov edi, eax (return value -> first arg for exit)
    code.push(0x89)
    code.push(0xC7)

    // mov eax, 60 (sys_exit)
    code.push(0xB8)
    code.push(0x3C)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)

    // syscall
    code.push(0x0F)
    code.push(0x05)

    return mainCallFixupOffset
end 'emitStartLinux'

// Linux write_stdout using write syscall (rax=1, rdi=1, rsi=buf, rdx=len)
// Args: rcx=ptr, rdx=len (same calling convention as Windows for caller convenience)
export function emitWriteStdoutLinux(code ByteBuffer) returns CodeOffset
    let offset = code.count()

    // Prologue
    code.push(0x55)
    code.push(0x48)
    code.push(0x89)
    code.push(0xE5)

    // System V ABI: rdi=fd, rsi=buf, rdx=count, rax=syscall#
    // Caller passes ptr in rcx, len in rdx (matching internal convention)
    // mov rsi, rcx (buf)
    code.push(0x48)
    code.push(0x89)
    code.push(0xCE)
    // rdx already has length, keep it
    // mov edi, 1 (stdout fd)
    code.push(0xBF)
    code.push(0x01)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    // mov eax, 1 (sys_write)
    code.push(0xB8)
    code.push(0x01)
    code.push(0x00)
    code.push(0x00)
    code.push(0x00)
    // syscall
    code.push(0x0F)
    code.push(0x05)

    // Epilogue
    code.push(0x5D)
    code.push(0xC3)

    return offset
end 'emitWriteStdoutLinux'

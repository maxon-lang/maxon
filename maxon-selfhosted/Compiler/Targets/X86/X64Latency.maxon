// X64-specific instruction latency data for the instruction scheduler.

// X64 latency table: 10 allocatable GPRs (rax,rcx,rdx,rbx,rsi,rdi,r8-r11),
// 16 XMM regs (xmm0-xmm15), pressure threshold at 80%.
export function createX64LatencyTable() returns TargetLatencyTable
	return TargetLatencyTable{
		defaultLatency: 1,
		intDivLatency: 40,
		fpDivLatency: 15,
		gprCount: 10,
		fpCount: 16,
		pressureThreshold: 8
	}
end 'createX64LatencyTable'

// X64 instruction latency estimates.
export function getX64Latency(op X64Op) returns Latency
	return match op 'dispatch'
		// Integer division: very high latency
		idivRcx gives 40
		idivReg gives 40
		iremRcx gives 40
		// Calls
		callDirect gives 5
		callIndirect gives 5
		// Loads from memory/stack
		loadSlot gives 4
		loadRegRbpOffset gives 4
		reloadFromStack gives 4
		loadIndirect gives 4
		globalLoad gives 4
		// Integer multiply
		imulRegReg gives 3
		// Simple ALU ops: 1 cycle
		movRegImm gives 1
		movRegReg gives 1
		addRegReg gives 1
		subRegReg gives 1
		addRegImm gives 1
		subRegImm gives 1
		andRegReg gives 1
		orRegReg gives 1
		xorRegReg gives 1
		cmpRegReg gives 1
		cmpRegImm gives 1
		negReg gives 1
		bitNotReg gives 1
		// Stores
		spillToStack gives 3
		movSlot gives 3
		storeIndirect gives 3
		globalStore gives 3
		// XMM floating-point arithmetic
		addXmm gives 4
		subXmm gives 4
		mulXmm gives 4
		divXmm gives 15
		sqrtXmm gives 20
		// XMM loads/stores
		reloadXmmFromStack gives 4
		spillXmmToStack gives 3
		loadIndirectXmm gives 4
		storeIndirectXmm gives 3
		globalLoadXmm gives 4
		globalStoreXmm gives 3
		// Other XMM ops
		movXmmXmm gives 1
		movXmmRipRel gives 4
		roundXmm gives 4
		ucomisXmm gives 3
		cvtSi2Float gives 4
		cvttFloat2Si gives 4
		cvtSd2Ss gives 3
		cvtSs2Sd gives 3
		movqXmmToGpr gives 3
		andMaskRipRel gives 4
		// Conditional/comparison ops
		setcc gives 1
		cmov gives 1
		cmpRaxRcx gives 1
		testRaxRax gives 1
		testRegReg gives 1
		// Width conversions
		movsxd gives 1
		movzx32 gives 1
		// Shift ops
		shlRegCl gives 1
		sarRegCl gives 1
		// LEA ops
		leaFromStack gives 1
		leaRipRelative gives 1
		leaFuncAddr gives 1
		// Misc
		xorRegRegSelf gives 1
		xchgRegReg gives 3
		cqo gives 1
		nullSafeLoad gives 4
		repMovsb gives 5
		repStosq gives 5
		// Syscall/IAT
		syscall gives 5
		iatCall gives 5
		// Simple control flow, bookkeeping, and pseudo-ops
		prologue to ret gives 1
		condJump to jmp gives 1
		movF64Slot to ucomisd gives 3
		printLiteral to printInt gives 5
		subRspImm to addRspImm gives 1
		movRspOffsetReg gives 3
		globalAddr to stackAddrOp gives 1
		storeByteOp gives 3
		loadByteOp gives 4
		memcpyOp gives 3
	end 'dispatch'
end 'getX64Latency'

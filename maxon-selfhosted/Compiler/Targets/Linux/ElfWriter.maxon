// ELF64 file writer for Linux x64 executables.
// Produces a minimal static ELF with two or three PT_LOAD segments:
//   Segment 1 (R+X): code, rdata, symdata
//   Segment 2 (R+W): .data section (writable heap arena for bump allocator)
//   Segment 3 (R+W): .covdata section (coverage counter globals, optional)
// The third segment is emitted only when the backend produced covDataSectionBytes;
// non-coverage builds stay byte-identical to the two-segment baseline.
// Linux x64 targets use raw syscalls, so no dynamic linking is needed.
//
// Debug symbols: when codeResult.debugSymbols is non-empty, .symtab + .strtab +
// .shstrtab are appended to the file along with a section header table.
// Loadable segments are unaffected; debuggers (lldb, llvm-readelf -s) read the
// section header table to resolve function names.

let ELF_LOAD_ADDR = 0x400000
let ELF_HEADER_SIZE = 64
let ELF_PHDR_SIZE = 56
let ELF_SHDR_SIZE = 64
let ELF_SYM_SIZE = 24
let ELF_PAGE_SIZE = 0x1000

// ELF section header types and flags (subset).
let ELF_SHT_NULL = 0
let ELF_SHT_PROGBITS = 1
let ELF_SHT_SYMTAB = 2
let ELF_SHT_STRTAB = 3

let ELF_SHF_WRITE = 0x1
let ELF_SHF_ALLOC = 0x2
let ELF_SHF_EXECINSTR = 0x4

// ELF symbol info (st_info) bindings/types.
let ELF_STB_GLOBAL = 1
let ELF_STT_FUNC = 2

// Size of the writable .data section (heap arena for bump allocator).
let ELF_DATA_SECTION_SIZE = 65536

typealias ElfStrOffsetArray = Array with ByteOffset

// Patch x64 RIP-relative rdata relocations for ELF
function patchElfRdataRelocationsX86(code ByteArray, rdataRelocs RdataRelocationArray, textVAddr MachineWord, rdataVAddr MachineWord, symdataVAddr MachineWord, dataVAddr MachineWord, covdataVAddr MachineWord)
	for reloc in rdataRelocs 'patch'
		let ripAtReloc = textVAddr + reloc.codeOffset + 4
		match reloc.kind 'kind'
			ripRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: rdataVAddr + reloc.rdataOffset - ripAtReloc)
			symdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: symdataVAddr - ripAtReloc)
			dataSectionRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: dataVAddr + reloc.rdataOffset - ripAtReloc)
			covdataRipRelDisp32 then patchDword(code, offset: reloc.codeOffset, value: covdataVAddr + reloc.rdataOffset - ripAtReloc)
			arm64Adr to covdataArm64Adr then break 'kind'
			funcAbs64InRdata then break 'kind'
		end 'kind'
	end 'patch'
end 'patchElfRdataRelocationsX86'

function patchElfRdataRelocationsArm64(code ByteArray, rdataRelocs RdataRelocationArray, textVAddr MachineWord, rdataVAddr MachineWord, symdataVAddr MachineWord, dataVAddr MachineWord, covdataVAddr MachineWord)
	for reloc in rdataRelocs 'patch'
		let instrVAddr = textVAddr + reloc.codeOffset
		match reloc.kind 'patchKind'
			ripRelDisp32 to covdataRipRelDisp32 then break 'patchKind'
			arm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrVAddr, targetAddr: rdataVAddr + reloc.rdataOffset)
			arm64LdrLiteral then patchArm64LdrLiteral(code, codeOffset: reloc.codeOffset, instrAddr: instrVAddr, targetAddr: rdataVAddr + reloc.rdataOffset)
			symdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrVAddr, targetAddr: symdataVAddr)
			dataSectionArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrVAddr, targetAddr: dataVAddr + reloc.rdataOffset)
			covdataArm64Adr then patchArm64Adr(code, codeOffset: reloc.codeOffset, instrAddr: instrVAddr, targetAddr: covdataVAddr + reloc.rdataOffset)
			funcAbs64InRdata then break 'patchKind'
		end 'patchKind'
	end 'patch'
end 'patchElfRdataRelocationsArm64'

// Append a NUL-terminated name to the strtab and return the offset where it
// was placed. The strtab must already have the leading NUL byte from create().
function appendStrtabName(strtab ByteArray, name String) returns ByteOffset
	let offset = strtab.count()
	strtab.append(name.toByteArray())
	strtab.push(0)
	return offset
end 'appendStrtabName'

// Write one Elf64_Shdr (64 bytes).
function writeElfShdr(elf ByteArray, nameOff MachineWord, shType MachineWord, flags MachineWord, addr MachineWord, offset MachineWord, size MachineWord, link MachineWord, info MachineWord, addralign MachineWord, entsize MachineWord)
	writeDword(elf, value: nameOff)
	writeDword(elf, value: shType)
	writeQword(elf, value: flags)
	writeQword(elf, value: addr)
	writeQword(elf, value: offset)
	writeQword(elf, value: size)
	writeDword(elf, value: link)
	writeDword(elf, value: info)
	writeQword(elf, value: addralign)
	writeQword(elf, value: entsize)
end 'writeElfShdr'

// Write one Elf64_Sym (24 bytes).
function writeElfSym(elf ByteArray, nameOff MachineWord, info MachineWord, other MachineWord, shndx MachineWord, value MachineWord, size MachineWord)
	writeDword(elf, value: nameOff)
	elf.push(info and 0xFF)         // st_info
	elf.push(other and 0xFF)        // st_other
	writeWord(elf, value: shndx)    // st_shndx
	writeQword(elf, value: value)   // st_value
	writeQword(elf, value: size)    // st_size
end 'writeElfSym'

export function writeElf(outputPath FilePath, codeResult CodeResult, target Target)
	var code = codeResult.code
	let codeSize = code.count()
	let rdataSize = codeResult.rdata.count()
	let symdataSize = codeResult.symdata.count()
	let covdataSize = codeResult.covDataSectionBytes.count()
	let hasCovdata = covdataSize > 0

	// A third PT_LOAD segment (for .covdata) is added only when coverage globals
	// exist, so non-coverage builds stay byte-identical to the two-segment baseline.
	var numPhdrs = 2
	if hasCovdata 'bumpPhdrs'
		numPhdrs = 3
	end 'bumpPhdrs'
	let headerSize = ELF_HEADER_SIZE + (numPhdrs * ELF_PHDR_SIZE)

	// Segment 1 layout: headers + code (8-byte aligned) + rdata (8-byte aligned) + symdata
	let codePadded = alignUp(codeSize, alignment: 8)
	let rdataFileOffset = headerSize + codePadded
	let rdataPadded = alignUp(rdataSize, alignment: 8)
	let symdataFileOffset = rdataFileOffset + rdataPadded
	let seg1FileSize = symdataFileOffset + symdataSize
	let seg1MemSize = seg1FileSize

	// Segment 2 layout: .data heap arena on a page-aligned boundary after segment 1.
	// The 64KB heap arena is zero-initialized by the OS loader; the prelude
	// carries initial values for top-level / static-field globals on disk. An
	// 8-byte tail keeps the segment non-empty when no globals were declared.
	let dataFileOffset = alignUp(seg1FileSize, alignment: ELF_PAGE_SIZE)
	let dataVAddr = ELF_LOAD_ADDR + dataFileOffset
	let dataFileSize = codeResult.dataPrelude.count() + 8
	let dataMemSize = ELF_DATA_SECTION_SIZE

	// Segment 3 layout (.covdata): page-aligned after segment 2. Coverage counter
	// globals need on-disk backing so __data_cov_num_sites survives process load.
	var covdataFileOffset = 0
	var covdataVAddr = 0
	var covdataFileSize = 0
	if hasCovdata 'setCovdata'
		covdataFileOffset = alignUp(dataFileOffset + dataFileSize, alignment: ELF_PAGE_SIZE)
		covdataVAddr = ELF_LOAD_ADDR + covdataFileOffset
		covdataFileSize = covdataSize
	end 'setCovdata'

	var totalFileSize = dataFileOffset + dataFileSize
	if hasCovdata 'extendTotal'
		totalFileSize = covdataFileOffset + covdataFileSize
	end 'extendTotal'

	let entryPoint = ELF_LOAD_ADDR + headerSize
	let textVAddr = entryPoint
	let rdataVAddr = ELF_LOAD_ADDR + rdataFileOffset
	let symdataVAddr = ELF_LOAD_ADDR + symdataFileOffset

	logInfo(LogCategory.binary, message: () gives "Writing ELF file: {outputPath}")
	logInfo(LogCategory.binary, message: () gives "Code size: {codeSize} bytes, rdata size: {rdataSize} bytes, symdata size: {symdataSize} bytes, data section: {dataMemSize} bytes (virtual), covdata size: {covdataSize} bytes, entry point: {entryPoint}")

	// Patch rdata, symdata, data, and covdata section relocations in code before writing
	match target.cpu 'patchRdata'
		x64 then patchElfRdataRelocationsX86(code, rdataRelocs: codeResult.rdataRelocations, textVAddr: textVAddr, rdataVAddr: rdataVAddr, symdataVAddr: symdataVAddr, dataVAddr: dataVAddr, covdataVAddr: covdataVAddr)
		arm64 then patchElfRdataRelocationsArm64(code, rdataRelocs: codeResult.rdataRelocations, textVAddr: textVAddr, rdataVAddr: rdataVAddr, symdataVAddr: symdataVAddr, dataVAddr: dataVAddr, covdataVAddr: covdataVAddr)
		wasm32 then panic("ELF writer not used for WASM targets")
	end 'patchRdata'

	// Phase 11.2: bake absolute VAs of layout-descriptor copy/destroy
	// thunks (and witness-table methods) into the on-disk rdata image.
	// ELF mirrors PE's strategy: a static ET_EXEC at a fixed load address
	// (ELF_LOAD_ADDR = 0x400000) with no dynamic linker involvement, so
	// absolute VAs can be baked at write time. A future PIE/ET_DYN writer
	// would need a `.rela.rdata` section so the loader can apply these.
	patchFuncAbs64InRdata(codeResult.rdata, rdataRelocs: codeResult.rdataRelocations, textAbsBase: textVAddr, debugSymbols: codeResult.debugSymbols)

	var elf = ByteArray.create()
	elf.reserve(totalFileSize)

	// === ELF Header (64 bytes) ===
	// e_shoff / e_shentsize / e_shnum / e_shstrndx are emitted as zero placeholders
	// here; if the backend supplied debug symbols, they are backpatched after the
	// section header table is appended at the end of the file.

	// e_ident[0..16]: magic, class=64, data=LSB, version=1, OS/ABI=SysV, padding
	elf.append(b"\x7fELF\x02\x01\x01\x00\x00\x00\x00\x00\x00\x00\x00\x00")

	// e_type: ET_EXEC (executable)
	writeWord(elf, value: 2)
	// e_machine: EM_X86_64=0x3E, EM_AARCH64=0xB7
	let eMachine = match target.cpu 'cpuMachine'
		x64 gives 0x3E
		arm64 gives 0xB7
		default panic("ELF writer not used for WASM targets")
	end 'cpuMachine'
	writeWord(elf, value: eMachine)
	// e_version (4)
	writeDword(elf, value: 1)
	// e_entry (8)
	writeQword(elf, value: entryPoint)
	// e_phoff (8): program headers immediately follow the ELF header
	writeQword(elf, value: ELF_HEADER_SIZE)
	// e_shoff (8) — patched if debug symbols are emitted
	let eShoffOffset = elf.count()
	writeQword(elf, value: 0)
	// e_flags (4)
	writeDword(elf, value: 0)
	// e_ehsize (2), e_phentsize (2)
	writeWord(elf, value: ELF_HEADER_SIZE)
	writeWord(elf, value: ELF_PHDR_SIZE)
	// e_phnum (2)
	writeWord(elf, value: numPhdrs)
	// e_shentsize (2), e_shnum (2), e_shstrndx (2) — patched if debug symbols emitted
	let eShentsizeOffset = elf.count()
	writeWord(elf, value: 0)
	let eShnumOffset = elf.count()
	writeWord(elf, value: 0)
	let eShstrndxOffset = elf.count()
	writeWord(elf, value: 0)

	// === Program Header 1: code + rdata + symdata (R+X) ===
	// p_type(PT_LOAD=1), p_flags(PF_R|PF_X=5), p_offset(0)
	elf.append(b"\x01\x00\x00\x00\x05\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00")
	// p_vaddr, p_paddr (both ELF_LOAD_ADDR=0x400000)
	elf.append(b"\x00\x00\x40\x00\x00\x00\x00\x00\x00\x00\x40\x00\x00\x00\x00\x00")
	// p_filesz, p_memsz
	writeQword(elf, value: seg1FileSize)
	writeQword(elf, value: seg1MemSize)
	// p_align (0x1000)
	elf.append(b"\x00\x10\x00\x00\x00\x00\x00\x00")

	// === Program Header 2: .data section (R+W) ===
	// p_type(PT_LOAD=1), p_flags(PF_R|PF_W=6)
	elf.append(b"\x01\x00\x00\x00\x06\x00\x00\x00")
	// p_offset
	writeQword(elf, value: dataFileOffset)
	// p_vaddr, p_paddr
	writeQword(elf, value: dataVAddr)
	writeQword(elf, value: dataVAddr)
	// p_filesz, p_memsz
	writeQword(elf, value: dataFileSize)
	writeQword(elf, value: dataMemSize)
	// p_align (0x1000)
	elf.append(b"\x00\x10\x00\x00\x00\x00\x00\x00")

	// === Program Header 3 (optional): .covdata section (R+W) ===
	if hasCovdata 'writeCovdataPhdr'
		// p_type(PT_LOAD=1), p_flags(PF_R|PF_W=6)
		elf.append(b"\x01\x00\x00\x00\x06\x00\x00\x00")
		writeQword(elf, value: covdataFileOffset)
		writeQword(elf, value: covdataVAddr)
		writeQword(elf, value: covdataVAddr)
		writeQword(elf, value: covdataFileSize)
		writeQword(elf, value: covdataFileSize)
		// p_align (0x1000)
		elf.append(b"\x00\x10\x00\x00\x00\x00\x00\x00")
	end 'writeCovdataPhdr'

	// === Code ===
	elf.append(code)

	// === Pad to rdata offset ===
	while elf.count() < rdataFileOffset 'padToRdata'
		elf.push(0)
	end 'padToRdata'

	// === Rdata ===
	elf.append(codeResult.rdata)

	// === Pad to symdata offset ===
	while elf.count() < symdataFileOffset 'padToSymdata'
		elf.push(0)
	end 'padToSymdata'

	// === Symdata ===
	elf.append(codeResult.symdata)

	// === Pad to .data section (page-aligned) ===
	while elf.count() < dataFileOffset 'padToData'
		elf.push(0)
	end 'padToData'

	// === .data section: prelude (initial global values) + zero-init padding ===
	elf.append(codeResult.dataPrelude)
	writeZeros(elf, n: dataFileSize - codeResult.dataPrelude.count())

	// === .covdata section (optional) ===
	if hasCovdata 'writeCovdataPayload'
		while elf.count() < covdataFileOffset 'padToCovdata'
			elf.push(0)
		end 'padToCovdata'
		elf.append(codeResult.covDataSectionBytes)
	end 'writeCovdataPayload'

	// === Debug symbol tables ===
	// Appended after all loadable segments. The section header table sits at the
	// very end of the file. Loadable PT_LOAD segments are unaffected because the
	// loader only follows program headers; the section header table is for tools.
	if codeResult.debugSymbols.count() > 0 'writeSymTables'
		// Section indices (positions in the section header table). Index 0 is
		// the SHT_NULL entry. PROGBITS sections (.text, optional .rodata, .data,
		// optional .covdata) come first, followed by .symtab, .strtab, .shstrtab.
		// Only `textShndx` (st_shndx for function symbols) and the trailing
		// indices are read; intermediate PROGBITS shndx values are implicit in
		// the section-header write order.
		let textShndx = 1
		var progbitsCount = 2  // SHT_NULL + .text
		if rdataSize > 0 'rodataIdx'
			progbitsCount = progbitsCount + 1
		end 'rodataIdx'
		progbitsCount = progbitsCount + 1  // .data
		if hasCovdata 'covdataIdx'
			progbitsCount = progbitsCount + 1
		end 'covdataIdx'
		let symtabShndx = progbitsCount
		let strtabShndx = symtabShndx + 1
		let shstrtabShndx = strtabShndx + 1
		let shnum = shstrtabShndx + 1

		// Build .strtab (function names) — leading NUL byte is required.
		var strtab = ByteArray.create()
		strtab.push(0)
		var symNameOffsets = ElfStrOffsetArray.create()
		for sym in codeResult.debugSymbols 'eachSym'
			let off = appendStrtabName(strtab, name: sym.name)
			symNameOffsets.push(off)
		end 'eachSym'

		// Build .shstrtab (section header names) — leading NUL byte is required.
		var shstrtab = ByteArray.create()
		shstrtab.push(0)
		let textNameOff = appendStrtabName(shstrtab, name: ".text")
		var rodataNameOff = 0
		if rdataSize > 0 'rodataName'
			rodataNameOff = appendStrtabName(shstrtab, name: ".rodata")
		end 'rodataName'
		let dataNameOff = appendStrtabName(shstrtab, name: ".data")
		var covdataNameOff = 0
		if hasCovdata 'covdataName'
			covdataNameOff = appendStrtabName(shstrtab, name: ".covdata")
		end 'covdataName'
		let symtabNameOff = appendStrtabName(shstrtab, name: ".symtab")
		let strtabNameOff = appendStrtabName(shstrtab, name: ".strtab")
		let shstrtabNameOff = appendStrtabName(shstrtab, name: ".shstrtab")

		// Lay out the on-disk symtab/strtab/shstrtab blocks (8-byte aligned).
		let symtabFileOffset = alignUp(elf.count(), alignment: 8)
		let symtabSize = (codeResult.debugSymbols.count() + 1) * ELF_SYM_SIZE
		let strtabFileOffset = symtabFileOffset + symtabSize
		let strtabSize = strtab.count()
		let shstrtabFileOffset = strtabFileOffset + strtabSize
		let shstrtabSize = shstrtab.count()
		let shoffFileOffset = alignUp(shstrtabFileOffset + shstrtabSize, alignment: 8)

		// .symtab: leading STN_UNDEF (all zero) + one Elf64_Sym per function.
		// All function symbols live in .text, so st_shndx = textShndx.
		while elf.count() < symtabFileOffset 'padToSymtab'
			elf.push(0)
		end 'padToSymtab'
		writeElfSym(elf, nameOff: 0, info: 0, other: 0, shndx: 0, value: 0, size: 0)
		let stInfoFunc = (ELF_STB_GLOBAL shl 4) or ELF_STT_FUNC
		for (iter, sym) in codeResult.debugSymbols.withIterator() 'writeSyms'
			let nameOff = try symNameOffsets.get(iter.index()) otherwise panic("invariant: symNameOffsets[{iter.index()}] OOB ({symNameOffsets.count()} entries)")
			writeElfSym(elf, nameOff: nameOff, info: stInfoFunc, other: 0, shndx: textShndx, value: textVAddr + sym.codeOffset, size: 0)
		end 'writeSyms'

		// .strtab and .shstrtab payloads.
		elf.append(strtab)
		elf.append(shstrtab)

		// Section header table — 8-byte aligned.
		while elf.count() < shoffFileOffset 'padToShoff'
			elf.push(0)
		end 'padToShoff'

		// [0] SHT_NULL
		writeElfShdr(elf, nameOff: 0, shType: ELF_SHT_NULL, flags: 0, addr: 0, offset: 0, size: 0, link: 0, info: 0, addralign: 0, entsize: 0)
		// [1] .text
		writeElfShdr(elf, nameOff: textNameOff, shType: ELF_SHT_PROGBITS, flags: ELF_SHF_ALLOC or ELF_SHF_EXECINSTR, addr: textVAddr, offset: headerSize, size: codeSize, link: 0, info: 0, addralign: 16, entsize: 0)
		// [2] .rodata (optional)
		if rdataSize > 0 'rodataShdr'
			writeElfShdr(elf, nameOff: rodataNameOff, shType: ELF_SHT_PROGBITS, flags: ELF_SHF_ALLOC, addr: rdataVAddr, offset: rdataFileOffset, size: rdataSize, link: 0, info: 0, addralign: 8, entsize: 0)
		end 'rodataShdr'
		// [n] .data — backed by the on-disk prelude region (the heap arena beyond
		// dataFileSize is uninitialized, not in any section).
		writeElfShdr(elf, nameOff: dataNameOff, shType: ELF_SHT_PROGBITS, flags: ELF_SHF_ALLOC or ELF_SHF_WRITE, addr: dataVAddr, offset: dataFileOffset, size: dataFileSize, link: 0, info: 0, addralign: 8, entsize: 0)
		// [n] .covdata (optional)
		if hasCovdata 'covdataShdr'
			writeElfShdr(elf, nameOff: covdataNameOff, shType: ELF_SHT_PROGBITS, flags: ELF_SHF_ALLOC or ELF_SHF_WRITE, addr: covdataVAddr, offset: covdataFileOffset, size: covdataFileSize, link: 0, info: 0, addralign: 8, entsize: 0)
		end 'covdataShdr'
		// [n] .symtab — sh_link points at .strtab; sh_info = 1 because the only
		// non-global symbol is the leading STN_UNDEF (we emit all functions as
		// STB_GLOBAL).
		writeElfShdr(elf, nameOff: symtabNameOff, shType: ELF_SHT_SYMTAB, flags: 0, addr: 0, offset: symtabFileOffset, size: symtabSize, link: strtabShndx, info: 1, addralign: 8, entsize: ELF_SYM_SIZE)
		// [n] .strtab
		writeElfShdr(elf, nameOff: strtabNameOff, shType: ELF_SHT_STRTAB, flags: 0, addr: 0, offset: strtabFileOffset, size: strtabSize, link: 0, info: 0, addralign: 1, entsize: 0)
		// [n] .shstrtab
		writeElfShdr(elf, nameOff: shstrtabNameOff, shType: ELF_SHT_STRTAB, flags: 0, addr: 0, offset: shstrtabFileOffset, size: shstrtabSize, link: 0, info: 0, addralign: 1, entsize: 0)

		// Backpatch the ELF header.
		patchQword(elf, offset: eShoffOffset, value: shoffFileOffset)
		patchWord(elf, offset: eShentsizeOffset, value: ELF_SHDR_SIZE)
		patchWord(elf, offset: eShnumOffset, value: shnum)
		patchWord(elf, offset: eShstrndxOffset, value: shstrtabShndx)

		logDebug(LogCategory.binary, message: () gives "ELF debug symbols: {codeResult.debugSymbols.count()} entries, section header table at file offset {shoffFileOffset}")
	end 'writeSymTables'

	// Write to file
	try File.writeBinary(outputPath, content: elf, mode: FilePermission.executable) otherwise 'writeErr'
		logError(LogCategory.binary, message: () gives "Failed to write ELF file: {outputPath}")
	end 'writeErr'
end 'writeElf'

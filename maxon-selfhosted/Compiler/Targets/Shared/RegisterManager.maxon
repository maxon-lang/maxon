// FP two-address: dest is use+def, src is use
function ax64FpTwoAddr(state RegState, dest X64FpVReg, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock, opCode RegInt)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = x64ResolveFpUse(state, vreg: dest, dstBlock: dstBlock)
	let dp = x64FpPhysFromOrd(d)
	let sp = x64FpPhysFromOrd(s)
	if opCode == 0 'add'
		dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.addXmm(dp, sp, precision)))
	end 'add' else if opCode == 1 'sub'
		dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.subXmm(dp, sp, precision)))
	end 'sub' else if opCode == 2 'mul'
		dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.mulXmm(dp, sp, precision)))
	end 'mul' else if opCode == 3 'div'
		dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.divXmm(dp, sp, precision)))
	end 'div' else 'invalid'
		panic("ax64FpTwoAddr: invalid opCode {opCode}")
	end 'invalid'
end 'ax64FpTwoAddr'


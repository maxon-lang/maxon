// ARM64 FP helpers
function aa64FmovRegReg(state RegState, dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	if s != d 'needFpMov'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fmovRegReg(arm64FpPhysFromOrd(d), arm64FpPhysFromOrd(s), precision)))
	end 'needFpMov'
end 'aa64FmovRegReg'


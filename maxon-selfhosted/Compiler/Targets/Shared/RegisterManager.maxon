	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.movXmmRipRel(x64FpPhysFromOrd(d), rdataLabel, precision)))

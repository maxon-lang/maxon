// XMM FP helpers
function ax64MovXmmXmm(state RegState, dest X64FpVReg, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	if s != d 'needFpMov'
		dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.movXmmXmm(x64FpPhysFromOrd(d), x64FpPhysFromOrd(s), precision)))
	end 'needFpMov'
end 'ax64MovXmmXmm'

function ax64SpillXmmToStack(state RegState, offset MachineWord, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.spillXmmToStack(offset, x64FpPhysFromOrd(s), precision)))
end 'ax64SpillXmmToStack'

function ax64ReloadXmmFromStack(state RegState, dest X64FpVReg, offset MachineWord, precision FloatPrecision, dstBlock MlirBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.reloadXmmFromStack(x64FpPhysFromOrd(d), offset, precision)))
end 'ax64ReloadXmmFromStack'


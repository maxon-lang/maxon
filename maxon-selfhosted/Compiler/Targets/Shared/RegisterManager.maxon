function ax64LoadIndirectXmm(state RegState, dest X64FpVReg, baseReg X64VReg, offset MachineWord, precision FloatPrecision, dstBlock MlirBlock)
	let b = x64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.loadIndirectXmm(x64FpPhysFromOrd(d), x64PhysFromOrd(b), offset, precision)))
end 'ax64LoadIndirectXmm'

function ax64GlobalLoadXmm(state RegState, dest X64FpVReg, name ByteArray, precision FloatPrecision, dstBlock MlirBlock)
	let d = x64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.globalLoadXmm(x64FpPhysFromOrd(d), name, precision)))
end 'ax64GlobalLoadXmm'

function ax64GlobalStoreXmm(state RegState, name ByteArray, src X64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = x64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxx64(MaxX64Op.globalStoreXmm(name, x64FpPhysFromOrd(s), precision)))
end 'ax64GlobalStoreXmm'

// ============================================================
// X64 per-op dispatch
// ============================================================

function allocX64Op(state RegState, x64Op MaxX64Op, dstBlock MlirBlock)
	match x64Op 'dispatch'
		prologue to ret then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		movRegImm(dest, value) then ax64MovRegImm(state, dest: dest, value: value, dstBlock: dstBlock)
		movSlot(slotIndex, srcReg) then ax64MovSlot(state, slotIndex: slotIndex, srcReg: srcReg, dstBlock: dstBlock)
		loadSlot(destReg, slotIndex) then ax64LoadSlot(state, destReg: destReg, slotIndex: slotIndex, dstBlock: dstBlock)
		addRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 0)
		subRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 1)
		imulRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 2)
		idivRcx to iremRcx then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		negReg(reg) then ax64UnaryInPlace(state, reg: reg, dstBlock: dstBlock, opCode: 0)
		bitNotReg(reg) then ax64UnaryInPlace(state, reg: reg, dstBlock: dstBlock, opCode: 1)
		andRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 3)
		orRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 4)
		xorRegReg(destReg, srcReg) then ax64TwoAddr(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock, opCode: 5)
		shlRegCl(reg) then ax64UnaryInPlace(state, reg: reg, dstBlock: dstBlock, opCode: 2)
		sarRegCl(reg) then ax64UnaryInPlace(state, reg: reg, dstBlock: dstBlock, opCode: 3)
		cmpRaxRcx to testRaxRax then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		condJump to jmp then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		movF64Slot to ucomisd then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		printLiteral to printInt then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		subRspImm to addRspImm then dstBlock.ops.push(MlirOp.maxx64(x64Op))
		movRspOffsetReg(offset, srcReg) then ax64MovRspOffsetReg(state, offset: offset, srcReg: srcReg, dstBlock: dstBlock)
		loadRegRbpOffset(destReg, offset) then ax64LoadRegRbpOffset(state, destReg: destReg, offset: offset, dstBlock: dstBlock)
		callDirect then ax64HandleCall(state, x64Op: x64Op, dstBlock: dstBlock)
		syscall to loadByteOp then ax64SlotBasedOp(state, x64Op: x64Op, dstBlock: dstBlock)
		memcpyOp then ax64MemcpyOp(state, x64Op: x64Op, dstBlock: dstBlock)
		movRegReg(destReg, srcReg) then ax64MovRegReg(state, destReg: destReg, srcReg: srcReg, dstBlock: dstBlock)
		cmpRegReg(lhsReg, rhsReg) then ax64CmpRegReg(state, lhsReg: lhsReg, rhsReg: rhsReg, dstBlock: dstBlock)
		testRegReg(reg1, reg2) then ax64TestRegReg(state, reg1: reg1, reg2: reg2, dstBlock: dstBlock)
		cqo then ax64Cqo(state, dstBlock: dstBlock)
		idivReg(divisorReg) then ax64IdivReg(state, divisorReg: divisorReg, dstBlock: dstBlock)
		spillToStack(offset, srcReg) then ax64SpillToStack(state, offset: offset, srcReg: srcReg, dstBlock: dstBlock)
		reloadFromStack(destReg, offset) then ax64ReloadFromStack(state, destReg: destReg, offset: offset, dstBlock: dstBlock)
		xorRegRegSelf(reg) then ax64XorSelf(state, reg: reg, dstBlock: dstBlock)
		callIndirect(reg) then ax64CallIndirect(state, reg: reg, dstBlock: dstBlock)
		xchgRegReg(reg1, reg2) then ax64XchgRegReg(state, reg1: reg1, reg2: reg2, dstBlock: dstBlock)
		movXmmXmm(dest, src, precision) then ax64MovXmmXmm(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		spillXmmToStack(offset, src, precision) then ax64SpillXmmToStack(state, offset: offset, src: src, precision: precision, dstBlock: dstBlock)
		reloadXmmFromStack(dest, offset, precision) then ax64ReloadXmmFromStack(state, dest: dest, offset: offset, precision: precision, dstBlock: dstBlock)
		movXmmRipRel(dest, rdataLabel, precision) then ax64MovXmmRipRel(state, dest: dest, rdataLabel: rdataLabel, precision: precision, dstBlock: dstBlock)
		addXmm(dest, src, precision) then ax64FpTwoAddr(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 0)
		subXmm(dest, src, precision) then ax64FpTwoAddr(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 1)
		mulXmm(dest, src, precision) then ax64FpTwoAddr(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 2)
		divXmm(dest, src, precision) then ax64FpTwoAddr(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 3)
		sqrtXmm(dest, src, precision) then ax64SqrtXmm(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		roundXmm(dest, src, mode, precision) then ax64RoundXmm(state, dest: dest, src: src, mode: mode, precision: precision, dstBlock: dstBlock)
		ucomisXmm(src1, src2, precision) then ax64UcomisXmm(state, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock)
		cvtSi2Float(dest, src, precision) then ax64CvtSi2Float(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		cvttFloat2Si(dest, src, precision) then ax64CvttFloat2Si(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		cvtSd2Ss(dest, src) then ax64CvtSd2Ss(state, dest: dest, src: src, dstBlock: dstBlock)
		cvtSs2Sd(dest, src) then ax64CvtSs2Sd(state, dest: dest, src: src, dstBlock: dstBlock)
		movqXmmToGpr(dest, src) then ax64MovqXmmToGpr(state, dest: dest, src: src, dstBlock: dstBlock)
		andMaskRipRel(dest, rdataLabel, precision) then ax64AndMaskRipRel(state, dest: dest, rdataLabel: rdataLabel, precision: precision, dstBlock: dstBlock)
		storeIndirect(baseReg, offset, srcReg, size) then ax64StoreIndirect(state, baseReg: baseReg, offset: offset, srcReg: srcReg, size: size, dstBlock: dstBlock)
		loadIndirect(destReg, baseReg, offset, size) then ax64LoadIndirect(state, destReg: destReg, baseReg: baseReg, offset: offset, size: size, dstBlock: dstBlock)
		storeIndirectXmm(baseReg, offset, src, precision) then ax64StoreIndirectXmm(state, baseReg: baseReg, offset: offset, src: src, precision: precision, dstBlock: dstBlock)
		loadIndirectXmm(dest, baseReg, offset, precision) then ax64LoadIndirectXmm(state, dest: dest, baseReg: baseReg, offset: offset, precision: precision, dstBlock: dstBlock)
		globalLoad(dest, name, size) then ax64GlobalLoad(state, dest: dest, name: name, size: size, dstBlock: dstBlock)
		globalStore(name, src, size) then ax64GlobalStore(state, name: name, src: src, size: size, dstBlock: dstBlock)
		globalLoadXmm(dest, name, precision) then ax64GlobalLoadXmm(state, dest: dest, name: name, precision: precision, dstBlock: dstBlock)
		globalStoreXmm(name, src, precision) then ax64GlobalStoreXmm(state, name: name, src: src, precision: precision, dstBlock: dstBlock)
		leaFromStack(dest, stackOffset) then ax64LeaFromStack(state, dest: dest, stackOffset: stackOffset, dstBlock: dstBlock)
		leaRipRelative(dest, rdataLabel) then ax64LeaRipRelative(state, dest: dest, rdataLabel: rdataLabel, dstBlock: dstBlock)
		leaFuncAddr(dest, funcName) then ax64LeaFuncAddr(state, dest: dest, funcName: funcName, dstBlock: dstBlock)
		setcc(dest, condition) then ax64Setcc(state, dest: dest, condition: condition, dstBlock: dstBlock)
		cmov(dest, src, condition) then ax64Cmov(state, dest: dest, src: src, condition: condition, dstBlock: dstBlock)
		movsxd(dest, src) then ax64Movsxd(state, dest: dest, src: src, dstBlock: dstBlock)
		movzx32(dest, src) then ax64Movzx32(state, dest: dest, src: src, dstBlock: dstBlock)
		nullSafeLoad(dest, baseReg, offset) then ax64NullSafeLoad(state, dest: dest, baseReg: baseReg, offset: offset, dstBlock: dstBlock)
		repMovsb to repStosq then dstBlock.ops.push(MlirOp.maxx64(x64Op))
	end 'dispatch'
end 'allocX64Op'

// ============================================================
// ARM64 per-op register allocation — helper functions
// ============================================================

function aa64MovImm(state RegState, dest Arm64VReg, value MachineWord, dstBlock MlirBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movImm(arm64PhysFromOrd(d), value)))
end 'aa64MovImm'

function aa64StrToSlot(state RegState, slotIndex VarSlot, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSlot(slotIndex, arm64PhysFromOrd(s))))
end 'aa64StrToSlot'

function aa64LdrFromSlot(state RegState, dest Arm64VReg, slotIndex VarSlot, dstBlock MlirBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.ldrFromSlot(arm64PhysFromOrd(d), slotIndex)))
end 'aa64LdrFromSlot'

// Three-address: dest=def, src1=use, src2=use
function aa64ThreeAddr(state RegState, dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg, dstBlock MlirBlock, opCode RegInt)
	let s1 = arm64ResolveGprUse(state, vreg: src1, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let s2 = arm64ResolveGprUse(state, vreg: src2, dstBlock: dstBlock, protect1: s1, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: s1, protect2: s2)
	let dp = arm64PhysFromOrd(d)
	let s1p = arm64PhysFromOrd(s1)
	let s2p = arm64PhysFromOrd(s2)
	if opCode == 0 'add'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.addRegs(dp, s1p, s2p)))
	end 'add' else if opCode == 1 'sub'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.subRegs(dp, s1p, s2p)))
	end 'sub' else if opCode == 2 'mul'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.mulRegs(dp, s1p, s2p)))
	end 'mul' else if opCode == 3 'sdiv'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.sdivRegs(dp, s1p, s2p)))
	end 'sdiv' else if opCode == 4 'rem'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.remRegs(dp, s1p, s2p)))
	end 'rem' else if opCode == 5 'and'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.andRegs(dp, s1p, s2p)))
	end 'and' else if opCode == 6 'orr'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.orrRegs(dp, s1p, s2p)))
	end 'orr' else if opCode == 7 'eor'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.eorRegs(dp, s1p, s2p)))
	end 'eor' else if opCode == 8 'lsl'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.lslRegs(dp, s1p, s2p)))
	end 'lsl' else 'asr'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.asrRegs(dp, s1p, s2p)))
	end 'asr'
end 'aa64ThreeAddr'

function aa64UnaryDestSrc(state RegState, dest Arm64VReg, src Arm64VReg, dstBlock MlirBlock, isNeg bool)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: s, protect2: RM_NONE)
	if isNeg 'neg'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.negReg(arm64PhysFromOrd(d), arm64PhysFromOrd(s))))
	end 'neg' else 'mvn'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.mvnReg(arm64PhysFromOrd(d), arm64PhysFromOrd(s))))
	end 'mvn'
end 'aa64UnaryDestSrc'

function aa64CmpRegs(state RegState, src1 Arm64VReg, src2 Arm64VReg, dstBlock MlirBlock)
	let s1 = arm64ResolveGprUse(state, vreg: src1, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let s2 = arm64ResolveGprUse(state, vreg: src2, dstBlock: dstBlock, protect1: s1, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.cmpRegs(arm64PhysFromOrd(s1), arm64PhysFromOrd(s2))))
end 'aa64CmpRegs'

function aa64CmpRegZero(state RegState, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.cmpRegZero(arm64PhysFromOrd(s))))
end 'aa64CmpRegZero'

function aa64MovRegReg(state RegState, dest Arm64VReg, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: s, protect2: RM_NONE)
	if s != d 'needMov'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.movRegReg(arm64PhysFromOrd(d), arm64PhysFromOrd(s))))
	end 'needMov'
end 'aa64MovRegReg'

function aa64SpillToStack(state RegState, offset MachineWord, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.spillToStack(offset, arm64PhysFromOrd(s))))
end 'aa64SpillToStack'

function aa64ReloadFromStack(state RegState, dest Arm64VReg, offset MachineWord, dstBlock MlirBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.reloadFromStack(arm64PhysFromOrd(d), offset)))
end 'aa64ReloadFromStack'

function aa64BranchLinkReg(state RegState, reg Arm64VReg, dstBlock MlirBlock)
	let r = arm64ResolveGprUse(state, vreg: reg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.branchLinkReg(arm64PhysFromOrd(r))))
end 'aa64BranchLinkReg'

function aa64StrToSpOffset(state RegState, offset StackSize, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.strToSpOffset(offset, arm64PhysFromOrd(s))))
end 'aa64StrToSpOffset'

function aa64Cset(state RegState, dest Arm64VReg, condition MaxArm64CondCode, dstBlock MlirBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.cset(arm64PhysFromOrd(d), condition)))
end 'aa64Cset'

function aa64Csel(state RegState, dest Arm64VReg, src1 Arm64VReg, src2 Arm64VReg, condition MaxArm64CondCode, dstBlock MlirBlock)
	let s1 = arm64ResolveGprUse(state, vreg: src1, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let s2 = arm64ResolveGprUse(state, vreg: src2, dstBlock: dstBlock, protect1: s1, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: s1, protect2: s2)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.csel(arm64PhysFromOrd(d), arm64PhysFromOrd(s1), arm64PhysFromOrd(s2), condition)))
end 'aa64Csel'

function aa64Sxtw(state RegState, dest Arm64VReg, src Arm64VReg, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: s, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.sxtw(arm64PhysFromOrd(d), arm64PhysFromOrd(s))))
end 'aa64Sxtw'

function aa64StoreIndirect(state RegState, baseReg Arm64VReg, offset MachineWord, srcReg Arm64VReg, size MachineWord, dstBlock MlirBlock)
	let b = arm64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let s = arm64ResolveGprUse(state, vreg: srcReg, dstBlock: dstBlock, protect1: b, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.storeIndirect(arm64PhysFromOrd(b), offset, arm64PhysFromOrd(s), size)))
end 'aa64StoreIndirect'

function aa64LoadIndirect(state RegState, destReg Arm64VReg, baseReg Arm64VReg, offset MachineWord, size MachineWord, dstBlock MlirBlock)
	let b = arm64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveGprDef(state, vreg: destReg, dstBlock: dstBlock, protect1: b, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.loadIndirect(arm64PhysFromOrd(d), arm64PhysFromOrd(b), offset, size)))
end 'aa64LoadIndirect'

function aa64NullSafeLoad(state RegState, dest Arm64VReg, baseReg Arm64VReg, offset MachineWord, dstBlock MlirBlock)
	let b = arm64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)

	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.spillFpToStack(offset, arm64FpPhysFromOrd(s), precision)))
end 'aa64SpillFpToStack'

function aa64ReloadFpFromStack(state RegState, dest Arm64FpVReg, offset MachineWord, precision FloatPrecision, dstBlock MlirBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.reloadFpFromStack(arm64FpPhysFromOrd(d), offset, precision)))
end 'aa64ReloadFpFromStack'

function aa64FpLoadRdata(state RegState, dest Arm64FpVReg, rdataLabel ByteArray, precision FloatPrecision, dstBlock MlirBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fpLoadRdata(arm64FpPhysFromOrd(d), rdataLabel, precision)))
end 'aa64FpLoadRdata'

function aa64FmovToFloat(state RegState, dest Arm64FpVReg, src Arm64VReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fmovToFloat(arm64FpPhysFromOrd(d), arm64PhysFromOrd(s), precision)))
end 'aa64FmovToFloat'

function aa64FmovToGpr(state RegState, dest Arm64VReg, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fmovToGpr(arm64PhysFromOrd(d), arm64FpPhysFromOrd(s), precision)))
end 'aa64FmovToGpr'

function aa64Scvtf(state RegState, dest Arm64FpVReg, src Arm64VReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveGprUse(state, vreg: src, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.scvtf(arm64FpPhysFromOrd(d), arm64PhysFromOrd(s), precision)))
end 'aa64Scvtf'

function aa64Fcvtzs(state RegState, dest Arm64VReg, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = arm64ResolveGprDef(state, vreg: dest, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fcvtzs(arm64PhysFromOrd(d), arm64FpPhysFromOrd(s), precision)))
end 'aa64Fcvtzs'

// FP three-address: dest=def, src1=use, src2=use
function aa64FpThreeAddr(state RegState, dest Arm64FpVReg, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock, opCode RegInt)
	let s1 = arm64ResolveFpUse(state, vreg: src1, dstBlock: dstBlock)
	let s2 = arm64ResolveFpUse(state, vreg: src2, dstBlock: dstBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	let dp = arm64FpPhysFromOrd(d)
	let s1p = arm64FpPhysFromOrd(s1)
	let s2p = arm64FpPhysFromOrd(s2)
	if opCode == 0 'add'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fadd(dp, s1p, s2p, precision)))
	end 'add' else if opCode == 1 'sub'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fsub(dp, s1p, s2p, precision)))
	end 'sub' else if opCode == 2 'mul'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fmul(dp, s1p, s2p, precision)))
	end 'mul' else 'div'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fdiv(dp, s1p, s2p, precision)))
	end 'div'
end 'aa64FpThreeAddr'

// FP unary: dest=def, src=use
function aa64FpUnary(state RegState, dest Arm64FpVReg, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock, opCode RegInt)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	let dp = arm64FpPhysFromOrd(d)
	let sp = arm64FpPhysFromOrd(s)
	if opCode == 0 'sqrt'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fsqrt(dp, sp, precision)))
	end 'sqrt' else if opCode == 1 'abs'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fabs(dp, sp, precision)))
	end 'abs' else if opCode == 2 'neg'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fneg(dp, sp, precision)))
	end 'neg' else if opCode == 3 'fcvt'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fcvt(dp, sp, precision)))
	end 'fcvt' else if opCode == 4 'frintm'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.frintm(dp, sp, precision)))
	end 'frintm' else if opCode == 5 'frintp'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.frintp(dp, sp, precision)))
	end 'frintp' else if opCode == 6 'frintz'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.frintz(dp, sp, precision)))
	end 'frintz' else 'frintn'
		dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.frintn(dp, sp, precision)))
	end 'frintn'
end 'aa64FpUnary'

function aa64Fcmp(state RegState, src1 Arm64FpVReg, src2 Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s1 = arm64ResolveFpUse(state, vreg: src1, dstBlock: dstBlock)
	let s2 = arm64ResolveFpUse(state, vreg: src2, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fcmp(arm64FpPhysFromOrd(s1), arm64FpPhysFromOrd(s2), precision)))
end 'aa64Fcmp'

function aa64FpStoreIndirect(state RegState, baseReg Arm64VReg, offset MachineWord, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let b = arm64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fpStoreIndirect(arm64PhysFromOrd(b), offset, arm64FpPhysFromOrd(s), precision)))
end 'aa64FpStoreIndirect'

function aa64FpLoadIndirect(state RegState, dest Arm64FpVReg, baseReg Arm64VReg, offset MachineWord, precision FloatPrecision, dstBlock MlirBlock)
	let b = arm64ResolveGprUse(state, vreg: baseReg, dstBlock: dstBlock, protect1: RM_NONE, protect2: RM_NONE)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.fpLoadIndirect(arm64FpPhysFromOrd(d), arm64PhysFromOrd(b), offset, precision)))
end 'aa64FpLoadIndirect'

function aa64GlobalLoadFloat(state RegState, dest Arm64FpVReg, name ByteArray, precision FloatPrecision, dstBlock MlirBlock)
	let d = arm64ResolveFpDef(state, vreg: dest, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.globalLoadFloat(arm64FpPhysFromOrd(d), name, precision)))
end 'aa64GlobalLoadFloat'

function aa64GlobalStoreFloat(state RegState, name ByteArray, src Arm64FpVReg, precision FloatPrecision, dstBlock MlirBlock)
	let s = arm64ResolveFpUse(state, vreg: src, dstBlock: dstBlock)
	dstBlock.ops.push(MlirOp.maxarm64(MaxArm64Op.globalStoreFloat(name, arm64FpPhysFromOrd(s), precision)))
end 'aa64GlobalStoreFloat'

// ============================================================
// ARM64 per-op dispatch
// ============================================================

function allocArm64Op(state RegState, a64Op MaxArm64Op, dstBlock MlirBlock)
	match a64Op 'dispatch'
		prologue to epilogue then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		movImm(dest, value) then aa64MovImm(state, dest: dest, value: value, dstBlock: dstBlock)
		strToSlot(slotIndex, src) then aa64StrToSlot(state, slotIndex: slotIndex, src: src, dstBlock: dstBlock)
		ldrFromSlot(dest, slotIndex) then aa64LdrFromSlot(state, dest: dest, slotIndex: slotIndex, dstBlock: dstBlock)
		addRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 0)
		subRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 1)
		mulRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 2)
		sdivRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 3)
		remRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 4)
		negReg(dest, src) then aa64UnaryDestSrc(state, dest: dest, src: src, dstBlock: dstBlock, isNeg: true)
		mvnReg(dest, src) then aa64UnaryDestSrc(state, dest: dest, src: src, dstBlock: dstBlock, isNeg: false)
		andRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 5)
		orrRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 6)
		eorRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 7)
		lslRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 8)
		asrRegs(dest, src1, src2) then aa64ThreeAddr(state, dest: dest, src1: src1, src2: src2, dstBlock: dstBlock, opCode: 9)
		cmpRegs(src1, src2) then aa64CmpRegs(state, src1: src1, src2: src2, dstBlock: dstBlock)
		cmpRegZero(src) then aa64CmpRegZero(state, src: src, dstBlock: dstBlock)
		condBranch to branch then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		branchLink then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		printLiteral to printInt then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		ret then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		syscall to memcpyOp then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		movRegReg(dest, src) then aa64MovRegReg(state, dest: dest, src: src, dstBlock: dstBlock)
		spillToStack(offset, src) then aa64SpillToStack(state, offset: offset, src: src, dstBlock: dstBlock)
		reloadFromStack(dest, offset) then aa64ReloadFromStack(state, dest: dest, offset: offset, dstBlock: dstBlock)
		branchLinkReg(reg) then aa64BranchLinkReg(state, reg: reg, dstBlock: dstBlock)
		subSpImm to addSpImm then dstBlock.ops.push(MlirOp.maxarm64(a64Op))
		strToSpOffset(offset, src) then aa64StrToSpOffset(state, offset: offset, src: src, dstBlock: dstBlock)
		fmovRegReg(dest, src, precision) then aa64FmovRegReg(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		spillFpToStack(offset, src, precision) then aa64SpillFpToStack(state, offset: offset, src: src, precision: precision, dstBlock: dstBlock)
		reloadFpFromStack(dest, offset, precision) then aa64ReloadFpFromStack(state, dest: dest, offset: offset, precision: precision, dstBlock: dstBlock)
		fmovToFloat(dest, src, precision) then aa64FmovToFloat(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		fmovToGpr(dest, src, precision) then aa64FmovToGpr(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		fpLoadRdata(dest, rdataLabel, precision) then aa64FpLoadRdata(state, dest: dest, rdataLabel: rdataLabel, precision: precision, dstBlock: dstBlock)
		fadd(dest, src1, src2, precision) then aa64FpThreeAddr(state, dest: dest, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock, opCode: 0)
		fsub(dest, src1, src2, precision) then aa64FpThreeAddr(state, dest: dest, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock, opCode: 1)
		fmul(dest, src1, src2, precision) then aa64FpThreeAddr(state, dest: dest, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock, opCode: 2)
		fdiv(dest, src1, src2, precision) then aa64FpThreeAddr(state, dest: dest, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock, opCode: 3)
		fsqrt(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 0)
		fabs(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 1)
		fneg(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 2)
		fcmp(src1, src2, precision) then aa64Fcmp(state, src1: src1, src2: src2, precision: precision, dstBlock: dstBlock)
		scvtf(dest, src, precision) then aa64Scvtf(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		fcvtzs(dest, src, precision) then aa64Fcvtzs(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock)
		fcvt(dest, src, destPrecision) then aa64FpUnary(state, dest: dest, src: src, precision: destPrecision, dstBlock: dstBlock, opCode: 3)
		frintm(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 4)
		frintp(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 5)
		frintz(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 6)
		frintn(dest, src, precision) then aa64FpUnary(state, dest: dest, src: src, precision: precision, dstBlock: dstBlock, opCode: 7)
		fpStoreIndirect(baseReg, offset, src, precision) then aa64FpStoreIndirect(state, baseReg: baseReg, offset: offset, src: src, precision: precision, dstBlock: dstBlock)
		fpLoadIndirect(dest, baseReg, offset, precision) then aa64FpLoadIndirect(state, dest: dest, baseReg: baseReg, offset: offset, precision: precision, dstBlock: dstBlock)
		storeIndirect(baseReg, offset, srcReg, size) then aa64StoreIndirect(state, baseReg: baseReg, offset: offset, srcReg: srcReg, size: size, dstBlock: dstBlock)
		loadIndirect(destReg, baseReg, offset, size) then aa64LoadIndirect(state, destReg: destReg, baseReg: baseReg, offset: offset, size: size, dstBlock: dstBlock)
		globalLoad(dest, name, size) then aa64GlobalLoad(state, dest: dest, name: name, size: size, dstBlock: dstBlock)
		globalStore(name, src, size) then aa64GlobalStore(state, name: name, src: src, size: size, dstBlock: dstBlock)
		globalLoadFloat(dest, name, precision) then aa64GlobalLoadFloat(state, dest: dest, name: name, precision: precision, dstBlock: dstBlock)
		globalStoreFloat(name, src, precision) then aa64GlobalStoreFloat(state, name: name, src: src, precision: precision, dstBlock: dstBlock)
		leaFromStack(dest, stackOffset) then aa64LeaFromStack(state, dest: dest, stackOffset: stackOffset, dstBlock: dstBlock)
		leaRdata(dest, rdataLabel) then aa64LeaRdata(state, dest: dest, rdataLabel: rdataLabel, dstBlock: dstBlock)
		leaFuncAddr(dest, funcName) then aa64LeaFuncAddr(state, dest: dest, funcName: funcName, dstBlock: dstBlock)
		cset(dest, condition) then aa64Cset(state, dest: dest, condition: condition, dstBlock: dstBlock)
		csel(dest, src1, src2, condition) then aa64Csel(state, dest: dest, src1: src1, src2: src2, condition: condition, dstBlock: dstBlock)
		sxtw(dest, src) then aa64Sxtw(state, dest: dest, src: src, dstBlock: dstBlock)
		nullSafeLoad(dest, baseReg, offset) then aa64NullSafeLoad(state, dest: dest, baseReg: baseReg, offset: offset, dstBlock: dstBlock)
	end 'dispatch'
end 'allocArm64Op'

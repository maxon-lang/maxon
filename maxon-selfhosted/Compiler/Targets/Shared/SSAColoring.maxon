// SSA-chordal interference graph coloring.
// Exploits the property that SSA interference graphs are chordal,
// so greedy coloring on a dominance-tree preorder gives optimal results.

export typealias RegIntArrayArray = Array with RegIntArray

// ============================================================
// Types
// ============================================================

export type InterferenceGraph
	export var neighbors RegIntArrayArray
	export var numRanges RegInt
	// Flat boolean matrix for O(1) duplicate-edge checks: matrix[a * numRanges + b]
	export var matrix BoolArray

	export static function create(numRanges RegInt) returns InterferenceGraph
		var nbrs = RegIntArrayArray.create()
		var mat = BoolArray.create()
		var i = 0
		while i < numRanges 'init'
			nbrs.push(RegIntArray.create())
			i = i + 1
		end 'init'
		let matSize = numRanges * numRanges
		var mi = 0
		while mi < matSize 'initMat'
			mat.push(false)
			mi = mi + 1
		end 'initMat'
		return Self{neighbors: nbrs, numRanges: numRanges, matrix: mat}
	end 'create'
end 'InterferenceGraph'

export type ColoringResult
	export var assignment RegIntArray

	export static function create(maxValueId RegInt) returns ColoringResult
		var arr = RegIntArray.create()
		var i = 0
		while i < maxValueId 'init'
			arr.push(RM_NONE)
			i = i + 1
		end 'init'
		return Self{assignment: arr}
	end 'create'
end 'ColoringResult'

// Diagnostic context for colorLookupGpr/Fp panics. Populated by applyColoring
// at the start of each function so that an uncolored-vreg panic can dump the
// failing range's full state (def block/pos, intervals) before aborting,
// without threading the LiveRangeArray through every per-op color helper.
// The dump is no-overhead in the success path — it only fires when a panic
// is already inevitable.
//
// Wrapped in a holder type so a single module-level var works (Maxon does not
// allow module-level vars to be initialized with String values directly).
type ColoringDiagContext
	export var funcName String
	export var ranges LiveRangeArray
	export var isSet bool

	export static function create() returns ColoringDiagContext
		return Self{funcName: "", ranges: LiveRangeArray.create(), isSet: false}
	end 'create'
end 'ColoringDiagContext'

var diagContext = ColoringDiagContext.create()

export function setColoringDiagnosticContext(funcName String, ranges LiveRangeArray)
	diagContext.funcName = funcName
	diagContext.ranges = ranges
	diagContext.isSet = true
end 'setColoringDiagnosticContext'

function dumpFailingVreg(id ValueId, kind String)
	if not diagContext.isSet 'noContext'
		logError(LogCategory.ir, message: function() gives "{kind}: vreg v{id} dump skipped — diagnostic context not set")
		return
	end 'noContext'
	logError(LogCategory.ir, message: function() gives "{kind}: vreg v{id} in func={diagContext.funcName} (ranges.count={diagContext.ranges.count()})")
	var found = false
	for range in diagContext.ranges 'scan'
		if range.valueId == id 'match'
			found = true
			logError(LogCategory.ir, message: function() gives "  range: defBlock={range.defBlock} defPosition={range.defPosition} regClass={range.regClass.name} fixedReg={range.fixedReg} hint={range.hint} assignedReg={range.assignedReg} spillWeight={range.spillWeight} crossesCall={range.crossesCall}")
			logError(LogCategory.ir, message: function() gives "  intervals.count={range.intervals.count()}")
			for iv in range.intervals 'eachIv'
				logError(LogCategory.ir, message: function() gives "    interval blockId={iv.blockId} startPos={iv.startPos} endPos={iv.endPos}")
			end 'eachIv'
			logError(LogCategory.ir, message: function() gives "  copyEdges.count={range.copyEdges.count()}")
			for ce in range.copyEdges 'eachCe'
				logError(LogCategory.ir, message: function() gives "    copyEdge partner=v{ce.partnerValueId} blockId={ce.blockId} copyPos={ce.copyPos}")
			end 'eachCe'
		end 'match'
	end 'scan'
	if not found 'notFound'
		logError(LogCategory.ir, message: function() gives "  NO live range was built for v{id} — scanDefinitions never recorded a def for this vreg (likely a missing noteOpDefs arm or a spill/reload rewrite that drops the def)")
	end 'notFound'
end 'dumpFailingVreg'

// Look up the physical GPR ordinal assigned to a virtual value, panicking
// with a helpful message if the value was never colored. Used by every
// target's colorXxxGpr helper.
export function colorLookupGpr(id ValueId, coloring ColoringResult) returns RegOrdinal
	let result = getOr(coloring.assignment, index: id, fallback: RM_NONE)
	if result == RM_NONE 'uncolored'
		dumpFailingVreg(id, kind: "colorLookupGpr")
		panic("colorLookupGpr: virtual GPR v{id} has no coloring assignment (coloring.count={coloring.assignment.count()})")
	end 'uncolored'
	return result
end 'colorLookupGpr'

// Look up the physical FP ordinal assigned to a virtual value, panicking
// with a helpful message if the value was never colored. Used by every
// target's colorXxxFp helper.
export function colorLookupFp(id ValueId, coloring ColoringResult) returns RegOrdinal
	let result = getOr(coloring.assignment, index: id, fallback: RM_NONE)
	if result == RM_NONE 'uncolored'
		dumpFailingVreg(id, kind: "colorLookupFp")
		panic("colorLookupFp: virtual FP vf{id} has no coloring assignment (uncolored/spilled)")
	end 'uncolored'
	return result
end 'colorLookupFp'

// ============================================================
// Public entry point
// ============================================================

// Maximum cascade depth for the Greedy-style eviction picker. Once a range
// has been evicted MAX_CASCADE times, it can no longer be evicted (the
// eviction rule requires strictly-smaller evictee cascade). This bounds the
// number of evictions to `n * MAX_CASCADE` per coloring pass, guaranteeing
// termination. Matches LLVM Greedy's cascade limit.
export let MAX_CASCADE = 8

export function colorSSA(ranges LiveRangeArray, domPreorder BlockIdArray, gprPool RegIntArray, callerSavedGprs RegIntArray, fpPool RegIntArray, callerSavedFps RegIntArray, cascadeByValueId RegIntArray) returns ColoringResult
	// Find max valueId for result sizing
	var maxValueId = 0
	for range in ranges 'findMax'
		if range.valueId >= maxValueId 'higher'
			maxValueId = range.valueId + 1
		end 'higher'
	end 'findMax'

	var result = ColoringResult.create(maxValueId)

	// Separate ranges by register class
	var gprRanges = LiveRangeArray.create()
	var fpRanges = LiveRangeArray.create()

	for range in ranges 'classify'
		match range.regClass 'rc'
			gpr then gprRanges.push(range)
			fp then fpRanges.push(range)
		end 'rc'
	end 'classify'

	// Color each class independently
	colorClass(gprRanges, pool: gprPool, callerSaved: callerSavedGprs, domPreorder: domPreorder, result: result, cascadeByValueId: cascadeByValueId)
	colorClass(fpRanges, pool: fpPool, callerSaved: callerSavedFps, domPreorder: domPreorder, result: result, cascadeByValueId: cascadeByValueId)

	logDebug(LogCategory.ir, message: function() gives "ssa-color: gpr={gprRanges.count()} fp={fpRanges.count()} maxVal={maxValueId}")
	return result
end 'colorSSA'

// ============================================================
// Per-class coloring
// ============================================================

function colorClass(ranges LiveRangeArray, pool RegIntArray, callerSaved RegIntArray, domPreorder BlockIdArray, result ColoringResult, cascadeByValueId RegIntArray)
	let numRanges = ranges.count()
	if numRanges == 0 'empty'
		return
	end 'empty'

	// Build range index -> valueId mapping and reverse (valueId -> range index)
	var rangeValueIds = RegIntArray.create()
	var vidToRangeIdx = RegIntArray.create()
	for range in ranges 'buildMap'
		let ri = rangeValueIds.count()
		rangeValueIds.push(range.valueId)
		let vid = range.valueId
		while vidToRangeIdx.count() <= vid 'grow'
			vidToRangeIdx.push(-1)
		end 'grow'
		try vidToRangeIdx.set(vid, value: ri) otherwise panic("invariant: vidToRangeIdx.set OOB")
	end 'buildMap'

	// Step 1: Build interference graph
	let ig = buildInterferenceGraph(ranges)

	// Step 2: Compute dominance-tree preorder index for sorting
	let domIndex = buildDomPreorderIndex(domPreorder)

	// Step 3: Sort ranges by dom-tree preorder of their def block
	let sortedOrder = sortByDomPreorder(ranges, domIndex: domIndex)

	// Step 4: Greedy coloring in dom-tree preorder
	let poolSize = pool.count()

	// Build reverse map: register ordinal -> pool index for O(1) lookup.
	// Used by markRegUsed/isRegUsed to avoid scanning the pool array.
	var poolIndexOf = RegIntArray.create()
	var pii = 0
	while pii < poolSize 'buildPoolIndex'
		let regOrd = try pool.get(pii) otherwise RM_NONE
		if regOrd != RM_NONE 'valid'
			while poolIndexOf.count() <= regOrd 'grow'
				poolIndexOf.push(RM_NONE)
			end 'grow'
			try poolIndexOf.set(regOrd, value: pii) otherwise panic("invariant: poolIndexOf.set OOB")
		end 'valid'
		pii = pii + 1
	end 'buildPoolIndex'

	// Build pool-index masks marking which pool slots are caller-saved.
	// This lets the fallback walk the pool in the natural order (which
	// preserves the existing scheduling-driven ordering — rax/rdx/rcx last
	// to avoid div/shift clobbers) but still bias the choice toward
	// caller-saved or callee-saved based on the range's crossesCall flag.
	let callerSavedMask = buildCallerSavedMask(pool, callerSaved: callerSaved)

	// Track which color (register) each range index has been assigned
	var rangeColors = RegIntArray.create()
	var ri = 0
	while ri < numRanges 'initColors'
		rangeColors.push(RM_NONE)
		ri = ri + 1
	end 'initColors'

	// First-fit pass in dominance-tree preorder. This pass is optimal under
	// SSA-chordal interference (no eviction needed when register pressure is
	// within bounds), and the dom-preorder ordering preserves the
	// scheduling-friendly hint propagation downstream tools rely on. Phase 4's
	// eviction logic runs as a SECOND pass below, touching only the ranges
	// this first pass left uncolored — so a successful first-fit produces
	// IDENTICAL coloring to the pre-Phase-4 allocator.
	for sortedIdx in sortedOrder 'colorEach'
		let range = try ranges.get(sortedIdx) otherwise panic("invariant: sortedIdx from sortedOrder out of bounds in ranges")

		// Collect registers used by already-colored neighbors
		var usedRegs = BoolArray.create()
		growColorBoolArray(usedRegs, size: poolSize)
		// Track registers strongly preferred by uncolored interfering
		// neighbors (their range.hint). The fallback picker defers these
		// in its first pass so a "scratch" range doesn't burn a register
		// some interfering neighbor has a specific reason to want.
		var hintReservedRegs = BoolArray.create()
		growColorBoolArray(hintReservedRegs, size: poolSize)

		let nbrs = try ig.neighbors.get(sortedIdx) otherwise panic("invariant: sortedIdx out of bounds in ig.neighbors (sized to numRanges)")

		for nbrIdx in nbrs 'eachNbr'
			let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
			if nbrColor != RM_NONE 'colored'
				// Find which pool index this register ordinal maps to
				markRegUsed(usedRegs, regOrd: nbrColor, poolIndexOf: poolIndexOf)
			end 'colored' else 'uncoloredNbr'
				let nbrRange = try ranges.get(nbrIdx) otherwise panic("invariant: nbrIdx from ig.neighbors out of bounds in ranges")
				// A fixed-reg neighbor will inevitably take its fixed register
				// when it's colored — that decision isn't optional. Treat
				// that reg as already taken even while the neighbor is
				// uncolored; otherwise a virtual that interferes with the
				// neighbor can grab the same color and the two ranges share
				// a register, with the downstream codegen silently
				// overwriting one. Hints are still soft (hintReservedRegs)
				// and fall through to the picker's tiered fallback.
				if nbrRange.fixedReg != RM_NONE 'hasFixed'
					markRegUsed(usedRegs, regOrd: nbrRange.fixedReg, poolIndexOf: poolIndexOf)
				end 'hasFixed' else 'noFixed'
					if nbrRange.hint != RM_NONE 'hasHint'
						markRegUsed(hintReservedRegs, regOrd: nbrRange.hint, poolIndexOf: poolIndexOf)
					end 'hasHint'
				end 'noFixed'
			end 'uncoloredNbr'
		end 'eachNbr'

		// Choose a register
		var chosenReg = RM_NONE

		// Hard constraint: fixed register
		if range.fixedReg != RM_NONE 'hasFixed'
			chosenReg = range.fixedReg
		end 'hasFixed' else 'pickReg'

			// Soft constraint: register hint.
			// Check both already-colored neighbors AND uncolored fixed-reg
			// neighbors (which will inevitably get their fixed register).
			var effectiveHint = range.hint

			// Resolve copy-link hint: if no physical hint but a copy partner
			// has been colored, use the partner's color as the hint.
			// If the partner isn't colored yet, check its static hint (e.g.,
			// from the loop body's two-address coalescing) and use that.
			if effectiveHint == RM_NONE and range.copyHintValueId >= 0 'resolveCopyHint'
				effectiveHint = resolveCopyLinkHint(range.copyHintValueId, vidToRangeIdx: vidToRangeIdx, rangeColors: rangeColors, ranges: ranges)
			end 'resolveCopyHint'

			if effectiveHint != RM_NONE 'hasHint'
				let hintConflictsFixed = hintConflictsWithFixedNeighbor(effectiveHint, nbrs: nbrs, ranges: ranges, rangeColors: rangeColors)

				// Honor the hint only when its class is safe for this range.
				// A call-crossing range cannot live in a caller-saved hint;
				// the call would clobber it silently.
				let hintIsCallerSaved = regIsCallerSaved(effectiveHint, pool: pool, callerSavedMask: callerSavedMask)
				let hintClassSafe = range.crossesCall == false or not hintIsCallerSaved

				if not isRegUsed(usedRegs, regOrd: effectiveHint, poolIndexOf: poolIndexOf) and not hintConflictsFixed and hintClassSafe 'hintAvail'
					chosenReg = effectiveHint
				end 'hintAvail'
			end 'hasHint'

			// Fallback: walk the pool, preferring caller-saved or callee-saved
			// based on whether the range survives across a call. The picker
			// also defers registers that an uncolored interfering neighbor
			// has explicitly hinted, falling back to them only when nothing
			// else of the right class is free.
			if chosenReg == RM_NONE 'needFallback'
				let preferCallerSaved = not range.crossesCall
				chosenReg = pickRegFromPool(pool, callerSavedMask: callerSavedMask, usedRegs: usedRegs, hintReservedRegs: hintReservedRegs, preferCallerSaved: preferCallerSaved)
			end 'needFallback'
		end 'pickReg'

		// Store the assignment
		try rangeColors.set(sortedIdx, value: chosenReg) otherwise panic("invariant: rangeColors.set OOB")

		if chosenReg != RM_NONE 'hasColor'
			let vid = range.valueId
			if vid < result.assignment.count() 'inBounds'
				try result.assignment.set(vid, value: chosenReg) otherwise panic("invariant: result.assignment.set OOB")
			end 'inBounds'
		end 'hasColor'
	end 'colorEach'

	// Phase 4: Greedy-style eviction fixup. For every virtual range still
	// uncolored after the first-fit pass, try to evict a lower-priority
	// colored neighbor to make room. The eviction rule (strictly-smaller
	// evictee weight or smaller cascade at equal weight) plus the
	// MAX_CASCADE bound guarantees termination — see the LiveRange.cascade
	// comment for the proof sketch.
	runEvictionFixup(ranges, ig: ig, rangeColors: rangeColors, vidToRangeIdx: vidToRangeIdx, pool: pool, callerSavedMask: callerSavedMask, poolIndexOf: poolIndexOf, poolSize: poolSize, result: result, cascadeByValueId: cascadeByValueId)
end 'colorClass'

// Attempt to color a single range, writing the assignment to `rangeColors` and
// `result` if successful. Computes the used-register set from currently-colored
// neighbors plus fixed-reg neighbors (whose color is inevitable), then runs the
// hint → fallback picker pipeline. Pulled out of the main first-fit loop so the
// eviction fixup can reuse the exact same picker logic — guaranteeing the two
// passes never disagree on what counts as a valid color for a range.
function tryColorRange(sortedIdx RegInt, ranges LiveRangeArray, ig InterferenceGraph, rangeColors RegIntArray, vidToRangeIdx RegIntArray, pool RegIntArray, callerSavedMask BoolArray, poolIndexOf RegIntArray, poolSize RegInt, result ColoringResult) returns RegOrdinal
	let range = try ranges.get(sortedIdx) otherwise panic("invariant: sortedIdx out of bounds in ranges")

	// Collect registers used by already-colored neighbors
	var usedRegs = BoolArray.create()
	growColorBoolArray(usedRegs, size: poolSize)
	// Track registers strongly preferred by uncolored interfering
	// neighbors (their range.hint). The fallback picker defers these
	// in its first pass so a "scratch" range doesn't burn a register
	// some interfering neighbor has a specific reason to want.
	var hintReservedRegs = BoolArray.create()
	growColorBoolArray(hintReservedRegs, size: poolSize)

	let nbrs = try ig.neighbors.get(sortedIdx) otherwise panic("invariant: sortedIdx out of bounds in ig.neighbors (sized to numRanges)")

	for nbrIdx in nbrs 'eachNbr'
		let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
		if nbrColor != RM_NONE 'colored'
			// Find which pool index this register ordinal maps to
			markRegUsed(usedRegs, regOrd: nbrColor, poolIndexOf: poolIndexOf)
		end 'colored' else 'uncoloredNbr'
			let nbrRange = try ranges.get(nbrIdx) otherwise panic("invariant: nbrIdx from ig.neighbors out of bounds in ranges")
			// A fixed-reg neighbor will inevitably take its fixed register
			// when it's colored — that decision isn't optional. Treat
			// that reg as already taken even while the neighbor is
			// uncolored; otherwise a virtual that interferes with the
			// neighbor can grab the same color and the two ranges share
			// a register, with the downstream codegen silently
			// overwriting one. Hints are still soft (hintReservedRegs)
			// and fall through to the picker's tiered fallback.
			if nbrRange.fixedReg != RM_NONE 'hasFixed'
				markRegUsed(usedRegs, regOrd: nbrRange.fixedReg, poolIndexOf: poolIndexOf)
			end 'hasFixed' else 'noFixed'
				if nbrRange.hint != RM_NONE 'hasHint'
					markRegUsed(hintReservedRegs, regOrd: nbrRange.hint, poolIndexOf: poolIndexOf)
				end 'hasHint'
			end 'noFixed'
		end 'uncoloredNbr'
	end 'eachNbr'

	// Choose a register
	var chosenReg = RM_NONE

	// Hard constraint: fixed register
	if range.fixedReg != RM_NONE 'hasFixed'
		chosenReg = range.fixedReg
	end 'hasFixed' else 'pickReg'

		// Soft constraint: register hint.
		// Check both already-colored neighbors AND uncolored fixed-reg
		// neighbors (which will inevitably get their fixed register).
		var effectiveHint = range.hint

		// Resolve copy-link hint: if no physical hint but a copy partner
		// has been colored, use the partner's color as the hint.
		// If the partner isn't colored yet, check its static hint (e.g.,
		// from the loop body's two-address coalescing) and use that.
		if effectiveHint == RM_NONE and range.copyHintValueId >= 0 'resolveCopyHint'
			effectiveHint = resolveCopyLinkHint(range.copyHintValueId, vidToRangeIdx: vidToRangeIdx, rangeColors: rangeColors, ranges: ranges)
		end 'resolveCopyHint'

		if effectiveHint != RM_NONE 'hasHint'
			let hintConflictsFixed = hintConflictsWithFixedNeighbor(effectiveHint, nbrs: nbrs, ranges: ranges, rangeColors: rangeColors)

			// Honor the hint only when its class is safe for this range.
			// A call-crossing range cannot live in a caller-saved hint;
			// the call would clobber it silently.
			let hintIsCallerSaved = regIsCallerSaved(effectiveHint, pool: pool, callerSavedMask: callerSavedMask)
			let hintClassSafe = range.crossesCall == false or not hintIsCallerSaved

			if not isRegUsed(usedRegs, regOrd: effectiveHint, poolIndexOf: poolIndexOf) and not hintConflictsFixed and hintClassSafe 'hintAvail'
				chosenReg = effectiveHint
			end 'hintAvail'
		end 'hasHint'

		// Fallback: walk the pool, preferring caller-saved or callee-saved
		// based on whether the range survives across a call. The picker
		// also defers registers that an uncolored interfering neighbor
		// has explicitly hinted, falling back to them only when nothing
		// else of the right class is free.
		if chosenReg == RM_NONE 'needFallback'
			let preferCallerSaved = not range.crossesCall
			chosenReg = pickRegFromPool(pool, callerSavedMask: callerSavedMask, usedRegs: usedRegs, hintReservedRegs: hintReservedRegs, preferCallerSaved: preferCallerSaved)
		end 'needFallback'
	end 'pickReg'

	// Store the assignment
	try rangeColors.set(sortedIdx, value: chosenReg) otherwise panic("invariant: rangeColors.set OOB")

	if chosenReg != RM_NONE 'hasColor'
		let vid = range.valueId
		if vid < result.assignment.count() 'inBounds'
			try result.assignment.set(vid, value: chosenReg) otherwise panic("invariant: result.assignment.set OOB")
		end 'inBounds'
	end 'hasColor'

	return chosenReg
end 'tryColorRange'

// Greedy-style eviction fixup. After the first-fit pass leaves some virtual
// ranges uncolored, iteratively try to find a colored neighbor with strictly
// lower (weight, cascade) that the uncolored range can evict. The freed
// register goes to the uncolored range; the evictee is re-queued for
// recoloring with cascade bumped by one.
//
// Termination: each eviction strictly increases the evictee's
// (weight, cascade) lexicographic key (weight unchanged, cascade += 1). The
// MAX_CASCADE bound means any individual range can be evicted at most
// MAX_CASCADE times. So the total work across the fixup is O(n * MAX_CASCADE)
// pops.
//
// Ranges left uncolored after this pass fall through to the spill loop
// (RegisterAllocator.runSpillColorLoop) just as before — the fixup never
// makes the picker fail where the first-fit pass succeeded.
function runEvictionFixup(ranges LiveRangeArray, ig InterferenceGraph, rangeColors RegIntArray, vidToRangeIdx RegIntArray, pool RegIntArray, callerSavedMask BoolArray, poolIndexOf RegIntArray, poolSize RegInt, result ColoringResult, cascadeByValueId RegIntArray)
	let numRanges = ranges.count()
	// Worklist of range indices to (re-)try coloring. Initialized from
	// the set of virtual ranges still uncolored after first-fit.
	var pending = RegIntArray.create()
	var ri = 0
	while ri < numRanges 'collect'
		let range = try ranges.get(ri) otherwise panic("invariant: ri < numRanges but ranges.get OOB")
		if range.fixedReg == RM_NONE 'isVirtual'
			let color = try rangeColors.get(ri) otherwise panic("invariant: rangeColors sized to numRanges but get OOB")
			if color == RM_NONE 'uncolored'
				pending.push(ri)
			end 'uncolored'
		end 'isVirtual'
		ri = ri + 1
	end 'collect'

	if pending.count() == 0 'allColored'
		return
	end 'allColored'

	// Safety belt: hard cap on total pops. With proper cascade discipline
	// the cap is `numRanges * (MAX_CASCADE + 1)`; the extra headroom catches
	// any subtle ordering bug without masking a real infinite loop.
	let popCap = numRanges * (MAX_CASCADE + 2) + 32
	var popCount = 0
	// Track whether any eviction has freed a register so far in this pass.
	// If not, calling tryColorRange a SECOND time on a range that first-fit
	// already failed to color is wasted work AND can produce a different
	// (still-valid but observably distinct) coloring because the picker
	// has a hint-deferral tiebreaker that depends on whether interfering
	// neighbors are colored or uncolored — and fixup sees more neighbors
	// colored than first-fit did. Skipping the re-color preserves the
	// pre-Phase-4 coloring on the no-eviction-needed path.
	var anyEvicted = false

	while pending.count() > 0 and popCount < popCap 'evictLoop'
		popCount = popCount + 1

		// Pop the highest-priority pending range: highest spill weight first
		// (so reload vregs with SPILL_WEIGHT_INFINITE go before normal-weight
		// ranges), tiebreak by lowest cascade (a freshly-pending range goes
		// before a range that has already cycled through eviction).
		let pickPos = pickHighestPriority(pending, ranges: ranges)
		let sortedIdx = try pending.get(pickPos) otherwise panic("invariant: pickPos in pending bounds")
		swapPopAt(pending, idx: pickPos)

		// Skip if this range was already colored in a previous eviction step
		// (e.g. an evictee may have been re-queued and then colored on a
		// fresh attempt). Defensive — the cascade discipline should prevent
		// the same range from being colored twice, but cheap to verify.
		let curColor = try rangeColors.get(sortedIdx) otherwise panic("invariant: rangeColors sized to numRanges")
		if curColor != RM_NONE 'alreadyColored'
			continue
		end 'alreadyColored'

		// Only retry coloring if an earlier eviction in THIS pass has freed
		// some register. Otherwise the picker sees the same constraints as
		// first-fit and would produce the same uncolored result — except
		// the hint-deferral tiebreaker can flip if a previously-uncolored
		// neighbor is now colored, which silently shifts the picker's
		// choice for THIS range. That shift is sound but not bit-identical
		// to the pre-Phase-4 baseline, which breaks the "no-eviction
		// inputs produce identical coloring" invariant.
		if anyEvicted 'evictedRecolor'
			let recolor = tryColorRange(sortedIdx, ranges: ranges, ig: ig, rangeColors: rangeColors, vidToRangeIdx: vidToRangeIdx, pool: pool, callerSavedMask: callerSavedMask, poolIndexOf: poolIndexOf, poolSize: poolSize, result: result)
			if recolor != RM_NONE 'gotColor'
				continue
			end 'gotColor'
		end 'evictedRecolor'

		// Still no register. Try eviction.
		let range = try ranges.get(sortedIdx) otherwise panic("invariant: sortedIdx in ranges bounds")

		// Restrict eviction to high-priority ranges: reload vregs
		// (SPILL_WEIGHT_INFINITE). For normal-weight ranges, evicting a
		// colored neighbor would just trade one spill for another — the
		// spill picker already does that calculus better, and the resulting
		// reload chain may grow pressure at downstream points rather than
		// reduce it (sha256 case). Reloads MUST be colored or the allocator
		// panics, so they alone justify the cost of cascading evictions.
		if range.spillWeight != SPILL_WEIGHT_INFINITE 'normalWeight'
			continue
		end 'normalWeight'

		if range.cascade >= MAX_CASCADE 'cascadeExhausted'
			// Cannot evict any neighbor — the eviction rule requires the
			// evictee's (weight, cascade) be STRICTLY smaller than the
			// evictor's, and a range at MAX_CASCADE has the maximum possible
			// cascade. Leave uncolored; the spill loop handles it.
			logTrace(LogCategory.ir, message: function() gives "ssa-color: cascade-exhausted v{range.valueId} (cascade={range.cascade})")
			continue
		end 'cascadeExhausted'

		let evicteeIdx = pickEvictionVictim(sortedIdx, ranges: ranges, ig: ig, rangeColors: rangeColors, pool: pool, callerSavedMask: callerSavedMask)
		if evicteeIdx < 0 'noVictim'
			// No evictable neighbor — fall through to spill loop.
			logTrace(LogCategory.ir, message: function() gives "ssa-color: no-evictee v{range.valueId} (weight={range.spillWeight}, cascade={range.cascade})")
			continue
		end 'noVictim'

		// Evict the victim: clear its color, bump its cascade, persist the
		// new cascade to the sidetable so it survives the next liveness
		// rebuild, and push it back onto the pending list.
		let evictedReg = try rangeColors.get(evicteeIdx) otherwise panic("invariant: evicteeIdx is colored neighbor (just selected)")
		try rangeColors.set(evicteeIdx, value: RM_NONE) otherwise panic("invariant: rangeColors.set OOB")
		// Mutate the evictee's cascade and clear its color in result.
		// Pulled into a helper so the `var evictee` borrow of `ranges`
		// is released before the next iteration tries to scan it.
		let evicteeVid = bumpEvicteeCascade(ranges, evicteeIdx: evicteeIdx, cascadeByValueId: cascadeByValueId, result: result)
		pending.push(evicteeIdx)
		anyEvicted = true

		logTrace(LogCategory.ir, message: function() gives "ssa-color: evict v{evicteeVid} reg={evictedReg} for v{range.valueId}(w={range.spillWeight},c={range.cascade})")

		// Now retry coloring the evictor. With the evictee's register freed,
		// the picker should succeed — unless another neighbor also occupies
		// every register acceptable for this range's class. In that
		// pathological case the picker returns RM_NONE again, and we leave
		// the range pending for another round (a different victim may be
		// eligible next time).
		let postEvictColor = tryColorRange(sortedIdx, ranges: ranges, ig: ig, rangeColors: rangeColors, vidToRangeIdx: vidToRangeIdx, pool: pool, callerSavedMask: callerSavedMask, poolIndexOf: poolIndexOf, poolSize: poolSize, result: result)
		if postEvictColor == RM_NONE 'stillUncolored'
			// Re-queue for another eviction attempt. Cascade unchanged for
			// the evictor — only the evictee's cascade was bumped. The next
			// pop will try a different victim (or fall through if none).
			pending.push(sortedIdx)
		end 'stillUncolored'
	end 'evictLoop'

	if popCount >= popCap 'capHit'
		// Safety belt — should never fire if the cascade discipline is
		// correct. If it does, the spill loop still recovers (uncolored
		// ranges are spilled), but the bug needs investigating.
		logError(LogCategory.ir, message: function() gives "ssa-color: eviction-fixup pop-cap hit ({popCount} pops, {pending.count()} still pending) — possible cascade-bookkeeping bug")
	end 'capHit'
end 'runEvictionFixup'

// Bump the evictee's cascade by 1 and clear its `result.assignment` entry.
// The `var evictee = ranges.get(...)` borrow is scoped to this function so
// the caller can immediately resume mutating `ranges` (or do another
// `ranges.get(...)`-and-mutate cycle) without tripping the borrow checker.
// Returns the evictee's valueId so the caller can fold it into a log
// message without re-borrowing `ranges`.
function bumpEvicteeCascade(ranges LiveRangeArray, evicteeIdx RegInt, cascadeByValueId RegIntArray, result ColoringResult) returns RegInt
	var evictee = try ranges.get(evicteeIdx) otherwise panic("invariant: evicteeIdx in ranges bounds")
	let vid = evictee.valueId
	if vid < result.assignment.count() 'inBounds'
		try result.assignment.set(vid, value: RM_NONE) otherwise panic("invariant: result.assignment.set OOB")
	end 'inBounds'
	evictee.cascade = evictee.cascade + 1
	set(cascadeByValueId, index: vid, value: evictee.cascade, sentinel: 0)
	return vid
end 'bumpEvicteeCascade'

// Find the position in `pending` of the highest-priority range. Higher spill
// weight wins; equal weight tiebreaks on lower cascade (a fresher range goes
// before a stale one). Linear scan — `pending` is bounded by the count of
// uncolored ranges, which is small in practice (the first-fit pass colors
// the vast majority).
function pickHighestPriority(pending RegIntArray, ranges LiveRangeArray) returns RegInt
	let n = pending.count()
	if n == 0 'empty'
		panic("pickHighestPriority: pending list empty (caller must check before calling)")
	end 'empty'
	var bestPos = 0
	var bestIdx = try pending.get(0) otherwise panic("invariant: n > 0 but pending.get(0) failed")
	var bestRange = try ranges.get(bestIdx) otherwise panic("invariant: bestIdx in ranges bounds")
	var i = 1
	while i < n 'scan'
		let candIdx = try pending.get(i) otherwise panic("invariant: i < n but pending.get failed")
		let cand = try ranges.get(candIdx) otherwise panic("invariant: candIdx in ranges bounds")
		// Higher weight wins; equal-weight tiebreak: lower cascade wins.
		if cand.spillWeight > bestRange.spillWeight 'higherWeight'
			bestPos = i
			bestIdx = candIdx
			bestRange = cand
		end 'higherWeight' else 'sameOrLower'
			if cand.spillWeight == bestRange.spillWeight and cand.cascade < bestRange.cascade 'lowerCascade'
				bestPos = i
				bestIdx = candIdx
				bestRange = cand
			end 'lowerCascade'
		end 'sameOrLower'
		i = i + 1
	end 'scan'
	return bestPos
end 'pickHighestPriority'

// Remove the entry at position `idx` from `list` by swapping the last entry
// into its slot and popping. O(1); does not preserve list order — fine for
// the worklist semantics of the eviction fixup.
function swapPopAt(list RegIntArray, idx RegInt)
	let last = list.count() - 1
	if idx < last 'notLast'
		let tail = try list.get(last) otherwise panic("invariant: list non-empty before swap")
		try list.set(idx, value: tail) otherwise panic("invariant: list.set OOB during swap-pop")
	end 'notLast'
	try list.pop() otherwise panic("invariant: list non-empty before pop")
end 'swapPopAt'

// Find the best eviction victim for `evictorIdx` from among its colored
// neighbors. The victim's (weight, cascade) must be strictly less than the
// evictor's under lexicographic ordering. Among all eligible victims, we
// pick the one with the LOWEST weight (cheapest to displace); ties on weight
// break to the lowest cascade (a freshly-evicted candidate has more "room"
// for the cascade bump that eviction will inflict).
//
// Fixed-reg ranges are excluded — their assignment is hardwired and cannot
// be moved. Returns -1 if no eligible victim exists; in that case the
// evictor must remain uncolored and fall through to the spill loop.
function pickEvictionVictim(evictorIdx RegInt, ranges LiveRangeArray, ig InterferenceGraph, rangeColors RegIntArray, pool RegIntArray, callerSavedMask BoolArray) returns RegInt
	let evictor = try ranges.get(evictorIdx) otherwise panic("invariant: evictorIdx in ranges bounds")
	let nbrs = try ig.neighbors.get(evictorIdx) otherwise panic("invariant: evictorIdx in ig.neighbors bounds")

	// The evictor must be able to USE the evictee's register after the swap.
	// Otherwise the eviction is pointless: the freed register is one the
	// evictor's class-safety constraint (e.g. crossesCall + caller-saved)
	// would reject. We probe this per-victim by checking whether the
	// candidate register would be acceptable for the evictor.
	let evictorPrefersCallerSaved = not evictor.crossesCall

	var bestNbr = -1
	var bestWeight = i64.max
	var bestCascade = i64.max
	for nbrIdx in nbrs 'each'
		let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
		if nbrColor == RM_NONE 'uncolored'
			continue
		end 'uncolored'

		let nbr = try ranges.get(nbrIdx) otherwise panic("invariant: nbrIdx in ranges bounds")
		// Fixed-reg ranges and infinite-weight reload ranges cannot be
		// evicted — the former because their assignment is hardwired, the
		// latter because the spill loop already considers them
		// unspillable (any attempt to "respill" loops indefinitely).
		if nbr.fixedReg != RM_NONE 'fixed'
			continue
		end 'fixed'
		if nbr.spillWeight == SPILL_WEIGHT_INFINITE 'unspillable'
			continue
		end 'unspillable'

		// Strict lexicographic priority: evictee MUST have either lower
		// weight, or equal weight with lower cascade. Equal (weight, cascade)
		// is NOT allowed — that would enable cycles where two same-priority
		// ranges trade the same register forever.
		let weightLower = nbr.spillWeight < evictor.spillWeight
		let weightEqualCascadeLower = nbr.spillWeight == evictor.spillWeight and nbr.cascade < evictor.cascade
		if not weightLower and not weightEqualCascadeLower 'notEligible'
			continue
		end 'notEligible'

		// The evictor must be able to take the freed register. A
		// non-crossesCall evictor accepts any register; a crossesCall
		// evictor only accepts a callee-saved register (a caller-saved
		// freed reg would be silently clobbered by the intervening call).
		let regIsCS = regIsCallerSaved(nbrColor, pool: pool, callerSavedMask: callerSavedMask)
		if not evictorPrefersCallerSaved and regIsCS 'wrongClass'
			continue
		end 'wrongClass'

		// Among eligible victims, pick the cheapest (lowest weight); break
		// ties on lowest cascade.
		if nbr.spillWeight < bestWeight 'newBest'
			bestNbr = nbrIdx
			bestWeight = nbr.spillWeight
			bestCascade = nbr.cascade
		end 'newBest' else 'sameOrHigher'
			if nbr.spillWeight == bestWeight and nbr.cascade < bestCascade 'tiebreak'
				bestNbr = nbrIdx
				bestCascade = nbr.cascade
			end 'tiebreak'
		end 'sameOrHigher'
	end 'each'

	return bestNbr
end 'pickEvictionVictim'

// Build a parallel BoolArray indexed by pool position: true if the register
// at that pool position is caller-saved. Computed once per coloring pass and
// reused for every range, so the fallback loop avoids quadratic re-scans of
// the (small but non-trivial) callerSaved list.
function buildCallerSavedMask(pool RegIntArray, callerSaved RegIntArray) returns BoolArray
	var mask = BoolArray.create()
	let poolSize = pool.count()
	var pi = 0
	while pi < poolSize 'each'
		let reg = try pool.get(pi) otherwise RM_NONE
		mask.push(regIntArrayContains(callerSaved, value: reg))
		pi = pi + 1
	end 'each'
	return mask
end 'buildCallerSavedMask'

// Pick a register from the pool. Walks the pool once and tracks candidates
// in priority order:
//   Tier 1 (best): preferred class AND not reserved by an uncolored hinted neighbor
//   Tier 2:        preferred class but reserved (give up the hint)
//   Tier 3:        wrong class — only safe for preferCallerSaved=true (non-
//                  call-crossing range); a callee-saved fallback there costs
//                  one extra prologue save. For preferCallerSaved=false (call-
//                  crossing range) a caller-saved fallback would be silently
//                  clobbered by the intervening call, so we return RM_NONE
//                  and let the spill-and-retry loop materialize the value to
//                  a stack slot across the call.
function pickRegFromPool(pool RegIntArray, callerSavedMask BoolArray, usedRegs BoolArray, hintReservedRegs BoolArray, preferCallerSaved bool) returns RegOrdinal
	let poolSize = pool.count()
	var bestTier1 = RM_NONE
	var bestTier2 = RM_NONE
	var bestTier3 = RM_NONE
	var pi = 0
	while pi < poolSize 'scan'
		let reg = try pool.get(pi) otherwise panic("pickColor: pi < poolSize just succeeded but pool.get({pi}) failed (poolSize={poolSize})")
		let isCallerSaved = try callerSavedMask.get(pi) otherwise panic("pickColor: callerSavedMask must be parallel to pool but get({pi}) failed (poolSize={poolSize}, mask.count={callerSavedMask.count()})")
		let matchesClass = isCallerSaved == preferCallerSaved

		let poolUsed = try usedRegs.get(pi) otherwise panic("pickColor: usedRegs must be parallel to pool but get({pi}) failed (poolSize={poolSize}, usedRegs.count={usedRegs.count()})")
		if poolUsed 'inUse'
			pi = pi + 1
			continue
		end 'inUse'

		let isReserved = try hintReservedRegs.get(pi) otherwise panic("pickColor: hintReservedRegs must be parallel to pool but get({pi}) failed (poolSize={poolSize}, hintReservedRegs.count={hintReservedRegs.count()})")

		if matchesClass and not isReserved 'tier1'
			if bestTier1 == RM_NONE 'firstTier1'
				bestTier1 = reg
			end 'firstTier1'
		end 'tier1' else if matchesClass 'tier2'
			if bestTier2 == RM_NONE 'firstTier2'
				bestTier2 = reg
			end 'firstTier2'
		end 'tier2' else 'tier3'
			if bestTier3 == RM_NONE 'firstTier3'
				bestTier3 = reg
			end 'firstTier3'
		end 'tier3'

		pi = pi + 1
	end 'scan'

	if bestTier1 != RM_NONE 'haveTier1'
		return bestTier1
	end 'haveTier1'
	if bestTier2 != RM_NONE 'haveTier2'
		return bestTier2
	end 'haveTier2'
	// Tier 3 (wrong class) is only safe for non-call-crossing ranges. A
	// call-crossing range placed in a caller-saved register would be silently
	// clobbered by the intervening call (precisely the bug that
	// `mrt_f64_to_string` exposes when the f64 pool contains no callee-saved
	// option: pow's xmm result evaporates across an intervening mrt_alloc).
	// Returning RM_NONE forces the spill-and-retry loop to materialize the
	// value to a stack slot across the call instead.
	if preferCallerSaved 'tier3OK'
		return bestTier3
	end 'tier3OK'
	return RM_NONE
end 'pickRegFromPool'

// ============================================================
// Interference graph construction
// ============================================================

function buildInterferenceGraph(ranges LiveRangeArray) returns InterferenceGraph
	let numRanges = ranges.count()
	var ig = InterferenceGraph.create(numRanges)

	// Build a block -> list of (rangeIdx, startPos, endPos) map
	// for efficient per-block overlap checking.
	// First find the max blockId
	var maxBlockId = 0
	for range in ranges 'findMaxBlock'
		for interval in range.intervals 'eachInt'
			if interval.blockId > maxBlockId 'higher'
				maxBlockId = interval.blockId
			end 'higher'
		end 'eachInt'
	end 'findMaxBlock'

	let numBlocks = maxBlockId + 1

	// blockRanges[blockId] = array of range indices that have an interval in this block
	var blockRanges = RegIntArrayArray.create()
	var blockStarts = RegIntArrayArray.create()
	var blockEnds = RegIntArrayArray.create()

	var bi = 0
	while bi < numBlocks 'initBlockMaps'
		blockRanges.push(RegIntArray.create())
		blockStarts.push(RegIntArray.create())
		blockEnds.push(RegIntArray.create())
		bi = bi + 1
	end 'initBlockMaps'

	// Populate block maps
	var rangeIdx = 0
	for range in ranges 'populateBlocks'
		for interval in range.intervals 'eachInt2'
			let bid = interval.blockId

			if bid < numBlocks 'inBounds'
				// blockRanges/blockStarts/blockEnds are all sized to numBlocks; bid < numBlocks
				// was just checked, so all three lookups are in-bounds.
				try 'recordInterval'
					var br = blockRanges.get(bid)
					var bs = blockStarts.get(bid)
					var be = blockEnds.get(bid)
					br.push(rangeIdx)
					bs.push(interval.startPos)
					be.push(interval.endPos)
				end 'recordInterval' otherwise (e) 'badInterval'
					match e 'kind'
						indexOutOfBounds then panic("invariant: bid < numBlocks but parallel block-info array.get OOB")
						emptySlot then panic("invariant: parallel block-info array slot empty (push-init guarantees fill)")
					end 'kind'
				end 'badInterval'
			end 'inBounds'
		end 'eachInt2'
		rangeIdx = rangeIdx + 1
	end 'populateBlocks'

	// For each block, sweep intervals in start-position order. The active
	// set holds positions (into the block's parallel br/bs/be arrays) for
	// ranges whose interval has begun but not yet ended at the sweep
	// point. On each new arrival we (a) retire active entries whose endPos
	// has passed, then (b) emit interference vs every survivor (they
	// overlap the new range by construction), then (c) add the new range
	// to the active set. This is O(R log R + edges) per block versus a
	// naive O(R^2) pairwise scan; both addInterference and
	// isCopyBoundaryOverlap are symmetric in (a,b), so swapping argument
	// order at the call site is safe.
	var active = RegIntArray.create()
	var blockId = 0
	while blockId < numBlocks 'eachBlock'
		let br = try blockRanges.get(blockId) otherwise 'noBr2'
			blockId = blockId + 1
			continue
		end 'noBr2'
		let bs = try blockStarts.get(blockId) otherwise 'noBs2'
			blockId = blockId + 1
			continue
		end 'noBs2'
		let be = try blockEnds.get(blockId) otherwise 'noBe2'
			blockId = blockId + 1
			continue
		end 'noBe2'

		let count = br.count()
		active.clear()

		let order = sortBlockIndicesByStart(bs)

		var oi = 0
		while oi < count 'sweep'
			let idx = try order.get(oi) otherwise panic("buildInterference: order.get({oi}) OOB (count={count}, order.count={order.count()})")
			let ri1 = try br.get(idx) otherwise panic("buildInterference: br.get({idx}) OOB (count={count})")
			let s1 = try bs.get(idx) otherwise panic("buildInterference: bs.get({idx}) OOB (count={count})")
			let e1 = try be.get(idx) otherwise panic("buildInterference: be.get({idx}) OOB (count={count})")

			// Retire active entries whose interval ended at or before s1.
			// Half-open semantics: a range ending at endPos shares no position
			// with a range starting at endPos, matching the original
			// (s1 < e2 and s2 < e1) overlap test.
			var ai = 0
			while ai < active.count() 'retire'
				let activeIdx = try active.get(ai) otherwise panic("buildInterference: active.get({ai}) OOB")
				let activeEnd = try be.get(activeIdx) otherwise panic("buildInterference: be.get({activeIdx}) OOB for active entry")
				if activeEnd <= s1 'expired'
					// Swap-pop: O(1) removal that doesn't preserve order.
					let lastPos = active.count() - 1
					if ai != lastPos 'notLast'
						let tail = try active.get(lastPos) otherwise panic("buildInterference: active.get(lastPos) OOB")
						try active.set(ai, value: tail) otherwise panic("buildInterference: active.set OOB during swap-pop")
					end 'notLast'
					try active.pop() otherwise panic("buildInterference: active.pop on non-empty active set must succeed")
				end 'expired' else 'stillLive'
					ai = ai + 1
				end 'stillLive'
			end 'retire'

			// Every surviving active entry overlaps the new range — its
			// startPos <= s1 and its endPos > s1, so [s1, min(activeEnd, e1))
			// is non-empty.
			var ei = 0
			while ei < active.count() 'emit'
				let activeIdx = try active.get(ei) otherwise panic("buildInterference: active.get({ei}) OOB during emit")
				let ri2 = try br.get(activeIdx) otherwise panic("buildInterference: br.get({activeIdx}) OOB during emit")
				let s2 = try bs.get(activeIdx) otherwise panic("buildInterference: bs.get({activeIdx}) OOB during emit")
				let e2 = try be.get(activeIdx) otherwise panic("buildInterference: be.get({activeIdx}) OOB during emit")

				// Skip interference for copy-connected ranges that overlap by
				// exactly 1 position at the copy boundary. This happens when
				// the source's interval is [_, P+1) and the dest starts at [P, _):
				// they share only position P (the movRegReg instruction).
				let isCopyBoundary = isCopyBoundaryOverlap(s1, e1: e1, s2: s2, e2: e2, blockId: blockId, ranges: ranges, ri1: ri1, ri2: ri2)
				if not isCopyBoundary 'realOverlap'
					addInterference(ig, a: ri1, b: ri2)
				end 'realOverlap'

				ei = ei + 1
			end 'emit'

			active.push(idx)
			oi = oi + 1
		end 'sweep'

		blockId = blockId + 1
	end 'eachBlock'

	return ig
end 'buildInterferenceGraph'

// Insertion-sort permutation: returns indices 0..bs.count() sorted by
// bs[idx] ascending. Per-block live-range counts are bounded (typically
// 10-100), so insertion sort is faster than a recursive quicksort once
// constants are folded in, and trivially stable.
function sortBlockIndicesByStart(bs RegIntArray) returns RegIntArray
	let count = bs.count()
	var order = RegIntArray.create()
	var i = 0
	while i < count 'init'
		order.push(i)
		i = i + 1
	end 'init'

	var si = 1
	while si < count 'sort'
		let keyIdx = try order.get(si) otherwise panic("sortBlockIndicesByStart: order.get({si}) OOB (count={count})")
		let keyStart = try bs.get(keyIdx) otherwise panic("sortBlockIndicesByStart: bs.get({keyIdx}) OOB (count={count})")

		var j = si - 1
		while j >= 0 'insert'
			let jIdx = try order.get(j) otherwise panic("sortBlockIndicesByStart: order.get({j}) OOB during insert")
			let jStart = try bs.get(jIdx) otherwise panic("sortBlockIndicesByStart: bs.get({jIdx}) OOB during insert")
			if jStart <= keyStart 'inPlace'
				break
			end 'inPlace'
			try order.set(j + 1, value: jIdx) otherwise panic("sortBlockIndicesByStart: order.set OOB during insert")
			j = j - 1
		end 'insert'
		try order.set(j + 1, value: keyIdx) otherwise panic("sortBlockIndicesByStart: order.set final OOB")
		si = si + 1
	end 'sort'

	return order
end 'sortBlockIndicesByStart'

// Check if two overlapping intervals only share a single position at a copy boundary.
// Edge-aware: the new `copyEdges` sidetable on each LiveRange anchors every
// copy site at its exact (blockId, copyPos). Two ranges may overlap by exactly
// one position at multiple distinct copy boundaries throughout the function;
// the previous global single-link check (areCopyConnected) over-coalesced when
// a block-arg destination had multiple predecessors, because the last writer
// to `copyHintValueId` won the suppression for every other edge too. Now we
// require the overlap to coincide with a recorded edge on either range.
function isCopyBoundaryOverlap(s1 RegInt, e1 RegInt, s2 RegInt, e2 RegInt, blockId BlockId, ranges LiveRangeArray, ri1 RegInt, ri2 RegInt) returns bool
	// Half-open overlap size: min(e1,e2) - max(s1,s2). Exactly 1 means
	// they share a single position — the copy boundary.
	var minEnd = e1
	if e2 < minEnd 'e2Smaller'
		minEnd = e2
	end 'e2Smaller'
	var maxStart = s1
	if s2 > maxStart 's2Bigger'
		maxStart = s2
	end 's2Bigger'
	if minEnd - maxStart != 1 'notBoundary'
		return false
	end 'notBoundary'

	let overlapPos = maxStart

	let r1 = try ranges.get(ri1) otherwise panic("isCopyBoundaryOverlap: ri1={ri1} out of bounds (ranges.count={ranges.count()})")
	let r2 = try ranges.get(ri2) otherwise panic("isCopyBoundaryOverlap: ri2={ri2} out of bounds (ranges.count={ranges.count()})")

	let edge1 = hasCopyEdgeAt(r1, partner: r2.valueId, blockId: blockId, copyPos: overlapPos)
	let edge2 = hasCopyEdgeAt(r2, partner: r1.valueId, blockId: blockId, copyPos: overlapPos)
	return edge1 or edge2
end 'isCopyBoundaryOverlap'

// Resolve a copy-link hint: if the partner is colored, return its color.
// If not, return the partner's static hint (from two-address coalescing).
function resolveCopyLinkHint(partnerValueId RegInt, vidToRangeIdx RegIntArray, rangeColors RegIntArray, ranges LiveRangeArray) returns RegOrdinal
	let partnerRangeIdx = getOr(vidToRangeIdx, index: partnerValueId, fallback: -1)
	if partnerRangeIdx < 0 'noPartner'
		return RM_NONE
	end 'noPartner'
	let partnerColor = getOr(rangeColors, index: partnerRangeIdx, fallback: RM_NONE)
	if partnerColor != RM_NONE 'colored'
		return partnerColor
	end 'colored'
	// Partner not colored yet — use its static hint if available.
	// partnerRangeIdx came from vidToRangeIdx (>=0 just checked) which holds valid range indices.
	let partnerRange = try ranges.get(partnerRangeIdx) otherwise panic("invariant: partnerRangeIdx from vidToRangeIdx out of bounds in ranges")
	return partnerRange.hint
end 'resolveCopyLinkHint'

// Two ranges are copy-connected if one's copyHintValueId points to the other's valueId.
// Copy-connected ranges at their boundary point should not interfere — the dest
// is a copy of the source and can safely share the same register.
function areCopyConnected(ranges LiveRangeArray, ri1 RegInt, ri2 RegInt) returns bool
	let r1 = try ranges.get(ri1) otherwise panic("invariant: ri1 out of bounds in ranges")
	let r2 = try ranges.get(ri2) otherwise panic("invariant: ri2 out of bounds in ranges")
	return r1.copyHintValueId == r2.valueId or r2.copyHintValueId == r1.valueId
end 'areCopyConnected'

function addInterference(ig InterferenceGraph, a RegInt, b RegInt)
	// Add edge a <-> b using matrix for O(1) duplicate check
	let idxAB = a * ig.numRanges + b
	let alreadyEdge = try ig.matrix.get(idxAB) otherwise panic("addInterference: matrix sized numRanges*numRanges but get({idxAB}) failed (numRanges={ig.numRanges}, matrix.count={ig.matrix.count()}, a={a}, b={b})")
	if alreadyEdge 'duplicate'
		return
	end 'duplicate'

	try ig.matrix.set(idxAB, value: true) otherwise panic("invariant: ig.matrix.set OOB")
	let idxBA = b * ig.numRanges + a
	try ig.matrix.set(idxBA, value: true) otherwise panic("invariant: ig.matrix.set OOB")

	var nbrsA = try ig.neighbors.get(a) otherwise panic("invariant: a out of bounds in ig.neighbors after matrix.get succeeded")
	var nbrsB = try ig.neighbors.get(b) otherwise panic("invariant: b out of bounds in ig.neighbors after matrix.get succeeded")
	nbrsA.push(b)
	nbrsB.push(a)
end 'addInterference'

export function regIntArrayContains(arr RegIntArray, value RegInt) returns bool
	for v in arr 'each'
		if v == value 'found'
			return true
		end 'found'
	end 'each'
	return false
end 'regIntArrayContains'

// ============================================================
// Dominance-tree preorder sorting
// ============================================================

// Build domPreorderIndex[blockId] = position in dominance-tree preorder
function buildDomPreorderIndex(domPreorder BlockIdArray) returns RegIntArray
	var index = RegIntArray.create()
	var pos = 0

	for blockId in domPreorder 'build'
		while index.count() <= blockId 'grow'
			index.push(i64.max)
		end 'grow'
		try index.set(blockId, value: pos) otherwise panic("invariant: index.set OOB")
		pos = pos + 1
	end 'build'

	return index
end 'buildDomPreorderIndex'

// Return range indices sorted by dominator-tree preorder of their def block.
// Uses insertion sort (simple, good enough for typical range counts).
function sortByDomPreorder(ranges LiveRangeArray, domIndex RegIntArray) returns RegIntArray
	let numRanges = ranges.count()
	var order = RegIntArray.create()

	// Initialize with identity permutation
	var i = 0
	while i < numRanges 'init'
		order.push(i)
		i = i + 1
	end 'init'

	// Insertion sort by (domPreorderIndex[range.defBlock], isVirtual, defPosition).
	// Fixed-reg ranges sort before virtual ranges at the same dom position so that
	// their physical register is already marked used when virtual ranges are colored.
	var si = 1
	while si < numRanges 'sort'
		let keyIdx = try order.get(si) otherwise 'skipSort'
			si = si + 1
			continue
		end 'skipSort'

		let keyRange = try ranges.get(keyIdx) otherwise 'skipSort2'
			si = si + 1
			continue
		end 'skipSort2'
		let keyDomPos = getOr(domIndex, index: keyRange.defBlock, fallback: i64.max)
		let keyIsVirtual = keyRange.fixedReg == RM_NONE
		let keyDefPos = keyRange.defPosition

		var j = si - 1
		while j >= 0 'insert'
			let jIdx = try order.get(j) otherwise break
			let jRange = try ranges.get(jIdx) otherwise break
			let jDomPos = getOr(domIndex, index: jRange.defBlock, fallback: i64.max)
			let jIsVirtual = jRange.fixedReg == RM_NONE
			let jDefPos = jRange.defPosition

			// Compare: (domPos, isVirtual, defPos) — fixed-reg before virtual
			if jDomPos < keyDomPos 'inPlace1'
				break
			end 'inPlace1'
			if jDomPos == keyDomPos 'sameDom'
				if not jIsVirtual and keyIsVirtual 'fixedFirst'
					break
				end 'fixedFirst'
				if jIsVirtual == keyIsVirtual and jDefPos <= keyDefPos 'sameKind'
					break
				end 'sameKind'
			end 'sameDom'

			// Shift j to j+1
			try order.set(j + 1, value: jIdx) otherwise panic("invariant: order.set OOB")
			j = j - 1
		end 'insert'

		try order.set(j + 1, value: keyIdx) otherwise panic("invariant: order.set OOB")
		si = si + 1
	end 'sort'

	return order
end 'sortByDomPreorder'

// ============================================================
// Register availability helpers
// ============================================================

function growColorBoolArray(arr BoolArray, size RegInt)
	while arr.count() < size 'grow'
		arr.push(false)
	end 'grow'
end 'growColorBoolArray'

// Check if any uncolored neighbor has a fixedReg matching the hint.
// These neighbors will inevitably be colored to that register, so using
// the hint would create a conflict.
function hintConflictsWithFixedNeighbor(hint RegOrdinal, nbrs RegIntArray, ranges LiveRangeArray, rangeColors RegIntArray) returns bool
	for nbrIdx in nbrs 'eachNbr'
		let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
		if nbrColor == RM_NONE 'uncolored'
			let nbrRange = try ranges.get(nbrIdx) otherwise panic("invariant: nbrIdx from ig.neighbors out of bounds in ranges")
			if nbrRange.fixedReg == hint 'conflicts'
				return true
			end 'conflicts'
		end 'uncolored'
	end 'eachNbr'
	return false
end 'hintConflictsWithFixedNeighbor'

// `regOrd` may be RM_NONE (=-1) for unhinted ranges, or a register from a
// different class than the active pool. Treat both as "not in pool" no-ops.
function markRegUsed(usedRegs BoolArray, regOrd RegInt, poolIndexOf RegIntArray)
	if regOrd < 0 'negative'
		return
	end 'negative'
	let pi = try poolIndexOf.get(regOrd) otherwise RM_NONE
	if pi != RM_NONE 'inPool'
		try usedRegs.set(pi, value: true) otherwise panic("markRegUsed: usedRegs.set({pi}) OOB; usedRegs must be parallel to pool")
	end 'inPool'
end 'markRegUsed'

// Check if a register ordinal is marked as used. See `markRegUsed` for why
// the negative / out-of-pool inputs are valid.
function isRegUsed(usedRegs BoolArray, regOrd RegInt, poolIndexOf RegIntArray) returns bool
	if regOrd < 0 'negative'
		return false
	end 'negative'
	let pi = try poolIndexOf.get(regOrd) otherwise RM_NONE
	if pi == RM_NONE 'notInPool'
		return false
	end 'notInPool'
	return try usedRegs.get(pi) otherwise panic("isRegUsed: usedRegs.get({pi}) OOB; usedRegs must be parallel to pool")
end 'isRegUsed'

// Check if a register ordinal is caller-saved. Used by the hint path to
// reject hints that would place a call-crossing range into a register the
// call would clobber. The pool/mask lookup mirrors isRegUsed so the
// caller-saved classification stays consistent with the fallback tier logic.
function regIsCallerSaved(regOrd RegInt, pool RegIntArray, callerSavedMask BoolArray) returns bool
	let poolSize = pool.count()
	var pi = 0
	while pi < poolSize 'find'
		let poolReg = try pool.get(pi) otherwise panic("regIsCallerSaved: pi < poolSize just succeeded but pool.get({pi}) failed (poolSize={poolSize})")
		if poolReg == regOrd 'match'
			return try callerSavedMask.get(pi) otherwise panic("regIsCallerSaved: callerSavedMask must be parallel to pool but get({pi}) failed (poolSize={poolSize}, mask.count={callerSavedMask.count()})")
		end 'match'
		pi = pi + 1
	end 'find'
	return false
end 'regIsCallerSaved'

// ============================================================
// Conservative coalescing (hint-based)
// ============================================================

// Scan for copy-like operations (movRegReg) and set register hints
// on destination ranges to prefer the same register as the source.
// This is a lightweight form of coalescing that the coloring phase
// supports via the hint field on LiveRange.
//
// returnGprOrd is the target's return register ordinal (or RM_NONE if the
// target has no special return-register handling). When non-RM_NONE, the
// coalescer also runs a reverse-direction pass that overrides any existing
// hint on the value flowing into a trailing `mov retReg, vreg` right before
// a `ret` terminator. The closest-to-death hint is the most valuable one
// for a return value because it costs zero extra moves to honor.
//
// errorFlagOrd is the target's error-flag return register ordinal (RDX on
// x64, X1 on arm64), used to pin inlined-continuation error-flag phis to
// the same register the multi-value-return ABI would have placed them in.
export function coalesceRanges(module TargetModule, ranges LiveRangeArray, func IrFunction, returnGprOrd RegOrdinal, errorFlagOrd RegOrdinal, opQuery TargetOpQuery)
	// Build valueId -> range index map for fast lookup
	var vidToRangeIdx = RegIntArray.create()

	var ri = 0
	while ri < ranges.count() 'buildVidMap'
		let range = try ranges.get(ri) otherwise 'skip'
			ri = ri + 1
			continue
		end 'skip'

		let vid = range.valueId
		while vidToRangeIdx.count() <= vid 'grow'
			vidToRangeIdx.push(-1)
		end 'grow'
		try vidToRangeIdx.set(vid, value: ri) otherwise panic("invariant: vidToRangeIdx.set OOB")

		ri = ri + 1
	end 'buildVidMap'

	// Scan all ops for copy-like patterns. opIdx is the 0-indexed position
	// within the block; opPos = opIdx + 1 matches the interval space used by
	// scanDefinitions (block-arg defs at 0, ops at 1..N, terminator at N+1).
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		var opIdx = 0
		for packed in block.opRefs 'eachOp'
			extractCopyHintsWith(module, packed: packed, blockId: block.id, opPos: opIdx + 1, ranges: ranges, vidToRangeIdx: vidToRangeIdx, opQuery: opQuery)
			opIdx = opIdx + 1
		end 'eachOp'

		if block.hasTerminatorOp() 'hasTerm'
			extractCopyHintsWith(module, packed: block.terminatorIndex(), blockId: block.id, opPos: opIdx + 1, ranges: ranges, vidToRangeIdx: vidToRangeIdx, opQuery: opQuery)
		end 'hasTerm'

		// Hint from outgoing branch edge args -> successor block args.
		// The parallel copy for each branch edge executes in the predecessor
		// block (`block`) at the slot immediately before its terminator —
		// see CopyResolution.buildBlockArgCopies. Anchor the CopyEdge there.
		let predBlockLen = block.opRefs.count() + 1
		let copyPos = predBlockLen - 1
		for edge in block.branchEdges 'eachEdge'
			hintBranchArgs(edge.argIds, targetBlockId: edge.targetBlockId, predBlockId: block.id, copyPos: copyPos, ranges: ranges, vidToRangeIdx: vidToRangeIdx, func: func, module: module)
		end 'eachEdge'
	end 'eachBlock'

	// Reverse-direction pass: override the hint on the return value so that
	// the coloring prefers the return register. This only fires for blocks
	// ending in `ret` and only affects the single vreg feeding the final
	// `mov retReg, vreg`. The override wins over whatever forward pass set
	// earlier because for a return value the death-site hint is terminal.
	if returnGprOrd != RM_NONE 'hasReturnReg'
		applyReturnRegHintOverride(module, ranges: ranges, func: func, vidToRangeIdx: vidToRangeIdx, returnGprOrd: returnGprOrd, opQuery: opQuery)
	end 'hasReturnReg'

	// Final pass: fill in ABI-role hints on inlined-continuation phis that
	// still have no hint after everything else. The role is what the
	// post-call capture mov (`mov virtual(resultId), r8`) used to seed
	// before the inliner replaced calls with continuations. We apply it
	// LAST and only when no other pass has hinted the phi (and the
	// phi's copy-link partner has no hint of its own + doesn't cross a
	// call), so a downstream constraint wins over the role default.
	applyContinuationRoleHints(module, ranges: ranges, func: func, vidToRangeIdx: vidToRangeIdx, returnGprOrd: returnGprOrd, errorFlagOrd: errorFlagOrd)
end 'coalesceRanges'

// Walk every block's blockArgs and seed a physical-register hint on each
// arg whose `returnRole` is non-`none`. These args are continuation phis
// the inliner synthesizes when splicing a multi-block callee; before
// inlining, the post-call capture mov (`mov virtual(resultId), r8`)
// provided the R8 hint anchor and the bidirectional copy link in
// setGprCopyHint propagated it to downstream phis. After inlining, no
// such mov exists — this seed restores the anchor.
//
// Only fills in the hint when the phi has none and its copy-link partner
// also has no hint — i.e. no downstream constraint has pinned this phi
// chain to a different register. If downstream pinned the merge phi to
// a callee-saved register (e.g. because the merge result crosses a
// caller's call), let that constraint flow back through the copy-link
// instead of forcing R8/RDX and synthesizing a save-call-return move
// on every success edge.
function applyContinuationRoleHints(module TargetModule, ranges LiveRangeArray, func IrFunction, vidToRangeIdx RegIntArray, returnGprOrd RegOrdinal, errorFlagOrd RegOrdinal)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		for blockArg in block.blockArgs 'eachArg'
			let physOrd = match blockArg.returnRole 'role'
				none gives RM_NONE
				primaryReturn gives returnGprOrd
				errorFlag gives errorFlagOrd
			end 'role'
			maybeSeedRoleHint(physOrd, virtualId: blockArg.valueId, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
		end 'eachArg'
	end 'eachBlock'
end 'applyContinuationRoleHints'

// Set the role-derived phys hint only when no copy-link partner has a
// stronger preference. Skips the seed when:
//   * the partner already has a hint or fixed register of its own —
//     resolveCopyLinkHint will surface it at coloring time; or
//   * the partner crosses a call. The role hint is always a caller-
//     saved register (R8/RDX), and forcing the inlined return value to
//     a caller-saved register when its downstream merge phi must live
//     in a callee-saved register manufactures a forced save-call-
//     return copy on every success edge.
function maybeSeedRoleHint(physOrd RegOrdinal, virtualId RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if virtualId < 0 or physOrd == RM_NONE 'invalid'
		return
	end 'invalid'

	let rangeIdx = getOr(vidToRangeIdx, index: virtualId, fallback: -1)
	if rangeIdx < 0 'noRange'
		return
	end 'noRange'

	var range = try ranges.get(rangeIdx) otherwise panic("invariant: rangeIdx from vidToRangeIdx out of bounds in ranges")
	if range.hint != RM_NONE 'alreadyHinted'
		return
	end 'alreadyHinted'

	if range.copyHintValueId >= 0 'hasPartner'
		let partnerIdx = getOr(vidToRangeIdx, index: range.copyHintValueId, fallback: -1)
		if partnerIdx >= 0 'partnerExists'
			let partner = try ranges.get(partnerIdx) otherwise panic("invariant: partnerIdx from vidToRangeIdx out of bounds in ranges")
			if partner.hint != RM_NONE or partner.fixedReg != RM_NONE 'partnerHinted'
				return
			end 'partnerHinted'
			if partner.crossesCall 'partnerCrossesCall'
				return
			end 'partnerCrossesCall'
		end 'partnerExists'
	end 'hasPartner'

	range.hint = physOrd
end 'maybeSeedRoleHint'

// (destOrd, srcId) describing a `movRegReg` op as decoded by a target-
// specific helper. destOrd is the destination's physical-register ordinal
// (RM_NONE if not physical); srcId is the source's virtual-register id
// (negative if not virtual). A `notFound` value means the op wasn't a mov.
export type ReturnMovProbe
	export var destOrd RegOrdinal
	export var srcId RegInt
	export var found bool

	export static function notFound() returns ReturnMovProbe
		return Self{destOrd: RM_NONE, srcId: -1, found: false}
	end 'notFound'

	export static function ok(destOrd RegOrdinal, srcId RegInt) returns ReturnMovProbe
		return Self{destOrd: destOrd, srcId: srcId, found: true}
	end 'ok'
end 'ReturnMovProbe'

// For each block that ends in a `ret` terminator, walk opRefs in reverse and
// find the first `movRegReg(physical retReg, virtual src)`. Force src's range
// hint to the return register, overriding any earlier forward-pass hint.
//
// The block walk and reverse scan are shared across targets; only the per-op
// decoding (and the matching ret-terminator check) is target-specific. Both
// are dispatched on `module.cpu` per block and op.
function applyReturnRegHintOverride(module TargetModule, ranges LiveRangeArray, func IrFunction, vidToRangeIdx RegIntArray, returnGprOrd RegOrdinal, opQuery TargetOpQuery)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")

		if not block.hasTerminatorOp() 'noTerm'
			continue
		end 'noTerm'
		if not opQuery.isReturnTerminator(module, packed: block.terminatorIndex()) 'notRet'
			continue
		end 'notRet'

		// Walk opRefs in reverse. The first movRegReg we find is the
		// return-value setup emitted by the target's lowerReturn (which
		// runs immediately before the epilogue+ret pair). Non-mov ops are
		// skipped; the scan stops on the first decoded mov.
		var j = block.opRefs.count() - 1
		while j >= 0 'scanBack'
			let packed = try block.opRefs.get(j) otherwise 'skipBack'
				j = j - 1
				continue
			end 'skipBack'

			let probe = opQuery.decodeReturnMovProbe(module, packed: packed)
			if probe.found 'isMov'
				tryApplyReturnHint(probe.destOrd, srcId: probe.srcId, returnGprOrd: returnGprOrd, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
				break
			end 'isMov'
			j = j - 1
		end 'scanBack'
	end 'eachBlock'
end 'applyReturnRegHintOverride'

// Apply the return-register override if this mov-reg-reg op is the return-
// value setup: movRegReg(physical retReg, virtual src). No-op when the dest
// isn't a physical register, isn't the return register, or src isn't virtual.
function tryApplyReturnHint(destOrd RegOrdinal, srcId RegInt, returnGprOrd RegOrdinal, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if destOrd == RM_NONE 'destNotPhys'
		return
	end 'destNotPhys'
	if destOrd != returnGprOrd 'notReturnReg'
		return
	end 'notReturnReg'
	if srcId < 0 'srcNotVirt'
		return
	end 'srcNotVirt'

	setPhysHintForce(returnGprOrd, virtualId: srcId, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'tryApplyReturnHint'

function extractCopyHintsWith(module TargetModule, packed OpIndex, blockId BlockId, opPos RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray, opQuery TargetOpQuery)
	opQuery.extractCopyHints(module, packed: packed, blockId: blockId, opPos: opPos, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'extractCopyHintsWith'

// For each branch arg, set a copy hint between the arg value and the
// corresponding block arg in the target block. The parallel copy for this
// edge executes in the predecessor block at `copyPos`; CopyEdges anchored
// there let isCopyBoundaryOverlap distinguish per-edge interference (Step 7).
function hintBranchArgs(argIds ValueIdArray, targetBlockId BlockId, predBlockId BlockId, copyPos RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray, func IrFunction, module TargetModule)
	if argIds.count() == 0 'noArgs'
		return
	end 'noArgs'
	let targetBlock = findBlockForHint(module, func: func, blockId: targetBlockId)
	var i = 0
	while i < argIds.count() 'eachArg'
		let srcId = try argIds.get(i) otherwise 'skipArg'
			i = i + 1
			continue
		end 'skipArg'
		let blockArg = try targetBlock.blockArgs.get(i) otherwise 'skipBlockArg'
			i = i + 1
			continue
		end 'skipBlockArg'
		let destId = blockArg.valueId
		setGprCopyHintEdge(destId, srcReg: srcId, blockId: predBlockId, copyPos: copyPos, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
		i = i + 1
	end 'eachArg'
end 'hintBranchArgs'

function findBlockForHint(module TargetModule, func IrFunction, blockId BlockId) returns IrBlock
	for blockRef in func.blockRefs 'search'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		if block.id == blockId 'found'
			return block
		end 'found'
	end 'search'
	panic("findBlockForHint: block {blockId} not found")
end 'findBlockForHint'

// Hint a virtual register to prefer a specific physical register ordinal.
export function setPhysHint(physOrd RegOrdinal, virtualId RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if virtualId < 0 or physOrd == RM_NONE 'invalid'
		return
	end 'invalid'

	let rangeIdx = getOr(vidToRangeIdx, index: virtualId, fallback: -1)
	if rangeIdx < 0 'noRange'
		return
	end 'noRange'

	var range = try ranges.get(rangeIdx) otherwise panic("invariant: rangeIdx from vidToRangeIdx out of bounds in ranges")

	if range.hint == RM_NONE 'noHintYet'
		range.hint = physOrd
	end 'noHintYet'
end 'setPhysHint'

// Like setPhysHint but unconditionally overwrites any existing hint. Used by
// the return-register reverse pass, where the death-site hint is always more
// valuable than a forward-pass birth-site hint.
function setPhysHintForce(physOrd RegOrdinal, virtualId RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if virtualId < 0 or physOrd == RM_NONE 'invalid'
		return
	end 'invalid'

	let rangeIdx = getOr(vidToRangeIdx, index: virtualId, fallback: -1)
	if rangeIdx < 0 'noRange'
		return
	end 'noRange'

	var range = try ranges.get(rangeIdx) otherwise panic("invariant: rangeIdx from vidToRangeIdx out of bounds in ranges")

	range.hint = physOrd
end 'setPhysHintForce'

// Set hint: destination should prefer the same register as source
export function setGprCopyHint(destReg RegInt, srcReg RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if destReg < 0 or srcReg < 0 'physical'
		return
	end 'physical'

	let srcRangeIdx = getOr(vidToRangeIdx, index: srcReg, fallback: -1)
	let destRangeIdx = getOr(vidToRangeIdx, index: destReg, fallback: -1)

	if srcRangeIdx < 0 or destRangeIdx < 0 'noRange'
		return
	end 'noRange'

	// Propagate hint: if source already has a hint, pass it to dest
	var srcRange = try ranges.get(srcRangeIdx) otherwise panic("invariant: srcRangeIdx from vidToRangeIdx out of bounds in ranges")
	var destRange = try ranges.get(destRangeIdx) otherwise panic("invariant: destRangeIdx from vidToRangeIdx out of bounds in ranges")

	// Only set hint if dest doesn't already have one
	// Always maintain the bidirectional copy-link, regardless of whether
	// either side already has a phys hint set. The link is what lets
	// `areCopyConnected` suppress interference at the 1-position copy
	// boundary, so dropping it would prevent the two ranges from ever
	// sharing a register even when their hint says they should.
	if destRange.copyHintValueId < 0 'destNoLink'
		destRange.copyHintValueId = srcReg
	end 'destNoLink'
	if srcRange.copyHintValueId < 0 'srcNoLink'
		srcRange.copyHintValueId = destReg
	end 'srcNoLink'

	if destRange.hint == RM_NONE 'destNoHint'
		if srcRange.fixedReg != RM_NONE 'srcFixed'
			// Source is in a fixed physical register — that's where it
			// inevitably lives, so the dest can prefer the same register
			// directly. This is a strong hint we can never improve on.
			destRange.hint = srcRange.fixedReg
		end 'srcFixed'
		// Note: we do NOT forward-propagate `srcRange.hint` here. A
		// soft hint on src may reflect a birth-side preference, while
		// dest may later acquire a stronger death-side preference via
		// applyReturnRegHintOverride. Leave dest unhinted so
		// resolveCopyLinkHint can lazily pull whichever color src
		// settles on at coloring time.
	end 'destNoHint' else 'destHasHint'
		// Reverse-direction propagation: dest is already pinned (e.g. by
		// applyContinuationRoleHints for an inlined-continuation phi, or
		// by an earlier extractCopyHints physical-side anchor). If src
		// has no hint of its own, push dest's into src directly so the
		// inlined body's value computes into the destination register and
		// the edge copy collapses to a no-op identity move.
		if srcRange.hint == RM_NONE and srcRange.fixedReg == RM_NONE 'srcNoHint'
			srcRange.hint = destRange.hint
		end 'srcNoHint'
	end 'destHasHint'
end 'setGprCopyHint'

// Edge-aware variant of setGprCopyHint. Performs the same hint propagation
// and bidirectional copyHintValueId seeding as setGprCopyHint, then also
// records a CopyEdge on both ranges anchored at (blockId, copyPos). The
// CopyEdge entries are what isCopyBoundaryOverlap will consult (in Step 7)
// to decide whether to suppress interference at exactly this copy site,
// replacing the global single-slot copyHintValueId match.
export function setGprCopyHintEdge(destReg RegInt, srcReg RegInt, blockId BlockId, copyPos RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if destReg < 0 or srcReg < 0 'physical'
		return
	end 'physical'

	// Delegate hint/link seeding to setGprCopyHint. The bidirectional
	// copyHintValueId remains useful for resolveCopyLinkHint's color-hint
	// propagation, so we keep that pathway intact and only add the
	// per-edge anchor on top.
	setGprCopyHint(destReg, srcReg: srcReg, ranges: ranges, vidToRangeIdx: vidToRangeIdx)

	let srcRangeIdx = getOr(vidToRangeIdx, index: srcReg, fallback: -1)
	let destRangeIdx = getOr(vidToRangeIdx, index: destReg, fallback: -1)

	if srcRangeIdx < 0 or destRangeIdx < 0 'noRange'
		return
	end 'noRange'

	var srcRange = try ranges.get(srcRangeIdx) otherwise panic("invariant: srcRangeIdx from vidToRangeIdx out of bounds in ranges")
	var destRange = try ranges.get(destRangeIdx) otherwise panic("invariant: destRangeIdx from vidToRangeIdx out of bounds in ranges")

	addCopyEdge(destRange, partner: srcReg, blockId: blockId, copyPos: copyPos)
	addCopyEdge(srcRange, partner: destReg, blockId: blockId, copyPos: copyPos)
end 'setGprCopyHintEdge'

export function setFpCopyHintEdge(destReg RegInt, srcReg RegInt, blockId BlockId, copyPos RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	// Same logic as GPR edge-aware copy hint
	setGprCopyHintEdge(destReg, srcReg: srcReg, blockId: blockId, copyPos: copyPos, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'setFpCopyHintEdge'

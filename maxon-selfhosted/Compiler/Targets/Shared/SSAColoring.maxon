// SSA-chordal interference graph coloring.
// Exploits the property that SSA interference graphs are chordal,
// so greedy coloring on a dominance-tree preorder gives optimal results.

export typealias RegIntArrayArray = Array with RegIntArray

// ============================================================
// Types
// ============================================================

export type InterferenceGraph
	export var neighbors RegIntArrayArray
	export var numRanges RegInt
	// Flat boolean matrix for O(1) duplicate-edge checks: matrix[a * numRanges + b]
	export var matrix BoolArray

	export static function create(numRanges RegInt) returns InterferenceGraph
		var nbrs = RegIntArrayArray.create()
		var mat = BoolArray.create()
		var i = 0
		while i < numRanges 'init'
			nbrs.push(RegIntArray.create())
			i = i + 1
		end 'init'
		let matSize = numRanges * numRanges
		var mi = 0
		while mi < matSize 'initMat'
			mat.push(false)
			mi = mi + 1
		end 'initMat'
		return Self{neighbors: nbrs, numRanges: numRanges, matrix: mat}
	end 'create'
end 'InterferenceGraph'

export type ColoringResult
	export var assignment RegIntArray

	export static function create(maxValueId RegInt) returns ColoringResult
		var arr = RegIntArray.create()
		var i = 0
		while i < maxValueId 'init'
			arr.push(RM_NONE)
			i = i + 1
		end 'init'
		return Self{assignment: arr}
	end 'create'
end 'ColoringResult'

// Look up the physical GPR ordinal assigned to a virtual value, panicking
// with a helpful message if the value was never colored. Used by every
// target's colorXxxGpr helper.
export function colorLookupGpr(id ValueId, coloring ColoringResult) returns RegOrdinal
	let result = getOr(coloring.assignment, index: id, fallback: RM_NONE)
	if result == RM_NONE 'uncolored'
		panic("colorLookupGpr: virtual GPR v{id} has no coloring assignment (coloring.count={coloring.assignment.count()})")
	end 'uncolored'
	return result
end 'colorLookupGpr'

// Look up the physical FP ordinal assigned to a virtual value, panicking
// with a helpful message if the value was never colored. Used by every
// target's colorXxxFp helper.
export function colorLookupFp(id ValueId, coloring ColoringResult) returns RegOrdinal
	let result = getOr(coloring.assignment, index: id, fallback: RM_NONE)
	if result == RM_NONE 'uncolored'
		panic("colorLookupFp: virtual FP vf{id} has no coloring assignment (uncolored/spilled)")
	end 'uncolored'
	return result
end 'colorLookupFp'

// ============================================================
// Public entry point
// ============================================================

export function colorSSA(ranges LiveRangeArray, domPreorder BlockIdArray, gprPool RegIntArray, callerSavedGprs RegIntArray, fpPool RegIntArray, callerSavedFps RegIntArray) returns ColoringResult
	// Find max valueId for result sizing
	var maxValueId = 0
	for range in ranges 'findMax'
		if range.valueId >= maxValueId 'higher'
			maxValueId = range.valueId + 1
		end 'higher'
	end 'findMax'

	var result = ColoringResult.create(maxValueId)

	// Separate ranges by register class
	var gprRanges = LiveRangeArray.create()
	var fpRanges = LiveRangeArray.create()

	for range in ranges 'classify'
		match range.regClass 'rc'
			gpr then gprRanges.push(range)
			fp then fpRanges.push(range)
		end 'rc'
	end 'classify'

	// Color each class independently
	colorClass(gprRanges, pool: gprPool, callerSaved: callerSavedGprs, domPreorder: domPreorder, result: result)
	colorClass(fpRanges, pool: fpPool, callerSaved: callerSavedFps, domPreorder: domPreorder, result: result)

	logDebug(LogCategory.ir, message: () gives "ssa-color: gpr={gprRanges.count()} fp={fpRanges.count()} maxVal={maxValueId}")
	return result
end 'colorSSA'

// ============================================================
// Per-class coloring
// ============================================================

function colorClass(ranges LiveRangeArray, pool RegIntArray, callerSaved RegIntArray, domPreorder BlockIdArray, result ColoringResult)
	let numRanges = ranges.count()
	if numRanges == 0 'empty'
		return
	end 'empty'

	// Build range index -> valueId mapping and reverse (valueId -> range index)
	var rangeValueIds = RegIntArray.create()
	var vidToRangeIdx = RegIntArray.create()
	for range in ranges 'buildMap'
		let ri = rangeValueIds.count()
		rangeValueIds.push(range.valueId)
		let vid = range.valueId
		while vidToRangeIdx.count() <= vid 'grow'
			vidToRangeIdx.push(-1)
		end 'grow'
		vidToRangeIdx.set(vid, value: ri)
	end 'buildMap'

	// Step 1: Build interference graph
	let ig = buildInterferenceGraph(ranges)

	// Step 2: Compute dominance-tree preorder index for sorting
	let domIndex = buildDomPreorderIndex(domPreorder)

	// Step 3: Sort ranges by dom-tree preorder of their def block
	let sortedOrder = sortByDomPreorder(ranges, domIndex: domIndex)

	// Step 4: Greedy coloring in dom-tree preorder
	let poolSize = pool.count()

	// Build reverse map: register ordinal -> pool index for O(1) lookup.
	// Used by markRegUsed/isRegUsed to avoid scanning the pool array.
	var poolIndexOf = RegIntArray.create()
	var pii = 0
	while pii < poolSize 'buildPoolIndex'
		let regOrd = try pool.get(pii) otherwise RM_NONE
		if regOrd != RM_NONE 'valid'
			while poolIndexOf.count() <= regOrd 'grow'
				poolIndexOf.push(RM_NONE)
			end 'grow'
			poolIndexOf.set(regOrd, value: pii)
		end 'valid'
		pii = pii + 1
	end 'buildPoolIndex'

	// Build pool-index masks marking which pool slots are caller-saved.
	// This lets the fallback walk the pool in the natural order (which
	// preserves the existing scheduling-driven ordering — rax/rdx/rcx last
	// to avoid div/shift clobbers) but still bias the choice toward
	// caller-saved or callee-saved based on the range's crossesCall flag.
	let callerSavedMask = buildCallerSavedMask(pool, callerSaved: callerSaved)

	// Track which color (register) each range index has been assigned
	var rangeColors = RegIntArray.create()
	var ri = 0
	while ri < numRanges 'initColors'
		rangeColors.push(RM_NONE)
		ri = ri + 1
	end 'initColors'

	for sortedIdx in sortedOrder 'colorEach'
		let range = try ranges.get(sortedIdx) otherwise 'skipRange'
			continue
		end 'skipRange'

		// Collect registers used by already-colored neighbors
		var usedRegs = BoolArray.create()
		growColorBoolArray(usedRegs, size: poolSize)
		// Track registers strongly preferred by uncolored interfering
		// neighbors (their range.hint). The fallback picker defers these
		// in its first pass so a "scratch" range doesn't burn a register
		// some interfering neighbor has a specific reason to want.
		var hintReservedRegs = BoolArray.create()
		growColorBoolArray(hintReservedRegs, size: poolSize)

		let nbrs = try ig.neighbors.get(sortedIdx) otherwise 'noNbrs'
			continue
		end 'noNbrs'

		for nbrIdx in nbrs 'eachNbr'
			let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
			if nbrColor != RM_NONE 'colored'
				// Find which pool index this register ordinal maps to
				markRegUsed(usedRegs, regOrd: nbrColor, poolIndexOf: poolIndexOf)
			end 'colored' else 'uncoloredNbr'
				let nbrRange = try ranges.get(nbrIdx) otherwise 'skipNbrRange'
					continue
				end 'skipNbrRange'
				if nbrRange.hint != RM_NONE 'hasHint'
					markRegUsed(hintReservedRegs, regOrd: nbrRange.hint, poolIndexOf: poolIndexOf)
				end 'hasHint'
			end 'uncoloredNbr'
		end 'eachNbr'

		// Choose a register
		var chosenReg = RM_NONE

		// Hard constraint: fixed register
		if range.fixedReg != RM_NONE 'hasFixed'
			chosenReg = range.fixedReg
		end 'hasFixed' else 'pickReg'

			// Soft constraint: register hint.
			// Check both already-colored neighbors AND uncolored fixed-reg
			// neighbors (which will inevitably get their fixed register).
			var effectiveHint = range.hint

			// Resolve copy-link hint: if no physical hint but a copy partner
			// has been colored, use the partner's color as the hint.
			// If the partner isn't colored yet, check its static hint (e.g.,
			// from the loop body's two-address coalescing) and use that.
			if effectiveHint == RM_NONE and range.copyHintValueId >= 0 'resolveCopyHint'
				effectiveHint = resolveCopyLinkHint(range.copyHintValueId, vidToRangeIdx: vidToRangeIdx, rangeColors: rangeColors, ranges: ranges)
			end 'resolveCopyHint'

			if effectiveHint != RM_NONE 'hasHint'
				let hintConflictsFixed = hintConflictsWithFixedNeighbor(effectiveHint, nbrs: nbrs, ranges: ranges, rangeColors: rangeColors)

				if not isRegUsed(usedRegs, regOrd: effectiveHint, poolIndexOf: poolIndexOf) and not hintConflictsFixed 'hintAvail'
					chosenReg = effectiveHint
				end 'hintAvail'
			end 'hasHint'

			// Fallback: walk the pool, preferring caller-saved or callee-saved
			// based on whether the range survives across a call. The picker
			// also defers registers that an uncolored interfering neighbor
			// has explicitly hinted, falling back to them only when nothing
			// else of the right class is free.
			if chosenReg == RM_NONE 'needFallback'
				let preferCallerSaved = not range.crossesCall
				chosenReg = pickRegFromPool(pool, callerSavedMask: callerSavedMask, usedRegs: usedRegs, hintReservedRegs: hintReservedRegs, preferCallerSaved: preferCallerSaved)
			end 'needFallback'
		end 'pickReg'

		// Store the assignment
		rangeColors.set(sortedIdx, value: chosenReg)

		if chosenReg != RM_NONE 'hasColor'
			let vid = range.valueId
			if vid < result.assignment.count() 'inBounds'
				result.assignment.set(vid, value: chosenReg)
			end 'inBounds'
		end 'hasColor'
	end 'colorEach'
end 'colorClass'

// Build a parallel BoolArray indexed by pool position: true if the register
// at that pool position is caller-saved. Computed once per coloring pass and
// reused for every range, so the fallback loop avoids quadratic re-scans of
// the (small but non-trivial) callerSaved list.
function buildCallerSavedMask(pool RegIntArray, callerSaved RegIntArray) returns BoolArray
	var mask = BoolArray.create()
	let poolSize = pool.count()
	var pi = 0
	while pi < poolSize 'each'
		let reg = try pool.get(pi) otherwise RM_NONE
		mask.push(regIntArrayContains(callerSaved, value: reg))
		pi = pi + 1
	end 'each'
	return mask
end 'buildCallerSavedMask'

// Pick a register from the pool. Walks the pool once and tracks three
// fallback candidates in priority order:
//   Tier 1 (best):  preferred class AND not reserved by an uncolored hinted neighbor
//   Tier 2:         preferred class but reserved (give up the hint)
//   Tier 3 (worst): wrong class (give up the call-cross preference)
// preferCallerSaved is true for ranges that don't survive a call (caller-
// saved is cheaper) and false for ranges that cross a call (callee-saved
// avoids extra spills around the call). Pool order within each tier is
// preserved, so existing scheduling-driven priorities (e.g. rax/rdx last)
// still apply within the chosen tier.
function pickRegFromPool(pool RegIntArray, callerSavedMask BoolArray, usedRegs BoolArray, hintReservedRegs BoolArray, preferCallerSaved bool) returns RegOrdinal
	let poolSize = pool.count()
	var bestTier1 = RM_NONE
	var bestTier2 = RM_NONE
	var bestTier3 = RM_NONE
	var pi = 0
	while pi < poolSize 'scan'
		let poolUsed = try usedRegs.get(pi) otherwise false
		if poolUsed 'inUse'
			pi = pi + 1
			continue
		end 'inUse'

		let reg = try pool.get(pi) otherwise RM_NONE
		let isCallerSaved = try callerSavedMask.get(pi) otherwise false
		let matchesClass = isCallerSaved == preferCallerSaved
		let isReserved = try hintReservedRegs.get(pi) otherwise false

		if matchesClass and not isReserved 'tier1'
			if bestTier1 == RM_NONE 'firstTier1'
				bestTier1 = reg
			end 'firstTier1'
		end 'tier1' else if matchesClass 'tier2'
			if bestTier2 == RM_NONE 'firstTier2'
				bestTier2 = reg
			end 'firstTier2'
		end 'tier2' else 'tier3'
			if bestTier3 == RM_NONE 'firstTier3'
				bestTier3 = reg
			end 'firstTier3'
		end 'tier3'

		pi = pi + 1
	end 'scan'

	if bestTier1 != RM_NONE 'haveTier1'
		return bestTier1
	end 'haveTier1'
	if bestTier2 != RM_NONE 'haveTier2'
		return bestTier2
	end 'haveTier2'
	return bestTier3
end 'pickRegFromPool'

// ============================================================
// Interference graph construction
// ============================================================

function buildInterferenceGraph(ranges LiveRangeArray) returns InterferenceGraph
	let numRanges = ranges.count()
	var ig = InterferenceGraph.create(numRanges)

	// Build a block -> list of (rangeIdx, startPos, endPos) map
	// for efficient per-block overlap checking.
	// First find the max blockId
	var maxBlockId = 0
	for range in ranges 'findMaxBlock'
		for interval in range.intervals 'eachInt'
			if interval.blockId > maxBlockId 'higher'
				maxBlockId = interval.blockId
			end 'higher'
		end 'eachInt'
	end 'findMaxBlock'

	let numBlocks = maxBlockId + 1

	// blockRanges[blockId] = array of range indices that have an interval in this block
	var blockRanges = RegIntArrayArray.create()
	var blockStarts = RegIntArrayArray.create()
	var blockEnds = RegIntArrayArray.create()

	var bi = 0
	while bi < numBlocks 'initBlockMaps'
		blockRanges.push(RegIntArray.create())
		blockStarts.push(RegIntArray.create())
		blockEnds.push(RegIntArray.create())
		bi = bi + 1
	end 'initBlockMaps'

	// Populate block maps
	var rangeIdx = 0
	for range in ranges 'populateBlocks'
		for interval in range.intervals 'eachInt2'
			let bid = interval.blockId

			if bid < numBlocks 'inBounds'
				var br = try blockRanges.get(bid) otherwise 'noBr'
					continue
				end 'noBr'
				var bs = try blockStarts.get(bid) otherwise 'noBs'
					continue
				end 'noBs'
				var be = try blockEnds.get(bid) otherwise 'noBe'
					continue
				end 'noBe'

				br.push(rangeIdx)
				bs.push(interval.startPos)
				be.push(interval.endPos)
			end 'inBounds'
		end 'eachInt2'
		rangeIdx = rangeIdx + 1
	end 'populateBlocks'

	// For each block, check pairwise overlap
	var blockId = 0
	while blockId < numBlocks 'eachBlock'
		let br = try blockRanges.get(blockId) otherwise 'noBr2'
			blockId = blockId + 1
			continue
		end 'noBr2'
		let bs = try blockStarts.get(blockId) otherwise 'noBs2'
			blockId = blockId + 1
			continue
		end 'noBs2'
		let be = try blockEnds.get(blockId) otherwise 'noBe2'
			blockId = blockId + 1
			continue
		end 'noBe2'

		let count = br.count()
		var i = 0
		while i < count 'outer'
			let ri1 = try br.get(i) otherwise 'skipI'
				i = i + 1
				continue
			end 'skipI'
			let s1 = try bs.get(i) otherwise 0
			let e1 = try be.get(i) otherwise 0

			var j = i + 1
			while j < count 'inner'
				let ri2 = try br.get(j) otherwise 'skipJ'
					j = j + 1
					continue
				end 'skipJ'
				let s2 = try bs.get(j) otherwise 0
				let e2 = try be.get(j) otherwise 0

				// Check overlap: s1 < e2 and s2 < e1
				if s1 < e2 and s2 < e1 'overlaps'
					// Skip interference for copy-connected ranges that overlap by
					// exactly 1 position at the copy boundary. This happens when
					// the source's interval is [_, P+1) and the dest starts at [P, _):
					// they share only position P (the movRegReg instruction).
					let isCopyBoundary = isCopyBoundaryOverlap(s1, e1: e1, s2: s2, e2: e2, ranges: ranges, ri1: ri1, ri2: ri2)
					if not isCopyBoundary 'realOverlap'
						addInterference(ig, a: ri1, b: ri2)
					end 'realOverlap'
				end 'overlaps'

				j = j + 1
			end 'inner'

			i = i + 1
		end 'outer'

		blockId = blockId + 1
	end 'eachBlock'

	return ig
end 'buildInterferenceGraph'

// Check if two overlapping intervals only share a single position at a copy boundary.
function isCopyBoundaryOverlap(s1 RegInt, e1 RegInt, s2 RegInt, e2 RegInt, ranges LiveRangeArray, ri1 RegInt, ri2 RegInt) returns bool
	if not areCopyConnected(ranges, ri1: ri1, ri2: ri2) 'notCopy'
		return false
	end 'notCopy'
	// Compute overlap size: min(e1,e2) - max(s1,s2)
	var minEnd = e1
	if e2 < minEnd 'e2Smaller'
		minEnd = e2
	end 'e2Smaller'
	var maxStart = s1
	if s2 > maxStart 's2Bigger'
		maxStart = s2
	end 's2Bigger'
	return minEnd - maxStart == 1
end 'isCopyBoundaryOverlap'

// Resolve a copy-link hint: if the partner is colored, return its color.
// If not, return the partner's static hint (from two-address coalescing).
function resolveCopyLinkHint(partnerValueId RegInt, vidToRangeIdx RegIntArray, rangeColors RegIntArray, ranges LiveRangeArray) returns RegOrdinal
	let partnerRangeIdx = getOr(vidToRangeIdx, index: partnerValueId, fallback: -1)
	if partnerRangeIdx < 0 'noPartner'
		return RM_NONE
	end 'noPartner'
	let partnerColor = getOr(rangeColors, index: partnerRangeIdx, fallback: RM_NONE)
	if partnerColor != RM_NONE 'colored'
		return partnerColor
	end 'colored'
	// Partner not colored yet — use its static hint if available
	let partnerRange = try ranges.get(partnerRangeIdx) otherwise 'noPR'
		return RM_NONE
	end 'noPR'
	return partnerRange.hint
end 'resolveCopyLinkHint'

// Two ranges are copy-connected if one's copyHintValueId points to the other's valueId.
// Copy-connected ranges at their boundary point should not interfere — the dest
// is a copy of the source and can safely share the same register.
function areCopyConnected(ranges LiveRangeArray, ri1 RegInt, ri2 RegInt) returns bool
	let r1 = try ranges.get(ri1) otherwise 'noR1'
		return false
	end 'noR1'
	let r2 = try ranges.get(ri2) otherwise 'noR2'
		return false
	end 'noR2'
	return r1.copyHintValueId == r2.valueId or r2.copyHintValueId == r1.valueId
end 'areCopyConnected'

function addInterference(ig InterferenceGraph, a RegInt, b RegInt)
	// Add edge a <-> b using matrix for O(1) duplicate check
	let idxAB = a * ig.numRanges + b
	let alreadyEdge = try ig.matrix.get(idxAB) otherwise false
	if alreadyEdge 'duplicate'
		return
	end 'duplicate'

	ig.matrix.set(idxAB, value: true)
	let idxBA = b * ig.numRanges + a
	ig.matrix.set(idxBA, value: true)

	var nbrsA = try ig.neighbors.get(a) otherwise 'noA'
		return
	end 'noA'
	var nbrsB = try ig.neighbors.get(b) otherwise 'noB'
		return
	end 'noB'
	nbrsA.push(b)
	nbrsB.push(a)
end 'addInterference'

function regIntArrayContains(arr RegIntArray, value RegInt) returns bool
	for v in arr 'each'
		if v == value 'found'
			return true
		end 'found'
	end 'each'
	return false
end 'regIntArrayContains'

// ============================================================
// Dominance-tree preorder sorting
// ============================================================

// Build domPreorderIndex[blockId] = position in dominance-tree preorder
function buildDomPreorderIndex(domPreorder BlockIdArray) returns RegIntArray
	var index = RegIntArray.create()
	var pos = 0

	for blockId in domPreorder 'build'
		while index.count() <= blockId 'grow'
			index.push(i64.max)
		end 'grow'
		index.set(blockId, value: pos)
		pos = pos + 1
	end 'build'

	return index
end 'buildDomPreorderIndex'

// Return range indices sorted by dominator-tree preorder of their def block.
// Uses insertion sort (simple, good enough for typical range counts).
function sortByDomPreorder(ranges LiveRangeArray, domIndex RegIntArray) returns RegIntArray
	let numRanges = ranges.count()
	var order = RegIntArray.create()

	// Initialize with identity permutation
	var i = 0
	while i < numRanges 'init'
		order.push(i)
		i = i + 1
	end 'init'

	// Insertion sort by (domPreorderIndex[range.defBlock], isVirtual, defPosition).
	// Fixed-reg ranges sort before virtual ranges at the same dom position so that
	// their physical register is already marked used when virtual ranges are colored.
	var si = 1
	while si < numRanges 'sort'
		let keyIdx = try order.get(si) otherwise 'skipSort'
			si = si + 1
			continue
		end 'skipSort'

		let keyRange = try ranges.get(keyIdx) otherwise 'skipSort2'
			si = si + 1
			continue
		end 'skipSort2'
		let keyDomPos = getOr(domIndex, index: keyRange.defBlock, fallback: i64.max)
		let keyIsVirtual = keyRange.fixedReg == RM_NONE
		let keyDefPos = keyRange.defPosition

		var j = si - 1
		while j >= 0 'insert'
			let jIdx = try order.get(j) otherwise 'break1'
				break
			end 'break1'
			let jRange = try ranges.get(jIdx) otherwise 'break2'
				break
			end 'break2'
			let jDomPos = getOr(domIndex, index: jRange.defBlock, fallback: i64.max)
			let jIsVirtual = jRange.fixedReg == RM_NONE
			let jDefPos = jRange.defPosition

			// Compare: (domPos, isVirtual, defPos) — fixed-reg before virtual
			if jDomPos < keyDomPos 'inPlace1'
				break
			end 'inPlace1'
			if jDomPos == keyDomPos 'sameDom'
				if not jIsVirtual and keyIsVirtual 'fixedFirst'
					break
				end 'fixedFirst'
				if jIsVirtual == keyIsVirtual and jDefPos <= keyDefPos 'sameKind'
					break
				end 'sameKind'
			end 'sameDom'

			// Shift j to j+1
			order.set(j + 1, value: jIdx)
			j = j - 1
		end 'insert'

		order.set(j + 1, value: keyIdx)
		si = si + 1
	end 'sort'

	return order
end 'sortByDomPreorder'

// ============================================================
// Register availability helpers
// ============================================================

function growColorBoolArray(arr BoolArray, size RegInt)
	while arr.count() < size 'grow'
		arr.push(false)
	end 'grow'
end 'growColorBoolArray'

// Check if any uncolored neighbor has a fixedReg matching the hint.
// These neighbors will inevitably be colored to that register, so using
// the hint would create a conflict.
function hintConflictsWithFixedNeighbor(hint RegOrdinal, nbrs RegIntArray, ranges LiveRangeArray, rangeColors RegIntArray) returns bool
	for nbrIdx in nbrs 'eachNbr'
		let nbrColor = getOr(rangeColors, index: nbrIdx, fallback: RM_NONE)
		if nbrColor == RM_NONE 'uncolored'
			let nbrRange = try ranges.get(nbrIdx) otherwise 'skipNbr'
				continue
			end 'skipNbr'
			if nbrRange.fixedReg == hint 'conflicts'
				return true
			end 'conflicts'
		end 'uncolored'
	end 'eachNbr'
	return false
end 'hintConflictsWithFixedNeighbor'

function markRegUsed(usedRegs BoolArray, regOrd RegInt, poolIndexOf RegIntArray)
	if regOrd < 0 or regOrd >= poolIndexOf.count() 'outOfBounds'
		return
	end 'outOfBounds'
	let pi = try poolIndexOf.get(regOrd) otherwise RM_NONE
	if pi != RM_NONE and pi < usedRegs.count() 'inBounds'
		usedRegs.set(pi, value: true)
	end 'inBounds'
end 'markRegUsed'

// Check if a register ordinal is marked as used
function isRegUsed(usedRegs BoolArray, regOrd RegInt, poolIndexOf RegIntArray) returns bool
	if regOrd < 0 or regOrd >= poolIndexOf.count() 'outOfBounds'
		return false
	end 'outOfBounds'
	let pi = try poolIndexOf.get(regOrd) otherwise RM_NONE
	if pi == RM_NONE 'notInPool'
		return false
	end 'notInPool'
	return try usedRegs.get(pi) otherwise false
end 'isRegUsed'

// ============================================================
// Conservative coalescing (hint-based)
// ============================================================

// Scan for copy-like operations (movRegReg) and set register hints
// on destination ranges to prefer the same register as the source.
// This is a lightweight form of coalescing that the coloring phase
// supports via the hint field on LiveRange.
//
// returnGprOrd is the target's return register ordinal (or RM_NONE if the
// target has no special return-register handling). When non-RM_NONE, the
// coalescer also runs a reverse-direction pass that overrides any existing
// hint on the value flowing into a trailing `mov retReg, vreg` right before
// a `ret` terminator. The closest-to-death hint is the most valuable one
// for a return value because it costs zero extra moves to honor.
export function coalesceRanges(module TargetModule, ranges LiveRangeArray, func IrFunction, returnGprOrd RegOrdinal, opQuery TargetOpQuery)
	// Build valueId -> range index map for fast lookup
	var vidToRangeIdx = RegIntArray.create()

	var ri = 0
	while ri < ranges.count() 'buildVidMap'
		let range = try ranges.get(ri) otherwise 'skip'
			ri = ri + 1
			continue
		end 'skip'

		let vid = range.valueId
		while vidToRangeIdx.count() <= vid 'grow'
			vidToRangeIdx.push(-1)
		end 'grow'
		vidToRangeIdx.set(vid, value: ri)

		ri = ri + 1
	end 'buildVidMap'

	// Scan all ops for copy-like patterns
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise 'skipOp'
			continue
		end 'skipOp'
		for packed in block.opRefs 'eachOp'
			extractCopyHintsWith(module, packed: packed, ranges: ranges, vidToRangeIdx: vidToRangeIdx, opQuery: opQuery)
		end 'eachOp'

		if block.hasTerminatorOp() 'hasTerm'
			extractCopyHintsWith(module, packed: block.terminatorIndex(), ranges: ranges, vidToRangeIdx: vidToRangeIdx, opQuery: opQuery)
		end 'hasTerm'

		// Hint from outgoing branch edge args -> successor block args.
		for edge in block.branchEdges 'eachEdge'
			hintBranchArgs(edge.argIds, targetBlockId: edge.targetBlockId, ranges: ranges, vidToRangeIdx: vidToRangeIdx, func: func, module: module)
		end 'eachEdge'
	end 'eachBlock'

	// Reverse-direction pass: override the hint on the return value so that
	// the coloring prefers the return register. This only fires for blocks
	// ending in `ret` and only affects the single vreg feeding the final
	// `mov retReg, vreg`. The override wins over whatever forward pass set
	// earlier because for a return value the death-site hint is terminal.
	if returnGprOrd != RM_NONE 'hasReturnReg'
		applyReturnRegHintOverride(module, ranges: ranges, func: func, vidToRangeIdx: vidToRangeIdx, returnGprOrd: returnGprOrd, opQuery: opQuery)
	end 'hasReturnReg'
end 'coalesceRanges'

// (destOrd, srcId) describing a `movRegReg` op as decoded by a target-
// specific helper. destOrd is the destination's physical-register ordinal
// (RM_NONE if not physical); srcId is the source's virtual-register id
// (negative if not virtual). A `notFound` value means the op wasn't a mov.
export type ReturnMovProbe
	export var destOrd RegOrdinal
	export var srcId RegInt
	export var found bool

	export static function notFound() returns ReturnMovProbe
		return Self{destOrd: RM_NONE, srcId: -1, found: false}
	end 'notFound'

	export static function ok(destOrd RegOrdinal, srcId RegInt) returns ReturnMovProbe
		return Self{destOrd: destOrd, srcId: srcId, found: true}
	end 'ok'
end 'ReturnMovProbe'

// For each block that ends in a `ret` terminator, walk opRefs in reverse and
// find the first `movRegReg(physical retReg, virtual src)`. Force src's range
// hint to the return register, overriding any earlier forward-pass hint.
//
// The block walk and reverse scan are shared across targets; only the per-op
// decoding (and the matching ret-terminator check) is target-specific. Both
// are dispatched on `module.cpu` per block and op.
function applyReturnRegHintOverride(module TargetModule, ranges LiveRangeArray, func IrFunction, vidToRangeIdx RegIntArray, returnGprOrd RegOrdinal, opQuery TargetOpQuery)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise 'skipBlock'
			continue
		end 'skipBlock'

		if not block.hasTerminatorOp() 'noTerm'
			continue
		end 'noTerm'
		if not opQuery.isReturnTerminator(module, packed: block.terminatorIndex()) 'notRet'
			continue
		end 'notRet'

		// Walk opRefs in reverse. The first movRegReg we find is the
		// return-value setup emitted by the target's lowerReturn (which
		// runs immediately before the epilogue+ret pair). Non-mov ops are
		// skipped; the scan stops on the first decoded mov.
		var j = block.opRefs.count() - 1
		while j >= 0 'scanBack'
			let packed = try block.opRefs.get(j) otherwise 'skipBack'
				j = j - 1
				continue
			end 'skipBack'

			let probe = opQuery.decodeReturnMovProbe(module, packed: packed)
			if probe.found 'isMov'
				tryApplyReturnHint(destOrd: probe.destOrd, srcId: probe.srcId, returnGprOrd: returnGprOrd, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
				break
			end 'isMov'
			j = j - 1
		end 'scanBack'
	end 'eachBlock'
end 'applyReturnRegHintOverride'

// Apply the return-register override if this mov-reg-reg op is the return-
// value setup: movRegReg(physical retReg, virtual src). No-op when the dest
// isn't a physical register, isn't the return register, or src isn't virtual.
function tryApplyReturnHint(destOrd RegOrdinal, srcId RegInt, returnGprOrd RegOrdinal, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if destOrd == RM_NONE 'destNotPhys'
		return
	end 'destNotPhys'
	if destOrd != returnGprOrd 'notReturnReg'
		return
	end 'notReturnReg'
	if srcId < 0 'srcNotVirt'
		return
	end 'srcNotVirt'

	setPhysHintForce(returnGprOrd, virtualId: srcId, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'tryApplyReturnHint'

function extractCopyHintsWith(module TargetModule, packed OpIndex, ranges LiveRangeArray, vidToRangeIdx RegIntArray, opQuery TargetOpQuery)
	opQuery.extractCopyHints(module, packed: packed, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'extractCopyHintsWith'

// For each branch arg, set a copy hint between the arg value and the
// corresponding block arg in the target block.
function hintBranchArgs(argIds ValueIdArray, targetBlockId BlockId, ranges LiveRangeArray, vidToRangeIdx RegIntArray, func IrFunction, module TargetModule)
	if argIds.count() == 0 'noArgs'
		return
	end 'noArgs'
	let targetBlock = findBlockForHint(module, func: func, blockId: targetBlockId)
	var i = 0
	while i < argIds.count() 'eachArg'
		let srcId = try argIds.get(i) otherwise 'skipArg'
			i = i + 1
			continue
		end 'skipArg'
		let blockArg = try targetBlock.blockArgs.get(i) otherwise 'skipBlockArg'
			i = i + 1
			continue
		end 'skipBlockArg'
		let destId = blockArg.valueId
		setGprCopyHint(destReg: destId, srcReg: srcId, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
		i = i + 1
	end 'eachArg'
end 'hintBranchArgs'

function findBlockForHint(module TargetModule, func IrFunction, blockId BlockId) returns IrBlock
	for blockRef in func.blockRefs 'search'
		let block = try module.blocks.get(blockRef) otherwise 'skipBlock'
			continue
		end 'skipBlock'
		if block.id == blockId 'found'
			return block
		end 'found'
	end 'search'
	panic("findBlockForHint: block {blockId} not found")
end 'findBlockForHint'

// Hint a virtual register to prefer a specific physical register ordinal.
export function setPhysHint(physOrd RegOrdinal, virtualId RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if virtualId < 0 or physOrd == RM_NONE 'invalid'
		return
	end 'invalid'

	let rangeIdx = getOr(vidToRangeIdx, index: virtualId, fallback: -1)
	if rangeIdx < 0 'noRange'
		return
	end 'noRange'

	var range = try ranges.get(rangeIdx) otherwise 'noRange2'
		return
	end 'noRange2'

	if range.hint == RM_NONE 'noHintYet'
		range.hint = physOrd
	end 'noHintYet'
end 'setPhysHint'

// Like setPhysHint but unconditionally overwrites any existing hint. Used by
// the return-register reverse pass, where the death-site hint is always more
// valuable than a forward-pass birth-site hint.
function setPhysHintForce(physOrd RegOrdinal, virtualId RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if virtualId < 0 or physOrd == RM_NONE 'invalid'
		return
	end 'invalid'

	let rangeIdx = getOr(vidToRangeIdx, index: virtualId, fallback: -1)
	if rangeIdx < 0 'noRange'
		return
	end 'noRange'

	var range = try ranges.get(rangeIdx) otherwise 'noRange2'
		return
	end 'noRange2'

	range.hint = physOrd
end 'setPhysHintForce'

// Set hint: destination should prefer the same register as source
export function setGprCopyHint(destReg RegInt, srcReg RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	if destReg < 0 or srcReg < 0 'physical'
		return
	end 'physical'

	let srcRangeIdx = getOr(vidToRangeIdx, index: srcReg, fallback: -1)
	let destRangeIdx = getOr(vidToRangeIdx, index: destReg, fallback: -1)

	if srcRangeIdx < 0 or destRangeIdx < 0 'noRange'
		return
	end 'noRange'

	// Propagate hint: if source already has a hint, pass it to dest
	var srcRange = try ranges.get(srcRangeIdx) otherwise 'noSrc'
		return
	end 'noSrc'
	var destRange = try ranges.get(destRangeIdx) otherwise 'noDest'
		return
	end 'noDest'

	// Only set hint if dest doesn't already have one
	if destRange.hint == RM_NONE 'noHintYet'
		if srcRange.fixedReg != RM_NONE 'srcFixed'
			// Source is in a fixed physical register — that's where it
			// inevitably lives, so the dest can prefer the same register
			// directly. This is a strong hint we can never improve on.
			destRange.hint = srcRange.fixedReg
		end 'srcFixed' else 'noFixed'
			// Otherwise record a copy-link in both directions so the
			// coloring phase can resolve the hint dynamically. We never
			// forward-propagate `srcRange.hint` because that hint may
			// reflect a *birth-side* preference (e.g. the source's own
			// param mov), while the dest may have a stronger *death-side*
			// preference (e.g. flowing into a return register). The copy-
			// link resolver picks whichever side has the more useful hint
			// when it gets there.
			destRange.copyHintValueId = srcReg
			if srcRange.copyHintValueId < 0 'srcNoLink'
				srcRange.copyHintValueId = destReg
			end 'srcNoLink'
		end 'noFixed'
	end 'noHintYet'
end 'setGprCopyHint'

export function setFpCopyHint(destReg RegInt, srcReg RegInt, ranges LiveRangeArray, vidToRangeIdx RegIntArray)
	// Same logic as GPR copy hint
	setGprCopyHint(destReg, srcReg: srcReg, ranges: ranges, vidToRangeIdx: vidToRangeIdx)
end 'setFpCopyHint'


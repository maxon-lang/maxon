// Prologue/Epilogue insertion pass.
// Runs after register allocation. Walks each function in the module,
// computes the final stack frame size, inserts a prologue at the entry
// block start when a frame is needed, and inserts an epilogue at every
// return block.
//
// The orchestration is target-independent and lives here. Backends plug
// in the small target-specific bits (callee-saved scanning, frame-size
// formula, op constructors) via TargetBackend hooks.

// Frame layout information computed per function.
export type FrameInfo
	export var totalStackSize StackSize
	export var spillAreaSize StackSize
	export var varAreaSize StackSize
	export var alignedSize StackSize
	// True when the function makes a direct or indirect call. ARM64 uses this
	// to decide whether STP x29,x30 is required: any BL/BLR clobbers the link
	// register, so x30 must be saved before any call.
	export var hasCalls bool

	export static function create(totalStackSize StackSize, spillAreaSize StackSize, varAreaSize StackSize, alignedSize StackSize, hasCalls bool) returns FrameInfo
		return Self{totalStackSize: totalStackSize, spillAreaSize: spillAreaSize, varAreaSize: varAreaSize, alignedSize: alignedSize, hasCalls: hasCalls}
	end 'create'
end 'FrameInfo'

// Round a size up to the next 16-byte boundary.
// Both x64 and Arm64 require 16-byte stack alignment.
export function alignTo16(size StackSize) returns StackSize
	if size mod 16 != 0 'needsAlign'
		return size + (16 - (size mod 16))
	end 'needsAlign'
	return size
end 'alignTo16'

// Mutable accumulator for frame scanning. Using a type (reference semantics)
// so that nested function calls can update the fields.
export type FrameScanState
	export var spillArea StackSize
	export var hasCalls bool

	static function create() returns FrameScanState
		return Self{
			spillArea: 0,
			hasCalls: false
		}
	end 'create'
end 'FrameScanState'

function createFrameScanState() returns FrameScanState
	return FrameScanState.create()
end 'createFrameScanState'

// Compute frame information for a single function by scanning its ops.
// The var area comes from slot-addressed ops (ISel records varSlotCount),
// the spill area comes from the register allocator, and scanning surfaces
// hasCalls for later decisions.
export function computeFrameInfoWith(module TargetModule, func IrFunction, backend TargetBackend) returns FrameInfo
	// The register allocator stores the spill size on the function.
	// The var area is varSlotCount * 8 (slot-addressed variables from ISel).
	// Total frame = var area + spill area, aligned to 16.
	let varArea = func.varSlotCount * 8
	let spillArea = func.spillSize
	var totalSize = varArea + spillArea

	let state = createFrameScanState()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise continue
		for packed in block.opRefs 'eachOp'
			backend.scanOpForFrameInfo(packed, state: state)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			backend.scanOpForFrameInfo(block.terminatorIndex(), state: state)
		end 'hasTerm'
	end 'eachBlock'

	// Any function with calls needs a frame for correct stack unwinding (panic stack traces).
	if state.hasCalls and totalSize == 0 'needFrame'
		totalSize = 16
	end 'needFrame'

	let aligned = alignTo16(totalSize)

	return FrameInfo.create(totalSize, spillAreaSize: spillArea, varAreaSize: varArea, alignedSize: aligned, hasCalls: state.hasCalls)
end 'computeFrameInfoWith'

// Update the spill area size to accommodate the given offset.
// Spill offsets are absolute values from the frame base; we track the maximum.
export function updateSpillArea(state FrameScanState, offset MachineWord)
	// Offsets may be negative (x86 grows down from rbp) or positive (arm64 grows up).
	// The spill area size is the absolute extent.
	let absOffset = absoluteOffset(offset)
	let needed = absOffset + 8
	if needed > state.spillArea 'larger'
		state.spillArea = needed
	end 'larger'
end 'updateSpillArea'

function absoluteOffset(offset MachineWord) returns MachineWord
	// MachineWord is unsigned; negative offsets wrap to large values (> i64.max).
	if offset > i64.max 'negative'
		return 0 - offset
	end 'negative'
	return offset
end 'absoluteOffset'

// ============================================================
// Shared driver
// ============================================================

// Insert prologue/epilogue ops for a single function.
//
// After ISel, every return block ends with a trailing `epilogue` op in opRefs
// (ISel emits epilogue+ret; setLastOpAsTerminator promotes the ret to the
// terminator, leaving epilogue as the last regular op). This pass strips
// those stale epilogue ops and re-emits prologue/epilogue based on the
// computed frame size and the backend's frame-necessity rules.
export function insertPrologueEpilogueShared(module TargetModule, func IrFunction, backend TargetBackend, opQuery TargetOpQuery, frameInfo FrameInfo)
	backend.detectCalleeSavedRegs(func: func)

	let saveArea = backend.calleeSaveAreaBytes(func: func)
	let adjustedStackSize = alignTo16(frameInfo.alignedSize + saveArea)
	let needsPrologue = backend.needsPrologue(adjustedStackSize: adjustedStackSize, hasCalls: frameInfo.hasCalls)

	var isFirstBlock = true
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise continue

		stripTrailingEpilogue(module, block: block, opQuery: opQuery)

		if isFirstBlock and needsPrologue 'emitProlog'
			backend.insertPrologueAtEntry(block: block, stackSize: adjustedStackSize)
		end 'emitProlog'
		isFirstBlock = false

		if needsPrologue and isReturnBlock(module, block: block, opQuery: opQuery) 'emitEpi'
			backend.insertEpilogueAtReturnBlock(block: block)
		end 'emitEpi'
	end 'eachBlock'
end 'insertPrologueEpilogueShared'

// After ISel, return blocks have a trailing `epilogue` op left in opRefs
// that we must remove before re-emitting. Non-return blocks never carry one.
function stripTrailingEpilogue(module TargetModule, block IrBlock, opQuery TargetOpQuery)
	let count = block.opRefs.count()
	if count == 0 'empty'
		return
	end 'empty'
	let lastIdx = count - 1
	let lastPacked = try block.opRefs.get(lastIdx) otherwise panic("stripTrailingEpilogue: last op index {lastIdx} missing from opRefs of size {count}")
	if opQuery.isEpilogueOp(module, packed: lastPacked) 'strip'
		try block.opRefs.remove(at: lastIdx) otherwise panic("stripTrailingEpilogue: remove of last index {lastIdx} failed")
	end 'strip'
end 'stripTrailingEpilogue'

function isReturnBlock(module TargetModule, block IrBlock, opQuery TargetOpQuery) returns bool
	if not block.hasTerminatorOp() 'noTerm'
		return false
	end 'noTerm'
	return opQuery.isReturnTerminator(module, packed: block.terminatorIndex())
end 'isReturnBlock'

// ============================================================
// Helpers used by target backends
// ============================================================

// Simple insertion sort for small register ordinal arrays.
export function sortRegOrdinals(arr RegIntArray)
	let n = arr.count()
	var i = 1
	while i < n 'outer'
		let key = try arr.get(i) otherwise panic("sortRegOrdinals.outer: i < n = arr.count() by loop guard but get({i}) failed")
		var j = i - 1
		while j >= 0 'inner'
			let val = try arr.get(j) otherwise panic("sortRegOrdinals.inner: 0 <= j < i < n = arr.count() but get({j}) failed")
			if val <= key 'done'
				break
			end 'done'
			arr.set(j + 1, value: val)
			j = j - 1
		end 'inner'
		arr.set(j + 1, value: key)
		i = i + 1
	end 'outer'
end 'sortRegOrdinals'

// Prologue/Epilogue insertion pass.
// Runs after register allocation. Walks each function in the module,
// computes the final stack frame size, inserts prologue at the entry block
// start, and inserts epilogue before every ret terminator.
//
// This pass is target-aware: it emits X64Op or Arm64Op depending on
// the compilation target. The actual machine code emission for prologue/epilogue
// is handled downstream by the code emitters.

// Frame layout information computed per function.
export type FrameInfo
	export var totalStackSize StackSize
	export var spillAreaSize StackSize
	export var varAreaSize StackSize
	export var alignedSize StackSize

	export static function create(totalStackSize StackSize, spillAreaSize StackSize, varAreaSize StackSize, alignedSize StackSize) returns FrameInfo
		return Self{totalStackSize: totalStackSize, spillAreaSize: spillAreaSize, varAreaSize: varAreaSize, alignedSize: alignedSize}
	end 'create'
end 'FrameInfo'

// Round a size up to the next 16-byte boundary.
// Both x64 and Arm64 require 16-byte stack alignment.
export function alignTo16(size StackSize) returns StackSize
	if size mod 16 != 0 'needsAlign'
		return size + (16 - (size mod 16))
	end 'needsAlign'
	return size
end 'alignTo16'

// Mutable accumulator for frame scanning. Using a type (reference semantics)
// so that nested function calls can update the fields.
type FrameScanState
	export var foundPrologue bool
	export var existingPrologueSize StackSize
	export var spillArea StackSize
	export var hasCalls bool
	export var hasPrint bool

	static function create() returns FrameScanState
		return Self{
			foundPrologue: false,
			existingPrologueSize: 0,
			spillArea: 0,
			hasCalls: false,
			hasPrint: false
		}
	end 'create'
end 'FrameScanState'

function createFrameScanState() returns FrameScanState
	return FrameScanState.create()
end 'createFrameScanState'

// Compute frame information for a single function by scanning its ops.
//
// Two modes:
// 1. If an existing prologue op is present (current pipeline), its stack size
//    already includes var area + spill area, properly aligned. We use it directly.
// 2. If no prologue exists (future pipeline where isel skips prologue insertion),
//    we independently compute var area from slot-based ops and spill area from
//    spill/reload ops, then combine and align.
export function computeFrameInfo(func MlirFunction) returns FrameInfo
	// The register allocator stores the spill size on the function.
	// The var area is varSlotCount * 8 (slot-addressed variables from ISel).
	// Total frame = var area + spill area, aligned to 16.
	let varArea = func.varSlotCount * 8
	let spillArea = func.spillSize
	var totalSize = varArea + spillArea

	// Scan for prints that require buffer space on the stack.
	let state = createFrameScanState()
	for block in func.blocks 'eachBlock'
		for op in block.ops 'eachOp'
			scanOpForFrameInfo(op, state: state)
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			scanOpForFrameInfo(block.terminator, state: state)
		end 'hasTerm'
	end 'eachBlock'

	// Print operations need stack buffer space for string formatting.
	if state.hasPrint and totalSize < 16 'needPrintBuf'
		totalSize = 16
	end 'needPrintBuf'

	// Any function with calls needs a frame for correct stack unwinding (panic stack traces).
	if state.hasCalls and totalSize == 0 'needFrame'
		totalSize = 16
	end 'needFrame'

	let aligned = alignTo16(totalSize)

	return FrameInfo.create(totalSize, spillAreaSize: spillArea, varAreaSize: varArea, alignedSize: aligned)
end 'computeFrameInfo'

// Scan a single op for frame-relevant information.
function scanOpForFrameInfo(op MlirOp, state FrameScanState)
	match op 'outer'
		maxon to sys then break 'outer'
		mir then break 'outer'
		x64(x64Op) then scanX64InstrForFrame(x64Op, state: state)
		arm64(a64Op) then scanArm64InstrForFrame(a64Op, state: state)
	end 'outer'
	// Runtime ops indicate print operations that need buffer space
	match op 'checkPrint'
		maxon to memref then break 'checkPrint'
		runtime then state.hasPrint = true
		sys to arm64 then break 'checkPrint'
	end 'checkPrint'
end 'scanOpForFrameInfo'

function scanX64InstrForFrame(op X64Op, state FrameScanState)
	match op 'scan'
		prologue(stackSize) then markPrologueFound(state, stackSize: stackSize)
		epilogue to movRegImm32 then break 'scan'
		movSlot(slotIndex, _) then updateSpillAreaFromSlot(state, slotIndex: slotIndex)
		loadSlot(_, slotIndex) then updateSpillAreaFromSlot(state, slotIndex: slotIndex)
		addRegReg to loadRegRbpOffset then break 'scan'
		callDirect then state.hasCalls = true
		syscall(resultSlot, _, argSlots) then updateSpillAreaFromSysOp(state, resultSlot: resultSlot, argSlots: argSlots)
		iatCall(resultSlot, _, argSlots) then updateSpillAreaFromSysOp(state, resultSlot: resultSlot, argSlots: argSlots)
		globalAddr(resultSlot, _) then updateSpillAreaFromSlot(state, slotIndex: resultSlot)
		stackAddrOp(resultSlot, targetSlot) then updateSpillAreaFromTwoSlots(state, slot1: resultSlot, slot2: targetSlot)
		storeByteOp(s1, s2, s3) then updateSpillAreaFromThreeSlots(state, s1: s1, s2: s2, s3: s3)
		loadByteOp(s1, s2, s3) then updateSpillAreaFromThreeSlots(state, s1: s1, s2: s2, s3: s3)
		memcpyOp(s1, s2, s3) then updateSpillAreaFromThreeSlots(state, s1: s1, s2: s2, s3: s3)
		movRegReg to idivReg then break 'scan'
		spillToStack(offset, _) then updateSpillArea(state, offset: offset)
		reloadFromStack(_, offset) then updateSpillArea(state, offset: offset)
		xorRegRegSelf then break 'scan'
		callIndirect then state.hasCalls = true
		xchgRegReg to repStosq then break 'scan'
	end 'scan'
end 'scanX64InstrForFrame'

function updateSpillAreaFromSlot(state FrameScanState, slotIndex VarSlot)
	let offset = (slotIndex + 1) * 8
	updateSpillArea(state, offset: 0 - offset)
end 'updateSpillAreaFromSlot'

function updateSpillAreaFromSysOp(state FrameScanState, resultSlot VarSlot, argSlots VarSlotArray)
	updateSpillAreaFromSlot(state, slotIndex: resultSlot)
	for s in argSlots 'eachArg'
		updateSpillAreaFromSlot(state, slotIndex: s)
	end 'eachArg'
end 'updateSpillAreaFromSysOp'

function updateSpillAreaFromTwoSlots(state FrameScanState, slot1 VarSlot, slot2 VarSlot)
	updateSpillAreaFromSlot(state, slotIndex: slot1)
	updateSpillAreaFromSlot(state, slotIndex: slot2)
end 'updateSpillAreaFromTwoSlots'

function updateSpillAreaFromThreeSlots(state FrameScanState, s1 VarSlot, s2 VarSlot, s3 VarSlot)
	updateSpillAreaFromSlot(state, slotIndex: s1)
	updateSpillAreaFromSlot(state, slotIndex: s2)
	updateSpillAreaFromSlot(state, slotIndex: s3)
end 'updateSpillAreaFromThreeSlots'


function scanArm64InstrForFrame(op Arm64Op, state FrameScanState)
	match op 'scan'
		prologue(stackSize) then markPrologueFound(state, stackSize: stackSize)
		epilogue to branch then break 'scan'
		branchLink then state.hasCalls = true
		printLiteral to movRegReg then break 'scan'
		spillToStack(offset, _) then updateSpillArea(state, offset: offset)
		reloadFromStack(_, offset) then updateSpillArea(state, offset: offset)
		branchLinkReg then state.hasCalls = true
		subSpImm to nullSafeLoad then break 'scan'
	end 'scan'
end 'scanArm64InstrForFrame'

function markPrologueFound(state FrameScanState, stackSize StackSize)
	state.foundPrologue = true
	state.existingPrologueSize = stackSize
end 'markPrologueFound'

// Update the spill area size to accommodate the given offset.
// Spill offsets are absolute values from the frame base; we track the maximum.
function updateSpillArea(state FrameScanState, offset MachineWord)
	// Offsets may be negative (x86 grows down from rbp) or positive (arm64 grows up).
	// The spill area size is the absolute extent.
	let absOffset = absoluteOffset(offset)
	let needed = absOffset + 8
	if needed > state.spillArea 'larger'
		state.spillArea = needed
	end 'larger'
end 'updateSpillArea'

function absoluteOffset(offset MachineWord) returns MachineWord
	// MachineWord is unsigned; negative offsets wrap to large values (> i64.max).
	if offset > i64.max 'negative'
		return 0 - offset
	end 'negative'
	return offset
end 'absoluteOffset'

// ============================================================
// Main pass entry point
// ============================================================

// Insert prologue and epilogue ops into every function in the module.
// This pass runs after register allocation and before code emission.
// It walks each function, computes the stack frame layout, inserts
// prologue ops at the entry block start, and inserts epilogue ops
// before every ret terminator.
export function insertPrologueEpilogue(module MlirModule, target Target) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "PrologueEpiloguePass: starting")

	let result = createMlirModule()

	for srcFunc in module.functions 'eachFunc'
		let funcName = srcFunc.name
		logDebug(LogCategory.mlir, message: () gives "Inserting prologue/epilogue for {funcName}")

		let dstFunc = insertPrologueEpilogueForFunc(srcFunc, target: target)
		result.functions.push(dstFunc)
	end 'eachFunc'

	logDebug(LogCategory.mlir, message: () gives "PrologueEpiloguePass: complete")
	return result
end 'insertPrologueEpilogue'

// Process a single function: compute frame info, strip any existing
// prologue/epilogue ops, and re-insert them with the correct stack size.
function insertPrologueEpilogueForFunc(srcFunc MlirFunction, target Target) returns MlirFunction
	var dstFunc = cloneFunctionShell(srcFunc)

	// First pass: compute the frame layout from the source function.
	let frameInfo = computeFrameInfo(srcFunc)
	let stackSize = frameInfo.alignedSize

	logTrace(LogCategory.mlir, message: () gives "  frame: var={frameInfo.varAreaSize} spill={frameInfo.spillAreaSize} total={frameInfo.totalStackSize} aligned={stackSize}")

	// Second pass: copy blocks, stripping existing prologue/epilogue ops
	// and inserting new ones at the correct positions.
	match target.cpu 'dispatchCpu'
		x64 then insertX64PrologueEpilogue(srcFunc, dstFunc: dstFunc, stackSize: stackSize)
		arm64 then insertArm64PrologueEpilogue(srcFunc, dstFunc: dstFunc, stackSize: stackSize)
		wasm32 then panic("prologue/epilogue not used for WASM targets")
	end 'dispatchCpu'

	// Preserve region metadata
	dstFunc.nextBlockId = srcFunc.nextBlockId
	return dstFunc
end 'insertPrologueEpilogueForFunc'

// ============================================================
// X86-64 prologue/epilogue insertion
// ============================================================

function insertX64PrologueEpilogue(srcFunc MlirFunction, dstFunc MlirFunction, stackSize StackSize)
	// Detect callee-saved registers used in this function.
	x64DetectCalleeSavedRegs(srcFunc, dstFunc: dstFunc)

	// Include callee-saved register space in the frame.
	// Callee-saved regs are saved/restored via mov (not push/pop) to preserve
	// the frame pointer chain for stack unwinding. Their space is at the
	// bottom of the frame, included in sub rsp.
	let calleeSavedCount = dstFunc.calleeSavedGprs.count()
	let calleeSaveArea = calleeSavedCount * 8
	var adjustedStackSize = alignTo16(stackSize + calleeSaveArea)

	var isFirstBlock = true

	for srcBlock in srcFunc.blocks 'eachBlock'
		var dstBlock = addBlock(dstFunc, label: srcBlock.label)
		dstBlock.id = srcBlock.id
		dstBlock.blockArgs = srcBlock.blockArgs

		if isFirstBlock 'isEntry'
			// Insert prologue at the start of the entry block (only if we need a frame).
			let needsFrame = adjustedStackSize > 0 or calleeSavedCount > 0
			if needsFrame 'hasFrame'
				dstBlock.ops.push(MlirOp.x64(X64Op.prologue(adjustedStackSize)))
			end 'hasFrame'
			isFirstBlock = false
		end 'isEntry'

		// Copy ops, stripping only prologue and epilogue (keep ret).
		// After copying, we reinsert epilogue before each ret.
		for op in srcBlock.ops 'eachOp'
			if isX64PrologueOrEpilogue(op) 'skipPeOp'
				continue
			end 'skipPeOp'
			dstBlock.ops.push(op)
		end 'eachOp'

		// Copy terminator through. When the VReg-based isel is active,
		// epilogue+ret are set as the block terminator (via setLastOpAsTerminator),
		// so we must also handle ret ops in the terminator position.
		if srcBlock.hasTerminator 'hasTerm'
			if not isX64PrologueOrEpilogue(srcBlock.terminator) 'notPE'
				// If the terminator is a ret, insert epilogue before it
				if isX64RetOp(srcBlock.terminator) and (adjustedStackSize > 0 or calleeSavedCount > 0) 'termRetNeedsEpi'
					let prevIsEpi = checkPrevIsX64Epilogue(dstBlock.ops)
					if not prevIsEpi 'insertEpi'
						dstBlock.ops.push(MlirOp.x64(X64Op.epilogue))
					end 'insertEpi'
				end 'termRetNeedsEpi'
				dstBlock.hasTerminator = srcBlock.hasTerminator
				dstBlock.terminator = srcBlock.terminator
			end 'notPE'
		end 'hasTerm'

		// Insert epilogue before each ret op in the block's ops.
		// The x64 lowering emits epilogue+ret as regular ops (not terminators),
		// so we find each ret and ensure it has an epilogue preceding it.
		reinsertX64EpilogueBeforeRets(dstBlock, stackSize: adjustedStackSize)
	end 'eachBlock'
end 'insertX64PrologueEpilogue'

// After copying ops (with existing prologue/epilogue/ret stripped),
// scan for ret ops and insert epilogue before each one.
// In the current x64 lowering, epilogue+ret are emitted as regular ops
// (not as terminators), so we need to find ret ops in the ops array
// and ensure each has an epilogue preceding it.
function reinsertX64EpilogueBeforeRets(block MlirBlock, stackSize StackSize)
	let newOps = MlirOpArray.create()
	var needsRewrite = false

	// First check if any rewriting is needed
	for op in block.ops 'scan'
		if isX64RetOp(op) 'foundRet'
			needsRewrite = true
		end 'foundRet'
	end 'scan'

	if not needsRewrite 'noRewrite'
		return
	end 'noRewrite'

	// Rebuild ops, inserting epilogue before each ret
	for op in block.ops 'rebuild'
		if isX64RetOp(op) 'isRet'
			// Check if the preceding op is already an epilogue
			let prevIsEpilogue = checkPrevIsX64Epilogue(newOps)
			if not prevIsEpilogue 'insertEpilogue'
				if stackSize > 0 'hasFrame'
					newOps.push(MlirOp.x64(X64Op.epilogue))
				end 'hasFrame'
			end 'insertEpilogue'
			newOps.push(op)
		end 'isRet' else 'notRet'
			newOps.push(op)
		end 'notRet'
	end 'rebuild'

	block.ops = newOps
end 'reinsertX64EpilogueBeforeRets'

function checkPrevIsX64Epilogue(ops MlirOpArray) returns bool
	let count = ops.count()
	if count == 0 'empty'
		return false
	end 'empty'
	let prev = try ops.get(count - 1) otherwise 'noPrev'
		return false
	end 'noPrev'
	return isX64EpilogueOp(prev)
end 'checkPrevIsX64Epilogue'

// Check if an MlirOp is an x64 prologue or epilogue (not ret).
function isX64PrologueOrEpilogue(op MlirOp) returns bool
	var result = false
	match op 'check'
		maxon to sys then break 'check'
		mir then break 'check'
		x64(x64Op) then result = isX64PeOnly(x64Op)
		arm64 then break 'check'
	end 'check'
	return result
end 'isX64PrologueOrEpilogue'

function isX64PeOnly(op X64Op) returns bool
	return match op 'check'
		prologue gives true
		epilogue gives true
		ret to repStosq gives false
	end 'check'
end 'isX64PeOnly'

function isX64RetOp(op MlirOp) returns bool
	var result = false
	match op 'check'
		maxon to sys then break 'check'
		mir then break 'check'
		x64(x64Op) then result = isX64Ret(x64Op)
		arm64 then break 'check'
	end 'check'
	return result
end 'isX64RetOp'

function isX64Ret(op X64Op) returns bool
	return match op 'check'
		prologue to epilogue gives false
		ret gives true
		movRegImm to repStosq gives false
	end 'check'
end 'isX64Ret'

function isX64EpilogueOp(op MlirOp) returns bool
	var result = false
	match op 'check'
		maxon to sys then break 'check'
		mir then break 'check'
		x64(x64Op) then result = isX64Epilogue(x64Op)
		arm64 then break 'check'
	end 'check'
	return result
end 'isX64EpilogueOp'

function isX64Epilogue(op X64Op) returns bool
	return match op 'check'
		prologue gives false
		epilogue gives true
		ret to repStosq gives false
	end 'check'
end 'isX64Epilogue'

// ============================================================
// ARM64 callee-saved register detection
// ============================================================

function arm64GetGprOrdinal(vreg Arm64VReg) returns RegInt
	return match vreg 'check'
		physical(reg) gives reg.rawValue
		virtual gives 0 - 1
	end 'check'
end 'arm64GetGprOrdinal'

function arm64GetFpOrdinal(vreg Arm64FpVReg) returns RegInt
	return match vreg 'check'
		physical(reg) gives reg.rawValue
		virtual gives 0 - 1
	end 'check'
end 'arm64GetFpOrdinal'

function arm64MarkGprIfCalleeSaved(seen RegIntArray, vreg Arm64VReg)
	let ord = arm64GetGprOrdinal(vreg)
	if ord >= 19 and ord <= 28 'calleeSaved'
		arm64MarkRegOrdinal(seen, ordinal: ord)
	end 'calleeSaved'
end 'arm64MarkGprIfCalleeSaved'

function arm64MarkFpIfCalleeSaved(seen RegIntArray, vreg Arm64FpVReg)
	let ord = arm64GetFpOrdinal(vreg)
	if ord >= 8 and ord <= 15 'calleeSaved'
		arm64MarkRegOrdinal(seen, ordinal: ord)
	end 'calleeSaved'
end 'arm64MarkFpIfCalleeSaved'

function arm64MarkRegOrdinal(seen RegIntArray, ordinal RegInt)
	for existing in seen 'check'
		if existing == ordinal 'dup'
			return
		end 'dup'
	end 'check'
	seen.push(ordinal)
end 'arm64MarkRegOrdinal'

// Scan a single Arm64Op for callee-saved register usage.
function arm64ScanOpForCalleeSaved(op Arm64Op, gprSeen RegIntArray, fpSeen RegIntArray)
	match op 'scan'
		prologue to epilogue then break 'scan'
		movImm(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		strToSlot(_, src) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		ldrFromSlot(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		addRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		addsRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		subRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		subsRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		mulRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		sdivRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		remRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		negReg(dest, src) then arm64ScanTwoGprs(gprSeen, a: dest, b: src)
		mvnReg(dest, src) then arm64ScanTwoGprs(gprSeen, a: dest, b: src)
		andRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		andsRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		orrRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		eorRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		lslRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		asrRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		lsrRegs(dest, src1, src2) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		cmpRegs(src1, src2) then arm64ScanTwoGprs(gprSeen, a: src1, b: src2)
		cmpRegZero(src) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		condBranch to memcpyOp then break 'scan'
		movRegReg(dest, src) then arm64ScanTwoGprs(gprSeen, a: dest, b: src)
		spillToStack(_, src) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		reloadFromStack(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		branchLinkReg(reg) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: reg)
		subSpImm to addSpImm then break 'scan'
		strToSpOffset(_, src) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		fmovRegReg(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		spillFpToStack(_, src, _) then arm64MarkFpIfCalleeSaved(fpSeen, vreg: src)
		reloadFpFromStack(dest, _, _) then arm64MarkFpIfCalleeSaved(fpSeen, vreg: dest)
		fmovToFloat(dest, src, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: src, fp: dest)
		fmovToGpr(dest, src, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: dest, fp: src)
		fpLoadRdata(dest, _, _) then arm64MarkFpIfCalleeSaved(fpSeen, vreg: dest)
		fadd(dest, src1, src2, _) then arm64ScanThreeFps(fpSeen, a: dest, b: src1, c: src2)
		fsub(dest, src1, src2, _) then arm64ScanThreeFps(fpSeen, a: dest, b: src1, c: src2)
		fmul(dest, src1, src2, _) then arm64ScanThreeFps(fpSeen, a: dest, b: src1, c: src2)
		fdiv(dest, src1, src2, _) then arm64ScanThreeFps(fpSeen, a: dest, b: src1, c: src2)
		fsqrt(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		fabs(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		fneg(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		fcmp(src1, src2, _) then arm64ScanTwoFps(fpSeen, a: src1, b: src2)
		scvtf(dest, src, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: src, fp: dest)
		fcvtzs(dest, src, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: dest, fp: src)
		fcvt(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		frintm(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		frintp(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		frintz(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		frintn(dest, src, _) then arm64ScanTwoFps(fpSeen, a: dest, b: src)
		fpStoreIndirect(baseReg, _, src, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: baseReg, fp: src)
		fpLoadIndirect(dest, baseReg, _, _) then arm64ScanGprAndFp(gprSeen, fpSeen: fpSeen, gpr: baseReg, fp: dest)
		storeIndirect(baseReg, _, srcReg, _) then arm64ScanTwoGprs(gprSeen, a: baseReg, b: srcReg)
		loadIndirect(destReg, baseReg, _, _) then arm64ScanTwoGprs(gprSeen, a: destReg, b: baseReg)
		globalLoad(dest, _, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		globalStore(_, src, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		globalLoadFloat(dest, _, _) then arm64MarkFpIfCalleeSaved(fpSeen, vreg: dest)
		globalStoreFloat(_, src, _) then arm64MarkFpIfCalleeSaved(fpSeen, vreg: src)
		leaFromStack(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		leaRdata(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		leaFuncAddr(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		cset(dest, _) then arm64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		csel(dest, src1, src2, _) then arm64ScanThreeGprs(gprSeen, a: dest, b: src1, c: src2)
		sxtw(dest, src) then arm64ScanTwoGprs(gprSeen, a: dest, b: src)
		nullSafeLoad(dest, baseReg, _) then arm64ScanTwoGprs(gprSeen, a: dest, b: baseReg)
	end 'scan'
end 'arm64ScanOpForCalleeSaved'

function arm64ScanTwoGprs(seen RegIntArray, a Arm64VReg, b Arm64VReg)
	arm64MarkGprIfCalleeSaved(seen, vreg: a)
	arm64MarkGprIfCalleeSaved(seen, vreg: b)
end 'arm64ScanTwoGprs'

function arm64ScanThreeGprs(seen RegIntArray, a Arm64VReg, b Arm64VReg, c Arm64VReg)
	arm64MarkGprIfCalleeSaved(seen, vreg: a)
	arm64MarkGprIfCalleeSaved(seen, vreg: b)
	arm64MarkGprIfCalleeSaved(seen, vreg: c)
end 'arm64ScanThreeGprs'

function arm64ScanTwoFps(seen RegIntArray, a Arm64FpVReg, b Arm64FpVReg)
	arm64MarkFpIfCalleeSaved(seen, vreg: a)
	arm64MarkFpIfCalleeSaved(seen, vreg: b)
end 'arm64ScanTwoFps'

function arm64ScanThreeFps(seen RegIntArray, a Arm64FpVReg, b Arm64FpVReg, c Arm64FpVReg)
	arm64MarkFpIfCalleeSaved(seen, vreg: a)
	arm64MarkFpIfCalleeSaved(seen, vreg: b)
	arm64MarkFpIfCalleeSaved(seen, vreg: c)
end 'arm64ScanThreeFps'

function arm64ScanGprAndFp(gprSeen RegIntArray, fpSeen RegIntArray, gpr Arm64VReg, fp Arm64FpVReg)
	arm64MarkGprIfCalleeSaved(gprSeen, vreg: gpr)
	arm64MarkFpIfCalleeSaved(fpSeen, vreg: fp)
end 'arm64ScanGprAndFp'

// Scan all ops in a function to find callee-saved registers that need saving.
function arm64DetectCalleeSavedRegs(srcFunc MlirFunction, dstFunc MlirFunction)
	let gprSeen = RegIntArray.create()
	let fpSeen = RegIntArray.create()

	for block in srcFunc.blocks 'eachBlock'
		if isArm64DivergingBlock(block) 'skipDiverging'
			continue
		end 'skipDiverging'
		for op in block.ops 'eachOp'
			arm64ScanMlirOpForCalleeSaved(op, gprSeen: gprSeen, fpSeen: fpSeen)
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			arm64ScanMlirOpForCalleeSaved(block.terminator, gprSeen: gprSeen, fpSeen: fpSeen)
		end 'hasTerm'
	end 'eachBlock'

	// Sort for deterministic prologue/epilogue ordering
	sortRegOrdinals(gprSeen)
	sortRegOrdinals(fpSeen)

	dstFunc.calleeSavedGprs = gprSeen
	dstFunc.calleeSavedFps = fpSeen
end 'arm64DetectCalleeSavedRegs'

function arm64ScanMlirOpForCalleeSaved(op MlirOp, gprSeen RegIntArray, fpSeen RegIntArray)
	match op 'dispatch'
		maxon to x64 then break 'dispatch'
		arm64(a64Op) then arm64ScanOpForCalleeSaved(a64Op, gprSeen: gprSeen, fpSeen: fpSeen)
	end 'dispatch'
end 'arm64ScanMlirOpForCalleeSaved'

// Simple insertion sort for small register ordinal arrays.
function sortRegOrdinals(arr RegIntArray)
	let n = arr.count()
	var i = 1
	while i < n 'outer'
		let key = try arr.get(i) otherwise 0
		var j = i - 1
		while j >= 0 'inner'
			let val = try arr.get(j) otherwise 0
			if val <= key 'done'
				break
			end 'done'
			arr.set(j + 1, value: val)
			j = j - 1
		end 'inner'
		arr.set(j + 1, value: key)
		i = i + 1
	end 'outer'
end 'sortRegOrdinals'

// ============================================================
// X64 callee-saved register detection
// ============================================================

function x64GetGprOrdinal(vreg X64VReg) returns RegInt
	return match vreg 'check'
		physical(reg) gives reg.rawValue
		virtual gives 0 - 1
	end 'check'
end 'x64GetGprOrdinal'

function x64MarkGprIfCalleeSaved(seen RegIntArray, vreg X64VReg)
	let ord = x64GetGprOrdinal(vreg)
	// r12=12, r13=13, r14=14, r15=15 are callee-saved
	if ord >= 12 and ord <= 15 'calleeSaved'
		x64MarkRegOrdinal(seen, ordinal: ord)
	end 'calleeSaved'
end 'x64MarkGprIfCalleeSaved'

function x64MarkRegOrdinal(seen RegIntArray, ordinal RegInt)
	for existing in seen 'check'
		if existing == ordinal 'dup'
			return
		end 'dup'
	end 'check'
	seen.push(ordinal)
end 'x64MarkRegOrdinal'

function x64ScanTwoGprs(seen RegIntArray, a X64VReg, b X64VReg)
	x64MarkGprIfCalleeSaved(seen, vreg: a)
	x64MarkGprIfCalleeSaved(seen, vreg: b)
end 'x64ScanTwoGprs'

function x64ScanThreeGprs(seen RegIntArray, a X64VReg, b X64VReg, c X64VReg)
	x64MarkGprIfCalleeSaved(seen, vreg: a)
	x64MarkGprIfCalleeSaved(seen, vreg: b)
	x64MarkGprIfCalleeSaved(seen, vreg: c)
end 'x64ScanThreeGprs'

// Scan all ops in a function to find callee-saved registers that need saving.
// Skips diverging blocks (panic paths) since they never return.
function x64DetectCalleeSavedRegs(srcFunc MlirFunction, dstFunc MlirFunction)
	let gprSeen = RegIntArray.create()

	for block in srcFunc.blocks 'eachBlock'
		if isX64DivergingBlock(block) 'skipDiverging'
			continue
		end 'skipDiverging'
		for op in block.ops 'eachOp'
			x64ScanMlirOpForCalleeSaved(op, gprSeen: gprSeen)
		end 'eachOp'
		if block.hasTerminator 'hasTerm'
			x64ScanMlirOpForCalleeSaved(block.terminator, gprSeen: gprSeen)
		end 'hasTerm'
	end 'eachBlock'

	// Sort for deterministic prologue/epilogue ordering
	sortRegOrdinals(gprSeen)

	dstFunc.calleeSavedGprs = gprSeen
end 'x64DetectCalleeSavedRegs'

function x64ScanMlirOpForCalleeSaved(op MlirOp, gprSeen RegIntArray)
	match op 'dispatch'
		maxon to sys then break 'dispatch'
		mir then break 'dispatch'
		x64(x64Op) then x64ScanOpForCalleeSaved(x64Op, gprSeen: gprSeen)
		arm64 then break 'dispatch'
	end 'dispatch'
end 'x64ScanMlirOpForCalleeSaved'

function x64ScanOpForCalleeSaved(op X64Op, gprSeen RegIntArray)
	match op 'scan'
		prologue to ret then break 'scan'
		movRegImm(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		movRegImm32(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		movSlot(_, src) then x64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		loadSlot(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		addRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		subRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		addRegImm(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		subRegImm(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		imulRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		idivRcx to iremRcx then break 'scan'
		negReg(reg) then x64MarkGprIfCalleeSaved(gprSeen, vreg: reg)
		bitNotReg(reg) then x64MarkGprIfCalleeSaved(gprSeen, vreg: reg)
		andRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		orRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		xorRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		shlRegCl(dest, operand, shift) then x64ScanThreeGprs(gprSeen, a: dest, b: operand, c: shift)
		sarRegCl(dest, operand, shift) then x64ScanThreeGprs(gprSeen, a: dest, b: operand, c: shift)
		shrRegCl(dest, operand, shift) then x64ScanThreeGprs(gprSeen, a: dest, b: operand, c: shift)
		cmpRaxRcx to jmp then break 'scan'
		movF64Slot to ucomisd then break 'scan'
		printLiteral to printInt then break 'scan'
		subRspImm to addRspImm then break 'scan'
		movRspOffsetReg(_, src) then x64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		loadRegRbpOffset(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		callDirect to memcpyOp then break 'scan'
		movRegReg(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		cmpRegReg(lhs, rhs) then x64ScanTwoGprs(gprSeen, a: lhs, b: rhs)
		cmpRegImm(lhs, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: lhs)
		testRegReg(r1, r2) then x64ScanTwoGprs(gprSeen, a: r1, b: r2)
		cqo then break 'scan'
		idivReg(divisor) then x64MarkGprIfCalleeSaved(gprSeen, vreg: divisor)
		spillToStack(_, src) then x64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		reloadFromStack(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		xorRegRegSelf(reg) then x64MarkGprIfCalleeSaved(gprSeen, vreg: reg)
		callIndirect(reg) then x64MarkGprIfCalleeSaved(gprSeen, vreg: reg)
		xchgRegReg(r1, r2) then x64ScanTwoGprs(gprSeen, a: r1, b: r2)
		movXmmXmm to andMaskRipRel then break 'scan'
		storeIndirect(base, _, src, _) then x64ScanTwoGprs(gprSeen, a: base, b: src)
		loadIndirect(dest, base, _, _) then x64ScanTwoGprs(gprSeen, a: dest, b: base)
		storeIndirectXmm(base, _, _, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: base)
		loadIndirectXmm(_, base, _, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: base)
		globalLoad(dest, _, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		globalStore(_, src, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: src)
		globalLoadXmm to globalStoreXmm then break 'scan'
		leaFromStack(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		leaRipRelative(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		leaFuncAddr(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		setcc(dest, _) then x64MarkGprIfCalleeSaved(gprSeen, vreg: dest)
		cmov(dest, src, _) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		movsxd(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		movzx32(dest, src) then x64ScanTwoGprs(gprSeen, a: dest, b: src)
		nullSafeLoad(dest, base, _) then x64ScanTwoGprs(gprSeen, a: dest, b: base)
		repMovsb to repStosq then break 'scan'
	end 'scan'
end 'x64ScanOpForCalleeSaved'

// ============================================================
// ARM64 prologue/epilogue insertion
// ============================================================

function insertArm64PrologueEpilogue(srcFunc MlirFunction, dstFunc MlirFunction, stackSize StackSize)
	// Detect callee-saved registers used in this function.
	arm64DetectCalleeSavedRegs(srcFunc, dstFunc: dstFunc)

	// Compute additional frame space for callee-saved registers.
	// Each register is 8 bytes; we store them in pairs (STP), so round up to even count.
	let gprCount = dstFunc.calleeSavedGprs.count()
	let fpCount = dstFunc.calleeSavedFps.count()
	let gprPairs = (gprCount + 1) / 2
	let fpPairs = (fpCount + 1) / 2
	let calleeSaveArea = (gprPairs + fpPairs) * 16
	let adjustedStackSize = alignTo16(stackSize + calleeSaveArea)

	var isFirstBlock = true

	for srcBlock in srcFunc.blocks 'eachBlock'
		var dstBlock = addBlock(dstFunc, label: srcBlock.label)
		dstBlock.id = srcBlock.id
		dstBlock.blockArgs = srcBlock.blockArgs

		if isFirstBlock 'isEntry'
			// ARM64 always emits prologue (even for stackSize=0) because the
			// prologue includes STP x29,x30 which is needed for unwinding.
			dstBlock.ops.push(MlirOp.arm64(Arm64Op.prologue(adjustedStackSize)))
			isFirstBlock = false
		end 'isEntry'

		// Copy ops, stripping any existing prologue/epilogue ops.
		for op in srcBlock.ops 'eachOp'
			if isArm64PrologueOrEpilogue(op) 'skipPeOp'
				continue
			end 'skipPeOp'
			dstBlock.ops.push(op)
		end 'eachOp'

		// Handle the terminator: ARM64 uses epilogue as the block terminator
		// for return blocks. The epilogue op includes the ret instruction.
		if srcBlock.hasTerminator 'hasTerm'
			if isArm64EpilogueTerminator(srcBlock.terminator) 'termIsEpilogue'
				// Re-emit the epilogue as the terminator with our computed stack size.
				dstBlock.hasTerminator = true
				dstBlock.terminator = MlirOp.arm64(Arm64Op.epilogue)
			end 'termIsEpilogue' else 'otherTerm'
				dstBlock.hasTerminator = srcBlock.hasTerminator
				dstBlock.terminator = srcBlock.terminator
			end 'otherTerm'
		end 'hasTerm'
	end 'eachBlock'
end 'insertArm64PrologueEpilogue'

// Check if an MlirOp is an ARM64 prologue or epilogue op.
function isArm64PrologueOrEpilogue(op MlirOp) returns bool
	var result = false
	match op 'check'
		maxon to sys then break 'check'
		mir then break 'check'
		x64 then break 'check'
		arm64(a64Op) then result = isArm64PeOp(a64Op)
	end 'check'
	return result
end 'isArm64PrologueOrEpilogue'

function isArm64PeOp(op Arm64Op) returns bool
	return match op 'check'
		prologue gives true
		epilogue gives true
		movImm to nullSafeLoad gives false
	end 'check'
end 'isArm64PeOp'

// Check if a terminator op is an ARM64 epilogue.
function isArm64EpilogueTerminator(op MlirOp) returns bool
	var result = false
	match op 'check'
		maxon to sys then break 'check'
		mir then break 'check'
		x64 then break 'check'
		arm64(a64Op) then result = isArm64EpilogueVariant(a64Op)
	end 'check'
	return result
end 'isArm64EpilogueTerminator'

function isArm64EpilogueVariant(op Arm64Op) returns bool
	return match op 'check'
		prologue gives false
		epilogue gives true
		movImm to nullSafeLoad gives false
	end 'check'
end 'isArm64EpilogueVariant'

// Cross-platform SSA register allocator.
// Computes liveness, builds live ranges, spills, and colors using SSA dominance.
// Works with integer register ordinals (0..N) — each target maps to/from its register enum.

export typealias RegInt = int(i64.min to i64.max)
export typealias RegIntArray = Array with RegInt
export typealias RegOrdinal = int(i64.min to i64.max)

export let RM_NONE = -1
export let RM_NO_STACK_HOME = -i64.max

export typealias RegMask = int(0 to u32.max)

export enum OpPattern
	// No register operands — just push the op through
	passThrough
	// GPR patterns
	singleDef
	singleUse
	defUse
	twoAddr
	useDefImm
	unaryInPlace
	threeAddr
	twoUse
	singleUseNodef
	// Memory GPR patterns
	baseUseSrcUse
	baseUseDest
	// FP patterns
	fpSingleDef
	fpSingleUse
	fpDefUse
	fpTwoAddr
	fpThreeAddr
	fpTwoUse
	fpMov
	// Cross-domain
	gprToFp
	fpToGpr
	baseUseFpUse
	baseUseFpDef
	// Special (keep dedicated handler)
	movRegReg
	constImm
	shift
	divReg
	callIndirect
	exchange
	csel
	// Memory-operand ALU (Phase 2 dialect groundwork): dest = dest OP [base+offset].
	// `dest` is read+written (use+def), `base` is read-only. Used by x64
	// addRegMem/subRegMem/andRegMem/orRegMem/xorRegMem/imulRegMem.
	baseUseUseDef
	// Memory-operand compare (Phase 2): lhs OP [base+offset]; both regs are
	// read-only and no register is defined (flags only). Used by x64 cmpRegMem.
	baseTwoUse
	// Three-operand ALU with one immediate (Phase 2): dest = src OP imm.
	// `dest` is def-only, `src` is read-only. Used by x64 imulRegImm.
	defUseImm
end 'OpPattern'

// Per-value state: consolidates all value-indexed register allocator fields.
export type ValueInfo
	export var gprOrdinal as RegOrdinal
	export var stackHome as RegInt
	export var constantValue as RegInt
	export var isConstant as bool
	export var fpOrdinal as RegOrdinal
	export var fpStackHome as RegInt
	export var previousFp as RegOrdinal
	export var deferred as bool
	export var remainingUses as RegInt

	export static function default() returns ValueInfo
		return Self{gprOrdinal: RM_NONE, stackHome: RM_NO_STACK_HOME, constantValue: 0, isConstant: false, fpOrdinal: RM_NONE, fpStackHome: RM_NO_STACK_HOME, previousFp: RM_NONE, deferred: false, remainingUses: 0}
	end 'default'
end 'ValueInfo'

export typealias ValueInfoArray = Array with ValueInfo

function defaultValueInfo() returns ValueInfo
	return ValueInfo.default()
end 'defaultValueInfo'

// Per-function mutable state for the register allocator.
//
// Target configuration (pools, calling convention, capability flags) lives
// on `desc: TargetRegAlloc` — see TargetRegAlloc.maxon. RegState carries
// only the mutable state that changes as the allocator walks a single
// function: the current register contents, spill offsets, per-block counters,
// and the FP-register-side equivalents.
//
// All target-config reads funnel through `state.desc.xxx` so the generic
// allocator never matches on a target enum directly; per-target dispatch is
// handled by the RegAllocTarget interface.
export type RegState
	// Target descriptor — holds pools, call-conv config.
	export var desc as TargetRegAlloc

	// registerContents[regOrdinal] = valueId or RM_NONE (empty)
	export var registerContents as RegIntArray
	// lastUsed[regOrdinal] = op index of last use
	export var lastUsed as RegIntArray

	// Per-value state: values[valueId] = ValueInfo
	export var values as ValueInfoArray

	// Spill management
	export var spillBaseOffset as RegInt
	export var nextSpillOffset as RegInt
	export var minSpillOffset as RegInt

	// Per-block counters
	export var currentOpIndex as RegInt
	export var nextFreshIndex as RegInt

	// FP register state (mutable)
	export var nextFreshFpIndex as RegInt
	// fpContents[fpOrdinal] = valueId or RM_NONE
	export var fpContents as RegIntArray
	// fpLastUsed[fpOrdinal] = op index of last use
	export var fpLastUsed as RegIntArray

	// Debug: function name for error messages
	export var funcName as String

	export static function create(desc TargetRegAlloc, registerContents RegIntArray, lastUsed RegIntArray, spillBase RegInt, fpContents RegIntArray, fpLastUsed RegIntArray) returns RegState
		return Self{
			desc: desc,
			registerContents: registerContents,
			lastUsed: lastUsed,
			values: ValueInfoArray.create(),
			spillBaseOffset: spillBase,
			nextSpillOffset: spillBase,
			minSpillOffset: spillBase,
			currentOpIndex: 0,
			nextFreshIndex: 0,
			nextFreshFpIndex: 0,
			fpContents: fpContents,
			fpLastUsed: fpLastUsed,
			funcName: ""
		}
	end 'create'
end 'RegState'

// Snapshot of register allocator state for carrying assignments across diverging blocks.
export type RegSnapshot
	export var registerContents as RegIntArray
	export var values as ValueInfoArray
	export var fpContents as RegIntArray
	export var nextSpillOffset as RegInt
	export var minSpillOffset as RegInt

	export static function create(registerContents RegIntArray, values ValueInfoArray, fpContents RegIntArray, nextSpillOffset RegInt, minSpillOffset RegInt) returns RegSnapshot
		return Self{registerContents: registerContents, values: values, fpContents: fpContents, nextSpillOffset: nextSpillOffset, minSpillOffset: minSpillOffset}
	end 'create'
end 'RegSnapshot'

export typealias SnapshotMap = Map with (RegInt, RegSnapshot)

function copyValueInfoArray(src ValueInfoArray) returns ValueInfoArray
	var dst = ValueInfoArray.create()
	for val in src 'copy'
		dst.push(val.clone())
	end 'copy'
	return dst
end 'copyValueInfoArray'

// Ensure the values array can hold the given valueId.
function ensureValueCapacity(state RegState, valueId RegInt)
	while state.values.count() <= valueId 'grow'
		state.values.push(defaultValueInfo())
	end 'grow'
end 'ensureValueCapacity'

// Get the ValueInfo for a valueId, growing the array if needed.
export function getValueInfo(state RegState, valueId RegInt) returns ValueInfo
	ensureValueCapacity(state, valueId: valueId)
	return try state.values.get(valueId) otherwise defaultValueInfo()
end 'getValueInfo'

// Save current register allocator state for later restoration.
export function saveState(state RegState) returns RegSnapshot
	return RegSnapshot.create(state.registerContents.clone(), values: copyValueInfoArray(state.values), fpContents: state.fpContents.clone(), nextSpillOffset: state.nextSpillOffset, minSpillOffset: state.minSpillOffset)
end 'saveState'

// Restore register allocator state from a snapshot.
// Preserves spill offset watermarks if the saved offsets are more allocated.
export function restoreState(state RegState, snapshot RegSnapshot)
	state.registerContents = snapshot.registerContents.clone()
	state.values = copyValueInfoArray(snapshot.values)
	state.fpContents = snapshot.fpContents.clone()
	state.nextSpillOffset = snapshot.nextSpillOffset
	state.minSpillOffset = snapshot.minSpillOffset
	state.nextFreshIndex = 0
	state.nextFreshFpIndex = 0
	state.currentOpIndex = 0
end 'restoreState'

// Restore register state but preserve spill watermarks from both paths.
// Used for condBr targets where both paths are live (unlike diverging blocks).
export function restoreStatePreserveSpills(state RegState, snapshot RegSnapshot)
	state.registerContents = snapshot.registerContents.clone()
	state.values = copyValueInfoArray(snapshot.values)
	state.fpContents = snapshot.fpContents.clone()
	// Keep the current spill offsets if they've grown beyond the snapshot's,
	// since the fallthrough path may have allocated spill slots that are still live.
	if state.desc.spillsGrowDown 'growDown'
		if snapshot.nextSpillOffset < state.nextSpillOffset 'snapshotDeeper'
			state.nextSpillOffset = snapshot.nextSpillOffset
		end 'snapshotDeeper'
		if snapshot.minSpillOffset < state.minSpillOffset 'snapshotMinDeeper'
			state.minSpillOffset = snapshot.minSpillOffset
		end 'snapshotMinDeeper'
	end 'growDown' else 'growUp'
		if snapshot.nextSpillOffset > state.nextSpillOffset 'snapshotHigher'
			state.nextSpillOffset = snapshot.nextSpillOffset
		end 'snapshotHigher'
		if snapshot.minSpillOffset > state.minSpillOffset 'snapshotMinHigher'
			state.minSpillOffset = snapshot.minSpillOffset
		end 'snapshotMinHigher'
	end 'growUp'
	state.nextFreshIndex = 0
	state.nextFreshFpIndex = 0
	state.currentOpIndex = 0
end 'restoreStatePreserveSpills'

// --- Initialization ---

export function createRegState(desc TargetRegAlloc) returns RegState
	// Find max GPR ordinal to size registerContents and lastUsed arrays
	let poolSize = desc.gprPool.count()
	var maxOrd = 0
	var mi = 0
	while mi < poolSize 'findMax'
		let ord = try desc.gprPool.get(mi) otherwise panic("createRegState.findMax: mi < poolSize = gprPool.count() by loop guard but get({mi}) failed")
		if ord > maxOrd 'bigger'
			maxOrd = ord
		end 'bigger'
		mi = mi + 1
	end 'findMax'
	let regArraySize = maxOrd + 1
	var regContents = RegIntArray.create()
	var regLastUsed = RegIntArray.create()
	var initIdx = 0
	while initIdx < regArraySize 'initRegs'
		regContents.push(RM_NONE)
		regLastUsed.push(0)
		initIdx = initIdx + 1
	end 'initRegs'

	// Find max FP ordinal and initialize FP register arrays
	let fpPoolSz = desc.fpPool.count()
	var fpMaxOrd = 0
	var fmi = 0
	while fmi < fpPoolSz 'findFpMax'
		let fOrd = try desc.fpPool.get(fmi) otherwise panic("createRegState.findFpMax: fmi < fpPoolSz = fpPool.count() by loop guard but get({fmi}) failed")
		if fOrd > fpMaxOrd 'bigger'
			fpMaxOrd = fOrd
		end 'bigger'
		fmi = fmi + 1
	end 'findFpMax'
	let fpArraySize = fpMaxOrd + 1
	var fpCont = RegIntArray.create()
	var fpLU = RegIntArray.create()
	var fpInit = 0
	while fpInit < fpArraySize 'initFpRegs'
		fpCont.push(RM_NONE)
		fpLU.push(0)
		fpInit = fpInit + 1
	end 'initFpRegs'

	return RegState.create(desc, registerContents: regContents, lastUsed: regLastUsed, spillBase: desc.initialSpillBase, fpContents: fpCont, fpLastUsed: fpLU)
end 'createRegState'

// --- Array helpers ---

function growSigned(arr RegIntArray, index RegInt, sentinel RegInt)
	while arr.count() <= index 'grow'
		arr.push(sentinel)
	end 'grow'
end 'growSigned'

// Lazy-map lookup with explicit fallback. The negative-index guard exists
// because `Array.get` panics on negatives (vs. returning try-failure for
// past-the-end), and callers may legitimately pass a sentinel index of -1.
export function getOr(arr RegIntArray, index RegInt, fallback RegInt) returns RegInt
	if index < 0 'negative'
		return fallback
	end 'negative'
	return try arr.get(index) otherwise fallback
end 'getOr'

export function set(arr RegIntArray, index RegInt, value RegInt, sentinel RegInt)
	growSigned(arr, index: index, sentinel: sentinel)
	try arr.set(index, value: value) otherwise panic("invariant: arr.set OOB")
end 'set'

// Union `source` into `dest` (both indexed by valueId; `false` is the
// "absent" default). Used by runSpillColorLoop to accumulate every spill
// iteration's freshly-minted reload vregs into the allocator's cumulative
// reload set, which buildLiveRanges then consults to assign
// SPILL_WEIGHT_INFINITE to those ranges.
export function unionReloadIds(dest BoolArray, source BoolArray)
	let n = source.count()
	while dest.count() < n 'grow'
		dest.push(false)
	end 'grow'
	var i = 0
	while i < n 'each'
		let bit = try source.get(i) otherwise false
		if bit 'set'
			try dest.set(i, value: true) otherwise panic("invariant: unionReloadIds.dest.set OOB i={i} count={dest.count()}")
		end 'set'
		i = i + 1
	end 'each'
end 'unionReloadIds'

// --- Core state operations ---

export function assign(state RegState, regOrdinal RegOrdinal, valueId RegInt)
	// If this value was previously in a different register, clear that old mapping
	// to prevent stale registerContents entries (e.g. after pre-seeded param moves).
	var info = getValueInfo(state, valueId: valueId)
	let oldReg = info.gprOrdinal
	if oldReg != RM_NONE and oldReg != regOrdinal 'clearOld'
		// Only clear if the old register still thinks it holds this value.
		// Another value may have been assigned to oldReg in the meantime.
		let oldOccupant = getOr(state.registerContents, index: oldReg, fallback: RM_NONE)
		if oldOccupant == valueId 'stillOurs'
			try state.registerContents.set(oldReg, value: RM_NONE) otherwise panic("invariant: state.registerContents.set OOB")
			try state.lastUsed.set(oldReg, value: 0) otherwise panic("invariant: state.lastUsed.set OOB")
		end 'stillOurs'
	end 'clearOld'
	try state.registerContents.set(regOrdinal, value: valueId) otherwise panic("invariant: state.registerContents.set OOB")
	info.gprOrdinal = regOrdinal
	try state.lastUsed.set(regOrdinal, value: state.currentOpIndex) otherwise panic("invariant: state.lastUsed.set OOB")
end 'assign'

export function recordConstant(state RegState, valueId RegInt, value RegInt)
	var info = getValueInfo(state, valueId: valueId)
	info.constantValue = value
	info.isConstant = true
end 'recordConstant'

export function advanceOp(state RegState)
	state.currentOpIndex = state.currentOpIndex + 1
end 'advanceOp'

// Allocate a new spill slot offset. Direction depends on target:
// - x86: grow downward (nextSpillOffset -= 8, return new offset)
// - ARM64: grow upward (return current offset, nextSpillOffset += 8)
function allocateSpillSlot(state RegState) returns RegInt
	if state.desc.spillsGrowDown 'growDown'
		state.nextSpillOffset = state.nextSpillOffset - 8
		return state.nextSpillOffset
	end 'growDown' else 'growUp'
		let slot = state.nextSpillOffset
		state.nextSpillOffset = state.nextSpillOffset + 8
		return slot
	end 'growUp'
end 'allocateSpillSlot'

// Track the high-water mark of spill usage, then reset for the next block/function.
// x86 spills grow downward so we track the minimum offset;
// ARM64 spills grow upward so we track the maximum offset.
function updateSpillWatermark(state RegState)
	if state.desc.spillsGrowDown 'x86Wm'
		if state.nextSpillOffset < state.minSpillOffset 'updateMin'
			state.minSpillOffset = state.nextSpillOffset
		end 'updateMin'
	end 'x86Wm' else 'arm64Wm'
		if state.nextSpillOffset > state.minSpillOffset 'updateMax'
			state.minSpillOffset = state.nextSpillOffset
		end 'updateMax'
	end 'arm64Wm'
end 'updateSpillWatermark'

// Compute the total spill area size, 16-byte aligned.
// spillBaseOffset is where spills start; minSpillOffset tracks the watermark
// (lowest offset for downward growth, highest for upward). The absolute
// distance between them is the spill extent, rounded up to 16-byte alignment.
export function totalStackSize(state RegState) returns RegInt
	updateSpillWatermark(state)
	let raw = trunc(abs(state.spillBaseOffset - state.minSpillOffset))
	if raw > 0 'hasSpills'
		return (raw + 15) and -16
	end 'hasSpills'
	return 0
end 'totalStackSize'

// --- FP register assignment ---

export function assignFp(state RegState, fpOrdinal RegOrdinal, valueId RegInt)
	try state.fpContents.set(fpOrdinal, value: valueId) otherwise panic("invariant: state.fpContents.set OOB")
	var vi = getValueInfo(state, valueId: valueId)
	vi.fpOrdinal = fpOrdinal
	try state.fpLastUsed.set(fpOrdinal, value: state.currentOpIndex) otherwise panic("invariant: state.fpLastUsed.set OOB")
end 'assignFp'

// --- Value lifetime ---

export function noteValueDead(state RegState, valueId RegInt)
	var info = getValueInfo(state, valueId: valueId)
	let regOrd = info.gprOrdinal
	if regOrd != RM_NONE 'inReg'
		info.gprOrdinal = RM_NONE
		try state.registerContents.set(regOrd, value: RM_NONE) otherwise panic("invariant: state.registerContents.set OOB")
		try state.lastUsed.set(regOrd, value: 0) otherwise panic("invariant: state.lastUsed.set OOB")
	end 'inReg'
	// Also check FP registers
	let fpOrd = info.fpOrdinal
	if fpOrd != RM_NONE 'inFp'
		info.fpOrdinal = RM_NONE
		try state.fpContents.set(fpOrd, value: RM_NONE) otherwise panic("invariant: state.fpContents.set OOB")
		try state.fpLastUsed.set(fpOrd, value: 0) otherwise panic("invariant: state.fpLastUsed.set OOB")
	end 'inFp'
end 'noteValueDead'

export function noteStoreToStack(state RegState, valueId RegInt, stackOffset RegInt)
	var vi = getValueInfo(state, valueId: valueId)
	vi.stackHome = stackOffset
end 'noteStoreToStack'

// Clear the virtual register mapping for a physical register.
// Used after instructions that clobber a register with a new value
// (e.g., IDIV writing quotient to RAX and remainder to RDX).
export function clearRegisterContents(state RegState, regOrdinal RegOrdinal)
	let occupant = getOr(state.registerContents, index: regOrdinal, fallback: RM_NONE)
	if occupant != RM_NONE 'hasOccupant'
		var occVI = getValueInfo(state, valueId: occupant)
		occVI.gprOrdinal = RM_NONE
		try state.registerContents.set(regOrdinal, value: RM_NONE) otherwise panic("invariant: state.registerContents.set OOB")
		try state.lastUsed.set(regOrdinal, value: 0) otherwise panic("invariant: state.lastUsed.set OOB")
	end 'hasOccupant'
end 'clearRegisterContents'

export function clearRegisterMapping(state RegState, valueId RegInt)
	var info = getValueInfo(state, valueId: valueId)
	if info.gprOrdinal != RM_NONE 'hasMapping'
		info.gprOrdinal = RM_NONE
	end 'hasMapping'
	if info.fpOrdinal != RM_NONE 'hasFpMapping'
		info.fpOrdinal = RM_NONE
	end 'hasFpMapping'
end 'clearRegisterMapping'

// ============================================================
// Terminator query functions
// ============================================================

// Check if a terminator is a conditional branch (condJump/condBranch).
// Kept as a free function because it is used outside the regalloc pipeline
// (MirToX64Conversion, MirToArm64Conversion).
export function terminatorIsConditionalBranch(module TargetModule, packed OpIndex) returns bool
	return match module.cpu 'dispatch'
		x64 gives terminatorIsCondBrX64(module, packed: packed)
		arm64 gives terminatorIsCondBrArm64(module, packed: packed)
		default panic("regalloc helper not used for WASM targets")
	end 'dispatch'
end 'terminatorIsConditionalBranch'

export function terminatorIsCondBrX64(module TargetModule, packed OpIndex) returns bool
	let x64Op = try module.x64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.x64Ops")
	return match x64Op 'check'
		condJump gives true
		prologue to testRaxRax gives false
		jmp to imulRegImm gives false
	end 'check'
end 'terminatorIsCondBrX64'

export function terminatorIsCondBrArm64(module TargetModule, packed OpIndex) returns bool
	let a64Op = try module.arm64Ops.get(packed) otherwise panic("invariant: packed opIdx not in module.arm64Ops")
	return match a64Op 'check'
		condBranch gives true
		prologue to cmpRegZero gives false
		branch to xorRegImm gives false
	end 'check'
end 'terminatorIsCondBrArm64'

// Swap two registers. If the target has a native exchange instruction
// (state.desc.hasXchg), use it directly; otherwise fall back to a 3-move
// sequence through the cycle-break scratch register.
export function targetEmitXchgOrSwap(module TargetModule, state RegState, target RegAllocTarget, dstBlock IrBlock, ord1 RegOrdinal, ord2 RegOrdinal)
	if state.desc.hasXchg 'xchg'
		target.emitXchg(module, dstBlock: dstBlock, ord1: ord1, ord2: ord2)
	end 'xchg' else 'threeMov'
		let scratch = state.desc.gprCycleBreakOrd
		target.emitMovReg(module, dstBlock: dstBlock, destOrd: scratch, srcOrd: ord2)
		target.emitMovReg(module, dstBlock: dstBlock, destOrd: ord2, srcOrd: ord1)
		target.emitMovReg(module, dstBlock: dstBlock, destOrd: ord1, srcOrd: scratch)
	end 'threeMov'
end 'targetEmitXchgOrSwap'

// ============================================================
// Standalone register allocation pass
// ============================================================

// Create the target-specific register allocator implementation.
// This is the single dispatch point that selects the concrete type.

typealias FuncIdx = int(0 to u64.max)
typealias FuncIdxArray = Array with FuncIdx

// Walk every function once and collect the indices of those carrying virtual
// registers. Used by `allocateRegistersWithTarget` to drive both the
// all-physical fast path (empty result → no-op) and the per-function regalloc
// loop on the slow path — fusing what used to be a `moduleHasVirtualRegs`
// pre-pass plus a per-function re-check into a single op-walk.
//
// Hand-written runtime / coverage stubs use physical registers directly, so
// re-running SSA regalloc on them is wasted work proportional to runtime size
// on every user compile — they fall out of this list by construction.
function collectFuncsNeedingRegalloc(module TargetModule, regTarget RegAllocTarget) returns FuncIdxArray
	var needs = FuncIdxArray.create()
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("collectFuncsNeedingRegalloc: functions.get OOB at {funcIdx}")
		if functionHasVirtualRegs(module, func: func, regTarget: regTarget) 'needsRegalloc'
			needs.push(funcIdx as FuncIdx)
		end 'needsRegalloc'
	end 'eachFunc'
	return needs
end 'collectFuncsNeedingRegalloc'

// Per-function virtual-register check. Returns on the first virtual operand,
// so unallocated functions short-circuit quickly; fully-physical bodies pay
// the full op-walk but that's also when the function is being SKIPPED, so the
// cost is bounded by the runtime stub size, not by user IR size.
function functionHasVirtualRegs(module TargetModule, func IrFunction, regTarget RegAllocTarget) returns bool
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		for packed in block.opRefs 'eachOp'
			if regTarget.opHasVirtualRegs(module, packed: packed) 'foundVirtual'
				return true
			end 'foundVirtual'
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			if regTarget.opHasVirtualRegs(module, packed: block.terminatorIndex()) 'foundVirtualTerm'
				return true
			end 'foundVirtualTerm'
		end 'hasTerm'
	end 'eachBlock'
	return false
end 'functionHasVirtualRegs'

// Standalone register allocation pass entry point.
// Walks each function in the module and checks if any ops contain virtual
// registers. If all registers are already physical (ISel assigned them
// directly), the module is returned unchanged. If virtual registers are
// present, runs the full SSA register allocation to resolve them.
export function allocateRegisters(module TargetModule, target Target) returns TargetModule
	match target.cpu 'dispatch'
		x64 then allocateWithX64(module, target: target)
		arm64 then allocateWithArm64(module)
		wasm32 then break 'dispatch'
	end 'dispatch'
	return module
end 'allocateRegisters'

function allocateWithX64(module TargetModule, target Target)
	let desc = createX64TargetRegAlloc(target.os)
	allocateRegistersWithTarget(module, regTarget: X64RegAllocTarget.create(), desc: desc, opQuery: X64OpQuery.create())
end 'allocateWithX64'

function allocateWithArm64(module TargetModule)
	let desc = createArm64TargetRegAlloc()
	allocateRegistersWithTarget(module, regTarget: Arm64RegAllocTarget.create(), desc: desc, opQuery: Arm64OpQuery.create())
end 'allocateWithArm64'

function allocateRegistersWithTarget(module TargetModule, regTarget RegAllocTarget, desc TargetRegAlloc, opQuery TargetOpQuery)
	let needsRegalloc = collectFuncsNeedingRegalloc(module, regTarget: regTarget)

	if needsRegalloc.count() == 0 'allPhysical'
		logDebug(LogCategory.ir, message: function() gives "allocateRegisters: all registers physical, pass-through")
		return
	end 'allPhysical'

	logDebug(LogCategory.ir, message: function() gives "allocateRegisters: virtual registers detected, running standalone regalloc")
	for funcIdx in needsRegalloc 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("allocateRegistersWithTarget: functions.get OOB at {funcIdx}")
		let funcStart = passTimerStart()
		allocateRegistersForFunc(func, module: module, regTarget: regTarget, desc: desc, opQuery: opQuery)
		// Defer the classify call so its string-format cost is only paid when
		// timings are active.
		if passTimingsActive() 'recordFunc'
			recordPassSince(classifyRegallocFunc(func.name), startMs: funcStart)
		end 'recordFunc'
	end 'eachFunc'
end 'allocateRegistersWithTarget'

// Coarse per-function bucketing for regalloc timings: runtime stubs roll
// up into `__regalloc-rt`, everything else into `__regalloc-user`. Two
// buckets keeps the dumpPassTimings output scannable instead of producing
// one row per function. Used only when --profile-passes is active.
function classifyRegallocFunc(name String) returns String
	if name.startsWith("mrt_") or name.startsWith("__slab_") or name.startsWith("mm_") or name.startsWith("__mm_") 'isRuntime'
		return "__regalloc-rt"
	end 'isRuntime'
	return "__regalloc-user"
end 'classifyRegallocFunc'

// Increment the use count for a value. Called during pre-scan for each read operand.
export function incUse(counts RegIntArray, id RegInt)
	if id < 0 'invalid'
		return
	end 'invalid'
	let current = getOr(counts, index: id, fallback: 0)
	set(counts, index: id, value: current + 1, sentinel: 0)
end 'incUse'

// Record the last use position for a value. Called during pre-scan for each read operand.
// Forward scan: each call overwrites the previous, so at the end we have the last use position.
export function recordLastUse(positions RegIntArray, id RegInt, opIdx RegInt)
	if id < 0 'invalid'
		return
	end 'invalid'
	set(positions, index: id, value: opIdx, sentinel: -1)
end 'recordLastUse'

function ssaGetEntryBlockId(module TargetModule, func IrFunction) returns BlockId
	if func.blockRefs.count() == 0 'noBlocks'
		return 0
	end 'noBlocks'
	let blockRef = try func.blockRefs.get(0) otherwise panic("invariant: blockRefs.count() > 0 just checked but get(0) failed")
	let entry = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
	return entry.id
end 'ssaGetEntryBlockId'

// ============================================================
// SSA register allocation pipeline
// ============================================================

function allocateRegistersForFunc(srcFunc IrFunction, module TargetModule, regTarget RegAllocTarget, desc TargetRegAlloc, opQuery TargetOpQuery)
	var allocator = FunctionRegAllocator.create(srcFunc, module: module, desc: desc, regTarget: regTarget, opQuery: opQuery)
	allocator.run()
end 'allocateRegistersForFunc'

// Per-function register allocator.
//
// Owns the function's `module`/`func`, the CFG/dominator analysis outputs,
// and the rolling state (RegState, live ranges, coloring) that evolves across
// phases. Replaces a pile of local vars threaded through every phase entry
// point — adding a new cross-phase concern (diagnostics, iteration cap, ISel
// hint table) is now a new field rather than a signature change on every
// free function.
//
type FunctionRegAllocator
	// --- Inputs (set in create) ---
	export var module as TargetModule
	export var func as IrFunction
	export var desc as TargetRegAlloc
	export var regTarget as RegAllocTarget
	export var opQuery as TargetOpQuery

	// --- Phase 0: CFG analysis outputs ---
	export var cfg as CfgInfo
	export var rpo as RpoInfo
	export var domInfo as DomInfo
	export var loopDepth as RegIntArray
	export var domPreorder as BlockIdArray
	export var entryBlockId as BlockId

	// --- Rolling state across phases 1..7 ---
	export var state as RegState
	export var ranges as LiveRangeArray
	export var coloring as ColoringResult
	// Cumulative bitmap of reload vregs seen across every spill iteration.
	// Indexed by valueId. Each pass through runSpillColorLoop unions in
	// the new reload ids minted by insertSpillCode (carried back via
	// SpillDecision.reloadIds). buildLiveRanges reads this to assign
	// SPILL_WEIGHT_INFINITE to reload ranges, which is what guarantees
	// the spill loop terminates: an uncolorable reload triggers a hard
	// panic instead of being chain-respilled forever.
	export var reloadIds as BoolArray
	// Cumulative bitmap of vregs the spiller decided to rematerialize at
	// each use rather than spill to stack. Sibling to `reloadIds`. Each
	// iteration's SpillDecision.rematerializeIds is unioned into this
	// set after insertSpillCode; buildLiveRanges reads it back to stamp
	// `isRematerializable=true` and re-populate `constantValue` on the
	// freshly-built LiveRange so the property survives rebuilds (each
	// minted remat vreg is itself rematerializable from the same constant
	// — no chain-spill, no cycle).
	export var rematerializeIds as BoolArray
	// Sidetable from valueId to the constant value to rematerialize.
	// Populated alongside `rematerializeIds`. buildLiveRanges consults
	// this when stamping `LiveRange.constantValue` on rebuild.
	export var rematerializeValueByValueId as RegIntArray
	// Phi-merge splitting sidetable produced by splitMultiAnchorMerges.
	// Empty when no phi-merge needed splitting. destroySSA consults this
	// to dual-emit (src → sub-range → merge) parallel-copy moves at the
	// edges that were rewritten; without an entry buildBlockArgCopies
	// falls back to its original single-move path.
	export var splitInfo as SplitMergeInfoArray
	// Per-valueId stage from the call-boundary splitter (RS_NEW / RS_SPLIT1 /
	// RS_SPLIT2 / RS_DONE). Loaded into LiveRange.stage on every rebuild via
	// buildLiveRanges. trySplitAtCall bumps entries here; phi-merge sub-ranges
	// and reload vregs are stamped RS_DONE so they're never picked for further
	// splitting. Default RS_NEW (sentinel 0) when not set.
	export var stageByValueId as RegIntArray
	// Per-valueId eviction cascade from the Greedy-style colorer
	// (SSAColoring.colorClass). Loaded into LiveRange.cascade on every
	// rebuild via buildLiveRanges. Each time the colorer evicts a range
	// so a higher-priority range can take its register, the cascade is
	// bumped here. Bounded by MAX_CASCADE (see SSAColoring.maxon) so the
	// PQ-driven coloring loop provably terminates: every eviction makes
	// the evictee's (weight, cascade) strictly increase, and a range at
	// cascade = MAX_CASCADE can never be evicted again. Default 0 when
	// not set.
	export var cascadeByValueId as RegIntArray

	export static function create(func IrFunction, module TargetModule, desc TargetRegAlloc, regTarget RegAllocTarget, opQuery TargetOpQuery) returns FunctionRegAllocator
		// Placeholder fields for CFG/dom/coloring are immediately overwritten
		// by run(); they exist only so the type can be constructed up front.
		return Self{
			module: module,
			func: func,
			desc: desc,
			regTarget: regTarget,
			opQuery: opQuery,
			cfg: createCfgInfo(0),
			rpo: RpoInfo.create(BlockIdArray.create(), index: ValueIdArray.create()),
			domInfo: DomInfo.create(ValueIdArray.create()),
			loopDepth: RegIntArray.create(),
			domPreorder: BlockIdArray.create(),
			entryBlockId: 0,
			state: createRegState(desc),
			ranges: LiveRangeArray.create(),
			coloring: ColoringResult.create(0),
			reloadIds: BoolArray.create(),
			rematerializeIds: BoolArray.create(),
			rematerializeValueByValueId: RegIntArray.create(),
			splitInfo: SplitMergeInfoArray.create(),
			stageByValueId: RegIntArray.create(),
			cascadeByValueId: RegIntArray.create()
		}
	end 'create'

	function runCfgAnalysis()
		cfg = buildIrFunctionCfg(func, module: module, opQuery: opQuery)
		entryBlockId = ssaGetEntryBlockId(module, func: func)
		rpo = computeReversePostorder(entryBlockId, numBlocks: cfg.numBlocks, cfg: cfg)
		domInfo = computeDominators(entryBlockId, numBlocks: cfg.numBlocks, cfg: cfg, rpo: rpo)
		loopDepth = computeLoopNesting(cfg, domInfo: domInfo, rpo: rpo)
		domPreorder = computeDomTreePreorder(entryBlockId, domInfo: domInfo, numBlocks: cfg.numBlocks)
		state.funcName = func.name
	end 'runCfgAnalysis'

	// Phases 1-3: liveness → live ranges + physical constraints → coalescing,
	// then phi-merge splitting. Run once initially and again after every spill
	// iteration. Splitting must follow coalescing (which populates copyEdges
	// via hintBranchArgs) so the splitter can find and redirect the source
	// vreg's copy edges. Splitting must precede coloring so the per-anchor
	// sub-ranges enter the interference graph independently.
	function runLivenessAndRanges()
		let liveness = computeLiveness(module, func: func, cfg: cfg, rpo: rpo, regTarget: regTarget)
		ranges = buildLiveRanges(module, func: func, cfg: cfg, liveness: liveness, loopDepth: loopDepth, regTarget: regTarget, opQuery: opQuery, reloadIds: reloadIds, stageByValueId: stageByValueId, rematerializeIds: rematerializeIds, rematerializeValueByValueId: rematerializeValueByValueId, cascadeByValueId: cascadeByValueId)
		insertPhysicalConstraints(module, ranges: ranges, func: func, regTarget: regTarget, opQuery: opQuery)
		coalesceRanges(module, ranges: ranges, func: func, returnGprOrd: state.desc.returnGprOrd, errorFlagOrd: state.desc.errorFlagOrd, opQuery: opQuery)
		splitInfo = splitMultiAnchorMerges(ranges, func: func, module: module, stageByValueId: stageByValueId)
	end 'runLivenessAndRanges'

	function runColoring()
		coloring = colorSSA(ranges, domPreorder: domPreorder, gprPool: state.desc.gprPool, callerSavedGprs: state.desc.callerSavedGprs, fpPool: state.desc.fpPool, callerSavedFps: state.desc.callerSavedFps, cascadeByValueId: cascadeByValueId)
	end 'runColoring'

	// Phases 4-5: iterate spill/re-color until every virtual range is colored.
	//
	// Each iteration runs two passes over the uncolored set:
	//   Pass 1: try to call-boundary-split each uncolored range. Successful
	//     splits don't add to spillDec — the next iteration's liveness
	//     rebuild discovers the L_post sub-range and re-attempts coloring.
	//   Pass 2: for everything still uncolored after Pass 1:
	//     • If it's a phi-merge sub-range, demote the PARENT MERGE to a
	//       stack slot (LLVM's memory-only phi).
	//     • If it's a normal-weight range, route it through the spill picker.
	//     • If it's a reload (SPILL_WEIGHT_INFINITE) that can't be respilled,
	//       panic with a rich diagnostic naming the failing value, function,
	//       block, position, and live set. This is the clean failure mode
	//       Phase 6 will replace with last-chance recoloring.
	//
	// Termination is guaranteed by:
	//   • SPILL_WEIGHT_INFINITE on reload vregs (set in buildLiveRanges via
	//     the cumulative `reloadIds` bitmap) — reloads never get re-spilled.
	//   • LiveRange.stage capped at RS_SPLIT2 — each range splits at most
	//     twice before the splitter rejects it.
	// The iteration cap is therefore a safety belt; a handful of passes is
	// enough in practice.
	function runSpillColorLoop()
		var iteration = 0
		// Iteration cap: each spill round insertSpillCode mints reload
		// vregs with SPILL_WEIGHT_INFINITE, which the spill picker refuses
		// to re-spill. So the working set strictly shrinks every iteration
		// (or panics via panicUnresolvableReload). A handful of rounds is
		// enough in practice; 10 is a safety belt.
		while iteration < 10 'spillColorLoop'
			let uncoloredSpills = findUncoloredRanges(ranges, coloring: coloring)

			if uncoloredSpills.count() == 0 'allColored'
				break
			end 'allColored'

			logTrace(LogCategory.ir, message: function() gives "regalloc: func={state.funcName} iteration={iteration} uncolored={uncoloredSpills.count()}")

			// Pass 1: call-boundary splitting (trySplitAtCall in
			// CallBoundarySplitter.maxon). DEFERRED — the splitter is kept
			// in the codebase for later phases but is intentionally not
			// invoked here in Phase 1. Reasons:
			//   • When applied broadly (every uncolored range, every
			//     iteration), the existing splitter's "rewrite uses past
			//     the call until first redef" rule corrupts SSA: it
			//     remaps the redef's dest to L_post, giving L_post two
			//     defs, AND leaves downstream reads of range.valueId
			//     pointing at a stale value. Easy to trigger with
			//     closure-capture-style test programs.
			//   • Even with soundness patched, the splitter alone cannot
			//     reduce the *total* pressure that sha256-style bodies
			//     impose — Phase 3 (memory-operand folding) is the
			//     mechanism that does. Pass 1 here would just shuffle
			//     pressure around without lowering it.
			// A later phase reintroduces the splitter once the dialect
			// supports the right primitives and the rebuild handles the
			// SSA reconstruction cleanly.

			// Pass 2: spill (or rematerialize) every uncolored range.
			var spillDec = SpillDecision.create()
			// Track which parent merges we've already added so we don't push
			// duplicate spilledRanges entries when multiple sub-ranges of the
			// same merge are uncolored in the same iteration. RegIntArray
			// stores 0 (not added) or 1 (added) per valueId, sentinel 0.
			var addedMerges = RegIntArray.create()
			for ur in uncoloredSpills 'pass2'

				if ur.spillWeight == SPILL_WEIGHT_INFINITE 'cannotRespill'
					// Sub-ranges minted by the LiveRangeSplitter carry
					// SPILL_WEIGHT_INFINITE because their def and only use
					// coincide at a single copy slot — spilling the sub-range
					// alone would yield no pressure relief (the parallel-copy
					// at that slot still needs a register). The fix is LLVM
					// Greedy's "memory-only phi": demote the PARENT MERGE to
					// a stack slot. SpillCodeInsertion's existing block-arg
					// path handles this: it emits a spill store at the top
					// of the merge block (so the brief register-live moment
					// at parallel-copy lands the value into memory) and
					// reloads at every use. With multiple merges sharing the
					// same predecessor slot, each iteration spills one merge
					// and the next iteration finds the remaining ones
					// colorable.
					let parentMergeVid = lookupSubRangeParent(splitInfo, subRangeValueId: ur.valueId)
					if parentMergeVid >= 0 'isSubRange'
						let alreadyVal = getOr(addedMerges, index: parentMergeVid, fallback: 0)
						if alreadyVal == 0 'firstSeen'
							let parentRange = findRangeByVid(ranges, valueId: parentMergeVid)
							if parentRange.valueId == parentMergeVid 'foundParent'
								logTrace(LogCategory.ir, message: function() gives "regalloc: sub-range v{ur.valueId} uncolored → spilling parent merge v{parentMergeVid} in {state.funcName}")
								spillDec.spilledRanges.push(parentRange)
								set(addedMerges, index: parentMergeVid, value: 1, sentinel: 0)
							end 'foundParent'
						end 'firstSeen'
						continue
					end 'isSubRange'

					// A reload vreg that can't be colored is the genuine
					// "register pressure unresolvable" case. Future phases
					// (memory-operand folding, eviction, last-chance
					// recoloring) will rescue this; until then it's a hard
					// stop with the richest diagnostic we can produce.
					panicUnresolvableReload(ranges, ur: ur, funcName: state.funcName, iteration: iteration)
				end 'cannotRespill'

				// Rematerializable ranges (constants) "spill" by re-emitting
				// the constant at each use; no stack slot, no spilledRanges
				// entry. Route them to the remat sidetable and let
				// insertSpillCode rewrite each use as a fresh movRegImm.
				if ur.isRematerializable 'isRemat'
					logTrace(LogCategory.ir, message: function() gives "regalloc: rematerialize %{ur.valueId} const={ur.constantValue}")
					markRematerialize(spillDec, valueId: ur.valueId, value: ur.constantValue)
					continue
				end 'isRemat'

				logTrace(LogCategory.ir, message: function() gives "regalloc: spill %{ur.valueId} class={ur.regClass.name} weight={ur.spillWeight} crossesCall={ur.crossesCall}")
				spillDec.spilledRanges.push(ur)
			end 'pass2'

			if spillDec.spilledRanges.count() == 0 and spillDec.rematerializeIds.count() == 0 'nothingToSpill'
				// findUncoloredRanges reported uncolored ranges but Pass 2
				// found nothing to spill or rematerialize. The only way to
				// reach here is if every uncolored range hit the
				// SPILL_WEIGHT_INFINITE branch — which already panics. If
				// control flows here, an uncolored range slipped past
				// every arm; treat it as a compiler bug.
				panic("regalloc: spill loop stalled in {state.funcName} — {uncoloredSpills.count()} uncolored ranges but Pass 2 spilled nothing (iteration={iteration})")
			end 'nothingToSpill'

			allocateSpillSlots(spillDec)
			insertSpillCode(module, func: func, spillDecision: spillDec, regTarget: regTarget, desc: desc)

			// Union this iteration's reload bitmap into the cumulative set
			// before rebuilding ranges, so the new reload vregs get
			// SPILL_WEIGHT_INFINITE on the next pass.
			unionReloadIds(reloadIds, source: spillDec.reloadIds)
			// Same for rematerialize-minted vregs — the new minted ids
			// must keep their rematerializable property across rebuilds.
			unionReloadIds(rematerializeIds, source: spillDec.rematerializeIds)
			unionRematValues(rematerializeValueByValueId, source: spillDec.rematerializeValue, ids: spillDec.rematerializeIds)

			self.runLivenessAndRanges()
			self.runColoring()

			iteration = iteration + 1
		end 'spillColorLoop'

		logTrace(LogCategory.ir, message: function() gives "regalloc: func={state.funcName} colored={coloring.assignment.count()} iterations={iteration}")
	end 'runSpillColorLoop'

	export function run()
		// Phase 0: CFG analysis
		self.runCfgAnalysis()

		// Phases 1-3: liveness, live ranges, coalescing
		self.runLivenessAndRanges()

		// Phase 4-5: spill/color loop
		self.runColoring()
		self.runSpillColorLoop()

		// Phase 6: Apply coloring (virtual -> physical)
		applyColoring(module, func: func, coloring: coloring, ranges: ranges, regTarget: regTarget)

		// Phase 7: Destroy SSA (parallel copies at CFG edges)
		destroySSA(module, func: func, coloring: coloring, cfg: cfg, state: state, regTarget: regTarget, opQuery: opQuery)
	end 'run'
end 'FunctionRegAllocator'

// If `subRangeValueId` matches one of the anchor sub-ranges minted by the
// LiveRangeSplitter, return the parent merge's valueId. Otherwise -1.
// Used by the spill loop to translate "spill a sub-range" into "spill the
// parent merge" — the sub-range itself has no MIR presence (its def and
// only use coincide at the predecessor's parallel-copy slot), so spilling
// it alone would yield no pressure relief. Spilling the merge does (it
// makes the value live in memory at the merge block).
function lookupSubRangeParent(splitInfo SplitMergeInfoArray, subRangeValueId ValueId) returns ValueId
	for info in splitInfo 'eachMerge'
		for anchor in info.anchors 'eachAnchor'
			if anchor.subRangeValueId == subRangeValueId 'match'
				return info.mergeValueId
			end 'match'
		end 'eachAnchor'
	end 'eachMerge'
	return -1
end 'lookupSubRangeParent'

// Linear scan over `ranges` for the LiveRange with the given valueId.
// Returns a LiveRange whose valueId equals -1 (the sentinel "not found") if
// no match. Callers check `result.valueId == soughtValueId` before using.
function findRangeByVid(ranges LiveRangeArray, valueId ValueId) returns LiveRange
	for range in ranges 'each'
		if range.valueId == valueId 'match'
			return range
		end 'match'
	end 'each'
	return LiveRange.create(-1)
end 'findRangeByVid'

// Find live ranges that have no coloring assignment (RM_NONE).
// These need to be spilled because the coloring couldn't assign them a register.
function findUncoloredRanges(ranges LiveRangeArray, coloring ColoringResult) returns LiveRangeArray
	var uncolored = LiveRangeArray.create()
	for range in ranges 'check'
		// Skip fixed-reg pseudo ranges — they're pre-colored
		if range.fixedReg != RM_NONE 'skipFixed'
			continue
		end 'skipFixed'

		let vid = range.valueId
		let assigned = getOr(coloring.assignment, index: vid, fallback: RM_NONE)
		if assigned == RM_NONE 'unassigned'
			uncolored.push(range)
		end 'unassigned'
	end 'check'
	return uncolored
end 'findUncoloredRanges'

// Union the per-iteration rematerialize-value sidetable into the cumulative
// one. Only valueIds set in `ids` are copied — the constant value array can
// be sparse beyond those indices.
function unionRematValues(dest RegIntArray, source RegIntArray, ids BoolArray)
	let n = ids.count()
	while dest.count() < n 'grow'
		dest.push(0)
	end 'grow'
	var i = 0
	while i < n 'each'
		let bit = try ids.get(i) otherwise false
		if bit 'set'
			let v = getOr(source, index: i, fallback: 0)
			try dest.set(i, value: v) otherwise panic("invariant: unionRematValues.dest.set OOB i={i} count={dest.count()}")
		end 'set'
		i = i + 1
	end 'each'
end 'unionRematValues'

// Build a comma-separated list of every range that is colored at the same
// program point as `ur` — useful diagnostic context for the "cannot color
// reload" panic so an operator can see what's actually competing for the
// register at the failing point.
function describeLiveSet(ranges LiveRangeArray, ur LiveRange) returns String
	if ur.intervals.count() == 0 'noIv'
		return "(no intervals)"
	end 'noIv'
	let urIv = try ur.intervals.get(0) otherwise panic("invariant: count > 0 just checked")
	let urBlock = urIv.blockId
	let urPos = urIv.startPos
	var parts = StringArray.create()
	for cand in ranges 'each'
		if cand.valueId == ur.valueId 'self'
			continue
		end 'self'
		if cand.fixedReg != RM_NONE 'fixed'
			continue
		end 'fixed'
		for iv in cand.intervals 'eachIv'
			if iv.blockId == urBlock and iv.startPos <= urPos and urPos < iv.endPos 'hit'
				parts.push("v{cand.valueId}(w={cand.spillWeight}{rematSuffix(cand)})")
				break
			end 'hit'
		end 'eachIv'
	end 'each'
	if parts.count() == 0 'empty'
		return "(none)"
	end 'empty'
	return joinStrings(parts, sep: ", ")
end 'describeLiveSet'

function rematSuffix(range LiveRange) returns String
	if range.isRematerializable 'remat'
		return ",remat"
	end 'remat'
	return ""
end 'rematSuffix'

function joinStrings(parts StringArray, sep String) returns String
	var out = ""
	var first = true
	for p in parts 'each'
		if first 'isFirst'
			out = "{p}"
			first = false
		end 'isFirst' else 'rest'
			out = "{out}{sep}{p}"
		end 'rest'
	end 'each'
	return out
end 'joinStrings'

// Rich panic for the genuinely-unrecoverable Phase 6 failure mode: a reload
// vreg made it to Pass 2 with SPILL_WEIGHT_INFINITE, has no parent-merge to
// spill instead, AND every demand-reduction technique in the pipeline has
// already failed on it:
//   1. Memory-operand folding (Phase 3) — the using op was not fold-eligible.
//   2. Greedy eviction (Phase 4) — no neighbor was strictly-lower priority.
//   3. Last-chance recursive recoloring (Phase 6) — no chain of register
//      reassignments could free a slot of the right class.
// Reaching this point means the demand structurally exceeds the GPR pool at
// this program point: e.g. more concurrent fixed-reg constraints than the
// pool has registers, or a sequence of infinite-weight reloads that all
// require the same callee-saved subset. The panic names the value, the
// function, the block, the program position, and the set of colored values
// that overlap the failing point so the user knows what's actually
// competing for the register.
function panicUnresolvableReload(ranges LiveRangeArray, ur LiveRange, funcName String, iteration RegInt)
	var blockId = -1
	var startPos = -1
	var endPos = -1
	if ur.intervals.count() > 0 'hasIv'
		let iv = try ur.intervals.get(0) otherwise panic("invariant: count > 0 just checked")
		blockId = iv.blockId
		startPos = iv.startPos
		endPos = iv.endPos
	end 'hasIv'
	let liveSet = describeLiveSet(ranges, ur: ur)
	panic("regalloc: cannot allocate register for reload vreg v{ur.valueId} in function `{funcName}` (class={ur.regClass.name}, block={blockId}, position={startPos}..{endPos}, iteration={iteration}). Live at this point: {liveSet}. Even last-chance recoloring couldn't resolve this; demand structurally exceeds the GPR pool at this point (likely more concurrent fixed-reg constraints than the pool has registers, or an unavoidable cluster of call-crossing reloads that all require the same callee-saved subset). Reduce pressure at the source: split the function, decrease simultaneous live-across-call values, or restructure the inner loop body so fewer scalars are alive at the failure site.")
end 'panicUnresolvableReload'

// ============================================================
// Phase 7: SSA destruction
// ============================================================

// Result of checking whether a block has the condBr pattern.
//
// `inTerminator` is true when the condJump lives in `block.terminator` rather
// than `block.opRefs[condBrIdx]`. This happens after `eliminateFallthroughJumps`
// promotes a trailing condJump back into the terminator slot (the trailing
// unconditional jmp was a fall-through and got dropped). In that case the
// trampoline-rewrite path must update the terminator, not opRefs.
type CondBrInfo
	export var hasCondBr as bool
	export var condBrIdx as RegInt
	export var elseTarget as RegInt
	export var inTerminator as bool

	static function none() returns CondBrInfo
		return Self{hasCondBr: false, condBrIdx: -1, elseTarget: -1, inTerminator: false}
	end 'none'

	static function found(condBrIdx RegInt, elseTarget RegInt) returns CondBrInfo
		return Self{hasCondBr: true, condBrIdx: condBrIdx, elseTarget: elseTarget, inTerminator: false}
	end 'found'

	static function foundInTerminator(elseTarget RegInt) returns CondBrInfo
		return Self{hasCondBr: true, condBrIdx: -1, elseTarget: elseTarget, inTerminator: true}
	end 'foundInTerminator'
end 'CondBrInfo'

// Detect the condBr pattern in a block. Two layouts are possible:
//   1. `opRefs: [..., condJump]` + `terminator: jmp(thenTarget)`. The natural
//      shape produced by `lowerCondBr`.
//   2. `opRefs: [...]` + `terminator: condJump`. Produced when
//      `eliminateFallthroughJumps` drops the trailing jmp because the then
//      target was the next block in layout order, then promotes the trailing
//      condJump back into the terminator slot.
// `CondBrInfo.inTerminator` distinguishes the two so callers can rewrite the
// right slot when inserting a trampoline.
function detectCondBrPattern(module TargetModule, block IrBlock, regTarget RegAllocTarget, opQuery TargetOpQuery) returns CondBrInfo
	// Layout 1: condJump is the last op in opRefs.
	let opsCount = block.opRefs.count()
	if opsCount > 0 'hasOps'
		let lastIdx = opsCount - 1
		let lastOp = try block.opRefs.get(lastIdx) otherwise panic("invariant: opsCount > 0 just checked but opRefs.get(lastIdx) failed")

		if opQuery.terminatorIsConditionalBranch(module, packed: lastOp) 'isCondBr'
			let target = regTarget.getCondBrTarget(module, packed: lastOp)
			if target >= 0 'validTarget'
				return CondBrInfo.found(lastIdx, elseTarget: target)
			end 'validTarget'
		end 'isCondBr'
	end 'hasOps'

	// Layout 2: condJump was promoted into the terminator slot.
	if block.hasTerminatorOp() 'hasTerm'
		let termIdx = block.terminatorIndex()
		if opQuery.terminatorIsConditionalBranch(module, packed: termIdx) 'isCondBrTerm'
			let target = regTarget.getCondBrTarget(module, packed: termIdx)
			if target >= 0 'validTermTarget'
				return CondBrInfo.foundInTerminator(target)
			end 'validTermTarget'
		end 'isCondBrTerm'
	end 'hasTerm'

	return CondBrInfo.none()
end 'detectCondBrPattern'

// True iff the (fromId, toId) edge has at least one pending parallel-copy
// move. Used to detect when restoring an eliminated fall-through jmp is
// necessary so then-edge copies don't land before the condJump.
function edgeHasCopies(edgeCopies EdgeCopyMap, fromId BlockId, toId RegInt, numBlocks RegInt) returns bool
	if toId < 0 'invalid'
		return false
	end 'invalid'
	let edgeKey = fromId * numBlocks + toId
	let moves = try edgeCopies.get(edgeKey) otherwise return false
	return moves.count() > 0
end 'edgeHasCopies'

// Emit sequentialized copies for a single CFG edge, if any are needed.
function emitEdgeCopies(module TargetModule, edgeCopies EdgeCopyMap, fromId BlockId, toId RegInt, numBlocks RegInt, dstBlock IrBlock, state RegState, regTarget RegAllocTarget)
	if toId < 0 'invalid'
		return
	end 'invalid'

	let edgeKey = fromId * numBlocks + toId
	// EdgeCopyMap is sparse: edges with no copies (identity moves only) aren't inserted, so a missing key means no work to do.
	let moves = try edgeCopies.get(edgeKey) otherwise return

	if moves.count() > 0 'hasMoves'
		sequentializeParallelCopy(module, moves: moves, dstBlock: dstBlock, state: state, regTarget: regTarget)
	end 'hasMoves'
end 'emitEdgeCopies'

// For a conditional branch, return the target of the fall-through (then) edge
// — the entry in branchEdges that is NOT the elseTarget. Used by destroySSA
// to look up edge-copy moves regardless of whether the trailing jmp survived
// the fall-through-jump elimination pass. Conditional branches always have
// at least one non-else edge; missing one means the upstream lowering failed
// to record both edges, which is a compiler bug.
function pickThenTarget(block IrBlock, elseTarget BlockId) returns BlockId
	for edge in block.branchEdges 'each'
		if edge.targetBlockId != elseTarget 'isThen'
			return edge.targetBlockId
		end 'isThen'
	end 'each'
	panic("pickThenTarget: conditional branch block {block.id} has no then-edge (only else={elseTarget})")
end 'pickThenTarget'

// Handle else-edge copies for a condBr by creating a trampoline block if needed.
// Returns the updated nextBlockId.
//
// `inTerminator` controls where the rewritten condJump op-index is patched
// back: when true the condJump is `block.terminator`, otherwise it lives at
// `block.opRefs[condBrIdx]`. Both layouts arise post-`eliminateFallthroughJumps`
// (see `detectCondBrPattern`).
function emitElseEdgeCopies(module TargetModule, edgeCopies EdgeCopyMap, block IrBlock, condBrIdx RegInt, inTerminator bool, elseTarget RegInt, numBlocks RegInt, trampolineRefs BlockRefList, nextBlockId BlockId, state RegState, regTarget RegAllocTarget) returns BlockId
	if elseTarget < 0 'invalid'
		return nextBlockId
	end 'invalid'

	let edgeKey = block.id * numBlocks + elseTarget
	// EdgeCopyMap is sparse: edges with no copies aren't inserted, so a missing key means we don't need a trampoline.
	let moves = try edgeCopies.get(edgeKey) otherwise return nextBlockId

	if moves.count() == 0 'noMoves2'
		return nextBlockId
	end 'noMoves2'

	// Create trampoline block in the module's block storage
	let trampolineId = nextBlockId
	let trampIdx = module.blocks.count()
	var tramp = IrBlock.create(trampolineId, label: "__phi_trampoline_{block.id}_{elseTarget}")

	// Emit parallel copies into the trampoline
	sequentializeParallelCopy(module, moves: moves, dstBlock: tramp, state: state, regTarget: regTarget)

	// Set jmp to original else-target as the trampoline's terminator
	tramp.terminator = Terminator.opIndex(regTarget.createJmpOp(module, blockId: elseTarget))

	module.blocks.push(tramp)
	trampolineRefs.append(trampIdx)

	if inTerminator 'patchTerminator'
		// The condJump is in the terminator slot — after eliminateFallthroughJumps
		// dropped the trailing jmp and promoted the condJump back. Patch the
		// terminator index in place.
		let condPacked = block.terminatorIndex()
		let rewritten = regTarget.rewriteCondBrTarget(module, packed: condPacked, newTarget: trampolineId)
		block.terminator = Terminator.opIndex(rewritten)
	end 'patchTerminator' else 'patchOpRefs'
		// Rewrite the condJump in block.opRefs to target the trampoline.
		// condBrIdx came from detectCondBrPattern (lastIdx of a non-empty opRefs), so it's a valid index.
		let condPacked = try block.opRefs.get(condBrIdx) otherwise panic("invariant: condBrIdx is the lastIdx of a non-empty opRefs but get failed")
		let rewritten = regTarget.rewriteCondBrTarget(module, packed: condPacked, newTarget: trampolineId)
		try block.opRefs.remove(condBrIdx) otherwise panic("invariant: condBrIdx is valid but remove failed")
		try block.opRefs.insert(condBrIdx, value: rewritten) otherwise panic("invariant: insert at condBrIdx (== new count after remove) must succeed")
	end 'patchOpRefs'
	return trampolineId + 1
end 'emitElseEdgeCopies'

// Replace SSA block arguments with explicit register moves at CFG edges.
// After applyColoring, every value has a physical register, but block arguments
// still exist as metadata. This function inserts parallel-copy moves at each
// CFG edge so that values land in the correct physical registers, then strips
// all block arguments from the function.
//
// For unconditional jumps, copies are inserted into the predecessor block
// before the terminator. For conditional branches (condJump in block.opRefs +
// jmp terminator), then-edge copies go after the condJump (fallthrough path)
// and else-edge copies go into a trampoline block that the condJump is
// rewritten to target.
function destroySSA(module TargetModule, func IrFunction, coloring ColoringResult, cfg CfgInfo, state RegState, regTarget RegAllocTarget, opQuery TargetOpQuery)
	let numBlocks = cfg.numBlocks
	let edgeCopies = buildBlockArgCopies(module, func: func, coloring: coloring, cfg: cfg)

	// Collect trampoline block refs to append after processing
	var trampolineRefs = BlockRefList.create()
	var nextBlockId = func.nextBlockId

	for blockRef in func.blockRefs 'eachBlock'
		var block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")

		// Skip blocks with no outgoing CFG edges (e.g. ret blocks).
		if block.branchEdges.count() == 0 'noEdges'
			continue
		end 'noEdges'

		// Branches with two outgoing edges are conditional. We need to detect
		// the condJump op to figure out which edge is the then-target (fallthrough)
		// and which is the else-target (branch taken). The condJump may live
		// either in opRefs (when the terminator is the trailing jmp) or as the
		// terminator itself; either way, detectCondBrPattern locates it. For
		// fall-through blocks whose trailing jmp was eliminated by
		// eliminateFallthroughJumps, the terminator may be a non-branch op —
		// the branchEdges array still records the outgoing edge regardless.
		let condBrInfo = detectCondBrPattern(module, block: block, regTarget: regTarget, opQuery: opQuery)

		if condBrInfo.hasCondBr 'condBrCase'
			// Conditional branch pattern:
			//   block.opRefs: [..., condJump(cond, elseTarget)]
			//   block.terminator: cf/mir condBr or x64 jmp(thenTarget)
			let elseTarget = condBrInfo.elseTarget
			var condBrIdx = condBrInfo.condBrIdx
			var inTerminator = condBrInfo.inTerminator
			let thenTarget = pickThenTarget(block, elseTarget: elseTarget)

			// If eliminateFallthroughJumps stripped the trailing jmp and the
			// then-edge has pending copies, restore the canonical layout
			// (condJump in opRefs, jmp $thenTarget as terminator) before
			// appending copies. Without this, then-edge copies would land
			// between the cmp and the condJump in the printed sequence, so
			// they'd execute unconditionally instead of only on the
			// not-taken / fallthrough path — corrupting the back-edge state.
			if inTerminator and edgeHasCopies(edgeCopies, fromId: block.id, toId: thenTarget, numBlocks: numBlocks) 'restoreLayout'
				let condPacked = block.terminatorIndex()
				block.opRefs.append(condPacked)
				condBrIdx = block.opRefs.count() - 1
				block.terminator = Terminator.opIndex(regTarget.createJmpOp(module, blockId: thenTarget))
				inTerminator = false
			end 'restoreLayout'

			// Then-edge copies: execute on fallthrough (condJump not taken).
			// Appended to block.opRefs after the condJump, before the jmp terminator.
			emitEdgeCopies(module, edgeCopies: edgeCopies, fromId: block.id, toId: thenTarget, numBlocks: numBlocks, dstBlock: block, state: state, regTarget: regTarget)

			// Else-edge copies: execute when condJump IS taken.
			// Since condJump branches directly to elseTarget, we need a trampoline
			// block to insert the copies between the condJump and the else-target.
			nextBlockId = emitElseEdgeCopies(module, edgeCopies: edgeCopies, block: block, condBrIdx: condBrIdx, inTerminator: inTerminator, elseTarget: elseTarget, numBlocks: numBlocks, trampolineRefs: trampolineRefs, nextBlockId: nextBlockId, state: state, regTarget: regTarget)
		end 'condBrCase' else 'plainJmp'
			// Single successor (unconditional jump or fall-through). All copies
			// go into this block before whatever terminator (or none) it has.
			let firstEdge = try block.branchEdges.get(0) otherwise panic("invariant: branchEdges.count() > 0 just checked but get(0) failed")
			emitEdgeCopies(module, edgeCopies: edgeCopies, fromId: block.id, toId: firstEdge.targetBlockId, numBlocks: numBlocks, dstBlock: block, state: state, regTarget: regTarget)
		end 'plainJmp'

	end 'eachBlock'

	// Append trampoline blocks to the function
	for trampRef in trampolineRefs 'addTrampolines'
		func.blockRefs.append(trampRef)
	end 'addTrampolines'

	func.nextBlockId = nextBlockId

	// Remove block args and convert CF/MIR branch terminators to target jmp.
	var blockIdx = 0
	while blockIdx < func.blockRefs.count() 'removeArgs'
		let bRef = try func.blockRefs.get(blockIdx) otherwise 'skipRemove'
			blockIdx = blockIdx + 1
			continue
		end 'skipRemove'
		var block = try module.blocks.get(bRef) otherwise 'skipRemove2'
			blockIdx = blockIdx + 1
			continue
		end 'skipRemove2'
		block.blockArgs = IrBlockArgArray.create()
		block.branchEdges = BranchEdgeArray.create()
		// Terminators were already lowered to x64 jmp / arm64 branch by
		// lowerMirToTarget. Nothing more to do here.

		blockIdx = blockIdx + 1
	end 'removeArgs'

	// Preserve spill size set by insertSpillCode (0 if no spills were needed).
end 'destroySSA'

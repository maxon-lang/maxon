// Interface for target-specific backend operations.
//
// Implemented by X64Backend and Arm64Backend. Each backend is created once
// with all the data it needs (MirModule, Target, GlobalDataTable,
// stdlibFunctions) and then passed around — callers never re-dispatch.
//
// The single dispatch point that selects which implementation to construct
// lives in BackendDispatch.maxon (emitBackend / buildAndWriteStdlibCache).

export interface TargetBackend

	// Lower MIR ops to target-specific dialect (X64Op / Arm64Op).
	// The result is stored on the backend for use by subsequent methods.
	function lowerMirToTarget() returns TargetModule

	// Emit machine code bytes from the fully-lowered target module.
	function emitTargetCode(stdlibCache StdlibCacheData) returns CodeResult

	// Insert prologue/epilogue for a single function given the computed stack size.
	function insertPrologueEpilogue(func IrFunction, stackSize StackSize)

	// Scan a single target op for frame-relevant information (stack slots, prints, calls).
	function scanOpForFrameInfo(packed OpIndex, state FrameScanState)

	// Emit per-function object code for stdlib caching.
	function emitPerFunction() returns ObjectFunctionArray

end 'TargetBackend'

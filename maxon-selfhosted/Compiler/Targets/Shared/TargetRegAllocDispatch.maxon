// Target dispatch for register allocation.
// This is the ONLY file that knows which targets exist.
// Adding a new target: add an enum variant to RegTarget and add match arms below.

export union RegTarget
	x64
	arm64
end 'RegTarget'

// --- State creation dispatch ---

export function targetCreateRegState(target Target) returns RegState
	return match target.cpu 'dispatch'
		x64 gives createX64RegState()
		arm64 gives createArm64RegState()
		default panic("register allocation not used for WASM targets")
	end 'dispatch'
end 'targetCreateRegState'

// --- GPR emission dispatch ---

export function targetEmitSpill(module MlirModule, state RegState, dstBlock MlirBlock, regOrdinal RegOrdinal, stackOffset RegInt)
	match state.target 'dispatch'
		x64 then emitSpillX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
		arm64 then emitSpillArm64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
	end 'dispatch'
end 'targetEmitSpill'

export function targetEmitReload(module MlirModule, state RegState, dstBlock MlirBlock, regOrdinal RegOrdinal, stackOffset RegInt)
	match state.target 'dispatch'
		x64 then emitReloadX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
		arm64 then emitReloadArm64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, stackOffset: stackOffset)
	end 'dispatch'
end 'targetEmitReload'

export function targetEmitMovImm(module MlirModule, state RegState, dstBlock MlirBlock, regOrdinal RegOrdinal, value RegInt)
	match state.target 'dispatch'
		x64 then emitMovImmX64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, value: value)
		arm64 then emitMovImmArm64(module, dstBlock: dstBlock, regOrdinal: regOrdinal, value: value)
	end 'dispatch'
end 'targetEmitMovImm'

export function targetEmitMovReg(module MlirModule, state RegState, dstBlock MlirBlock, destOrd RegOrdinal, srcOrd RegOrdinal)
	match state.target 'dispatch'
		x64 then emitMovRegX64(module, dstBlock: dstBlock, destOrd: destOrd, srcOrd: srcOrd)
		arm64 then emitMovRegArm64(module, dstBlock: dstBlock, destOrd: destOrd, srcOrd: srcOrd)
	end 'dispatch'
end 'targetEmitMovReg'


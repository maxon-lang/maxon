// --- Cross-class transfer dispatch (GPR to FP) ---

export function targetEmitGprToFp(module MlirModule, state RegState, dstBlock MlirBlock, fpOrdinal RegOrdinal, gprOrdinal RegOrdinal)
	match state.target 'dispatch'
		x64 then emitGprToFpX64(module, dstBlock: dstBlock, fpOrdinal: fpOrdinal, gprOrdinal: gprOrdinal)
		arm64 then emitGprToFpArm64(module, dstBlock: dstBlock, fpOrdinal: fpOrdinal, gprOrdinal: gprOrdinal)

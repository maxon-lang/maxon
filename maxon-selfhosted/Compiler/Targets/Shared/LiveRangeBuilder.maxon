// Live range construction and spill weight computation.
// Builds LiveRange objects for every virtual register using liveness information.

export typealias LiveRangeArray = Array with LiveRange
export typealias IntervalArray = Array with Interval
export typealias CopyEdgeArray = Array with CopyEdge

let LR_NO_DEF = i64.max

// Sentinel weight assigned to ranges whose vreg is a reload destination
// (def→use copy of a spilled value, minted by SpillCodeInsertion's
// freshValueId). The spill picker treats this as an unspillable marker:
// if such a range fails to color, the allocator panics with a clear
// "pressure unresolvable" message instead of silently chain-respilling.
// Matches LLVM Greedy's "infinite spill weight on reload ranges" and the
// "single-use bundle has minimum weight, can't be evicted" invariant in
// Cranelift regalloc2 — both guarantee spill-loop termination.
export let SPILL_WEIGHT_INFINITE = i64.max

export union RegClass
	gpr
	fp
end 'RegClass'

export union CallConvSlot
	gpr(ord RegInt)
	spilled
end 'CallConvSlot'

export type Interval
	export var blockId as BlockId
	export var startPos as RegInt
	export var endPos as RegInt

	export static function create(blockId BlockId, startPos RegInt, endPos RegInt) returns Interval
		return Self{blockId: blockId, startPos: startPos, endPos: endPos}
	end 'create'
end 'Interval'

// CopyEdge anchors a copy site between two live ranges (partner ↔ self).
// `blockId` is the block in which the copy executes; `copyPos` is the
// position within that block where the move lives. For 2-address ops and
// movRegReg the copy is at the op's own position. For block-arg parallel
// copies the copy lives in the PREDECESSOR block at `predBlockLen - 1`
// (the slot right before the terminator). Multiple edges are recorded
// when a range participates in multiple distinct copy sites (e.g. a
// block-arg dest receives one edge per predecessor).
export type CopyEdge
	export var partnerValueId as ValueId
	export var blockId as BlockId
	export var copyPos as RegInt

	export static function create(partnerValueId ValueId, blockId BlockId, copyPos RegInt) returns CopyEdge
		return Self{partnerValueId: partnerValueId, blockId: blockId, copyPos: copyPos}
	end 'create'
end 'CopyEdge'

// Records a single (predecessor, sub-range) anchor produced by phi-merge
// splitting. When a multi-anchor phi-merge is split, each predecessor copy
// slot becomes its own LiveRange with a fresh valueId; that fresh id is
// stored here paired with the predecessor block id. Consumed by
// buildBlockArgCopies to dual-emit edge moves (src → sub → merge) instead
// of the original single src → merge move.
export type SplitPredAnchor
	export var predBlockId as BlockId
	export var subRangeValueId as ValueId

	export static function create(predBlockId BlockId, subRangeValueId ValueId) returns SplitPredAnchor
		return Self{predBlockId: predBlockId, subRangeValueId: subRangeValueId}
	end 'create'
end 'SplitPredAnchor'

export typealias SplitPredAnchorArray = Array with SplitPredAnchor

// One per phi-merge that the splitter rewrote into per-anchor sub-ranges.
// `mergeValueId` is the merge's original valueId (R_main) — block-args still
// reference it, so MIR ops are unchanged. `anchors` lists the sub-ranges
// minted for each predecessor copy slot.
export type SplitMergeInfo
	export var mergeValueId as ValueId
	export var anchors as SplitPredAnchorArray

	export static function create(mergeValueId ValueId) returns SplitMergeInfo
		return Self{mergeValueId: mergeValueId, anchors: SplitPredAnchorArray.create()}
	end 'create'
end 'SplitMergeInfo'

export typealias SplitMergeInfoArray = Array with SplitMergeInfo

export type LiveRange
	export var valueId as ValueId
	export var defBlock as BlockId
	export var defPosition as RegInt
	export var intervals as IntervalArray
	export var spillWeight as RegInt
	export var regClass as RegClass
	export var fixedReg as RegOrdinal
	export var assignedReg as RegOrdinal
	export var spillSlot as RegInt
	export var isRematerializable as bool
	export var constantValue as RegInt
	export var hint as RegOrdinal
	export var copyHintValueId as RegInt
	// Per-edge copy-link sidetable. Lets the interference graph builder
	// suppress the 1-position copy-boundary overlap only at the EXACT
	// (block, position) where a parallel copy or 2-addr move executes.
	// Replaces the suppression role of `copyHintValueId`, which was a
	// single-slot last-writer-wins link and over-coalesced block-arg
	// destinations against values still live through other predecessors.
	// `copyHintValueId` remains for color-hint propagation only.
	export var copyEdges as CopyEdgeArray
	// True when this range is live across a call instruction. Drives the
	// caller-saved-vs-callee-saved decision in the coloring fallback: ranges
	// that don't cross a call should land in caller-saved registers (no
	// callee-save area cost), while ranges that do should land in callee-saved
	// registers to avoid spill-around-call sequences.
	export var crossesCall as bool

	export static function create(valueId ValueId) returns LiveRange
		return Self{
			valueId: valueId,
			defBlock: 0,
			defPosition: 0,
			intervals: IntervalArray.create(),
			spillWeight: 0,
			regClass: RegClass.gpr,
			fixedReg: RM_NONE,
			assignedReg: RM_NONE,
			spillSlot: RM_NO_STACK_HOME,
			isRematerializable: false,
			constantValue: 0,
			hint: RM_NONE,
			copyHintValueId: -1,
			copyEdges: CopyEdgeArray.create(),
			crossesCall: false
		}
	end 'create'
end 'LiveRange'

// Record a copy edge from `range` to `partner` at (blockId, copyPos).
// Linear-time dedup against an existing identical entry so multiple
// callers that anchor the same edge don't bloat the list.
export function addCopyEdge(range LiveRange, partner ValueId, blockId BlockId, copyPos RegInt)
	if partner < 0 'invalid'
		return
	end 'invalid'
	for existing in range.copyEdges 'dedup'
		if existing.partnerValueId == partner and existing.blockId == blockId and existing.copyPos == copyPos 'match'
			return
		end 'match'
	end 'dedup'
	range.copyEdges.push(CopyEdge.create(partner, blockId: blockId, copyPos: copyPos))
end 'addCopyEdge'

// True if `range` carries a copy edge to `partner` anchored at exactly
// (blockId, copyPos). Linear scan; per-range edge lists are small
// (typically 1-3 entries even for multi-pred block args).
export function hasCopyEdgeAt(range LiveRange, partner ValueId, blockId BlockId, copyPos RegInt) returns bool
	for edge in range.copyEdges 'scan'
		if edge.partnerValueId == partner and edge.blockId == blockId and edge.copyPos == copyPos 'match'
			return true
		end 'match'
	end 'scan'
	return false
end 'hasCopyEdgeAt'

// ============================================================
// Public entry point
// ============================================================

export function buildLiveRanges(module TargetModule, func IrFunction, cfg CfgInfo, liveness LivenessInfo, loopDepth RegIntArray, regTarget RegAllocTarget, opQuery TargetOpQuery, reloadIds BoolArray) returns LiveRangeArray
	let maxVal = liveness.maxValueId

	// Phase 1: Build definition map — defBlockId[valueId] and defPos[valueId]
	var defBlockId = RegIntArray.create()
	var defPos = RegIntArray.create()
	var defRegClass = RegIntArray.create()
	var isConst = BoolArray.create()
	var constVal = RegIntArray.create()

	initDefArrays(defBlockId, defPos: defPos, defRegClass: defRegClass, isConst: isConst, constVal: constVal, size: maxVal)
	scanDefinitions(module, func: func, defBlockId: defBlockId, defPos: defPos, defRegClass: defRegClass, isConst: isConst, constVal: constVal, regTarget: regTarget, opQuery: opQuery)

	// Phase 2: Build last-use-in-block map for interval end points
	let lastUseInBlock = buildRegIntArray(module, func: func, maxVal: maxVal, regTarget: regTarget)

	// Phase 2b: For each block, collect the op positions of every call.
	// Used by Phase 3 to flag ranges whose interval crosses a call so the
	// coloring fallback can prefer callee-saved registers for them.
	let callPositionsPerBlock = buildCallPositionsPerBlock(module, func: func, opQuery: opQuery)

	// Phase 3: Build live ranges for each value
	var ranges = LiveRangeArray.create()

	var vid = 0
	while vid < maxVal 'eachValue'
		let defBid = getOr(defBlockId, index: vid, fallback: -1)

		if defBid < 0 'noDef'
			// Value has no definition — skip (physical register or unused)
			vid = vid + 1
			continue
		end 'noDef'

		var range = LiveRange.create(vid)
		range.defBlock = defBid
		range.defPosition = getOr(defPos, index: vid, fallback: 0)

		// Register class
		let rcVal = getOr(defRegClass, index: vid, fallback: 0)
		if rcVal == 1 'isFp'
			range.regClass = RegClass.fp
		end 'isFp'

		// Rematerialization
		// Sentinel: isConst is lazily populated; absent entries default to false ("not a constant").
		let isConstVal = try isConst.get(vid) otherwise false
		if isConstVal 'isConst'
			range.isRematerializable = true
			range.constantValue = getOr(constVal, index: vid, fallback: 0)
		end 'isConst'

		// Build intervals from liveness
		buildIntervalsForValue(module, range: range, liveness: liveness, defBid: defBid, func: func, lastUseInBlock: lastUseInBlock, maxVal: maxVal)

		// Mark whether the range survives across any call
		range.crossesCall = intervalsCrossCall(range.intervals, callPositionsPerBlock: callPositionsPerBlock)

		// Compute spill weight. Reload destinations get a sentinel
		// infinite weight so the spill picker refuses to spill them.
		let isReload = try reloadIds.get(vid) otherwise false
		if isReload 'reloadInfWeight'
			range.spillWeight = SPILL_WEIGHT_INFINITE
		end 'reloadInfWeight' else 'normalWeight'
			range.spillWeight = computeSpillWeight(range, loopDepth: loopDepth)
		end 'normalWeight'

		ranges.push(range)
		vid = vid + 1
	end 'eachValue'

	// Step 6: Add a 1-position tail interval on every block-arg destination
	// inside each of its predecessor blocks. The parallel-copy that materializes
	// the block-arg lives at predBlockLen - 1 in the predecessor, so the
	// destination value is "born" at that slot — without this interval, the
	// interference graph would miss conflicts between the block-arg dest and
	// values that die at the predecessor's terminator. Pairs with the matching
	// suppression in isCopyBoundaryOverlap, which uses `copyEdges` to ignore
	// the legitimate copy-boundary touch at exactly (predId, predBlockLen - 1).
	addBlockArgEdgeIntervals(module, func: func, cfg: cfg, ranges: ranges)

	logDebug(LogCategory.ir, message: function() gives "liverange: func={func.name} ranges={ranges.count()} vregs={maxVal}")
	return ranges
end 'buildLiveRanges'

// For each block B and each blockArg in B, push a [copyPos, copyPos+1)
// interval into the arg's LiveRange anchored to every predecessor of B.
// copyPos is `predBlockLen - 1` — the slot just before the predecessor's
// terminator, which is where lowerMirToTarget materializes the parallel
// copies that bind block args. Dedup is per (blockId, startPos) on the
// destination's intervals list; multiple predecessors with the same id
// can't exist (CFG edge add is set-like), so a (predId, copyPos) probe is
// sufficient.
function addBlockArgEdgeIntervals(module TargetModule, func IrFunction, cfg CfgInfo, ranges LiveRangeArray)
	// Build valueId -> ranges index for O(1) blockArg lookup. ranges are
	// appended only when defBlockId[vid] >= 0, so the array is not vid-
	// indexed; instead we materialize a sparse map keyed by valueId.
	var maxValueId = 0
	for range in ranges 'findMax'
		if range.valueId >= maxValueId 'higher'
			maxValueId = range.valueId + 1
		end 'higher'
	end 'findMax'

	var vidToRange = RegIntArray.create()
	var initIdx = 0
	while initIdx < maxValueId 'init'
		vidToRange.push(-1)
		initIdx = initIdx + 1
	end 'init'

	var ri = 0
	let rangeCount = ranges.count()
	while ri < rangeCount 'index'
		let range = try ranges.get(ri) otherwise panic("addBlockArgEdgeIntervals.index: ri < rangeCount but get({ri}) failed")
		if range.valueId < maxValueId 'inBounds'
			try vidToRange.set(range.valueId, value: ri) otherwise panic("invariant: vidToRange.set OOB")
		end 'inBounds'
		ri = ri + 1
	end 'index'

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		if block.blockArgs.count() == 0 'noArgs'
			continue
		end 'noArgs'

		let preds = try cfg.predecessors.get(block.id) otherwise 'noPreds'
			// Entry block (or unreachable): no predecessors, no edge copies
			// to model. Block args of the entry block are bound to function
			// parameters via the calling convention, not via a parallel copy.
			continue
		end 'noPreds'

		for blockArg in block.blockArgs 'eachArg'
			let vid = blockArg.valueId
			if vid >= maxValueId 'outOfRange'
				// blockArg references a value with no live range entry — can
				// happen if the value was DCE'd from `ranges` but the block
				// arg slot survives. Nothing to attach an interval to.
				continue
			end 'outOfRange'
			let rangeIdx = try vidToRange.get(vid) otherwise panic("addBlockArgEdgeIntervals.eachArg: vid < maxValueId but vidToRange.get({vid}) failed")
			if rangeIdx < 0 'noRange'
				continue
			end 'noRange'
			var range = try ranges.get(rangeIdx) otherwise panic("addBlockArgEdgeIntervals.eachArg: rangeIdx populated from ranges scan but get({rangeIdx}) failed")

			for predId in preds 'eachPred'
				let predBlock = findBlockById(module, func: func, blockId: predId)
				let predBlockLen = predBlock.opRefs.count() + 1
				let copyPos = predBlockLen - 1

				// Dedup: skip if an interval anchored to this predecessor at
				// copyPos already exists. addBlockArgEdgeIntervals can be
				// called repeatedly across spill iterations.
				if intervalsContain(range.intervals, blockId: predId, startPos: copyPos) 'alreadyHave'
					continue
				end 'alreadyHave'

				range.intervals.push(Interval.create(predId, startPos: copyPos, endPos: predBlockLen))
			end 'eachPred'
		end 'eachArg'
	end 'eachBlock'
end 'addBlockArgEdgeIntervals'

// Linear scan over `func.blockRefs` to map a raw BlockId back to its IrBlock.
// Block lists are small (typically <100 even in large functions) so we avoid
// carrying an extra sidetable up the call chain.
export function findBlockById(module TargetModule, func IrFunction, blockId BlockId) returns IrBlock
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		if block.id == blockId 'match'
			return block
		end 'match'
	end 'eachBlock'
	panic("findBlockById: blockId {blockId} not found in func.blockRefs")
end 'findBlockById'

// True if `intervals` already contains an entry with the given anchor.
// Per-range interval lists are small (one per live block); a linear scan
// keeps the dedup honest without growing the LiveRange type.
function intervalsContain(intervals IntervalArray, blockId BlockId, startPos RegInt) returns bool
	for existing in intervals 'each'
		if existing.blockId == blockId and existing.startPos == startPos 'match'
			return true
		end 'match'
	end 'each'
	return false
end 'intervalsContain'

// ============================================================
// Call-position scanning (for crossesCall analysis)
// ============================================================

// Build a parallel-array map: blockId -> sorted list of op positions where
// a call instruction lives. The position scheme matches buildIntervalsForValue
// (1-indexed; opIdx + 1). Blocks with no calls get an empty list. The result
// is keyed by raw blockId, so the array length is maxBlockId + 1.
function buildCallPositionsPerBlock(module TargetModule, func IrFunction, opQuery TargetOpQuery) returns RegIntArrayArray
	var maxBlockId = 0
	for blockRef in func.blockRefs 'findMax'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		if block.id > maxBlockId 'higher'
			maxBlockId = block.id
		end 'higher'
	end 'findMax'

	var perBlock = RegIntArrayArray.create()
	var i = 0
	while i <= maxBlockId 'init'
		perBlock.push(RegIntArray.create())
		i = i + 1
	end 'init'

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		var bucket = try perBlock.get(block.id) otherwise panic("invariant: perBlock sized to maxBlockId+1 but get({block.id}) failed")
		var opIdx = 0
		for packed in block.opRefs 'eachOp'
			if isCallOpWith(module, packed: packed, opQuery: opQuery) 'isCall'
				bucket.push(opIdx + 1)
			end 'isCall'
			opIdx = opIdx + 1
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			if isCallOpWith(module, packed: block.terminatorIndex(), opQuery: opQuery) 'isCallTerm'
				bucket.push(opIdx + 1)
			end 'isCallTerm'
		end 'hasTerm'
	end 'eachBlock'

	return perBlock
end 'buildCallPositionsPerBlock'

// Returns true if any of the range's intervals contains a call position.
// An interval is half-open [startPos, endPos): a call at position P crosses
// the range when startPos < P < endPos. (P == startPos means the call IS the
// def site — the value doesn't exist yet. P == endPos - 1 is the last use,
// so the value dies at the call and doesn't need to survive it.)
// Call positions per block are sorted (built in opIdx order), so we use
// binary search to find the first candidate call position >= startPos+1.
function intervalsCrossCall(intervals IntervalArray, callPositionsPerBlock RegIntArrayArray) returns bool
	for interval in intervals 'eachInt'
		// callPositionsPerBlock is sized to maxBlockId+1 (built via buildCallPositionsPerBlock).
		let bucket = try callPositionsPerBlock.get(interval.blockId) otherwise panic("invariant: callPositionsPerBlock get({interval.blockId}) failed")
		let lo = interval.startPos + 1
		let hi = interval.endPos - 1
		if lo >= hi 'tooShort'
			continue
		end 'tooShort'
		// Binary search for first call position >= lo
		let count = bucket.count()
		var left = 0
		var right = count
		while left < right 'bsearch'
			let mid = left + (right - left) / 2
			let midVal = try bucket.get(mid) otherwise panic("intervalsCrossCall.bsearch: mid < count = bucket.count() but get({mid}) failed")
			if midVal < lo 'goRight'
				left = mid + 1
			end 'goRight' else 'goLeft'
				right = mid
			end 'goLeft'
		end 'bsearch'
		// left is now the index of the first call position >= lo
		if left < count 'checkHit'
			let callPos = try bucket.get(left) otherwise panic("intervalsCrossCall.checkHit: left < count = bucket.count() just checked but get({left}) failed")
			if callPos < hi 'crosses'
				return true
			end 'crosses'
		end 'checkHit'
	end 'eachInt'
	return false
end 'intervalsCrossCall'

function isCallOpWith(module TargetModule, packed OpIndex, opQuery TargetOpQuery) returns bool
	return opQuery.isCallOp(module, packed: packed)
end 'isCallOpWith'

// ============================================================
// Phase 1: Scan definitions
// ============================================================

function initDefArrays(defBlockId RegIntArray, defPos RegIntArray, defRegClass RegIntArray, isConst BoolArray, constVal RegIntArray, size RegInt)
	var i = 0
	while i < size 'init'
		defBlockId.push(-1)
		defPos.push(0)
		defRegClass.push(0)
		isConst.push(false)
		constVal.push(0)
		i = i + 1
	end 'init'
end 'initDefArrays'

function scanDefinitions(module TargetModule, func IrFunction, defBlockId RegIntArray, defPos RegIntArray, defRegClass RegIntArray, isConst BoolArray, constVal RegIntArray, regTarget RegAllocTarget, opQuery TargetOpQuery)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		let blockId = block.id

		// Block arguments are definitions at position 0
		for blockArg in block.blockArgs 'eachArg'
			let vid = blockArg.valueId
			if vid < defBlockId.count() 'inBounds'
				try defBlockId.set(vid, value: blockId) otherwise panic("invariant: defBlockId.set OOB")
				try defPos.set(vid, value: 0) otherwise panic("invariant: defPos.set OOB")

				if stdTypeIsFloat(blockArg.argType) 'isFpArg'
					try defRegClass.set(vid, value: 1) otherwise panic("invariant: defRegClass.set OOB")
				end 'isFpArg'
			end 'inBounds'
		end 'eachArg'

		// Scan ops to find definitions
		var opIdx = 0
		for packed in block.opRefs 'eachOp'
			scanOpDefPacked(module, packed: packed, blockId: blockId, opIdx: opIdx + 1, defBlockId: defBlockId, defPos: defPos, defRegClass: defRegClass, isConst: isConst, constVal: constVal, regTarget: regTarget, opQuery: opQuery)
			opIdx = opIdx + 1
		end 'eachOp'

		// Terminator
		if block.hasTerminatorOp() 'hasTerm'
			scanOpDefPacked(module, packed: block.terminatorIndex(), blockId: blockId, opIdx: opIdx + 1, defBlockId: defBlockId, defPos: defPos, defRegClass: defRegClass, isConst: isConst, constVal: constVal, regTarget: regTarget, opQuery: opQuery)
		end 'hasTerm'
	end 'eachBlock'
end 'scanDefinitions'

function scanOpDefPacked(module TargetModule, packed OpIndex, blockId BlockId, opIdx RegInt, defBlockId RegIntArray, defPos RegIntArray, defRegClass RegIntArray, isConst BoolArray, constVal RegIntArray, regTarget RegAllocTarget, opQuery TargetOpQuery)
	// Use noteOpDefs to find which valueIds this op defines
	var defs = RegIntArray.create()
	regTarget.noteOpDefs(module, defBlocks: defs, blockIdx: 1, packed: packed)

	var di = 0
	while di < defs.count() 'eachDef'
		let defBlock = try defs.get(di) otherwise panic("scanOpDefPacked.eachDef: di < defs.count() by loop guard but get({di}) failed")
		if defBlock == 1 and di < defBlockId.count() 'isDef'
			// Only record the FIRST definition of a value in a block.
			// TwoAddr ops (e.g., addRegReg) both read and write the dest register,
			// creating a second "def" after the initial movRegReg def. The interval
			// must start at the first def to correctly cover the full lifetime.
			let existingDef = getOr(defBlockId, index: di, fallback: -1)
			if existingDef != blockId 'firstDef'
				try defBlockId.set(di, value: blockId) otherwise panic("invariant: defBlockId.set OOB")
				try defPos.set(di, value: opIdx) otherwise panic("invariant: defPos.set OOB")
			end 'firstDef'

			// Determine register class from op pattern
			let rc = getOpDefRegClassWith(module, packed: packed, opQuery: opQuery)
			try defRegClass.set(di, value: rc) otherwise panic("invariant: defRegClass.set OOB")

			// Detect constants for rematerialization
			detectConstantWith(module, packed: packed, valueId: di, isConst: isConst, constVal: constVal, opQuery: opQuery)
		end 'isDef'
		di = di + 1
	end 'eachDef'
end 'scanOpDefPacked'

// Returns 1 for FP, 0 for GPR based on the op's pattern.
// Shared across targets because OpPattern is target-independent.
function getOpDefRegClassWith(module TargetModule, packed OpIndex, opQuery TargetOpQuery) returns RegInt
	let patOrd = opQuery.getOpPatternOrdinal(module, packed: packed)
	let pat = try OpPattern.fromRawValue(patOrd) otherwise OpPattern.passThrough
	return defRegClassForPattern(pat)
end 'getOpDefRegClassWith'

function defRegClassForPattern(pat OpPattern) returns RegInt
	return match pat 'check'
		fpSingleDef gives 1
		fpDefUse gives 1
		fpTwoAddr gives 1
		fpThreeAddr gives 1
		fpMov gives 1
		gprToFp gives 1
		baseUseFpDef gives 1
		passThrough to baseUseDest gives 0
		fpSingleUse gives 0
		fpTwoUse gives 0
		fpToGpr gives 0
		baseUseFpUse gives 0
		movRegReg to csel gives 0
	end 'check'
end 'defRegClassForPattern'

// Detect if op is a constant load (movRegImm / movImm)
function detectConstantWith(module TargetModule, packed OpIndex, valueId RegInt, isConst BoolArray, constVal RegIntArray, opQuery TargetOpQuery)
	opQuery.detectConstant(module, packed: packed, valueId: valueId, isConst: isConst, constVal: constVal)
end 'detectConstantWith'

export function markConstant(valueId RegInt, value RegInt, isConst BoolArray, constVal RegIntArray)
	if valueId < isConst.count() 'inBounds'
		try isConst.set(valueId, value: true) otherwise panic("invariant: isConst.set OOB")
	end 'inBounds'
	if valueId < constVal.count() 'inBounds2'
		try constVal.set(valueId, value: value) otherwise panic("invariant: constVal.set OOB")
	end 'inBounds2'
end 'markConstant'

// ============================================================
// Phase 2: Build last-use-in-block map
// ============================================================

// lastUseInBlock is a flat array: lastUseInBlock[blockId * maxVal + valueId] = opIdx
// This tells us the last instruction index within a block where a value is read.

// RegIntArray is a flat RegIntArray: [blockId * maxVal + valueId] = opIdx

function buildRegIntArray(module TargetModule, func IrFunction, maxVal RegInt, regTarget RegAllocTarget) returns RegIntArray
	var map = RegIntArray.create()

	// Initialize: -1 means "not used in this block"
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		let blockBase = block.id * maxVal

		// Ensure map is big enough for this block
		while map.count() <= blockBase + maxVal 'grow'
			map.push(-1)
		end 'grow'

		// Scan ops forward, recording last use position for each value
		var opIdx = 0
		for packed in block.opRefs 'eachOp'
			recordOpLastUsesPacked(module, packed: packed, map: map, blockBase: blockBase, opIdx: opIdx + 1, regTarget: regTarget)
			opIdx = opIdx + 1
		end 'eachOp'

		// Terminator
		if block.hasTerminatorOp() 'hasTerm'
			recordOpLastUsesPacked(module, packed: block.terminatorIndex(), map: map, blockBase: blockBase, opIdx: opIdx + 1, regTarget: regTarget)
		end 'hasTerm'

		// Branch arg uses from outgoing edges
		for edge in block.branchEdges 'eachEdge'
			recordArgIdsLastUses(edge.argIds, map: map, blockBase: blockBase, opIdx: opIdx + 1)
		end 'eachEdge'
	end 'eachBlock'

	return map
end 'buildRegIntArray'

function recordArgIdsLastUses(argIds ValueIdArray, map RegIntArray, blockBase RegInt, opIdx RegInt)
	for argId in argIds 'each'
		let idx = blockBase + argId
		if idx < map.count() 'inBounds'
			try map.set(idx, value: opIdx) otherwise panic("invariant: map.set OOB")
		end 'inBounds'
	end 'each'
end 'recordArgIdsLastUses'

function recordOpLastUsesPacked(module TargetModule, packed OpIndex, map RegIntArray, blockBase RegInt, opIdx RegInt, regTarget RegAllocTarget)
	var counts = RegIntArray.create()
	regTarget.countOpReads(module, counts: counts, packed: packed)

	var i = 0
	while i < counts.count() 'each'
		let cnt = try counts.get(i) otherwise panic("recordOpLastUsesPacked.each: i < counts.count() by loop guard but get({i}) failed")
		if cnt > 0 'isUsed'
			let idx = blockBase + i
			if idx < map.count() 'inBounds'
				try map.set(idx, value: opIdx) otherwise panic("invariant: map.set OOB")
			end 'inBounds'
		end 'isUsed'
		i = i + 1
	end 'each'
end 'recordOpLastUsesPacked'

function getLastUseInBlock(map RegIntArray, blockId BlockId, valueId ValueId, maxVal RegInt) returns RegInt
	let idx = blockId * maxVal + valueId
	return getOr(map, index: idx, fallback: -1)
end 'getLastUseInBlock'

// ============================================================
// Phase 3: Build intervals for a value
// ============================================================

function buildIntervalsForValue(module TargetModule, range LiveRange, liveness LivenessInfo, defBid BlockId, func IrFunction, lastUseInBlock RegIntArray, maxVal RegInt)
	let vid = range.valueId

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		let blockId = block.id
		let blockLen = block.opRefs.count() + 1

		let isLiveIn = liveGetBool(liveness.liveIn, blockId: blockId, valueId: vid)
		let isLiveOut = liveGetBool(liveness.liveOut, blockId: blockId, valueId: vid)

		let lastUse = getLastUseInBlock(lastUseInBlock, blockId: blockId, valueId: vid, maxVal: maxVal)

		if blockId == defBid 'isDefBlock'
			// Value is defined in this block.
			// Intervals use half-open [start, end) convention to match the
			// overlap check in SSAColoring (s1 < e2 and s2 < e1).
			let startPos = range.defPosition

			if isLiveOut 'liveOut'
				// Live through to end of block (blockLen is already exclusive)
				range.intervals.push(Interval.create(blockId, startPos: startPos, endPos: blockLen))
			end 'liveOut' else 'notLiveOut'
				// Dies in this block — end one past the last use (exclusive)
				if lastUse >= 0 'hasUse'
					range.intervals.push(Interval.create(blockId, startPos: startPos, endPos: lastUse + 1))
				end 'hasUse' else 'noUse'
					// Defined but not used in this block and not live-out
					// Still create a minimal interval at the def point
					range.intervals.push(Interval.create(blockId, startPos: startPos, endPos: startPos + 1))
				end 'noUse'
			end 'notLiveOut'

		end 'isDefBlock' else 'notDefBlock'
			// Value is NOT defined in this block — only include if live-in
			if isLiveIn 'liveIn'
				if isLiveOut 'liveThrough'
					// Live through entire block (blockLen is already exclusive)
					range.intervals.push(Interval.create(blockId, startPos: 0, endPos: blockLen))
				end 'liveThrough' else 'diesHere'
					// Live-in but dies in this block (exclusive end)
					if lastUse >= 0 'hasUse2'
						range.intervals.push(Interval.create(blockId, startPos: 0, endPos: lastUse + 1))
					end 'hasUse2' else 'noUse2'
						// Live-in but never used and not live-out — shouldn't happen normally
						// but handle gracefully
						range.intervals.push(Interval.create(blockId, startPos: 0, endPos: 1))
					end 'noUse2'
				end 'diesHere'
			end 'liveIn'
		end 'notDefBlock'
	end 'eachBlock'
end 'buildIntervalsForValue'

// Helper to read from LiveSetArray liveness sets. `sets` is
// `liveness.liveIn` or `liveness.liveOut`; the outer array is sized to
// numBlocks. Membership queries hit the dense bitvector inside each
// LiveSet (O(1)); the sparse member-list is used only by the liveness
// pass itself during fixed-point propagation.
function liveGetBool(sets LiveSetArray, blockId BlockId, valueId ValueId) returns bool
	let blockSet = try sets.get(blockId) otherwise panic("liveGetBool: sets.get({blockId}) OOB; liveness sets sized to numBlocks")
	return blockSet.contains(valueId)
end 'liveGetBool'

// ============================================================
// Spill weight computation
// ============================================================

// spillWeight = sum(uses_in_block * loopWeight) / totalLength
// loopWeight = 10^loopDepth (capped to avoid overflow)
function computeSpillWeight(range LiveRange, loopDepth RegIntArray) returns RegInt
	var totalUses = 0
	var totalLength = 0

	for interval in range.intervals 'eachInterval'
		let blockId = interval.blockId
		let length = interval.endPos - interval.startPos
		if length < 1 'minLen'
			totalLength = totalLength + 1
		end 'minLen' else 'hasLen'
			totalLength = totalLength + length
		end 'hasLen'

		// Count uses in this block (approximate: count from interval presence)
		// Use loop depth as a weight multiplier
		let depth = getOr(loopDepth, index: blockId, fallback: 0)
		let weight = loopWeightForDepth(depth)
		totalUses = totalUses + weight
	end 'eachInterval'

	if totalLength == 0 'noLength'
		return 0
	end 'noLength'

	// Rematerializable values get reduced weight (cheaper to spill)
	if range.isRematerializable 'remat'
		return totalUses / totalLength / 2
	end 'remat'

	return totalUses / totalLength
end 'computeSpillWeight'

function loopWeightForDepth(depth RegInt) returns RegInt
	if depth <= 0 'noLoop'
		return 1
	end 'noLoop'
	if depth == 1 'single'
		return 10
	end 'single'
	if depth == 2 'double'
		return 100
	end 'double'

	// Cap at 1000 for deeply nested loops
	return 1000
end 'loopWeightForDepth'

// ============================================================
// Physical register constraints
// ============================================================

// Insert pseudo live ranges for physical registers that are implicitly
// clobbered by instructions (e.g. idiv clobbers RAX/RDX, call clobbers
// caller-saved registers). These pseudo ranges participate in the
// interference graph and prevent the coloring from assigning virtual
// values to registers that would be destroyed.

export function insertPhysicalConstraints(module TargetModule, ranges LiveRangeArray, func IrFunction, regTarget RegAllocTarget, opQuery TargetOpQuery)
	// Find the next available value ID above all existing ranges
	var nextPseudoId = 0
	for range in ranges 'findMax'
		if range.valueId >= nextPseudoId 'higher'
			nextPseudoId = range.valueId + 1
		end 'higher'
	end 'findMax'

	var isFirstBlock = true

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		let blockId = block.id

		// Entry block: add pseudo-ranges for calling convention registers
		// that carry function parameters. These prevent the coloring from
		// assigning virtual values to registers that still hold unsaved params.
		// Each param register's pseudo-range ends at THAT specific register's
		// last use, not at the latest use across all params — that lets early-
		// consumed param registers (e.g. rcx for arg 0) become free to host
		// later virtual values, instead of pinning every caller-saved reg
		// until the slowest param has been copied out.
		if isFirstBlock and func.paramCount > 0 'entryBlock'
			let paramMask = targetGetParamRegMask(regTarget, paramCount: func.paramCount, paramTypes: func.paramTypes)
			if paramMask > 0 'hasParams'
				nextPseudoId = emitPerBitParamRanges(module, ranges: ranges, mask: paramMask, block: block, blockId: blockId, regTarget: regTarget, opQuery: opQuery, nextId: nextPseudoId)
			end 'hasParams'
			isFirstBlock = false
		end 'entryBlock'

		var opIdx = 0
		for packed in block.opRefs 'eachOp'
			let clobberMask = regTarget.getImplicitGprDefs(module, packed: packed)

			if clobberMask > 0 'hasClobbers'
				let firstPseudoId = nextPseudoId
				nextPseudoId = emitClobberRanges(ranges, mask: clobberMask, blockId: blockId, opIdx: opIdx + 1, nextId: nextPseudoId)
				// `movRegReg physDest, virtSrc` clobbers physDest at the same
				// position virtSrc dies. Without a copy-link, the half-open
				// intervals overlap by one position and the interference graph
				// blocks the colorer from honoring virtSrc's hint to physDest.
				// Linking the clobber pseudo to virtSrc lets `isCopyBoundaryOverlap`
				// suppress the spurious 1-position conflict, so a return value
				// produced by `movRegImm` lands directly in the return register
				// instead of routing through a scratch register first.
				let probe = opQuery.decodeReturnMovProbe(module, packed: packed)
				if probe.found and probe.destOrd != RM_NONE and probe.srcId >= 0 'isPhysToVirtMov'
					linkClobberToVirtSrc(ranges, firstPseudoId: firstPseudoId, lastPseudoId: nextPseudoId, physOrd: probe.destOrd, virtSrcId: probe.srcId, blockId: blockId, opPos: opIdx + 1)
				end 'isPhysToVirtMov'
			end 'hasClobbers'

			opIdx = opIdx + 1
		end 'eachOp'

		// Terminator
		if block.hasTerminatorOp() 'hasTerm'
			let termMask = regTarget.getImplicitGprDefs(module, packed: block.terminatorIndex())

			if termMask > 0 'termClobbers'
				nextPseudoId = emitClobberRanges(ranges, mask: termMask, blockId: blockId, opIdx: opIdx + 1, nextId: nextPseudoId)
			end 'termClobbers'
		end 'hasTerm'
	end 'eachBlock'
end 'insertPhysicalConstraints'

// Compute a bitmask of GPR calling convention registers used for parameters.
function targetGetParamRegMask(regTarget RegAllocTarget, paramCount ParamCount, paramTypes StdTypeArray) returns RegMask
	var mask = 0
	var gprIdx = 0
	var pi = 0
	while pi < paramCount 'eachParam'
		let pt = try paramTypes.get(pi) otherwise panic("unreachable: param index out of bounds")
		if not stdTypeIsFloat(pt) 'isGpr'
			match regTarget.getCallConvGprOrd(gprIdx) 'slot'
				gpr(ord) then mask = mask or (1 shl ord)
				spilled then break 'slot'
			end 'slot'
			gprIdx = gprIdx + 1
		end 'isGpr'
		pi = pi + 1
	end 'eachParam'
	return mask
end 'targetGetParamRegMask'

// Find the last op position in the entry block that reads a parameter register.
// This is the position up to which parameter registers are "live".
function findLastParamRegUsePacked(module TargetModule, block IrBlock, paramMask RegMask, regTarget RegAllocTarget, opQuery TargetOpQuery) returns RegInt
	var lastPos = 0
	var opIdx = 0
	for packed in block.opRefs 'eachOp'
		let reads = regTarget.getImplicitGprReads(module, packed: packed)

		// Also check explicit reads of physical registers (movRegReg from phys)
		let explicitMask = getExplicitPhysReadsWith(module, packed: packed, opQuery: opQuery)
		let combinedMask = reads or explicitMask

		if (combinedMask and paramMask) > 0 'usesParam'
			lastPos = opIdx + 1
		end 'usesParam'

		opIdx = opIdx + 1
	end 'eachOp'
	return lastPos
end 'findLastParamRegUsePacked'

// Emit one pseudo-range per param register, each spanning [0, that register's
// last use). A whole-mask `lastParamUse` would force every param register to
// stay "occupied" until the SLOWEST param is consumed — which keeps caller-
// saved registers like rcx blocked for the entire param-copy phase even after
// rcx's own param has been moved out, pushing later virtuals into callee-
// saved registers and inflating the save area.
function emitPerBitParamRanges(module TargetModule, ranges LiveRangeArray, mask RegMask, block IrBlock, blockId BlockId, regTarget RegAllocTarget, opQuery TargetOpQuery, nextId RegInt) returns RegInt
	var currentId = nextId
	var bit = 0
	var remaining = mask
	while remaining > 0 'eachBit'
		if (remaining and 1) == 1 'bitSet'
			let bitMask = 1 shl bit
			let bitLastUse = findLastParamRegUsePacked(module, block: block, paramMask: bitMask, regTarget: regTarget, opQuery: opQuery)
			if bitLastUse > 0 'hasUse'
				var range = LiveRange.create(currentId)
				range.defBlock = blockId
				range.defPosition = 0
				range.regClass = RegClass.gpr
				range.fixedReg = bit
				range.assignedReg = bit
				range.spillWeight = 1000000
				range.isRematerializable = false
				range.intervals.push(Interval.create(blockId, startPos: 0, endPos: bitLastUse))
				ranges.push(range)
				currentId = currentId + 1
			end 'hasUse'
		end 'bitSet'
		remaining = remaining shr 1
		bit = bit + 1
	end 'eachBit'
	return currentId
end 'emitPerBitParamRanges'

// Get a mask of physical GPR registers explicitly read by a movRegReg-from-physical op.
function getExplicitPhysReadsWith(module TargetModule, packed OpIndex, opQuery TargetOpQuery) returns RegMask
	return opQuery.getExplicitPhysReads(module, packed: packed)
end 'getExplicitPhysReadsWith'

// Emit one pseudo LiveRange per set bit in the clobber mask.
// Returns the next available pseudo value ID.
function emitClobberRanges(ranges LiveRangeArray, mask RegMask, blockId BlockId, opIdx RegInt, nextId RegInt) returns RegInt
	return emitFixedRegRanges(ranges, mask: mask, blockId: blockId, startPos: opIdx, endPos: opIdx + 1, nextId: nextId)
end 'emitClobberRanges'

// Walk the pseudo-ranges just emitted for the current op and tag the one
// pinned to `physOrd` with a copy-link to `virtSrcId`. The link tells the
// interference graph that the 1-position boundary overlap between the
// vreg's death and the clobber's birth is a copy artifact, not a real
// conflict — symmetrical to how the existing copy-hint flow handles
// vreg-to-vreg movRegReg. The (blockId, opPos) pair anchors a CopyEdge
// so the edge-aware suppression check in isCopyBoundaryOverlap can match
// this pair exactly at the overlap position.
function linkClobberToVirtSrc(ranges LiveRangeArray, firstPseudoId RegInt, lastPseudoId RegInt, physOrd RegOrdinal, virtSrcId RegInt, blockId BlockId, opPos RegInt)
	let total = ranges.count()
	var i = total - 1
	var clobberValueId = -1

	while i >= 0 'scanBack'
		var range = try ranges.get(i) otherwise break
		if range.valueId < firstPseudoId 'beforeWindow'
			break
		end 'beforeWindow'
		if range.valueId < lastPseudoId and range.fixedReg == physOrd 'isTarget'
			range.copyHintValueId = virtSrcId
			addCopyEdge(range, partner: virtSrcId, blockId: blockId, copyPos: opPos)
			clobberValueId = range.valueId
			break
		end 'isTarget'
		i = i - 1
	end 'scanBack'

	// Push the reverse edge on the virtual source range too. vidToRangeIdx
	// isn't built yet at this phase (insertPhysicalConstraints runs before
	// coalesceRanges), so locate the source range by linear scan. Either
	// direction matching is enough for isCopyBoundaryOverlap, but recording
	// both keeps the model symmetric with setGprCopyHintEdge.
	if clobberValueId >= 0 'foundClobber'
		var j = 0
		let rangeCount = ranges.count()
		while j < rangeCount 'findSrc'
			var srcRange = try ranges.get(j) otherwise break
			if srcRange.valueId == virtSrcId 'isVirtSrc'
				addCopyEdge(srcRange, partner: clobberValueId, blockId: blockId, copyPos: opPos)
				break
			end 'isVirtSrc'
			j = j + 1
		end 'findSrc'
	end 'foundClobber'
end 'linkClobberToVirtSrc'

// Emit one pseudo LiveRange per set bit in a register mask.
// Each pseudo range is pinned to a physical register ordinal and participates
// in the interference graph to prevent the coloring from assigning virtual
// values to registers that are implicitly occupied or clobbered.
function emitFixedRegRanges(ranges LiveRangeArray, mask RegMask, blockId BlockId, startPos RegInt, endPos RegInt, nextId RegInt) returns RegInt
	var currentId = nextId
	var bit = 0
	var remaining = mask

	while remaining > 0 'eachBit'
		if (remaining and 1) == 1 'bitSet'
			var range = LiveRange.create(currentId)
			range.defBlock = blockId
			range.defPosition = startPos
			range.regClass = RegClass.gpr
			range.fixedReg = bit
			range.assignedReg = bit
			range.spillWeight = 1000000
			range.isRematerializable = false
			range.intervals.push(Interval.create(blockId, startPos: startPos, endPos: endPos))

			ranges.push(range)
			currentId = currentId + 1
		end 'bitSet'

		remaining = remaining shr 1
		bit = bit + 1
	end 'eachBit'

	return currentId
end 'emitFixedRegRanges'

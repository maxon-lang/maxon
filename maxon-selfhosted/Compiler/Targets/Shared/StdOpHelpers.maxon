// Shared helpers for Standard dialect -> target dialect conversion.
// Used by both StandardToX86Conversion and StandardToArm64Conversion.

export typealias SlotIndex = int(i64.min to i64.max)
export typealias StdOpIndex = int(0 to u64.max)

export union JumpKind
    eq
    ne
    lt
    le
    gt
    ge
    feq
    boolTest
end 'JumpKind'

// Value location tracking for SSA-based register management.
// Maps ValueId -> VarSlot so binary ops can load operands from the right slots.
export typealias ValueSlotMap = Array with VarSlot

export function valueSlotMapGet(m ValueSlotMap, valueId ValueId) returns VarSlot
    let result = try m.get(valueId) otherwise 0 - 1
    return result
end 'valueSlotMapGet'

export function valueSlotMapSet(m ValueSlotMap, valueId ValueId, slot VarSlot)
    while m.count() <= valueId 'grow'
        m.push(0 - 1)
    end 'grow'
    m.set(valueId, value: slot)
end 'valueSlotMapSet'

export function maxOf(a SlotIndex, b SlotIndex) returns SlotIndex
    if a > b 'aGreater'
        return a
    end 'aGreater'
    return b
end 'maxOf'

// Info about a constant operation for SSA temp slot allocation.
export type ConstInfo
    export var isConst bool
    export var resultId ValueId
    export var value ParsedInt
end 'ConstInfo'

// Extract constant info; returns isConst=false for non-constant ops.
export function getConstInfo(op StdOp) returns ConstInfo
    var result = ConstInfo{isConst: false, resultId: 0, value: 0}
    match op 'check'
        constI64(resultId, value) then result = ConstInfo{isConst: true, resultId: resultId, value: value}
        constF64(resultId, rawBits) then result = ConstInfo{isConst: true, resultId: resultId, value: rawBits}
        funcBegin(name, returnType) then break 'check'
        funcEnd then break 'check'
        returnOp(retValId) then break 'check'
        storeSlot(slotId, valueId) then break 'check'
        loadSlot(resultId, slotId) then break 'check'
        addI64(resultId, leftId, rightId) then break 'check'
        subI64(resultId, leftId, rightId) then break 'check'
        mulI64(resultId, leftId, rightId) then break 'check'
        divI64(resultId, leftId, rightId) then break 'check'
        remI64(resultId, leftId, rightId) then break 'check'
        negI64(resultId, operandId) then break 'check'
        bitNotI64(resultId, operandId) then break 'check'
        andI64(resultId, leftId, rightId) then break 'check'
        orI64(resultId, leftId, rightId) then break 'check'
        xorI64(resultId, leftId, rightId) then break 'check'
        shlI64(resultId, leftId, rightId) then break 'check'
        shrI64(resultId, leftId, rightId) then break 'check'
        cmpI64Eq(resultId, leftId, rightId) then break 'check'
        cmpI64Ne(resultId, leftId, rightId) then break 'check'
        cmpI64Lt(resultId, leftId, rightId) then break 'check'
        cmpI64Le(resultId, leftId, rightId) then break 'check'
        cmpI64Gt(resultId, leftId, rightId) then break 'check'
        cmpI64Ge(resultId, leftId, rightId) then break 'check'
        cmpF64Eq(resultId, leftId, rightId) then break 'check'
        condBr(condId, thenLabel, elseLabel) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getConstInfo'

// Extract function name from a funcBegin op; returns empty ByteArray for other ops.
export function getFuncBeginName(op StdOp) returns ByteArray
    var result = ByteArray{}
    match op 'check'
        funcBegin(name, returnType) then result = name
        funcEnd then break 'check'
        constI64(resultId, value) then break 'check'
        constF64(resultId, rawBits) then break 'check'
        returnOp(retValId) then break 'check'
        storeSlot(slotId, valueId) then break 'check'
        loadSlot(resultId, slotId) then break 'check'
        addI64(resultId, leftId, rightId) then break 'check'
        subI64(resultId, leftId, rightId) then break 'check'
        mulI64(resultId, leftId, rightId) then break 'check'
        divI64(resultId, leftId, rightId) then break 'check'
        remI64(resultId, leftId, rightId) then break 'check'
        negI64(resultId, operandId) then break 'check'
        bitNotI64(resultId, operandId) then break 'check'
        andI64(resultId, leftId, rightId) then break 'check'
        orI64(resultId, leftId, rightId) then break 'check'
        xorI64(resultId, leftId, rightId) then break 'check'
        shlI64(resultId, leftId, rightId) then break 'check'
        shrI64(resultId, leftId, rightId) then break 'check'
        cmpI64Eq(resultId, leftId, rightId) then break 'check'
        cmpI64Ne(resultId, leftId, rightId) then break 'check'
        cmpI64Lt(resultId, leftId, rightId) then break 'check'
        cmpI64Le(resultId, leftId, rightId) then break 'check'
        cmpI64Gt(resultId, leftId, rightId) then break 'check'
        cmpI64Ge(resultId, leftId, rightId) then break 'check'
        cmpF64Eq(resultId, leftId, rightId) then break 'check'
        condBr(condId, thenLabel, elseLabel) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getFuncBeginName'

// Extract else label from a condBr op; returns empty ByteArray for other ops.
// Extract the condition value ID from a condBr op. Returns -1 for non-condBr ops.
export function getCondBrCondId(op StdOp) returns ValueId
    var result = 0 - 1
    match op 'check'
        condBr(condId, thenLabel, elseLabel) then result = condId
        funcBegin(name, returnType) then break 'check'
        funcEnd then break 'check'
        constI64(resultId, value) then break 'check'
        constF64(resultId, rawBits) then break 'check'
        returnOp(retValId) then break 'check'
        storeSlot(slotId, valueId) then break 'check'
        loadSlot(resultId, slotId) then break 'check'
        addI64(resultId, leftId, rightId) then break 'check'
        subI64(resultId, leftId, rightId) then break 'check'
        mulI64(resultId, leftId, rightId) then break 'check'
        divI64(resultId, leftId, rightId) then break 'check'
        remI64(resultId, leftId, rightId) then break 'check'
        negI64(resultId, operandId) then break 'check'
        bitNotI64(resultId, operandId) then break 'check'
        andI64(resultId, leftId, rightId) then break 'check'
        orI64(resultId, leftId, rightId) then break 'check'
        xorI64(resultId, leftId, rightId) then break 'check'
        shlI64(resultId, leftId, rightId) then break 'check'
        shrI64(resultId, leftId, rightId) then break 'check'
        cmpI64Eq(resultId, leftId, rightId) then break 'check'
        cmpI64Ne(resultId, leftId, rightId) then break 'check'
        cmpI64Lt(resultId, leftId, rightId) then break 'check'
        cmpI64Le(resultId, leftId, rightId) then break 'check'
        cmpI64Gt(resultId, leftId, rightId) then break 'check'
        cmpI64Ge(resultId, leftId, rightId) then break 'check'
        cmpF64Eq(resultId, leftId, rightId) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getCondBrCondId'


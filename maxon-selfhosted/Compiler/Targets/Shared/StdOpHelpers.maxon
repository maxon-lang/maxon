    end 'check'
    return result
end 'getCondBrElseLabel'

// Info about a unary operation for SSA-based lowering.
export type UnaryOpInfo
    export var isUnary bool
    export var resultId ValueId
    export var operandId ValueId
end 'UnaryOpInfo'

// Extract unary op info; returns isUnary=false for non-unary ops.
export function getUnaryOpInfo(op StdOp) returns UnaryOpInfo
    var result = UnaryOpInfo{isUnary: false, resultId: 0, operandId: 0}
    match op 'check'
        negI64(resultId, operandId) then result = UnaryOpInfo{isUnary: true, resultId: resultId, operandId: operandId}
        bitNotI64(resultId, operandId) then result = UnaryOpInfo{isUnary: true, resultId: resultId, operandId: operandId}
        constI64(resultId, value) then break 'check'
        constF64(resultId, rawBits) then break 'check'
        funcBegin(name, returnType) then break 'check'
        funcEnd then break 'check'
        returnOp(retValId) then break 'check'
        storeSlot(slotId, valueId) then break 'check'
        loadSlot(resultId, slotId) then break 'check'
        addI64(resultId, leftId, rightId) then break 'check'
        subI64(resultId, leftId, rightId) then break 'check'
        mulI64(resultId, leftId, rightId) then break 'check'
        divI64(resultId, leftId, rightId) then break 'check'
        remI64(resultId, leftId, rightId) then break 'check'
        andI64(resultId, leftId, rightId) then break 'check'
        orI64(resultId, leftId, rightId) then break 'check'
        xorI64(resultId, leftId, rightId) then break 'check'
        shlI64(resultId, leftId, rightId) then break 'check'
        shrI64(resultId, leftId, rightId) then break 'check'
        cmpI64Eq(resultId, leftId, rightId) then break 'check'
        cmpI64Ne(resultId, leftId, rightId) then break 'check'
        cmpI64Lt(resultId, leftId, rightId) then break 'check'
        cmpI64Le(resultId, leftId, rightId) then break 'check'
        cmpI64Gt(resultId, leftId, rightId) then break 'check'
        cmpI64Ge(resultId, leftId, rightId) then break 'check'
        cmpF64Eq(resultId, leftId, rightId) then break 'check'
        condBr(condId, thenLabel, elseLabel) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getUnaryOpInfo'

// Find the max parser-allocated slot in a function body (from storeSlot/loadSlot ops).
export function computeMaxParserSlot(stdOps StdOpArray, startIndex StdOpIndex) returns SlotIndex
    var maxSlot = 0 - 1
    var j = startIndex + 1
    while j < stdOps.count() 'scan'
        let op = try stdOps.get(j) otherwise 'scanSkip'
            j = j + 1
            continue
        end 'scanSkip'
        match op 'check'
            funcEnd then break 'scan'
            storeSlot(slotId, valueId) then maxSlot = maxOf(maxSlot, b: slotId)
            loadSlot(resultId, slotId) then maxSlot = maxOf(maxSlot, b: slotId)
            constI64(resultId, value) then break 'check'
            constF64(resultId, rawBits) then break 'check'
            returnOp(retValId) then break 'check'
            addI64(resultId, leftId, rightId) then break 'check'
            subI64(resultId, leftId, rightId) then break 'check'
            mulI64(resultId, leftId, rightId) then break 'check'
            divI64(resultId, leftId, rightId) then break 'check'
            remI64(resultId, leftId, rightId) then break 'check'
            negI64(resultId, operandId) then break 'check'
            bitNotI64(resultId, operandId) then break 'check'
            andI64(resultId, leftId, rightId) then break 'check'
            orI64(resultId, leftId, rightId) then break 'check'
            xorI64(resultId, leftId, rightId) then break 'check'
            shlI64(resultId, leftId, rightId) then break 'check'
            shrI64(resultId, leftId, rightId) then break 'check'
            cmpI64Eq(resultId, leftId, rightId) then break 'check'
            cmpI64Ne(resultId, leftId, rightId) then break 'check'
            cmpI64Lt(resultId, leftId, rightId) then break 'check'
            cmpI64Le(resultId, leftId, rightId) then break 'check'
            cmpI64Gt(resultId, leftId, rightId) then break 'check'
            cmpI64Ge(resultId, leftId, rightId) then break 'check'
            cmpF64Eq(resultId, leftId, rightId) then break 'check'
            condBr(condId, thenLabel, elseLabel) then break 'check'
            br(targetLabel) then break 'check'
            label(name) then break 'check'
            funcBegin(n, rt) then break 'check'
            printLiteral(data) then break 'check'
            printInt(valueId) then break 'check'
            call(resultId, callee) then break 'check'
        end 'check'
        j = j + 1
    end 'scan'
    return maxSlot
end 'computeMaxParserSlot'

// Read-only scan: look back from condBr to find the comparison that produced the condition.
export function determineJumpKind(stdOps StdOpArray, condIndex StdOpIndex) returns JumpKind
    var j = condIndex - 1
    while j >= 0 'scanBack'
        let prevOp = try stdOps.get(j) otherwise 'scanSkip'
            j = j - 1
            continue
        end 'scanSkip'
        match prevOp 'checkCmp'
            cmpI64Eq(resultId, leftId, rightId) then return JumpKind.eq
            cmpI64Ne(resultId, leftId, rightId) then return JumpKind.ne
            cmpI64Lt(resultId, leftId, rightId) then return JumpKind.lt
            cmpI64Le(resultId, leftId, rightId) then return JumpKind.le
            cmpI64Gt(resultId, leftId, rightId) then return JumpKind.gt
            cmpI64Ge(resultId, leftId, rightId) then return JumpKind.ge
            cmpF64Eq(resultId, leftId, rightId) then return JumpKind.feq
            constI64(resultId, value) then j = j - 1
            constF64(resultId, rawBits) then j = j - 1
            returnOp(retValId) then j = j - 1
            storeSlot(slotId, valueId) then j = j - 1
            loadSlot(resultId, slotId) then j = j - 1
            addI64(resultId, leftId, rightId) then j = j - 1
            subI64(resultId, leftId, rightId) then j = j - 1
            mulI64(resultId, leftId, rightId) then j = j - 1
            divI64(resultId, leftId, rightId) then j = j - 1
            remI64(resultId, leftId, rightId) then j = j - 1
            negI64(resultId, operandId) then j = j - 1
            bitNotI64(resultId, operandId) then j = j - 1
            andI64(resultId, leftId, rightId) then j = j - 1
            orI64(resultId, leftId, rightId) then j = j - 1
            xorI64(resultId, leftId, rightId) then j = j - 1
            shlI64(resultId, leftId, rightId) then j = j - 1
            shrI64(resultId, leftId, rightId) then j = j - 1
            condBr(cId, tl, el) then j = j - 1
            br(targetLabel) then j = j - 1
            label(name) then j = j - 1
            printLiteral(data) then j = j - 1
            printInt(valueId) then j = j - 1
            funcBegin(name, returnType) then j = j - 1
            funcEnd then j = j - 1
            call(resultId, callee) then j = j - 1
        end 'checkCmp'
    end 'scanBack'
    return JumpKind.boolTest
end 'determineJumpKind'

// Info about a div/rem operation for SSA-based lowering.
// Shared between X86 and ARM64 since both need identical extraction logic.
export type DivRemOpInfo
    export var isDivRem bool
    export var isRem bool
    export var resultId ValueId
    export var leftId ValueId
    export var rightId ValueId
end 'DivRemOpInfo'

// Extract div/rem op info; returns isDivRem=false for non-div/rem ops.
export function getDivRemOpInfo(op StdOp) returns DivRemOpInfo
    var result = DivRemOpInfo{isDivRem: false, isRem: false, resultId: 0 - 1, leftId: 0, rightId: 0}
    match op 'check'
        divI64(resultId, leftId, rightId) then result = DivRemOpInfo{isDivRem: true, isRem: false, resultId: resultId, leftId: leftId, rightId: rightId}
        remI64(resultId, leftId, rightId) then result = DivRemOpInfo{isDivRem: true, isRem: true, resultId: resultId, leftId: leftId, rightId: rightId}
        constI64(resultId, value) then break 'check'
        constF64(resultId, rawBits) then break 'check'
        funcBegin(name, returnType) then break 'check'
        funcEnd then break 'check'
        returnOp(retValId) then break 'check'
        storeSlot(slotId, valueId) then break 'check'
        loadSlot(resultId, slotId) then break 'check'
        addI64(resultId, leftId, rightId) then break 'check'
        subI64(resultId, leftId, rightId) then break 'check'
        mulI64(resultId, leftId, rightId) then break 'check'
        negI64(resultId, operandId) then break 'check'
        bitNotI64(resultId, operandId) then break 'check'
        andI64(resultId, leftId, rightId) then break 'check'
        orI64(resultId, leftId, rightId) then break 'check'
        xorI64(resultId, leftId, rightId) then break 'check'
        shlI64(resultId, leftId, rightId) then break 'check'
        shrI64(resultId, leftId, rightId) then break 'check'
        cmpI64Eq(resultId, leftId, rightId) then break 'check'
        cmpI64Ne(resultId, leftId, rightId) then break 'check'
        cmpI64Lt(resultId, leftId, rightId) then break 'check'
        cmpI64Le(resultId, leftId, rightId) then break 'check'
        cmpI64Gt(resultId, leftId, rightId) then break 'check'
        cmpI64Ge(resultId, leftId, rightId) then break 'check'
        cmpF64Eq(resultId, leftId, rightId) then break 'check'
        condBr(condId, thenLabel, elseLabel) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getDivRemOpInfo'

// Read-only scan: compute stack frame size by finding max slot, temp slots, and print usage.
export function computeStackSize(stdOps StdOpArray, startIndex StdOpIndex, shadowSpace StackSize, savedRegsSize StackSize) returns StackSize
    var maxSlot = 0 - 1
    var hasPrint = false
    var tempSlotCount = 0

    var j = startIndex + 1
    while j < stdOps.count() 'scan'
        let op = try stdOps.get(j) otherwise 'scanSkip'
            j = j + 1
            continue
        end 'scanSkip'
        match op 'countSlot'
            funcEnd then break 'scan'
            storeSlot(slotId, valueId) then maxSlot = maxOf(maxSlot, b: slotId)
            loadSlot(resultId, slotId) then maxSlot = maxOf(maxSlot, b: slotId)
            printInt(valueId) then hasPrint = true
            printLiteral(data) then hasPrint = true
            constI64(resultId, value) then tempSlotCount = tempSlotCount + 1
            constF64(resultId, rawBits) then tempSlotCount = tempSlotCount + 1
            addI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            subI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            mulI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            divI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            remI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            negI64(resultId, operandId) then tempSlotCount = tempSlotCount + 1
            bitNotI64(resultId, operandId) then tempSlotCount = tempSlotCount + 1
            andI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            orI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            xorI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            shlI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            shrI64(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Eq(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Ne(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Lt(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Le(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Gt(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpI64Ge(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            cmpF64Eq(resultId, leftId, rightId) then tempSlotCount = tempSlotCount + 1
            returnOp(retValId) then break 'countSlot'
            condBr(condId, thenLabel, elseLabel) then break 'countSlot'
            br(targetLabel) then break 'countSlot'
            label(name) then break 'countSlot'
            funcBegin(n, rt) then break 'countSlot'
            call(resultId, callee) then break 'countSlot'
        end 'countSlot'
        j = j + 1
    end 'scan'

    let totalMaxSlot = maxSlot + tempSlotCount
    let overhead = shadowSpace + savedRegsSize

    var stackSize = 0
    if totalMaxSlot >= 0 'hasSlots'
        stackSize = (totalMaxSlot + 1) * 8 + overhead
    end 'hasSlots'
    if hasPrint and stackSize == 0 'needPrintBuf'
        stackSize = overhead
        if stackSize == 0 'noOverhead'
            stackSize = 16
        end 'noOverhead'
    end 'needPrintBuf'
    // Align to 16
    if stackSize mod 16 != 0 'align'
        stackSize = stackSize + (16 - (stackSize mod 16))
    end 'align'
    return stackSize
end 'computeStackSize'

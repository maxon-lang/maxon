// Shared types for code emission results, used across all backends.

typealias RelocSlotIndex = int(0 to u64.max)

// A relocation records a code location that needs patching after section layout.
// Used for IAT entries (Windows PE) and GOT entries (Linux ELF).
export type Relocation
	export var codeOffset CodeOffset
	export var slotIndex RelocSlotIndex

	export static function create(codeOffset CodeOffset, slotIndex RelocSlotIndex) returns Relocation
		return Self{codeOffset: codeOffset, slotIndex: slotIndex}
	end 'create'
end 'Relocation'

export typealias RelocationArray = Array with Relocation

export type CallFixup
	export var codeOffset CodeOffset
	export var targetName String

	export static function create(codeOffset CodeOffset, targetName String) returns CallFixup
		return Self{codeOffset: codeOffset, targetName: targetName}
	end 'create'
end 'CallFixup'

export typealias CallFixupArray = Array with CallFixup

// A DebugSymbol pairs a function name with its byte offset in the .text section.
// Format-neutral: PE writes COFF symbol entries from it, ELF emits Elf64_Sym
// entries, Mach-O emits nlist_64 entries.
export type DebugSymbol
	export var name String
	export var codeOffset CodeOffset

	export static function create(name String, codeOffset CodeOffset) returns DebugSymbol
		return Self{name: name, codeOffset: codeOffset}
	end 'create'
end 'DebugSymbol'

export typealias DebugSymbolArray = Array with DebugSymbol

// Zip parallel function-name and code-offset arrays into a DebugSymbolArray.
export function buildDebugSymbols(labelNames StringArray, labelOffsets CodeOffsetArray) returns DebugSymbolArray
	var symbols = DebugSymbolArray.create()
	for (iter, name) in labelNames.withIterator() 'each'
		let offset = try labelOffsets.get(iter.index()) otherwise panic("buildDebugSymbols: labelNames.count()={labelNames.count()} but labelOffsets.get({iter.index()}) failed (count={labelOffsets.count()})")
		symbols.push(DebugSymbol.create(name, codeOffset: offset))
	end 'each'
	return symbols
end 'buildDebugSymbols'

// Relocation kind for code-to-rdata references.
export union RdataRelocKind
	ripRelDisp32
	symdataRipRelDisp32
	dataSectionRipRelDisp32
	covdataRipRelDisp32
	arm64Adr
	arm64LdrLiteral
	symdataArm64Adr
	dataSectionArm64Adr
	covdataArm64Adr
end 'RdataRelocKind'

// --- Cache codec ---
// All variants are bare, so the writer just emits the ordinal. The reader
// lifts the raw int through .unionCases.fromRawValue and matches over the
// companion enum (exhaustive); adding a variant breaks the reader.

export function writeRdataRelocKind(buf ByteArray, kind RdataRelocKind)
	writeDword(buf, value: kind.ordinal)
end 'writeRdataRelocKind'

export function readRdataRelocKind(buf ByteArray, offset ByteOffset) returns (RdataRelocKind, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let pos = offset + 4
	let kase = try RdataRelocKind.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown RdataRelocKind tag {raw}")
	match kase 'tag'
		ripRelDisp32 then return (RdataRelocKind.ripRelDisp32, pos)
		symdataRipRelDisp32 then return (RdataRelocKind.symdataRipRelDisp32, pos)
		dataSectionRipRelDisp32 then return (RdataRelocKind.dataSectionRipRelDisp32, pos)
		covdataRipRelDisp32 then return (RdataRelocKind.covdataRipRelDisp32, pos)
		arm64Adr then return (RdataRelocKind.arm64Adr, pos)
		arm64LdrLiteral then return (RdataRelocKind.arm64LdrLiteral, pos)
		symdataArm64Adr then return (RdataRelocKind.symdataArm64Adr, pos)
		dataSectionArm64Adr then return (RdataRelocKind.dataSectionArm64Adr, pos)
		covdataArm64Adr then return (RdataRelocKind.covdataArm64Adr, pos)
	end 'tag'
end 'readRdataRelocKind'

// A relocation from code to a data section (.rdata, .symtab, .data, or .covdata).
// For rdata kinds: rdataLabel names the global data entry, rdataOffset is resolved during serialization.
// For symdata kinds: points to the base of the .symtab section (rdataOffset unused).
// For covdata kinds: rdataLabel names a `__data_cov_*` entry in the .covdata section.
export type RdataRelocation
	export var codeOffset CodeOffset
	export var rdataLabel String
	export var rdataOffset CodeOffset
	export var kind RdataRelocKind

	export static function create(codeOffset CodeOffset, rdataLabel String, kind RdataRelocKind) returns RdataRelocation
		return Self{codeOffset: codeOffset, rdataLabel: rdataLabel, rdataOffset: 0, kind: kind}
	end 'create'
end 'RdataRelocation'

export typealias RdataRelocationArray = Array with RdataRelocation

// CodeResult bundles the emitted machine code along with the data needed
// to finish writing an executable and the IR module(s) that produced it.
//
// `targetModule` holds the final TargetModule (x64 or arm64 ops) used by the
// printer consumer in compileSourceWithIr. For WASM targets this is a dummy
// empty TargetModule -- WASM reads `mirModule` instead, which carries the
// MIR-level MirModule that the WASM backend consumes directly.
//
// `covDataSectionBytes` holds the on-disk image of the .covdata section —
// i.e. coverage counter globals (`__data_cov_*`) registered when instrumentation
// is enabled. Empty for builds that don't register coverage entries; the writer
// then omits the .covdata section entirely so PE/ELF output stays byte-identical
// to non-instrumented builds.
export type CodeResult
	export var code ByteArray
	export var mainCallFixupOffset CodeOffset
	export var relocations RelocationArray
	export var globalData GlobalDataTable
	export var targetModule TargetModule
	export var mirModule MirModule
	export var rdata ByteArray
	export var rdataRelocations RdataRelocationArray
	export var symdata ByteArray
	export var covDataSectionBytes ByteArray
	// Initial bytes for top-level / static-field globals (`var counter = 0`,
	// `static var Counter.count = 0`). These bytes sit at the start of the
	// .data section, before the bump allocator's heap arena. Empty for builds
	// with no top-level mutable globals.
	export var dataPrelude ByteArray
	// Function-name → code-offset symbols for debug-symbol emission. Populated
	// by backends after stdlib linking; consumed by PE/ELF/Mach-O writers to
	// emit standard symbol tables that debuggers can consume.
	export var debugSymbols DebugSymbolArray

	export static function create(code ByteArray, mainCallFixupOffset CodeOffset, relocations RelocationArray, globalData GlobalDataTable, targetModule TargetModule, mirModule MirModule, rdata ByteArray, rdataRelocations RdataRelocationArray, symdata ByteArray, covDataSectionBytes ByteArray) returns CodeResult
		return Self{code: code, mainCallFixupOffset: mainCallFixupOffset, relocations: relocations, globalData: globalData, targetModule: targetModule, mirModule: mirModule, rdata: rdata, rdataRelocations: rdataRelocations, symdata: symdata, covDataSectionBytes: covDataSectionBytes, dataPrelude: ByteArray.create(), debugSymbols: DebugSymbolArray.create()}
	end 'create'
end 'CodeResult'

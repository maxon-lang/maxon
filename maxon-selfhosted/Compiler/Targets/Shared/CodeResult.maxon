// Shared types for code emission results, used across all backends.

typealias IatSlotIndex = int(0 to u64.max)

export type IatFixup
    export var codeOffset CodeOffset
    export var iatSlotIndex IatSlotIndex
end 'IatFixup'
export typealias IatFixupArray = Array with IatFixup

export type CallFixup
    export var codeOffset CodeOffset
    export var targetName ByteArray
end 'CallFixup'
export typealias CallFixupArray = Array with CallFixup

// OS-specific fixup data carried through to the executable writer
export union OsFixups
    none
    peFixups(iatFixups IatFixupArray)
end 'OsFixups'

export type CodeResult
    export var code ByteBuffer
    export var mainCallFixupOffset CodeOffset
    export var osFixups OsFixups
end 'CodeResult'

// Shared types for code emission results, used across all backends.

typealias RelocSlotIndex = int(0 to u64.max)

// A relocation records a code location that needs patching after section layout.
// Used for IAT entries (Windows PE) and GOT entries (Linux ELF).
export type Relocation
    export var codeOffset CodeOffset
    export var slotIndex RelocSlotIndex
end 'Relocation'
export typealias RelocationArray = Array with Relocation

export type CallFixup
    export var codeOffset CodeOffset
    export var targetName ByteArray
end 'CallFixup'
export typealias CallFixupArray = Array with CallFixup

export type CodeResult
    export var code ByteArray
    export var mainCallFixupOffset CodeOffset
    export var relocations RelocationArray
end 'CodeResult'

// OS descriptor: pure data describing how to interact with the operating system.
// The CPU emitter consumes this to generate platform-specific stubs.

// How to terminate the process
export union ExitStrategy
	syscall(number MachineWord)
	iatCall(slotIndex MachineWord)
end 'ExitStrategy'

// How to suspend the current thread for N milliseconds. Each variant maps to
// the per-OS primitive used by `osSleep`:
//   * `syscall(nanosleepNumber)` — Linux `nanosleep(2)`. The callee converts ms
//     to a `struct timespec { tv_sec, tv_nsec }` on the stack and passes its
//     address as the first argument; the second argument (rem-timespec) is
//     NULL since we don't support EINTR resume.
//   * `iatCall(sleepSlot)` — Windows kernel32!Sleep (ms argument is passed
//     directly in ecx; no return value to consume). Slot index comes from
//     `iatSlotIndex(IatSlot.sleep)` in PeWriter.maxon.
//   * `libcall(nanosleepSlot)` — macOS libc `nanosleep`. Same calling
//     contract as the Linux syscall but routed through the dyld import slot.
export union SleepStrategy
	syscall(nanosleepNumber MachineWord)
	iatCall(sleepSlot MachineWord)
	libcall(nanosleepSlot MachineWord)
end 'SleepStrategy'

// How to write to stdout
export union WriteStrategy
	syscall(writeNumber MachineWord, fd MachineWord)
	winApi(getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
	libcall(writeSlot MachineWord, fd MachineWord)
end 'WriteStrategy'

// How to read from stdin
export union ReadStrategy
	syscall(readNumber MachineWord, fd MachineWord)
	winApi(getHandleSlot MachineWord, handleConstant MachineWord, readFileSlot MachineWord)
	libcall(readSlot MachineWord, fd MachineWord)
end 'ReadStrategy'

export type OsDescriptor
	export var os as Os
	export var exit as ExitStrategy
	export var write as WriteStrategy
	export var writeErr as WriteStrategy
	export var read as ReadStrategy
	export var sleep as SleepStrategy
	export var startShadowSpace as MachineWord

	export static function create(os Os, exit ExitStrategy, write WriteStrategy, writeErr WriteStrategy, read ReadStrategy, sleep SleepStrategy, startShadowSpace MachineWord) returns OsDescriptor
		return Self{os: os, exit: exit, write: write, writeErr: writeErr, read: read, sleep: sleep, startShadowSpace: startShadowSpace}
	end 'create'
end 'OsDescriptor'

export function makeOsDescriptor(target Target) returns OsDescriptor
	var result = OsDescriptor.create(target.os, exit: ExitStrategy.syscall(0), write: WriteStrategy.syscall(0, fd: 0), writeErr: WriteStrategy.syscall(0, fd: 0), read: ReadStrategy.syscall(0, fd: 0), sleep: SleepStrategy.syscall(0), startShadowSpace: 0)

	match target.os 'pickOs'
		windows then result = makeWindowsDescriptor()
		linux then result = makeLinuxDescriptor(target)
		macos then result = makeMacOsDescriptor()
		wasi then panic("OsDescriptor not used for WASI targets")
	end 'pickOs'

	return result
end 'makeOsDescriptor'

function makeWindowsDescriptor() returns OsDescriptor
	// Windows-targeted strategies route through PE IAT slots resolved by
	// `iatSlotIndex(IatSlot.<case>)` so the per-strategy integers stay in
	// lockstep with PeWriter's slot ordering. Handle constants are
	// STD_OUTPUT_HANDLE = -11 (0xFFFFFFF5), STD_ERROR_HANDLE = -12
	// (0xFFFFFFF4), STD_INPUT_HANDLE = -10 (0xFFFFFFF6).
	let exitSlot = iatSlotIndex(IatSlot.exitProcess)
	let getStdHandle = iatSlotIndex(IatSlot.getStdHandle)
	let writeFile = iatSlotIndex(IatSlot.writeFile)
	let readFile = iatSlotIndex(IatSlot.readFile)
	let sleepSlot = iatSlotIndex(IatSlot.sleep)
	return OsDescriptor.create(Os.windows, exit: ExitStrategy.iatCall(exitSlot), write: WriteStrategy.winApi(getStdHandle, handleConstant: 0xFFFFFFF5, writeFileSlot: writeFile), writeErr: WriteStrategy.winApi(getStdHandle, handleConstant: 0xFFFFFFF4, writeFileSlot: writeFile), read: ReadStrategy.winApi(getStdHandle, handleConstant: 0xFFFFFFF6, readFileSlot: readFile), sleep: SleepStrategy.iatCall(sleepSlot), startShadowSpace: 0x28)
end 'makeWindowsDescriptor'

function makeMacOsDescriptor() returns OsDescriptor
	// macOS dyld slot layout: slot 0 = exit, slot 1 = write, slot 2 = read,
	// slot 3 = nanosleep (libc).
	return OsDescriptor.create(Os.macos, exit: ExitStrategy.iatCall(0), write: WriteStrategy.libcall(1, fd: 1), writeErr: WriteStrategy.libcall(1, fd: 2), read: ReadStrategy.libcall(2, fd: 0), sleep: SleepStrategy.libcall(3), startShadowSpace: 0)
end 'makeMacOsDescriptor'

function makeLinuxDescriptor(target Target) returns OsDescriptor
	let exitNum = match target.cpu 'cpuSyscalls'
		x64 gives 60
		arm64 gives 93
		default panic("Linux descriptor not used for WASM targets")
	end 'cpuSyscalls'
	let writeNum = match target.cpu 'cpuWrite'
		x64 gives 1
		arm64 gives 64
		default panic("Linux descriptor not used for WASM targets")
	end 'cpuWrite'
	let readNum = match target.cpu 'cpuRead'
		x64 gives 0
		arm64 gives 63
		default panic("Linux descriptor not used for WASM targets")
	end 'cpuRead'
	let nanosleepNum = match target.cpu 'cpuNanosleep'
		x64 gives 35
		arm64 gives 101
		default panic("Linux descriptor not used for WASM targets")
	end 'cpuNanosleep'

	return OsDescriptor.create(Os.linux, exit: ExitStrategy.syscall(exitNum), write: WriteStrategy.syscall(writeNum, fd: 1), writeErr: WriteStrategy.syscall(writeNum, fd: 2), read: ReadStrategy.syscall(readNum, fd: 0), sleep: SleepStrategy.syscall(nanosleepNum), startShadowSpace: 0)
end 'makeLinuxDescriptor'

// OS descriptor: pure data describing how to interact with the operating system.
// The CPU emitter consumes this to generate platform-specific stubs.

// How to terminate the process
export enum ExitStrategy
	syscall(number MachineWord)
	iatCall(slotIndex MachineWord)
end 'ExitStrategy'

// How to write to stdout
export enum WriteStrategy
	syscall(writeNumber MachineWord, fd MachineWord)
	winApi(getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
	libcall(writeSlot MachineWord, fd MachineWord)
end 'WriteStrategy'

export type OsDescriptor
	export var exit ExitStrategy
	export var write WriteStrategy
	export var writeErr WriteStrategy
	export var startShadowSpace MachineWord

	export static function create(exit ExitStrategy, write WriteStrategy, writeErr WriteStrategy, startShadowSpace MachineWord) returns OsDescriptor
		return Self{exit: exit, write: write, writeErr: writeErr, startShadowSpace: startShadowSpace}
	end 'create'
end 'OsDescriptor'

export function makeOsDescriptor(target Target) returns OsDescriptor
	var result = OsDescriptor.create(exit: ExitStrategy.syscall(0), write: WriteStrategy.syscall(0, 0), writeErr: WriteStrategy.syscall(0, 0), startShadowSpace: 0)

	match target.os 'pickOs'
		windows then result = makeWindowsDescriptor()
		linux then result = makeLinuxDescriptor(target)
		macos then result = makeMacOsDescriptor()
	end 'pickOs'

	return result
end 'makeOsDescriptor'

function makeWindowsDescriptor() returns OsDescriptor
	return OsDescriptor.create(exit: ExitStrategy.iatCall(0), write: WriteStrategy.winApi(1, 0xFFFFFFF5, 2), writeErr: WriteStrategy.winApi(1, 0xFFFFFFF4, 2), startShadowSpace: 0x28)
end 'makeWindowsDescriptor'

function makeMacOsDescriptor() returns OsDescriptor
	return OsDescriptor.create(exit: ExitStrategy.iatCall(0), write: WriteStrategy.libcall(1, 1), writeErr: WriteStrategy.libcall(1, 2), startShadowSpace: 0)
end 'makeMacOsDescriptor'

function makeLinuxDescriptor(target Target) returns OsDescriptor
	let exitNum = match target.cpu 'cpuSyscalls'
		x86_64 gives 60
		aarch64 gives 93
	end 'cpuSyscalls'
	let writeNum = match target.cpu 'cpuWrite'
		x86_64 gives 1
		aarch64 gives 64
	end 'cpuWrite'

	return OsDescriptor.create(exit: ExitStrategy.syscall(exitNum), write: WriteStrategy.syscall(writeNum, 1), writeErr: WriteStrategy.syscall(writeNum, 2), startShadowSpace: 0)
end 'makeLinuxDescriptor'

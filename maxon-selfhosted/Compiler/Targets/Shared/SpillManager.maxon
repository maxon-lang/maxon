// Spill manager: decides which live ranges to spill and allocates spill slots.
// Uses a greedy approach: sort ranges by spill weight, spill lowest-weight
// ranges until register pressure is within bounds.

export typealias PQEntryArray = Array with PQEntry

let SPILL_SLOT_SIZE = 8

// ============================================================
// Priority queue (binary max-heap by weight)
// ============================================================

export type PQEntry
	export var valueId ValueId
	export var weight RegInt

	export static function create(valueId ValueId, weight RegInt) returns PQEntry
		return Self{valueId: valueId, weight: weight}
	end 'create'
end 'PQEntry'

export type PriorityQueue
	export var entries PQEntryArray

	export static function create() returns PriorityQueue
		return Self{entries: PQEntryArray.create()}
	end 'create'
end 'PriorityQueue'

export function pqInsert(queue PriorityQueue, valueId ValueId, weight RegInt)
	queue.entries.push(PQEntry.create(valueId, weight: weight))
	pqBubbleUp(queue, index: queue.entries.count() - 1)
end 'pqInsert'

export function pqExtractMax(queue PriorityQueue) returns PQEntry
	let count = queue.entries.count()
	if count == 0 'empty'
		return PQEntry.create(0, weight: 0)
	end 'empty'

	let max = try queue.entries.get(0) otherwise PQEntry.create(0, weight: 0)

	if count == 1 'lastEntry'
		try queue.entries.pop() otherwise panic("invariant: count == 1 just checked but pop failed")
		return max
	end 'lastEntry'

	// Move last entry to root and bubble down
	let last = try queue.entries.pop() otherwise PQEntry.create(0, weight: 0)
	try queue.entries.set(0, value: last) otherwise panic("invariant: queue.entries.set OOB")
	pqBubbleDown(queue, index: 0)

	return max
end 'pqExtractMax'

export function pqIsEmpty(queue PriorityQueue) returns bool
	return queue.entries.count() == 0
end 'pqIsEmpty'

function pqBubbleUp(queue PriorityQueue, index RegInt)
	var i = index

	while i > 0 'bubbleUp'
		let parentIdx = (i - 1) / 2
		let current = try queue.entries.get(i) otherwise break
		let parent = try queue.entries.get(parentIdx) otherwise break

		if current.weight <= parent.weight 'inPlace'
			break
		end 'inPlace'

		// Swap
		try queue.entries.set(i, value: parent) otherwise panic("invariant: queue.entries.set OOB")
		try queue.entries.set(parentIdx, value: current) otherwise panic("invariant: queue.entries.set OOB")
		i = parentIdx
	end 'bubbleUp'
end 'pqBubbleUp'

function pqBubbleDown(queue PriorityQueue, index RegInt)
	let count = queue.entries.count()
	var i = index

	while true 'bubbleDown'
		let left = 2 * i + 1
		let right = 2 * i + 2
		var largest = i

		if left < count 'checkLeft'
			let leftEntry = try queue.entries.get(left) otherwise break
			let largestEntry = try queue.entries.get(largest) otherwise break

			if leftEntry.weight > largestEntry.weight 'leftLarger'
				largest = left
			end 'leftLarger'
		end 'checkLeft'

		if right < count 'checkRight'
			let rightEntry = try queue.entries.get(right) otherwise break
			let largestEntry2 = try queue.entries.get(largest) otherwise break

			if rightEntry.weight > largestEntry2.weight 'rightLarger'
				largest = right
			end 'rightLarger'
		end 'checkRight'

		if largest == i 'done'
			break
		end 'done'

		// Swap
		let currentEntry = try queue.entries.get(i) otherwise break
		let largestSwap = try queue.entries.get(largest) otherwise break

		try queue.entries.set(i, value: largestSwap) otherwise panic("invariant: queue.entries.set OOB")
		try queue.entries.set(largest, value: currentEntry) otherwise panic("invariant: queue.entries.set OOB")
		i = largest
	end 'bubbleDown'
end 'pqBubbleDown'

// ============================================================
// Spill decision
// ============================================================

export type SpillDecision
	export var spilledRanges LiveRangeArray
	export var nonSpilledRanges LiveRangeArray
	export var spillSlotAssignment RegIntArray
	export var totalSpillSize RegInt

	export static function create() returns SpillDecision
		return Self{
			spilledRanges: LiveRangeArray.create(),
			nonSpilledRanges: LiveRangeArray.create(),
			spillSlotAssignment: RegIntArray.create(),
			totalSpillSize: 0
		}
	end 'create'
end 'SpillDecision'

// ============================================================
// Public entry point
// ============================================================

// Decide which live ranges to spill based on register pressure.
// Ranges with the lowest spill weight are spilled first.
export function computeSpills(ranges LiveRangeArray, gprPoolSize RegInt, fpPoolSize RegInt) returns SpillDecision
	var decision = SpillDecision.create()

	// Separate ranges by register class
	var gprRanges = LiveRangeArray.create()
	var fpRanges = LiveRangeArray.create()

	for range in ranges 'classify'
		match range.regClass 'rc'
			gpr then gprRanges.push(range)
			fp then fpRanges.push(range)
		end 'rc'
	end 'classify'

	// Process each class independently
	spillClass(gprRanges, poolSize: gprPoolSize, decision: decision)
	spillClass(fpRanges, poolSize: fpPoolSize, decision: decision)

	// Allocate spill slots for spilled ranges
	allocateSpillSlots(decision)

	return decision
end 'computeSpills'

// ============================================================
// Per-class spill decisions
// ============================================================

function spillClass(ranges LiveRangeArray, poolSize RegInt, decision SpillDecision)
	if ranges.count() == 0 'empty'
		return
	end 'empty'

	// Separate fixed-reg ranges (physical register constraints) from virtual ranges.
	// Fixed-reg ranges are pre-colored and don't compete for registers — they just
	// exist as interference markers. They go straight to nonSpilledRanges.
	var virtualRanges = LiveRangeArray.create()
	for range in ranges 'separateFixed'
		if range.fixedReg != RM_NONE 'isFixed'
			decision.nonSpilledRanges.push(range)
		end 'isFixed' else 'isVirtual'
			virtualRanges.push(range)
		end 'isVirtual'
	end 'separateFixed'

	// Compute max register pressure across all program points (virtual ranges only).
	let maxPressure = computeMaxPressure(virtualRanges)

	if maxPressure <= poolSize 'noPressure'
		// No spilling needed — all ranges fit
		for range in virtualRanges 'keepAll'
			decision.nonSpilledRanges.push(range)
		end 'keepAll'
		return
	end 'noPressure'

	// Need to spill. Sort ranges by spill weight (ascending) and spill
	// the lowest-weight ranges until pressure is within bounds.
	let spillCount = maxPressure - poolSize

	// Build a min-heap: lowest weight gets extracted first for spilling
	var minQueue = PriorityQueue.create()
	for range in virtualRanges 'enqueue'
		// Negate weight so the max-heap acts as a min-heap
		pqInsert(minQueue, valueId: range.valueId, weight: 0 - range.spillWeight)
	end 'enqueue'

	// Spill the lowest-weight ranges
	var spilled = 0
	while spilled < spillCount and not pqIsEmpty(minQueue) 'spillLoop'
		let entry = pqExtractMax(minQueue)

		// Find the range for this valueId
		let range = findRangeByValueId(virtualRanges, valueId: entry.valueId)

		if range.valueId == entry.valueId 'found'
			// Skip rematerializable values — they're free to "spill"
			// (just re-emit the constant), so they don't count toward pressure
			if range.isRematerializable 'remat'
				decision.nonSpilledRanges.push(range)
			end 'remat' else 'realSpill'
				decision.spilledRanges.push(range)
				spilled = spilled + 1
			end 'realSpill'
		end 'found'
	end 'spillLoop'

	// Remaining ranges in the queue are non-spilled
	while not pqIsEmpty(minQueue) 'drainQueue'
		let entry = pqExtractMax(minQueue)
		let range = findRangeByValueId(virtualRanges, valueId: entry.valueId)

		if range.valueId == entry.valueId 'found2'
			decision.nonSpilledRanges.push(range)
		end 'found2'
	end 'drainQueue'
end 'spillClass'

// Find a range by valueId (linear scan — fine for now)
function findRangeByValueId(ranges LiveRangeArray, valueId ValueId) returns LiveRange
	for range in ranges 'search'
		if range.valueId == valueId 'found'
			return range
		end 'found'
	end 'search'

	// Return a dummy range if not found
	return LiveRange.create(valueId)
end 'findRangeByValueId'

// ============================================================
// Register pressure computation
// ============================================================

// Compute the maximum number of simultaneously-live ranges at any block boundary.
// A range is "live" at a block boundary if its intervals span that point.
// Simple approach: count how many ranges have an interval in each block,
// then find the max.
function computeMaxPressure(ranges LiveRangeArray) returns RegInt
	// Collect all block IDs from intervals
	var blockPressure = RegIntArray.create()

	for range in ranges 'eachRange'
		for interval in range.intervals 'eachInterval'
			let blockId = interval.blockId

			// Grow array if needed
			while blockPressure.count() <= blockId 'grow'
				blockPressure.push(0)
			end 'grow'

			let current = try blockPressure.get(blockId) otherwise panic("blockPressure: grown to include blockId={blockId} but get failed (count={blockPressure.count()})")
			try blockPressure.set(blockId, value: current + 1) otherwise panic("invariant: blockPressure.set OOB")
		end 'eachInterval'
	end 'eachRange'

	// Find max
	var maxP = 0
	for pressure in blockPressure 'findMax'
		if pressure > maxP 'higher'
			maxP = pressure
		end 'higher'
	end 'findMax'

	return maxP
end 'computeMaxPressure'

// ============================================================
// Spill slot allocation
// ============================================================

// Two ranges interfere iff some block contains an interval from each whose
// half-open [startPos, endPos) ranges overlap. Mirrors the SSAColoring
// interference check.
function rangesInterfere(a LiveRange, b LiveRange) returns bool
	for ai in a.intervals 'eachA'
		for bi in b.intervals 'eachB'
			if ai.blockId == bi.blockId 'sameBlock'
				if ai.startPos < bi.endPos and bi.startPos < ai.endPos 'overlap'
					return true
				end 'overlap'
			end 'sameBlock'
		end 'eachB'
	end 'eachA'
	return false
end 'rangesInterfere'

// Earliest startPos across all of a range's intervals — the global "start
// time" we sort by for linear-scan.
function rangeEarliestStart(range LiveRange) returns RegInt
	var best = i64.max
	for iv in range.intervals 'each'
		if iv.startPos < best 'lower'
			best = iv.startPos
		end 'lower'
	end 'each'
	if best == i64.max 'noIntervals'
		return 0
	end 'noIntervals'
	return best
end 'rangeEarliestStart'

// Pool of stack slots already assigned by linear-scan, available for reuse.
// Each entry tracks the most recent occupant of a slot offset; a new range
// reuses the slot iff it does not interfere with any range that has been
// assigned to that slot so far. (Slot offsets compress liveness from many
// non-interfering ranges into one storage location, so we track the FULL
// set of prior occupants, not just the most recent — sharing slot X among
// {A, B, C} requires C to interfere with neither A nor B.)
type SlotPool
	export var slotOffsets RegIntArray
	export var slotOccupants LiveRangeArrayArray

	export static function create() returns SlotPool
		return Self{slotOffsets: RegIntArray.create(), slotOccupants: LiveRangeArrayArray.create()}
	end 'create'
end 'SlotPool'

typealias LiveRangeArrayArray = Array with LiveRangeArray

// Try to find an existing slot in `pool` whose occupants don't interfere
// with `range`. Returns the slot offset, or -1 if none is reusable.
function findReusableSlot(pool SlotPool, range LiveRange) returns RegInt
	var i = 0
	while i < pool.slotOffsets.count() 'scan'
		let occupants = try pool.slotOccupants.get(i) otherwise panic("invariant: slotOccupants get OOB after count() guard")
		var compatible = true
		for occupant in occupants 'checkEach'
			if rangesInterfere(occupant, b: range) 'conflict'
				compatible = false
				break
			end 'conflict'
		end 'checkEach'
		if compatible 'reuse'
			return try pool.slotOffsets.get(i) otherwise panic("invariant: slotOffsets get OOB after count() guard")
		end 'reuse'
		i = i + 1
	end 'scan'
	return -1
end 'findReusableSlot'

// Add `range` as a new occupant of an existing slot at `offset`.
function recordSlotOccupant(pool SlotPool, offset RegInt, range LiveRange)
	var i = 0
	while i < pool.slotOffsets.count() 'scan'
		let slotOff = try pool.slotOffsets.get(i) otherwise panic("invariant: slotOffsets get OOB after count() guard")
		if slotOff == offset 'match'
			var occupants = try pool.slotOccupants.get(i) otherwise panic("invariant: slotOccupants get OOB after count() guard")
			occupants.push(range)
			try pool.slotOccupants.set(i, value: occupants) otherwise panic("invariant: slotOccupants set OOB after count() guard")
			return
		end 'match'
		i = i + 1
	end 'scan'
	panic("recordSlotOccupant: offset {offset} not found in pool")
end 'recordSlotOccupant'

// Register a freshly-allocated slot in the pool with `range` as its first occupant.
function addNewSlot(pool SlotPool, offset RegInt, range LiveRange)
	pool.slotOffsets.push(offset)
	var occupants = LiveRangeArray.create()
	occupants.push(range)
	pool.slotOccupants.push(occupants)
end 'addNewSlot'

// Sort spilled ranges by earliest startPos (ascending). Returns a permutation
// of indices into `ranges`, leaving the input array untouched. Uses insertion
// sort — spill set sizes here are typically <100, so O(n^2) is fine.
function sortRangesByStart(ranges LiveRangeArray) returns RegIntArray
	let count = ranges.count()
	var order = RegIntArray.create()
	var i = 0
	while i < count 'init'
		order.push(i)
		i = i + 1
	end 'init'

	var si = 1
	while si < count 'sort'
		let keyIdx = try order.get(si) otherwise panic("invariant: order.get OOB during sort")
		let keyRange = try ranges.get(keyIdx) otherwise panic("invariant: ranges.get OOB during sort")
		let keyStart = rangeEarliestStart(keyRange)

		var j = si - 1
		while j >= 0 'insert'
			let jIdx = try order.get(j) otherwise break
			let jRange = try ranges.get(jIdx) otherwise break
			if rangeEarliestStart(jRange) <= keyStart 'inPlace'
				break
			end 'inPlace'
			try order.set(j + 1, value: jIdx) otherwise panic("invariant: order.set OOB")
			j = j - 1
		end 'insert'
		try order.set(j + 1, value: keyIdx) otherwise panic("invariant: order.set OOB")
		si = si + 1
	end 'sort'

	return order
end 'sortRangesByStart'

// Allocate spill slots for ranges of a single regClass using linear-scan
// coloring. Returns the (now-bumped) high-water nextSlotOffset.
function allocateSlotsForClass(ranges LiveRangeArray, decision SpillDecision, nextSlotOffset RegInt) returns RegInt
	if ranges.count() == 0 'empty'
		return nextSlotOffset
	end 'empty'

	let order = sortRangesByStart(ranges)
	var pool = SlotPool.create()
	var watermark = nextSlotOffset

	var oi = 0
	while oi < order.count() 'assign'
		let rangeIdx = try order.get(oi) otherwise panic("invariant: order.get OOB after count() guard")
		let range = try ranges.get(rangeIdx) otherwise panic("invariant: ranges.get OOB during assign")
		let vid = range.valueId
		let reuseOffset = findReusableSlot(pool, range: range)
		var chosenOffset = 0
		if reuseOffset >= 0 'gotReuse'
			chosenOffset = reuseOffset
			recordSlotOccupant(pool, offset: chosenOffset, range: range)
		end 'gotReuse' else 'allocateNew'
			chosenOffset = watermark
			watermark = watermark + SPILL_SLOT_SIZE
			addNewSlot(pool, offset: chosenOffset, range: range)
		end 'allocateNew'

		if vid < decision.spillSlotAssignment.count() 'inBounds'
			try decision.spillSlotAssignment.set(vid, value: chosenOffset) otherwise panic("invariant: decision.spillSlotAssignment.set OOB")
		end 'inBounds'
		oi = oi + 1
	end 'assign'

	return watermark
end 'allocateSlotsForClass'

export function allocateSpillSlots(decision SpillDecision)
	// Find max valueId to size the assignment array
	var maxValueId = 0
	for range in decision.spilledRanges 'findMax'
		if range.valueId > maxValueId 'higher'
			maxValueId = range.valueId
		end 'higher'
	end 'findMax'

	// Initialize assignment array
	while decision.spillSlotAssignment.count() <= maxValueId 'grow'
		decision.spillSlotAssignment.push(RM_NO_STACK_HOME)
	end 'grow'

	// Partition ranges by regClass. Slots are shared only within a class so
	// reload-op selection (gpr mov vs xmm movsd) still matches the value at
	// every use site.
	var gprRanges = LiveRangeArray.create()
	var fpRanges = LiveRangeArray.create()
	for range in decision.spilledRanges 'partition'
		match range.regClass 'rc'
			gpr then gprRanges.push(range)
			fp then fpRanges.push(range)
		end 'rc'
	end 'partition'

	var nextSlotOffset = 0
	nextSlotOffset = allocateSlotsForClass(gprRanges, decision: decision, nextSlotOffset: nextSlotOffset)
	nextSlotOffset = allocateSlotsForClass(fpRanges, decision: decision, nextSlotOffset: nextSlotOffset)

	decision.totalSpillSize = nextSlotOffset
	logDebug(LogCategory.ir, message: () gives "spill-mgr: slots={decision.spilledRanges.count()} totalBytes={nextSlotOffset}")
end 'allocateSpillSlots'

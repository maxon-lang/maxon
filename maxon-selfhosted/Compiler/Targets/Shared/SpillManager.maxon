// Spill manager: owns the SpillDecision data type, the spill-slot allocator
// (allocateSpillSlots / allocateSlotsForClass), the interference query used
// for slot coalescing, and the markRematerialize helper. The actual
// spill-vs-keep decisions live in RegisterAllocator's runSpillColorLoop,
// which constructs a SpillDecision incrementally per spill iteration.

let SPILL_SLOT_SIZE = 8

// ============================================================
// Spill decision
// ============================================================

export type SpillDecision
	export var spilledRanges as LiveRangeArray
	export var nonSpilledRanges as LiveRangeArray
	export var spillSlotAssignment as RegIntArray
	export var totalSpillSize as RegInt
	// Bitmap of vregs minted by this round of insertSpillCode as reload
	// destinations. Indexed by valueId. Populated by insertSpillCode (via
	// SpillInsertState.reloadIds) and consumed by FunctionRegAllocator,
	// which unions every iteration's reloads into a cumulative set so
	// reload ranges get infinite spill weight on every subsequent
	// rebuild of liveness/ranges.
	export var reloadIds as BoolArray
	// Bitmap of vregs that should be rematerialized (re-emitted as a
	// constant load) at each use rather than spilled to a stack slot.
	// Populated by the spill loop's Pass 2 (via markRematerialize) for
	// ranges flagged isRematerializable, and by insertSpillCode for the
	// fresh vregs it mints at each remat use.
	// Indexed by valueId. Consumed by FunctionRegAllocator, which unions
	// every iteration's remats into a cumulative set so rebuilt
	// LiveRanges keep isRematerializable=true and constantValue.
	export var rematerializeIds as BoolArray
	// Sidetable from valueId to the constant value to materialize at each
	// use. Populated alongside rematerializeIds. Sparse: entries past the
	// last rematerializable valueId default to 0 via getOr.
	export var rematerializeValue as RegIntArray

	export static function create() returns SpillDecision
		return Self{
			spilledRanges: LiveRangeArray.create(),
			nonSpilledRanges: LiveRangeArray.create(),
			spillSlotAssignment: RegIntArray.create(),
			totalSpillSize: 0,
			reloadIds: BoolArray.create(),
			rematerializeIds: BoolArray.create(),
			rematerializeValue: RegIntArray.create()
		}
	end 'create'
end 'SpillDecision'

// ============================================================
// Rematerialization marking
// ============================================================

// Mark `valueId` as one that should be rematerialized at each use, and
// stash the constant value to materialize. Called by the spill loop when
// a range that *would* be spilled is rematerializable — instead of
// allocating a stack slot, we record "re-emit this constant" so the
// spill code insertion phase can emit a fresh `movRegImm` at every use.
export function markRematerialize(decision SpillDecision, valueId ValueId, value RegInt)
	while decision.rematerializeIds.count() <= valueId 'growIds'
		decision.rematerializeIds.push(false)
	end 'growIds'
	while decision.rematerializeValue.count() <= valueId 'growVal'
		decision.rematerializeValue.push(0)
	end 'growVal'
	try decision.rematerializeIds.set(valueId, value: true) otherwise panic("invariant: rematerializeIds.set OOB after grow")
	try decision.rematerializeValue.set(valueId, value: value) otherwise panic("invariant: rematerializeValue.set OOB after grow")
end 'markRematerialize'

// ============================================================
// Spill slot allocation
// ============================================================

// Two ranges interfere iff some block contains an interval from each whose
// half-open [startPos, endPos) ranges overlap. Mirrors the SSAColoring
// interference check.
function rangesInterfere(a LiveRange, b LiveRange) returns bool
	for ai in a.intervals 'eachA'
		for bi in b.intervals 'eachB'
			if ai.blockId == bi.blockId 'sameBlock'
				if ai.startPos < bi.endPos and bi.startPos < ai.endPos 'overlap'
					return true
				end 'overlap'
			end 'sameBlock'
		end 'eachB'
	end 'eachA'
	return false
end 'rangesInterfere'

// Earliest startPos across all of a range's intervals — the global "start
// time" we sort by for linear-scan.
function rangeEarliestStart(range LiveRange) returns RegInt
	var best = i64.max
	for iv in range.intervals 'each'
		if iv.startPos < best 'lower'
			best = iv.startPos
		end 'lower'
	end 'each'
	if best == i64.max 'noIntervals'
		return 0
	end 'noIntervals'
	return best
end 'rangeEarliestStart'

// Pool of stack slots already assigned by linear-scan, available for reuse.
// Each entry tracks the most recent occupant of a slot offset; a new range
// reuses the slot iff it does not interfere with any range that has been
// assigned to that slot so far. (Slot offsets compress liveness from many
// non-interfering ranges into one storage location, so we track the FULL
// set of prior occupants, not just the most recent — sharing slot X among
// {A, B, C} requires C to interfere with neither A nor B.)
type SlotPool
	export var slotOffsets as RegIntArray
	export var slotOccupants as LiveRangeArrayArray

	export static function create() returns SlotPool
		return Self{slotOffsets: RegIntArray.create(), slotOccupants: LiveRangeArrayArray.create()}
	end 'create'
end 'SlotPool'

typealias LiveRangeArrayArray = Array with LiveRangeArray

// Try to find an existing slot in `pool` whose occupants don't interfere
// with `range`. Returns the slot offset, or -1 if none is reusable.
function findReusableSlot(pool SlotPool, range LiveRange) returns RegInt
	var i = 0
	while i < pool.slotOffsets.count() 'scan'
		let occupants = try pool.slotOccupants.get(i) otherwise panic("invariant: slotOccupants get OOB after count() guard")
		var compatible = true
		for occupant in occupants 'checkEach'
			if rangesInterfere(occupant, b: range) 'conflict'
				compatible = false
				break
			end 'conflict'
		end 'checkEach'
		if compatible 'reuse'
			return try pool.slotOffsets.get(i) otherwise panic("invariant: slotOffsets get OOB after count() guard")
		end 'reuse'
		i = i + 1
	end 'scan'
	return -1
end 'findReusableSlot'

// Add `range` as a new occupant of an existing slot at `offset`.
function recordSlotOccupant(pool SlotPool, offset RegInt, range LiveRange)
	var i = 0
	while i < pool.slotOffsets.count() 'scan'
		let slotOff = try pool.slotOffsets.get(i) otherwise panic("invariant: slotOffsets get OOB after count() guard")
		if slotOff == offset 'match'
			var occupants = try pool.slotOccupants.get(i) otherwise panic("invariant: slotOccupants get OOB after count() guard")
			occupants.push(range)
			try pool.slotOccupants.set(i, value: occupants) otherwise panic("invariant: slotOccupants set OOB after count() guard")
			return
		end 'match'
		i = i + 1
	end 'scan'
	panic("recordSlotOccupant: offset {offset} not found in pool")
end 'recordSlotOccupant'

// Register a freshly-allocated slot in the pool with `range` as its first occupant.
function addNewSlot(pool SlotPool, offset RegInt, range LiveRange)
	pool.slotOffsets.push(offset)
	var occupants = LiveRangeArray.create()
	occupants.push(range)
	pool.slotOccupants.push(occupants)
end 'addNewSlot'

// Sort spilled ranges by earliest startPos (ascending). Returns a permutation
// of indices into `ranges`, leaving the input array untouched. Uses insertion
// sort — spill set sizes here are typically <100, so O(n^2) is fine.
function sortRangesByStart(ranges LiveRangeArray) returns RegIntArray
	let count = ranges.count()
	var order = RegIntArray.create()
	var i = 0
	while i < count 'init'
		order.push(i)
		i = i + 1
	end 'init'

	var si = 1
	while si < count 'sort'
		let keyIdx = try order.get(si) otherwise panic("invariant: order.get OOB during sort")
		let keyRange = try ranges.get(keyIdx) otherwise panic("invariant: ranges.get OOB during sort")
		let keyStart = rangeEarliestStart(keyRange)

		var j = si - 1
		while j >= 0 'insert'
			let jIdx = try order.get(j) otherwise break
			let jRange = try ranges.get(jIdx) otherwise break
			if rangeEarliestStart(jRange) <= keyStart 'inPlace'
				break
			end 'inPlace'
			try order.set(j + 1, value: jIdx) otherwise panic("invariant: order.set OOB")
			j = j - 1
		end 'insert'
		try order.set(j + 1, value: keyIdx) otherwise panic("invariant: order.set OOB")
		si = si + 1
	end 'sort'

	return order
end 'sortRangesByStart'

// Allocate spill slots for ranges of a single regClass using linear-scan
// coloring. Returns the (now-bumped) high-water nextSlotOffset.
function allocateSlotsForClass(ranges LiveRangeArray, decision SpillDecision, nextSlotOffset RegInt) returns RegInt
	if ranges.count() == 0 'empty'
		return nextSlotOffset
	end 'empty'

	let order = sortRangesByStart(ranges)
	var pool = SlotPool.create()
	var watermark = nextSlotOffset

	var oi = 0
	while oi < order.count() 'assign'
		let rangeIdx = try order.get(oi) otherwise panic("invariant: order.get OOB after count() guard")
		let range = try ranges.get(rangeIdx) otherwise panic("invariant: ranges.get OOB during assign")
		let vid = range.valueId
		let reuseOffset = findReusableSlot(pool, range: range)
		var chosenOffset = 0
		if reuseOffset >= 0 'gotReuse'
			chosenOffset = reuseOffset
			recordSlotOccupant(pool, offset: chosenOffset, range: range)
		end 'gotReuse' else 'allocateNew'
			chosenOffset = watermark
			watermark = watermark + SPILL_SLOT_SIZE
			addNewSlot(pool, offset: chosenOffset, range: range)
		end 'allocateNew'

		if vid < decision.spillSlotAssignment.count() 'inBounds'
			try decision.spillSlotAssignment.set(vid, value: chosenOffset) otherwise panic("invariant: decision.spillSlotAssignment.set OOB")
		end 'inBounds'

		logTrace(LogCategory.ir, message: function() gives "spill-slot: %{vid} -> off={chosenOffset} reused={reuseOffset >= 0} start={rangeEarliestStart(range)} intervals={range.intervals.count()}")
		oi = oi + 1
	end 'assign'

	return watermark
end 'allocateSlotsForClass'

// Allocate spill slot offsets for the ranges in `decision`. `baseOffset` is
// the running high-water mark across PREVIOUS spill iterations of the same
// function — fresh slot offsets start there so iteration N's slots never
// collide with iteration N-1's. Returns the new high-water mark (caller
// passes it back as `baseOffset` on the next iteration).
export function allocateSpillSlots(decision SpillDecision, baseOffset RegInt) returns RegInt
	// Find max valueId to size the assignment array
	var maxValueId = 0
	for range in decision.spilledRanges 'findMax'
		if range.valueId > maxValueId 'higher'
			maxValueId = range.valueId
		end 'higher'
	end 'findMax'

	// Initialize assignment array
	while decision.spillSlotAssignment.count() <= maxValueId 'grow'
		decision.spillSlotAssignment.push(RM_NO_STACK_HOME)
	end 'grow'

	// Partition ranges by regClass. Slots are shared only within a class so
	// reload-op selection (gpr mov vs xmm movsd) still matches the value at
	// every use site.
	var gprRanges = LiveRangeArray.create()
	var fpRanges = LiveRangeArray.create()
	for range in decision.spilledRanges 'partition'
		match range.regClass 'rc'
			gpr then gprRanges.push(range)
			fp then fpRanges.push(range)
		end 'rc'
	end 'partition'

	var nextSlotOffset = baseOffset
	nextSlotOffset = allocateSlotsForClass(gprRanges, decision: decision, nextSlotOffset: nextSlotOffset)
	nextSlotOffset = allocateSlotsForClass(fpRanges, decision: decision, nextSlotOffset: nextSlotOffset)

	decision.totalSpillSize = nextSlotOffset - baseOffset
	logDebug(LogCategory.ir, message: function() gives "spill-mgr: slots={decision.spilledRanges.count()} totalBytes={decision.totalSpillSize} base={baseOffset} watermark={nextSlotOffset}")
	return nextSlotOffset
end 'allocateSpillSlots'

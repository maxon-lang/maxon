// Single dispatch point for all CPU+OS backend combinations.
// CPU emitters consume OsDescriptor to handle OS differences — no CPU*OS dispatch needed.

export function emitBackend(module MlirModule, target Target) returns CodeResult throws CompileError
    let osDesc = makeOsDescriptor(target)
    var result = CodeResult{code: ByteArray{}, mainCallFixupOffset: 0, relocations: RelocationArray{}}
    match target.cpu 'cpu'
        CpuArch.x86_64 then result = emitX86(lowerMidToMaxX64(module, target: target), target: target, osDesc: osDesc)
        CpuArch.aarch64 then result = emitMaxArm64(lowerMidToMaxArm64(module, target: target), target: target, osDesc: osDesc)
    end 'cpu'
    return result
end 'emitBackend'

export function writeExecutable(outputPath String, codeResult CodeResult, target Target)
    match target.os 'os'
        Os.windows then writePe(outputPath, codeResult: codeResult, target: target)
        Os.linux then writeElf(outputPath, codeResult: codeResult, target: target)
    end 'os'
end 'writeExecutable'

// Single dispatch point for all CPU+OS backend combinations.
// CPU emitters consume OsDescriptor to handle OS differences -- no CPU*OS dispatch needed.
// Runtime functions (mrt_write_stdout, mrt_i64_to_string, mrt_start) are prepended
// to the module as mid-level IR before target-specific lowering.
// The runtime is loaded from runtime.std (text-based IR) by MidLevelParser.
//
// Target-specific behavior is abstracted behind the TargetBackend interface.
// Each public function that needs target dispatch has a single match that
// creates the concrete backend type and passes it to a helper function
// accepting a TargetBackend parameter — the compiler monomorphizes the helper
// for each concrete type.

// Parsed runtime.std module, cached for the process lifetime. The runtime
// source is a build-time input that cannot change mid-process, so a simple
// one-shot parse is safe — no revision tracking needed. Callers get back a
// shared reference; each pipeline pass merges a filtered copy into its own
// StdModule via augmentWithRuntime, so the cached value stays read-only.
//
// The cache stores the runtime in **post-mem2reg form**: parsing produces
// raw `memref.storeSlot`/`loadSlot` ops on every param + local, and we
// promote those to SSA once at first load instead of re-running mem2reg
// on every compile (or, on wasm, after every `augmentWithRuntime` splice).
// Promoting at cache-load time helps both backends:
//   - native: runtime function bodies reach codegen with values in SSA
//     locals instead of round-tripping through stack slots — fewer
//     mem accesses per call into mrt_alloc / mrt_strcmp / etc.
//   - wasm: runtime callees no longer carry param-init storeSlot ops
//     into the shared `stackBase` slot region, so they can't clobber
//     the caller's frame slots — fixes the closure-self correctness
//     bug without needing a second mem2reg pass downstream.
var cachedRuntimeModule = StdModule.create()
var runtimeModuleLoaded = false

export function loadRuntimeModule() returns StdModule
	if runtimeModuleLoaded 'cached'
		return cachedRuntimeModule
	end 'cached'

	let runtimePath = findRuntimePath()
	if runtimePath.isEmpty() 'noRuntime'
		panic("Cannot find runtime.std -- searched up from current directory")
	end 'noRuntime'

	let source = try File.readText(runtimePath) otherwise panic("Failed to read runtime.std at {runtimePath}")

	var parsed = try parseStdModule(source, startValueId: 0) otherwise panic("Failed to parse runtime.std at {runtimePath}")
	cachedRuntimeModule = promoteMem2Reg(parsed)
	runtimeModuleLoaded = true
	return cachedRuntimeModule
end 'loadRuntimeModule'

// True when `name` is a function defined in `runtime.std`. Used to identify
// runtime-defined names cheaply against the parsed runtime module. The
// native stdlib cache now bakes most runtime bodies into the cache — the
// linker pulls them in by name when user code references them. The wasm
// cache still strips runtime bodies (the user pipeline supplies them).
export function isRuntimeFunctionName(name String) returns bool
	let runtimeModule = loadRuntimeModule()
	for func in runtimeModule.functions 'check'
		if func.name == name 'match'
			return true
		end 'match'
	end 'check'
	return false
end 'isRuntimeFunctionName'

// True for the entry-point variants. These two are emitted fresh per user
// compile because each project's `__module_init_*` calls are patched into
// `mrt_start`'s entry block (`patchMrtStartWithModuleInits`) — caching a
// pre-patched body would bind it to whichever project's inits ran during
// the cache build.
export function isStartFunctionName(name String) returns bool
	return name == "mrt_start" or name == "mrt_start_with_coverage"
end 'isStartFunctionName'

// True for runtime functions that must be emitted fresh per user compile
// rather than served from the stdlib cache. Two categories qualify:
//   1. Entry-point variants — see isStartFunctionName.
//   2. Coverage helpers (mrt_cov_hit, mrt_cov_dump). Their bodies reference
//      the `__data_cov_*` globals, which `augmentWithRuntime` registers
//      only when `project.coverageEnabled` is true. The stdlib cache is
//      built with coverage off, so caching these bodies would bake in
//      unresolved global references that wouldn't relocate against the
//      coverage-on user compile's globalData layout.
// The remaining ~46 runtime functions (mrt_panic, mrt_write_*, __slab_*,
// mm_*, __managed_mem_*, __layout_word_*, __destruct___ManagedMemory) are
// project-independent and live in the cache.
export function isPerCompileRuntimeName(name String) returns bool
	return isStartFunctionName(name) or name == "mrt_cov_hit" or name == "mrt_cov_dump"
end 'isPerCompileRuntimeName'

export function findRuntimePath() returns FilePath
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		// Look for maxon-selfhosted/Compiler/Runtime/runtime.std
		let candidate = dir.join("maxon-selfhosted").join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate) 'found'
			return candidate
		end 'found'
		// Also check Compiler/Runtime/runtime.std (if we're inside maxon-selfhosted)
		let candidate2 = dir.join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate2) 'found2'
			return candidate2
		end 'found2'
		// Also check Runtime/runtime.std (if we're inside Compiler)
		let candidate3 = dir.join("Runtime").join("runtime.std")
		if File.exists(candidate3) 'found3'
			return candidate3
		end 'found3'
		// Also check runtime.std directly
		let candidate4 = dir.join("runtime.std")
		if File.exists(candidate4) 'found4'
			return candidate4
		end 'found4'
		// dir.parent() returns no value at the filesystem root; bail out with empty path.
		let parentDir = try dir.parent() otherwise return FilePath from ""
		dir = parentDir
	end 'search'
	return FilePath from ""
end 'findRuntimePath'

// Prepends runtime functions from runtime.std to a user module.
// Runtime functions are expressed as Std-level IR and will be lowered by
// the backend just like user functions.
//
// Coverage-related runtime functions (mrt_cov_hit, mrt_cov_dump,
// mrt_start_with_coverage) live in runtime.std so StdParser can validate them
// at compiler-startup time. They are selectively retained or dropped based on
// project.coverageEnabled:
//   - coverage off: strip all three (non-coverage builds don't need them and
//     keeping them forces every backend to lower unused OS primitives).
//   - coverage on: rename `mrt_start_with_coverage` to `mrt_start` (the entry
//     symbol the linker looks for), strip the original `mrt_start`, and keep
//     `mrt_cov_hit` / `mrt_cov_dump` reachable from the coverage-aware start.
//     Also reserves the `__data_cov_*` globals so the counter array and site
//     count are visible to the backend's data-section emission.
//
// Per-function dispatch note: `augmentWithRuntime` is inherently
// **whole-module** and is not eligible for per-function dispatch. It runs
// a transitive call-graph walk (`filterRuntimeByReachability`) starting
// from the user module's `call` ops and chasing edges through both user-
// defined and runtime helpers to compute the closure of actually-reachable
// runtime functions. The walk is interprocedural — knowing whether
// `__slab_init` is reachable requires seeing every user call op plus the
// call edges inside `mrt_start`, `mrt_panic`, etc. A per-function entry
// point would have to re-walk the entire graph for each function (no win)
// or rely on a pre-computed closure (the closure IS the whole-module
// operation). It therefore stays classified as `wholeModule` in
// `PassPipeline.classifyPass` and runs once at the head of the MIR-tier
// section of `dispatch()`, feeding its augmented `StdModule` to the
// downstream per-function lowering / MIR passes.
export function augmentWithRuntime(module StdModule, project Project) returns StdModule
	let runtimeModule = loadRuntimeModule()
	let covFilteredRuntime = filterRuntimeForCoverage(runtimeModule, coverageEnabled: project.coverageEnabled)
	// Stage B.2 (d43069642): reachability-prune the runtime. After OS /
	// coverage filtering the runtime module still carries every helper
	// the project might ever need (~62 entries). Most user binaries reach
	// only a handful — a hello-world style test pulls in `mrt_start`,
	// `__slab_init`, `mrt_panic`. We walk the user module's call edges
	// + transitively walk runtime helpers' call edges, and trim the
	// runtime to that closure. This makes cache-off and cache-on paths
	// emit the same set of runtime functions for the same user program.
	let filteredRuntime = filterRuntimeByReachability(covFilteredRuntime, userModule: module, target: project.target, globalData: project.globalData)
	if project.coverageEnabled 'reserveGlobals'
		// Register the coverage globals once per compile, after instrumentation
		// has finalized the site count but before backend emission reads the
		// data section layout.
		registerCoverageGlobals(project.globalData, numSites: project.covSites.nextId)
	end 'reserveGlobals'
	var augmented = StdModule.create()
	// On native targets, when the stdlib cache is valid it already holds
	// the runtime ObjectFunctions, so the user pipeline only needs the
	// per-compile bodies (entry point + coverage helpers) merged in for
	// real lowering — every other runtime call resolves to a cached body
	// at link time. Trimming here means the user pipeline's lowerStdToMir,
	// MIR passes, target lowering, and regalloc don't pay for ~46 runtime
	// functions on every compile. The wasm cache build doesn't include
	// runtime bodies (call_indirect's inline type-section index would need
	// a fixup mechanism to be portable across cache and link), so on wasm
	// we always merge the full filtered runtime.
	let cacheHasRuntimeBodies = isStdlibCacheValid() and project.target.cpu != CpuArch.wasm32
	if cacheHasRuntimeBodies 'trimToPerCompile'
		augmented.merge(buildUserSideRuntime(filteredRuntime))
		augmented.merge(module)
	end 'trimToPerCompile' else 'mergeFullRuntime'
		// Cache-bypass / wasm path: mimic the cache-on emission order so
		// the resulting `.text` section is byte-identical for the same
		// user program. Cache-on emits in this order:
		//   1. user-side runtime (`mrt_start` + coverage helpers)
		//   2. user module (just `main` + `__module_init_*`; user
		//      pipeline doesn't lower stdlib in cache-on mode)
		//   3. `linkX64StdlibFunctions` appends cached stdlib bodies
		//   4. cache-side runtime stays in cache (referenced via fixups)
		//
		// Cache-off has stdlib lowered in the user `module` itself, so
		// we split it into user-code + stdlib slices and emit:
		//   1. user-side runtime
		//   2. user-code-only slice of `module`
		//   3. stdlib slice of `module`            (mirrors step 3)
		//   4. cache-side runtime                  (mirrors step 4)
		let userOnly = filterModuleByStdlibNamespace(module, keepStdlib: false)
		let stdlibOnly = filterModuleByStdlibNamespace(module, keepStdlib: true)
		augmented.merge(buildUserSideRuntime(filteredRuntime))
		augmented.merge(userOnly)
		augmented.merge(stdlibOnly)
		augmented.merge(buildCacheSideRuntime(filteredRuntime))
	end 'mergeFullRuntime'
	// After merge, mrt_start has body `[__slab_init, main, osExit, ret]`.
	// Each per-file `__module_init_<n>` function (registered in
	// `project.moduleInitFuncs` by the parser) materializes that file's
	// top-level array literals into their .data slots. The runtime entry
	// point must call them in registration order before main, otherwise
	// user code reading the global slot sees zero. The user module never
	// references these inits via a normal `call` op, so the patch is the
	// only path that wires them up.
	patchMrtStartWithModuleInits(augmented, project: project)
	return augmented
end 'augmentWithRuntime'

typealias RuntimeReachSet = Set with String
typealias RuntimeFuncByName = Map with (String, IrFunction)

// Stage B.2 (d43069642): reachability filter for the runtime module.
// Walks the user module's call/funcRef/funcAddr edges to seed which
// runtime names are demanded, then transitively walks the runtime
// functions themselves (runtime helpers call each other —
// `mm_alloc` reaches `__slab_alloc`, `mrt_panic` reaches
// `mrt_panic_print_frame`, etc.) until no new names are pulled in.
// `mrt_start` is unconditionally seeded because it's the binary entry
// point invoked by the OS, not by any in-module call op. `mrt_panic`
// is also seeded because backends emit literal `call mrt_panic` for
// range-check guards regardless of whether user IR has a matching call
// edge yet.
function filterRuntimeByReachability(runtime StdModule, userModule StdModule, target Target, globalData GlobalDataTable) returns StdModule
	let cpu = target.cpu
	var runtimeMap = RuntimeFuncByName.create()
	for func in runtime.functions 'buildRuntimeMap'
		runtimeMap.upsert(func.name, value: func)
	end 'buildRuntimeMap'

	var seen = RuntimeReachSet.create()
	var worklist = StringArray.create()
	// `mrt_start` is unconditionally seeded — it's the binary entry point
	// invoked by the OS, not by any in-module call op. Everything else
	// (including `mrt_panic`) must be reached through real call edges
	// from user code or stdlib bodies; that keeps cache-off in lockstep
	// with cache-on's link-time reachability, which seeds from user
	// call fixups only.
	seedRuntimeReachName("mrt_start", runtimeMap: runtimeMap, seen: seen, worklist: worklist)

	// Phase B1+B2: the X64 Windows backend emits hand-rolled `mrt_win32_*`
	// helpers unconditionally as raw machine bytes after concat. Those bytes
	// contain `call rel32` fixups to runtime functions (`mrt_alloc`, `mm_decref`)
	// which need to resolve in both cache-off and cache-on legs. Seed those
	// transitive deps here so cache-off compiles the runtime dependencies
	// just like cache-on's link-time fixup walk would.
	if target.cpu == CpuArch.x64 and target.os == Os.windows 'win32Helpers'
		seedRuntimeReachName("mrt_alloc", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		seedRuntimeReachName("mm_decref", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'win32Helpers'
	for func in userModule.functions 'eachUserFunc'
		collectRuntimeReachFromFunc(userModule, func: func, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'eachUserFunc'

	// When the stdlib cache is valid, its pre-compiled bodies are spliced
	// into the user binary at link time. Those bodies call runtime helpers
	// by name (e.g. `__managed_mem_grow` from `stdlib/Internals.maxon`
	// emits a `call mm_realloc` op at lowering time, which lives in the
	// cached body's `callFixups`). The user pipeline can't see those calls
	// — they're in cached machine code, not in `userModule.functions` —
	// so we seed from cached `callFixups` here. To stay in lockstep with
	// the linker (which only pulls in cached bodies transitively reachable
	// from the user's calls), we first compute the needed-stdlib set from
	// user-module callees, then walk only those cached bodies' fixups.
	// Walking the entire cache would re-anchor runtime helpers via stdlib
	// functions the user never reaches (e.g. a Math.pow-only program would
	// otherwise pull in `mm_alloc` via every cached String / Map helper).
	if isStdlibCacheValid() 'cacheValid'
		var userCalleeSeeds = collectUserCalleeSeeds(userModule)
		// Layout/witness descriptor entries reach cached thunk bodies via
		// `funcAbs64InRdata` relocs registered by BuildLayoutDescriptors /
		// BuildWitnessTables — those thunks aren't named by any Std-level
		// `call` op (they're invoked indirectly through the descriptor at
		// runtime) so the cache-side reachability walk wouldn't pull them
		// in otherwise. The wasm emitter's `computeNeededWasmStdlibFunctions`
		// makes the same seed contribution at MIR time; mirroring it here
		// keeps the two reachability sets in sync.
		appendFuncAbs64Seeds(userCalleeSeeds, relocs: globalData.pendingRdataRelocs)
		seedFromCacheCallees(cpu, userCalleeSeeds: userCalleeSeeds, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'cacheValid'

	var i = 0
	while i < worklist.count() 'walk'
		let name = (try worklist.get(i) otherwise panic("filterRuntimeByReachability: worklist.get OOB at {i}")).clone()
		if let func = try runtimeMap.get(name) 'isRuntime'
			collectRuntimeReachFromFunc(runtime, func: func, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		end 'isRuntime'
		seedRuntimeBackendEdges(name, cpu: cpu, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		i = i + 1
	end 'walk'

	// Phase D4: the fifteen `mrt_win32_*` helpers (twelve file/dir I/O +
	// three argv/exec-path) are now emitted as raw machine code by
	// `emitX64Win32Helpers` (x64) / `emitArm64Win32Helpers` (arm64) — they
	// have no IR bodies in `runtime.std`, so no name-based seeding is
	// needed. The transitive runtime deps (`mrt_alloc` / `mm_decref`) that
	// the x64 hand-rolled bodies emit `call rel32` against are seeded above
	// in the `win32Helpers` block, which feeds them into the main walk loop.

	var trimmed = cloneRuntimeShellSharingBodies(runtime)
	for func in runtime.functions 'filter'
		if seen.contains(func.name) 'keep'
			trimmed.functions.push(func)
		end 'keep' else 'drop'
			logTrace(LogCategory.ir, message: function() gives "augmentWithRuntime: dropping unreachable runtime function '{func.name}'")
		end 'drop'
	end 'filter'
	return trimmed
end 'filterRuntimeByReachability'

function seedRuntimeReachName(name String, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	if seen.contains(name) 'already'
		return
	end 'already'
	if not runtimeMap.contains(name) 'notInRuntime'
		return
	end 'notInRuntime'
	seen.insert(name)
	worklist.push(name)
end 'seedRuntimeReachName'

// Per-arch seed for runtime DCE: every callFixup on a NEEDED cached function
// (either `ObjectFunction.callFixups` for native or
// `WasmObjectFunction.callFixups` for wasm) names a callee. If the callee is a
// runtime function (e.g. `mm_realloc` called from `__managed_mem_grow`'s
// cached body), seed it into the runtime DCE worklist. "Needed" means
// transitively reachable from `userCalleeSeeds` through the cache's call /
// funcAddr / adr fixup graph — same computation the linker / wasm emitter
// uses to decide which cached bodies to actually splice in. Restricting the
// walk to needed bodies keeps the runtime DCE in lockstep with link-time
// reachability so programs that never reach an allocator-touching stdlib
// helper don't carry the slab/MM runtime along for the ride.
function seedFromCacheCallees(cpu CpuArch, userCalleeSeeds StringArray, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	let cacheData = getStdlibCacheData()
	match cpu 'arch'
		x64 to arm64 then seedFromNativeCacheFixups(cacheData.functions, needed: computeNeededStdlibFunctions(userCalleeSeeds, stdlibCache: cacheData), runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		wasm32 then seedFromWasmCacheFixups(cacheData.wasmFunctions, needed: computeNeededStdlibFunctionsWasm(userCalleeSeeds, stdlibCache: cacheData), runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'arch'
end 'seedFromCacheCallees'

// `ObjectFunction` and `WasmObjectFunction` are distinct types with the same
// `name`/`callFixups` shape, so the per-arch fixup walkers are mechanically
// identical but can't share a body without a common interface for the
// fixup-bearing array element. Keeping them separate is the cost of avoiding
// a one-use interface.
function seedFromNativeCacheFixups(functions ObjectFunctionArray, needed StdlibFuncNameSet, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	for func in functions 'eachCacheFunc'
		if not needed.contains(func.name) 'skipUnneeded'
			continue
		end 'skipUnneeded'
		for fixup in func.callFixups 'eachFixup'
			seedRuntimeReachName(fixup.targetName, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		end 'eachFixup'
	end 'eachCacheFunc'
end 'seedFromNativeCacheFixups'

function seedFromWasmCacheFixups(functions WasmObjectFunctionArray, needed StdlibFuncNameSet, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	for func in functions 'eachCacheFunc'
		if not needed.contains(func.name) 'skipUnneeded'
			continue
		end 'skipUnneeded'
		for fixup in func.callFixups 'eachFixup'
			seedRuntimeReachName(fixup.targetName, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		end 'eachFixup'
	end 'eachCacheFunc'
end 'seedFromWasmCacheFixups'

// Collect every callee name from the user `module`'s Std-level ops. Both
// stdlib and non-stdlib names are returned — the caller filters via the
// stdlib cache's name index. Used by `seedFromCacheCallees` to seed the
// linker-parity reachability walk.
function collectUserCalleeSeeds(module StdModule) returns StringArray
	var seeds = StringArray.create()
	for func in module.functions 'eachFunc'
		appendStdCalleesInFunc(module, func: func, seeds: seeds)
	end 'eachFunc'
	return seeds
end 'collectUserCalleeSeeds'

// Walk every op (body + terminator) in `func` and push every direct-call,
// funcRef, and funcAddr callee name into `seeds`. Shared by `collectUser-
// CalleeSeeds` (which feeds the cache-side reachability walk) and `collect-
// RuntimeReachFromFunc` (which then filters via `seedRuntimeReachName`).
function appendStdCalleesInFunc(module StdModule, func IrFunction, seeds StringArray)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("appendStdCalleesInFunc: blockRef {blockRef} not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			appendCalleeFromStdOp(module, opIdx: opIdx, seeds: seeds)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			appendCalleeFromStdOp(module, opIdx: block.terminatorIndex(), seeds: seeds)
		end 'hasTerm'
	end 'eachBlock'
end 'appendStdCalleesInFunc'

function appendCalleeFromStdOp(module StdModule, opIdx OpIndex, seeds StringArray)
	let op = try module.ops.get(opIdx) otherwise panic("appendCalleeFromStdOp: opIdx {opIdx} not in module.ops")
	match op 'shape'
		call(inner) then appendCalleeFromStdCallOp(inner, seeds: seeds)
		system(inner) then appendCalleeFromStdSystemOp(inner, seeds: seeds)
		arith then return
		control then return
		memory then return
	end 'shape'
end 'appendCalleeFromStdOp'

function appendCalleeFromStdCallOp(op StdCallOp, seeds StringArray)
	match op 'kind'
		ret then return
		call(_, callee, _) then seeds.push(callee)
		tryCall(_, callee, _, _) then seeds.push(callee)
		tailCall(callee, _) then seeds.push(callee)
		funcRef(_, funcName) then seeds.push(funcName)
		indirectCall then return
		witnessCall then return
		witnessTryCall then return
		param then return
		errorReturn then return
	end 'kind'
end 'appendCalleeFromStdCallOp'

// Only `funcAddr` names a runtime function; every other system-op arm
// operates on register values or named rdata/data blobs which the runtime
// split doesn't care about (those are pruned separately by
// `pruneDeadGlobalData`).
function appendCalleeFromStdSystemOp(op StdSystemOp, seeds StringArray)
	match op 'kind'
		globalAddr then return
		loadLayoutDescriptor then return
		loadWitnessTable then return
		memcpy to loadIndirect then return
		funcAddr(_, funcName) then seeds.push(funcName)
		storeIndirect to unboxValue then return
		descriptorField to dropTypeParam then return
	end 'kind'
end 'appendCalleeFromStdSystemOp'

// Wasm backend emits per-runtime-function bodies that call OTHER runtime
// functions by name at codegen time (after augmentWithRuntime). The
// in-body reachability walk doesn't see these post-augment edges, so
// codify them here so DCE keeps the wasm-side callees alive whenever
// their caller does. Native (x64-windows / x64-linux / arm64-macos)
// emits the bodies as written, so the IR walk catches every edge and
// this hook is a no-op there.
function seedRuntimeBackendEdges(funcName String, cpu CpuArch, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	match cpu 'arch'
		x64 to arm64 then return
		wasm32 then seedRuntimeBackendEdgesWasm(funcName, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'arch'
end 'seedRuntimeBackendEdges'

function seedRuntimeBackendEdgesWasm(funcName String, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	// MirToWasm's emitWasm* helpers synthesize calls into other runtime
	// functions from the wasm-side body of each caller below. The IR
	// bodies stored in `runtime.std` don't show these edges (the wasm
	// bodies are emitted afresh post-augment), so DCE needs them wired
	// here. Transitive edges are reached via the outer worklist, so each
	// entry below lists only its direct callees.
	if funcName == "mrt_executable_path" 'isExePath'
		seedRuntimeReachName("mrt_command_line_arg", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'isExePath' else if funcName == "mrt_command_line_arg" 'isCmdLineArg'
		seedRuntimeReachName("mrt_alloc", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
		seedRuntimeReachName("__managed_mem_create", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'isCmdLineArg' else if funcName == "mrt_command_line_count" 'isCmdLineCount'
		seedRuntimeReachName("mrt_alloc", runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'isCmdLineCount'
end 'seedRuntimeBackendEdgesWasm'

// Walk every op in `func`'s body. For each call/tryCall/tailCall/funcRef/
// funcAddr op whose callee names a runtime function, add the runtime
// function to the reachability set. Non-runtime callees are ignored —
// `seedRuntimeReachName` does the filter — but we collect them first via
// the same op-walker the cache-side seed path uses, so the two reachability
// sets are guaranteed to see the same edges.
function collectRuntimeReachFromFunc(module StdModule, func IrFunction, runtimeMap RuntimeFuncByName, seen RuntimeReachSet, worklist StringArray)
	var callees = StringArray.create()
	appendStdCalleesInFunc(module, func: func, seeds: callees)
	for name in callees 'eachCallee'
		seedRuntimeReachName(name, runtimeMap: runtimeMap, seen: seen, worklist: worklist)
	end 'eachCallee'
end 'collectRuntimeReachFromFunc'

// Splits the runtime module along the per-compile boundary. The cache-side
// caller wants the project-independent functions baked into the stdlib
// cache (mrt_panic, mrt_write_*, __slab_*, mm_*, __managed_mem_*,
// __layout_word_*, __destruct___ManagedMemory). The user-side caller wants
// only the per-compile names (entry-point + coverage helpers — see
// `isPerCompileRuntimeName`) so the user pipeline lowers them with the
// project's coverage globals and `__module_init_*` patches in scope.
//
// Sharing block/op arrays with `source` is safe because every consumer
// runs the result through `IrModule.merge`, which clones blocks and
// rebases op indices into its destination module.
//
// Including signature-only stubs on the user side would add zero-blockRefs
// functions to the user pipeline's targetModule.functions — the per-
// function backend loop records each function's start label at the current
// code offset, so a stub at zero bytes claims a label slot the linker
// subsequently has to retarget, leaving stale entries in the symbol table.
// That's why the user-side filter accepts ONLY the per-compile names rather
// than mirroring the cache-side filter and dropping them.
export function buildCacheSideRuntime(source StdModule) returns StdModule
	return splitRuntimeBySide(source, keepPerCompile: false)
end 'buildCacheSideRuntime'

function buildUserSideRuntime(source StdModule) returns StdModule
	return splitRuntimeBySide(source, keepPerCompile: true)
end 'buildUserSideRuntime'

function splitRuntimeBySide(source StdModule, keepPerCompile bool) returns StdModule
	var trimmed = cloneRuntimeShellSharingBodies(source)
	for func in source.functions 'eachFunc'
		if isPerCompileRuntimeName(func.name) == keepPerCompile 'keep'
			trimmed.functions.push(func)
		end 'keep'
	end 'eachFunc'
	return trimmed
end 'splitRuntimeBySide'

// Split a user module into stdlib-namespace and user-code-namespace
// slices, sharing block/op storage with the source (caller-side merge
// rebases the references). Used by `augmentWithRuntime`'s cache-bypass
// path to lay out stdlib functions AFTER user code, matching the
// emission order of the cache-on path (which appends cached stdlib via
// `linkX64StdlibFunctions` after user-code emission).
function filterModuleByStdlibNamespace(source StdModule, keepStdlib bool) returns StdModule
	var trimmed = cloneRuntimeShellSharingBodies(source)
	for func in source.functions 'eachFunc'
		let isStdlib = isStdlibNamespace(func.namespace)
		if isStdlib == keepStdlib 'keep'
			trimmed.functions.push(func)
		end 'keep'
	end 'eachFunc'
	return trimmed
end 'filterModuleByStdlibNamespace'

// Build an empty-functions StdModule whose `ops`, `blocks`, and
// `blockSourceInfo` arrays share entries with the source. Callers fill in
// `functions` themselves with whichever subset they need, then the result
// is consumed by `IrModule.merge`, which clones blocks and rebases op
// indices into its destination — making the shared-reference approach
// safe even if the destination later mutates ops or blocks.
function cloneRuntimeShellSharingBodies(source StdModule) returns StdModule
	var shell = StdModule.create()
	shell.ops.append(source.ops)
	for i in 0 upto source.blocks.count() 'copyBlocks'
		let block = try source.blocks.get(i) otherwise panic("cloneRuntimeShellSharingBodies: blocks.get out of bounds")
		shell.blocks.push(block)
		let info = try source.blockSourceInfo.get(i) otherwise BlockSourceInfo.empty()
		shell.blockSourceInfo.push(info)
	end 'copyBlocks'
	return shell
end 'cloneRuntimeShellSharingBodies'

// Insert `std call __module_init_<n>` ops into mrt_start's entry block,
// just before the existing `call main` op. No-op when the project has no
// module-init functions registered. Allocates ValueIds above the current
// max so the inserts don't collide with existing op result ids.
function patchMrtStartWithModuleInits(module StdModule, project Project)
	if project.moduleInitFuncs.count() == 0 'noInits'
		return
	end 'noInits'
	// Skip the whole patch path when every entry is a placeholder reserved
	// by `seedModuleInitFuncsFromLivenessRoots`. Without this check, the
	// scan + ValueId allocation in `insertModuleInitCalls` still runs (even
	// though no `call` op gets inserted), and the heap-allocated ValueIdRef
	// it constructs perturbs downstream id assignment — making cache-on
	// binaries byte-diverge from cache-off binaries that filter the same
	// dead inits out of `moduleInitFuncs` entirely.
	var hasReal = false
	for n in project.moduleInitFuncs 'checkAny'
		if not n.isEmpty() 'real'
			hasReal = true
			break
		end 'real'
	end 'checkAny'
	if not hasReal 'allPlaceholders'
		return
	end 'allPlaceholders'
	for func in module.functions 'findStart'
		if func.name != "mrt_start" 'notStart'
			continue
		end 'notStart'
		// mrt_start has a single block ('entry') so the first blockRef is the
		// one we want. The runtime never branches inside mrt_start.
		if func.blockRefs.count() == 0 'noBlocks'
			panic("patchMrtStartWithModuleInits: mrt_start has no blocks")
		end 'noBlocks'
		let entryBlockRef = try func.blockRefs.get(0) otherwise panic("patchMrtStartWithModuleInits: blockRefs.get(0) OOB")
		let entryBlock = try module.blocks.get(entryBlockRef) otherwise panic("patchMrtStartWithModuleInits: blocks.get OOB at {entryBlockRef}")
		insertModuleInitCalls(module, func: func, block: entryBlock, project: project)
		return
	end 'findStart'
	panic("patchMrtStartWithModuleInits: mrt_start function not in module after augmentWithRuntime")
end 'patchMrtStartWithModuleInits'

// Find the position in entryBlock.opRefs of the `call main` op and insert
// fresh `call __module_init_<n>` ops immediately before it. The list-based
// opRefs supports insert-at-index, so the original op order around the
// insertion is preserved. ValueIds are minted from a per-function counter
// seeded above the current max so we never reuse an existing id.
function insertModuleInitCalls(module StdModule, func IrFunction, block IrBlock, project Project)
	var mainCallPos = 0 as ParsedInt
	var foundMain = false
	for i in 0 upto block.opRefs.count() 'each'
		let opIdx = try block.opRefs.get(i) otherwise panic("insertModuleInitCalls: opRefs.get OOB at {i}")
		let op = try module.ops.get(opIdx) otherwise panic("insertModuleInitCalls: ops.get OOB at {opIdx}")
		if isCallToMain(op) 'isMain'
			mainCallPos = i
			foundMain = true
			break
		end 'isMain'
	end 'each'
	if not foundMain 'noMain'
		panic("patchMrtStartWithModuleInits: could not locate `call main` in mrt_start entry block")
	end 'noMain'
	let valueIdRef = ValueIdRef.create(scanMaxValueId(func, module: module) + 1)
	var insertAt = mainCallPos
	for name in project.moduleInitFuncs 'eachInit'
		// Placeholder slots reserved by `seedModuleInitFuncsFromLivenessRoots`
		// to push the user parser's `__module_init_<n>` numbering past the
		// stdlib init names baked into the cached function table. They carry
		// no callable function — skip them.
		if name.isEmpty() 'placeholder'
			continue
		end 'placeholder'
		let resultId = allocValueId(valueIdRef)
		let opIdx = module.ops.count()
		module.ops.push(StdOp.call(StdCallOp.call(resultId, callee: name, argIds: ValueIdArray.create())))
		try block.opRefs.insert(insertAt, value: opIdx) otherwise panic("insertModuleInitCalls: opRefs.insert failed at {insertAt}")
		insertAt = insertAt + 1
	end 'eachInit'
end 'insertModuleInitCalls'

function isCallToMain(op StdOp) returns bool
	return match op 'shape'
		call(c) gives stdCallOpIsCallTo(c, name: "main")
		arith gives false
		control gives false
		memory gives false
		system gives false
	end 'shape'
end 'isCallToMain'

function stdCallOpIsCallTo(inner StdCallOp, name String) returns bool
	return match inner 'callShape'
		call(_, callee, _) gives callee == name
		ret gives false
		tryCall gives false
		indirectCall gives false
		witnessCall gives false
		witnessTryCall gives false
		funcRef gives false
		tailCall gives false
		param gives false
		errorReturn gives false
	end 'callShape'
end 'stdCallOpIsCallTo'

// Filter the loaded runtime module's function list based on whether coverage
// instrumentation is active. Blocks and ops stay put in the arrays (dropping
// them there would require renumbering every op/block reference in every
// retained function) — only the function list is pruned.
//
// The backend emitters place code in functions-list order and assume
// `mrt_start` lives at code offset 0 (the PE/ELF entry point RVA), so the
// coverage-on branch is careful to keep the renamed start at the front of
// the filtered list even though `mrt_start_with_coverage` appears last in
// runtime.std.
function filterRuntimeForCoverage(module StdModule, coverageEnabled bool) returns StdModule
	var filtered = cloneRuntimeShellSharingBodies(module)
	// First pass: when coverage is on, emit the renamed coverage-start as the
	// very first function so it wins the entry-point slot. Skip over it in the
	// main pass below so it isn't pushed twice. u64.max is the sentinel meaning
	// "no index" — no real function will have that many entries ahead of it.
	var coverageStartIdx = u64.max
	if coverageEnabled 'promoteStart'
		for funcIdx in 0 upto module.functions.count() 'find'
			let func = try module.functions.get(funcIdx) otherwise panic("filterRuntimeForCoverage: functions.get out of bounds")
			if func.name == "mrt_start_with_coverage" 'match'
				// Clone before renaming — `module` is the shared cached runtime
				// module and struct .get returns a reference. Mutating `func.name`
				// directly would bleed the rename back into subsequent calls.
				// `cloneWithBlockRefs` carries the body's blockRefs across so
				// the renamed function lowers like a real entry point — bare
				// `clone` would drop them and the backend would emit a zero-
				// byte symbol at offset 0, hiding `mrt_start` behind whichever
				// runtime function got emitted next.
				var renamed = IrFunction.cloneWithBlockRefs(func)
				renamed.name = "mrt_start"
				filtered.functions.push(renamed)
				coverageStartIdx = funcIdx
				break
			end 'match'
		end 'find'
	end 'promoteStart'
	for funcIdx in 0 upto module.functions.count() 'copyFuncs'
		if funcIdx == coverageStartIdx 'alreadyEmitted'
			continue
		end 'alreadyEmitted'
		let func = try module.functions.get(funcIdx) otherwise panic("filterRuntimeForCoverage: functions.get out of bounds")
		if coverageEnabled 'covOn'
			// Drop the original non-coverage start: its role has been taken
			// over by the renamed coverage-start emitted above.
			if func.name == "mrt_start" 'dropDefaultStart'
				continue
			end 'dropDefaultStart'
		end 'covOn' else 'covOff'
			if isCoverageRuntimeFunction(func.name) 'skip'
				continue
			end 'skip'
		end 'covOff'
		filtered.functions.push(func)
	end 'copyFuncs'
	return filtered
end 'filterRuntimeForCoverage'

function isCoverageRuntimeFunction(name String) returns bool
	return name == "mrt_cov_hit" or name == "mrt_cov_dump" or name == "mrt_start_with_coverage"
end 'isCoverageRuntimeFunction'

// Backend execution driven by the pipeline.
// Phases 5-7 (augmentWithRuntime, lowerStdToMir, scheduleInstructions,
// lowerMirToTarget, allocateRegisters, insertPrologueEpilogue) run through
// the PassPipeline; then code emission converts the final target ops to
// machine code bytes. For WASM: branches from MIR directly — skips target
// lowering, regalloc, and scheduling.
export function emitBackend(stdModule StdModule, target Target, globalData GlobalDataTable, project Project, stdlibCache StdlibCacheData) returns CodeResult throws CompileError
	var pipeline = try buildNativeOrWasmPipeline(stdModule, target: target, globalData: globalData, project: project)
	if target.cpu == CpuArch.wasm32 'isWasm'
		return emitWasmCodeResult(pipeline, globalData: globalData)
	end 'isWasm'

	// `registerPanicStrings` mutates `globalData` and was previously called
	// at the top of `X64Backend.emitTargetCode` / `Arm64Backend.emitTargetCode`.
	// Lifted into the dispatch layer so both this whole-module path and the
	// chunk-driven `emitBackendIncremental` call it exactly once — the chunk
	// path can pull pre-emitted chunks from `db.codePerFunc` without going
	// through `emitTargetCode` at all, so the registration must happen here.
	registerPanicStrings(globalData)

	// Phase 7: target lowering + regalloc + prologue/epilogue + code emission
	// Create the backend once with all state, then pass it through.
	match target.cpu 'dispatchCpu'
		x64 then return try emitBackendWith(pipeline, stdlibCache: stdlibCache, backend: X64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		arm64 then return try emitBackendWith(pipeline, stdlibCache: stdlibCache, backend: Arm64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		wasm32 then panic("unreachable: WASM handled above")
	end 'dispatchCpu'
end 'emitBackend'

// Chunk-driven sibling of `emitBackend` (Phase 11.5 / Stage P Step 2). Native
// targets here pull each function's `FunctionCodeChunk` from the per-function
// query cache (`db.codePerFunc`) — concat then reassembles `.text` with the
// same stdlib link / rdata / symbol-table post-process as the whole-module
// path, so the bytes are identical. The whole-module path remains the
// authoritative cold-build emitter (it stamps the cache via Step 1); the
// chunk path turns subsequent same-`Project` rebuilds into N cache reads +
// one concat. WASM stays on the whole-module driver: Stage O.5 notes WASM is
// structurally per-function but the chunk-driven rollout is PE-only, so the
// wasm branch delegates to `emitBackend` unchanged.
export function emitBackendIncremental(stdModule StdModule, target Target, globalData GlobalDataTable, project Project, stdlibCache StdlibCacheData) returns CodeResult throws CompileError
	if target.cpu == CpuArch.wasm32 'isWasm'
		// The chunk-driven path is PE-only per Stage O.5. Hand WASM back to
		// the whole-module driver so the chunk-driven path stays focused on
		// native.
		return try emitBackend(stdModule, target: target, globalData: globalData, project: project, stdlibCache: stdlibCache)
	end 'isWasm'

	var pipeline = try buildNativeOrWasmPipeline(stdModule, target: target, globalData: globalData, project: project)

	// Mirror `emitBackend`'s single registration of panic strings — see the
	// comment there for why this lives in the dispatch layer.
	registerPanicStrings(globalData)

	match target.cpu 'dispatchCpu'
		x64 then return try emitBackendIncrementalWith(pipeline, stdlibCache: stdlibCache, backend: X64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		arm64 then return try emitBackendIncrementalWith(pipeline, stdlibCache: stdlibCache, backend: Arm64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		wasm32 then panic("unreachable: WASM handled above")
	end 'dispatchCpu'
end 'emitBackendIncremental'

// Build the `PassPipeline` shared by `emitBackend` and `emitBackendIncremental`:
// the pre-emit lowering work (augmentWithRuntime, lowerStdToMir,
// commuteForCoalescing, scheduleInstructions for native; the WASM-only
// pipeline otherwise). Returning the populated pipeline lets both callers
// dispatch their own emit strategy without re-running the lowering passes.
function buildNativeOrWasmPipeline(stdModule StdModule, target Target, globalData GlobalDataTable, project Project) returns PassPipeline throws CompileError
	var pipeline = PassPipeline.create(MaxonModule.create(), project: project, globalData: globalData, target: target, sourceFileName: "")
	pipeline.stdModule = stdModule

	if target.cpu == CpuArch.wasm32 'isWasm'
		// WASM pipeline: only augmentWithRuntime + lowerStdToMir, then the
		// caller emits directly from MIR — no target lowering / regalloc.
		pipeline.addPasses(buildWasmBackendPipeline())
		try pipeline.run()
		return pipeline
	end 'isWasm'

	// Native pipeline: run Phases 5-6 (Std→MIR + MIR passes)
	pipeline.addPass(PassKind.augmentWithRuntime)
	pipeline.addPass(PassKind.lowerStdToMir)
	pipeline.addPass(PassKind.commuteForCoalescing)
	pipeline.addPass(PassKind.scheduleInstructions)
	try pipeline.run()
	return pipeline
end 'buildNativeOrWasmPipeline'

// Build the WASM `CodeResult` from a pipeline whose MIR module is fully
// lowered. Factored out of `emitBackend` so both the whole-module and
// chunk-driven paths can short-circuit through the same shape for WASM.
// `targetModule` stays an empty dummy because WASM never reaches the
// target-lowering phase — downstream readers consume `mirModule` instead.
function emitWasmCodeResult(pipeline PassPipeline, globalData GlobalDataTable) returns CodeResult
	return CodeResult.create(ByteArray.create(), mainCallFixupOffset: 0, relocations: RelocationArray.create(), globalData: globalData, targetModule: TargetModule.create(CpuArch.x64), mirModule: pipeline.mirModule, rdata: ByteArray.create(), rdataRelocations: RdataRelocationArray.create(), symdata: ByteArray.create(), covDataSectionBytes: ByteArray.create())
end 'emitWasmCodeResult'

// Run the target-lowering / regalloc / prologue-epilogue passes on a
// freshly-built backend. Shared by `emitBackendWith` (whole-module emit) and
// `emitBackendIncrementalWith` (chunk-driven emit) so the prepared
// `pipeline.targetModule` is byte-identical between the two paths.
function prepareTargetModule(pipeline PassPipeline, backend TargetBackend) throws CompileError
	logDebug(LogCategory.ir, message: function() gives "=== Running pass: lower-mir-to-target ===")
	let lmtStart = passTimerStart()
	pipeline.targetModule = backend.lowerMirToTarget()
	recordPassSince("__lowerMirToTarget", startMs: lmtStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "lower-mir-to-target"))

	// Register allocation (target-independent)
	logDebug(LogCategory.ir, message: function() gives "=== Running pass: allocate-registers ===")
	let regStart = passTimerStart()
	pipeline.targetModule = allocateRegisters(pipeline.targetModule, target: pipeline.target)
	recordPassSince("__allocateRegisters", startMs: regStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "allocate-registers"))

	// Prologue/epilogue insertion (uses backend for target-specific ops)
	logDebug(LogCategory.ir, message: function() gives "=== Running pass: insert-prologue-epilogue ===")
	let peStart = passTimerStart()
	insertPrologueEpilogueWith(pipeline.targetModule, backend: backend)
	recordPassSince("__insertPrologueEpilogue", startMs: peStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "insert-prologue-epilogue"))
end 'prepareTargetModule'

function emitBackendWith(pipeline PassPipeline, stdlibCache StdlibCacheData, backend TargetBackend) returns CodeResult throws CompileError
	try prepareTargetModule(pipeline, backend: backend)

	// Emit machine code from the fully-lowered target module
	let emitStart = passTimerStart()
	var result = backend.emitTargetCode(pipeline.project, stdlibCache: stdlibCache)
	recordPassSince("__emitTargetCode", startMs: emitStart)
	result.targetModule = pipeline.targetModule
	return result
end 'emitBackendWith'

// Chunk-driven counterpart to `emitBackendWith`. After the shared
// `prepareTargetModule` populates `pipeline.targetModule`, this loops over
// the function list and assembles each function's `FunctionCodeChunk` from
// `db.codePerFunc`. Concat then rebases every fixup and runs the same stdlib
// link / rdata / symbol post-process as the whole-module path, so the
// resulting `.text` and `.rdata` bytes are identical between the two emit
// strategies.
//
// Step 3 (recursion break): the miss path emits the function chunk directly
// via `backend.emitFunctionChunk(func)` rather than recursing through
// `queryCodeForFunction` → `queryCodeResult` → `dispatchBackendEmit` →
// `emitBackendIncremental` (which would loop). Calling
// `queryCodeForFunction` from here was the load-bearing recursion bug Step 2
// flagged; with this direct-emit miss tail the chunk-driven path is self-
// contained — every chunk either hits the per-function cache or gets
// computed inline, and the result is stamped into `db.codePerFunc` so the
// next same-`Project` rebuild hits.
//
// Per-function dep tracking still flows: `assembleFunctionChunk` records
// each `codeForFunction(funcName)` dep against the active `codeResult`
// query (pushed by `queryCodeResult` before it called us) regardless of
// hit-vs-miss. The outer `queryCodeResult` cache thereby learns "this
// whole-binary result depends on each function chunk" without any function
// chunk depending on the whole-binary result. Step 3.5a moved per-function
// invalidation off the dep graph and onto a content-hash comparison inside
// `lookupCachedChunkByKeyHash`, so the outer codeResult dep is the only
// signal flowing through the dep graph itself.
function emitBackendIncrementalWith(pipeline PassPipeline, stdlibCache StdlibCacheData, backend TargetBackend) returns CodeResult throws CompileError
	// Stage P Step 3.5b: pre-compute cache hits / misses BEFORE running the
	// expensive target-lowering / regalloc / prologue-epilogue pipeline. The
	// chunk for a cache-hit function carries its target-lowered bytes baked
	// in (stamped on cold compile), so re-running Phase 7 on those functions
	// just to throw the work away on the per-function emit was the regalloc
	// bottleneck Step 4 traced (`__regalloc-user: ~127ms per invocation` on
	// the 100-function synthetic). Restricting Phase 7 to the miss set drops
	// the warm-rebuild cost roughly linearly in (1 / N) for N-function edits.
	var freshKeyHashByName = StringContentHashMap.create()
	var missFuncs = IrFunctionArray.create()
	for func in pipeline.mirModule.functions 'precheck'
		// Record the per-function dep here so the outer `queryCodeResult`
		// memo knows the whole-binary result transitively depends on each
		// function chunk — same edge `assembleFunctionChunk` would have
		// recorded on the post-prepareTargetModule loop.
		recordDependency(pipeline.project, dependency: QueryKey.codeForFunction(func.name))
		// Refresh the per-function content hash off the freshly-rebuilt
		// queryAllMid so the chunk-cache validator sees the post-edit shape.
		// Runtime / stdlib helpers (`mrt_*`, `__slab_*`, …) aren't in
		// queryAllMid's StdModule — the refresh is a no-op for those names,
		// and their chunk memos rely on the stable `mix(0, mirPassVersion,
		// backendVersion)` keyHash.
		try refreshMidContentHashForFunction(pipeline.project, funcName: func.name)
		let freshKeyHash = computeChunkKeyHash(pipeline.project, funcName: func.name)
		freshKeyHashByName.upsert(func.name, value: freshKeyHash)
		if isCachedChunkValid(pipeline.project, funcName: func.name, freshKeyHash: freshKeyHash) 'isHit'
			continue
		end 'isHit'
		missFuncs.push(func)
	end 'precheck'

	// Only run the target-lowering pipeline when there's at least one cache
	// miss — a same-source rebuild after a no-op edit gets a free pass.
	if missFuncs.count() > 0 'hasMisses'
		try prepareTargetModuleForFunctions(pipeline, backend: backend, funcsToLower: missFuncs)
	end 'hasMisses'

	let emitStart = passTimerStart()
	var chunks = FunctionCodeChunkArray.create()
	// Assemble in `mirModule.functions` order — the same order target-lowering
	// would have emitted them in on a cold compile — so concat lays bytes out
	// byte-identically across the two emission strategies.
	for func in pipeline.mirModule.functions 'collect'
		let freshKeyHash = try freshKeyHashByName.get(func.name) otherwise panic("emitBackendIncrementalWith: freshKeyHashByName missing entry for '{func.name}'")
		if let hit = try lookupCachedChunkByKeyHash(pipeline.project, funcName: func.name, freshKeyHash: freshKeyHash) 'cached'
			chunks.push(hit)
			continue
		end 'cached'
		// Miss tail: pull the freshly-target-lowered IrFunction out of the
		// backend's `targetModule.functions` (populated by the
		// `prepareTargetModuleForFunctions` call above) and emit its chunk.
		// The lookup is a linear scan, but `targetModule.functions` is the
		// miss set only — typically one function on a single-edit rebuild —
		// so the cost is negligible.
		let targetFunc = try findTargetFuncByName(pipeline.targetModule, name: func.name) otherwise panic("emitBackendIncrementalWith: missing target func '{func.name}' after prepareTargetModuleForFunctions ({pipeline.targetModule.functions.count()} lowered)")
		pipeline.project.db.codePerFuncMisses = pipeline.project.db.codePerFuncMisses + 1
		let chunk = backend.emitFunctionChunk(targetFunc)
		stampChunkMemo(pipeline.project, funcName: func.name, chunk: chunk)
		chunks.push(chunk)
	end 'collect'

	var result = concatFunctionChunksForTarget(chunks, targetModule: pipeline.targetModule, mirModule: pipeline.mirModule, globalData: pipeline.globalData, stdlibCache: stdlibCache, target: pipeline.target)
	recordPassSince("__emitTargetCode", startMs: emitStart)
	result.targetModule = pipeline.targetModule
	return result
end 'emitBackendIncrementalWith'

// Stage P Step 3.5b: chunk-cache hit predicate that mirrors
// `lookupCachedChunkByKeyHash`'s validation but does NOT touch the hit
// counter or refresh `verifiedAt`. Used by the pre-check loop in
// `emitBackendIncrementalWith` to bucket functions into hit/miss before any
// chunks are actually pulled — the real hit counter increments later when
// the assembly loop calls `lookupCachedChunkByKeyHash` on each hit.
function isCachedChunkValid(project Project, funcName String, freshKeyHash ContentHash) returns bool
	if let memo = try project.db.codePerFunc.get(funcName) 'checkCache'
		if memo.computedAt > 0 and memo.keyHash == freshKeyHash 'valid'
			return true
		end 'valid'
	end 'checkCache'
	return false
end 'isCachedChunkValid'

// Stage P Step 3.5b: linear lookup over `targetModule.functions`. The lookup
// is called once per cache-miss function; on a single-function-edit rebuild
// (the dominant warm-rebuild shape) there's exactly one miss and one entry to
// scan. Used by the chunk-driven path to find the target-lowered IrFunction
// corresponding to a MIR function whose chunk needs fresh emission.
function findTargetFuncByName(targetModule TargetModule, name String) returns IrFunction throws ChunkCacheLookupError
	for func in targetModule.functions 'scan'
		if func.name == name 'match'
			return func
		end 'match'
	end 'scan'
	throw ChunkCacheLookupError.miss
end 'findTargetFuncByName'

// Stage P Step 3.5b: chunk-driven Phase 7 driver. Same as `prepareTargetModule`
// but restricts target lowering / regalloc / prologue-epilogue to
// `funcsToLower`. Regalloc and prologue/epilogue iterate
// `targetModule.functions` and therefore self-limit to the miss subset once
// `lowerMirToTargetForFunctions` populated it with only those entries.
function prepareTargetModuleForFunctions(pipeline PassPipeline, backend TargetBackend, funcsToLower IrFunctionArray) throws CompileError
	logDebug(LogCategory.ir, message: function() gives "=== Running pass: lower-mir-to-target (subset: {funcsToLower.count()} functions) ===")
	let lmtStart = passTimerStart()
	pipeline.targetModule = backend.lowerMirToTargetForFunctions(funcsToLower)
	recordPassSince("__lowerMirToTarget", startMs: lmtStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "lower-mir-to-target"))

	logDebug(LogCategory.ir, message: function() gives "=== Running pass: allocate-registers (subset) ===")
	let regStart = passTimerStart()
	pipeline.targetModule = allocateRegisters(pipeline.targetModule, target: pipeline.target)
	recordPassSince("__allocateRegisters", startMs: regStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "allocate-registers"))

	logDebug(LogCategory.ir, message: function() gives "=== Running pass: insert-prologue-epilogue (subset) ===")
	let peStart = passTimerStart()
	insertPrologueEpilogueWith(pipeline.targetModule, backend: backend)
	recordPassSince("__insertPrologueEpilogue", startMs: peStart)
	logTrace(LogCategory.ir, message: function() gives dumpTargetSummary(pipeline.targetModule, passName: "insert-prologue-epilogue"))
end 'prepareTargetModuleForFunctions'

typealias StringContentHashMap = Map with (String, ContentHash)

// Per-CPU dispatch for the chunk concat helpers. The two backends carry
// distinct fixup vocabularies (ARM64 has ADR fixups; X64 doesn't) so the
// concat functions live in their respective backend modules. WASM is
// unreachable here because `emitBackendIncremental` delegates wasm builds
// to the whole-module driver before this point.
function concatFunctionChunksForTarget(chunks FunctionCodeChunkArray, targetModule TargetModule, mirModule MirModule, globalData GlobalDataTable, stdlibCache StdlibCacheData, target Target) returns CodeResult
	return match target.cpu 'cpu'
		x64 gives concatX64FunctionChunks(chunks, targetModule: targetModule, mirModule: mirModule, globalData: globalData, stdlibCache: stdlibCache, os: target.os)
		arm64 gives concatArm64FunctionChunks(chunks, targetModule: targetModule, mirModule: mirModule, globalData: globalData, stdlibCache: stdlibCache, target: target)
		wasm32 panic("unreachable: emitBackendIncremental delegates WASM to emitBackend")
	end 'cpu'
end 'concatFunctionChunksForTarget'

function dumpTargetSummary(module TargetModule, passName String) returns String
	return dumpModuleSummary(module.functions.count(), blockCount: module.blocks.count(), opCount: module.x64Ops.count() + module.arm64Ops.count(), dialect: module.cpu.name, passName: passName)
end 'dumpTargetSummary'

export function createLatencyTable(target Target) returns TargetLatencyTable
	return match target.cpu 'cpu'
		x64 gives X64Backend.createLatencyTable()
		arm64 gives Arm64Backend.createLatencyTable()
		default panic("latency table not used for WASM targets")
	end 'cpu'
end 'createLatencyTable'

// Latency lookup for a MIR op by its index in the MirModule. The instruction
// scheduler calls this per op to drive its critical-path heuristic.
export function getMirLatencyPacked(module MirModule, packed OpIndex, table TargetLatencyTable) returns Latency
	let mirOp = try module.ops.get(packed) otherwise panic("invariant: packed opIdx not in module.ops")
	return getMirLatency(mirOp, table: table)
end 'getMirLatencyPacked'

// MIR-level latency estimates, parameterized by the target's latency table
// so division and other high-variance ops reflect the actual target CPU.
function getMirLatency(op MirOp, table TargetLatencyTable) returns Latency
	return match op 'dispatch'
		movImm gives 1
		movReg gives 1
		binOp(_, _, _, opcode) gives getMirBinOpLatency(opcode, table: table)
		unaryOp gives 1
		cmp gives 1
		condBranch gives 1
		branch gives 1
		call gives 5
		indirectCall gives 5
		witnessCall gives 9
		ret gives 1
		param gives 1
		load gives 4
		store gives 3
		loadSlot gives 4
		storeSlot gives 3
		stackSlotAddr gives 1
		globalAddr gives 1
		funcAddr gives 1
		loadFramePtr gives 1
		osExit gives 1
		osSleep gives 50
		osWrite gives 5
		osWriteErr gives 5
		osRead gives 5
		osOpenWrite gives 5
		osWriteFd gives 5
		osClose gives 5
		osGetEnv gives 5
		osGetArgc gives 5
		osGetArgv gives 5
		osGetExecutablePath gives 5
		memcpy gives 5
		storeByte gives 3
		loadByte gives 4
		osAllocPages gives 50
		osAllocPagesLarge gives 50
		osFreePages gives 50
		// Linux file-I/O syscalls. Model them with the same syscall-class
		// latency budget the other os* ops use (50 cycles each) — the
		// scheduler doesn't try to model real I/O wait, but treating each
		// op as a heavy barrier reflects the actual instruction cost.
		osFileOpen gives 50
		osFileRead gives 50
		osFileWrite gives 50
		osFileClose gives 50
		osFileLseek gives 50
		osFileStat gives 50
		osFileAccess gives 50
		osFileUnlink gives 50
		osDirGetdents64 gives 50
		osDirGetcwd gives 50
		osDirMkdir gives 50
		atomicInc gives 8
		atomicDec gives 8
		atomicXadd gives 8
		osLockInit gives 5
		osLockAcquire gives 30
		osLockRelease gives 5
		// Mirror the latency budget for `call` (5) — tryCall lowers to a
		// direct call followed by a single mov of RDX/X1 into a virtual.
		// errorReturn is a terminator (epilogue+ret), modelled like `ret` (1).
		tryCall gives 5
		// witnessTryCall: memory-indirect witness dispatch (like witnessCall, 9)
		// plus the post-call error-flag mov.
		witnessTryCall gives 9
		errorReturn gives 1
	end 'dispatch'
end 'getMirLatency'

function getMirBinOpLatency(opcode MirBinOpcode, table TargetLatencyTable) returns Latency
	return match opcode 'dispatch'
		addI64 gives 1
		subI64 gives 1
		mulI64 gives 3
		divI64 gives table.intDivLatency
		remI64 gives table.intDivLatency
		andI64 gives 1
		orI64 gives 1
		xorI64 gives 1
		shlI64 gives 1
		shrI64 gives 1
		addF64 gives 4
		subF64 gives 4
		mulF64 gives 4
		divF64 gives table.fpDivLatency
		minF64 gives 4
		maxF64 gives 4
	end 'dispatch'
end 'getMirBinOpLatency'

// Insert prologue/epilogue for all functions using the given backend. The
// backend supplies its own TargetOpQuery so shared passes can ask
// target-specific questions (is-epilogue-op, is-ret) without re-dispatching
// on module.cpu.
export function insertPrologueEpilogueWith(module TargetModule, backend TargetBackend)
	let opQuery = backend.createOpQuery()
	for func in module.functions 'eachFunc'
		logTrace(LogCategory.ir, message: function() gives "prologue-epilogue: func={func.name}")
		insertPrologueEpilogueShared(module, func: func, backend: backend, opQuery: opQuery)
	end 'eachFunc'
end 'insertPrologueEpilogueWith'

export function writeExecutable(outputPath FilePath, codeResult CodeResult, target Target, stdlibCache StdlibCacheData)
	match target.os 'os'
		windows then writePe(outputPath, codeResult: codeResult, target: target)
		linux then writeElf(outputPath, codeResult: codeResult, target: target)
		macos then writeMachO(outputPath, codeResult: codeResult, target: target)
		wasi then compileWasm(codeResult.mirModule, globalData: codeResult.globalData, outputPath: outputPath, stdlibCache: stdlibCache)
	end 'os'
end 'writeExecutable'

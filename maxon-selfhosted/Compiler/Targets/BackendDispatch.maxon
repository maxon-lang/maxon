// Single dispatch point for all CPU+OS backend combinations.
// CPU emitters consume OsDescriptor to handle OS differences -- no CPU*OS dispatch needed.
// Runtime functions (mrt_write_stdout, mrt_i64_to_string, mrt_printInt, mrt_start) are prepended
// to the module as mid-level IR before target-specific lowering.
// The runtime is loaded from runtime.std (text-based IR) by MidLevelParser.

function loadRuntimeModule() returns StdModule
	let runtimePath = findRuntimePath()
	if runtimePath.isEmpty() 'noRuntime'
		panic("Cannot find runtime.std -- searched up from current directory")
	end 'noRuntime'

	let source = try File.readText(runtimePath) otherwise 'readErr'
		panic("Failed to read runtime.std at {runtimePath}")
	end 'readErr'

	return parseStdModule(source, startValueId: 0)
end 'loadRuntimeModule'

function findRuntimePath() returns FilePath
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		// Look for maxon-selfhosted/Compiler/Runtime/runtime.std
		let candidate = dir.join("maxon-selfhosted").join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate) 'found'
			return candidate
		end 'found'
		// Also check Compiler/Runtime/runtime.std (if we're inside maxon-selfhosted)
		let candidate2 = dir.join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate2) 'found2'
			return candidate2
		end 'found2'
		// Also check Runtime/runtime.std (if we're inside Compiler)
		let candidate3 = dir.join("Runtime").join("runtime.std")
		if File.exists(candidate3) 'found3'
			return candidate3
		end 'found3'
		// Also check runtime.std directly
		let candidate4 = dir.join("runtime.std")
		if File.exists(candidate4) 'found4'
			return candidate4
		end 'found4'
		let parentDir = try dir.parent() otherwise 'noParent'
			return FilePath from ""
		end 'noParent'
		dir = parentDir
	end 'search'
	return FilePath from ""
end 'findRuntimePath'

// Prepends runtime functions from runtime.std to a user module.
// Runtime functions are expressed as Std-level IR and will be lowered by
// the backend just like user functions.
export function augmentWithRuntime(module StdModule) returns StdModule
	let runtimeModule = loadRuntimeModule()
	// Merge runtime into a new module, then merge user module on top
	var augmented = createStdModule()
	augmented.merge(runtimeModule)
	augmented.merge(module)
	return augmented
end 'augmentWithRuntime'

// Backend execution driven by the pipeline.
// Phases 5-7 (augmentWithRuntime, lowerStdToMir, scheduleInstructions,
// lowerMirToTarget, allocateRegisters, insertPrologueEpilogue) run through
// the PassPipeline; then code emission converts the final target ops to
// machine code bytes. For WASM: branches from MIR directly — skips target
// lowering, regalloc, and scheduling.
export function emitBackend(stdModule StdModule, target Target, globalData GlobalDataTable, project Project, nextValueIdRef ValueIdRef, stdlibCache StdlibCacheData) returns CodeResult throws CompileError
	// emitBackend starts from the optimized StdModule produced by queryAllMid.
	// The PipelineContext carries a placeholder MaxonModule (the Maxon phase
	// already ran upstream) and the incoming stdModule seeded into ctx.stdModule.
	var ctx = PipelineContext.create(createMaxonModule(), project: project, globalData: globalData, nextValueIdRef: nextValueIdRef, target: target, sourceFileName: "")
	ctx.stdModule = stdModule

	if target.cpu == CpuArch.wasm32 'isWasm'
		// WASM pipeline: only augmentWithRuntime + lowerStdToMir, then emit directly.
		// WASM reads the MIR module out of `mirModule`; `targetModule` is an empty
		// dummy TargetModule since WASM never reaches the Target phase.
		let wasmPasses = buildWasmBackendPipeline()
		try runPipeline(ctx, passes: wasmPasses)
		return CodeResult.create(ByteArray.create(), mainCallFixupOffset: 0, relocations: RelocationArray.create(), globalData: globalData, targetModule: createTargetModule(CpuArch.x64), mirModule: ctx.mirModule, rdata: ByteArray.create(), rdataRelocations: RdataRelocationArray.create(), symdata: ByteArray.create())
	end 'isWasm'

	// Native pipeline: run Phases 5-6 (Std→MIR + MIR passes)
	var mirPasses = PassKindArray.create()
	mirPasses.push(PassKind.augmentWithRuntime)
	mirPasses.push(PassKind.lowerStdToMir)
	mirPasses.push(PassKind.commuteForCoalescing)
	mirPasses.push(PassKind.scheduleInstructions)
	try runPipeline(ctx, passes: mirPasses)

	// Phase 7: target lowering (with stdlib cache for cross-module call metadata)
	ctx.targetModule = lowerToTarget(ctx.mirModule, target: ctx.target, globalData: ctx.globalData, stdlibCache: stdlibCache)

	// Regalloc + prologue/epilogue
	var targetPasses = PassKindArray.create()
	targetPasses.push(PassKind.allocateRegisters)
	targetPasses.push(PassKind.insertPrologueEpilogue)
	try runPipeline(ctx, passes: targetPasses)

	// Emit machine code from the fully-lowered target module
	var result = emitTargetCode(ctx.targetModule, target: target, globalData: globalData, stdlibCache: stdlibCache)
	result.targetModule = ctx.targetModule
	return result
end 'emitBackend'

export function createLatencyTable(target Target) returns TargetLatencyTable
	match target.cpu 'cpu'
		x64 then return createX64LatencyTable()
		arm64 then return createArm64LatencyTable()
		wasm32 then panic("latency table not used for WASM targets")
	end 'cpu'
end 'createLatencyTable'

// Latency lookup for a MIR op by its index in the MirModule. The instruction
// scheduler calls this per op to drive its critical-path heuristic.
export function getMirLatencyPacked(module MirModule, packed MirOpIndex, table TargetLatencyTable) returns Latency
	let mirOp = try module.ops.get(packed) otherwise 'noMir'
		return table.defaultLatency
	end 'noMir'
	return getMirLatency(mirOp, table: table)
end 'getMirLatencyPacked'

// MIR-level latency estimates, parameterized by the target's latency table
// so division and other high-variance ops reflect the actual target CPU.
function getMirLatency(op MirOp, table TargetLatencyTable) returns Latency
	return match op 'dispatch'
		movImm gives 1
		movReg gives 1
		binOp(_, _, _, opcode) gives getMirBinOpLatency(opcode, table: table)
		unaryOp gives 1
		cmp gives 1
		condBranch gives 1
		branch gives 1
		call gives 5
		indirectCall gives 5
		ret gives 1
		param gives 1
		load gives 4
		store gives 3
		loadSlot gives 4
		storeSlot gives 3
		stackSlotAddr gives 1
		globalAddr gives 1
		funcAddr gives 1
		loadFramePtr gives 1
		syscall gives 5
		iatCall gives 5
		osExit gives 1
		osWrite gives 5
		osWriteErr gives 5
		memcpy gives 5
		storeByte gives 3
		loadByte gives 4
	end 'dispatch'
end 'getMirLatency'

function getMirBinOpLatency(opcode MirBinOpcode, table TargetLatencyTable) returns Latency
	return match opcode 'dispatch'
		addI64 gives 1
		subI64 gives 1
		mulI64 gives 3
		divI64 gives table.intDivLatency
		remI64 gives table.intDivLatency
		andI64 gives 1
		orI64 gives 1
		xorI64 gives 1
		shlI64 gives 1
		shrI64 gives 1
		addF64 gives 4
		subF64 gives 4
		mulF64 gives 4
		divF64 gives table.fpDivLatency
	end 'dispatch'
end 'getMirBinOpLatency'

// Dispatch prologue/epilogue insertion for a single function to the target backend.
export function insertPrologueEpilogueForFunc(module TargetModule, func TargetFunction, target Target)
	// First pass: compute the frame layout from the function.
	let frameInfo = computeFrameInfo(module, func: func)
	let stackSize = frameInfo.alignedSize

	logTrace(LogCategory.ir, message: () gives "  frame: var={frameInfo.varAreaSize} spill={frameInfo.spillAreaSize} total={frameInfo.totalStackSize} aligned={stackSize}")

	// Second pass: strip existing prologue/epilogue ops and insert new ones.
	match target.cpu 'dispatchCpu'
		x64 then insertX64PrologueEpilogue(module, func: func, stackSize: stackSize)
		arm64 then insertArm64PrologueEpilogue(module, func: func, stackSize: stackSize)
		wasm32 then panic("prologue/epilogue not used for WASM targets")
	end 'dispatchCpu'
end 'insertPrologueEpilogueForFunc'

// Scan a single target op for frame-relevant information (target dispatch).
export function scanOpForFrameInfo(packed TargetOpIndex, module TargetModule, state FrameScanState)
	match module.cpu 'dispatch'
		x64 then scanX64FrameInfo(module, packed: packed, state: state)
		arm64 then scanArm64FrameInfo(module, packed: packed, state: state)
		wasm32 then panic("scanOpForFrameInfo: unexpected wasm32 cpu")
	end 'dispatch'
end 'scanOpForFrameInfo'

function scanX64FrameInfo(module TargetModule, packed TargetOpIndex, state FrameScanState)
	let x64Op = try module.x64Ops.get(packed) otherwise 'noOp'
		return
	end 'noOp'
	scanX64InstrForFrame(x64Op, state: state)
end 'scanX64FrameInfo'

function scanArm64FrameInfo(module TargetModule, packed TargetOpIndex, state FrameScanState)
	let a64Op = try module.arm64Ops.get(packed) otherwise 'noOp'
		return
	end 'noOp'
	scanArm64InstrForFrame(a64Op, state: state)
end 'scanArm64FrameInfo'

// Lower the MIR module to a TargetModule. Reads MIR ops from the input
// MirModule and produces a fresh TargetModule; does not mutate the input.
export function lowerToTarget(module MirModule, target Target, globalData GlobalDataTable, stdlibCache StdlibCacheData) returns TargetModule
	return match target.cpu 'cpu'
		x64 gives lowerMirToX64(module, target: target, globalData: globalData, stdlibFunctions: stdlibCache.functions)
		arm64 gives lowerMirToArm64(module, target: target, globalData: globalData, stdlibFunctions: stdlibCache.functions)
		default panic("target lowering not used for WASM targets")
	end 'cpu'
end 'lowerToTarget'

function emitTargetCode(module TargetModule, target Target, globalData GlobalDataTable, stdlibCache StdlibCacheData) returns CodeResult
	return match target.cpu 'cpu'
		x64 gives emitX64(module, target: target, globalData: globalData, stdlibCache: stdlibCache)
		arm64 gives emitArm64(module, target: target, globalData: globalData, stdlibCache: stdlibCache)
		default panic("target code emission not used for WASM targets")
	end 'cpu'
end 'emitTargetCode'

export function writeExecutable(outputPath FilePath, codeResult CodeResult, target Target, stdlibCache StdlibCacheData)
	match target.os 'os'
		windows then writePe(outputPath, codeResult: codeResult, target: target)
		linux then writeElf(outputPath, codeResult: codeResult, target: target)
		macos then writeMachO(outputPath, codeResult: codeResult, target: target)
		wasi then compileWasm(codeResult.mirModule, globalData: codeResult.globalData, outputPath: outputPath, stdlibCache: stdlibCache)
	end 'os'
end 'writeExecutable'

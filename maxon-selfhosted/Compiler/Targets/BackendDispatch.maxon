// Single dispatch point for all CPU+OS backend combinations.
// CPU emitters consume OsDescriptor to handle OS differences -- no CPU*OS dispatch needed.
// Runtime functions (mrt_write_stdout, mrt_i64_to_string, mrt_printInt, mrt_start) are prepended
// to the module as mid-level IR before target-specific lowering.
// The runtime is loaded from runtime.std (text-based IR) by MidLevelParser.
//
// Target-specific behavior is abstracted behind the TargetBackend interface.
// Each public function that needs target dispatch has a single match that
// creates the concrete backend type and passes it to a helper function
// accepting a TargetBackend parameter — the compiler monomorphizes the helper
// for each concrete type.

// Parsed runtime.std module, cached for the process lifetime. The runtime
// source is a build-time input that cannot change mid-process, so a simple
// one-shot parse is safe — no revision tracking needed. Callers get back a
// shared reference; each pipeline pass merges a filtered copy into its own
// StdModule via augmentWithRuntime, so the cached value stays read-only.
var cachedRuntimeModule = StdModule.create()
var runtimeModuleLoaded = false

export function loadRuntimeModule() returns StdModule
	if runtimeModuleLoaded 'cached'
		return cachedRuntimeModule
	end 'cached'

	let runtimePath = findRuntimePath()
	if runtimePath.isEmpty() 'noRuntime'
		panic("Cannot find runtime.std -- searched up from current directory")
	end 'noRuntime'

	let source = try File.readText(runtimePath) otherwise panic("Failed to read runtime.std at {runtimePath}")

	cachedRuntimeModule = try parseStdModule(source, startValueId: 0) otherwise panic("Failed to parse runtime.std at {runtimePath}")
	runtimeModuleLoaded = true
	return cachedRuntimeModule
end 'loadRuntimeModule'

export function findRuntimePath() returns FilePath
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		// Look for maxon-selfhosted/Compiler/Runtime/runtime.std
		let candidate = dir.join("maxon-selfhosted").join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate) 'found'
			return candidate
		end 'found'
		// Also check Compiler/Runtime/runtime.std (if we're inside maxon-selfhosted)
		let candidate2 = dir.join("Compiler").join("Runtime").join("runtime.std")
		if File.exists(candidate2) 'found2'
			return candidate2
		end 'found2'
		// Also check Runtime/runtime.std (if we're inside Compiler)
		let candidate3 = dir.join("Runtime").join("runtime.std")
		if File.exists(candidate3) 'found3'
			return candidate3
		end 'found3'
		// Also check runtime.std directly
		let candidate4 = dir.join("runtime.std")
		if File.exists(candidate4) 'found4'
			return candidate4
		end 'found4'
		// dir.parent() returns no value at the filesystem root; bail out with empty path.
		let parentDir = try dir.parent() otherwise return FilePath from ""
		dir = parentDir
	end 'search'
	return FilePath from ""
end 'findRuntimePath'

// Prepends runtime functions from runtime.std to a user module.
// Runtime functions are expressed as Std-level IR and will be lowered by
// the backend just like user functions.
//
// Coverage-related runtime functions (mrt_cov_hit, mrt_cov_dump,
// mrt_start_with_coverage) live in runtime.std so StdParser can validate them
// at compiler-startup time. They are selectively retained or dropped based on
// project.coverageEnabled:
//   - coverage off: strip all three (non-coverage builds don't need them and
//     keeping them forces every backend to lower unused OS primitives).
//   - coverage on: rename `mrt_start_with_coverage` to `mrt_start` (the entry
//     symbol the linker looks for), strip the original `mrt_start`, and keep
//     `mrt_cov_hit` / `mrt_cov_dump` reachable from the coverage-aware start.
//     Also reserves the `__data_cov_*` globals so the counter array and site
//     count are visible to the backend's data-section emission.
export function augmentWithRuntime(module StdModule, project Project) returns StdModule
	let runtimeModule = loadRuntimeModule()
	let filteredRuntime = filterRuntimeForCoverage(runtimeModule, coverageEnabled: project.coverageEnabled)
	if project.coverageEnabled 'reserveGlobals'
		// Register the coverage globals once per compile, after instrumentation
		// has finalized the site count but before backend emission reads the
		// data section layout.
		registerCoverageGlobals(project.globalData, numSites: project.covSites.nextId)
	end 'reserveGlobals'
	var augmented = StdModule.create()
	augmented.merge(filteredRuntime)
	augmented.merge(module)
	return augmented
end 'augmentWithRuntime'

// Filter the loaded runtime module's function list based on whether coverage
// instrumentation is active. Blocks and ops stay put in the arrays (dropping
// them there would require renumbering every op/block reference in every
// retained function) — only the function list is pruned.
//
// The backend emitters place code in functions-list order and assume
// `mrt_start` lives at code offset 0 (the PE/ELF entry point RVA), so the
// coverage-on branch is careful to keep the renamed start at the front of
// the filtered list even though `mrt_start_with_coverage` appears last in
// runtime.std.
function filterRuntimeForCoverage(module StdModule, coverageEnabled bool) returns StdModule
	var filtered = StdModule.create()
	filtered.ops.append(module.ops)
	for i in 0 upto module.blocks.count() 'copyBlocks'
		let block = try module.blocks.get(i) otherwise panic("filterRuntimeForCoverage: blocks.get out of bounds")
		filtered.blocks.push(block)
		// Keep blockSourceInfo lock-step with blocks so the merge that consumes
		// this filtered module doesn't see a misaligned parallel array.
		let info = try module.blockSourceInfo.get(i) otherwise BlockSourceInfo.empty()
		filtered.blockSourceInfo.push(info)
	end 'copyBlocks'
	// First pass: when coverage is on, emit the renamed coverage-start as the
	// very first function so it wins the entry-point slot. Skip over it in the
	// main pass below so it isn't pushed twice. u64.max is the sentinel meaning
	// "no index" — no real function will have that many entries ahead of it.
	var coverageStartIdx = u64.max
	if coverageEnabled 'promoteStart'
		for funcIdx in 0 upto module.functions.count() 'find'
			let func = try module.functions.get(funcIdx) otherwise panic("filterRuntimeForCoverage: functions.get out of bounds")
			if func.name == "mrt_start_with_coverage" 'match'
				// Clone before renaming — `module` is the shared cached runtime
				// module and struct .get returns a reference. Mutating `func.name`
				// directly would bleed the rename back into subsequent calls.
				var renamed = func.clone()
				renamed.name = "mrt_start"
				filtered.functions.push(renamed)
				coverageStartIdx = funcIdx
				break
			end 'match'
		end 'find'
	end 'promoteStart'
	for funcIdx in 0 upto module.functions.count() 'copyFuncs'
		if funcIdx == coverageStartIdx 'alreadyEmitted'
			continue
		end 'alreadyEmitted'
		let func = try module.functions.get(funcIdx) otherwise panic("filterRuntimeForCoverage: functions.get out of bounds")
		if coverageEnabled 'covOn'
			// Drop the original non-coverage start: its role has been taken
			// over by the renamed coverage-start emitted above.
			if func.name == "mrt_start" 'dropDefaultStart'
				continue
			end 'dropDefaultStart'
		end 'covOn' else 'covOff'
			if isCoverageRuntimeFunction(func.name) 'skip'
				continue
			end 'skip'
		end 'covOff'
		filtered.functions.push(func)
	end 'copyFuncs'
	return filtered
end 'filterRuntimeForCoverage'

function isCoverageRuntimeFunction(name String) returns bool
	return name == "mrt_cov_hit" or name == "mrt_cov_dump" or name == "mrt_start_with_coverage"
end 'isCoverageRuntimeFunction'

// Backend execution driven by the pipeline.
// Phases 5-7 (augmentWithRuntime, lowerStdToMir, scheduleInstructions,
// lowerMirToTarget, allocateRegisters, insertPrologueEpilogue) run through
// the PassPipeline; then code emission converts the final target ops to
// machine code bytes. For WASM: branches from MIR directly — skips target
// lowering, regalloc, and scheduling.
export function emitBackend(stdModule StdModule, target Target, globalData GlobalDataTable, project Project, stdlibCache StdlibCacheData) returns CodeResult throws CompileError
	// emitBackend starts from the optimized StdModule produced by queryAllMid.
	// The pipeline carries a placeholder MaxonModule (the Maxon phase already
	// ran upstream) and the incoming stdModule seeded into pipeline.stdModule.
	var pipeline = PassPipeline.create(MaxonModule.create(), project: project, globalData: globalData, target: target, sourceFileName: "")
	pipeline.stdModule = stdModule

	if target.cpu == CpuArch.wasm32 'isWasm'
		// WASM pipeline: only augmentWithRuntime + lowerStdToMir, then emit directly.
		// WASM reads the MIR module out of `mirModule`; `targetModule` is an empty
		// dummy TargetModule since WASM never reaches the Target phase.
		pipeline.addPasses(buildWasmBackendPipeline())
		try pipeline.run()
		return CodeResult.create(ByteArray.create(), mainCallFixupOffset: 0, relocations: RelocationArray.create(), globalData: globalData, targetModule: TargetModule.create(CpuArch.x64), mirModule: pipeline.mirModule, rdata: ByteArray.create(), rdataRelocations: RdataRelocationArray.create(), symdata: ByteArray.create(), covDataSectionBytes: ByteArray.create())
	end 'isWasm'

	// Native pipeline: run Phases 5-6 (Std→MIR + MIR passes)
	pipeline.addPass(PassKind.augmentWithRuntime)
	pipeline.addPass(PassKind.lowerStdToMir)
	pipeline.addPass(PassKind.commuteForCoalescing)
	pipeline.addPass(PassKind.scheduleInstructions)
	try pipeline.run()

	// Phase 7: target lowering + regalloc + prologue/epilogue + code emission
	// Create the backend once with all state, then pass it through.
	match target.cpu 'dispatchCpu'
		x64 then return try emitBackendWith(pipeline, stdlibCache: stdlibCache, backend: X64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		arm64 then return try emitBackendWith(pipeline, stdlibCache: stdlibCache, backend: Arm64Backend.create(pipeline.mirModule, target: project.target, globalData: pipeline.globalData, stdlibFunctions: stdlibCache.functions))
		wasm32 then panic("unreachable: WASM handled above")
	end 'dispatchCpu'
end 'emitBackend'

function emitBackendWith(pipeline PassPipeline, stdlibCache StdlibCacheData, backend TargetBackend) returns CodeResult throws CompileError
	logDebug(LogCategory.ir, message: () gives "=== Running pass: lower-mir-to-target ===")
	pipeline.targetModule = backend.lowerMirToTarget()
	logTrace(LogCategory.ir, message: () gives dumpTargetSummary(pipeline.targetModule, passName: "lower-mir-to-target"))

	// Register allocation (target-independent)
	logDebug(LogCategory.ir, message: () gives "=== Running pass: allocate-registers ===")
	pipeline.targetModule = allocateRegisters(pipeline.targetModule, target: pipeline.target)
	logTrace(LogCategory.ir, message: () gives dumpTargetSummary(pipeline.targetModule, passName: "allocate-registers"))

	// Prologue/epilogue insertion (uses backend for target-specific ops)
	logDebug(LogCategory.ir, message: () gives "=== Running pass: insert-prologue-epilogue ===")
	insertPrologueEpilogueWith(pipeline.targetModule, backend: backend)
	logTrace(LogCategory.ir, message: () gives dumpTargetSummary(pipeline.targetModule, passName: "insert-prologue-epilogue"))

	// Emit machine code from the fully-lowered target module
	var result = backend.emitTargetCode(stdlibCache)
	result.targetModule = pipeline.targetModule
	return result
end 'emitBackendWith'

function dumpTargetSummary(module TargetModule, passName String) returns String
	return dumpModuleSummary(module.functions.count(), blockCount: module.blocks.count(), opCount: module.x64Ops.count() + module.arm64Ops.count(), dialect: module.cpu.name, passName: passName)
end 'dumpTargetSummary'

export function createLatencyTable(target Target) returns TargetLatencyTable
	return match target.cpu 'cpu'
		x64 gives X64Backend.createLatencyTable()
		arm64 gives Arm64Backend.createLatencyTable()
		default panic("latency table not used for WASM targets")
	end 'cpu'
end 'createLatencyTable'

// Latency lookup for a MIR op by its index in the MirModule. The instruction
// scheduler calls this per op to drive its critical-path heuristic.
export function getMirLatencyPacked(module MirModule, packed OpIndex, table TargetLatencyTable) returns Latency
	let mirOp = try module.ops.get(packed) otherwise panic("invariant: packed opIdx not in module.ops")
	return getMirLatency(mirOp, table: table)
end 'getMirLatencyPacked'

// MIR-level latency estimates, parameterized by the target's latency table
// so division and other high-variance ops reflect the actual target CPU.
function getMirLatency(op MirOp, table TargetLatencyTable) returns Latency
	return match op 'dispatch'
		movImm gives 1
		movReg gives 1
		binOp(_, _, _, opcode) gives getMirBinOpLatency(opcode, table: table)
		unaryOp gives 1
		cmp gives 1
		condBranch gives 1
		branch gives 1
		call gives 5
		indirectCall gives 5
		ret gives 1
		param gives 1
		load gives 4
		store gives 3
		loadSlot gives 4
		storeSlot gives 3
		stackSlotAddr gives 1
		globalAddr gives 1
		funcAddr gives 1
		loadFramePtr gives 1
		syscall gives 5
		iatCall gives 5
		osExit gives 1
		osWrite gives 5
		osWriteErr gives 5
		osOpenWrite gives 5
		osWriteFd gives 5
		osClose gives 5
		osGetEnv gives 5
		memcpy gives 5
		storeByte gives 3
		loadByte gives 4
	end 'dispatch'
end 'getMirLatency'

function getMirBinOpLatency(opcode MirBinOpcode, table TargetLatencyTable) returns Latency
	return match opcode 'dispatch'
		addI64 gives 1
		subI64 gives 1
		mulI64 gives 3
		divI64 gives table.intDivLatency
		remI64 gives table.intDivLatency
		andI64 gives 1
		orI64 gives 1
		xorI64 gives 1
		shlI64 gives 1
		shrI64 gives 1
		addF64 gives 4
		subF64 gives 4
		mulF64 gives 4
		divF64 gives table.fpDivLatency
	end 'dispatch'
end 'getMirBinOpLatency'

// Insert prologue/epilogue for all functions using the given backend. The
// backend supplies its own TargetOpQuery so shared passes can ask
// target-specific questions (is-epilogue-op, is-ret) without re-dispatching
// on module.cpu.
export function insertPrologueEpilogueWith(module TargetModule, backend TargetBackend)
	let opQuery = backend.createOpQuery()
	for func in module.functions 'eachFunc'
		logTrace(LogCategory.ir, message: () gives "prologue-epilogue: func={func.name}")
		let frameInfo = computeFrameInfoWith(module, func: func, backend: backend)
		logTrace(LogCategory.ir, message: () gives "  frame: var={frameInfo.varAreaSize} spill={frameInfo.spillAreaSize} total={frameInfo.totalStackSize} aligned={frameInfo.alignedSize}")
		insertPrologueEpilogueShared(module, func: func, backend: backend, opQuery: opQuery, frameInfo: frameInfo)
	end 'eachFunc'
end 'insertPrologueEpilogueWith'

export function writeExecutable(outputPath FilePath, codeResult CodeResult, target Target, stdlibCache StdlibCacheData)
	match target.os 'os'
		windows then writePe(outputPath, codeResult: codeResult, target: target)
		linux then writeElf(outputPath, codeResult: codeResult, target: target)
		macos then writeMachO(outputPath, codeResult: codeResult, target: target)
		wasi then compileWasm(codeResult.mirModule, globalData: codeResult.globalData, outputPath: outputPath, stdlibCache: stdlibCache)
	end 'os'
end 'writeExecutable'

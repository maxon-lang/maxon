// Single dispatch point for all CPU+OS backend combinations.
// CPU emitters consume OsDescriptor to handle OS differences -- no CPU*OS dispatch needed.
// Runtime functions (mrt_write_stdout, mrt_i64_to_string, mrt_printInt, mrt_start) are prepended
// to the module as mid-level IR before target-specific lowering.
// The runtime is loaded from runtime.mid (text-based MLIR) by MidLevelParser.

function loadRuntimeModule() returns MlirModule
	let runtimePath = findRuntimePath()
	if runtimePath.isEmpty() 'noRuntime'
		panic("Cannot find runtime.mid -- searched up from current directory")
	end 'noRuntime'

	let source = try File.readText(runtimePath) otherwise 'readErr'
		panic("Failed to read runtime.mid at {runtimePath}")
	end 'readErr'

	return parseMidModule(source, startValueId: 0)
end 'loadRuntimeModule'

function findRuntimePath() returns FilePath
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		// Look for maxon-selfhosted/Compiler/Runtime/runtime.mid
		let candidate = dir.join("maxon-selfhosted").join("Compiler").join("Runtime").join("runtime.mid")
		if candidate.fileExists() 'found'
			return candidate
		end 'found'
		// Also check Compiler/Runtime/runtime.mid (if we're inside maxon-selfhosted)
		let candidate2 = dir.join("Compiler").join("Runtime").join("runtime.mid")
		if candidate2.fileExists() 'found2'
			return candidate2
		end 'found2'
		// Also check Runtime/runtime.mid (if we're inside Compiler)
		let candidate3 = dir.join("Runtime").join("runtime.mid")
		if candidate3.fileExists() 'found3'
			return candidate3
		end 'found3'
		// Also check runtime.mid directly
		let candidate4 = dir.join("runtime.mid")
		if candidate4.fileExists() 'found4'
			return candidate4
		end 'found4'
		let parentDir = dir.parent()
		if parentDir.isEmpty() 'noParent'
			return FilePath from ""
		end 'noParent'
		dir = parentDir
	end 'search'
	return FilePath from ""
end 'findRuntimePath'

// Prepends runtime functions from runtime.mid to a user module.
// Runtime functions are expressed as mid-level IR (arith/cf/func/memref/sys ops)
// and will be lowered by the target backends just like user functions.
export function augmentWithRuntime(module MlirModule) returns MlirModule
	let runtimeModule = loadRuntimeModule()
	// Merge runtime into a new module, then merge user module on top
	var augmented = createMlirModule()
	mergeModules(augmented, source: runtimeModule)
	mergeModules(augmented, source: module)
	return augmented
end 'augmentWithRuntime'

// Backend execution driven by the pipeline.
// Phase 6-7 passes (augmentWithRuntime, lowerMirToTarget, scheduleInstructions,
// allocateRegisters, insertPrologueEpilogue) run through the PassPipeline,
// then code emission converts the final target ops to machine code bytes.
// For WASM: branches from MIR directly — skips target lowering, regalloc, scheduling.
export function emitBackend(module MlirModule, target Target, globalData GlobalDataTable, project Project, nextValueIdRef ValueIdRef) returns CodeResult throws CompileError
	let ctx = PipelineContext.create(module, project: project, globalData: globalData, nextValueIdRef: nextValueIdRef, target: target, sourceFileName: "")

	if target.cpu == CpuArch.wasm32 'isWasm'
		// WASM pipeline: only augmentWithRuntime + lowerToMir, then emit directly.
		let wasmPasses = buildWasmBackendPipeline()
		try runPipeline(ctx, passes: wasmPasses)
		// Return CodeResult with the MIR module — actual .wasm emission happens in writeExecutable.
		return CodeResult.create(ByteArray.create(), mainCallFixupOffset: 0, relocations: RelocationArray.create(), globalData: globalData, targetModule: ctx.module, rdata: ByteArray.create(), rdataRelocations: RdataRelocationArray.create(), symdata: ByteArray.create())
	end 'isWasm'

	// Native pipeline: run Phase 6-7 through the full backend pipeline
	let backendPasses = buildBackendPipeline()
	try runPipeline(ctx, passes: backendPasses)

	// Emit machine code from the fully-lowered target module
	var result = emitTargetCode(ctx.module, target: target, globalData: globalData)
	result.targetModule = ctx.module
	return result
end 'emitBackend'

export function createLatencyTable(target Target) returns TargetLatencyTable
	match target.cpu 'cpu'
		x64 then return createX64LatencyTable()
		arm64 then return createArm64LatencyTable()
		wasm32 then panic("latency table not used for WASM targets")
	end 'cpu'
end 'createLatencyTable'

export function getTargetLatency(packed OpRef, module MlirModule, table TargetLatencyTable) returns Latency
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)
	if tag == TAG_MIR 'isMir'
		let mirOp = try module.mirOps.get(idx) otherwise 'noMir'
			return table.defaultLatency
		end 'noMir'
		return getMirLatency(mirOp, table: table)
	end 'isMir' else if tag == TAG_X64 'isX64'
		let x64Op = try module.x64Ops.get(idx) otherwise 'noX64'
			return table.defaultLatency
		end 'noX64'
		return x64Op.rawValue.latency
	end 'isX64' else if tag == TAG_ARM64 'isArm64'
		let arm64Op = try module.arm64Ops.get(idx) otherwise 'noArm64'
			return table.defaultLatency
		end 'noArm64'
		return arm64Op.rawValue.latency
	end 'isArm64'

	// Non-target ops (maxon, arith, cf, func, memref, runtime, sys) use default latency
	return table.defaultLatency
end 'getTargetLatency'

// MIR-level latency estimates, parameterized by the target's latency table
// so division and other high-variance ops reflect the actual target CPU.
function getMirLatency(op MirOp, table TargetLatencyTable) returns Latency
	return match op 'dispatch'
		movImm gives 1
		movReg gives 1
		binOp(_, _, _, opcode) gives getMirBinOpLatency(opcode, table: table)
		unaryOp gives 1
		cmp gives 1
		condBranch gives 1
		branch gives 1
		call gives 5
		indirectCall gives 5
		ret gives 1
		param gives 1
		load gives 4
		store gives 3
		stackSlotAddr gives 1
		globalAddr gives 1
		syscall gives 5
		iatCall gives 5
		osExit gives 1
		osWrite gives 5
		memcpy gives 5
		storeByte gives 3
		loadByte gives 4
	end 'dispatch'
end 'getMirLatency'

function getMirBinOpLatency(opcode MirBinOpcode, table TargetLatencyTable) returns Latency
	return match opcode 'dispatch'
		addI64 gives 1
		subI64 gives 1
		mulI64 gives 3
		divI64 gives table.intDivLatency
		remI64 gives table.intDivLatency
		andI64 gives 1
		orI64 gives 1
		xorI64 gives 1
		shlI64 gives 1
		shrI64 gives 1
		addF64 gives 4
		subF64 gives 4
		mulF64 gives 4
		divF64 gives table.fpDivLatency
	end 'dispatch'
end 'getMirBinOpLatency'

// Dispatch prologue/epilogue insertion for a single function to the target backend.
export function insertPrologueEpilogueForFunc(module MlirModule, func MlirFunction, target Target)
	// First pass: compute the frame layout from the function.
	let frameInfo = computeFrameInfo(module, func: func)
	let stackSize = frameInfo.alignedSize

	logTrace(LogCategory.mlir, message: () gives "  frame: var={frameInfo.varAreaSize} spill={frameInfo.spillAreaSize} total={frameInfo.totalStackSize} aligned={stackSize}")

	// Second pass: strip existing prologue/epilogue ops and insert new ones.
	match target.cpu 'dispatchCpu'
		x64 then insertX64PrologueEpilogue(module, func: func, stackSize: stackSize)
		arm64 then insertArm64PrologueEpilogue(module, func: func, stackSize: stackSize)
		wasm32 then panic("prologue/epilogue not used for WASM targets")
	end 'dispatchCpu'
end 'insertPrologueEpilogueForFunc'

// Scan a single op for frame-relevant information (target dispatch).
export function scanOpForFrameInfo(packed OpRef, module MlirModule, state FrameScanState)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)
	if tag == TAG_X64 'isX64'
		let x64Op = try module.x64Ops.get(idx) otherwise 'noX64'
			return
		end 'noX64'
		scanX64InstrForFrame(x64Op, state: state)
	end 'isX64' else if tag == TAG_ARM64 'isArm64'
		let a64Op = try module.arm64Ops.get(idx) otherwise 'noArm64'
			return
		end 'noArm64'
		scanArm64InstrForFrame(a64Op, state: state)
	end 'isArm64' else if tag == TAG_RUNTIME 'isRuntime'
		// Runtime ops indicate print operations that need buffer space
		state.hasPrint = true
	end 'isRuntime'
end 'scanOpForFrameInfo'

export function lowerToTarget(module MlirModule, target Target, globalData GlobalDataTable) returns MlirModule
	return match target.cpu 'cpu'
		x64 gives lowerMidToX64(module, target: target, globalData: globalData)
		arm64 gives lowerMidToArm64(module, target: target, globalData: globalData)
		default panic("target lowering not used for WASM targets")
	end 'cpu'
end 'lowerToTarget'

function emitTargetCode(module MlirModule, target Target, globalData GlobalDataTable) returns CodeResult
	return match target.cpu 'cpu'
		x64 gives emitX64(module, target: target, globalData: globalData)
		arm64 gives emitArm64(module, target: target, globalData: globalData)
		default panic("target code emission not used for WASM targets")
	end 'cpu'
end 'emitTargetCode'

export function writeExecutable(outputPath FilePath, codeResult CodeResult, target Target)
	match target.os 'os'
		windows then writePe(outputPath, codeResult: codeResult, target: target)
		linux then writeElf(outputPath, codeResult: codeResult, target: target)
		macos then writeMachO(outputPath, codeResult: codeResult, target: target)
		wasi then compileWasm(codeResult.targetModule, globalData: codeResult.globalData, outputPath: outputPath)
	end 'os'
end 'writeExecutable'

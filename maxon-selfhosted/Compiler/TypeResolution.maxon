// Type resolution pass.
//
// Runs immediately after parsing, before any other Maxon-level pass. Two
// jobs:
//
//   1. Drain `project.unresolvedTypealiases` into the resolved registries
//      (`typealiases` + `typealiasRanges`). The drain is a fixed-point loop:
//      each iteration converts whatever entries it can, then re-runs to pick
//      up entries that were waiting on something resolved this round. The
//      loop stops when either every entry has been resolved (success) or no
//      progress was made for a full iteration (cycle or unknown reference,
//      reported on the entries that remain).
//
//   2. Validate `MaxonType.named(id)` references on the module's ops, on
//      struct field types, and on function signatures — every such name
//      must point at a registered typealias, struct, or function type.
//      Unknown names are E3013 (semanticUnknownType).
//
//   3. Validate convert / cmp ops (the original responsibility of this pass):
//      cast widening rules and same-category compare rules.
//
// All errors flow through reportCompileError; the pass never throws.
// Downstream passes (lowerMaxonToStd and beyond) depend on this pass having
// run, so it sits first in the mid pipeline.

// Cycle-guard set for interface-graph walks. Membership is the only
// operation we need, and the walks can reach deep extends chains — a Set
// keeps the per-step `contains` check at O(1) rather than O(visited).
typealias StringSet = Set with String

// Extract the bare typealias name from a registry key. The key is either
// bare (`Score`) or namespace-qualified (`api.Score`, `stdlib.fmt.Score`)
// — qualified keys are staged by `parseTopLevelTypealias` when a cross-file
// collision needs disambiguation. The bare form is what callers compare to
// `usedTypeAliases` and to error-message names; the qualified form is for
// the `parseTypeRef` dotted-lookup path. Strips a leading `{ns}.` if and
// only if it matches the entry's declaring namespace; otherwise returns the
// key unchanged (defensive against names containing dots for other reasons).
function bareNameFromKey(key String, filePath FilePath, rootPath FilePath) returns String
	let ns = deriveNamespace(filePath, rootPath: rootPath)
	if ns.isEmpty() 'noNs'
		return key
	end 'noNs'
	let prefix = "{ns}."
	if not key.startsWith(prefix) 'noMatch'
		return key
	end 'noMatch'
	let bytes = key.toByteArray()
	let prefixLen = prefix.toByteArray().count()
	return byteSliceToString(bytes, startIndex: prefixLen, endIndex: bytes.count())
end 'bareNameFromKey'

// --- Typealias resolution (fixed-point) ---

// Try to translate a single UnresolvedTypeExpr into a (StdType, optional
// range) pair. Returns success=false when the expression is a named
// reference whose target is not yet in `project.typealiases`; the caller
// retries on a later iteration.
type ResolveResult
	export var success as bool
	// True when the resolved alias also has a range to record. Float and
	// bool aliases leave this false.
	export var hasRange as bool
	export var stdType as StdType
	export var range as TypealiasRange

	export static function notYet() returns ResolveResult
		return Self{success: false, hasRange: false, stdType: StdType.i64, range: TypealiasRange.create(0, upper: 0)}
	end 'notYet'

	export static function done(stdType StdType) returns ResolveResult
		return Self{success: true, hasRange: false, stdType: stdType, range: TypealiasRange.create(0, upper: 0)}
	end 'done'

	export static function doneRanged(stdType StdType, range TypealiasRange) returns ResolveResult
		return Self{success: true, hasRange: true, stdType: stdType, range: range}
	end 'doneRanged'
end 'ResolveResult'

function tryResolveTypeExpr(project Project, expr UnresolvedTypeExpr) returns ResolveResult
	return match expr 'eval'
		boolPrim gives ResolveResult.done(StdType.i1)
		rangedFloat(lower, upper) gives ResolveResult.doneRanged(StdType.f64, range: TypealiasRange.create(lower, upper: upper))
		// `int(...)` narrows storage via computeOptimalIntType so small ranges
		// pack tighter; the user-declared cast category (`int`) is preserved
		// separately in `project.typealiasCastCategories` so the storage
		// choice can't reclassify the alias as `byte`.
		rangedInt(lower, upper) gives ResolveResult.doneRanged(computeOptimalIntType(lower, upper: upper), range: TypealiasRange.create(lower, upper: upper))
		// `byte(...)` always lowers to u8 storage and `byte` cast category.
		aliasName(name) gives tryResolveAliasName(project, name: name)
		// Phase 11.0 step 2: generic typealiases never flow through this
		// StdType-typed channel — `drainResolvableTypealiases` handles them
		// out-of-band by storing into `project.genericTypealiases`. Returning
		// `notYet` here lets the match stay exhaustive without any caller
		// silently consuming a generic alias as a primitive.
		genericAlias gives ResolveResult.notYet()
		// Phase 13 (sized typealiases): mirror genericAlias — sized variants
		// also live in `project.genericTypealiases`.
		sizedGenericAlias gives ResolveResult.notYet()
		// Function-type aliases live in `project.genericTypealiases` alongside
		// generic aliases. The drain pass takes them out-of-band.
		functionAlias gives ResolveResult.notYet()
		// Validation-rejected typealias — surface i64 storage so downstream
		// passes don't crash on a placeholder. The originating E3005 is the
		// user-visible diagnostic.
		invalid gives ResolveResult.done(StdType.i64)
	end 'eval'
end 'tryResolveTypeExpr'

// Pick the user-declared cast category from a typealias RHS expression.
// Returns `none` when the expression doesn't directly declare one (alias
// chains, generic, bool, invalid sentinel) — the caller skips populating
// `project.typealiasCastCategories` for those names so the lookup falls
// through to the storage-based StdType.castCategory derivation.
type DeclaredCastCategory
	export var present as bool
	export var category as CastCategory

	export static function none() returns DeclaredCastCategory
		return Self{present: false, category: CastCategory.int}
	end 'none'

	export static function some(category CastCategory) returns DeclaredCastCategory
		return Self{present: true, category: category}
	end 'some'
end 'DeclaredCastCategory'

function declaredCastCategoryFor(expr UnresolvedTypeExpr) returns DeclaredCastCategory
	return match expr 'pick'
		rangedInt gives DeclaredCastCategory.some(CastCategory.int)
		rangedFloat gives DeclaredCastCategory.some(CastCategory.float)
		boolPrim gives DeclaredCastCategory.none()
		aliasName gives DeclaredCastCategory.none()
		genericAlias gives DeclaredCastCategory.none()
		sizedGenericAlias gives DeclaredCastCategory.none()
		functionAlias gives DeclaredCastCategory.none()
		invalid gives DeclaredCastCategory.none()
	end 'pick'
end 'declaredCastCategoryFor'

// Phase 11.0 step 2: returns true iff `expr` is a `genericAlias(...)` arm.
// Used by `drainResolvableTypealiases` to short-circuit into the
// `project.genericTypealiases` storage path before the StdType-typed
// resolver runs.
export function isGenericAliasExpr(expr UnresolvedTypeExpr) returns bool
	return match expr 'check'
		genericAlias gives true
		sizedGenericAlias gives true
		boolPrim gives false
		rangedFloat gives false
		rangedInt gives false
		aliasName gives false
		functionAlias gives false
		invalid gives false
	end 'check'
end 'isGenericAliasExpr'

// True iff `expr` is a `functionAlias(...)` arm. Mirrors `isGenericAliasExpr`
// so the drain pass can route function-type aliases into `genericTypealiases`
// via their own fast path (the carried MaxonType is already fully resolved).
export function isFunctionAliasExpr(expr UnresolvedTypeExpr) returns bool
	return match expr 'check'
		functionAlias gives true
		genericAlias gives false
		sizedGenericAlias gives false
		boolPrim gives false
		rangedFloat gives false
		rangedInt gives false
		aliasName gives false
		invalid gives false
	end 'check'
end 'isFunctionAliasExpr'

// Resolve a non-generic inner-alias expression. Function-type aliases unwrap
// to their stored MaxonType.function so later passes can chase the alias to
// its callable signature; all other shapes are recorded as named placeholders
// keyed by `aliasName` (step 5 sharpens the lookup through StdType chaining).
function resolveNonGenericInnerAlias(project Project, expr UnresolvedTypeExpr, aliasName String) returns MaxonType
	return match expr 'extract'
		functionAlias(target) gives target
		boolPrim gives internMaxonType(project, name: aliasName)
		rangedInt gives internMaxonType(project, name: aliasName)
		rangedFloat gives internMaxonType(project, name: aliasName)
		aliasName gives internMaxonType(project, name: aliasName)
		genericAlias gives internMaxonType(project, name: aliasName)
		sizedGenericAlias gives internMaxonType(project, name: aliasName)
		invalid gives internMaxonType(project, name: aliasName)
	end 'extract'
end 'resolveNonGenericInnerAlias'

// Resolve a single argument name in a generic-alias RHS into a MaxonType.
// Lookup precedence: in-scope type-parameter (when `declaringTypeName` is
// non-empty and the name is registered against it), `bool` primitive, then
// the regular `internMaxonType` fallback. The fallback always succeeds — it
// returns `MaxonType.named(...)` for any unknown name and downstream
// validation reports E3013 if the named type doesn't exist. This matches
// `parseTypeRef`'s own fallback behavior.
function resolveGenericAliasArgName(project Project, declaringTypeName String, argName String) returns MaxonType
	if declaringTypeName.isEmpty() == false 'maybeParam'
		if project.typeParameters.contains(declaringTypeName, paramName: argName) 'isParam'
			let pid = project.typeParameters.intern(declaringTypeName, paramName: argName)
			return MaxonType.typeParameter(pid)
		end 'isParam'
	end 'maybeParam'
	return internMaxonType(project, name: argName)
end 'resolveGenericAliasArgName'

// Resolve a `genericAlias(baseName, args)` UnresolvedTypeExpr into a
// `MaxonType.genericInstance(...)`. `declaringTypeName` is the enclosing
// type-decl name when this expression came from an inner-typealias slot
// (used to look up in-scope type parameters); empty for top-level
// generic aliases. Caller guarantees `expr` is a `genericAlias` arm.
export function resolveGenericAliasExpr(project Project, expr UnresolvedTypeExpr, declaringTypeName String) returns MaxonType
	match expr 'extract'
		genericAlias(baseName, args) then return buildGenericInstanceType(project, baseName: baseName, args: args, declaringTypeName: declaringTypeName)
		sizedGenericAlias(baseName, size, args) then return buildSizedGenericInstanceType(project, baseName: baseName, size: size, args: args, declaringTypeName: declaringTypeName)
		boolPrim then panic("resolveGenericAliasExpr: caller passed boolPrim — must be genericAlias / sizedGenericAlias")
		rangedFloat then panic("resolveGenericAliasExpr: caller passed rangedFloat — must be genericAlias / sizedGenericAlias")
		rangedInt then panic("resolveGenericAliasExpr: caller passed rangedInt — must be genericAlias / sizedGenericAlias")
		aliasName then panic("resolveGenericAliasExpr: caller passed aliasName — must be genericAlias / sizedGenericAlias")
		functionAlias then panic("resolveGenericAliasExpr: caller passed functionAlias — function-type aliases drain via their own path")
		invalid then panic("resolveGenericAliasExpr: caller passed invalid — must be genericAlias / sizedGenericAlias")
	end 'extract'
end 'resolveGenericAliasExpr'

// Phase 13 sized typealias: prepends a `constInt(size)` arg to the
// resolved args so distinct N produce distinct gids (e.g. `Vector with 1
// Int` vs `Vector with 4 Int` are separate monomorphizations).
function buildSizedGenericInstanceType(project Project, baseName String, size IntConstant, args StringArray, declaringTypeName String) returns MaxonType
	let baseId = project.typeNames.intern(baseName)
	var resolvedArgs = MaxonTypeArray.create()
	resolvedArgs.push(MaxonType.constInt(size))
	for i in 0 upto args.count() 'eachArg'
		let argName = try args.get(i) otherwise panic("buildSizedGenericInstanceType: args.get OOB at {i}")
		resolvedArgs.push(resolveGenericAliasArgName(project, declaringTypeName: declaringTypeName, argName: argName))
	end 'eachArg'
	let giid = project.genericInstances.intern(baseId, args: resolvedArgs)
	return MaxonType.genericInstance(giid)
end 'buildSizedGenericInstanceType'

function buildGenericInstanceType(project Project, baseName String, args StringArray, declaringTypeName String) returns MaxonType
	let baseId = project.typeNames.intern(baseName)
	var resolvedArgs = MaxonTypeArray.create()
	for i in 0 upto args.count() 'eachArg'
		let argName = try args.get(i) otherwise panic("buildGenericInstanceType: args.get OOB at {i}")
		resolvedArgs.push(resolveGenericAliasArgName(project, declaringTypeName: declaringTypeName, argName: argName))
	end 'eachArg'
	let giid = project.genericInstances.intern(baseId, args: resolvedArgs)
	return MaxonType.genericInstance(giid)
end 'buildGenericInstanceType'

// Phase 11.7: walk every deferred where-clause check and emit E3017 per
// failing constraint. Runs after `validateConformances` has populated
// `project.conformances`, so `typeConformsTo` returns accurate verdicts.
//
// Also walks each generic-typealias `Base with (Args...)` to flag any arg
// name that doesn't resolve to a real type, mirroring the bootstrap's
// parse-time `Unknown type: X` (E2003) emission. The bootstrap fires the
// check while parsing the typealias body; the self-hosted parser captures
// the arg names without registry validation and resolves them lazily, so
// the existence check has to wait until every type registry is populated
// (typealiases, structs, enums, type parameters of the enclosing decl).
export function drainPendingConstraintChecks(project Project)
	for check in project.pendingConstraintChecks 'eachCheck'
		// Snapshot the diagnostic count so we can detect whether this
		// alias's validation emitted any error (E3017 / E2003 / E3015 /
		// E3016). If it did, mark the alias name so the deferred
		// unused-typealias drain skips it — matches the bootstrap's
		// behavior of throwing on the constraint failure before ever
		// reaching the unused-check.
		let beforeCount = project.diagnostics.count()
		validateGenericInstanceConstraints(project, expr: check.expr, declLine: check.declLine, declColumn: check.declColumn, declFilePath: check.declFilePath)
		validateGenericInstanceArgs(project, expr: check.expr, declLine: check.declLine, declColumn: check.declColumn, declFilePath: check.declFilePath)
		validateGenericInstanceArity(project, expr: check.expr, declLine: check.declLine, declColumn: check.declColumn, declFilePath: check.declFilePath)
		if project.diagnostics.count() > beforeCount 'aliasHadError'
			project.constraintFailedTypealiases.insert(check.name)
		end 'aliasHadError'
	end 'eachCheck'
	project.pendingConstraintChecks = PendingConstraintCheckArray.create()
end 'drainPendingConstraintChecks'

// Phase 11.7: drain the deferred unused-typealias queue. The parser
// populates `project.pendingUnusedTypealiases` at end-of-parse with every
// file-private alias whose name never appeared in a type position. This
// runs AFTER `drainPendingConstraintChecks` so an alias whose RHS failed
// validation has been recorded in `constraintFailedTypealiases` and we
// can drop its E3062 — matches the bootstrap's single-diagnostic shape
// when a `typealias X = Base with BadArg` triggers E3017.
export function drainPendingUnusedTypealiases(project Project)
	for entry in project.pendingUnusedTypealiases 'eachEntry'
		if project.constraintFailedTypealiases.contains(entry.name) 'hadConstraintError'
			continue
		end 'hadConstraintError'
		reportCompileError(project, code: ErrorCode.semanticUnusedTypeAlias, message: "unused typealias: '{entry.name}'", line: entry.line, column: entry.column, filePath: entry.filePath)
	end 'eachEntry'
	project.pendingUnusedTypealiases = PendingUnusedTypealiasArray.create()
end 'drainPendingUnusedTypealiases'

// Emit E2003 ("Unknown type: X") for every arg-name in a `genericAlias` that
// can't be resolved as a primitive, typealias, struct, enum, interface, or
// any other registered type. Reports against the typealias declaration's
// own location since the per-arg token positions are not threaded through
// the UnresolvedTypeExpr. Non-genericAlias variants have no arg-names to
// validate and are no-ops.
function validateGenericInstanceArgs(project Project, expr UnresolvedTypeExpr, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	match expr 'extract'
		genericAlias(_, args) then validateArgNamesExist(project, args: args, declLine: declLine, declColumn: declColumn, declFilePath: declFilePath)
		sizedGenericAlias then return
		boolPrim then return
		rangedFloat then return
		rangedInt then return
		aliasName then return
		functionAlias then return
		invalid then return
	end 'extract'
end 'validateGenericInstanceArgs'

function validateArgNamesExist(project Project, args StringArray, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	for argName in args 'eachArg'
		if isKnownTypeName(project, name: argName) 'known'
			continue
		end 'known'
		reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Unknown type: {argName}", line: declLine, column: declColumn, filePath: declFilePath)
	end 'eachArg'
end 'validateArgNamesExist'

// True when `name` resolves to any registered type (primitive, typealias,
// struct, enum, interface, generic-typealias, function, or known stdlib
// builtin) or to an inner-alias slot known to TypeResolution. Also checks
// the *unresolved* struct/enum/typealias/interface tables: drainPending-
// ConstraintChecks runs before `resolveAllStructTypes`, so during stdlib
// build the registries that will hold `Character` etc. are still under
// the `unresolvedStructTypes` / `unresolvedEnums` keys when we look them
// up. Differs from `namedIdIsKnown` (which gates a NameId-keyed
// resolved-type validity check that runs after the unresolved tables have
// been drained) by also probing those staging maps.
function isKnownTypeName(project Project, name String) returns bool
	if isBuiltinTypeName(name) 'isPrim'
		return true
	end 'isPrim'
	if project.unresolvedTypealiases.contains(name) or project.unresolvedStructTypes.contains(name) or project.unresolvedEnums.contains(name) or project.unresolvedInterfaces.contains(name) 'isUnresolved'
		return true
	end 'isUnresolved'
	return namedNameIsKnown(project, name: name)
end 'isKnownTypeName'

// Shared primitive whitelist for both unresolved-stage and post-resolution
// type-name validity probes. Includes both the casing of `string` (lower-
// case used by some stdlib decls) and `String` (the canonical alias name).
function isBuiltinTypeName(name String) returns bool
	return name == "bool" or name == "int" or name == "float" or name == "string" or name == "String" or name == "Character"
end 'isBuiltinTypeName'

function validateGenericInstanceConstraints(project Project, expr UnresolvedTypeExpr, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	match expr 'extract'
		genericAlias(baseName, args) then validateConstraintsFor(project, baseName: baseName, args: args, declLine: declLine, declColumn: declColumn, declFilePath: declFilePath)
		sizedGenericAlias then return
		boolPrim then return
		rangedFloat then return
		rangedInt then return
		aliasName then return
		functionAlias then return
		invalid then return
	end 'extract'
end 'validateGenericInstanceConstraints'

// Emit E2003 when the supplied `with`-arg count diverges from the base
// type's declared `uses` parameter arity (e.g. `Array with (Integer, String)`
// when `Array` declares `uses Element`). Mirrors the C# bootstrap's parse-
// time check at `PreScanTypeAlias` — the self-hosted parser accepts any
// arity and defers validation here, after every interface / struct / enum
// is registered. Bases with no recorded params (synthetic non-generic
// types, or a base we couldn't resolve) are left to `validateBaseAndArg-
// NamesExist`'s E2003 emission so we don't double-report.
function validateGenericInstanceArity(project Project, expr UnresolvedTypeExpr, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	match expr 'extract'
		genericAlias(baseName, args) then validateArityFor(project, baseName: baseName, args: args, declLine: declLine, declColumn: declColumn, declFilePath: declFilePath)
		sizedGenericAlias then return
		boolPrim then return
		rangedFloat then return
		rangedInt then return
		aliasName then return
		functionAlias then return
		invalid then return
	end 'extract'
end 'validateGenericInstanceArity'

function validateArityFor(project Project, baseName String, args StringArray, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	// Skip bases that haven't been registered through the parser's
	// `uses` clause path. This covers stdlib types not yet whitelisted
	// for self-host compilation (the resolver lazily handles them via
	// genericInstance lookups against the cache), and avoids false-
	// positive "no associated types" diagnostics on bases whose
	// generic-arity info isn't reachable from `lookupTypeParamsForBase`.
	let typeParams = lookupTypeParamsForBase(project, baseName: baseName)
	if typeParams.count() == 0 'noParams'
		return
	end 'noParams'
	if args.count() == typeParams.count() 'match'
		return
	end 'match'
	reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Type '{baseName}' expects {typeParams.count()} type argument(s), got {args.count()}", line: declLine, column: declColumn, filePath: declFilePath)
end 'validateArityFor'

function validateConstraintsFor(project Project, baseName String, args StringArray, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath)
	let typeParams = lookupTypeParamsForBase(project, baseName: baseName)
	let whereClauses = lookupWhereClausesForBase(project, baseName: baseName)
	if whereClauses.count() == 0 'noConstraints'
		return
	end 'noConstraints'
	if typeParams.count() == 0 'noParams'
		return
	end 'noParams'

	for i in 0 upto whereClauses.count() 'eachClause'
		let wc = try whereClauses.get(i) otherwise panic("validateConstraintsFor: whereClauses.get OOB at {i}")
		// Find the position of `wc.paramName` within the base's typeParams,
		// then look up the corresponding arg supplied at the call site.
		var paramIdx = -1
		for j in 0 upto typeParams.count() 'lookupIdx'
			let tp = try typeParams.get(j) otherwise panic("validateConstraintsFor: typeParams.get OOB at {j}")
			if tp == wc.paramName 'hit'
				paramIdx = j
				break
			end 'hit'
		end 'lookupIdx'
		if paramIdx < 0 'unknownParam'
			continue
		end 'unknownParam'
		if paramIdx >= args.count() 'argMissing'
			continue
		end 'argMissing'
		let argName = try args.get(paramIdx) otherwise panic("validateConstraintsFor: args.get OOB at {paramIdx}")
		let argType = internMaxonType(project, name: argName)
		if not typeConformsTo(project, t: argType, interfaceName: wc.requiredTraitName) 'violation'
			reportCompileError(project, code: ErrorCode.semanticConstraintViolation, message: "Type '{argName}' does not satisfy constraint '{wc.requiredTraitName}' required by type parameter '{wc.paramName}' of '{baseName}'", line: declLine, column: declColumn, filePath: declFilePath)
			// Match bootstrap's throw-on-first-error semantics: stop after
			// the first constraint violation for this generic instantiation.
			// Continuing would emit a cascade of related errors (e.g. Map's
			// `Key is Hashable and Equatable` would fire E3017 for both
			// constraints when `Key` is neither) that the bootstrap doesn't
			// produce, breaking spec-test diagnostic-text parity.
			return
		end 'violation'
	end 'eachClause'
end 'validateConstraintsFor'

export function lookupTypeParamsForBase(project Project, baseName String) returns StringArray
	if let unresolved = try project.unresolvedStructTypes.get(baseName) 'unresolvedHit'
		return unresolved.typeParams
	end 'unresolvedHit'
	// Interface bases store `uses` parameters directly on the IR record —
	// the parser doesn't intern them into TypeParamRegistry (mirrors the
	// bootstrap's `_interfaceAssociatedTypes` side-channel), so probe the
	// interface tables before falling through to the registry.
	if let unresolvedIface = try project.unresolvedInterfaces.get(baseName) 'unresolvedIfaceHit'
		return unresolvedIface.usesParams
	end 'unresolvedIfaceHit'
	if let iface = try project.interfaces.get(baseName) 'resolvedIfaceHit'
		return iface.usesParams
	end 'resolvedIfaceHit'
	// Resolved structs don't carry their typeParams directly; reconstruct
	// the parameter-name list from the project's TypeParamRegistry.
	return project.typeParameters.getParamNames(baseName)
end 'lookupTypeParamsForBase'

function lookupWhereClausesForBase(project Project, baseName String) returns WhereClauseArray
	if let unresolved = try project.unresolvedStructTypes.get(baseName) 'unresolvedHit'
		return unresolved.whereClauses
	end 'unresolvedHit'
	// Resolved structs lose their whereClauses array; reconstruct from the
	// per-typeParameter constraint sidecar populated by `parseTypeDecl`.
	var result = WhereClauseArray.create()
	let paramNames = project.typeParameters.getParamNames(baseName)
	for paramName in paramNames 'eachParam'
		let pid = project.typeParameters.intern(baseName, paramName: paramName)
		let traits = project.typeParameters.getConstraints(pid)
		for trait in traits 'eachTrait'
			result.push(WhereClause.createScoped(paramName, requiredTraitName: trait, declaringTypeName: baseName))
		end 'eachTrait'
	end 'eachParam'
	return result
end 'lookupWhereClausesForBase'

function tryResolveAliasName(project Project, name String) returns ResolveResult
	// If the referenced alias is already resolved, copy its StdType through
	// and propagate the range when one is recorded. Otherwise the entry has
	// to wait for a later iteration.
	let stdType = try project.typealiases.get(name) otherwise return ResolveResult.notYet()
	let range = try project.typealiasRanges.get(name) otherwise 'noRange'
		return ResolveResult.done(stdType)
	end 'noRange'
	return ResolveResult.doneRanged(stdType, range: range)
end 'tryResolveAliasName'

// One pass over the unresolved-typealias map: for every entry whose RHS
// resolves, move it into `typealiases` (and `typealiasRanges` if it has a
// range), then drop it from the unresolved map. Returns the number of
// entries that got resolved this pass — zero means the outer loop should
// stop.
function drainResolvableTypealiases(project Project) returns ParsedInt
	var resolvedNames = StringArray.create()

	for (name, entry) in project.unresolvedTypealiases 'sweep'
		// Phase 11.0 step 2: generic typealiases (`E = Base with (...)`) build a
		// `MaxonType.genericInstance(...)` and live in `project.genericTypealiases`,
		// not the StdType-typed `typealiases` map. Resolve out-of-band so the
		// rest of the drain stays focused on primitive/aliasName handling.
		if isGenericAliasExpr(entry.expr) 'genericFork'
			let resolvedType = resolveGenericAliasExpr(project, expr: entry.expr, declaringTypeName: "")
			try project.genericTypealiases.insert(name, value: resolvedType) otherwise ignore
			project.pendingConstraintChecks.push(PendingConstraintCheck.create(name, expr: entry.expr, declLine: entry.line, declColumn: entry.column, declFilePath: entry.filePath))
			resolvedNames.push(name)
			continue
		end 'genericFork'

		// Function-type aliases land in `genericTypealiases` too — the parser
		// fully resolved the signature via `parseTypeRef`, so the carried
		// MaxonType.function(id) is already canonical. No constraint check
		// is needed (no generic args).
		if isFunctionAliasExpr(entry.expr) 'functionFork'
			match entry.expr 'extract'
				functionAlias(target) then try project.genericTypealiases.insert(name, value: target) otherwise ignore
				boolPrim then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for boolPrim arm")
				rangedInt then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for rangedInt arm")
				rangedFloat then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for rangedFloat arm")
				aliasName then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for aliasName arm")
				genericAlias then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for genericAlias arm")
				sizedGenericAlias then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for sizedGenericAlias arm")
				invalid then panic("drainResolvableTypealiases: isFunctionAliasExpr returned true for invalid arm")
			end 'extract'
			resolvedNames.push(name)
			continue
		end 'functionFork'

		let result = tryResolveTypeExpr(project, expr: entry.expr)
		if not result.success 'wait'
			continue
		end 'wait'
		// Insert into the resolved maps. Duplicate insertions are ignored:
		// stdlib metadata restore may have already placed identical values
		// for bootstrap typealiases (ExitCode, IterStep, etc.) before the
		// unresolved map is drained, so collisions are benign.
		try project.typealiases.insert(name, value: result.stdType) otherwise ignore
		// Mirror the visibility tier into the sidecar map so cross-file
		// uses of the alias as a parameter / return type can be filtered.
		// Sidecar holds an array per name to support file-private aliases
		// declared in multiple files. The bare-name sidecar entry was already
		// added at parse time by `appendTypealiasVisibility` in
		// `parseTopLevelTypealias`; this drain-time append is idempotent
		// (duplicates coalesce by (visibility, sourceFilePath)).
		let sidecarName = bareNameFromKey(name, filePath: entry.filePath, rootPath: project.rootPath)
		appendTypealiasVisibility(project, name: sidecarName, info: TypealiasVisibilityInfo.create(entry.visibility, sourceFilePath: entry.filePath))
		if result.hasRange 'recordRange'
			try project.typealiasRanges.insert(name, value: result.range) otherwise ignore
		end 'recordRange'
		// Pin the user-declared cast category for ranged-primitive aliases so
		// narrow storage (e.g. u8 for `int(0 to 255)`) doesn't reclassify the
		// alias into the byte cast family.
		let declared = declaredCastCategoryFor(entry.expr)
		if declared.present 'recordCategory'
			try project.typealiasCastCategories.insert(name, value: declared.category) otherwise ignore
		end 'recordCategory'
		// E3063 support: also register under the qualified key
		// `{ns}.{bareName}` so a use-site `api.Score` resolves alongside the
		// bare `Score`. For entries that were already staged under the
		// qualified key (legacy.Score on the second-parsed cross-file
		// declaration), this also writes a bare-key entry — but the bare key
		// was already claimed by the first parsed declaration via the
		// `insert ... otherwise ignore` path above, so the bare lookup keeps
		// pointing at whichever was parsed first.
		let ns = deriveNamespace(entry.filePath, rootPath: project.rootPath)
		if not ns.isEmpty() 'haveNs'
			let qualifiedKey = qualifyName(ns, name: sidecarName)
			if qualifiedKey != name 'differsFromEntry'
				try project.typealiases.insert(qualifiedKey, value: result.stdType) otherwise ignore
				if result.hasRange 'recordRangeQualified'
					try project.typealiasRanges.insert(qualifiedKey, value: result.range) otherwise ignore
				end 'recordRangeQualified'
				if declared.present 'recordCategoryQualified'
					try project.typealiasCastCategories.insert(qualifiedKey, value: declared.category) otherwise ignore
				end 'recordCategoryQualified'
			end 'differsFromEntry'
			// Mirror the bare key as well when the entry was staged qualified
			// — so `Score` lookups have a value even if the bare slot wasn't
			// otherwise populated (rare edge case where only qualified entries
			// exist). The bare slot uses `otherwise ignore` so whichever
			// declaration wrote first stays the canonical bare entry.
			if sidecarName != name 'differsFromBare'
				try project.typealiases.insert(sidecarName, value: result.stdType) otherwise ignore
				if result.hasRange 'recordRangeBare'
					try project.typealiasRanges.insert(sidecarName, value: result.range) otherwise ignore
				end 'recordRangeBare'
				if declared.present 'recordCategoryBare'
					try project.typealiasCastCategories.insert(sidecarName, value: declared.category) otherwise ignore
				end 'recordCategoryBare'
			end 'differsFromBare'
		end 'haveNs'
		resolvedNames.push(name)
	end 'sweep'

	for resolvedName in resolvedNames 'drop'
		_ = project.unresolvedTypealiases.remove(resolvedName)
	end 'drop'

	return resolvedNames.count()
end 'drainResolvableTypealiases'

// Project-wide fixed-point typealias resolution. Runs zero or more drain
// passes until either the unresolved map is empty (success) or a pass
// produces no progress (failure — emit diagnostics for what's left).
//
// Idempotent: a second call is a no-op once the unresolved map is empty.
// The pass pipeline dispatches per-module, so the first module's call
// drains the project-wide registry and every later module just walks an
// empty map.
function resolveAllTypealiases(project Project)
	while project.unresolvedTypealiases.count() > 0 'fixedPoint'
		let progress = drainResolvableTypealiases(project)
		if progress == 0 'stuck'
			break
		end 'stuck'
	end 'fixedPoint'

	// Anything still in the unresolved map cannot be resolved. Distinguish
	// "RHS references a name nobody defined" (E3013) from "RHS references
	// another unresolved alias, which is itself unresolvable" (E3014 cycle).
	for (_, entry) in project.unresolvedTypealiases 'reportLeftover'
		reportUnresolvedTypealias(project, entry: entry)
	end 'reportLeftover'

	// Drop the unresolvable entries so subsequent module-level validation
	// doesn't trip over them again.
	var leftoverNames = StringArray.create()
	for (name, _) in project.unresolvedTypealiases 'collectNames'
		leftoverNames.push(name)
	end 'collectNames'
	for name in leftoverNames 'dropLeftover'
		_ = project.unresolvedTypealiases.remove(name)
	end 'dropLeftover'
end 'resolveAllTypealiases'

function reportUnresolvedTypealias(project Project, entry UnresolvedTypealias)
	match entry.expr 'classify'
		aliasName(target) then reportAliasNameUnresolved(project, entry: entry, target: target)
		boolPrim then panic("TypeResolution: boolPrim left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
		rangedInt then panic("TypeResolution: rangedInt left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
		rangedFloat then panic("TypeResolution: rangedFloat left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
		genericAlias then panic("TypeResolution: genericAlias left unresolved for '{entry.name}' — drainResolvableTypealiases unconditionally resolves these into project.genericTypealiases")
		sizedGenericAlias then panic("TypeResolution: sizedGenericAlias left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
		functionAlias then panic("TypeResolution: functionAlias left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
		invalid then panic("TypeResolution: invalid left unresolved for '{entry.name}' — drainResolvableTypealiases should have handled it")
	end 'classify'
end 'reportUnresolvedTypealias'

function reportAliasNameUnresolved(project Project, entry UnresolvedTypealias, target String)
	if project.unresolvedTypealiases.contains(target) 'isCycle'
		// Target is itself unresolved; treat as a cycle. The diagnostic
		// names both ends so a `typealias A = B; typealias B = A` pair
		// produces messages on both lines that point at each other.
		reportCompileError(project, code: ErrorCode.semanticTypeResolutionCycle, message: "typealias '{entry.name}' depends on '{target}', which is itself unresolved (cycle)", line: entry.line, column: entry.column, filePath: entry.filePath)
		return
	end 'isCycle'
	reportCompileError(project, code: ErrorCode.semanticUnknownType, message: "typealias '{entry.name}' references unknown type '{target}'", line: entry.line, column: entry.column, filePath: entry.filePath)
end 'reportAliasNameUnresolved'

// --- Interface resolution ---

// Drain `project.unresolvedInterfaces` into `project.interfaces`. Each
// `UnresolvedInterfaceType` becomes an `IrInterface` carrying the
// parser-recorded method signatures unchanged — names matching a `usesParams`
// entry stay as `MaxonType.named(<param-name>)`. Per-conformance
// substitution into a concrete method set is the conforming type's job
// (see `computeExpectedMethodsForConformances`).
//
// The drain is non-fixed-point: interface declarations don't depend on
// other interfaces structurally for resolution. `extends` parents are
// validated by Phase 3b's transitive walk, not here.
function resolveAllInterfaces(project Project)
	// Inherit `uses` parameters from `extends` parents before draining —
	// the parser cannot do this safely because parents declared in a
	// different file aren't in `unresolvedInterfaces` until every file
	// has been parsed.
	inheritInterfaceUsesParams(project)

	var resolvedNames = StringArray.create()

	for (name, entry) in project.unresolvedInterfaces 'sweep'
		// Phase 11.0 mirror of `resolveAllStructTypes`: promote inner-typealias
		// declarations harvested by `mergeExtensionInnerAliases` into a
		// per-interface table of resolved MaxonTypes. Generic-form aliases
		// resolve through `resolveGenericAliasExpr` so `Element` in
		// `__ManagedMemory with Element` becomes a `MaxonType.typeParameter`
		// scoped to this interface; non-generic aliases fall back to a named
		// placeholder until full StdType chaining is wired up.
		var resolvedInnerAliases = ResolvedInnerAliasMap.create()
		for (aliasName, aliasExpr) in entry.innerAliases 'eachInner'
			if isGenericAliasExpr(aliasExpr) 'isGeneric'
				let resolvedType = resolveGenericAliasExpr(project, expr: aliasExpr, declaringTypeName: entry.name)
				try resolvedInnerAliases.insert(aliasName, value: resolvedType) otherwise ignore
			end 'isGeneric' else 'nonGeneric'
				let resolvedType = resolveNonGenericInnerAlias(project, expr: aliasExpr, aliasName: aliasName)
				try resolvedInnerAliases.insert(aliasName, value: resolvedType) otherwise ignore
			end 'nonGeneric'
		end 'eachInner'

		let iface = IrInterface.create(entry.name, extendsNames: entry.extendsNames, usesParams: entry.usesParams, methods: entry.methods, visibility: entry.visibility, line: entry.line, column: entry.column, filePath: entry.filePath, innerAliases: resolvedInnerAliases)
		// Parser rejects duplicate interfaces against the unresolved map
		// before inserting. Collisions with the resolved map (e.g. stdlib-
		// cached interfaces reusing a name) are silently ignored here so
		// cache restore continues to win — same convention as the struct
		// and enum drains.
		try project.interfaces.insert(name, value: iface) otherwise ignore
		resolvedNames.push(name)
	end 'sweep'

	for resolvedName in resolvedNames 'drop'
		_ = project.unresolvedInterfaces.remove(resolvedName)
	end 'drop'
end 'resolveAllInterfaces'

// For each interface in `unresolvedInterfaces` with no explicit `uses`
// clause, copy `usesParams` from its first `extends` parent that has
// any. Parents are looked up against both `unresolvedInterfaces` (the
// current compile's user interfaces) and `interfaces` (stdlib-cached
// interfaces). An explicit `uses` clause on the child is preserved
// unchanged — opting in to inheritance is the default, opting out is
// explicit. Forward references across files are now safe because every
// interface has been recorded by the time TR runs.
function inheritInterfaceUsesParams(project Project)
	var updates = InterfaceUsesUpdateArray.create()
	for (name, entry) in project.unresolvedInterfaces 'scan'
		if entry.usesParams.count() > 0 'hasOwnUses'
			continue
		end 'hasOwnUses'
		for parentName in entry.extendsNames 'eachParent'
			let inherited = lookupInterfaceUsesParams(project, name: parentName)
			if inherited.count() > 0 'foundInherit'
				updates.push(InterfaceUsesUpdate.create(name, params: inherited))
				break
			end 'foundInherit'
		end 'eachParent'
	end 'scan'

	for upd in updates 'apply'
		// Mutate in place so any state attached after parsing (e.g.
		// extension-merged `innerAliases`) survives the usesParams refresh.
		// Recreating via `UnresolvedInterfaceType.create` would zero those
		// fields back to their defaults.
		if var existing = try project.unresolvedInterfaces.get(upd.name) 'haveEntry'
			existing.usesParams = upd.params
			project.unresolvedInterfaces.upsert(upd.name, value: existing)
		end 'haveEntry'
	end 'apply'
end 'inheritInterfaceUsesParams'

function lookupInterfaceUsesParams(project Project, name String) returns StringArray
	if let resolved = try project.interfaces.get(name) 'fromResolved'
		return resolved.usesParams
	end 'fromResolved'
	if let unresolved = try project.unresolvedInterfaces.get(name) 'fromUnresolved'
		return unresolved.usesParams
	end 'fromUnresolved'
	return StringArray.create()
end 'lookupInterfaceUsesParams'

type InterfaceUsesUpdate
	export var name as String
	export var params as StringArray

	export static function create(name String, params StringArray) returns InterfaceUsesUpdate
		return Self{name: name, params: params}
	end 'create'
end 'InterfaceUsesUpdate'

typealias InterfaceUsesUpdateArray = Array with InterfaceUsesUpdate

// Phase 9.7: when an interface inherits its `usesParams` from an `extends`
// parent, allow a 0-args sibling conformance to reuse the parent's bindings.
// Walks `iface.extendsNames` (transitively via project.interfaces) looking
// for any ancestor that appears in the sibling conformance list with the
// expected number of withArgs. Returns the first match's withArgs, or an
// empty StringArray if no sibling-parent conformance was found.
//
// The transitive walk is bounded by the project's interface graph; cycles
// would indicate a malformed `extends` graph (the parser doesn't validate
// for those today, so we keep a `visited` set as a guard).
function findInheritedBindings(project Project, iface IrInterface, siblings ConformanceArray) returns StringArray
	var visited = StringSet.create()
	var queue = StringArray.create()
	for parentName in iface.extendsNames 'seedQueue'
		queue.push(parentName)
	end 'seedQueue'

	while queue.count() > 0 'walk'
		let head = try queue.remove(0) otherwise break

		if visited.contains(head) 'skip'
			continue
		end 'skip'
		visited.insert(head)

		// Look for a sibling conformance that names this ancestor.
		for sib in siblings 'eachSib'
			if sib.interfaceName == head and sib.withArgs.count() == iface.usesParams.count() 'match'
				return sib.withArgs
			end 'match'
		end 'eachSib'

		// Enqueue the ancestor's own extends-parents for transitive lookup.
		let parent = try project.interfaces.get(head) otherwise continue
		for grandparent in parent.extendsNames 'enqueueGp'
			queue.push(grandparent)
		end 'enqueueGp'
	end 'walk'

	return StringArray.create()
end 'findInheritedBindings'

// Type-parameter name → bound MaxonType, threaded through the substitute
// family below. A map (rather than two parallel arrays) keeps the per-name
// lookup O(1) so the inner loop of `substituteNamedId` doesn't turn the
// conformance walk into O(M·I·K·P²).
typealias TypeBindingMap = Map with (String, MaxonType)

// Build the substituted method set a conforming type is expected to
// provide. Each `Conformance` in `conformances` names an interface and
// (optionally) a list of `withArgs` that bind the interface's `usesParams`
// to concrete type names. For each interface method, we walk the
// signature, replace any `MaxonType.named(<param-name>)` reference with
// the concrete binding's MaxonType, and append the result.
//
// A missing-interface conformance reports E3015 and contributes nothing
// (Phase 3b only sees what conformances we believe in). An arity-mismatch
// conformance reports E3015 and contributes nothing for the same reason —
// substituting against a partial binding map would silently drop or
// duplicate methods.
function computeExpectedMethodsForConformances(project Project, declName String, conformances ConformanceArray, declFilePath FilePath) returns InterfaceMethodSigArray
	var expected = InterfaceMethodSigArray.create()

	for conf in conformances 'eachConf'
		let iface = try project.interfaces.get(conf.interfaceName) otherwise 'noIface'
			reportCompileError(project, code: ErrorCode.semanticUnknownInterface, message: "type '{declName}' implements unknown interface '{conf.interfaceName}'", line: conf.line, column: conf.column, filePath: declFilePath)
			continue
		end 'noIface'

		// Resolve the parser-time bare names into MaxonTypes, applying the
		// parenthesized-tuple collapse when the interface has exactly one
		// `uses` param. This lets `Iterator with (Source, Element)` bind
		// `Element = __Tuple2(Source, Element)` instead of erroring on arity.
		var resolvedWithArgs = resolveConformanceWithArgs(project, conf: conf, usesCount: iface.usesParams.count())

		// Phase 9.7: when a conformance lists 0 args but the interface
		// inherits its `usesParams` from an `extends` parent, allow the
		// bindings to come from a sibling conformance to that parent in
		// the same `implements` list. This lets
		// `RangeIterator implements Iterator with RangeBound, BidirectionalIterator`
		// reuse the `Iterator with RangeBound` binding for
		// BidirectionalIterator's inherited `Element` slot — the explicit
		// re-declaration `BidirectionalIterator with RangeBound` is also
		// accepted via the standard arity-matched path below.
		if conf.withArgs.count() == 0 and iface.usesParams.count() > 0 'maybeInherit'
			let inherited = findInheritedBindings(project, iface: iface, siblings: conformances)
			if inherited.count() == iface.usesParams.count() 'gotInherit'
				resolvedWithArgs = MaxonTypeArray.create()
				for arg in inherited 'copyInherit'
					resolvedWithArgs.push(internMaxonType(project, name: arg))
				end 'copyInherit'
			end 'gotInherit'
		end 'maybeInherit'

		if resolvedWithArgs.count() != iface.usesParams.count() 'arityMismatch'
			// The "conformer provides zero `with` clauses but the interface
			// declares one or more `uses` params" case has a dedicated
			// diagnostic (E3016, "does not define required associated type
			// '<Param>' from interface '<Iface>'") — the bootstrap fires
			// this shape so the user knows to add `with <Type>` clauses.
			// The arity-mismatch shape (E3015) covers the case where SOME
			// args were provided but not enough (`Pair with Int` against
			// `Pair uses First, Second`).
			if conf.withArgs.count() == 0 and iface.usesParams.count() > 0 'missingBinding'
				let firstParam = try iface.usesParams.get(0) otherwise ""
				reportCompileError(project, code: ErrorCode.semanticPartialInterfaceImpl, message: "Type '{declName}' does not define required associated type '{firstParam}' from interface '{conf.interfaceName}'", line: conf.line, column: conf.column, filePath: declFilePath)
				continue
			end 'missingBinding'
			reportCompileError(project, code: ErrorCode.semanticUnknownInterface, message: "interface '{conf.interfaceName}' expects {iface.usesParams.count()} type parameter(s), got {conf.withArgs.count()}", line: conf.line, column: conf.column, filePath: declFilePath)
			continue
		end 'arityMismatch'

		// Build the parameter-name → concrete-MaxonType map for this
		// conformance. Bindings are interned through the project's
		// type-name table so the substituted `MaxonType.named(id)` shares
		// the canonical id with every other reference to the same name.
		// `Self` in an interface body parses to `MaxonType.named(<ifaceName>)`
		// (currentTypeName resolution at parse time), so we add an extra
		// binding mapping the interface's own name to the conforming type's
		// name. Without this binding, signature-matching would compare an
		// interface's `equals(other Self)` (resolved to `equals(other Equatable)`)
		// against an implementer's `equals(other String)` and reject the
		// otherwise-correct conformance.
		var bindings = TypeBindingMap.create()
		for i in 0 upto iface.usesParams.count() 'buildBindings'
			let paramName = try iface.usesParams.get(i) otherwise panic("computeExpectedMethodsForConformances: usesParams.get OOB at {i}")
			let argType = try resolvedWithArgs.get(i) otherwise panic("computeExpectedMethodsForConformances: resolvedWithArgs.get OOB at {i}")
			bindings.upsert(paramName, value: argType)
		end 'buildBindings'
		bindings.upsert(conf.interfaceName, value: internMaxonType(project, name: declName))

		// Walk this interface and every transitively-extended parent so the
		// implementing type is responsible for satisfying the inherited methods
		// too — `interface Derived extends Base` means a type that
		// `implements Derived` must declare every method from both `Derived`
		// and `Base`. Each parent contributes a `(parentName → declName)`
		// binding so any `Self` references inside the parent's signatures
		// (parsed as `MaxonType.named(<parentName>)`) substitute back to the
		// implementing type, mirroring the C# bootstrap's `CollectInterfaceMethods`.
		var visited = StringSet.create()
		collectInterfaceMethodsInto(project, iface: iface, declName: declName, directInterfaceName: conf.interfaceName, bindings: bindings, expected: expected, visited: visited)
	end 'eachConf'

	return expected
end 'computeExpectedMethodsForConformances'

// Walk an interface and its `extends` ancestors, appending each method
// signature (substituted against the binding map) into `expected`. The
// `visited` set guards against cycles and against an ancestor being reached
// twice via two different extends paths. For each ancestor visited, we
// temporarily augment `bindings` with `(ancestorName → declName)` so any
// `Self` references parsed inside that ancestor's body resolve to the
// implementing type, then restore the previous mapping after recursion so
// siblings see the original binding state.
function collectInterfaceMethodsInto(project Project, iface IrInterface, declName String, directInterfaceName String, bindings TypeBindingMap, expected InterfaceMethodSigArray, visited StringSet)
	if visited.contains(iface.name) 'hit'
		return
	end 'hit'
	visited.insert(iface.name)

	for sig in iface.methods 'eachMethod'
		var substituted = substituteMethodSig(project, sig: sig, bindings: bindings)
		substituted.sourceInterfaceName = iface.name
		substituted.directInterfaceName = directInterfaceName
		expected.push(substituted)
	end 'eachMethod'

	for parentName in iface.extendsNames 'eachParent'
		let parent = try project.interfaces.get(parentName) otherwise continue
		// Augment bindings with `(parentName → declName)` so the parent's
		// `Self` references substitute correctly. The parent inherits the
		// child's `usesParams` bindings unchanged — interface inheritance in
		// Maxon doesn't introduce new type parameters at the boundary.
		// First-binding-wins: a pre-existing entry for `parentName` (e.g. a
		// usesParam already mapped to a concrete type) is preserved so the
		// inner recursion sees the same lookup the original linear scan did.
		// When no prior entry exists, insert the parent→declName binding for
		// the duration of the recursion and remove it afterward so sibling
		// parents at this level start from the same binding state.
		let hadPrev = bindings.contains(parentName)
		if not hadPrev 'inject'
			bindings.upsert(parentName, value: internMaxonType(project, name: declName))
		end 'inject'
		collectInterfaceMethodsInto(project, iface: parent, declName: declName, directInterfaceName: directInterfaceName, bindings: bindings, expected: expected, visited: visited)
		if not hadPrev 'drop'
			_ = bindings.remove(parentName)
		end 'drop'
	end 'eachParent'
end 'collectInterfaceMethodsInto'

// Apply the binding map to one method signature: every parameter type and
// the return type get walked through `substituteMaxonType`; the throws
// type name gets the same string-substitution treatment so a method
// declared as `throws Element` (rare, but valid in principle) ends up
// throwing the bound concrete type.
function substituteMethodSig(project Project, sig InterfaceMethodSig, bindings TypeBindingMap) returns InterfaceMethodSig
	var newParamTypes = MaxonTypeArray.create()
	for pt in sig.paramTypes 'eachParam'
		newParamTypes.push(substituteMaxonType(project, t: pt, bindings: bindings))
	end 'eachParam'

	let newReturnType = match sig.returnType 'rt'
		void gives MaxonReturnType.void
		value(inner) gives MaxonReturnType.value(substituteMaxonType(project, t: inner, bindings: bindings))
	end 'rt'

	let newThrows = substituteThrowsName(sig.throwsTypeName, bindings: bindings, project: project)

	return InterfaceMethodSig.create(sig.name, paramNames: sig.paramNames, paramTypes: newParamTypes, returnType: newReturnType, throwsTypeName: newThrows, isStatic: sig.isStatic, line: sig.line, column: sig.column)
end 'substituteMethodSig'

// Replace one `MaxonType.named(id)` whose name matches a binding with the
// bound concrete type. Other arms (primitives, unresolved, unmapped named
// references) pass through unchanged. A primitive can never be a type-
// parameter binding target since binding names are always identifiers.
function substituteMaxonType(project Project, t MaxonType, bindings TypeBindingMap) returns MaxonType
	match t 'kind'
		named(id) then return substituteNamedId(project, id: id, bindings: bindings)
		boolean then return MaxonType.boolean
		integer then return MaxonType.integer
		float then return MaxonType.float
		string then return MaxonType.string
		// Function types are structural — they don't carry a name to bind
		// against — so they pass through substitution unchanged. (Inner
		// param/return types might mention bound names, but that
		// substitution is Stage E's concern; today's Stage A doesn't
		// permit interface methods to take function-typed parameters in
		// generic positions.)
		function(id) then return MaxonType.function(id)
		unresolved then return MaxonType.unresolved
		// Phase 11.0: generic-aware arms pass through unchanged for now.
		// Phase 11 step 5 will recurse into genericInstance args and resolve
		// typeParameter against the binding tables — until then, every
		// caller of substituteMaxonType only sees parser-AST inputs that
		// don't yet carry these arms in conformance-derived signatures.
		typeParameter to opaquePointer then return t
	end 'kind'
end 'substituteMaxonType'

function substituteNamedId(project Project, id TypeNameId, bindings TypeBindingMap) returns MaxonType
	let name = project.typeNames.get(id)
	return try bindings.get(name) otherwise MaxonType.named(id)
end 'substituteNamedId'

// When the name carried by a `ThrowsClause.throwing(name)` matches a
// parameter binding, resolve through the binding's concrete type and rebuild
// the `throwing` arm with the substituted name. Non-throwing methods
// (`ThrowsClause.none`) pass through unchanged. If the substituted type has
// no name, fall back to the original clause to avoid synthesising a
// `throwing("")` sentinel.
function substituteThrowsName(throwsTypeName ThrowsClause, bindings TypeBindingMap, project Project) returns ThrowsClause
	let name = match throwsTypeName 'unwrap'
		none gives ""
		throwing(n) gives n
	end 'unwrap'
	if name.isEmpty() 'noThrow'
		return ThrowsClause.none
	end 'noThrow'
	let bt = try bindings.get(name) otherwise 'noBind'
		return ThrowsClause.throwing(name)
	end 'noBind'
	let substituted = bt.nameOrEmpty(project)
	if substituted.isEmpty() 'unnamed'
		// Anonymous binding type — fall back to the unsubstituted clause
		// rather than introducing a `throwing("")` sentinel.
		return throwsTypeName
	end 'unnamed'
	return ThrowsClause.throwing(substituted)
end 'substituteThrowsName'

// --- Struct type resolution ---

// Drain `project.unresolvedStructTypes` into `project.structTypes`. Struct
// resolution is non-fixed-point — each entry's information is independent
// (its field MaxonTypes are validated separately, after this drain, against
// the now-fully-populated registries). The expected method set from any
// `implements` clause is computed here so the resolved `StructType` carries
// it; Phase 3b consumes the field for E3016 enforcement.
// Drain the cross-file extension-inner-alias queue. The parser queues an
// extension's inner typealiases here when the target struct/interface hadn't
// been parsed yet (`mergeExtensionInnerAliases`). By the time runTypeResolution
// runs, every type declaration exists, so merge each queued alias into its
// target's `innerAliases` (unresolved struct or interface). resolveAllStructTypes
// / resolveAllInterfaces then promote them into the resolved inner-alias maps
// so `chaseTypealiasToFunctionType` (used by buildAbiParamMaps and the indirect-
// call resolver) finds them. A target still absent here stays unmerged — the
// extension's methods surface the missing-target diagnostic on their own.
function drainPendingExtensionInnerAliases(project Project)
	for (targetTypeName, extInnerAliases) in project.pendingExtensionInnerAliases 'eachTarget'
		if var structTarget = try project.unresolvedStructTypes.get(targetTypeName) 'structHit'
			for (aliasName, aliasExpr) in extInnerAliases 'eachStructAlias'
				if not structTarget.innerAliases.contains(aliasName) 'novelStruct'
					structTarget.innerAliases.upsert(aliasName, value: aliasExpr)
				end 'novelStruct'
				project.structInnerAliasNames.insert(aliasName)
			end 'eachStructAlias'
			project.unresolvedStructTypes.upsert(targetTypeName, value: structTarget)
		end 'structHit' else if var ifaceTarget = try project.unresolvedInterfaces.get(targetTypeName) 'ifaceHit'
			for (aliasName, aliasExpr) in extInnerAliases 'eachIfaceAlias'
				if not ifaceTarget.innerAliases.contains(aliasName) 'novelIface'
					ifaceTarget.innerAliases.upsert(aliasName, value: aliasExpr)
				end 'novelIface'
			end 'eachIfaceAlias'
			project.unresolvedInterfaces.upsert(targetTypeName, value: ifaceTarget)
		end 'ifaceHit'
	end 'eachTarget'
	project.pendingExtensionInnerAliases = PendingExtensionInnerAliasMap.create()
end 'drainPendingExtensionInnerAliases'

//
// The interface drain (`resolveAllInterfaces`) MUST run before this so the
// expected-method computation can look up named interfaces.
function resolveAllStructTypes(project Project)
	var resolvedNames = StringArray.create()

	for (name, entry) in project.unresolvedStructTypes 'sweep'
		let expected = computeExpectedMethodsForConformances(project, declName: entry.name, conformances: entry.implementedInterfaces, declFilePath: entry.filePath)
		// Phase 11.0 step 2: promote inner-typealias declarations into a
		// per-struct table of resolved MaxonTypes. Type-parameter args defer
		// to the type's own `typeParams` scope so `typealias E = Base with
		// Element` inside `type Foo uses Element` resolves `Element` as a
		// `MaxonType.typeParameter(...)`. Non-genericAlias inner aliases
		// pass through `tryResolveTypeExpr` and store their StdType-typed
		// resolution as `MaxonType.named(<aliasName>)` placeholder for now —
		// step 5 will sharpen the lookup. Today, only generic inner aliases
		// (the `__ManagedMemory with Element` shape) are observed in stdlib.
		var resolvedInnerAliases = ResolvedInnerAliasMap.create()
		for (aliasName, aliasExpr) in entry.innerAliases 'eachInner'
			if isGenericAliasExpr(aliasExpr) 'isGeneric'
				let resolvedType = resolveGenericAliasExpr(project, expr: aliasExpr, declaringTypeName: entry.name)
				try resolvedInnerAliases.insert(aliasName, value: resolvedType) otherwise ignore
			end 'isGeneric' else 'nonGeneric'
				let resolvedType = resolveNonGenericInnerAlias(project, expr: aliasExpr, aliasName: aliasName)
				try resolvedInnerAliases.insert(aliasName, value: resolvedType) otherwise ignore
			end 'nonGeneric'
		end 'eachInner'

		let st = StructType.create(entry.name, fields: entry.fields, byteSize: entry.byteSize, visibility: entry.visibility, sourceFilePath: entry.filePath, nameLine: entry.line, nameColumn: entry.column, expectedMethods: expected, innerAliases: resolvedInnerAliases)
		// Parser rejects duplicates against the unresolved map before
		// inserting; collisions with the resolved map (e.g. stdlib-cached
		// structs reusing a name) are silently ignored here so cache restore
		// continues to win.
		try project.structTypes.insert(name, value: st) otherwise ignore
		// Persist source-declaration order so `getParamNames` returns the
		// right pairing for `resolveCalleeParamToConcreteType` regardless
		// of what order the registry's id space got populated.
		if entry.typeParams.count() > 0 'hasTypeParams'
			var paramOrderCopy = StringArray.create()
			for n in entry.typeParams 'copyTypeParams'
				paramOrderCopy.push(n)
			end 'copyTypeParams'
			project.typeParameters.recordParamOrder(entry.name, paramOrder: paramOrderCopy)
		end 'hasTypeParams'
		resolvedNames.push(name)
	end 'sweep'

	for resolvedName in resolvedNames 'drop'
		_ = project.unresolvedStructTypes.remove(resolvedName)
	end 'drop'
end 'resolveAllStructTypes'

// Drain `project.unresolvedEnums` into `project.enumTypes`. Mirrors the struct
// drain — each enum's information is independent (case raw-value uniqueness
// was validated at parse time), so the drain is non-fixed-point. Conformance
// substitution mirrors structs: an enum that declares `implements I with X`
// gets its expected method set computed against the resolved interface
// before the EnumType is built.
function resolveAllEnumTypes(project Project)
	var resolvedNames = StringArray.create()

	for (name, entry) in project.unresolvedEnums 'sweep'
		let expected = computeExpectedMethodsForConformances(project, declName: entry.name, conformances: entry.implementedInterfaces, declFilePath: entry.filePath)
		let et = EnumType.create(entry.name, cases: entry.cases, isFloatBacked: entry.isFloatBacked, visibility: entry.visibility, sourceFilePath: entry.filePath, nameLine: entry.line, nameColumn: entry.column, expectedMethods: expected, isUnion: entry.isUnion, isStringBacked: entry.isStringBacked, isCharBacked: entry.isCharBacked, isFunctionBacked: entry.isFunctionBacked)
		try project.enumTypes.insert(name, value: et) otherwise ignore
		resolvedNames.push(name)
	end 'sweep'

	for resolvedName in resolvedNames 'drop'
		_ = project.unresolvedEnums.remove(resolvedName)
	end 'drop'
end 'resolveAllEnumTypes'

// Resolves the deferred function references on every function-backed enum.
// Runs after `resolveAllEnumTypes` (which has populated `project.enumTypes`)
// and after every file's top-level function signatures have been registered
// into `project.funcReturnTypes` / `project.funcSignatures`. For each
// function-backed enum, look every case's bare function identifier up via
// `qualifyCalleeForContext`, then ensure all cases share the same signature
// (signature = same parameter MaxonTypes + same return MaxonReturnType). On
// success: rewrite each case's `rawFunctionName` to the fully qualified
// callable name (so the `.rawValue` lowering can emit a matching `funcRef`),
// and stamp the enum's `functionBackingTypeId` with the shared
// `FunctionTypeId`. On failure: report a diagnostic and leave the enum
// in its placeholder state.
export function resolveFunctionBackedEnumRefs(project Project)
	// Collect the work first, then mutate the map after — Maxon for-in
	// tuple bindings are immutable, so we can't update enumDef in place
	// during the iteration. The map.upsert at the end writes the resolved
	// EnumType back keyed by its name.
	var pendingNames = StringArray.create()
	var pendingTypes = EnumTypeArray.create()
	for (enumName, enumDef) in project.enumTypes 'sweep'
		if not enumDef.isFunctionBacked 'notFn'
			continue
		end 'notFn'
		if enumDef.functionBackingTypeId != 0 'alreadyResolved'
			continue
		end 'alreadyResolved'
		var sharedFnTypeId = 0 as FunctionTypeId
		var sharedFromCase = ""
		var hadError = false
		// Build a fresh case list with rewritten rawFunctionName. We replace
		// the array rather than mutating elements because EnumCase fields
		// flowing out of `for c in cases` are immutable.
		var newCases = EnumCaseArray.create()
		for i in 0 upto enumDef.cases.count() 'cases'
			let c = try enumDef.cases.get(i) otherwise panic("resolveFunctionBackedEnumRefs: cases.get OOB at {i}")
			if c.rawFunctionName.isEmpty() 'noFn'
				newCases.push(c)
				continue
			end 'noFn'
			let ns = deriveNamespace(enumDef.sourceFilePath, rootPath: project.rootPath)
			let qualified = qualifyCalleeForContext(project, bare: c.rawFunctionName, callContext: CallContext.free, currentNamespace: ns, readerFilePath: enumDef.sourceFilePath)
			if not project.funcSignatures.contains(qualified) or not project.funcReturnTypes.contains(qualified) 'noFunc'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "function '{c.rawFunctionName}' (referenced by enum case '{enumName}.{c.name}') is not declared", line: c.line, column: c.column, filePath: enumDef.sourceFilePath)
				hadError = true
				newCases.push(c)
				continue
			end 'noFunc'
			let sig = try project.funcSignatures.get(qualified) otherwise panic("resolveFunctionBackedEnumRefs: funcSignatures.contains(true) but get() failed for '{qualified}'")
			let returnType = try project.funcReturnTypes.get(qualified) otherwise panic("resolveFunctionBackedEnumRefs: funcReturnTypes.contains(true) but get() failed for '{qualified}'")
			let caseFnTypeId = internFunctionType(project, paramTypes: sig.paramTypes, returnType: returnType)
			if sharedFnTypeId == 0 'first'
				sharedFnTypeId = caseFnTypeId
				sharedFromCase = c.name
			end 'first' else if caseFnTypeId != sharedFnTypeId 'mismatch'
				let gotSig = functionTypeToString(project, id: caseFnTypeId)
				let expectedSig = functionTypeToString(project, id: sharedFnTypeId)
				reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: function '{c.rawFunctionName}' has signature '{gotSig}', but case '{enumName}.{sharedFromCase}' established signature '{expectedSig}'", line: c.line, column: c.column, filePath: enumDef.sourceFilePath)
				hadError = true
			end 'mismatch'
			let updated = EnumCase.create(c.name, ordinal: c.ordinal, rawValue: c.rawValue, line: c.line, column: c.column, payloadFields: c.payloadFields, backingStructName: c.backingStructName, backingStructExprId: c.backingStructExprId, rawStringValue: c.rawStringValue, rawFunctionName: qualified)
			newCases.push(updated)
		end 'cases'
		if hadError 'skipCommit'
			continue
		end 'skipCommit'
		let finalFnTypeId = sharedFnTypeId
		let rebuilt = EnumType.create(enumDef.name, cases: newCases, isFloatBacked: enumDef.isFloatBacked, visibility: enumDef.visibility, sourceFilePath: enumDef.sourceFilePath, nameLine: enumDef.nameLine, nameColumn: enumDef.nameColumn, expectedMethods: enumDef.expectedMethods, isUnion: enumDef.isUnion, isStringBacked: enumDef.isStringBacked, isCharBacked: enumDef.isCharBacked, isFunctionBacked: true, functionBackingTypeId: finalFnTypeId)
		pendingNames.push(enumName)
		pendingTypes.push(rebuilt)
		// Seed every case's function as a liveness root. The `.rawValue`
		// lowering reaches these functions only through a StdCallOp.funcRef
		// emitted in a synthesized helper — DFE's MaxonOp walker doesn't
		// see those references, so without an explicit root each fn-backed
		// case's function would get stripped before codegen.
		for i in 0 upto newCases.count() 'roots'
			let c = try newCases.get(i) otherwise panic("resolveFunctionBackedEnumRefs: newCases.get OOB at {i}")
			if not c.rawFunctionName.isEmpty() 'haveFn'
				project.livenessRoots.push(c.rawFunctionName)
			end 'haveFn'
		end 'roots'
	end 'sweep'
	for i in 0 upto pendingNames.count() 'apply'
		let key = try pendingNames.get(i) otherwise panic("resolveFunctionBackedEnumRefs: pendingNames.get OOB at {i}")
		let value = try pendingTypes.get(i) otherwise panic("resolveFunctionBackedEnumRefs: pendingTypes.get OOB at {i}")
		project.enumTypes.upsert(key, value: value)
	end 'apply'
end 'resolveFunctionBackedEnumRefs'

// Round `value` up to the next multiple of `multiple`. `multiple` is always
// a positive power-of-2 here (1, 2, 4, 8 — the storeWidthBytes results), so
// the bit-twiddling form is equivalent to `((value + multiple - 1) / multiple)
// * multiple` and avoids the division. Local to the layout pass — other
// alignment paths in the codebase use the targets/Shared `alignUp` helper
// which carries the same semantics but a different parameter shape.
function roundUpToMultiple(value MachineWord, multiple MachineWord) returns MachineWord
	return (value + multiple - 1) and not (multiple - 1)
end 'roundUpToMultiple'

// Stamp every registered struct's field offsets and total `byteSize`.
//
// Runs after both `resolveAllStructTypes` and `resolveAllEnumTypes` so that:
//   - Every struct that the parser registered now lives in
//     `project.structTypes` with its fields' MaxonTypes copied over.
//   - Typealiases (including narrow-int aliases produced by enums) are
//     fully resolved, so this pass can call
//     `resolveMaxonTypeToStd(project, ref: field.fieldType)` and get a
//     correct StdType for each field.
//
// Each field is placed at the next offset that satisfies natural alignment
// for its resolved StdType's `StoreWidth`. Pointer-shaped types (struct
// references, strings, function values, interface values, typeParameters,
// genericInstances) resolve to `i64` and so consume 8 bytes at 8-byte
// alignment — preserving the historic layout. Narrow integer typealiases
// (e.g. an enum backed by `int(0 to 255)` → `u8`) consume only 1 byte. The
// struct's total `byteSize` is rounded up to 8 bytes so `__mm_alloc`'s
// 8-byte alignment invariant continues to hold for every allocated struct.
//
// Structs whose fields are all already `offsetResolved: true` (i.e.
// loaded from the stdlib cache, or synthesized at lowering time with
// hand-baked offsets) are left untouched.
export function layoutAllStructs(project Project)
	// Iterating `project.structTypes` by value yields immutable copies of
	// each StructType, so we accumulate the rebuilt entries and `upsert`
	// them after the walk. Mutating in-place would be cheaper but the map
	// API doesn't expose that today.
	var rebuiltNames = StringArray.create()
	var rebuiltStructs = StructTypeArray.create()
	for (structName, st) in project.structTypes 'eachStruct'
		var allResolved = true
		for f in st.fields 'check'
			if not f.offsetResolved 'unresolved'
				allResolved = false
				break
			end 'unresolved'
		end 'check'
		if allResolved 'skipCached'
			continue
		end 'skipCached'

		var newFields = StructFieldArray.create()
		var nextOffset = 0 as MachineWord
		for i in 0 upto st.fields.count() 'eachField'
			let f = try st.fields.get(i) otherwise panic("layoutAllStructs: fields.get OOB at {i} for '{structName}'")
			// Interface-typed fields are stored as 16-byte fat pointers
			// (data half at +0, witness-table address at +8). Without this
			// carve-out the field is sized as a plain pointer (8 bytes) and
			// the field-load lowering has nowhere to read the witness back
			// from when an interface value is passed onward to a function
			// expecting the same interface. Both halves are pointer-sized so
			// 8-byte alignment is sufficient — no need for 16-byte alignment.
			var widthBytes = 0 as MachineWord
			var alignBytes = 0 as MachineWord
			if interfaceTypeIsFat(f.fieldType) 'iface'
				widthBytes = 16
				alignBytes = 8
			end 'iface' else 'plain'
				let stdType = resolveMaxonTypeToStd(project, ref: f.fieldType)
				widthBytes = storeWidthBytes(storeWidthOfStdType(stdType))
				alignBytes = widthBytes
			end 'plain'
			let aligned = roundUpToMultiple(nextOffset, multiple: alignBytes)
			newFields.push(StructField.create(f.name, fieldType: f.fieldType, offset: aligned as FieldOffset, isMutable: f.isMutable, hasDefault: f.hasDefault, offsetResolved: true, isExported: f.isExported))
			nextOffset = aligned + widthBytes
		end 'eachField'
		// Pad struct size up to 8 bytes so `__mm_alloc`'s 8-byte alignment
		// invariant for managed allocations is preserved regardless of how
		// the trailing field's natural alignment landed.
		let totalSize = roundUpToMultiple(nextOffset, multiple: 8)
		let rebuilt = StructType.create(st.name, fields: newFields, byteSize: totalSize as FieldOffset, visibility: st.visibility, sourceFilePath: st.sourceFilePath, nameLine: st.nameLine, nameColumn: st.nameColumn, expectedMethods: st.expectedMethods, innerAliases: st.innerAliases)
		rebuiltNames.push(structName)
		rebuiltStructs.push(rebuilt)
	end 'eachStruct'

	for i in 0 upto rebuiltNames.count() 'commit'
		let name = try rebuiltNames.get(i) otherwise panic("layoutAllStructs: rebuiltNames.get OOB at {i}")
		let st = try rebuiltStructs.get(i) otherwise panic("layoutAllStructs: rebuiltStructs.get OOB at {i}")
		project.structTypes.upsert(name, value: st)
	end 'commit'
end 'layoutAllStructs'

// --- Phase 11.1 (step 5): conformance + extension validation ---

// Walk every still-pending unresolved struct/enum's `implementedInterfaces`
// clause and:
//   1. Confirm the named interface exists. (E3015 already emitted by
//      `computeExpectedMethodsForConformances`; we silently skip here.)
//   2. Confirm each interface method has a same-named function on the
//      conforming type's method table (`Type.method` qualified name in
//      `funcReturnTypes`). Missing methods report E3015.
//   3. Record the (typeName, interfaceName, withArgs) entry in
//      `project.conformances` so `Constraints.typeConformsTo` answers
//      "yes" for this pair.
//
// The signature-matching deeper than name presence is deferred: full
// param/return-type-after-substitution matching is Step 7's job when it
// emits witness tables.
//
// MUST be called BEFORE `resolveAllStructTypes` / `resolveAllEnumTypes`
// drain — we read `implementedInterfaces` off the unresolved entries.
// (After the drain that field is gone; `StructType` only carries the
// already-substituted `expectedMethods`.)
function validateConformances(project Project)
	for (typeName, entry) in project.unresolvedStructTypes 'eachStruct'
		validateConformancesFor(project, typeName: typeName, conformances: entry.implementedInterfaces)
	end 'eachStruct'
	for (typeName, entry) in project.unresolvedEnums 'eachEnum'
		validateConformancesFor(project, typeName: typeName, conformances: entry.implementedInterfaces)
	end 'eachEnum'
end 'validateConformances'

// Per-type validation helper: walks one conformance list.
function validateConformancesFor(project Project, typeName String, conformances ConformanceArray)
	for conf in conformances 'eachConf'
		// Phase 11.7: per-method existence + signature check moved to
		// SemanticCheck.reportMissingMethods (E3016). Here we only walk
		// the interface to confirm it exists and record the conformance.
		// Verify the interface exists (unresolved registry first, then resolved
		// registry inside the helper). Phase 11.7: missing-method / wrong-
		// signature emission moved to SemanticCheck.reportMissingMethods.
		if not project.unresolvedInterfaces.contains(conf.interfaceName) 'tryResolved'
			validateConformancesForResolved(project, typeName: typeName, conf: conf)
			continue
		end 'tryResolved'
		recordConformance(project, typeName: typeName, conf: conf)
	end 'eachConf'
end 'validateConformancesFor'

function validateConformancesForResolved(project Project, typeName String, conf Conformance)
	if not project.interfaces.contains(conf.interfaceName) 'unknown'
		return
	end 'unknown'
	recordConformance(project, typeName: typeName, conf: conf)
end 'validateConformancesForResolved'

// Resolve a `Conformance`'s parser-time bare-name args into the canonical
// `MaxonTypeArray` shape stored on `project.conformances`. Two cases:
//
//   1. `usesCount == 1` and `parenForm` is true with `withArgs.count() >= 2`:
//      collapse the parenthesized comma list into a single `__TupleN`
//      generic-instance. Mirrors maxon-sharp's `ParseWithTypeArgs`
//      `expectedCount == 1` branch — `Iterator with (Source, Element)` against
//      `Iterator uses Element` binds `Element = (Source, Element)`.
//
//   2. Otherwise: each bare name interns into its own `MaxonType.named(...)`
//      placeholder. Unknown names stay placeholders here and get upgraded
//      later by the lowering layer; the conformance entry only needs shape.
//
// `usesCount` arrives from the caller's already-performed interface lookup
// so we don't repeat the resolved-vs-unresolved branching. Callers that
// don't have the interface in scope (because it's missing — diagnostic
// already emitted) pass `withArgs.count()` to disable collapse.
function resolveConformanceWithArgs(project Project, conf Conformance, usesCount ElementCount) returns MaxonTypeArray
	var result = MaxonTypeArray.create()
	if conf.parenForm and usesCount == 1 and conf.withArgs.count() >= 2 'tupleCollapse'
		var tupleArgs = MaxonTypeArray.create()
		for i in 0 upto conf.withArgs.count() 'eachTupleArg'
			let argName = try conf.withArgs.get(i) otherwise panic("resolveConformanceWithArgs: withArgs.get OOB at {i}")
			tupleArgs.push(internMaxonType(project, name: argName))
		end 'eachTupleArg'
		ensureTupleStructRegistered(project, arity: conf.withArgs.count())
		let baseName = "__Tuple{conf.withArgs.count()}"
		let baseId = project.typeNames.intern(baseName)
		let giid = project.genericInstances.intern(baseId, args: tupleArgs)
		result.push(MaxonType.genericInstance(giid))
		return result
	end 'tupleCollapse'

	for i in 0 upto conf.withArgs.count() 'eachArg'
		let argName = try conf.withArgs.get(i) otherwise panic("resolveConformanceWithArgs: withArgs.get OOB at {i}")
		result.push(internMaxonType(project, name: argName))
	end 'eachArg'
	return result
end 'resolveConformanceWithArgs'

// Record a (typeName, interfaceName, withArgs) entry in
// `project.conformances`. The withArgs list arrives as bare strings
// from the parser; we resolve each one to a MaxonType via the type-name
// interner. Unknown names land as `MaxonType.named(<name>)` placeholders
// that lowering can later upgrade — the conformance entry just needs the
// shape, not the typing-correctness, recorded.
//
// Also walks the interface's `extends` chain and records a derived
// conformance for every parent — `type Impl implements Extended` where
// `interface Extended extends Base` ends up registering both
// `(Impl, Extended)` and `(Impl, Base)`. Without this, the witness-table
// builder won't emit a `(Impl, Base)` table and call sites that pass an
// `Impl` to a `Base`-typed parameter materialize a null witness pointer
// (interface-method-via-extended-interface segfaults at runtime).
function recordConformance(project Project, typeName String, conf Conformance)
	let usesCount = lookupInterfaceUsesParams(project, name: conf.interfaceName).count()
	let withArgs = resolveConformanceWithArgs(project, conf: conf, usesCount: usesCount)
	_ = project.conformances.intern(typeName, interfaceName: conf.interfaceName, withArgs: withArgs)
	var visited = StringSet.create()
	recordParentConformancesHelper(project, typeName: typeName, interfaceName: conf.interfaceName, withArgs: withArgs, visited: visited)
end 'recordConformance'

// Walk `interfaceName`'s `extends` chain transitively and record a
// conformance entry for `typeName` against every ancestor. The same
// `withArgs` list is reused — interface inheritance in Maxon doesn't
// rebind associated-type parameters today, so the child's bindings are
// also valid bindings for each parent. A duplicate visit is gated by the
// conformance registry's idempotent `intern` and a local `visited` set
// guards against cycles in malformed interface graphs.
function recordParentConformancesHelper(project Project, typeName String, interfaceName String, withArgs MaxonTypeArray, visited StringSet)
	if visited.contains(interfaceName) 'seen'
		return
	end 'seen'
	visited.insert(interfaceName)

	var parents = StringArray.create()
	if let resolved = try project.interfaces.get(interfaceName) 'fromResolved'
		for p in resolved.extendsNames 'eachP'
			parents.push(p)
		end 'eachP'
	end 'fromResolved' else 'tryUnresolved'
		if let unresolved = try project.unresolvedInterfaces.get(interfaceName) 'fromUnresolved'
			for p in unresolved.extendsNames 'eachU'
				parents.push(p)
			end 'eachU'
		end 'fromUnresolved'
	end 'tryUnresolved'

	for parentName in parents 'eachParent'
		_ = project.conformances.intern(typeName, interfaceName: parentName, withArgs: withArgs)
		recordParentConformancesHelper(project, typeName: typeName, interfaceName: parentName, withArgs: withArgs, visited: visited)
	end 'eachParent'
end 'recordParentConformancesHelper'

// Phase 11.1 step 5c: walk every parser-recorded extension and:
//   1. Register each `addedConformances` entry in `project.conformances`.
//      Extensions don't have a separate "Self" — the target type is the
//      conforming type. The where-clause that gates the conformance is
//      stored separately on the registered conformance via the
//      `whereClauses` field on the extension; consumers (Step 7's
//      witness-table builder, call-site checker) re-read the extension
//      record when they need to verify a per-call-site instantiation.
//   2. Validate the added conformance's interface methods exist on the
//      target type. Same minimum-viable name presence check as
//      `validateConformancesFor`.
//
// The extension's own method bodies were already registered into
// `funcReturnTypes` by `parseFunction` at parse time, so by the time
// this pass runs the conformance lookup will see them.
//
// Idempotent against re-runs: `ConformanceRegistry.intern` returns the
// existing id on a duplicate.
function processExtensions(project Project)
	for ext in project.unresolvedExtensions 'eachExt'
		for conf in ext.addedConformances 'eachConf'
			if not project.interfaces.contains(conf.interfaceName) 'tryUnresolved'
				processExtensionConformanceUnresolved(project, ext: ext, conf: conf)
				continue
			end 'tryUnresolved'
			recordConformance(project, typeName: ext.targetTypeName, conf: conf)
		end 'eachConf'
	end 'eachExt'
end 'processExtensions'

function processExtensionConformanceUnresolved(project Project, ext UnresolvedExtension, conf Conformance)
	recordConformance(project, typeName: ext.targetTypeName, conf: conf)
end 'processExtensionConformanceUnresolved'

// --- Cast / compare validation (unchanged from prior behavior) ---

export function convertCastCategory(project Project, t MaxonType) returns CastCategory
	match t 'unresolvedGuard'
		unresolved then panic("convertCastCategory: MaxonType.unresolved should have been resolved before reaching cast/compare validation")
		boolean then return CastCategory.bool
		integer then return CastCategory.int
		float then return CastCategory.float
		string then return CastCategory.string
		named(id) then return namedIdCastCategory(project, id: id)
		// Stage E (closures): function-typed values lower to i64 pointers.
		// Cast/compare validation treats them as `int` so a `(T) returns
		// R`-typed param accepts an i64 fn-pointer arg without spurious
		// E3005. Structural mismatches between two distinct function
		// signatures aren't caught here; Stage E's user-facing
		// FunctionTypeRegistry interning is meant to dedupe identical
		// shapes, and signature-validation in `slotArgsForCall` would be
		// a follow-up if we add a true call-site type-check.
		function then return CastCategory.int
		// Phase 11.0: generic-aware arms shouldn't reach the cast/compare
		// validator — substitution would have replaced them with concrete
		// types first. If they slip through, treat them as `int` so the
		// downstream slot/operand validation surfaces the missing-pass
		// failure as a normal type error rather than a panic.
		typeParameter then return CastCategory.int
		genericInstance then return CastCategory.int
		interface then return CastCategory.int
		constInt then return CastCategory.int
		// `opaquePointer` is i64-shaped at the ABI layer; treat like int.
		opaquePointer then return CastCategory.int
	end 'unresolvedGuard'
end 'convertCastCategory'

// Phase A widening predicate: true when `from`'s category is `int` and
// `to`'s category is `float`. Used at every widening site in TR (varStore
// merge, varLoad re-publish, varDecl restamp, cmp/binop operand restamp)
// to keep the rule in one place — narrowing or any non-numeric kind is
// out-of-scope.
function isIntToFloatWidening(project Project, from MaxonType, to MaxonType) returns bool
	if isUnresolvedType(from) or isUnresolvedType(to) 'unresolved'
		return false
	end 'unresolved'
	let fromCategory = convertCastCategory(project, t: from)
	let toCategory = convertCastCategory(project, t: to)
	return fromCategory == CastCategory.int and toCategory == CastCategory.float
end 'isIntToFloatWidening'

function namedIdCastCategory(project Project, id TypeNameId) returns CastCategory
	let name = project.typeNames.get(id)
	if not namedIdIsKnown(project, id: id) 'unknown'
		// Interface `usesParams` (e.g. `interface HasItems uses Element`)
		// are parsed as `named("Element")` because the parser doesn't
		// push them onto `currentTypeParams` for interface bodies. When
		// an `extension HasItems` method consumes such a reference
		// (e.g. `current()` returns Element, then `item == target` with
		// `target Element`), the cast category check reaches this arm.
		// Treat as `int` for the same reason as the `typeParameter`
		// arm above: substitution would have replaced the param at a
		// monomorphic call site; reaching the cast validator with a
		// surviving free param means downstream slot/operand validation
		// surfaces the missing-pass failure as a normal type error
		// rather than a panic. Mirrors the genericInstance/interface
		// arms in `convertCastCategory`.
		return CastCategory.int
	end 'unknown'
	// Phase 7: the `String` struct is the user-facing string type; map to
	// `CastCategory.string` so call/cast diagnostics distinguish it from
	// generic struct-pointer i64 values.
	if name == "String" 'isString'
		return CastCategory.string
	end 'isString'
	// Ranged-primitive aliases pin their cast category at resolution time so
	// storage narrowing (`int(0 to 255)` → u8) can't reclassify the alias as
	// `byte`. Aliases without a pinned entry fall through to the storage-
	// type-derived category.
	let pinned = try project.typealiasCastCategories.get(name) otherwise return resolveNamedToStdType(project, name: name).rawValue.castCategory
	return pinned
end 'namedIdCastCategory'

// Check whether `t` names a type that's known to the project. Primitives are
// always known; named types must appear in one of the project registries.
// Used by the post-resolution validation walk that catches type-name typos
// in struct field declarations, function signatures, and op annotations.
export function maxonTypeIsKnown(project Project, t MaxonType) returns bool
	// Function types are interned by signature, not by name — every
	// `MaxonType.function(id)` came from `internFunctionType` which only
	// hands out ids the registry can resolve. They're always "known" for
	// struct-field / signature validation purposes.
	match t 'check'
		named(id) then return namedIdIsKnown(project, id: id)
		boolean to string then return true
		function then return true
		unresolved then return false
		// Phase 11.0: generic-aware arms exist on the parser-AST surface only.
		// `typeParameter` is "known" by construction (the parser only emits it
		// for names it has interned into TypeParamRegistry). `genericInstance`
		// and `interface` are similarly stamped at parse time — Phase 11
		// step 5+ adds the deeper validation pass. Treat as known for now so
		// the post-resolution validator doesn't trip on Array.maxon's headers.
		typeParameter to opaquePointer then return true
	end 'check'
end 'maxonTypeIsKnown'

function namedIdIsKnown(project Project, id TypeNameId) returns bool
	return namedNameIsKnown(project, name: project.typeNames.get(id))
end 'namedIdIsKnown'

// Shared "name resolves to a registered (resolved or interface-staging)
// type" probe. Used by `namedIdIsKnown` for the post-resolution validity
// gate and by `isKnownTypeName` for the unresolved-stage probe (which
// adds checks against the still-unresolved staging maps).
function namedNameIsKnown(project Project, name String) returns bool
	return isBuiltinTypeName(name) or project.typealiases.contains(name) or project.structTypes.contains(name) or project.enumTypes.contains(name) or project.funcReturnTypes.contains(name) or project.genericTypealiases.contains(name) or anyStructHasInnerAlias(project, aliasName: name) or project.interfaces.contains(name) or project.unresolvedInterfaces.contains(name)
end 'namedNameIsKnown'

// Emit E3009 if `t` references an unknown named type and return true so the
// caller can bail out. Returns false (no diagnostic) when `t` is known.
// resolveNamedToStdType panics on unknown names, so any cast/compare validator
// that touches a user-supplied type must call this first.
function reportIfUnknownType(project Project, t MaxonType, filePath FilePath) returns bool
	if maxonTypeIsKnown(project, t: t) 'known'
		return false
	end 'known'
	// Suppress the diagnostic for `MaxonType.unresolved` operands — these are
	// the explicit recovery sentinel a prior error already reported (E3063
	// for ambiguous typealias, E2003 for unknown type name, etc.). Surfacing
	// E3011 on top of those would only add noise.
	if isUnresolvedType(t) 'silentUnresolved'
		return true
	end 'silentUnresolved'
	reportCompileError(project, code: ErrorCode.semanticUnknownType, message: "unknown type '{t.toString(project)}'", line: 0, column: 0, filePath: filePath)
	return true
end 'reportIfUnknownType'

function reportIfUnknownTypeAt(project Project, t MaxonType, range SourceRange, filePath FilePath) returns bool
	if maxonTypeIsKnown(project, t: t) 'known'
		return false
	end 'known'
	// Phase 7 + Phase 11.4 partial: stdlib `for cp in iter.codepoints()` desugars
	// produce iterator-value reads typed `MaxonType.unresolved` because Iterable
	// associated-type substitution isn't fully wired yet. Suppress the diagnostic
	// here for unresolved operands and let downstream lowering surface a real
	// failure if the IR is genuinely broken — silencing this avoids cascading
	// E3011 noise that obscures real type errors.
	if isUnresolvedType(t) 'silentUnresolved'
		return true
	end 'silentUnresolved'
	reportCompileError(project, code: ErrorCode.semanticUnknownType, message: "unknown type '{t.toString(project)}' (cmp/cast operand)", line: range.line, column: range.column, filePath: filePath)
	return true
end 'reportIfUnknownTypeAt'

function validateConvertOp(project Project, module MaxonModule, func IrFunction, operandName ByteArray, fromType MaxonType, toType MaxonType, implicit bool, range SourceRange, filePath FilePath)
	// Compiler-synthesized conversions (e.g. trunc(Float) → int) bypass the
	// widening-only rules the user-level `as` casts enforce.
	if implicit 'skip'
		return
	end 'skip'
	let crossCategoryFailed = validateConvert(project, fromType: fromType, toType: toType, filePath: filePath)
	// Compile-time range check for `LITERAL as RangedAlias`. If the operand
	// resolves to a literal in the producing op stream and the target is a
	// named typealias with a registered range, emit E3005 when the value
	// doesn't fit. Skipped when the cross-category check already raised
	// E3009 — the user only needs one diagnostic per failing cast.
	if crossCategoryFailed 'crossFailed'
		return
	end 'crossFailed'
	checkConvertLiteralRange(project, module: module, func: func, operandName: operandName, toType: toType, range: range, filePath: filePath)
end 'validateConvertOp'

// Compile-time range check on `LITERAL as RangedAlias`. Walks the function's
// blocks looking for the literal that produced `operandName`. If found and
// the alias name has a registered range that the literal value violates,
// emit E3005 against the convert's range.
function checkConvertLiteralRange(project Project, module MaxonModule, func IrFunction, operandName ByteArray, toType MaxonType, range SourceRange, filePath FilePath)
	let aliasName = toType.namedAliasNameOrEmpty(project)
	if aliasName.isEmpty() 'notNamed'
		return
	end 'notNamed'
	let typealiasRange = try project.typealiasRanges.get(aliasName) otherwise return
	if isAliasFullRange(project, aliasName: aliasName, range: typealiasRange) 'fullRange'
		return
	end 'fullRange'
	let lit = findLiteralProducerInFunc(project, module: module, func: func, operandName: operandName)
	if not lit.found 'noLit'
		return
	end 'noLit'
	let isFloat = aliasIsFloat(project, name: aliasName)
	let outOfRange = literalOutOfRangeFloat(lit.value, range: typealiasRange) if isFloat else literalOutOfRangeInt(lit.value, range: typealiasRange)
	if not outOfRange 'inRange'
		return
	end 'inRange'
	let displayValue = formatLiteralValue(lit.value, isFloat: isFloat)
	let displayRange = formatTypealiasRange(project, aliasName: aliasName, range: typealiasRange)
	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Value {displayValue} is outside the range of '{aliasName}' ({displayRange})", line: range.line, column: range.column, filePath: filePath)
end 'checkConvertLiteralRange'

// True when a named typealias is float-backed.
function aliasIsFloat(project Project, name String) returns bool
	let stdType = try project.typealiases.get(name) otherwise return false
	return stdTypeIsFloat(stdType)
end 'aliasIsFloat'

// True when a typealias range covers every value of its underlying type.
// For int aliases that means the i64 extremes; for float aliases it means
// the IEEE-754 bit patterns of f64.min/f64.max (float bounds flow through
// `TypealiasRange` as i64-encoded bit patterns). Used to short-circuit
// compile-time literal-range checks that can't ever fail.
function isAliasFullRange(project Project, aliasName String, range TypealiasRange) returns bool
	if aliasIsFloat(project, name: aliasName) 'isFloat'
		let f64MinBits = -4503599627370497
		let f64MaxBits = 9218868437227405311
		return range.lower == f64MinBits and range.upper == f64MaxBits
	end 'isFloat'
	return range.lower <= i64.min and range.upper == i64.max
end 'isAliasFullRange'

export type LiteralProducer
	export var found as bool
	export var value as ParsedInt

	export static function miss() returns LiteralProducer
		return Self{found: false, value: 0}
	end 'miss'

	export static function hit(value ParsedInt) returns LiteralProducer
		return Self{found: true, value: value}
	end 'hit'
end 'LiteralProducer'

// Walk a function's blocks looking for the op that defined `operandName`.
// Recognized producers:
//   - `literal(name, value, ...)` — direct hit, returns value.
//   - `unop(name, operand, neg, ...)` — recurse into operand; on hit,
//     return -value. Handles `-5 as RangedAlias` patterns.
//   - `convert(name, operand, ...)` — recurse into operand. Lets the
//     cast-check expander see through the parser-emitted convert that
//     pairs with each `as` cast (e.g. `50 as Byte` → `convert 50 →
//     Byte` followed by a `castCheck` whose value is the convert
//     result). Integer convert preserves the value; byte conversion
//     of an in-range literal is a no-op so the literal value still
//     applies.
// Returns miss if the operand wasn't produced by a recognised constant
// shape — runtime range checks (or downstream emitters) handle non-
// constants. Constrained to function-local ops because synthetic names
// (`$t1`, …) repeat across functions and a flat module-wide walk would
// alias unrelated literals.
export function findLiteralProducerInFunc(project Project, module MaxonModule, func IrFunction, operandName ByteArray) returns LiteralProducer
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("findLiteralProducerInFunc: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("findLiteralProducerInFunc: opIdx OOB")
			if op.name == "literal" 'isLit'
				let hit = matchLiteralProducer(op, operandName: operandName)
				if hit.found 'gotIt'
					return hit
				end 'gotIt'
			end 'isLit'
			if op.name == "unop" 'isUnop'
				let inner = matchUnopNegProducer(op, operandName: operandName)
				if inner.found 'gotInner'
					let nested = findLiteralProducerInFunc(project, module: module, func: func, operandName: inner.innerName)
					if nested.found 'recurseHit'
						return LiteralProducer.hit(0 - nested.value)
					end 'recurseHit'
					return LiteralProducer.miss()
				end 'gotInner'
			end 'isUnop'
			if op.name == "convert" 'isConvert'
				let inner = matchConvertProducer(project, op: op, operandName: operandName)
				if inner.found 'gotConvert'
					return findLiteralProducerInFunc(project, module: module, func: func, operandName: inner.innerName)
				end 'gotConvert'
			end 'isConvert'
		end 'eachOp'
	end 'eachBlock'
	return LiteralProducer.miss()
end 'findLiteralProducerInFunc'

function matchConvertProducer(project Project, op MaxonOp, operandName ByteArray) returns UnopHit
	match op 'extract'
		convert(result, operand, fromType, toType, _, _) then return convertHitIfKindPreserving(project, result: result, operandName: operandName, operand: operand, fromType: fromType, toType: toType)
		default panic("unreachable: caller checked name == convert")
	end 'extract'
end 'matchConvertProducer'

// Only recurse through `convert` ops that preserve the value's "kind" —
// int↔int and float↔float. A float→int convert truncates (different
// numeric value); an int→float convert reinterprets via sitofp (so the
// i64 the walker sees flips from a numeric value to an IEEE-754 bit
// pattern, breaking the literal-out-of-range check). Same-kind converts
// preserve the literal value as-is, so the cast-check pass can trust
// that the literal it finds is the same one TypeResolution already
// range-checked.
function convertHitIfKindPreserving(project Project, result ByteArray, operandName ByteArray, operand ByteArray, fromType MaxonType, toType MaxonType) returns UnopHit
	if not byteArraysEqual(result, b: operandName) 'noMatch'
		return UnopHit.miss()
	end 'noMatch'
	let fromKind = numericKindOf(project, t: fromType)
	let toKind = numericKindOf(project, t: toType)
	if fromKind == NumericKind.notNumeric or toKind == NumericKind.notNumeric 'notNumeric'
		return UnopHit.miss()
	end 'notNumeric'
	if fromKind != toKind 'kindMismatch'
		return UnopHit.miss()
	end 'kindMismatch'
	return UnopHit.hit(operand)
end 'convertHitIfKindPreserving'

enum NumericKind
	integer
	floating
	notNumeric
end 'NumericKind'

// Classify a MaxonType for the literal-walker's same-kind-convert filter.
// The pinned cast category is consulted for named typealiases so a u8-stored
// `int(0 to 255)` alias still classifies as `integer` (matching its declared
// category, not its storage type).
function numericKindOf(project Project, t MaxonType) returns NumericKind
	return match t 'check'
		integer gives NumericKind.integer
		float gives NumericKind.floating
		named(id) gives namedIdNumericKind(project, id: id)
		boolean gives NumericKind.notNumeric
		string gives NumericKind.notNumeric
		function to opaquePointer gives NumericKind.notNumeric
	end 'check'
end 'numericKindOf'

function namedIdNumericKind(project Project, id TypeNameId) returns NumericKind
	let name = project.typeNames.get(id)
	let category = try project.typealiasCastCategories.get(name) otherwise return namedIdStorageNumericKind(project, name: name)
	return castCategoryNumericKind(category)
end 'namedIdNumericKind'

// Fallback for aliases without a pinned category (alias chains): peek at
// the resolved StdType and classify by its float bit. Non-typealias names
// (structs, enums) fall through to `notNumeric` because their storage
// shape — i64 pointer — doesn't map to a numeric kind the walker can
// safely recurse through.
function namedIdStorageNumericKind(project Project, name String) returns NumericKind
	let stdType = try project.typealiases.get(name) otherwise return NumericKind.notNumeric
	if stdTypeIsFloat(stdType) 'isFloat'
		return NumericKind.floating
	end 'isFloat'
	return castCategoryNumericKind(stdType.rawValue.castCategory)
end 'namedIdStorageNumericKind'

function castCategoryNumericKind(category CastCategory) returns NumericKind
	return match category 'pick'
		int gives NumericKind.integer
		float gives NumericKind.floating
		bool gives NumericKind.notNumeric
		string gives NumericKind.notNumeric
	end 'pick'
end 'castCategoryNumericKind'

function matchLiteralProducer(op MaxonOp, operandName ByteArray) returns LiteralProducer
	match op 'extract'
		literal(result, value, _, _) then return literalProducerHitIfMatch(result, operandName: operandName, value: value)
		default panic("unreachable: caller checked name == literal")
	end 'extract'
end 'matchLiteralProducer'

function literalProducerHitIfMatch(result ByteArray, operandName ByteArray, value ParsedInt) returns LiteralProducer
	if byteArraysEqual(result, b: operandName) 'match'
		return LiteralProducer.hit(value)
	end 'match'
	return LiteralProducer.miss()
end 'literalProducerHitIfMatch'

type UnopHit
	export var found as bool
	export var innerName as ByteArray

	export static function miss() returns UnopHit
		return Self{found: false, innerName: ByteArray.create()}
	end 'miss'

	export static function hit(innerName ByteArray) returns UnopHit
		return Self{found: true, innerName: innerName}
	end 'hit'
end 'UnopHit'

function matchUnopNegProducer(op MaxonOp, operandName ByteArray) returns UnopHit
	match op 'extract'
		unop(result, operand, opKind, _, _) then return unopHitIfNegMatch(result, operandName: operandName, operand: operand, opKind: opKind)
		default panic("unreachable: caller checked name == unop")
	end 'extract'
end 'matchUnopNegProducer'

function unopHitIfNegMatch(result ByteArray, operandName ByteArray, operand ByteArray, opKind UnaryOpKind) returns UnopHit
	if not byteArraysEqual(result, b: operandName) 'noMatch'
		return UnopHit.miss()
	end 'noMatch'
	let isNeg = match opKind 'kind'
		neg gives true
		bitNot gives false
		logicalNot gives false
	end 'kind'
	if not isNeg 'notNeg'
		return UnopHit.miss()
	end 'notNeg'
	return UnopHit.hit(operand)
end 'unopHitIfNegMatch'

// True when an integer literal value falls outside `range`. The range's
// lower bound flags whether to use signed or unsigned semantics:
// non-negative lower → unsigned (so `0 to u64.max` accepts every value);
// negative lower → signed.
function literalOutOfRangeInt(value ParsedInt, range TypealiasRange) returns bool
	if range.lower >= 0 'unsigned'
		// `upper < 0` represents a u64 value above i64.max; the range
		// effectively spans every 64-bit value, so nothing is out of range.
		if range.upper < 0 'wrapped'
			return false
		end 'wrapped'
		return value < range.lower or value > range.upper
	end 'unsigned'
	return value < range.lower or value > range.upper
end 'literalOutOfRangeInt'

// True when a float literal (as i64 bit pattern) falls outside `range`.
function literalOutOfRangeFloat(value ParsedInt, range TypealiasRange) returns bool
	return floatBitsGreater(range.lower, b: value) or floatBitsGreater(value, b: range.upper)
end 'literalOutOfRangeFloat'

// Format a literal value for diagnostic display: integer values are
// printed as-is, float bit patterns are reinterpreted to a decimal number.
function formatLiteralValue(value ParsedInt, isFloat bool) returns String
	if isFloat 'asFloat'
		return formatFloatBits(value)
	end 'asFloat'
	return "{value}"
end 'formatLiteralValue'

// Render an IEEE-754 double (encoded as i64 bits) for diagnostic output.
// The compiler doesn't ship a Grisu/Ryu-style decimal converter, and
// pulling one in solely for E3005 messages would dwarf the diagnostic
// benefit. Surfacing the raw bit pattern under a `bits=` tag makes the
// printed bound unambiguous (the user can decode the constant they
// wrote) without claiming a decimal we can't faithfully produce.
function formatFloatBits(bits ParsedInt) returns String
	if bits == 0 'zero'
		return "0"
	end 'zero'
	return "bits={bits}"
end 'formatFloatBits'

// Format a typealias's source-level range as `int(L to U)` / `byte(L to U)` /
// `float(L to U)`. Used in E3005 diagnostics. Reads the user-declared cast
// category from `project.typealiasCastCategories` so a u8-stored `int(0 to 255)`
// alias still prints as `int(...)`. Falls back to `int` when the alias has
// no pinned category (alias chains land here).
function formatTypealiasRange(project Project, aliasName String, range TypealiasRange) returns String
	// `typealiasCastCategories` is only populated for `int(...)`/`float(...)`
	// aliases (see `declaredCastCategoryFor`), so the bool/string arms are
	// unreachable. The match is statement-shaped + early-return so each
	// unreachable arm panics rather than silently surfacing an `int(...)`
	// shape under the wrong category name.
	let category = try project.typealiasCastCategories.get(aliasName) otherwise CastCategory.int
	match category 'pick'
		float then return "float({formatFloatBits(range.lower)} to {formatFloatBits(range.upper)})"
		int then return "int({range.lower} to {range.upper})"
		bool then panic("formatTypealiasRange: alias '{aliasName}' has bool category — typealiasCastCategories should only carry int/float")
		string then panic("formatTypealiasRange: alias '{aliasName}' has string category — typealiasCastCategories should only carry int/float")
	end 'pick'
end 'formatTypealiasRange'

function validateConvert(project Project, fromType MaxonType, toType MaxonType, filePath FilePath) returns bool
	if reportIfUnknownType(project, t: fromType, filePath: filePath) 'unknownFrom'
		return true
	end 'unknownFrom'
	if reportIfUnknownType(project, t: toType, filePath: filePath) 'unknownTo'
		return true
	end 'unknownTo'
	let sourceCategory = convertCastCategory(project, t: fromType)
	let targetCategory = convertCastCategory(project, t: toType)

	// Same category is always a no-op at the cast level.
	if sourceCategory == targetCategory 'sameType'
		return false
	end 'sameType'

	// Widening rule: int→float is the only cross-category cast permitted.
	if sourceCategory == CastCategory.int and targetCategory == CastCategory.float 'intToFloat'
		return false
	end 'intToFloat'

	reportCompileError(project, code: ErrorCode.semanticInvalidCast, message: "Cannot cast from {castCategoryName(sourceCategory)} to {castCategoryName(targetCategory)}", line: 0, column: 0, filePath: filePath)
	return true
end 'validateConvert'

// Phase 11.7: walk every function's cmp ops and emit E3005 when either
// operand is a type-parameter-typed value whose declaring type's `where`
// clause (struct-level OR extension-scoped) doesn't constrain it with the
// required interface (`Equatable` for `==`/`!=`, `Comparable` for ordering
// predicates). Mirrors `ValidateTypeParameterConstraints` in the bootstrap.
//
// Runs after `fillCmp` has populated operand types and after
// `extensionMethodWhereClauses` has been seeded by the parser, but BEFORE
// DCE — so a `Box uses T; function eq(x T) ... item == x` body still
// triggers the diagnostic even if no `Box.eq` call site monomorphizes.
function validateTypeParamComparisonConstraints(project Project, module MaxonModule, filePath FilePath)
	for func in module.functions 'eachFunc'
		let enclosingType = enclosingTypeNameOrEmpty(func.name)
		var structConstraints = WhereClauseArray.create()
		if not enclosingType.isEmpty() 'haveRecv'
			structConstraints = lookupWhereClausesForBase(project, baseName: enclosingType)
		end 'haveRecv'
		let extClauses = try project.extensionMethodWhereClauses.get(func.name) otherwise WhereClauseArray.create()
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateTypeParamComparisonConstraints: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateTypeParamComparisonConstraints: opIdx OOB")
				if op.name != "cmp" 'notCmp'
					continue
				end 'notCmp'
				match op 'extract'
					cmp(_, _, _, predicate, _, _, operandType, range) then checkTypeParamComparison(project, predicate: predicate, operandType: operandType, range: range, filePath: filePath, structConstraints: structConstraints, extClauses: extClauses)
					default panic("validateTypeParamComparisonConstraints: cmp op shape mismatch")
				end 'extract'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateTypeParamComparisonConstraints'

// Non-throwing variant of `enclosingTypeName` — returns empty string for free
// functions. Used by passes that walk every function (method or not) and want
// a single uniform path rather than `if let`/`else` at every call site.
function enclosingTypeNameOrEmpty(funcName String) returns String
	return try enclosingTypeName(funcName) otherwise ""
end 'enclosingTypeNameOrEmpty'

// Strip the `$<overloadDiscriminator>` suffix from a function name.
// `project.extensionMethodWhereClauses` is keyed by the bare
// `<Type>.<method>` form so overload-suffixed function names need this
// transform before lookup.
function stripFunctionOverloadSuffix(name String) returns String
	let bytes = name.toByteArray()
	let dollarByte = 0x24
	var i = 0
	while i < bytes.count() 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i < count but get failed")
		if b == dollarByte 'hit'
			return byteSliceToString(bytes, startIndex: 0, endIndex: i)
		end 'hit'
		i = i + 1
	end 'scan'
	return name
end 'stripFunctionOverloadSuffix'

// True iff `clauses` constrains `paramName` with `interfaceName`.
function whereClausesCoverConstraint(clauses WhereClauseArray, paramName String, interfaceName String) returns bool
	for i in 0 upto clauses.count() 'scan'
		let wc = try clauses.get(i) otherwise panic("whereClausesCoverConstraint: clauses.get OOB at {i}")
		if wc.paramName == paramName and wc.requiredTraitName == interfaceName 'hit'
			return true
		end 'hit'
	end 'scan'
	return false
end 'whereClausesCoverConstraint'

// E3005 when a cmp's operand is a bare type parameter and neither the
// struct-level nor extension-level `where` clause supplies the required
// interface. The required interface is `Equatable` for eq/ne and
// `Comparable` for ordering predicates — same classification as the
// bootstrap's `ValidateTypeParameterConstraints`.
function checkTypeParamComparison(project Project, predicate CmpPredicate, operandType MaxonType, range SourceRange, filePath FilePath, structConstraints WhereClauseArray, extClauses WhereClauseArray)
	let paramName = match operandType 'extract'
		typeParameter(id) gives project.typeParameters.getName(id)
		boolean gives ""
		integer gives ""
		float gives ""
		string gives ""
		named gives ""
		function gives ""
		unresolved gives ""
		genericInstance to opaquePointer gives ""
	end 'extract'
	if paramName.isEmpty() 'notTypeParam'
		return
	end 'notTypeParam'
	let requiredIface = requiredInterfaceForCmpPredicate(predicate)
	if whereClausesCoverConstraint(structConstraints, paramName: paramName, interfaceName: requiredIface) 'structCovers'
		return
	end 'structCovers'
	if whereClausesCoverConstraint(extClauses, paramName: paramName, interfaceName: requiredIface) 'extCovers'
		return
	end 'extCovers'
	let opStr = cmpPredicateOpStr(predicate)
	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Operator '{opStr}' requires type parameter '{paramName}' to be constrained with 'where {paramName} is {requiredIface}'", line: range.line, column: range.column, filePath: filePath)
end 'checkTypeParamComparison'

function requiredInterfaceForCmpPredicate(predicate CmpPredicate) returns String
	return match predicate 'p'
		eq gives "Equatable"
		ne gives "Equatable"
		lt gives "Comparable"
		le gives "Comparable"
		gt gives "Comparable"
		ge gives "Comparable"
	end 'p'
end 'requiredInterfaceForCmpPredicate'

function cmpPredicateOpStr(predicate CmpPredicate) returns String
	return match predicate 'p'
		eq gives "=="
		ne gives "!="
		lt gives "<"
		le gives "<="
		gt gives ">"
		ge gives ">="
	end 'p'
end 'cmpPredicateOpStr'

// Validate a cmp op's operand types. Comparisons are category-strict: both
// sides must land in the same CastCategory (int/float/bool). Any mismatch
// emits E3005.
function validateCompareOp(project Project, leftType MaxonType, rightType MaxonType, range SourceRange, filePath FilePath)
	if reportIfUnknownTypeAt(project, t: leftType, range: range, filePath: filePath) 'unknownLeft'
		return
	end 'unknownLeft'
	if reportIfUnknownTypeAt(project, t: rightType, range: range, filePath: filePath) 'unknownRight'
		return
	end 'unknownRight'
	let leftCategory = convertCastCategory(project, t: leftType)
	let rightCategory = convertCastCategory(project, t: rightType)
	if leftCategory == rightCategory 'sameCategory'
		return
	end 'sameCategory'

	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "type mismatch: 'cannot compare {castCategoryName(leftCategory)} with {castCategoryName(rightCategory)}'", line: range.line, column: range.column, filePath: filePath)
end 'validateCompareOp'

// --- Unresolved-name rewrites ---
//
// The parser emits `unresolvedRead` and `unresolvedAssign` ops when it sees a
// bare or qualified identifier whose kind it cannot decide without
// cross-declaration knowledge. This pass walks every such op and replaces it
// with the concrete equivalent — `globalLoad`/`globalStore` for top-level vars,
// `literal` substitution for top-level integer constants, or a
// `semanticUnknownName` diagnostic when the name resolves to nothing the
// project knows about. After this rewrite, lowering only ever sees concrete
// op shapes; the unresolved* arms in LowerMaxonToStd are pure safety panics.

// Walk every function's ops, rewriting `unresolvedRead` / `unresolvedAssign`
// against the function's declaring file path as the visibility context.
// `fallbackFilePath` is used when a function's entry block has no recorded
// source path (detached / synthesized functions). Visibility filtering at
// the rewrite site needs the *reader's* file, not the project's primary
// source path, because module-merge produces one MaxonModule covering
// every input file.
function rewriteUnresolvedOpsPerFunction(project Project, module MaxonModule, fallbackFilePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("invariant: funcIdx < count but get failed")
		let funcFilePathStr = try entryBlockFilePath(module, func: func) otherwise ""
		let funcFilePath = filePathFromString(funcFilePathStr, fallback: fallbackFilePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("invariant: opIdx from block.opRefs not in module.ops")
				rewriteOneUnresolvedOp(project, module: module, opIdx: opIdx, op: op, filePath: funcFilePath)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'rewriteUnresolvedOpsPerFunction'

function rewriteOneUnresolvedOp(project Project, module MaxonModule, opIdx OpIndex, op MaxonOp, filePath FilePath)
	if op.name == "unresolvedRead" 'isUnresolvedRead'
		match op 'extract'
			unresolvedRead(result, name, range) then rewriteUnresolvedRead(project, module: module, opIdx: opIdx, result: result, name: name, range: range, filePath: filePath)
			default panic("unreachable: already checked name == unresolvedRead")
		end 'extract'
		return
	end 'isUnresolvedRead'
	if op.name == "unresolvedAssign" 'isUnresolvedAssign'
		match op 'extract'
			unresolvedAssign(name, value, range) then rewriteUnresolvedAssign(project, module: module, opIdx: opIdx, name: name, value: value, range: range, filePath: filePath)
			default panic("unreachable: already checked name == unresolvedAssign")
		end 'extract'
	end 'isUnresolvedAssign'
end 'rewriteOneUnresolvedOp'

// Bridge `BlockSourceInfo.filePath` (a String) into a FilePath. Empty
// strings (sentinel for non-parser-created blocks) fall back to the
// project's primary source path so visibility checks against detached
// blocks still resolve to *some* file.
function filePathFromString(s String, fallback FilePath) returns FilePath
	if s.isEmpty() 'empty'
		return fallback
	end 'empty'
	return try FilePath.from(s) otherwise fallback
end 'filePathFromString'

function rewriteUnresolvedRead(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, name String, range SourceRange, filePath FilePath)
	if let info = try project.topLevelVars.get(name) 'isTopLevelVar'
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: filePath) 'visible'
			try module.ops.set(opIdx, value: MaxonOp.globalLoad(result, name: name, slotType: info.slotType, range: range)) otherwise panic("rewriteUnresolvedRead: ops.set OOB at idx={opIdx} (count={module.ops.count()})")
			return
		end 'visible'
	end 'isTopLevelVar'
	// `name` shaped `receiver.field` where `receiver` is a top-level var
	// (instance variable holding a struct). Rewrite to globalLoad(receiver)
	// + fieldLoad(field) so cross-file `shared.value` works the same way as
	// the in-function `shared.value` access would. The static-field shape
	// (`TypeName.staticField` registered with the dotted qualifiedName) was
	// caught by the prior topLevelVars lookup, so falling through here means
	// the dotted form is NOT a registered global itself.
	if tryRewriteDottedRead(project, module: module, opIdx: opIdx, result: result, name: name, range: range, filePath: filePath) 'wasInstanceField'
		return
	end 'wasInstanceField'
	if let entry = try project.topLevelConstants.get(name) 'isConst'
		if isVisibleFrom(entry.visibility, declFilePath: entry.sourceFilePath, readerFilePath: filePath) 'visible'
			// Record this read for the `checkUnusedExports` pass. The pass runs
			// after all rewrites finish, by which point this op will be a bare
			// `literal` / `stringConst` carrying no reference to the constant's
			// name — so we capture the (constantName, readerFilePath) pair here,
			// at the only moment both are still in scope. Stdlib constants
			// (sourceFilePath = stdlib bootstrap path) get the same treatment;
			// the pass skips stdlib decls regardless.
			project.crossFileConstReads.push(CrossFileConstRead.create(name, readerFilePath: filePath))
			// Enum cases get tagged with the enclosing enum's named MaxonType so
			// downstream consumers (varDecl slotType inference, match scrutinee
			// type recovery) can recover the case set rather than seeing a bare
			// integer or float literal.
			let intValueType = enumLiteralTypeOr(project, qualifiedName: name, fallback: MaxonType.integer)
			let floatValueType = enumLiteralTypeOr(project, qualifiedName: name, fallback: MaxonType.float)
			match entry.value 'inline'
				intValue(v) then rewriteToLiteral(module, opIdx: opIdx, result: result, value: v, range: range, valueType: intValueType)
				// Float-typed top-level constants store IEEE 754 raw bits in the
				// same i64 slot used by MaxonOp.literal for floats.
				floatValue(bits) then rewriteToLiteral(module, opIdx: opIdx, result: result, value: bits, range: range, valueType: floatValueType)
				// String constants resolve to a `stringConst` op carrying the
				// interned StringId. A follow-up walk pattern-matches on
				// `stringConst` producers to specialize cmp consumers
				// (cmp(stringConst, stringConst) → literal fold).
				stringValue(stringId) then rewriteToStringConst(module, opIdx: opIdx, result: result, stringId: stringId, range: range)
			end 'inline'
			return
		end 'visible'
	end 'isConst'
	// Phase 9 Stage 3: a qualified read `UnionName.caseName` on a union
	// case (bare or payload-bearing) rewrites to a no-arg call to the
	// synthesized constructor `__construct_UnionName_caseName`. This keeps
	// union values uniformly heap-boxed at the producer site even when
	// the user writes `Op.mul` without explicit parens.
	if tryRewriteUnresolvedUnionCaseRead(project, module: module, opIdx: opIdx, result: result, name: name, range: range, filePath: filePath) 'wasUnionCase'
		return
	end 'wasUnionCase'
	// Enum-case lookup: a qualified name `EnumName.case` whose case isn't a
	// known top-level constant might still name a known enum — that means the
	// enum exists but the case spelling is wrong (E3034). Distinguish so the
	// diagnostic points the user at "did you misspell the case?" rather than
	// the generic "undefined name" message.
	if reportEnumUnknownCaseIfApplicable(project, name: name, range: range, filePath: filePath) 'wasEnumCase'
		return
	end 'wasEnumCase'
	reportUnknownName(project, name: name, range: range, filePath: filePath)
end 'rewriteUnresolvedRead'

// Phase 9 Stage 3: rewrite a bare-case union read `UnionName.caseName` to
// a no-arg call against the synthesized constructor. Returns true when
// the rewrite fired; false leaves the caller to fall through to the
// enum-case / unknown-name diagnostic path. Payload cases are matched
// alongside bare cases — a stand-alone `Shape.circle` (no parens) does
// fail TR's existing arity check via the constructor's signature, which
// surfaces E3005 ("wrong arg count") rather than the union-case path.
function tryRewriteUnresolvedUnionCaseRead(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, name String, range SourceRange, filePath FilePath) returns bool
	// The visibility check happens through the constructor's existing
	// FuncVisibilityInfo entry once the call is dispatched; `filePath`
	// kept on the signature for parity with the surrounding rewrite
	// helpers (`tryRewriteDottedRead` / `reportEnumUnknownCaseIfApplicable`)
	// so future visibility tightening can reuse it. Discard via the
	// emptiness probe so the unused-variable check sees an observation.
	let pathStr = filePath.toString()
	if pathStr.byteLength() < 0 'never'
		return false
	end 'never'
	let bytes = name.toByteArray()
	let count = bytes.count()
	let dotIdx = lastIndexOfDotByte(bytes)
	if dotIdx >= count 'noDot'
		return false
	end 'noDot'
	let head = byteSliceToString(bytes, startIndex: 0, endIndex: dotIdx)
	let tail = byteSliceToString(bytes, startIndex: dotIdx + 1, endIndex: count)
	let info = lookupUnionCasePayloadArity(project, unionName: head, caseName: tail)
	if not info.isUnion 'notUnion'
		return false
	end 'notUnion'
	if info.payloadArity > 0 'needsParens'
		// Payload-bearing case referenced without parens — let the
		// existing diagnostic flow (callable referenced as value) catch
		// this; returning false routes us to the unknown-name path which
		// produces a cleaner diagnostic.
		return false
	end 'needsParens'
	let ctorName = unionConstructorSymbolName(head, caseName: tail)
	if not project.funcReturnTypes.contains(ctorName) 'noCtor'
		return false
	end 'noCtor'
	let calleeBytes = project.calleeNames.intern(ctorName)
	let emptyArgs = ByteArrayArray.create()
	let emptyArgLabels = StringArray.create()
	let emptyArgTypes = MaxonTypeArray.create()
	let emptyArgRanges = SourceRangeArray.create()
	try module.ops.set(opIdx, value: MaxonOp.call(result, callee: calleeBytes, callContext: CallContext.qualified, args: emptyArgs, argLabels: emptyArgLabels, argTypes: emptyArgTypes, argRanges: emptyArgRanges, range: range)) otherwise panic("tryRewriteUnresolvedUnionCaseRead: ops.set OOB at idx={opIdx}")
	return true
end 'tryRewriteUnresolvedUnionCaseRead'

// If `name` looks like `EnumName.case` and `EnumName` is a registered enum
// visible from `filePath`, emit E3034 for the unknown case and return true
// so the caller skips the generic "undefined name" diagnostic. When the
// enum exists but is hidden from the reader, treat it as if it didn't
// exist — the caller's "Undefined variable" path then matches the C#
// bootstrap's wording for cross-file private enums.
function reportEnumUnknownCaseIfApplicable(project Project, name String, range SourceRange, filePath FilePath) returns bool
	let split = splitQualifiedEnumName(project, qualifiedName: name)
	if not split.isEnum 'notEnum'
		return false
	end 'notEnum'
	// Phase 9 Stage 4: the full dotted name `Shape.unionCases` IS itself a
	// registered companion enum / typealias — treat it as a known name and
	// let the rest of the resolver handle it (the `Shape.unionCases` value
	// is the enum type, not a case lookup, so the caller's misspelled-case
	// diagnostic would be wrong).
	if project.enumTypes.contains(name) or project.unresolvedEnums.contains(name) or project.typealiases.contains(name) or project.unresolvedTypealiases.contains(name) 'isCompanionType'
		return false
	end 'isCompanionType'
	if let enumType = try project.enumTypes.get(split.prefix) 'haveEnum'
		if not isVisibleFrom(enumType.visibility, declFilePath: enumType.sourceFilePath, readerFilePath: filePath) 'hidden'
			return false
		end 'hidden'
	end 'haveEnum'
	reportCompileError(project, code: ErrorCode.semanticEnumUnknownCase, message: "unknown enum case: '{split.suffix}'", line: range.line, column: range.column, filePath: filePath)
	return true
end 'reportEnumUnknownCaseIfApplicable'

// Split a `Prefix.suffix` qualified name and report whether `Prefix` names
// a registered enum. The returned `prefix` and `suffix` are populated
// regardless of the enum check; callers that only care about the enum-ness
// inspect `isEnum`.
type QualifiedEnumName
	export var prefix as String
	export var suffix as String
	export var isEnum as bool

	export static function notEnum() returns QualifiedEnumName
		return Self{prefix: "", suffix: "", isEnum: false}
	end 'notEnum'

	export static function enumCase(prefix String, suffix String) returns QualifiedEnumName
		return Self{prefix: prefix, suffix: suffix, isEnum: true}
	end 'enumCase'
end 'QualifiedEnumName'

function splitQualifiedEnumName(project Project, qualifiedName String) returns QualifiedEnumName
	let bytes = qualifiedName.toByteArray()
	var dotIdx = -1 as ParsedInt
	for i in 0 upto bytes.count() 'scan'
		let b = try bytes.get(i) otherwise return QualifiedEnumName.notEnum()
		if b == '.' 'hit'
			dotIdx = i
			break
		end 'hit'
	end 'scan'
	if dotIdx < 0 'noDot'
		return QualifiedEnumName.notEnum()
	end 'noDot'
	let prefixBytes = try bytes.slice(0, endIndex: dotIdx) otherwise return QualifiedEnumName.notEnum()
	let suffixBytes = try bytes.slice(dotIdx + 1, endIndex: bytes.count()) otherwise return QualifiedEnumName.notEnum()
	let enumName = String.from(prefixBytes)
	if not project.enumTypes.contains(enumName) 'notEnum'
		return QualifiedEnumName.notEnum()
	end 'notEnum'
	return QualifiedEnumName.enumCase(enumName, suffix: String.from(suffixBytes))
end 'splitQualifiedEnumName'

function rewriteToLiteral(module MaxonModule, opIdx OpIndex, result ByteArray, value IntConstant, range SourceRange, valueType MaxonType = MaxonType.integer)
	try module.ops.set(opIdx, value: MaxonOp.literal(result, value: value, valueType: valueType, range: range)) otherwise panic("rewriteToLiteral: ops.set OOB at idx={opIdx} (count={module.ops.count()})")
end 'rewriteToLiteral'

// Fill pass for a `literal` op: repair an `unresolved` valueType to a bare
// integer so it can lower. A resolved valueType is left untouched. This is the
// safety net for synthetic literals that were born unresolved (e.g. a ternary
// seed whose true-arm type was unresolved at parse time) — see parseTernaryTail.
function fillLiteral(module MaxonModule, opIdx OpIndex, op MaxonOp)
	match op 'lit'
		literal(result, value, valueType, range) then repairLiteralType(module, opIdx: opIdx, result: result, value: value, valueType: valueType, range: range)
		default panic("fillLiteral: called on a non-literal op")
	end 'lit'
end 'fillLiteral'

function repairLiteralType(module MaxonModule, opIdx OpIndex, result ByteArray, value IntConstant, valueType MaxonType, range SourceRange)
	if isUnresolvedType(valueType) 'repair'
		rewriteToLiteral(module, opIdx: opIdx, result: result, value: value, range: range)
	end 'repair'
end 'repairLiteralType'

// Recover the named MaxonType for an enum-case constant. `qualifiedName`
// looks like `EnumName.case`; if `EnumName` is a registered enum the result
// carries that named type so downstream type-tracking sees `Direction.north`
// as a `Direction` rather than a bare int. Non-enum constants fall through
// to `fallback` so int-backed and float-backed callers can each pass the
// natural primitive type for their literal kind.
function enumLiteralTypeOr(project Project, qualifiedName String, fallback MaxonType) returns MaxonType
	let split = splitQualifiedEnumName(project, qualifiedName: qualifiedName)
	if not split.isEnum 'notEnum'
		return fallback
	end 'notEnum'
	return MaxonType.named(project.typeNames.intern(split.prefix))
end 'enumLiteralTypeOr'

function rewriteToStringConst(module MaxonModule, opIdx OpIndex, result ByteArray, stringId StringId, range SourceRange)
	try module.ops.set(opIdx, value: MaxonOp.stringConst(result, stringId: stringId, range: range)) otherwise panic("rewriteToStringConst: ops.set OOB at idx={opIdx} (count={module.ops.count()})")
end 'rewriteToStringConst'

// --- Enum-match arm resolution ---
//
// The parser emits `enumMatchArm(scrutineeName, caseName, ...)` as a
// terminator for each match arm without consulting the enum registry.
// This pass walks every op, looks the case name up against the scrutinee
// type's enum, and patches the raw value (or rewrites to `br(elseTarget)`
// after reporting a diagnostic on a miss).

function resolveEnumMatchArms(project Project, module MaxonModule, filePath FilePath)
	for opIdx in 0 upto module.ops.count() 'each'
		let op = try module.ops.get(opIdx) otherwise panic("resolveEnumMatchArms: opIdx OOB")
		if op.name == "enumMatchArm" 'isArm'
			match op 'extract'
				enumMatchArm(scrutineeName, caseName, scrutineeType, _, _, resolved, thenTarget, elseTarget, bindingNames, range) then resolveOneEnumMatchArm(project, module: module, opIdx: opIdx, scrutineeName: scrutineeName, caseName: caseName, scrutineeType: scrutineeType, alreadyResolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range, filePath: filePath)
				default panic("unreachable: already checked op.name == enumMatchArm")
			end 'extract'
		end 'isArm'
	end 'each'
end 'resolveEnumMatchArms'

function resolveOneEnumMatchArm(project Project, module MaxonModule, opIdx OpIndex, scrutineeName ByteArray, caseName String, scrutineeType MaxonType, alreadyResolved bool, thenTarget BlockId, elseTarget BlockId, bindingNames ByteArrayArray, range SourceRange, filePath FilePath)
	if alreadyResolved 'skip'
		return
	end 'skip'
	let enumName = try enumNameFromMaxonType(project, t: scrutineeType) otherwise 'noEnum'
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "match scrutinee must be an enum-typed value (got non-enum type)", line: range.line, column: range.column, filePath: filePath)
		try module.ops.set(opIdx, value: MaxonOp.br(elseTarget, range: range)) otherwise panic("resolveOneEnumMatchArm: ops.set OOB at idx={opIdx}")
		return
	end 'noEnum'
	let qualifiedName = "{enumName}.{caseName}"
	if let entry = try project.topLevelConstants.get(qualifiedName) 'isCase'
		let resolvedHit = matchCaseFromConstantValue(entry.value)
		try module.ops.set(opIdx, value: MaxonOp.enumMatchArm(scrutineeName, caseName: caseName, scrutineeType: scrutineeType, rawValue: resolvedHit.rawValue, isFloat: resolvedHit.isFloat, resolved: true, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range)) otherwise panic("resolveOneEnumMatchArm: ops.set OOB at idx={opIdx}")
		return
	end 'isCase'
	// Phase 9 Stage 2: payload union cases never reach `topLevelConstants`
	// because the parser routes them to constructor synthesis. Resolve the
	// case ordinal directly from the union's case table — match arms on
	// a `value(n)` payload case use the tag value as their raw comparison.
	let unionCaseHit = resolveUnionCaseRawValue(project, enumName: enumName, caseName: caseName)
	if unionCaseHit.hit 'isUnionCase'
		// E3035: a destructuring pattern `case(b1, b2, ...)` must supply
		// exactly as many bindings as the union case has payload fields.
		// Only fires when the user wrote bindings — bare-case patterns
		// (`case` without parens) carry an empty `bindingNames` and are
		// always valid against any payload arity.
		if bindingNames.count() > 0 'haveBindings'
			let info = lookupUnionCasePayloadArity(project, unionName: enumName, caseName: caseName)
			if info.isUnion and info.payloadArity != bindingNames.count() 'arityMismatch'
				reportCompileError(project, code: ErrorCode.semanticMatchPayloadArityMismatch, message: "wrong binding count: '{caseName}'", line: range.line, column: range.column, filePath: filePath)
			end 'arityMismatch'
		end 'haveBindings'
		try module.ops.set(opIdx, value: MaxonOp.enumMatchArm(scrutineeName, caseName: caseName, scrutineeType: scrutineeType, rawValue: unionCaseHit.rawValue, isFloat: false, resolved: true, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range)) otherwise panic("resolveOneEnumMatchArm: ops.set OOB at idx={opIdx}")
		return
	end 'isUnionCase'
	reportCompileError(project, code: ErrorCode.semanticEnumUnknownCase, message: "unknown enum case: '{caseName}'", line: range.line, column: range.column, filePath: filePath)
	try module.ops.set(opIdx, value: MaxonOp.br(elseTarget, range: range)) otherwise panic("resolveOneEnumMatchArm: ops.set OOB at idx={opIdx}")
end 'resolveOneEnumMatchArm'

// Phase 9 Stage 2: look up a union case's tag value (ordinal) from the
// resolved enum registry. Returns hit=false when the name isn't found or
// the entry isn't a union — caller falls through to the generic
// "unknown case" diagnostic. Bare cases on plain enums are reached via
// `topLevelConstants` and never enter this helper.
type UnionCaseMatchHit
	export var hit as bool
	export var rawValue as IntConstant

	export static function miss() returns UnionCaseMatchHit
		return Self{hit: false, rawValue: 0}
	end 'miss'

	export static function found(rawValue IntConstant) returns UnionCaseMatchHit
		return Self{hit: true, rawValue: rawValue}
	end 'found'
end 'UnionCaseMatchHit'

function resolveUnionCaseRawValue(project Project, enumName String, caseName String) returns UnionCaseMatchHit
	if let et = try project.enumTypes.get(enumName) 'resolved'
		if not et.isUnion 'notUnion'
			return UnionCaseMatchHit.miss()
		end 'notUnion'
		if let idx = try et.caseByName.get(caseName) 'haveCase'
			let c = try et.cases.get(idx) otherwise return UnionCaseMatchHit.miss()
			return UnionCaseMatchHit.found(c.rawValue)
		end 'haveCase'
	end 'resolved'
	if let ut = try project.unresolvedEnums.get(enumName) 'unresolved'
		if not ut.isUnion 'notUnion2'
			return UnionCaseMatchHit.miss()
		end 'notUnion2'
		for c in ut.cases 'eachCase'
			if c.name == caseName 'hit'
				return UnionCaseMatchHit.found(c.rawValue)
			end 'hit'
		end 'eachCase'
	end 'unresolved'
	return UnionCaseMatchHit.miss()
end 'resolveUnionCaseRawValue'

// Walk the (possibly chained) typealias from a MaxonType.named back to its
// originating enum name. Throws `NotEnumError.notEnum` when the named type
// isn't a registered enum (or when the type is a primitive / function /
// generic / interface arm); callers use `try ... otherwise` to fall through
// to the non-enum dispatch path.
function enumNameFromMaxonType(project Project, t MaxonType) returns String throws NotEnumError
	return match t 'unwrap'
		named(id) gives try enumNameFromTypeNameId(project, id: id)
		default throws NotEnumError.notEnum
	end 'unwrap'
end 'enumNameFromMaxonType'

function enumNameFromTypeNameId(project Project, id TypeNameId) returns String throws NotEnumError
	let name = project.typeNames.get(id)
	if project.enumTypes.contains(name) 'isEnum'
		return name
	end 'isEnum'
	throw NotEnumError.notEnum
end 'enumNameFromTypeNameId'

enum NotEnumError implements Error
	notEnum
end 'NotEnumError'

// Outcome of looking up a `topLevelConstants` entry that resolved an
// `EnumName.case` qualified name. Bundles the raw bit pattern with the
// int-vs-float family flag the lowering needs.
type EnumCaseHit
	export var rawValue as IntConstant
	export var isFloat as bool

	export static function intHit(rawValue IntConstant) returns EnumCaseHit
		return Self{rawValue: rawValue, isFloat: false}
	end 'intHit'

	export static function floatHit(bits IntConstant) returns EnumCaseHit
		return Self{rawValue: bits, isFloat: true}
	end 'floatHit'
end 'EnumCaseHit'

function matchCaseFromConstantValue(constVal ConstantValue) returns EnumCaseHit
	return match constVal 'unwrap'
		intValue(v) gives EnumCaseHit.intHit(v)
		floatValue(bits) gives EnumCaseHit.floatHit(bits)
		stringValue panic("matchCaseFromConstantValue: enum case stored as string constant — parser registers cases as int/float only")
	end 'unwrap'
end 'matchCaseFromConstantValue'

function rewriteUnresolvedAssign(project Project, module MaxonModule, opIdx OpIndex, name String, value ByteArray, range SourceRange, filePath FilePath)
	if let info = try project.topLevelVars.get(name) 'isTopLevelVar'
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: filePath) 'visible'
			// `let xs = [...]` parks the entry in `topLevelVars` (writable
			// data slot needed for the runtime initializer) but the source-
			// level binding is still immutable. Surface E2013 here so the
			// store doesn't silently rewrite as a globalStore.
			if project.immutableArrayLitNames.contains(name) 'immutableLet'
				reportCompileError(project, code: ErrorCode.parserImmutableVariable, message: "cannot assign to immutable variable: '{name}'", line: range.line, column: range.column, filePath: filePath)
				return
			end 'immutableLet'
			try module.ops.set(opIdx, value: MaxonOp.globalStore(name, value: value, slotType: info.slotType, range: range)) otherwise panic("rewriteUnresolvedAssign: ops.set OOB at idx={opIdx} (count={module.ops.count()})")
			return
		end 'visible'
	end 'isTopLevelVar'
	if let entry = try project.topLevelConstants.get(name) 'isConst'
		if isVisibleFrom(entry.visibility, declFilePath: entry.sourceFilePath, readerFilePath: filePath) 'visible'
			// Top-level lets are immutable; reassignment is rejected with
			// the E2013 wording shared with the C# bootstrap. By the time
			// this runs `resolveAllTopLevelDecls` has drained every let
			// into `topLevelConstants`, so a single map check suffices.
			reportCompileError(project, code: ErrorCode.parserImmutableVariable, message: "cannot assign to immutable variable: '{name}'", line: range.line, column: range.column, filePath: filePath)
			return
		end 'visible'
	end 'isConst'
	// `name` shaped `receiver.field` where `receiver` is a top-level var.
	// Mirrors the read path: rewrite to globalLoad(receiver) + fieldStore.
	if tryRewriteDottedAssign(project, module: module, opIdx: opIdx, name: name, value: value, range: range, filePath: filePath) 'wasInstanceField'
		return
	end 'wasInstanceField'
	reportUnknownName(project, name: name, range: range, filePath: filePath)
end 'rewriteUnresolvedAssign'

// Decompose `receiver.field` reads where the receiver is a top-level var
// holding a struct value. Replaces the unresolvedRead with a globalLoad of
// the receiver and inserts a fieldLoad after it carrying the original
// result name. Returns true on success so the caller skips the not-found
// diagnostic.
function tryRewriteDottedRead(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, name String, range SourceRange, filePath FilePath) returns bool
	let resolved = try resolveDottedTopLevelReceiver(project, name: name, filePath: filePath) otherwise return false
	let receiverName = freshGlobalLoadName(result)
	try module.ops.set(opIdx, value: MaxonOp.globalLoad(receiverName, name: resolved.prefix, slotType: resolved.info.slotType, range: range)) otherwise panic("tryRewriteDottedRead: ops.set OOB at idx={opIdx}")
	let fieldLoadIdx = module.ops.count()
	module.ops.push(MaxonOp.fieldLoad(result, receiver: receiverName, fieldName: resolved.fieldName.toByteArray(), range: range))
	insertOpAfter(module, anchorOpIdx: opIdx, newOpIdx: fieldLoadIdx)
	return true
end 'tryRewriteDottedRead'

// Decompose `receiver.field = value` writes where the receiver is a
// top-level var. Replaces the unresolvedAssign with a globalLoad and
// inserts a fieldStore after it. Reports E2013 (without rewriting) when
// the receiver was bound via `let`.
function tryRewriteDottedAssign(project Project, module MaxonModule, opIdx OpIndex, name String, value ByteArray, range SourceRange, filePath FilePath) returns bool
	let resolved = try resolveDottedTopLevelReceiver(project, name: name, filePath: filePath) otherwise return false
	if project.immutableArrayLitNames.contains(resolved.prefix) 'immutableLet'
		reportCompileError(project, code: ErrorCode.parserImmutableVariable, message: "cannot assign to immutable variable: '{resolved.prefix}'", line: range.line, column: range.column, filePath: filePath)
		return true
	end 'immutableLet'
	let receiverName = freshGlobalLoadName(value)
	try module.ops.set(opIdx, value: MaxonOp.globalLoad(receiverName, name: resolved.prefix, slotType: resolved.info.slotType, range: range)) otherwise panic("tryRewriteDottedAssign: ops.set OOB at idx={opIdx}")
	let fieldStoreIdx = module.ops.count()
	module.ops.push(MaxonOp.fieldStore(receiverName, fieldName: resolved.fieldName.toByteArray(), value: value, isInit: false, range: range))
	insertOpAfter(module, anchorOpIdx: opIdx, newOpIdx: fieldStoreIdx)
	return true
end 'tryRewriteDottedAssign'

// Resolution result for the dotted-receiver helper: the receiver-side
// prefix, its registered TopLevelVarInfo, and the trailing field name.
type ResolvedDottedReceiver
	export var prefix as String
	export var fieldName as String
	export var info as TopLevelVarInfo

	export static function create(prefix String, fieldName String, info TopLevelVarInfo) returns ResolvedDottedReceiver
		self.prefix = prefix
		self.fieldName = fieldName
		self.info = info
		return ResolvedDottedReceiver{}
	end 'create'
end 'ResolvedDottedReceiver'

// Shared resolution for `receiver.field` lookup against `topLevelVars`.
// Throws CompileError when the dotted form doesn't resolve to a visible
// top-level var with a non-empty trailing field name, so the read/assign
// callers can short-circuit via `try ... otherwise return false` without
// nesting per-failure-mode conditionals at every call site.
function resolveDottedTopLevelReceiver(project Project, name String, filePath FilePath) returns ResolvedDottedReceiver throws CompileError
	let prefix = leadingSegment(name)
	if prefix.count() == name.count() 'noDot'
		throw CompileError.compileError
	end 'noDot'
	let info = try project.topLevelVars.get(prefix) otherwise throw CompileError.compileError
	if not isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: filePath) 'notVisible'
		throw CompileError.compileError
	end 'notVisible'
	let fieldName = trailingSegmentAfterDot(name)
	if fieldName.isEmpty() 'noField'
		throw CompileError.compileError
	end 'noField'
	return ResolvedDottedReceiver.create(prefix, fieldName: fieldName, info: info)
end 'resolveDottedTopLevelReceiver'

// Splice `newOpIdx` into whichever block's opRefs currently holds
// `anchorOpIdx`, immediately after that anchor. Mirrors `insertBitNotAfter`
// — every op produced during type-resolution rewrites lives in exactly
// one block, so the linear scan is bounded by the block's own length.
function insertOpAfter(module MaxonModule, anchorOpIdx OpIndex, newOpIdx OpIndex)
	for blockRef in 0 upto module.blocks.count() 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("insertOpAfter: blockRef OOB")
		var insertPos = -1 as ParsedInt
		for posIdx in 0 upto block.opRefs.count() 'eachOpRef'
			let ref = try block.opRefs.get(posIdx) otherwise panic("insertOpAfter: posIdx OOB")
			if ref == anchorOpIdx 'foundAnchor'
				insertPos = posIdx
				break
			end 'foundAnchor'
		end 'eachOpRef'
		if insertPos >= 0 'doInsert'
			try block.opRefs.insert(insertPos + 1, value: newOpIdx) otherwise panic("insertOpAfter: opRefs.insert OOB")
			return
		end 'doInsert'
	end 'eachBlock'
	panic("insertOpAfter: anchor op at idx={anchorOpIdx} not registered in any block")
end 'insertOpAfter'

// Synthesize a name for the inserted globalLoad. Prefixed so IR dumps
// distinguish it from user-emitted names; suffixed with the related
// op's primary name so the receiver ↔ field pairing stays scannable.
function freshGlobalLoadName(related ByteArray) returns ByteArray
	let s = "$gload_{String.from(related)}"
	return s.toByteArray()
end 'freshGlobalLoadName'

// Return the segment of `name` after the first '.', or an empty string
// when there is no dot or the dot is the last character.
function trailingSegmentAfterDot(name String) returns String
	let bytes = name.toByteArray()
	for i in 0 upto bytes.count() 'scan'
		let b = try bytes.get(i) otherwise return ""
		if b == '.' 'isDot'
			let suffixBytes = try bytes.slice(i + 1, endIndex: bytes.count()) otherwise return ""
			return String.from(suffixBytes)
		end 'isDot'
	end 'scan'
	return ""
end 'trailingSegmentAfterDot'

function reportUnknownName(project Project, name String, range SourceRange, filePath FilePath)
	// Wording matches the C# bootstrap's E2004 phrasing for unresolved
	// reads. For dotted names (`Foo.bar`) we report the *prefix* before
	// the first dot — that's the part that didn't resolve to a
	// variable / type / enum the project knows about.
	let display = leadingSegment(name)
	reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Undefined variable '{display}'", line: range.line, column: range.column, filePath: filePath)
end 'reportUnknownName'

// Return the leading segment of `name` up to (but not including) the
// first '.', or the full name if there is no dot. Used to extract the
// receiver-side identifier from a qualified read like `Foo.bar` so the
// "Undefined variable" diagnostic mentions `Foo` rather than the full
// dotted name.
function leadingSegment(name String) returns String
	let bytes = name.toByteArray()
	for i in 0 upto bytes.count() 'scan'
		let b = try bytes.get(i) otherwise return name
		if b == '.' 'isDot'
			let prefixBytes = try bytes.slice(0, endIndex: i) otherwise return name
			return String.from(prefixBytes)
		end 'isDot'
	end 'scan'
	return name
end 'leadingSegment'

// --- Producer-type map for filling in MaxonType.unresolved operands ---
//
// Many parser-emitted ops carry MaxonType operands that are populated from
// the producing op's result type (varDecl.slotType, convert.fromType,
// cmp.leftType/rightType, call.argTypes, etc.). After Phase 2 of the
// "no parser lookups" migration, the parser leaves those fields as
// MaxonType.unresolved when the producing op's result type itself depended
// on a cross-declaration lookup (call return type, methodCall return type,
// fieldLoad type, etc.). This pass builds a name → MaxonType map by walking
// every op once, then walks again replacing every MaxonType.unresolved
// operand with the concrete type sourced from the map.

export typealias ProducerTypeMap = Map with (ByteArray, MaxonType)
export typealias SlotTypeMap = Map with (VarSlot, MaxonType)
export typealias SlotTypeMapArray = Array with SlotTypeMap

// Per-function map from a value-name (the result of a `stringConst` op)
// to the StringId it carries. Used by the post-rewrite walk that
// folds `cmp` between two stringConsts to a literal. Slot-tracked flow
// (varDecl(slot, stringConstResult); varLoad → consumer(varLoadResult))
// is captured by also threading slot-id → StringId through the same map
// indirected via slotTypes.
export typealias StringIdNameMap = Map with (ByteArray, StringId)
export typealias SlotStringIdMap = Map with (VarSlot, StringId)

function recordResultType(producerTypes ProducerTypeMap, name ByteArray, t MaxonType)
	if name.isEmpty() 'noName'
		return
	end 'noName'
	producerTypes.upsert(name, value: t)
end 'recordResultType'

function lookupProducerType(producerTypes ProducerTypeMap, name ByteArray) returns MaxonType
	return try producerTypes.get(name) otherwise MaxonType.unresolved
end 'lookupProducerType'

// Record a varDecl: store the slot's effective type (concrete if known,
// otherwise the producer's recorded type from the value name) into the
// slot-type map. Subsequent varLoads on the same slot read from this map.
//
// Phase 15e: when the parser-stamped slotType is a bare `__TupleN` named type
// but the producer-type has already been upgraded to a fully-specialised
// `genericInstance(__TupleN, [...])`, prefer the producer's view so downstream
// fieldLoad type-flow can substitute `_T0`/`_T1`/... typeParameter fields
// through to their concrete arg types. The parser can't intern the
// genericInstance because element types are unresolved at parse time.
function recordVarDecl(project Project, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, slotId VarSlot, value ByteArray, slotType MaxonType)
	if not isUnresolvedType(slotType) 'haveType'
		let fromValue = lookupProducerType(producerTypes, name: value)
		if maxonTypeIsBareTupleNamed(project, t: slotType) and maxonTypeIsTupleGenericInstance(project, t: fromValue) 'preferRefined'
			slotTypes.upsert(slotId, value: fromValue)
			return
		end 'preferRefined'
		slotTypes.upsert(slotId, value: slotType)
		return
	end 'haveType'
	let fromValue = lookupProducerType(producerTypes, name: value)
	if not isUnresolvedType(fromValue) 'fromValue'
		slotTypes.upsert(slotId, value: fromValue)
	end 'fromValue'
end 'recordVarDecl'

// Phase 15e: helpers used by recordVarDecl to detect the "slot was stamped
// as the unspecialised `__TupleN` named type, but the producer-type has the
// specialised generic-instance" case so we can prefer the latter.
function maxonTypeIsBareTupleNamed(project Project, t MaxonType) returns bool
	let name = match t 'getName'
		named(id) gives project.typeNames.get(id)
		boolean to string gives ""
		function to opaquePointer gives ""
	end 'getName'
	return isTupleStructName(name)
end 'maxonTypeIsBareTupleNamed'

function maxonTypeIsTupleGenericInstance(project Project, t MaxonType) returns bool
	let name = match t 'getName'
		genericInstance(id) gives genericInstanceBaseName(project, gid: id)
		boolean to string gives ""
		function gives ""
		named gives ""
		unresolved gives ""
		typeParameter gives ""
		interface to opaquePointer gives ""
	end 'getName'
	return isTupleStructName(name)
end 'maxonTypeIsTupleGenericInstance'

function genericInstanceBaseName(project Project, gid GenericInstanceId) returns String
	let (baseId, _) = project.genericInstances.get(gid)
	return project.typeNames.get(baseId)
end 'genericInstanceBaseName'

// Record a varLoad: read the slot's recorded type. If the parser-stamped
// slotType on the varLoad is concrete, use that; otherwise consult the
// slot-type map.
//
// Phase 15e: the parser stamps `__TupleN` varLoads with the bare named type
// (it doesn't intern a generic-instance at parse time because element types
// are still unresolved). When the slot-type map has the post-refine
// `genericInstance(__TupleN, [...])` entry, prefer it so downstream
// fieldLoad type-flow substitutes the `_T0`/`_T1`/... type-parameter
// fields against their concrete arg types.
function recordVarLoad(project Project, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, result ByteArray, slotId VarSlot, slotType MaxonType, enclosingType String)
	if not isUnresolvedType(slotType) 'haveType'
		let fromSlot = try slotTypes.get(slotId) otherwise MaxonType.unresolved
		if maxonTypeIsBareTupleNamed(project, t: slotType) and maxonTypeIsTupleGenericInstance(project, t: fromSlot) 'preferRefined'
			recordResultType(producerTypes, name: result, t: fromSlot)
			return
		end 'preferRefined'
		// Phase A widening: when the parser-stamped slotType is int but
		// the slot's effective type (after `recordVarStore` upgraded it
		// across arms) is float, prefer the slot-type-map entry so the
		// consumer's cmp/binop validation sees the widened type. Mirrors
		// `fillVarLoad`'s int→float rewrite at the op level.
		if isIntToFloatWidening(project, from: slotType, to: fromSlot) 'widenInt2Float'
			recordResultType(producerTypes, name: result, t: fromSlot)
			return
		end 'widenInt2Float'
		// Generic-body seed promotion: parser stamped the merge varLoad
		// from `try EXPR otherwise FALLBACK` with the seed-int slotType,
		// but `recordVarStore` upgraded the slot to `typeParameter` once
		// the success arm wrote a generic-method result owned by the
		// enclosing type. Prefer the slot-type-map entry so downstream
		// method dispatch (e.g. `prev.compare(pending)` inside
		// `extension Array where Element is Comparable`) sees the
		// typeParameter receiver and routes through the per-Element
		// witness instead of `int.compare`. Gated on the typeParameter
		// being in scope — see `recordVarStore`'s sibling guard.
		if (not maxonTypeIsTypeParameter(slotType)) and typeParamBelongsToEnclosing(project, t: fromSlot, enclosingType: enclosingType) 'promoteTypeParam'
			recordResultType(producerTypes, name: result, t: fromSlot)
			return
		end 'promoteTypeParam'
		recordResultType(producerTypes, name: result, t: slotType)
		return
	end 'haveType'
	let fromSlot = try slotTypes.get(slotId) otherwise MaxonType.unresolved
	recordResultType(producerTypes, name: result, t: fromSlot)
end 'recordVarLoad'

// Record a varStore: refine the slot's recorded type from the stored value's
// producer type when the value carries a more specific type than the slot
// already has. Two cases motivate this:
//   1. The slot's varDecl had unresolved slotType AND the initializer's
//      producer type was unresolved at varDecl-time (e.g. a methodCall whose
//      receiver type wasn't known yet). The follow-up varStore now sees the
//      methodCall's resolved type and can fill in.
//   2. The slot was seeded with a literal-zero placeholder by the parser
//      (parseTryFallback / parseMatchExpression) so the merge-block varLoad
//      reads a well-typed value under wasm validation. The seed pins the
//      slot type to `integer`; the real varStore later writes a value of the
//      slot's true type — usually a struct/enum, sometimes a different
//      primitive — and that has to win over the seed.
//
// Refinement rules:
//   - If the slot's current type is unresolved, take the value's type.
//   - If the value's type is a `named` (struct/enum) type and the slot's
//     current type is not `named`, take the value's type — a slot that
//     legitimately holds a struct can never have started life as a
//     primitive.
// Otherwise leave slotTypes alone — the existing entry is at least as
// specific as the new one.
function recordVarStore(project Project, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, slotId VarSlot, value ByteArray, enclosingType String)
	let fromValue = lookupProducerType(producerTypes, name: value)
	if isUnresolvedType(fromValue) 'noType'
		return
	end 'noType'
	let current = try slotTypes.get(slotId) otherwise MaxonType.unresolved
	if isUnresolvedType(current) 'fillUnresolved'
		slotTypes.upsert(slotId, value: fromValue)
		return
	end 'fillUnresolved'
	// Replace a primitive seed (the literal-zero stamp the parser uses
	// for try-fallback / match-expression merge slots) with any
	// non-primitive type the real varStore later writes. Covers struct
	// (named), generic-instance, and interface-typed merges.
	let currentIsStructLike = maxonTypeIsNamed(current) or maxonTypeIsGenericInstance(current)
	let fromValueIsStructLike = maxonTypeIsNamed(fromValue) or maxonTypeIsGenericInstance(fromValue)
	if not currentIsStructLike and fromValueIsStructLike 'replaceSeed'
		slotTypes.upsert(slotId, value: fromValue)
		return
	end 'replaceSeed'
	// Same seed-replacement rule for generic bodies: inside `extension
	// Array where Element is Comparable`, `let prev = try managed.get(i)
	// otherwise panic(...)` registers `prev`'s merge slot with the
	// literal-zero seed (recordVarDecl pinned it to `int`). The success
	// arm later writes the real value whose producer type is
	// `typeParameter(Element)`. Without this branch, the slot stays
	// `int`, the downstream `prev.compare(pending)` resolves against
	// `int.compare`, and the stdlib-cached `Array.sort$` body silently
	// pointer-compares heap pointers instead of calling `Pair.compare`.
	// Mirrors the C# bootstrap fix in `maxon-sharp/Compiler/2-Parser.cs`
	// (let-binding registration captures typeParamName from the
	// MaxonManagedMemGetOp result).
	//
	// Gate on the typeParameter belonging to the enclosing type — only
	// type parameters in scope on the surrounding method's signature
	// participate in trait-routed dispatch against its `where` clauses.
	// Out-of-scope type parameters (e.g. raw `__ManagedMemory.get`
	// called from `main`) fall back to int-category at every use site;
	// promoting the slot would force `mm.get(i) != 0` to require
	// `Element is Equatable` and break the managed-memory-builtin
	// tests.
	if not currentIsStructLike and typeParamBelongsToEnclosing(project, t: fromValue, enclosingType: enclosingType) 'replaceSeedTypeParam'
		slotTypes.upsert(slotId, value: fromValue)
		return
	end 'replaceSeedTypeParam'
	// Phase A widening: when an earlier arm pinned the slot to `int` (the
	// literal-zero seed's category, or a prior arm that produced an int)
	// and a later arm produces a `float`, upgrade the slot to the value's
	// float-category type so the merge varLoad reads an IEEE-754 value and
	// so `lowerVarStore` emits siToFp for the earlier int-typed arms.
	// Mirrors the C# bootstrap's `BackPromotePriorMatchArms` — narrowing
	// (float → int) stays pinned to the original kind so no fractional
	// data is silently lost. Preserves the incoming float type (which may
	// carry a named-typealias decoration, e.g. `JsonFloat`) rather than
	// forcing bare `float`, matching the upstream "first arm pins" rule.
	if isIntToFloatWidening(project, from: current, to: fromValue) 'widenIntToFloat'
		slotTypes.upsert(slotId, value: fromValue)
		return
	end 'widenIntToFloat'
	// Refine `named(X)` → `genericInstance(X, [...])` when the bases
	// agree. Static-method return types parsed as `Self` (e.g.
	// `Array.slice` returning `Self`) collapse to `named(Array)` at
	// parse time; the varStore on the success path of
	// `try arr.slice(...) otherwise [1]` later sees the substituted
	// `genericInstance(Array, [Integer])` from `methodCallResultType`.
	// Without this, the slot stays at `named(Array)`, the merge
	// varLoad stamps that onto downstream `sub.get(...)` callsites, and
	// layout-arg materialization can't recover the element binding.
	let promoted = promoteNamedToGenericInstance(project, raw: current, candidate: fromValue)
	if not maxonTypesStructurallyEqual(promoted, b: current) 'didPromote'
		slotTypes.upsert(slotId, value: promoted)
	end 'didPromote'
end 'recordVarStore'

// True iff `t` is a struct/enum type. Used by recordVarStore to detect when
// a varStore's value type out-ranks an integer seed left by the parser's
// merge-block initialization scheme.
export function maxonTypeIsNamed(t MaxonType) returns bool
	return match t 'check'
		named gives true
		boolean to string gives false
		function to opaquePointer gives false
	end 'check'
end 'maxonTypeIsNamed'

export function maxonTypeIsGenericInstance(t MaxonType) returns bool
	return match t 'check'
		genericInstance gives true
		boolean to string gives false
		named gives false
		function to unresolved gives false
		typeParameter gives false
		interface to opaquePointer gives false
	end 'check'
end 'maxonTypeIsGenericInstance'

// True when `t` is a free type-parameter (the parser/TR shape for a
// generic body's `Element`-like binding). Used by the hybrid-generics
// call-boundary bridges in LowerMaxonToStd: a typeParameter param/return
// indicates the callee was compiled with an int-channel ABI for that
// slot regardless of how the call site substitutes the parameter, so
// float-class args/returns need an f64↔i64 bitcast at the boundary.
export function maxonTypeIsTypeParameter(t MaxonType) returns bool
	return match t 'check'
		typeParameter gives true
		boolean to string gives false
		named gives false
		function to unresolved gives false
		genericInstance to opaquePointer gives false
	end 'check'
end 'maxonTypeIsTypeParameter'

// True when `t` is a `typeParameter(id)` owned by `enclosingType` — i.e.
// a parameter the surrounding struct/extension method itself declares
// (e.g. `Array.Element` while compiling a method in `extension Array
// ...`). Used by the seed-promotion guard in `recordVarStore` /
// `recordVarLoad` / `widenOneVarDecl` / `fillVarLoad`: only
// in-scope type parameters participate in trait-routed dispatch
// against the enclosing method's `where` clauses, so promoting a
// try-fallback merge slot from its literal-zero seed (`int`) to a
// typeParameter only helps when the downstream dispatch will actually
// substitute that parameter. Out-of-scope type parameters (e.g. the
// raw `__ManagedMemory.get` return when called from `main`) fall back
// to the int-category coercion at every use site, so promoting the
// slot would force `mm.get(i) != 0` to demand `Element is Equatable`
// for no semantic benefit and break the managed-memory-builtin tests.
function typeParamBelongsToEnclosing(project Project, t MaxonType, enclosingType String) returns bool
	if enclosingType.isEmpty() 'noEnclosing'
		return false
	end 'noEnclosing'
	if not maxonTypeIsTypeParameter(t) 'notTypeParam'
		return false
	end 'notTypeParam'
	let id = match t 'extract'
		typeParameter(pid) gives pid
		boolean to string panic("typeParamBelongsToEnclosing: just verified typeParameter shape — unreachable")
		named panic("typeParamBelongsToEnclosing: just verified typeParameter shape — unreachable")
		function to unresolved panic("typeParamBelongsToEnclosing: just verified typeParameter shape — unreachable")
		genericInstance to opaquePointer panic("typeParamBelongsToEnclosing: just verified typeParameter shape — unreachable")
	end 'extract'
	return project.typeParameters.getOwner(id) == enclosingType
end 'typeParamBelongsToEnclosing'

// Promote `named(X)` → `genericInstance(X, [...])` when `candidate`
// carries the binding `raw` was missing — i.e. their base names match.
// Returns `candidate` on a match, `raw` otherwise. The parser collapses
// `Self` and bare `T` to `named(EnclosingType)` (it has no type-arg
// context at parse time); call sites that learn the receiver's
// `genericInstance(EnclosingType, [Args])` later in the pipeline pass
// it as `candidate` to recover the binding.
export function promoteNamedToGenericInstance(project Project, raw MaxonType, candidate MaxonType) returns MaxonType
	if not maxonTypeIsNamed(raw) 'rawNotNamed'
		return raw
	end 'rawNotNamed'
	if not maxonTypeIsGenericInstance(candidate) 'candNotGeneric'
		return raw
	end 'candNotGeneric'
	let rawName = raw.nameOrEmpty(project)
	let candidateName = candidate.nameOrEmpty(project)
	if rawName.isEmpty() or rawName != candidateName 'mismatch'
		return raw
	end 'mismatch'
	return candidate
end 'promoteNamedToGenericInstance'

// Resolve a methodCall's result type by combining the receiver's resolved
// type with the method name. Returns MaxonType.unresolved when the receiver
// type isn't a known struct or the method isn't registered.
//
// First-param overload disambiguation: when the bare qualified name has
// overload variants registered, pick the variant matching the call's first
// argument type; if the first arg type is still unresolved at this stage,
// fall back to the first variant's return type (overload return types are
// rarely heterogeneous in practice and this keeps the producer-type walk
// from cascading into unresolved propagation).
function methodCallResultType(project Project, receiverType MaxonType, methodName ByteArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, args ByteArrayArray, enclosingType String) returns MaxonType
	let normReceiver = normalizeReceiverInContext(project, t: receiverType, enclosingType: enclosingType)
	// Iterator-shape passthrough on an interface receiver: when an
	// `interface Iface` declares `current()` + `advance()` but no
	// `createIterator`, `for item in self` inside `extension Iface ...` is
	// the user's "Iface is its own iterator" pattern. The lowerer aliases
	// the createIterator result back to the receiver; mirror that here so
	// the iter slot's MaxonType resolves to the receiver's interface and
	// downstream `advance` / `current` calls dispatch via witness table.
	if String.from(methodName) == "createIterator" 'maybeIteratorShapePassthrough'
		if interfaceReceiverIsIteratorShape(project, t: normReceiver) 'isShape'
			return normReceiver
		end 'isShape'
	end 'maybeIteratorShapePassthrough'
	// Interface receivers: `s.area()` on `s Shape` doesn't qualify through a
	// concrete struct's funcReturnTypes entry (the interface itself isn't a
	// struct and the conforming type isn't known at this site — that's the
	// whole point of dispatch). Without this branch we'd fall through to the
	// `maxonTypeStructName` / `primitiveExtensionTypeNameWithProject` checks
	// below, both throw, and the methodCall's producer-type entry stays
	// `unresolved`. Downstream `fillBinop` then can't derive an operand type
	// when two interface-dispatched results are combined (`s.area() + s.perimeter()`).
	// Lookup the method's declared return type on the interface — Phase 11
	// monomorphization (or witness-table dispatch) preserves this signature
	// across the lowering boundary.
	if let interfaceMethodResult = try interfaceMethodResultType(project, receiverType: normReceiver, methodName: methodName) 'fromInterface'
		return interfaceMethodResult
	end 'fromInterface'
	// typeParameter receivers (e.g. `a.compare(b)` inside a closure where
	// `a` is typed as the enclosing extension's `Element` type-param): we
	// don't have a where-clause context inside the lifted closure body, so
	// fall back to searching every interface for a uniquely-named method.
	// Comparable.compare, Hashable.hash etc. are unique, so this routes
	// the closure-body's producer-type to the right return type even
	// before monomorphization specializes Element to a concrete type.
	if let typeParamMethodResult = try typeParameterMethodResultType(project, receiverType: normReceiver, methodName: methodName) 'fromTypeParam'
		return typeParamMethodResult
	end 'fromTypeParam'
	// Phase 11.4 / Phase 7: when the receiver is a primitive
	// (`int`/`float`/`bool`/`byte`), `maxonTypeStructName` throws and we
	// fall back to the extension type name registered for the primitive
	// (`int.toString`, `bool.equals`, …). Without this, `let s = 42.toString()`
	// records `s` as `MaxonType.unresolved` and downstream cmp dispatch
	// (`s == "42"`) never gets rewritten to `s.equals("42")`.
	var structName = ""
	if let direct = try maxonTypeStructName(project, t: normReceiver) 'haveStruct'
		structName = direct
	end 'haveStruct'
	if structName.isEmpty() 'tryPrimitive'
		structName = try primitiveExtensionTypeNameWithProject(project, t: normReceiver) otherwise return MaxonType.unresolved
	end 'tryPrimitive'
	let bareCallee = "{structName}.{String.from(methodName)}"
	var qualifiedCallee = resolveOverloadFromArgs(project, bareName: bareCallee, args: args, argTypes: argTypes, producerTypes: producerTypes, hasSelf: false)
	// Mirror `resolveMethodCallSite`: fall back to an interface-extension
	// method when the concrete-type qualified name has no return-type entry.
	// Without this, `c.asSimple()` (extension on `Pointlike`, called via a
	// concrete `Coord`) would record an unresolved producer type and the
	// downstream `p.x` field-load would fail to find a struct context.
	if not project.funcReturnTypes.contains(qualifiedCallee) 'noDirectReturn'
		let bareMethodName = String.from(methodName)
		if let extensionCallee = try findInterfaceExtensionCallee(project, typeName: structName, methodName: bareMethodName, argTypes: argTypes) 'foundExt'
			qualifiedCallee = extensionCallee
		end 'foundExt'
	end 'noDirectReturn'
	// `it.createIterator()` on a type that conforms to Iterator (but does not
	// define its own createIterator) is the iterator-passthrough identity —
	// same shape lowerMethodCall recognises. The producer-type walk needs
	// this answer too so the result's slotType becomes the receiver's
	// concrete iterator type (RangeIterator, etc.) rather than `<unresolved>`;
	// without this, downstream `.advance()` / `.current()` calls land on an
	// unresolved receiver and lower as an interface-dispatch stub.
	if not project.funcReturnTypes.contains(qualifiedCallee) and String.from(methodName) == "createIterator" 'maybeIteratorPassthrough'
		if typeConformsTo(project, t: normReceiver, interfaceName: "Iterator") 'isIteratorPassthrough'
			return normReceiver
		end 'isIteratorPassthrough'
	end 'maybeIteratorPassthrough'
	let returnType = try project.funcReturnTypes.get(qualifiedCallee) otherwise return MaxonType.unresolved
	let raw = match returnType 'unwrap'
		void gives MaxonType.unresolved
		value(inner) gives inner
	end 'unwrap'
	// Phase 11.0 Step 8a: substitute the method's declared return type
	// against the receiver's generic instantiation. For a non-generic
	// receiver, buildSubstitutionForInstance returns an empty subst and
	// substituteType is a no-op.
	//
	// Before substituting, unwrap any inner-alias `named(...)` arms — when
	// the method returns one of the receiver's inner typealiases (e.g.
	// `Array.createIterator()` returns `ArrayIter` which is the alias for
	// `ArrayIterator with Element`), `substituteType`'s `named` arm is a
	// no-op and the receiver's `Element → String` binding never reaches
	// the alias body. Applying `applyInnerAliasIfNamed` first promotes the
	// alias to its `genericInstance(...)` form so substitution flows.
	let aliasResolved = applyInnerAliasFromReceiver(project, t: raw, receiverStructName: structName)
	let selfResolved = promoteSelfReturnToReceiver(project, raw: aliasResolved, receiverType: normReceiver, receiverStructName: structName)
	// When promoteSelfReturnToReceiver swapped in the receiver type
	// directly (the `Self` case), skip the subsequent substitution —
	// substituting would re-walk the receiver's typeParameter args
	// against a subst built from the same receiver, which round-trips
	// each `typeParameter` arm through `subst.lookup` and falls out as
	// `unresolved`. Conditional receivers (`__ManagedMemory with Element`)
	// must keep their typeParameter args intact for stdlib generic
	// bodies.
	if maxonTypesStructurallyEqual(selfResolved, b: normReceiver) 'selfReturn'
		return selfResolved
	end 'selfReturn'
	// Bare-generic return promotion: when a method on `Map<Key, Value>`
	// returns `MapIterator` (bare) and `MapIterator` is itself declared
	// `uses Key, Value`, neither inner-alias nor Self-promotion catches
	// it — yet downstream layout/witness materialization needs a fully
	// shaped genericInstance. Promote `named(GenericType)` by pairing
	// `GenericType`'s param names with typeParameter ids in the
	// enclosing struct's scope; the upcoming substitution then binds
	// them through the receiver. Without this, lowering of
	// `iter.advance()` on a non-generic caller (e.g. `main`) hits
	// `forwardCallerLayout` with nothing to forward.
	let scopeResolved = promoteBareGenericReturnToScope(project, t: selfResolved, enclosingStructName: structName)
	// J.4f.2: when the method is declared on an interface extension
	// (`extension Iterable ... function map(...) returns ElementArray`),
	// the return type references the interface's own typeParameter
	// (`Iterable.Element`). Map/Set/etc. bind that typeParameter through
	// their `implements Iterable with (Entry, MapIterator)` clause, which
	// the receiver-typed substitution built below DOES NOT know about
	// (it only carries the receiver's own typeParameters → concrete-args
	// map). Pre-resolve interface typeParameters against the receiver's
	// conformance row first so the downstream `substituteType` can finish
	// the job with the receiver's own bindings. Without this pass,
	// `m.map(...)`'s return type lands as `Array with unresolved` and
	// downstream layout materialization for `for pair in mapped` panics
	// at `forwardCallerLayout`.
	let ifaceResolved = resolveInterfaceTypeParamsViaConformance(project, t: scopeResolved, receiverType: normReceiver)
	let subst = buildSubstitutionForInstance(project, t: normReceiver)
	return substituteType(project, t: ifaceResolved, subst: subst)
end 'methodCallResultType'

// J.4f.2: walk `t` and replace every `typeParameter(id)` whose declaring
// scope is an interface the receiver implements with the type that the
// receiver's `implements I with (...)` clause binds to that param. This
// turns `Array with Iterable.Element` (declared on Map's
// `extension Iterable`) into `Array with (Key, Value)` for a Map
// receiver, so the receiver-substitution that follows finds the bare
// Map.Key / Map.Value typeParameters it knows how to resolve.
function resolveInterfaceTypeParamsViaConformance(project Project, t MaxonType, receiverType MaxonType) returns MaxonType
	return match t 'walk'
		boolean to string gives t
		named gives chaseReceiverInnerAlias(project, t: t, receiverType: receiverType)
		function(id) gives resolveInterfaceTypeParamsInFunction(project, id: id, receiverType: receiverType)
		unresolved gives t
		typeParameter(id) gives resolveSingleInterfaceTypeParam(project, paramId: id, receiverType: receiverType, fallback: t)
		genericInstance(gid) gives resolveInterfaceTypeParamsInGenericInstance(project, gid: gid, receiverType: receiverType)
		interface to opaquePointer gives t
	end 'walk'
end 'resolveInterfaceTypeParamsViaConformance'

// Substitute one `typeParameter(id)` arm via the receiver's conformance.
// Skipped when the param's declaring scope isn't an interface (the
// receiver's own typeParameter — left for `buildSubstitutionForInstance`
// to handle) or the receiver doesn't conform to that interface. After a
// successful conformance lookup, the raw withArg may still be a bare
// `named(InnerAlias)` (e.g. Map's conformance entry stores Element as
// `named(Entry)` because the parser interns conformance args by name
// without chasing inner aliases). Re-walk through `chaseReceiverInnerAlias`
// so an unwrappable alias on the receiver expands into its underlying
// generic instance.
function resolveSingleInterfaceTypeParam(project Project, paramId TypeParamId, receiverType MaxonType, fallback MaxonType) returns MaxonType
	let declaringScope = project.typeParameters.getDeclaringTypeName(paramId)
	if not project.interfaces.contains(declaringScope) and not project.unresolvedInterfaces.contains(declaringScope) 'notIface'
		return fallback
	end 'notIface'
	let paramName = project.typeParameters.getName(paramId)
	let resolved = try resolveInterfaceUsesParamThroughConformance(project, selfType: receiverType, interfaceName: declaringScope, paramName: paramName) otherwise return fallback
	return resolveInterfaceTypeParamsViaConformance(project, t: resolved, receiverType: receiverType)
end 'resolveSingleInterfaceTypeParam'

// Chase one `named(X)` arm through the receiver's inner-aliases (the
// receiver's own struct, then each interface it implements). When the
// alias expands, recurse on the result so a chain like
// `Entry → (Key, Value) → __Tuple2 with (typeParameter(Map, Key), typeParameter(Map, Value))`
// fully unwraps. Returns `t` unchanged when no alias matches.
function chaseReceiverInnerAlias(project Project, t MaxonType, receiverType MaxonType) returns MaxonType
	let receiverStructName = baseNameOfReceiverType(project, selfType: receiverType)
	if receiverStructName.isEmpty() 'noRecv'
		return t
	end 'noRecv'
	let expanded = applyInnerAliasFromReceiver(project, t: t, receiverStructName: receiverStructName)
	if maxonTypesStructurallyEqual(expanded, b: t) 'noChange'
		return t
	end 'noChange'
	// Recurse so a typeParameter inside the expanded form (e.g. the
	// `typeParameter(Map, Key)` arms inside `__Tuple2 with (Key, Value)`)
	// can be resolved on the next pass — though those are receiver
	// typeParameters and will be left for `substituteType` to handle in
	// `methodCallResultType`. This walk only chases further named-aliases.
	return resolveInterfaceTypeParamsViaConformance(project, t: expanded, receiverType: receiverType)
end 'chaseReceiverInnerAlias'

// Recursive case for `resolveInterfaceTypeParamsViaConformance`: walk a
// genericInstance's args, resolving each in turn, then re-intern through
// the registry so the result keeps the same baseId.
function resolveInterfaceTypeParamsInGenericInstance(project Project, gid GenericInstanceId, receiverType MaxonType) returns MaxonType
	let (baseId, args) = project.genericInstances.get(gid)
	var newArgs = MaxonTypeArray.create()
	var changed = false
	for i in 0 upto args.count() 'each'
		let a = try args.get(i) otherwise panic("resolveInterfaceTypeParamsInGenericInstance: args.get OOB at {i}")
		let na = resolveInterfaceTypeParamsViaConformance(project, t: a, receiverType: receiverType)
		if not maxonTypesStructurallyEqual(a, b: na) 'diff'
			changed = true
		end 'diff'
		newArgs.push(na)
	end 'each'
	if not changed 'unchanged'
		return MaxonType.genericInstance(gid)
	end 'unchanged'
	let newGid = project.genericInstances.intern(baseId, args: newArgs)
	return MaxonType.genericInstance(newGid)
end 'resolveInterfaceTypeParamsInGenericInstance'

// Recursive case for `resolveInterfaceTypeParamsViaConformance` on a
// function type. Walks param types + return type, resolves each, and
// re-interns to preserve registry identity.
function resolveInterfaceTypeParamsInFunction(project Project, id FunctionTypeId, receiverType MaxonType) returns MaxonType
	let (paramTypes, returnType) = project.functionTypes.get(id)
	var newParamTypes = MaxonTypeArray.create()
	var changed = false
	for i in 0 upto paramTypes.count() 'each'
		let p = try paramTypes.get(i) otherwise panic("resolveInterfaceTypeParamsInFunction: paramTypes.get OOB at {i}")
		let np = resolveInterfaceTypeParamsViaConformance(project, t: p, receiverType: receiverType)
		if not maxonTypesStructurallyEqual(p, b: np) 'diff'
			changed = true
		end 'diff'
		newParamTypes.push(np)
	end 'each'
	let newReturn = match returnType 'r'
		void gives MaxonReturnType.void
		value(inner) gives MaxonReturnType.value(resolveInterfaceTypeParamsViaConformance(project, t: inner, receiverType: receiverType))
	end 'r'
	let returnChanged = match returnType 'rcmp'
		void gives false
		value(inner) gives not maxonTypesStructurallyEqual(inner, b: match newReturn 'unwrap'
			void gives MaxonType.unresolved
			value(ni) gives ni
		end 'unwrap')
	end 'rcmp'
	if not changed and not returnChanged 'unchanged'
		return MaxonType.function(id)
	end 'unchanged'
	let newId = internFunctionType(project, paramTypes: newParamTypes, returnType: newReturn)
	return MaxonType.function(newId)
end 'resolveInterfaceTypeParamsInFunction'

// Promote `named(X)` to `genericInstance(X, [typeParameter(<scope>, p)...])`
// when X is generic and the enclosing scope declares the same param names.
// The result threads through `buildSubstitutionForInstance`'s scope-keyed
// bindings; partial overlap means we can't reconstruct a faithful instance
// and we leave the type as-is for the caller.
function promoteBareGenericReturnToScope(project Project, t MaxonType, enclosingStructName String) returns MaxonType
	if not maxonTypeIsNamed(t) 'notNamed'
		return t
	end 'notNamed'
	if enclosingStructName.isEmpty() 'noScope'
		return t
	end 'noScope'
	let targetName = t.nameOrEmpty(project)
	if targetName.isEmpty() 'noName'
		return t
	end 'noName'
	let targetParams = project.typeParameters.getParamNames(targetName)
	if targetParams.count() == 0 'notGeneric'
		return t
	end 'notGeneric'
	var args = MaxonTypeArray.create()
	for i in 0 upto targetParams.count() 'eachParam'
		let pname = try targetParams.get(i) otherwise panic("promoteBareGenericReturnToScope: targetParams.get OOB at {i}")
		if not project.typeParameters.contains(enclosingStructName, paramName: pname) 'missingInScope'
			return t
		end 'missingInScope'
		let pid = project.typeParameters.intern(enclosingStructName, paramName: pname)
		args.push(MaxonType.typeParameter(pid))
	end 'eachParam'
	let baseId = project.typeNames.intern(targetName)
	let gid = project.genericInstances.intern(baseId, args: args)
	return MaxonType.genericInstance(gid)
end 'promoteBareGenericReturnToScope'

// True when `t` is an interface receiver whose interface declares both
// `current()` and `advance()` but no `createIterator` — the user's "this
// interface is its own iterator" pattern (e.g. `interface HasItems uses
// Element function current() returns Element function advance() throws ...`).
// Mirrors `interfaceDeclaresMethodTransitive` in LowerMaxonToStd: the
// producer-type walk needs to agree with the lowerer about what
// createIterator returns so the iter-slot's MaxonType lands as the
// receiver's interface and downstream witness dispatch resolves.
function interfaceReceiverIsIteratorShape(project Project, t MaxonType) returns bool
	let interfaceName = match t 'pick'
		interface(id) gives project.interfaceRegistry.getName(id)
		boolean to string gives ""
		function gives ""
		unresolved gives ""
		typeParameter gives ""
		named gives ""
		genericInstance gives ""
		constInt to opaquePointer gives ""
	end 'pick'
	if interfaceName.isEmpty() 'notIface'
		return false
	end 'notIface'
	if interfaceDeclaresMethodInResolved(project, interfaceName: interfaceName, methodName: "createIterator") 'hasCreate'
		return false
	end 'hasCreate'
	if not interfaceDeclaresMethodInResolved(project, interfaceName: interfaceName, methodName: "current") 'noCurrent'
		return false
	end 'noCurrent'
	return interfaceDeclaresMethodInResolved(project, interfaceName: interfaceName, methodName: "advance")
end 'interfaceReceiverIsIteratorShape'

// Walk an interface's direct methods plus its transitive `extends`
// parents in the resolved interfaces table. Returns true when any of
// them declares `methodName`. Used by the iterator-shape passthrough to
// classify receivers without depending on `unresolvedInterfaces` (which
// has been drained by the time `methodCallResultType` runs).
function interfaceDeclaresMethodInResolved(project Project, interfaceName String, methodName String) returns bool
	var visited = StringSet.create()
	return interfaceDeclaresMethodInResolvedHelper(project, interfaceName: interfaceName, methodName: methodName, visited: visited)
end 'interfaceDeclaresMethodInResolved'

function interfaceDeclaresMethodInResolvedHelper(project Project, interfaceName String, methodName String, visited StringSet) returns bool
	if visited.contains(interfaceName) 'seen'
		return false
	end 'seen'
	visited.insert(interfaceName)
	let iface = try project.interfaces.get(interfaceName) otherwise return false
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("interfaceDeclaresMethodInResolvedHelper: methods.get OOB at {i}")
		if m.name == methodName 'hit'
			return true
		end 'hit'
	end 'scan'
	for j in 0 upto iface.extendsNames.count() 'parents'
		let parent = try iface.extendsNames.get(j) otherwise panic("interfaceDeclaresMethodInResolvedHelper: extendsNames.get OOB at {j}")
		if interfaceDeclaresMethodInResolvedHelper(project, interfaceName: parent, methodName: methodName, visited: visited) 'parentMatch'
			return true
		end 'parentMatch'
	end 'parents'
	return false
end 'interfaceDeclaresMethodInResolvedHelper'

// Resolve a methodCall result type when the receiver is `MaxonType.interface(_)`.
// Walks the interface's declared methods (resolved-side only — the parser drains
// `unresolvedInterfaces` into `interfaces` early in type resolution) and returns
// the matching signature's value-return MaxonType. Throws `InterfaceMethodLookupError`
// if the receiver isn't an interface, the interface isn't registered, the method
// isn't declared on it, or the declared return is `void` — callers fall back to
// the struct/primitive paths in those cases.
function interfaceMethodResultType(project Project, receiverType MaxonType, methodName ByteArray) returns MaxonType throws InterfaceMethodLookupError
	let interfaceName = match receiverType 'pick'
		interface(id) gives project.interfaceRegistry.getName(id)
		default throws InterfaceMethodLookupError.notInterface
	end 'pick'
	let iface = try project.interfaces.get(interfaceName) otherwise throw InterfaceMethodLookupError.notInterface
	let methodNameStr = String.from(methodName)
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("interfaceMethodResultType: methods.get OOB at {i} (interface={interfaceName})")
		if m.name == methodNameStr 'hit'
			let raw = match m.returnType 'unwrap'
				value(inner) gives inner
				default throws InterfaceMethodLookupError.voidReturn
			end 'unwrap'
			return promoteInterfaceUsesParamRef(project, t: raw, interfaceName: interfaceName)
		end 'hit'
	end 'scan'
	throw InterfaceMethodLookupError.methodNotFound
end 'interfaceMethodResultType'

// typeParameter receivers (closure bodies lifted from inside a generic
// extension): no where-clause context is carried into the lifted body, so
// fall back to scanning every interface in the project for a uniquely-named
// method. If multiple interfaces declare the method, return unresolved —
// downstream monomorphization resolves the call once Element is specialized.
function typeParameterMethodResultType(project Project, receiverType MaxonType, methodName ByteArray) returns MaxonType throws InterfaceMethodLookupError
	let isTypeParam = match receiverType 'pick'
		typeParameter gives true
		boolean to unresolved gives false
		genericInstance to opaquePointer gives false
	end 'pick'
	if not isTypeParam 'notTypeParam'
		throw InterfaceMethodLookupError.notInterface
	end 'notTypeParam'
	let methodNameStr = String.from(methodName)
	var foundIface = ""
	var foundReturn = MaxonType.unresolved
	var matchCount = 0
	for (ifaceName, iface) in project.interfaces 'eachIface'
		for i in 0 upto iface.methods.count() 'scan'
			let m = try iface.methods.get(i) otherwise panic("typeParameterMethodResultType: methods.get OOB at {i} (interface={ifaceName})")
			if m.name != methodNameStr 'mismatch'
				continue
			end 'mismatch'
			let raw = match m.returnType 'unwrap'
				value(inner) gives inner
				void gives MaxonType.unresolved
			end 'unwrap'
			if isUnresolvedType(raw) 'voidReturn'
				continue
			end 'voidReturn'
			foundIface = ifaceName
			foundReturn = promoteInterfaceUsesParamRef(project, t: raw, interfaceName: ifaceName)
			matchCount = matchCount + 1
		end 'scan'
	end 'eachIface'
	if matchCount == 1 'unique'
		return foundReturn
	end 'unique'
	throw InterfaceMethodLookupError.methodNotFound
end 'typeParameterMethodResultType'

// Interface bodies are parsed with `currentTypeParams = []`, so a bare
// reference to one of the interface's `uses` parameters (e.g. `Element`
// in `function current() returns Element`) lands as `named(Element)`
// instead of `typeParameter(...)`. When this type later flows out as a
// producer-type, downstream cmp/cast validators (`maxonTypeIsKnown`) reject
// the `named` arm because "Element" isn't a registered named type.
// Promote `named(usesParamName)` → `typeParameter(intern(IfaceName, name))`
// at the interface-result boundary so the producer-type map carries the
// real generic shape the user wrote.
function promoteInterfaceUsesParamRef(project Project, t MaxonType, interfaceName String) returns MaxonType
	let name = match t 'pick'
		named(id) gives project.typeNames.get(id)
		boolean to string gives ""
		function to opaquePointer gives ""
	end 'pick'
	if name.isEmpty() 'notNamed'
		return t
	end 'notNamed'
	let iface = try project.interfaces.get(interfaceName) otherwise return t
	for i in 0 upto iface.usesParams.count() 'scan'
		let p = try iface.usesParams.get(i) otherwise panic("promoteInterfaceUsesParamRef: usesParams.get OOB at {i} (interface={interfaceName})")
		if p == name 'hit'
			return MaxonType.typeParameter(project.typeParameters.intern(interfaceName, paramName: name))
		end 'hit'
	end 'scan'
	return t
end 'promoteInterfaceUsesParamRef'

enum InterfaceMethodLookupError implements Error
	notInterface
	methodNotFound
	voidReturn
end 'InterfaceMethodLookupError'

// Promote `Self`-shaped return types to the receiver's full
// `genericInstance(...)` shape. The parser collapses `Self` to
// `named(EnclosingType)` (it has no type-arg context at parse time);
// this helper recognises that pattern and supplies the full receiver
// shape so downstream substitution can bind the type-args. Falls back
// to `raw` when the receiver isn't a generic instance, when the names
// disagree, or when the receiver lookup didn't find a struct at all.
function promoteSelfReturnToReceiver(project Project, raw MaxonType, receiverType MaxonType, receiverStructName String) returns MaxonType
	if receiverStructName.isEmpty() 'noStruct'
		return raw
	end 'noStruct'
	return promoteNamedToGenericInstance(project, raw: raw, candidate: receiverType)
end 'promoteSelfReturnToReceiver'

// Resolve a `named(name)` MaxonType against the named struct's
// `innerAliases` map. Returns `t` unchanged when:
//   - `t` is not a named arm
//   - the receiver struct doesn't exist in `structTypes`
//   - the named id doesn't match any inner-alias key on that struct
function applyInnerAliasFromReceiver(project Project, t MaxonType, receiverStructName String) returns MaxonType
	if receiverStructName.isEmpty() 'noStruct'
		return t
	end 'noStruct'
	let st = try project.structTypes.get(receiverStructName) otherwise return applyInnerAliasFromInterfaces(project, t: t, receiverStructName: receiverStructName)
	if st.innerAliases.count() == 0 'noAliases'
		return applyInnerAliasFromInterfaces(project, t: t, receiverStructName: receiverStructName)
	end 'noAliases'
	let viaStruct = applyInnerAliasIfNamed(project, t: t, innerAliases: st.innerAliases)
	if not maxonTypesStructurallyEqual(viaStruct, b: t) 'structHit'
		return viaStruct
	end 'structHit'
	// J.4f.2: aliases declared inside `extension Iface ...` blocks land on
	// the *interface*'s innerAliases, not the conformer's. When the
	// receiver is a conformer (`Map<K,V>` for `Iterable.map` → returns
	// `ElementArray`), the per-struct lookup above misses; fall back to
	// the receiver's `implements` chain so the alias resolves via the
	// interface's body.
	return applyInnerAliasFromInterfaces(project, t: t, receiverStructName: receiverStructName)
end 'applyInnerAliasFromReceiver'

// J.4f.2: walk each interface the receiver implements and apply that
// interface's inner-aliases. The global `project.conformances` registry
// lists every recorded `(implementer, interface)` pair; for each match
// on `receiverStructName`, look up the interface's `innerAliases` map
// and try to apply it to `t`. First hit wins — alias names are
// project-wide unique within the stdlib so there's no ambiguity in
// practice. Returns `t` unchanged when no conformance hit.
function applyInnerAliasFromInterfaces(project Project, t MaxonType, receiverStructName String) returns MaxonType
	for confId in 0 upto project.conformances.typeNames.count() 'scan'
		let implementerName = try project.conformances.typeNames.get(confId) otherwise panic("applyInnerAliasFromInterfaces: typeNames.get OOB at {confId}")
		if implementerName != receiverStructName 'skip'
			continue
		end 'skip'
		let interfaceName = try project.conformances.interfaceNames.get(confId) otherwise panic("applyInnerAliasFromInterfaces: interfaceNames.get OOB at {confId}")
		let iface = try project.interfaces.get(interfaceName) otherwise continue
		if iface.innerAliases.count() == 0 'noAliases'
			continue
		end 'noAliases'
		let resolved = applyInnerAliasIfNamed(project, t: t, innerAliases: iface.innerAliases)
		if not maxonTypesStructurallyEqual(resolved, b: t) 'hit'
			return resolved
		end 'hit'
	end 'scan'
	return t
end 'applyInnerAliasFromInterfaces'

// Phase 11.0 Step 8a: normalize a receiver type by chasing per-struct inner
// typealiases (via the current method's enclosing namespace) and project-
// global generic typealiases. Lets `Self.managed` (declared as
// `ElementMemory`) flow downstream as `genericInstance(__ManagedMemory,
// [Element])` so call-site result-type lookups can find the struct.
export function normalizeReceiverInContext(project Project, t MaxonType, enclosingType String) returns MaxonType
	return match t 'norm'
		named(id) gives normalizeNamedReceiver(project, id: id, enclosingType: enclosingType)
		boolean to string gives t
		function to opaquePointer gives t
	end 'norm'
end 'normalizeReceiverInContext'

function normalizeNamedReceiver(project Project, id TypeNameId, enclosingType String) returns MaxonType
	let name = project.typeNames.get(id)
	// Per-struct inner-typealias lookup: when the named type is an inner
	// alias on the enclosing struct, use the alias's resolved MaxonType
	// (which carries the underlying generic instance).
	if not enclosingType.isEmpty() 'maybeInner'
		let st = try project.structTypes.get(enclosingType) otherwise return tryGenericTypealias(project, name: name, fallbackId: id)
		// Self-mention shortcut: a bare reference to the enclosing struct
		// itself inside a generic body means `Self`, which lowers to a
		// `genericInstance(Self, [TypeParams...])` so further substitution
		// continues to flow.
		if name == enclosingType 'isSelf'
			return synthesizeSelfReceiver(project, typeName: enclosingType)
		end 'isSelf'
		let inner = try st.innerAliases.get(name) otherwise return tryGenericTypealias(project, name: name, fallbackId: id)
		return inner
	end 'maybeInner'
	return tryGenericTypealias(project, name: name, fallbackId: id)
end 'normalizeNamedReceiver'

function tryGenericTypealias(project Project, name String, fallbackId TypeNameId) returns MaxonType
	let resolved = try project.genericTypealiases.get(name) otherwise 'noAlias'
		// When `name` is a real top-level struct/enum, treat it as that named
		// type — do NOT fall through to `tryAnyStructInnerAlias`, which would
		// pick up an arbitrary other struct's inner-alias with the same name
		// (e.g. user's `type Entry` collides with `Map.typealias Entry = (Key,Value)`).
		// Returning the named id preserves the struct identity for the
		// downstream `maxonTypeStructName` lookup.
		if project.structTypes.contains(name) or project.enumTypes.contains(name) or project.unresolvedEnums.contains(name) 'isNamed'
			return MaxonType.named(fallbackId)
		end 'isNamed'
		return tryAnyStructInnerAlias(project, name: name, fallbackId: fallbackId)
	end 'noAlias'
	return resolved
end 'tryGenericTypealias'

// Phase 11.4: a method call whose receiver is named after an inner typealias
// of some struct (e.g. `Array.innerAliases["ArrayIter"] = ArrayIterator with
// Element`) needs the alias unwrapped to the underlying generic instance so
// `maxonTypeStructName` can return the real receiver type. The lookup is
// scoped per-struct under `normalizeNamedReceiver` when the receiver is
// inside that struct's body; for receivers in user-scope code, the alias
// still has to resolve, so this helper scans every struct's `innerAliases`.
// Inner-alias names are unique across the stdlib (only `ArrayIter` declared
// in `Array`), so the first match is the correct one — no ambiguity.
//
// This is what unblocks `let arr = [1,2,3]; for n in arr` in user code:
// `arr.createIterator()` returns `ArrayIter`, and the next call
// `iter.advance()` lives in user-scope where the per-struct fast path
// can't help.
function tryAnyStructInnerAlias(project Project, name String, fallbackId TypeNameId) returns MaxonType
	for (_, st) in project.structTypes 'eachStruct'
		let resolved = try st.innerAliases.get(name) otherwise continue
		return resolved
	end 'eachStruct'
	return MaxonType.named(fallbackId)
end 'tryAnyStructInnerAlias'

// Resolve an overloaded callee at TypeResolution time. Mirrors
// `resolveOverloadedCallee` in MaxonDialect but additionally consults the
// per-function `producerTypes` map to fill in any unresolved entries in the
// stored argTypes vector. When no variant's first-param suffix matches the
// (possibly still-unresolved) first arg type, falls back to the first
// registered variant so the result-type lookup at least returns a concrete
// type — this matches the pragmatic reality that overloaded sets in the
// Maxon stdlib uniformly return the same type across variants today.
function resolveOverloadFromArgs(project Project, bareName String, args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, hasSelf bool) returns String
	let variants = try project.overloadedNames.get(bareName) otherwise return bareName
	var startIdx = 0
	if hasSelf 'skipSelf'
		startIdx = 1
	end 'skipSelf'
	if startIdx >= argTypes.count() 'zeroArg'
		let zeroArgCandidate = "{bareName}$"
		for v in variants 'scanZero'
			if v == zeroArgCandidate 'hit'
				return zeroArgCandidate
			end 'hit'
		end 'scanZero'
		return firstOverloadVariant(variants, fallback: bareName)
	end 'zeroArg'
	var firstArgType = try argTypes.get(startIdx) otherwise return bareName
	if isUnresolvedType(firstArgType) 'fillFromProducer'
		let argName = try args.get(startIdx) otherwise return firstOverloadVariant(variants, fallback: bareName)
		firstArgType = lookupProducerType(producerTypes, name: argName)
	end 'fillFromProducer'
	if isUnresolvedType(firstArgType) 'stillUnresolved'
		return firstOverloadVariant(variants, fallback: bareName)
	end 'stillUnresolved'
	let target = "{bareName}{mangleSuffixForMaxonType(project, t: firstArgType)}"
	for v in variants 'scan'
		if v == target 'hit'
			return target
		end 'hit'
	end 'scan'
	return firstOverloadVariant(variants, fallback: bareName)
end 'resolveOverloadFromArgs'

function firstOverloadVariant(variants QualifiedNameArray, fallback String) returns String
	if variants.count() == 0 'empty'
		return fallback
	end 'empty'
	return try variants.get(0) otherwise fallback
end 'firstOverloadVariant'

// Resolve a call's result type by qualifying the bare callee name and
// looking it up in funcReturnTypes. Returns MaxonType.unresolved when the
// callee isn't registered. First-param overload disambiguation kicks in
// when the qualified name is registered in `overloadedNames`.
function callResultType(project Project, callee ByteArray, callContext CallContext, currentNamespace String, readerFilePath FilePath, args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, enclosingType String) returns MaxonType
	let bareCallee = String.from(callee)
	// Math primitives are inlined to a Std unary/binary op by lowering — they
	// have no entry in funcReturnTypes, so look up their result type directly.
	if let hit = try mathIntrinsicTarget(bareCallee) 'isMath'
		return hit.resultType
	end 'isMath'
	if let binaryHit = try mathBinaryIntrinsicTarget(bareCallee) 'isMathBinary'
		return binaryHit.resultType
	end 'isMathBinary'
	// Forward enclosingType through `qualifyCalleeForContext` so a qualified
	// callee headed by an inner typealias (e.g. `MyArr.create()` where
	// `MyArr` is declared inside `Foo`) chases through the enclosing
	// struct's `innerAliases` to land on `Array.create` — the actual
	// `funcReturnTypes` key.
	let (qualifiedRaw, _) = qualifyCalleeForContextWithType(project, bare: bareCallee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, enclosingType: enclosingType)
	let qualified = resolveOverloadFromArgs(project, bareName: qualifiedRaw, args: args, argTypes: argTypes, producerTypes: producerTypes, hasSelf: false)
	let returnType = try project.funcReturnTypes.get(qualified) otherwise return MaxonType.unresolved
	return match returnType 'unwrap'
		void gives MaxonType.unresolved
		value(inner) gives inner
	end 'unwrap'
end 'callResultType'

// Resolve a fieldLoad's result type by walking the receiver's struct fields.
// Phase 11.1 step 5d/5e: when the receiver is a `genericInstance`, the
// field's stored type may be a `MaxonType.typeParameter(...)` (the field
// was declared with the type-param name like `Element`) or a
// `MaxonType.named(<innerAliasName>)` placeholder (the field was declared
// with an inner typealias like `ElementMemory` whose true resolution is
// `__ManagedMemory with Element`). We:
//   1. Resolve named-inner-alias placeholders against the struct's
//      `innerAliases` table.
//   2. Apply the receiver's type-parameter substitution if the receiver
//      is itself a `genericInstance`.
//
// Non-generic field accesses pay only the .isEmpty() check on the inner
// alias map (always empty for non-generic types) and the substitution's
// own short-circuit on isEmpty.
function fieldLoadResultType(project Project, receiverType MaxonType, fieldName ByteArray) returns MaxonType
	let structName = try maxonTypeStructName(project, t: receiverType) otherwise return MaxonType.unresolved
	// Phase 9 Stage 1: enum builtin accessors are not real struct fields —
	// they're synthesized by `lowerFieldLoad`. Pin their result types here
	// so producer-type tracking (and downstream string-interp kind inference)
	// see the right answer.
	if project.enumTypes.contains(structName) 'maybeEnumAccessor'
		let fieldNameStr = String.from(fieldName)
		if fieldNameStr == "name" 'isName'
			return MaxonType.named(project.typeNames.intern("String"))
		end 'isName'
		if fieldNameStr == "rawValue" 'isRaw'
			// Function-backed enums return a function pointer of the enum's
			// shared signature; all other backings (int/float/string/char/struct/ordinal)
			// surface as int at the producer-type level.
			let enumDef = try project.enumTypes.get(structName) otherwise return MaxonType.integer
			if enumDef.isFunctionBacked and enumDef.functionBackingTypeId != 0 'asFn'
				return MaxonType.function(enumDef.functionBackingTypeId)
			end 'asFn'
			return MaxonType.integer
		end 'isRaw'
		if fieldNameStr == "ordinal" 'isOrdinal'
			return MaxonType.integer
		end 'isOrdinal'
	end 'maybeEnumAccessor'
	let structType = try project.structTypes.get(structName) otherwise return MaxonType.unresolved
	let fieldIdx = try structType.fieldByName.get(String.from(fieldName)) otherwise return MaxonType.unresolved
	let field = try structType.fields.get(fieldIdx) otherwise return MaxonType.unresolved
	return resolveFieldTypeInContext(project, fieldType: field.fieldType, structType: structType, receiverType: receiverType)
end 'fieldLoadResultType'

// Phase 11.0 Step 8a: resolve a selfFieldLoad's result type. The implicit
// receiver is `Self`, identified by `currentNamespace` (the enclosing
// type's name set by the parser at function-decl time). For generic
// types the synthetic receiver is `genericInstance(Self, [Element, ...])`
// using the typeParameter ids the inner-alias resolution already
// produced — this lets resolveFieldTypeInContext substitute typeParam
// fields when the body later wraps them into a generic instance.
function selfFieldLoadResultType(project Project, enclosingType String, fieldName ByteArray) returns MaxonType
	if enclosingType.isEmpty() 'noSelf'
		return MaxonType.unresolved
	end 'noSelf'
	let structType = try project.structTypes.get(enclosingType) otherwise return MaxonType.unresolved
	let fieldIdx = try structType.fieldByName.get(String.from(fieldName)) otherwise return MaxonType.unresolved
	let field = try structType.fields.get(fieldIdx) otherwise return MaxonType.unresolved
	let selfRecv = synthesizeSelfReceiver(project, typeName: enclosingType)
	return resolveFieldTypeInContext(project, fieldType: field.fieldType, structType: structType, receiverType: selfRecv)
end 'selfFieldLoadResultType'

// Phase 11.0 Step 8a: derive the for-in iterator-variable's element type
// from the source's already-recorded type. For an `Iterable`-shaped source
// like `genericInstance(Array, [Element])` the element type is the
// first generic arg (Array's `Iter` arg is at index 1). For
// non-generic-instance sources we leave the binding unresolved — Step 8e
// will tighten this when interface witness-table dispatch lands.
function recordForInIterable(project Project, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, iterName String, iterSlot VarSlot, sourceValue ByteArray, sourceType MaxonType, enclosingType String)
	var resolvedSource = sourceType
	if isUnresolvedType(resolvedSource) 'fromProducer'
		resolvedSource = lookupProducerType(producerTypes, name: sourceValue)
	end 'fromProducer'
	resolvedSource = normalizeReceiverInContext(project, t: resolvedSource, enclosingType: enclosingType)
	let elementType = elementTypeForIterable(project, t: resolvedSource)
	if isUnresolvedType(elementType) 'leave'
		return
	end 'leave'
	if not iterName.isEmpty() 'bindByName'
		let iterBytes = iterName.toByteArray()
		recordResultType(producerTypes, name: iterBytes, t: elementType)
	end 'bindByName'
	slotTypes.upsert(iterSlot, value: elementType)
end 'recordForInIterable'

function elementTypeForIterable(project Project, t MaxonType) returns MaxonType
	return match t 'pick'
		genericInstance(gid) gives firstGenericArg(project, gid: gid)
		boolean to function gives MaxonType.unresolved
		unresolved gives MaxonType.unresolved
		typeParameter gives MaxonType.unresolved
		interface to opaquePointer gives MaxonType.unresolved
	end 'pick'
end 'elementTypeForIterable'

function firstGenericArg(project Project, gid GenericInstanceId) returns MaxonType
	let (_, args) = project.genericInstances.get(gid)
	return try args.get(0) otherwise MaxonType.unresolved
end 'firstGenericArg'

// Phase 11.0 Step 8a: synthesize the `Self` receiver type for a method
// body. For non-generic types this is just `MaxonType.named(typeName)`;
// for generic types we build a `genericInstance(typeName, [typeParam, ...])`
// keyed on the type's declared `usesParams` so substitution upstream
// correctly carries `typeParameter(...)` ids through the body.
export function synthesizeSelfReceiver(project Project, typeName String) returns MaxonType
	let baseId = project.typeNames.intern(typeName)
	let paramNames = project.typeParameters.getParamNames(typeName)
	if paramNames.count() == 0 'nonGeneric'
		return MaxonType.named(baseId)
	end 'nonGeneric'
	var args = MaxonTypeArray.create()
	for i in 0 upto paramNames.count() 'each'
		let pn = try paramNames.get(i) otherwise panic("synthesizeSelfReceiver: paramNames.get OOB at {i}")
		let pid = project.typeParameters.intern(typeName, paramName: pn)
		args.push(MaxonType.typeParameter(pid))
	end 'each'
	let gid = project.genericInstances.intern(baseId, args: args)
	return MaxonType.genericInstance(gid)
end 'synthesizeSelfReceiver'

// Phase 11.1 step 5d/5e: take a raw field type as recorded on the struct
// declaration and resolve it in the context of a (possibly-generic)
// receiver. Two passes:
//   1. Inner-alias substitution: if the field type names an entry in
//      `structType.innerAliases`, replace with the alias's resolved
//      MaxonType (which may itself contain type-parameter references).
//   2. Type-parameter substitution: if the receiver is a
//      `genericInstance`, build the (paramName -> concrete) substitution
//      from its args and apply through `substituteType`.
export function resolveFieldTypeInContext(project Project, fieldType MaxonType, structType StructType, receiverType MaxonType) returns MaxonType
	let aliasResolved = applyInnerAliasIfNamed(project, t: fieldType, innerAliases: structType.innerAliases)
	let subst = buildSubstitutionForInstance(project, t: receiverType)
	if subst.isEmpty() 'noSubst'
		return aliasResolved
	end 'noSubst'
	return substituteType(project, t: aliasResolved, subst: subst)
end 'resolveFieldTypeInContext'

// Phase 11.1 step 5e: when `t` is a `MaxonType.named(name)` and `name`
// matches an inner-typealias on the surrounding struct, return the
// resolved MaxonType. Otherwise pass through unchanged.
export function applyInnerAliasIfNamed(project Project, t MaxonType, innerAliases ResolvedInnerAliasMap) returns MaxonType
	if innerAliases.count() == 0 'empty'
		return t
	end 'empty'
	return match t 'check'
		named(id) gives lookupInnerAliasOrPassThrough(project, id: id, innerAliases: innerAliases)
		boolean to string gives t
		function gives t
		unresolved gives t
		typeParameter gives t
		genericInstance(gid) gives applyInnerAliasInGenericInstance(project, gid: gid, innerAliases: innerAliases)
		interface to opaquePointer gives t
	end 'check'
end 'applyInnerAliasIfNamed'

// Recurse `applyInnerAliasIfNamed` into a genericInstance's arg list so
// that paramTypes like `Iterable with (Element, ElementIterator)` — where
// `ElementIterator` is itself an inner-alias — collapse all the way to
// the underlying generic-instance form. Without this, a cast/compare
// validator that walks the args (or a downstream substitution that
// expects the args to be free of named-inner-alias placeholders) trips
// on the unresolved inner reference.
function applyInnerAliasInGenericInstance(project Project, gid GenericInstanceId, innerAliases ResolvedInnerAliasMap) returns MaxonType
	let (baseId, args) = project.genericInstances.get(gid)
	var newArgs = MaxonTypeArray.create()
	var changed = false
	for i in 0 upto args.count() 'argLoop'
		let a = try args.get(i) otherwise panic("applyInnerAliasInGenericInstance: args.get OOB at {i}")
		let na = applyInnerAliasIfNamed(project, t: a, innerAliases: innerAliases)
		if not maxonTypesStructurallyEqual(a, b: na) 'diff'
			changed = true
		end 'diff'
		newArgs.push(na)
	end 'argLoop'
	if not changed 'unchanged'
		return MaxonType.genericInstance(gid)
	end 'unchanged'
	let newGid = project.genericInstances.intern(baseId, args: newArgs)
	return MaxonType.genericInstance(newGid)
end 'applyInnerAliasInGenericInstance'

function lookupInnerAliasOrPassThrough(project Project, id TypeNameId, innerAliases ResolvedInnerAliasMap) returns MaxonType
	let name = project.typeNames.get(id)
	let resolved = try innerAliases.get(name) otherwise return MaxonType.named(id)
	return resolved
end 'lookupInnerAliasOrPassThrough'

// Phase 11.0 Step 8.7c (proper substitution): given a callee's declared
// `paramType` (read off the global FuncSignature, which may carry inner-
// alias names like `MaxonType.named("ElementMemory")` or free
// type-parameters like `MaxonType.typeParameter(Element)`), resolve it to
// the concrete shape the call site would observe — using the callee's
// enclosing struct's `innerAliases` table for the alias lookup and the
// receiver type's `genericInstance` args for the type-parameter binding.
//
// Mirrors `resolveFieldTypeInContext` but plumbs the substitution context
// through a qualifiedCallee instead of a structType handle so the
// LowerMaxonToStd pass can call this without re-resolving the callee's
// enclosing struct each time.
//
// Returns the input `paramType` unchanged when the callee isn't a method
// on a registered struct (e.g. free functions), when the receiver carries
// no generic args (non-generic struct), and the inner-alias map is empty —
// the cheap-path for non-generic call sites pays only one map lookup.
export function resolveCalleeParamTypeInContext(project Project, paramType MaxonType, calleeQualifiedName String, receiverType MaxonType) returns MaxonType
	if let enclosingType = try enclosingTypeNameForCallee(project, callee: calleeQualifiedName) 'haveEnclosing'
		// Inner-aliases may live on a struct OR an interface (when the method
		// is declared inside `extension SomeInterface`). Try the struct registry
		// first; fall back to the interface registry so `Iterable.map`'s
		// `transform ElementTransform` parameter resolves through the alias
		// declared in the Iterable extension body.
		var aliasResolved = paramType
		var didApplyAlias = false
		var enclosingIsInterface = false
		if let structType = try project.structTypes.get(enclosingType) 'isStruct'
			aliasResolved = applyInnerAliasIfNamed(project, t: paramType, innerAliases: structType.innerAliases)
			didApplyAlias = true
		end 'isStruct'
		if not didApplyAlias 'tryIface'
			if let iface = try project.interfaces.get(enclosingType) 'isIface'
				aliasResolved = applyInnerAliasIfNamed(project, t: paramType, innerAliases: iface.innerAliases)
				enclosingIsInterface = true
			end 'isIface'
		end 'tryIface'
		// For interface-method calls, the alias may carry the interface's own
		// `uses` type parameters (e.g. `function(Element) returns Element`).
		// `resolveInterfaceTypeParamsViaConformance` walks the type, rewriting
		// any interface-declared typeParameter into the conformance's withArg
		// (e.g. `Iterable.Element` → `Map`'s `(Key, Value)` tuple) before the
		// receiver-substitution pass binds the receiver's own typeParameters.
		var conformanceResolved = aliasResolved
		if enclosingIsInterface 'ifaceConformance'
			conformanceResolved = resolveInterfaceTypeParamsViaConformance(project, t: aliasResolved, receiverType: receiverType)
		end 'ifaceConformance'
		let subst = buildSubstitutionForInstance(project, t: receiverType)
		if subst.isEmpty() 'noSubst'
			return conformanceResolved
		end 'noSubst'
		return substituteType(project, t: conformanceResolved, subst: subst)
	end 'haveEnclosing'
	return paramType
end 'resolveCalleeParamTypeInContext'

// Split `Type.method` into `Type`. Method bodies are registered as
// `TypeName.methodName` (`Array.push`, `__ManagedMemory.length`, ...).
// Throws `EnclosingTypeError.notAMethod` when the callee is a free function
// (no dot) or the prefix isn't a registered type (e.g. namespace-qualified
// `stdlib.foo`); callers use `if let` to take the method-on-type path.
//
// The head is matched against structs, resolved interfaces, and not-yet-drained
// interfaces. The interface paths exist so methods declared inside an
// `extension <SomeInterface> ... end` block get their enclosing type
// resolved the same way a method declared on a struct does.
export function enclosingTypeNameForCallee(project Project, callee String) returns String throws EnclosingTypeError
	let bytes = callee.toByteArray()
	let count = bytes.count()
	let dotIdx = lastIndexOfDotByte(bytes)
	if dotIdx >= count 'noDot'
		throw EnclosingTypeError.notAMethod
	end 'noDot'
	let head = byteSliceToString(bytes, startIndex: 0, endIndex: dotIdx)
	if project.structTypes.contains(head) 'isStruct'
		return head
	end 'isStruct'
	if project.interfaces.contains(head) 'isIface'
		return head
	end 'isIface'
	if project.unresolvedInterfaces.contains(head) 'isUnresolvedIface'
		return head
	end 'isUnresolvedIface'
	throw EnclosingTypeError.notAMethod
end 'enclosingTypeNameForCallee'

export enum EnclosingTypeError implements Error
	notAMethod
end 'EnclosingTypeError'

// First-pass: walk ops per-function and record the result type of every
// value-producing op. Names of types that depend on receiver types
// (fieldLoad, methodCall) are resolved against the producer-type map being
// built — this works because Maxon IR is in execution order, so producers
// always precede consumers. Maps are per-function because parser-emitted
// synthetic names ($t0, $t1, ...) reset between functions and collide if
// pooled. slotTypes carries varDecl→slot-type so later varLoads can
// recover the concrete slot type even when the parser emitted them with
// `unresolved`.
export typealias ProducerTypeMapArray = Array with ProducerTypeMap

function buildProducerTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, slotTypesPerFunc SlotTypeMapArray)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("buildProducerTypes: funcIdx < count but get failed")
		var perFuncProducerTypes = ProducerTypeMap.create()
		var perFuncSlotTypes = SlotTypeMap.create()
		recordFuncOpResults(project, module: module, func: func, producerTypes: perFuncProducerTypes, slotTypes: perFuncSlotTypes)
		producerTypesPerFunc.push(perFuncProducerTypes)
		slotTypesPerFunc.push(perFuncSlotTypes)
	end 'eachFunc'
end 'buildProducerTypes'

function recordFuncOpResults(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, slotTypes SlotTypeMap)
	let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
	// Phase 15e: per-function side-table that tracks `(receiver -> partial
	// args)` for in-progress `__TupleN` allocations. Lives in this stack
	// frame so the partial state never leaks across function boundaries.
	var tuplePartialArgs = TuplePartialArgsMap.create()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("recordFuncOpResults: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("recordFuncOpResults: opIdx OOB")
			recordOpResult(project, producerTypes: producerTypes, slotTypes: slotTypes, tuplePartialArgs: tuplePartialArgs, currentNamespace: func.namespace, enclosingType: enclosingType, readerFilePath: func.sourceFilePath, funcName: func.name, op: op)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			let termIdx = block.terminatorIndex()
			let termOp = try module.ops.get(termIdx) otherwise panic("recordFuncOpResults: terminator OOB")
			recordOpResult(project, producerTypes: producerTypes, slotTypes: slotTypes, tuplePartialArgs: tuplePartialArgs, currentNamespace: func.namespace, enclosingType: enclosingType, readerFilePath: func.sourceFilePath, funcName: func.name, op: termOp)
		end 'hasTerm'
	end 'eachBlock'
end 'recordFuncOpResults'

// Phase 7: stringConst / stringInterp produce a real `String` struct value
// once stdlib/String.maxon is whitelisted. When that struct is registered,
// return its named-type form; otherwise fall back to the legacy
// `MaxonType.string` primitive tag so pre-Phase-7 code paths still work.
function stringConstResultType(project Project) returns MaxonType
	let stringId = project.typeNames.intern("String")
	if project.structTypes.contains("String") or project.unresolvedStructTypes.contains("String") 'haveStruct'
		return MaxonType.named(stringId)
	end 'haveStruct'
	return MaxonType.string
end 'stringConstResultType'

// Phase 7: a `b"..."` byte-string literal lowers to an `Array with byte`
// wrapper around a __ManagedMemory whose element_size is 1. The result
// type is the bound generic instance — bare `MaxonType.named("Array")`
// would leave subsequent method calls (`bytes.count()`, `bytes.get(i)`)
// without the layout binding lowering's `materializeLayoutArg` requires
// for implicit-layout-arg generic methods. Element type is
// `MaxonType.integer` because Maxon's source-level type system has a
// single integer arm; byte-ness is conveyed at the StdDialect level
// (i8/u8) via the consuming typealias, not the MaxonType encoding.
// Exported so `LowerMaxonToStd.lowerByteStringLiteral` can pin the
// per-function value-type map to the identical gid the resolver wrote.
export function byteStringLiteralResultType(project Project) returns MaxonType
	return internSingleArgGenericInstance(project, baseTypeName: "Array", elementType: MaxonType.integer)
end 'byteStringLiteralResultType'

// Resolve a `call`/`tryCall` op's result type, with a special case for
// the two ops the parser emits for an array literal
// (`__ManagedMemory.create` for `__mm` and `<arrayTypeName>.init` for
// `__arr`). For both, the regular `callResultType` path lacks the
// generic-instance Element binding the literal carries implicitly
// through its element value names; substituting the binding here keeps
// the parser out of the type system while still letting the downstream
// `__mm.set(...)` and `arr.get(...)` resolutions find the concrete
// element type. Map literals follow the same pattern but bind two type
// args (Key, Value); the dictionary-shape lookup runs first because a
// map's init-call result is keyed in `mapLiteralProducers`, which the
// `arrayLiteralProducers` lookup wouldn't find. Falls through to
// `callResultType` for every call whose result name isn't tracked in
// either map.
function callOrArrayLiteralResultType(project Project, funcName String, name ByteArray, callee ByteArray, callContext CallContext, currentNamespace String, readerFilePath FilePath, args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, enclosingType String) returns MaxonType
	let pinnedMap = mapLiteralResultType(project, funcName: funcName, name: name, producerTypes: producerTypes)
	if not isUnresolvedType(pinnedMap) 'gotMapPin'
		return pinnedMap
	end 'gotMapPin'
	let pinned = arrayLiteralResultType(project, funcName: funcName, name: name, producerTypes: producerTypes)
	if not isUnresolvedType(pinned) 'gotPin'
		return pinned
	end 'gotPin'
	let raw = callResultType(project, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, args: args, argTypes: argTypes, producerTypes: producerTypes, enclosingType: enclosingType)
	// Static factories like `IntArray.create()` register their return as
	// `named(Array)` (the parser collapses `Self` to the enclosing
	// type's bare name). When the call's qualified head was a generic
	// typealias (`IntArray` → `Array with Integer`), promote the bare
	// name to the resolved generic instance using the receiver type
	// recorded by `resolveAllCalls`. Without this, the variable bound
	// to the call result drops to `named(Array)` and downstream
	// methodCalls can't recover the layout-arg binding.
	let refined = refineStaticReturnFromQualifiedCallee(project, returnType: raw, callee: callee, callContext: callContext, enclosingType: enclosingType)
	// Generic inference for static factories that take a bound arg whose
	// type pins the enclosing struct's type parameters — `Set from [1,2,3]`
	// emits `Set.init(arr)` where the arg's type is
	// `genericInstance(Array, [Int])` and `Set.init`'s signature param is
	// `Array with Element`. Unify (param, arg) pairs to recover
	// `Element = Int`, then build `genericInstance(Set, [Int])` for the
	// call's result type. Lets `parseFromLiteralCall`-emitted callsites
	// reach lowering with a concrete receiver context instead of the bare
	// `named(Set)` that would trip `forwardCallerLayout`.
	return inferGenericReturnFromArgs(project, returnType: refined, callee: callee, callContext: callContext, args: args, argTypes: argTypes, producerTypes: producerTypes)
end 'callOrArrayLiteralResultType'

// Promote a static-method return type from `named(X)` to
// `genericInstance(X, [...])` when the qualified callee's head was a
// generic typealias. Reads the resolved receiver type via
// `chaseTypealiasInQualifiedCalleeWithType`, which is the same lookup
// `resolveAllCalls` does — so this stays consistent with the
// receiverContext that lowering threads to the call site.
function refineStaticReturnFromQualifiedCallee(project Project, returnType MaxonType, callee ByteArray, callContext CallContext, enclosingType String) returns MaxonType
	if not isQualifiedCallContext(callContext) 'notQualified'
		return returnType
	end 'notQualified'
	let bareCallee = String.from(callee)
	// Forward the caller's enclosingType so an inner typealias declared on
	// the enclosing struct (e.g. `Foo.typealias MyArr = Array with String`,
	// referenced inside `Foo.makeArr` as `MyArr.create()`) chases through
	// the per-struct innerAliases map. Empty for free functions.
	let (_, receiverType) = chaseTypealiasInQualifiedCalleeWithType(project, callee: bareCallee, enclosingType: enclosingType)
	return promoteNamedToGenericInstance(project, raw: returnType, candidate: receiverType)
end 'refineStaticReturnFromQualifiedCallee'

// Infer generic type-parameter bindings for a static-factory call `T.init(args)`
// (or any `T.method` returning `Self`) by unifying the callee's declared
// signature param types against the actual arg types. When the return type
// is still `named(T)` (because the chase didn't recover bindings from a
// typealias head) and T declares `uses Param1, ...`, walk the (param, arg)
// pairs and accumulate bindings for any `typeParameter(T.Param_i)` slot
// reachable inside a `genericInstance` param shape. If a complete binding
// is recovered, return `genericInstance(T, [bound...])`; otherwise return
// the input unchanged. Mirrors what the `from-literal` parser would have
// done if it had access to the callee's signature at parse time.
function inferGenericReturnFromArgs(project Project, returnType MaxonType, callee ByteArray, callContext CallContext, args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap) returns MaxonType
	if not isQualifiedCallContext(callContext) 'notQualified'
		return returnType
	end 'notQualified'
	if not maxonTypeIsNamed(returnType) 'notBareNamed'
		return returnType
	end 'notBareNamed'
	let typeName = returnType.nameOrEmpty(project)
	if typeName.isEmpty() 'noName'
		return returnType
	end 'noName'
	let paramNames = project.typeParameters.getParamNames(typeName)
	if paramNames.count() == 0 'notGeneric'
		return returnType
	end 'notGeneric'
	let signature = try project.funcSignatures.get(String.from(callee)) otherwise return returnType
	let subst = inferSubstitutionFromCallArgs(project, declaringTypeName: typeName, signature: signature, args: args, argTypes: argTypes, producerTypes: producerTypes)
	if subst.count() != paramNames.count() 'incomplete'
		return returnType
	end 'incomplete'
	var instanceArgs = MaxonTypeArray.create()
	for i in 0 upto paramNames.count() 'collect'
		let pname = try paramNames.get(i) otherwise panic("inferGenericReturnFromArgs: paramNames.get OOB at {i}")
		let pid = project.typeParameters.intern(typeName, paramName: pname)
		instanceArgs.push(subst.lookup(pid))
	end 'collect'
	let baseId = project.typeNames.intern(typeName)
	let gid = project.genericInstances.intern(baseId, args: instanceArgs)
	return MaxonType.genericInstance(gid)
end 'inferGenericReturnFromArgs'

// Walk the callee's signature against the call's argument types and
// produce a substitution binding each `typeParameter(declaringTypeName.X)`
// it encounters to the actual concrete type observed in the matching arg
// slot. Used by `inferGenericReturnFromArgs` to recover type parameters
// when the return type is `named(T)` and T's type-parameter slots only
// appear inside the parameter types. The signature's leading `__self`
// slot (if any) is skipped so user-arg indices align with `args`.
function inferSubstitutionFromCallArgs(project Project, declaringTypeName String, signature FuncSignature, args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap) returns TypeSubstitution
	var subst = TypeSubstitution.create()
	// Inner typealias resolution: `Set.init`'s `arr ElementArray` registers
	// its paramType as `named(ElementArray)`, the inner-alias placeholder.
	// Resolve through the enclosing struct's innerAliases so unification
	// sees the real `genericInstance(Array, [typeParameter(Element)])` shape.
	var innerAliases = ResolvedInnerAliasMap.create()
	if let st = try project.structTypes.get(declaringTypeName) 'haveStruct'
		innerAliases = st.innerAliases
	end 'haveStruct'
	var startIdx = 0
	if signature.paramNames.count() > 0 'maybeSelf'
		let firstName = try signature.paramNames.get(0) otherwise ""
		if firstName == "__self" 'isSelf'
			startIdx = 1
		end 'isSelf'
	end 'maybeSelf'
	let userParamCount = signature.paramTypes.count() - startIdx
	let argCount = argTypes.count()
	var limit = userParamCount
	if argCount < limit 'pickFewer'
		limit = argCount
	end 'pickFewer'
	for i in 0 upto limit 'unifyLoop'
		let rawParamType = try signature.paramTypes.get(i + startIdx) otherwise panic("inferSubstitutionFromCallArgs: paramTypes.get OOB at {i + startIdx}")
		let paramType = applyInnerAliasIfNamed(project, t: rawParamType, innerAliases: innerAliases)
		var argType = try argTypes.get(i) otherwise panic("inferSubstitutionFromCallArgs: argTypes.get OOB at {i}")
		if isUnresolvedType(argType) 'fallback'
			let argName = try args.get(i) otherwise ByteArray.create()
			if argName.count() > 0 'haveName'
				argType = lookupProducerType(producerTypes, name: argName)
			end 'haveName'
		end 'fallback'
		unifyParamWithArg(project, declaringTypeName: declaringTypeName, paramType: paramType, argType: argType, subst: subst)
	end 'unifyLoop'
	return subst
end 'inferSubstitutionFromCallArgs'

// One-step structural unification of a callee param type against an
// actual arg type, accumulating `typeParameter(declaringTypeName.X)`
// bindings into `subst`. Recurses through `genericInstance` arg lists
// when the base ids match. A binding is only added on the first sighting
// of each type-parameter id — duplicate slots that disagree are silently
// ignored (the caller's substitution-count check downstream catches
// incomplete unifications). Non-typeParameter param arms with mismatched
// arg shapes are dropped without error: this routine is best-effort
// inference, not constraint validation.
function unifyParamWithArg(project Project, declaringTypeName String, paramType MaxonType, argType MaxonType, subst TypeSubstitution)
	match paramType 'paramShape'
		typeParameter(pid) then unifyBindParam(project, declaringTypeName: declaringTypeName, pid: pid, argType: argType, subst: subst)
		genericInstance(pgid) then unifyGenericInstance(project, declaringTypeName: declaringTypeName, paramGid: pgid, argType: argType, subst: subst)
		boolean to string then return
		named then return
		function then return
		unresolved then return
		interface to opaquePointer then return
	end 'paramShape'
end 'unifyParamWithArg'

function unifyBindParam(project Project, declaringTypeName String, pid TypeParamId, argType MaxonType, subst TypeSubstitution)
	if isUnresolvedType(argType) 'noBind'
		return
	end 'noBind'
	// Only bind type-parameters declared on the enclosing struct; the
	// signature may also reference type-parameters from outer scopes
	// (interface usesParams, where-clause forwards) that shouldn't
	// contribute to this struct's instantiation.
	let ownerName = project.typeParameters.getOwner(pid)
	if ownerName != declaringTypeName 'foreign'
		return
	end 'foreign'
	if not isUnresolvedType(subst.lookup(pid)) 'alreadyBound'
		return
	end 'alreadyBound'
	subst.bind(pid, concrete: argType)
end 'unifyBindParam'

function unifyGenericInstance(project Project, declaringTypeName String, paramGid GenericInstanceId, argType MaxonType, subst TypeSubstitution)
	match argType 'argShape'
		genericInstance(argGid) then unifyGenericInstanceArgs(project, declaringTypeName: declaringTypeName, paramGid: paramGid, argGid: argGid, subst: subst)
		boolean to string then return
		named then return
		function then return
		unresolved then return
		typeParameter then return
		interface to opaquePointer then return
	end 'argShape'
end 'unifyGenericInstance'

function unifyGenericInstanceArgs(project Project, declaringTypeName String, paramGid GenericInstanceId, argGid GenericInstanceId, subst TypeSubstitution)
	let (paramBaseId, paramArgs) = project.genericInstances.get(paramGid)
	let (argBaseId, argArgs) = project.genericInstances.get(argGid)
	if paramBaseId != argBaseId 'differentBase'
		return
	end 'differentBase'
	var limit = paramArgs.count()
	if argArgs.count() < limit 'pickFewer'
		limit = argArgs.count()
	end 'pickFewer'
	for i in 0 upto limit 'eachArg'
		let p = try paramArgs.get(i) otherwise panic("unifyGenericInstanceArgs: paramArgs.get OOB at {i}")
		let a = try argArgs.get(i) otherwise panic("unifyGenericInstanceArgs: argArgs.get OOB at {i}")
		unifyParamWithArg(project, declaringTypeName: declaringTypeName, paramType: p, argType: a, subst: subst)
	end 'eachArg'
end 'unifyGenericInstanceArgs'

// Look up the array-literal entry under `(funcName, name)` and, if found,
// return the matching `genericInstance(...)` shape. The parser writes the
// same entry under both `mmName` and `arrName` keys, so this single O(1)
// lookup serves both the `__ManagedMemory.create` and `<arrayType>.init`
// callsites. Returns `unresolved` when:
//   - no entry exists for `(funcName, name)` — not an array-literal call
//   - the literal is empty
//   - elements unified to no concrete type yet (every elem still
//     `unresolved` at this walk)
//   - elements disagreed on a concrete type (E3005 reported here)
function arrayLiteralResultType(project Project, funcName String, name ByteArray, producerTypes ProducerTypeMap) returns MaxonType
	let key = arrayLiteralProducerKey(funcName, valueName: name)
	let entry = try project.arrayLiteralProducers.get(key) otherwise return MaxonType.unresolved
	let element = unifyArrayLiteralElementTypes(project, entry: entry, producerTypes: producerTypes)
	if isUnresolvedType(element) 'noUnify'
		return MaxonType.unresolved
	end 'noUnify'
	let baseTypeName = arrayLiteralBaseTypeName(entry, name: name)
	return internSingleArgGenericInstance(project, baseTypeName: baseTypeName, elementType: element)
end 'arrayLiteralResultType'

// Pick the genericInstance base type name for an array-literal entry: the
// `__mm` slot pins `__ManagedMemory`, the `__arr` slot pins the literal's
// chosen array type. The parser inserts the entry under exactly two keys
// (mmResultName and initResultName), so any other `name` here is a
// stale-key bug — panic rather than silently picking a default.
function arrayLiteralBaseTypeName(entry ArrayLiteralProducer, name ByteArray) returns String
	if entry.initResultName == name 'isInit'
		return entry.arrayTypeName
	end 'isInit'
	if entry.mmResultName == name 'isCreate'
		return "__ManagedMemory"
	end 'isCreate'
	panic("arrayLiteralBaseTypeName: name {String.from(name)} matches neither mmResultName ({String.from(entry.mmResultName)}) nor initResultName ({String.from(entry.initResultName)})")
end 'arrayLiteralBaseTypeName'

// Walk an array literal's element value names and unify their
// already-recorded producer types into a single concrete element type.
// Mirrors the typed-element unification rules: `unresolved` elements
// are skipped (TypeResolution may revisit later, by which point the
// element will have a concrete type or a different value-shape will
// have surfaced the gap), and a real disagreement reports E3005 on the
// offending element using the parser-recorded source range. The entry's
// `errorReported` flag latches on the first report so the second
// resolution pass (the `<arrayType>.init` callsite resolving the same
// shared entry as the earlier `__ManagedMemory.create`) doesn't re-fire
// the diagnostic. Returns `unresolved` for empty literals and after
// reporting an error.
function unifyArrayLiteralElementTypes(project Project, entry ArrayLiteralProducer, producerTypes ProducerTypeMap) returns MaxonType
	var unified = MaxonType.unresolved
	for i in 0 upto entry.elemNames.count() 'walk'
		let elemName = try entry.elemNames.get(i) otherwise panic("unifyArrayLiteralElementTypes: elemNames.get OOB at {i}")
		let t = lookupProducerType(producerTypes, name: elemName)
		if isUnresolvedType(t) 'skipUnresolved'
			continue
		end 'skipUnresolved'
		if isUnresolvedType(unified) 'firstConcrete'
			unified = t
			continue
		end 'firstConcrete'
		if not maxonTypesStructurallyEqual(unified, b: t) 'mismatch'
			if not entry.errorReported 'firstReport'
				let expectedName = unified.toString(project)
				let gotName = t.toString(project)
				let mismatchRange = try entry.elemRanges.get(i) otherwise panic("unifyArrayLiteralElementTypes: elemRanges.get OOB at {i}")
				reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "array literal: element {i} type '{gotName}' does not match unified element type '{expectedName}'", line: mismatchRange.line, column: mismatchRange.column, filePath: entry.sourceFilePath)
				entry.errorReported = true
			end 'firstReport'
			return MaxonType.unresolved
		end 'mismatch'
	end 'walk'
	return unified
end 'unifyArrayLiteralElementTypes'

// Build (or look up) `genericInstance(<baseTypeName>, [elementType])`.
// Both array-literal sites pin a single-arg shape so the helper stays
// specialised; widening to N args would only add a `MaxonTypeArray`
// parameter that no existing caller needs.
function internSingleArgGenericInstance(project Project, baseTypeName String, elementType MaxonType) returns MaxonType
	let baseId = project.typeNames.intern(baseTypeName)
	var giArgs = MaxonTypeArray.create()
	giArgs.push(elementType)
	let giId = project.genericInstances.intern(baseId, args: giArgs)
	return MaxonType.genericInstance(giId)
end 'internSingleArgGenericInstance'

// Build (or look up) `genericInstance(<baseTypeName>, [keyType, valueType])`.
// Map-literal-shaped counterpart to `internSingleArgGenericInstance`.
function internTwoArgGenericInstance(project Project, baseTypeName String, keyType MaxonType, valueType MaxonType) returns MaxonType
	let baseId = project.typeNames.intern(baseTypeName)
	var giArgs = MaxonTypeArray.create()
	giArgs.push(keyType)
	giArgs.push(valueType)
	let giId = project.genericInstances.intern(baseId, args: giArgs)
	return MaxonType.genericInstance(giId)
end 'internTwoArgGenericInstance'

// Mirror of `arrayLiteralResultType` for map literals. The parser only
// keys map-literal entries under the init-call result name (the two
// per-axis __mm allocations are resolved through their own
// arrayLiteralProducers entries), so a single-key lookup suffices. Both
// axes' element types must unify before we can pin a concrete
// `genericInstance(<mapType>, [Key, Value])` — if either is still
// `unresolved`, the caller falls through to `callResultType` and a
// later resolution pass retries.
function mapLiteralResultType(project Project, funcName String, name ByteArray, producerTypes ProducerTypeMap) returns MaxonType
	let key = mapLiteralProducerKey(funcName, valueName: name)
	let entry = try project.mapLiteralProducers.get(key) otherwise return MaxonType.unresolved
	let keyType = unifyMapLiteralAxisFromProducer(project, funcName: funcName, mmResultName: entry.keyMmResultName, producerTypes: producerTypes)
	if isUnresolvedType(keyType) 'noKey'
		return MaxonType.unresolved
	end 'noKey'
	let valueType = unifyMapLiteralAxisFromProducer(project, funcName: funcName, mmResultName: entry.valueMmResultName, producerTypes: producerTypes)
	if isUnresolvedType(valueType) 'noVal'
		return MaxonType.unresolved
	end 'noVal'
	return internTwoArgGenericInstance(project, baseTypeName: entry.mapTypeName, keyType: keyType, valueType: valueType)
end 'mapLiteralResultType'

// Resolve a single map-literal axis's element type by deferring to the
// already-registered `arrayLiteralProducers` entry keyed under the
// axis's `__mm` result name. Returns `unresolved` when the entry is
// missing or its elements haven't unified yet.
function unifyMapLiteralAxisFromProducer(project Project, funcName String, mmResultName ByteArray, producerTypes ProducerTypeMap) returns MaxonType
	let key = arrayLiteralProducerKey(funcName, valueName: mmResultName)
	let entry = try project.arrayLiteralProducers.get(key) otherwise return MaxonType.unresolved
	return unifyArrayLiteralElementTypes(project, entry: entry, producerTypes: producerTypes)
end 'unifyMapLiteralAxisFromProducer'

// Compose the `mapLiteralProducers` key. Mirrors `arrayLiteralProducerKey`:
// the composite `(funcName, valueName)` keeps per-function
// `freshSynthName` resets from colliding across functions.
export function mapLiteralProducerKey(funcName String, valueName ByteArray) returns String
	return "{funcName}|{String.from(valueName)}"
end 'mapLiteralProducerKey'

// Compose the `arrayLiteralProducers` key. Same shape used at the parser
// site (writer) and the TypeResolution site (reader); centralised so the
// byte representation can change without scattering touch-ups. Top-level
// so both modules can call it without dragging in extra state. The
// parser inserts each literal's entry under both its `mmName` and
// `arrName`, so callsites pass whichever is the IR result name they're
// resolving — both keys map to the same entry.
export function arrayLiteralProducerKey(funcName String, valueName ByteArray) returns String
	return "{funcName}|{String.from(valueName)}"
end 'arrayLiteralProducerKey'

enum ArrayLiteralLookupError implements Error
	notFound
	cannotUnify
end 'ArrayLiteralLookupError'

// Look up an array-literal entry by the (funcName, valueName) it was
// keyed under at the parser site. Used by the top-level pre-resolve and
// backfill passes once they've routed iteration through the owning
// init function so the funcName is known. A bare-name lookup is a bug:
// `freshSynthName`'s per-function counter resets, so two init funcs
// in a batched compile can mint the same `$tN` for unrelated literals,
// and a name-only sweep would return the first hit (whose elements
// belong to a *different* literal entirely — for non-int element
// types this then ripples into a wrong `genericInstance` slot type).
function lookupArrayLiteralProducer(project Project, funcName String, name ByteArray) returns ArrayLiteralProducer throws ArrayLiteralLookupError
	return try project.arrayLiteralProducers.get(arrayLiteralProducerKey(funcName, valueName: name)) otherwise throw ArrayLiteralLookupError.notFound
end 'lookupArrayLiteralProducer'

// Map-literal counterpart of `lookupArrayLiteralProducer`. Map literals are
// keyed only under their init-call result name (the per-axis __mm
// allocations live in `arrayLiteralProducers`), so a single-name lookup
// suffices.
function lookupMapLiteralProducer(project Project, funcName String, name ByteArray) returns MapLiteralProducer throws ArrayLiteralLookupError
	return try project.mapLiteralProducers.get(mapLiteralProducerKey(funcName, valueName: name)) otherwise throw ArrayLiteralLookupError.notFound
end 'lookupMapLiteralProducer'

// Mirror of `unifyArrayLiteralElementsFromModule` for map literals: read
// the unified element types of each axis via that helper (each axis is
// registered as an ArrayLiteralProducer under its `__mm` name) and pin a
// `genericInstance(<mapType>, [Key, Value])` shape when both axes resolve.
function unifyMapLiteralFromModule(project Project, module MaxonModule, func IrFunction, entry MapLiteralProducer) returns MaxonType throws ArrayLiteralLookupError
	let keyEntry = try project.arrayLiteralProducers.get(arrayLiteralProducerKey(func.name, valueName: entry.keyMmResultName)) otherwise throw ArrayLiteralLookupError.notFound
	let valueEntry = try project.arrayLiteralProducers.get(arrayLiteralProducerKey(func.name, valueName: entry.valueMmResultName)) otherwise throw ArrayLiteralLookupError.notFound
	let keyType = try unifyArrayLiteralElementsFromModule(project, module: module, func: func, entry: keyEntry)
	let valueType = try unifyArrayLiteralElementsFromModule(project, module: module, func: func, entry: valueEntry)
	return internTwoArgGenericInstance(project, baseTypeName: entry.mapTypeName, keyType: keyType, valueType: valueType)
end 'unifyMapLiteralFromModule'

// Unify an array literal's element types by walking the module ops
// directly — used when the regular per-function producer-type map
// hasn't been built yet (the pre-resolve pass that runs before
// rewriteUnresolvedOpsPerFunction). Each elemName must resolve to a
// statically-typed op (literal / stringConst / charLiteral /
// byteStringLiteral); falls through to `cannotUnify` when any element
// produces from a more-complex shape (call, methodCall, varLoad of an
// untyped slot, ...) — those literals will be re-tried by the post-
// fillUnresolvedTypes backfill, which has full producerTypes available.
function unifyArrayLiteralElementsFromModule(project Project, module MaxonModule, func IrFunction, entry ArrayLiteralProducer) returns MaxonType throws ArrayLiteralLookupError
	var unified = MaxonType.unresolved
	for i in 0 upto entry.elemNames.count() 'walk'
		let elemName = try entry.elemNames.get(i) otherwise panic("unifyArrayLiteralElementsFromModule: elemNames.get OOB at {i}")
		let t = try staticTypeOfValueInFunction(project, module: module, func: func, name: elemName) otherwise throw ArrayLiteralLookupError.cannotUnify
		if isUnresolvedType(unified) 'firstConcrete'
			unified = t
			continue
		end 'firstConcrete'
		if not maxonTypesStructurallyEqual(unified, b: t) 'mismatch'
			throw ArrayLiteralLookupError.cannotUnify
		end 'mismatch'
	end 'walk'
	if isUnresolvedType(unified) 'allUnresolved'
		throw ArrayLiteralLookupError.cannotUnify
	end 'allUnresolved'
	return unified
end 'unifyArrayLiteralElementsFromModule'

// Type a value name by finding its defining op in `func`'s blocks and
// reading the type the parser already stamped on the op (literal
// valueType, stringConst → String, etc.). Scans only `func`'s ops
// because `freshSynthName`'s per-function counter resets between
// functions: a flat module.ops walk would match a same-named op in an
// unrelated user function (e.g. `helper`'s `$t21` int literal vs.
// `__module_init_0`'s `$t21` "bob" string), and silently mistype the
// element. Throws `notFound` for any value whose defining op is
// something this pre-resolve helper doesn't statically recognise —
// call sites bail with `cannotUnify` and let the later
// producer-type-aware pass do the work.
function staticTypeOfValueInFunction(project Project, module MaxonModule, func IrFunction, name ByteArray) returns MaxonType throws ArrayLiteralLookupError
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("staticTypeOfValueInFunction: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("staticTypeOfValueInFunction: opIdx OOB at {opIdx}")
			if let t = try staticTypeFromOpIfMatches(project, op: op, name: name) 'hit'
				return t
			end 'hit'
		end 'eachOp'
	end 'eachBlock'
	throw ArrayLiteralLookupError.notFound
end 'staticTypeOfValueInFunction'

// Throws `notFound` when `op` doesn't define `name`, or when `op`'s shape
// isn't one of the four parser-typed-on-emission shapes this helper
// statically recognises (literal / stringConst / charLiteral /
// byteStringLiteral). Caller sweeps every op in the module and stops at
// the first hit; anything else makes the caller fall back to the
// post-fillUnresolvedTypes backfill.
function staticTypeFromOpIfMatches(project Project, op MaxonOp, name ByteArray) returns MaxonType throws ArrayLiteralLookupError
	match op 'pick'
		literal(result, _, valueType, _) then return try staticTypedResult(name, result: result, t: valueType)
		stringConst(result, _, _) then return try staticTypedResult(name, result: result, t: stringConstResultType(project))
		charLiteral(result, _, _) then return try staticTypedResult(name, result: result, t: MaxonType.named(project.typeNames.intern("Character")))
		byteStringLiteral(result, _, _) then return try staticTypedResult(name, result: result, t: byteStringLiteralResultType(project))
		stringInterp to forInIterable then throw ArrayLiteralLookupError.notFound
	end 'pick'
end 'staticTypeFromOpIfMatches'

// Returns `t` when `result == name`, otherwise throws `notFound`.
// Folded out of the four `staticTypeFromOpIfMatches` arms so the per-arm
// `try ... otherwise throw` boilerplate doesn't repeat at each callsite.
function staticTypedResult(name ByteArray, result ByteArray, t MaxonType) returns MaxonType throws ArrayLiteralLookupError
	if result == name 'hit'
		return t
	end 'hit'
	throw ArrayLiteralLookupError.notFound
end 'staticTypedResult'

// Derive a binop's result type, falling back to its operands' recorded
// producer types when the parser left `operandType` as unresolved. This
// happens whenever a binop's operand is itself the result of an earlier op
// (typically a `call` or another `binop`) whose type the parser couldn't
// see at parse time. Without the fallback, downstream consumers of the
// binop's result observe `unresolved` and `fillBinop` can't recover the
// operandType either.
function deriveBinopResultType(producerTypes ProducerTypeMap, operandType MaxonType, left ByteArray, right ByteArray) returns MaxonType
	if not isUnresolvedType(operandType) 'concrete'
		return operandType
	end 'concrete'
	let leftT = lookupProducerType(producerTypes, name: left)
	if not isUnresolvedType(leftT) 'fromLeft'
		return leftT
	end 'fromLeft'
	return lookupProducerType(producerTypes, name: right)
end 'deriveBinopResultType'

// Mirror of `deriveBinopResultType` for the single-operand case.
function deriveUnopResultType(producerTypes ProducerTypeMap, operandType MaxonType, operand ByteArray) returns MaxonType
	if not isUnresolvedType(operandType) 'concrete'
		return operandType
	end 'concrete'
	return lookupProducerType(producerTypes, name: operand)
end 'deriveUnopResultType'

typealias TuplePartialArgsMap = Map with (ByteArray, MaxonTypeArray)

// Phase 15e: track tuple-allocation field stores by collecting the value type
// for each `_N` field via a per-function `tuplePartialArgs` side-table. The
// staged partial args stay private to this pass (they never reach
// project.genericInstances), so BuildWitnessTables doesn't see half-resolved
// __TupleN gids. Once every slot is filled with a concrete arg type, the
// receiver's producer-type is upgraded from `MaxonType.named("__TupleN")` to
// `MaxonType.genericInstance(__TupleN, [T0..TN])` and the side-table entry is
// dropped.
function refineTupleStructAlloc(project Project, producerTypes ProducerTypeMap, tuplePartialArgs TuplePartialArgsMap, currentNamespace String, receiver ByteArray, fieldName ByteArray, value ByteArray)
	// Phase 15e: only refine inside the user pipeline. Stdlib functions go
	// through this same TypeResolution pass during cache build, and any new
	// genericInstance entry interned here gets serialised to disk. On cache
	// hit, those entries are recreated via `readMaxonGenericInstance` (which
	// re-interns through structural identity). If the user-pipeline run
	// doesn't observe the same tuple shapes during stdlib re-compile (which
	// it can't — the cache hit short-circuits that work), captured
	// layoutDescriptor / witnessTable gids would dangle. Keep refinement
	// scoped to non-stdlib code so the stdlib cache stays deterministic.
	if isStdlibNamespace(currentNamespace) 'isStdlib'
		return
	end 'isStdlib'
	let receiverType = lookupProducerType(producerTypes, name: receiver)
	let receiverName = match receiverType 'extractBase'
		named(id) gives project.typeNames.get(id)
		boolean to string gives ""
		function to opaquePointer gives ""
	end 'extractBase'
	if not isTupleStructName(receiverName) 'notTuple'
		return
	end 'notTuple'
	let fieldIdx = try tupleFieldIndex(fieldName) otherwise return
	let arity = tupleStructArity(receiverName)
	if fieldIdx >= arity 'oob'
		return
	end 'oob'
	let valueType = lookupProducerType(producerTypes, name: value)
	if not isConcreteTupleArgType(valueType) 'notConcrete'
		// Generic-context tuples (stdlib's `(k, v)` where k/v are type
		// parameters, or values whose type hasn't been resolved yet) stay
		// `MaxonType.named("__TupleN")`. Introducing a generic-instance entry
		// with `typeParameter` / `unresolved` args would feed BuildWitnessTables
		// a non-conditional gid that lowering can't synthesize a witness for.
		return
	end 'notConcrete'
	var args = cloneTupleArgs(try tuplePartialArgs.get(receiver) otherwise seedTupleArgs(arity))
	try args.set(fieldIdx, value: valueType) otherwise return
	if not allConcreteTupleArgs(args) 'incomplete'
		tuplePartialArgs.upsert(receiver, value: args)
		return
	end 'incomplete'
	_ = tuplePartialArgs.remove(receiver)
	let baseId = project.typeNames.intern(receiverName)
	let newGid = project.genericInstances.intern(baseId, args: args)
	recordResultType(producerTypes, name: receiver, t: MaxonType.genericInstance(newGid))
end 'refineTupleStructAlloc'

function seedTupleArgs(arity TupleArity) returns MaxonTypeArray
	var seeded = MaxonTypeArray.create()
	for _ in 0 upto arity 'seed'
		seeded.push(MaxonType.unresolved)
	end 'seed'
	return seeded
end 'seedTupleArgs'

// Deep-copy a stored arg list before mutating it so the borrow-checker doesn't
// flag the subsequent `upsert` on the side-table.
function cloneTupleArgs(src MaxonTypeArray) returns MaxonTypeArray
	var copy = MaxonTypeArray.create()
	for i in 0 upto src.count() 'each'
		let a = try src.get(i) otherwise MaxonType.unresolved
		copy.push(a)
	end 'each'
	return copy
end 'cloneTupleArgs'

function isConcreteTupleArgType(t MaxonType) returns bool
	return match t 'check'
		boolean to string gives true
		named gives true
		function gives true
		genericInstance gives true
		interface gives true
		unresolved gives false
		typeParameter gives false
		constInt to opaquePointer gives true
	end 'check'
end 'isConcreteTupleArgType'

function allConcreteTupleArgs(args MaxonTypeArray) returns bool
	for i in 0 upto args.count() 'each'
		let a = try args.get(i) otherwise return false
		if not isConcreteTupleArgType(a) 'notConcrete'
			return false
		end 'notConcrete'
	end 'each'
	return true
end 'allConcreteTupleArgs'

// `__TupleN` where N is a digit string (2 or 3 today; future arities follow the
// same shape). Mirrors the parser's `parseParenExpr` tuple-literal emission.
function isTupleStructName(name String) returns bool
	if not name.startsWith("__Tuple") 'noPrefix'
		return false
	end 'noPrefix'
	return tupleStructArity(name) >= 2
end 'isTupleStructName'

typealias TupleArity = int(0 to u64.max)
typealias TupleFieldOrdinal = int(0 to u64.max)

enum TupleFieldNameError implements Error
	notTupleField
end 'TupleFieldNameError'

// Lookup-table approach: tuple arity is bounded by what the parser emits
// (today `__Tuple2`, `__Tuple3`; expand the table when higher-arity literals
// land). Kept simple to avoid coupling to a generic int-parse stdlib helper.
let knownTupleArities = [2, 3, 4, 5, 6, 7, 8, 9]

function tupleStructArity(name String) returns TupleArity
	for arity in knownTupleArities 'each'
		if name == "__Tuple{arity}" 'match'
			return arity
		end 'match'
	end 'each'
	return 0
end 'tupleStructArity'

// Tuple field names are `_0`, `_1`, ...; throws if the field name doesn't
// follow the pattern (callers use `try ... otherwise return` to short-circuit).
function tupleFieldIndex(fieldName ByteArray) returns TupleFieldOrdinal throws TupleFieldNameError
	let nameStr = String.from(fieldName)
	for arity in knownTupleArities 'each'
		for i in 0 upto arity 'eachIdx'
			if nameStr == "_{i}" 'match'
				return i
			end 'match'
		end 'eachIdx'
	end 'each'
	throw TupleFieldNameError.notTupleField
end 'tupleFieldIndex'

function recordOpResult(project Project, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, tuplePartialArgs TuplePartialArgsMap, currentNamespace String, enclosingType String, readerFilePath FilePath, funcName String, op MaxonOp)
	match op 'rec'
		literal(result, _, valueType, _) then recordResultType(producerTypes, name: result, t: valueType)
		stringConst(result, _, _) then recordResultType(producerTypes, name: result, t: stringConstResultType(project))
		charLiteral(result, _, _) then recordResultType(producerTypes, name: result, t: MaxonType.named(project.typeNames.intern("Character")))
		byteStringLiteral(result, _, _) then recordResultType(producerTypes, name: result, t: byteStringLiteralResultType(project))
		stringInterp(result, _, _) then recordResultType(producerTypes, name: result, t: stringConstResultType(project))
		varDecl(slotId, value, slotType, _) then recordVarDecl(project, producerTypes: producerTypes, slotTypes: slotTypes, slotId: slotId, value: value, slotType: slotType)
		varLoad(result, slotId, slotType, _) then recordVarLoad(project, producerTypes: producerTypes, slotTypes: slotTypes, result: result, slotId: slotId, slotType: slotType, enclosingType: enclosingType)
		varStore(slotId, value, _) then recordVarStore(project, producerTypes: producerTypes, slotTypes: slotTypes, slotId: slotId, value: value, enclosingType: enclosingType)
		globalLoad(result, _, slotType, _) then recordResultType(producerTypes, name: result, t: slotType)
		globalStore then return
		binop(result, left, right, _, operandType, _) then recordResultType(producerTypes, name: result, t: deriveBinopResultType(producerTypes, operandType: operandType, left: left, right: right))
		unop(result, operand, _, operandType, _) then recordResultType(producerTypes, name: result, t: deriveUnopResultType(producerTypes, operandType: operandType, operand: operand))
		convert(result, _, _, toType, _, _) then recordResultType(producerTypes, name: result, t: toType)
		cmp(result, _, _, _, _, _, _, _) then recordResultType(producerTypes, name: result, t: MaxonType.boolean)
		refEq(result, _, _, _, _) then recordResultType(producerTypes, name: result, t: MaxonType.boolean)
		condBr then return
		br then return
		call(result, callee, callContext, args, _, argTypes, _, _) then recordResultType(producerTypes, name: result, t: callOrArrayLiteralResultType(project, funcName: funcName, name: result, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, args: args, argTypes: argTypes, producerTypes: producerTypes, enclosingType: enclosingType))
		methodCall(result, receiver, methodName, args, _, argTypes, _, _) then recordResultType(producerTypes, name: result, t: methodCallResultType(project, receiverType: retypeCharByteReceiver(project, receiver: receiver, receiverType: lookupProducerType(producerTypes, name: receiver), funcName: funcName), methodName: methodName, argTypes: argTypes, producerTypes: producerTypes, args: args, enclosingType: enclosingType))
		ret then return
		panic then return
		panicDynamic then return
		structAlloc(result, structName, _) then recordResultType(producerTypes, name: result, t: MaxonType.named(project.typeNames.intern(String.from(structName))))
		fieldLoad(result, receiver, fieldName, _) then recordResultType(producerTypes, name: result, t: fieldLoadResultType(project, receiverType: normalizeReceiverInContext(project, t: lookupProducerType(producerTypes, name: receiver), enclosingType: enclosingType), fieldName: fieldName))
		fieldStore(receiver, fieldName, value, _, _) then refineTupleStructAlloc(project, producerTypes: producerTypes, tuplePartialArgs: tuplePartialArgs, currentNamespace: currentNamespace, receiver: receiver, fieldName: fieldName, value: value)
		selfFieldLoad(result, fieldName, _) then recordResultType(producerTypes, name: result, t: selfFieldLoadResultType(project, enclosingType: enclosingType, fieldName: fieldName))
		selfFieldStore then return
		unresolvedRead then return
		unresolvedAssign then return
		enumMatchArm then return
		rangeMatchArm then return
		// Phase 9 Stage 2: union ops carry concrete types on the op itself.
		// `enumConstruct` produces a union value (named-type pointer);
		// `enumTag` produces an integer; `enumPayloadRead` produces the
		// declared field type.
		// Record `enumConstruct` so a closure body whose terminator is
		// `ret <enumConstructResult>` (e.g. `function(...) gives Ordering.greaterThan`)
		// can resolve the lifted function's return type from the producer map.
		enumConstruct(result, enumName, _, _, _) then recordResultType(producerTypes, name: result, t: MaxonType.named(project.typeNames.intern(enumName)))
		enumTag then return
		enumPayloadRead(result, enumValName, caseName, fieldIndex, fieldType, _) then recordResultType(producerTypes, name: result, t: resolveEnumPayloadFieldType(project, producerTypes: producerTypes, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType))
		enumPayloadStore then return
		error then return
		throw then return
		tryCall(result, callee, callContext, args, _, argTypes, _, _, _) then recordResultType(producerTypes, name: result, t: callOrArrayLiteralResultType(project, funcName: funcName, name: result, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, args: args, argTypes: argTypes, producerTypes: producerTypes, enclosingType: enclosingType))
		tryMethodCall(result, receiver, methodName, args, _, argTypes, _, _, _) then recordResultType(producerTypes, name: result, t: methodCallResultType(project, receiverType: retypeCharByteReceiver(project, receiver: receiver, receiverType: lookupProducerType(producerTypes, name: receiver), funcName: funcName), methodName: methodName, argTypes: argTypes, producerTypes: producerTypes, args: args, enclosingType: enclosingType))
		rethrow then return
		// Stage E (closures): each closure op's result type derives directly
		// from a field on the op itself, so the producer-type map gets a
		// concrete entry without consulting external registries.
		// `functionRef` / `closureCreate` produce a `MaxonType.function(id)`
		// where `id` is already interned. `closureEnvLoad` carries the
		// captured value's MaxonType. `indirectCall` resolves its return
		// type via Project.functionTypes from the carried fnTypeId.
		functionRef(result, _, fnTypeId, _) then recordResultType(producerTypes, name: result, t: MaxonType.function(fnTypeId))
		closureCreate(result, _, fnTypeId, _, _, _) then recordResultType(producerTypes, name: result, t: MaxonType.function(fnTypeId))
		closureEnvLoad(result, _, _, captureType, _) then recordResultType(producerTypes, name: result, t: captureType)
		indirectCall(result, _, fnTypeId, _, _, _, _, _) then recordResultType(producerTypes, name: result, t: indirectCallResultType(project, returnType: functionTypeIdReturnType(project, id: fnTypeId)))
		// Phase 11 Step 8a: derive the loop variable's element type from the
		// source's recorded type. For Iterable conformers like
		// `genericInstance(Array, [Element])` the element type is the first
		// generic arg. We bind the iterName under producerTypes so cmp/ops
		// inside the body resolve through the producer-type lookup.
		forInIterable(iterName, iterSlot, _, sourceValue, sourceType, _, _, _, _) then recordForInIterable(project, producerTypes: producerTypes, slotTypes: slotTypes, iterName: iterName, iterSlot: iterSlot, sourceValue: sourceValue, sourceType: sourceType, enclosingType: enclosingType)
		castCheck then return
	end 'rec'
end 'recordOpResult'

// Replace a MaxonType.unresolved with its concrete type from the producer
// map. If the producer also has unresolved as its recorded type (rare —
// happens when a fieldLoad's receiver type is itself unresolved), the
// unresolved propagates and a downstream consumer (lowering or validation)
// catches it.
function fillType(producerTypes ProducerTypeMap, t MaxonType, source ByteArray) returns MaxonType
	if not isUnresolvedType(t) 'concrete'
		return t
	end 'concrete'
	return lookupProducerType(producerTypes, name: source)
end 'fillType'

// Second-pass: walk ops with the producer-type map and replace any
// MaxonType.unresolved operand with the concrete type sourced from the
// Stage E (closures): patch any function whose `maxonReturnType` is still
// `value(unresolved)` after the producer-type pass. Walks each function's
// terminator blocks for a `ret` op, looks up the ret-value's name in the
// producer map, and re-stamps `maxonReturnType` + `funcReturnTypes` with
// the concrete inner type. Lifted closure bodies (`_$closure_<n>`) are
// the primary client — the parser can't infer the body type when it
// terminates on a `fieldLoad` / `methodCall` whose result is filled in
// later. Non-closure functions whose return type was declared in source
// are already concrete and skipped on the `isUnresolvedType` guard.
function resolveUnresolvedFunctionReturnTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		var func = try module.functions.get(funcIdx) otherwise panic("resolveUnresolvedFunctionReturnTypes: funcIdx < count but get failed")
		let needsResolve = match func.maxonReturnType 'check'
			void gives false
			value(inner) gives isUnresolvedType(inner)
		end 'check'
		if not needsResolve 'skip'
			continue
		end 'skip'
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("resolveUnresolvedFunctionReturnTypes: producerTypesPerFunc.get({funcIdx}) failed")
		let resolved = findRetTypeFromProducers(module, func: func, producerTypes: producerTypes)
		if isUnresolvedType(resolved) 'stillUnresolved'
			continue
		end 'stillUnresolved'
		let newReturn = MaxonReturnType.value(resolved)
		func.maxonReturnType = newReturn
		project.funcReturnTypes.upsert(func.name, value: newReturn)
	end 'eachFunc'
	// Stage E (closures): the parser interned each lifted closure's
	// FunctionTypeRegistry entry with the (then-unresolved) body type.
	// Now that every lifted function's `maxonReturnType` is concrete,
	// walk closureCreate / functionRef ops and re-stamp the carried
	// `fnTypeId`'s return type so indirect-call sites and
	// MaxonType.function(id) consumers see the resolved signature.
	patchFunctionTypeRegistryReturns(project, module: module)
end 'resolveUnresolvedFunctionReturnTypes'

function patchFunctionTypeRegistryReturns(project Project, module MaxonModule)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("patchFunctionTypeRegistryReturns: functions.get OOB")
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("patchFunctionTypeRegistryReturns: blocks.get OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("patchFunctionTypeRegistryReturns: ops.get OOB at {opIdx}")
				maybePatchFnRegistryForOp(project, op: op)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'patchFunctionTypeRegistryReturns'

// Inspect a single op; when it's a `functionRef` or `closureCreate`, route
// the captured funcName + fnTypeId pair through the registry-patch helper.
// Every other op shape is a no-op for this pass.
function maybePatchFnRegistryForOp(project Project, op MaxonOp)
	match op 'pick'
		literal to rethrow then return
		functionRef(_, funcName, fnTypeId, _) then patchFnRegistryEntryIfUnresolved(project, funcName: funcName, fnTypeId: fnTypeId)
		closureCreate(_, funcName, fnTypeId, _, _, _) then patchFnRegistryEntryIfUnresolved(project, funcName: funcName, fnTypeId: fnTypeId)
		closureEnvLoad to forInIterable then return
	end 'pick'
end 'maybePatchFnRegistryForOp'

// Stage E (closures): walk every `closureCreate` op in the module, then
// for each, find the matching lifted function (by funcName) and patch
// its body's `closureEnvLoad` ops' `captureType` from the outer function's
// resolved slot/producer types. Re-runs `recordFuncOpResults` on each
// affected lifted body so downstream consumers (fieldLoad, methodCall)
// see the fixed receiver type in the producer map.
function patchClosureEnvLoadCaptureTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, slotTypesPerFunc SlotTypeMapArray)
	// Track lifted closures that needed a fix, so we can re-record their
	// producer-types in a second pass. (Building the map of capture types
	// in the first pass and applying them in the second avoids mutating
	// op storage while iterating producers we may revisit.)
	var liftedToRebuild = StringArray.create()
	for outerIdx in 0 upto module.functions.count() 'eachOuter'
		let outerFunc = try module.functions.get(outerIdx) otherwise panic("patchClosureEnvLoadCaptureTypes: outerIdx OOB")
		let outerSlots = try slotTypesPerFunc.get(outerIdx) otherwise panic("patchClosureEnvLoadCaptureTypes: outer slotTypes OOB")
		for blockRef in outerFunc.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("patchClosureEnvLoadCaptureTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("patchClosureEnvLoadCaptureTypes: opIdx OOB")
				match op 'check'
					closureCreate(_, funcName, _, capturedNames, _, _) then patchOneClosureLifted(module, liftedName: funcName, capturedNames: capturedNames, outerFunc: outerFunc, outerSlots: outerSlots, liftedToRebuild: liftedToRebuild)
					literal to functionRef then break 'check'
					closureEnvLoad to forInIterable then break 'check'
				end 'check'
			end 'eachOp'
		end 'eachBlock'
	end 'eachOuter'
	// Re-record producer types for each lifted function we patched. The
	// fix updates `closureEnvLoad`'s `captureType` field but the
	// previously-recorded producer-type-map entry was the stale unresolved
	// value; walking the body again from scratch refreshes downstream
	// fieldLoad / methodCall result types as well.
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("patchClosureEnvLoadCaptureTypes: funcIdx OOB")
		if not liftedToRebuild.contains(func.name) 'notLifted'
			continue
		end 'notLifted'
		var freshProducers = ProducerTypeMap.create()
		var freshSlots = SlotTypeMap.create()
		recordFuncOpResults(project, module: module, func: func, producerTypes: freshProducers, slotTypes: freshSlots)
		try producerTypesPerFunc.set(funcIdx, value: freshProducers) otherwise panic("patchClosureEnvLoadCaptureTypes: producerTypesPerFunc.set OOB")
		try slotTypesPerFunc.set(funcIdx, value: freshSlots) otherwise panic("patchClosureEnvLoadCaptureTypes: slotTypesPerFunc.set OOB")
	end 'eachFunc'
end 'patchClosureEnvLoadCaptureTypes'

// Walk the lifted closure body's `closureEnvLoad` ops. For each, look
// up the captured name's resolved type from the outer function's
// scope (slot id) → outerSlots / outerProducers, and update the op's
// captureType field when the parser-stamped type was unresolved.
function patchOneClosureLifted(module MaxonModule, liftedName String, capturedNames StringArray, outerFunc IrFunction, outerSlots SlotTypeMap, liftedToRebuild StringArray)
	// Locate the lifted IrFunction by name.
	var liftedFuncIdx = -1
	for funcIdx in 0 upto module.functions.count() 'find'
		let candidate = try module.functions.get(funcIdx) otherwise panic("patchOneClosureLifted: funcIdx OOB")
		if candidate.name == liftedName 'match'
			liftedFuncIdx = funcIdx
			break
		end 'match'
	end 'find'
	if liftedFuncIdx < 0 'noMatch'
		return
	end 'noMatch'
	let liftedFunc = try module.functions.get(liftedFuncIdx) otherwise panic("patchOneClosureLifted: liftedFuncIdx OOB after find")
	var anyPatched = false
	for liftedBlockRef in liftedFunc.blockRefs 'eachLBlock'
		let liftedBlock = try module.blocks.get(liftedBlockRef) otherwise panic("patchOneClosureLifted: liftedBlockRef OOB")
		for liftedOpIdx in liftedBlock.opRefs 'eachLOp'
			let liftedOp = try module.ops.get(liftedOpIdx) otherwise panic("patchOneClosureLifted: liftedOpIdx OOB")
			if patchOneEnvLoadOp(module, opIdx: liftedOpIdx, op: liftedOp, capturedNames: capturedNames, outerFunc: outerFunc, outerSlots: outerSlots) 'patched'
				anyPatched = true
			end 'patched'
		end 'eachLOp'
	end 'eachLBlock'
	if anyPatched 'mark'
		liftedToRebuild.push(liftedName)
	end 'mark'
end 'patchOneClosureLifted'

// Patch a single `closureEnvLoad` op in place when its `captureType` is
// unresolved and the outer function's resolved slot type carries a concrete
// answer. Returns true when the op was rewritten so the caller can mark
// the lifted body for producer-types rebuild.
function patchOneEnvLoadOp(module MaxonModule, opIdx OpIndex, op MaxonOp, capturedNames StringArray, outerFunc IrFunction, outerSlots SlotTypeMap) returns bool
	match op 'pick'
		closureEnvLoad(result, captureIndex, captureName, captureType, range) then return patchEnvLoadIfNeeded(module, opIdx: opIdx, result: result, captureIndex: captureIndex, captureName: captureName, captureType: captureType, range: range, capturedNames: capturedNames, outerFunc: outerFunc, outerSlots: outerSlots)
		literal to closureCreate then return false
		indirectCall to forInIterable then return false
	end 'pick'
end 'patchOneEnvLoadOp'

function patchEnvLoadIfNeeded(module MaxonModule, opIdx OpIndex, result ByteArray, captureIndex ParsedInt, captureName ByteArray, captureType MaxonType, range SourceRange, capturedNames StringArray, outerFunc IrFunction, outerSlots SlotTypeMap) returns bool
	if not isUnresolvedType(captureType) 'haveConcrete'
		return false
	end 'haveConcrete'
	if captureIndex >= capturedNames.count() 'idxOOB'
		return false
	end 'idxOOB'
	let outerName = try capturedNames.get(captureIndex) otherwise panic("patchEnvLoadIfNeeded: capturedNames.get({captureIndex}) failed despite count guard")
	let resolved = resolveOuterCaptureType(outerFunc, outerSlots: outerSlots, captureName: outerName)
	if isUnresolvedType(resolved) 'noFix'
		return false
	end 'noFix'
	try module.ops.set(opIdx, value: MaxonOp.closureEnvLoad(result, captureIndex: captureIndex, captureName: captureName, captureType: resolved, range: range)) otherwise panic("patchEnvLoadIfNeeded: ops.set OOB at idx={opIdx}")
	return true
end 'patchEnvLoadIfNeeded'

// Find the captured name's resolved MaxonType in the outer function's
// scope. The parser-stamped scope on `outerFunc.scope` carries the slot
// id; `outerSlots` is the slot → resolved-type map built by `recordVarDecl`.
function resolveOuterCaptureType(outerFunc IrFunction, outerSlots SlotTypeMap, captureName String) returns MaxonType
	if not outerFunc.scope.contains(captureName) 'notInScope'
		return MaxonType.unresolved
	end 'notInScope'
	let info = outerFunc.scope.getInfo(captureName)
	// Slot type may have been refined past the parser's varType stamp.
	if let slotType = try outerSlots.get(info.slot) 'fromSlot'
		if not isUnresolvedType(slotType) 'concrete'
			return slotType
		end 'concrete'
	end 'fromSlot'
	// Fall back to the parser-stamped scope varType — concrete when the
	// parser already knew the type (parameter, explicit annotation).
	if not isUnresolvedType(info.varType) 'fromVarInfo'
		return info.varType
	end 'fromVarInfo'
	return MaxonType.unresolved
end 'resolveOuterCaptureType'

function patchFnRegistryEntryIfUnresolved(project Project, funcName String, fnTypeId FunctionTypeId)
	let (_, currentReturn) = project.functionTypes.get(fnTypeId)
	let stillUnresolved = match currentReturn 'check'
		void gives false
		value(inner) gives isUnresolvedType(inner)
	end 'check'
	if not stillUnresolved 'alreadyResolved'
		return
	end 'alreadyResolved'
	if let resolved = try project.funcReturnTypes.get(funcName) 'haveResolved'
		let resolvedUnresolved = match resolved 'r'
			void gives false
			value(inner) gives isUnresolvedType(inner)
		end 'r'
		if not resolvedUnresolved 'concrete'
			project.functionTypes.setReturnType(fnTypeId, returnType: resolved)
		end 'concrete'
	end 'haveResolved'
end 'patchFnRegistryEntryIfUnresolved'

// Walk a function's terminators; the first `ret` op's value name yields a
// concrete type via the producer map. Returns `MaxonType.unresolved` when
// no `ret` is found or its source name is missing from the map — caller
// preserves the existing (unresolved) signature in that case.
function findRetTypeFromProducers(module MaxonModule, func IrFunction, producerTypes ProducerTypeMap) returns MaxonType
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("findRetTypeFromProducers: blockRef OOB")
		if not block.hasTerminatorOp() 'noTerm'
			continue
		end 'noTerm'
		let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("findRetTypeFromProducers: terminator OOB")
		let probed = retValueTypeFromProducers(termOp, producerTypes: producerTypes)
		if not isUnresolvedType(probed) 'hit'
			return probed
		end 'hit'
	end 'eachBlock'
	return MaxonType.unresolved
end 'findRetTypeFromProducers'

function retValueTypeFromProducers(op MaxonOp, producerTypes ProducerTypeMap) returns MaxonType
	return match op 'pick'
		ret(retVal, _) gives lookupProducerType(producerTypes, name: retVal)
		literal gives MaxonType.unresolved
		stringConst gives MaxonType.unresolved
		charLiteral gives MaxonType.unresolved
		byteStringLiteral gives MaxonType.unresolved
		stringInterp gives MaxonType.unresolved
		varDecl gives MaxonType.unresolved
		varLoad gives MaxonType.unresolved
		varStore gives MaxonType.unresolved
		globalLoad gives MaxonType.unresolved
		globalStore gives MaxonType.unresolved
		binop gives MaxonType.unresolved
		unop gives MaxonType.unresolved
		convert gives MaxonType.unresolved
		cmp gives MaxonType.unresolved
		refEq gives MaxonType.unresolved
		condBr gives MaxonType.unresolved
		br gives MaxonType.unresolved
		call gives MaxonType.unresolved
		methodCall gives MaxonType.unresolved
		panic gives MaxonType.unresolved
		panicDynamic gives MaxonType.unresolved
		structAlloc gives MaxonType.unresolved
		fieldLoad gives MaxonType.unresolved
		fieldStore gives MaxonType.unresolved
		selfFieldLoad gives MaxonType.unresolved
		selfFieldStore gives MaxonType.unresolved
		unresolvedRead gives MaxonType.unresolved
		unresolvedAssign gives MaxonType.unresolved
		enumMatchArm gives MaxonType.unresolved
		rangeMatchArm gives MaxonType.unresolved
		enumConstruct gives MaxonType.unresolved
		enumTag gives MaxonType.unresolved
		enumPayloadRead gives MaxonType.unresolved
		enumPayloadStore gives MaxonType.unresolved
		error gives MaxonType.unresolved
		throw gives MaxonType.unresolved
		tryCall gives MaxonType.unresolved
		tryMethodCall gives MaxonType.unresolved
		rethrow gives MaxonType.unresolved
		functionRef gives MaxonType.unresolved
		closureCreate gives MaxonType.unresolved
		closureEnvLoad gives MaxonType.unresolved
		indirectCall gives MaxonType.unresolved
		forInIterable gives MaxonType.unresolved
		castCheck gives MaxonType.unresolved
	end 'pick'
end 'retValueTypeFromProducers'

// producer map. Op variants that don't carry MaxonType operands are
// skipped.
function fillUnresolvedTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, slotTypesPerFunc SlotTypeMapArray)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("fillUnresolvedTypes: funcIdx < count but get failed")
		var producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("fillUnresolvedTypes: producerTypesPerFunc.get({funcIdx}) failed")
		var slotTypes = try slotTypesPerFunc.get(funcIdx) otherwise panic("fillUnresolvedTypes: slotTypesPerFunc.get({funcIdx}) failed")
		runFillUnresolvedTypesForFunc(project, module: module, func: func, producerTypes: producerTypes, slotTypes: slotTypes)
	end 'eachFunc'
end 'fillUnresolvedTypes'

// Apply `fillUnresolvedTypesForOp` to every op + terminator in `func`. Pulled
// out of `fillUnresolvedTypes` so the on-demand path in `resolveAllCalls`
// (which discovers newly-cloned monomorphization bodies after the module-wide
// fill has already run) can reuse the same per-op fill discipline without
// rebuilding the perFunc maps just to dispatch into the inner walk.
export function runFillUnresolvedTypesForFunc(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, slotTypes SlotTypeMap)
	let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("runFillUnresolvedTypesForFunc: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("runFillUnresolvedTypesForFunc: opIdx OOB")
			fillUnresolvedTypesForOp(project, module: module, opIdx: opIdx, op: op, producerTypes: producerTypes, slotTypes: slotTypes, enclosingType: enclosingType)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			let termIdx = block.terminatorIndex()
			let termOp = try module.ops.get(termIdx) otherwise panic("runFillUnresolvedTypesForFunc: terminator OOB")
			fillUnresolvedTypesForOp(project, module: module, opIdx: termIdx, op: termOp, producerTypes: producerTypes, slotTypes: slotTypes, enclosingType: enclosingType)
		end 'hasTerm'
	end 'eachBlock'
end 'runFillUnresolvedTypesForFunc'

function fillUnresolvedTypesForOp(project Project, module MaxonModule, opIdx OpIndex, op MaxonOp, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, enclosingType String)
	match op 'fill'
		varDecl(slotId, value, slotType, range) then fillVarDecl(project, module: module, opIdx: opIdx, slotId: slotId, value: value, slotType: slotType, range: range, producerTypes: producerTypes, slotTypes: slotTypes)
		varLoad(result, slotId, slotType, range) then fillVarLoad(project, module: module, opIdx: opIdx, result: result, slotId: slotId, slotType: slotType, range: range, producerTypes: producerTypes, slotTypes: slotTypes, enclosingType: enclosingType)
		globalStore(name, value, slotType, range) then fillGlobalStore(module, opIdx: opIdx, name: name, value: value, slotType: slotType, range: range, producerTypes: producerTypes)
		convert(result, operand, fromType, toType, implicit, range) then fillConvert(module, opIdx: opIdx, result: result, operand: operand, fromType: fromType, toType: toType, implicit: implicit, range: range, producerTypes: producerTypes)
		cmp(result, left, right, predicate, leftType, rightType, operandType, range) then fillCmp(project, module: module, opIdx: opIdx, result: result, left: left, right: right, predicate: predicate, leftType: leftType, rightType: rightType, operandType: operandType, range: range, producerTypes: producerTypes)
		binop(result, left, right, opKind, operandType, range) then fillBinop(module, opIdx: opIdx, result: result, left: left, right: right, opKind: opKind, operandType: operandType, range: range, producerTypes: producerTypes)
		unop(result, operand, opKind, operandType, range) then fillUnop(module, opIdx: opIdx, result: result, operand: operand, opKind: opKind, operandType: operandType, range: range, producerTypes: producerTypes)
		call(result, callee, callContext, args, argLabels, argTypes, argRanges, range) then fillCall(module, opIdx: opIdx, result: result, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: range, producerTypes: producerTypes)
		methodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, range) then fillMethodCall(module, opIdx: opIdx, result: result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: range, producerTypes: producerTypes)
		tryMethodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, errorBoundName, range) then fillTryMethodCall(module, opIdx: opIdx, result: result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorBoundName, range: range, producerTypes: producerTypes)
		// A literal carries its type in `valueType` with no upstream producer to
		// source from, so the fill pass normally leaves it alone. But a literal
		// must never reach lowering still `unresolved` — there is no later pass
		// that repairs literals, so it would panic in resolveMaxonTypeToStd. A
		// numeric literal's natural type is a bare integer, so fall back to that.
		// Pass the whole op (not destructured fields) so the rewrite's owned
		// `result`/`value` come from a single re-match inside `fillLiteral`,
		// avoiding a double-decref of fields aliased across the match boundary.
		literal then fillLiteral(module, opIdx: opIdx, op: op)
		stringConst then return
		charLiteral then return
		byteStringLiteral then return
		stringInterp(result, parts, range) then fillStringInterpKinds(project, module: module, opIdx: opIdx, result: result, parts: parts, range: range, producerTypes: producerTypes)
		varStore then return
		globalLoad then return
		refEq then return
		condBr then return
		br then return
		ret then return
		panic then return
		panicDynamic then return
		structAlloc then return
		fieldLoad then return
		fieldStore then return
		selfFieldLoad then return
		selfFieldStore then return
		unresolvedRead then return
		unresolvedAssign then return
		enumMatchArm(scrutineeName, caseName, scrutineeType, rawValue, isFloat, resolved, thenTarget, elseTarget, bindingNames, range) then fillEnumMatchArmType(module, opIdx: opIdx, scrutineeName: scrutineeName, caseName: caseName, scrutineeType: scrutineeType, rawValue: rawValue, isFloat: isFloat, resolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range, producerTypes: producerTypes)
		rangeMatchArm then return
		// Phase 9 Stage 2 plumbing: most union ops carry concrete payload
		// types from parse-time on. `enumPayloadRead` / `enumPayloadStore`
		// are the exceptions — the parser stamps `unresolved` because the
		// union's case-table may live in another file; these fills make
		// that resolution flow through the producer-types map to the
		// matching varDecl / lowering.
		enumConstruct then return
		enumTag then return
		enumPayloadRead(result, enumValName, caseName, fieldIndex, fieldType, range) then fillEnumPayloadRead(project, module: module, opIdx: opIdx, result: result, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType, range: range, producerTypes: producerTypes)
		enumPayloadStore(enumValName, caseName, fieldIndex, fieldType, newValueName, range) then fillEnumPayloadStore(project, module: module, opIdx: opIdx, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType, newValueName: newValueName, range: range, producerTypes: producerTypes)
		error then return
		throw then return
		tryCall then return
		rethrow then return
		// Stage E (closures): all four ops carry no MaxonType.unresolved
		// fields that depend on cross-declaration lookups. functionRef /
		// closureCreate / indirectCall reference an already-interned
		// FunctionTypeId; closureEnvLoad's captureType was stamped from
		// the outer scope's recorded type at parse time. Nothing to fill
		// in here — the recordOpResult pass above produced the concrete
		// result type, and any consumer sees it directly.
		functionRef then return
		closureCreate then return
		closureEnvLoad then return
		indirectCall then return
		// Phase 11 Step 9: forInIterable's iterType / sourceType become
		// concrete only once Step 8's iterator-protocol resolution lands.
		// Until then, leave the op alone — downstream lowering will panic
		// before any user-visible type-mismatch can leak.
		forInIterable then return
		castCheck then return
	end 'fill'
end 'fillUnresolvedTypesForOp'

// Fill the scrutineeType field on an enumMatchArm op from the producer-type
// map. Resolution of the case name itself happens later in
// `resolveEnumMatchArms` once the scrutinee's type is concrete across all
// arm sites in the module.
function fillEnumMatchArmType(module MaxonModule, opIdx OpIndex, scrutineeName ByteArray, caseName String, scrutineeType MaxonType, rawValue IntConstant, isFloat bool, resolved bool, thenTarget BlockId, elseTarget BlockId, bindingNames ByteArrayArray, range SourceRange, producerTypes ProducerTypeMap)
	let filled = fillType(producerTypes, t: scrutineeType, source: scrutineeName)
	if isUnresolvedType(filled) == isUnresolvedType(scrutineeType) and not isUnresolvedType(scrutineeType) 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.enumMatchArm(scrutineeName, caseName: caseName, scrutineeType: filled, rawValue: rawValue, isFloat: isFloat, resolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range)) otherwise panic("fillEnumMatchArmType: ops.set OOB at idx={opIdx}")
end 'fillEnumMatchArmType'

function fillVarDecl(project Project, module MaxonModule, opIdx OpIndex, slotId VarSlot, value ByteArray, slotType MaxonType, range SourceRange, producerTypes ProducerTypeMap, slotTypes SlotTypeMap)
	let filled = fillType(producerTypes, t: slotType, source: value)
	if isUnresolvedType(filled) == isUnresolvedType(slotType) and not isUnresolvedType(slotType) 'noChange'
		// Phase A widening: when the user wrote `let r = match ... end`
		// and the match's first arm seeded the parser-stamped slotType at
		// `integer` but a later arm produced a `float`, the initializer
		// value's recorded producer type is now `float`. Promote the
		// `let r` slot to float so downstream reads see f64 bits. This
		// catches the chain: match-internal-slot → widened-float varLoad
		// →  varDecl(slot_r, value, slotType: integer) — the integer
		// stamp here would otherwise pin slot_r's slotTypes entry to int.
		let fromValue = lookupProducerType(producerTypes, name: value)
		if isIntToFloatWidening(project, from: slotType, to: fromValue) 'widenInt2Float'
			try module.ops.set(opIdx, value: MaxonOp.varDecl(slotId, value: value, slotType: fromValue, range: range)) otherwise panic("fillVarDecl: ops.set OOB at idx={opIdx}")
			slotTypes.upsert(slotId, value: fromValue)
			return
		end 'widenInt2Float'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.varDecl(slotId, value: value, slotType: filled, range: range)) otherwise panic("fillVarDecl: ops.set OOB at idx={opIdx}")
end 'fillVarDecl'

// Phase A widening: rewrite varDecl ops whose recorded `slotType` is `int`
// but whose effective slot type (after `recordVarStore` upgraded it across
// arms) became `float`. Mirrors the C# bootstrap's match-expression
// post-pass that swaps the entry-block seed literal + declaration to the
// final wider kind. Walks every varDecl after the main TR fill passes have
// converged so any first-arm-seeded match slot picks up the widening.
function widenVarDeclTypesFromSlotTypes(project Project, module MaxonModule, slotTypesPerFunc SlotTypeMapArray)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("widenVarDeclTypesFromSlotTypes: funcIdx OOB")
		let slotTypes = try slotTypesPerFunc.get(funcIdx) otherwise panic("widenVarDeclTypesFromSlotTypes: slotTypesPerFunc.get({funcIdx}) failed")
		let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("widenVarDeclTypesFromSlotTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("widenVarDeclTypesFromSlotTypes: opIdx OOB")
				if op.name != "varDecl" 'notVarDecl'
					continue
				end 'notVarDecl'
				match op 'widen'
					varDecl(slotId, value, slotType, range) then widenOneVarDecl(project, module: module, opIdx: opIdx, slotId: slotId, value: value, slotType: slotType, range: range, slotTypes: slotTypes, enclosingType: enclosingType)
					default panic("widenVarDeclTypesFromSlotTypes: unreachable — op.name == varDecl but match did not extract")
				end 'widen'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'widenVarDeclTypesFromSlotTypes'

function widenOneVarDecl(project Project, module MaxonModule, opIdx OpIndex, slotId VarSlot, value ByteArray, slotType MaxonType, range SourceRange, slotTypes SlotTypeMap, enclosingType String)
	let effective = try slotTypes.get(slotId) otherwise return
	if maxonTypesStructurallyEqual(effective, b: slotType) 'sameType'
		return
	end 'sameType'
	// Two restamp cases:
	//  (1) int → float widening — when an earlier arm pinned the slot to
	//      `int` (the literal-zero seed's category, or a prior arm that
	//      produced an int) and a later arm produced `float`, restamp so
	//      `lowerVarStore` emits siToFp for the int-typed arms.
	//  (2) primitive seed → typeParameter — `recordVarStore` promoted the
	//      slot to a `typeParameter(Element)` from the literal-zero seed
	//      when a try-success arm wrote a generic-method result owned by
	//      the enclosing type. The varDecl op's slotType still says
	//      `int` from `fillVarDecl` (which keys off the seed-zero
	//      literal's type). Restamp so the seed `varDecl` and every
	//      downstream `varLoad` agree on the typeParameter type — without
	//      this, `prev.compare(pending)` inside a generic stdlib body
	//      silently routes through `int.compare`. Gated on the
	//      typeParameter being in scope — see `recordVarStore` for the
	//      rationale. Other transitions (struct refinement,
	//      genericInstance promotion) are owned by `fillVarDecl`.
	let widensToFloat = isIntToFloatWidening(project, from: slotType, to: effective)
	let promotesToTypeParam = (not maxonTypeIsTypeParameter(slotType)) and typeParamBelongsToEnclosing(project, t: effective, enclosingType: enclosingType)
	if not (widensToFloat or promotesToTypeParam) 'notWidening'
		return
	end 'notWidening'
	try module.ops.set(opIdx, value: MaxonOp.varDecl(slotId, value: value, slotType: effective, range: range)) otherwise panic("widenOneVarDecl: ops.set OOB at idx={opIdx}")
end 'widenOneVarDecl'

// Resolve the field type for a union case's payload at the given index.
// The parser emits `enumPayloadRead` with `fieldType = unresolved` because
// the scrutinee's union may be declared in a different file — TR fills
// the type once `producerTypes` has the scrutinee's resolved type.
// Returns the op-stamped `fieldType` if it is already concrete, or
// `MaxonType.unresolved` if the scrutinee's union name or the union case
// itself isn't known yet (a later pass will retry).
function resolveEnumPayloadFieldType(project Project, producerTypes ProducerTypeMap, enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType) returns MaxonType
	if not isUnresolvedType(fieldType) 'haveType'
		return fieldType
	end 'haveType'
	let scrutineeType = lookupProducerType(producerTypes, name: enumValName)
	let unionName = scrutineeType.nameOrEmpty(project)
	if unionName.isEmpty() 'noUnion'
		return MaxonType.unresolved
	end 'noUnion'
	return lookupUnionCasePayloadField(project, unionName: unionName, caseName: caseName, fieldIndex: fieldIndex)
end 'resolveEnumPayloadFieldType'

// Walk both the resolved and unresolved enum registries to find a union
// case's payload field by index. Returns `MaxonType.unresolved` on miss
// (unknown union, unknown case, or index out of range) — the diagnostic
// is the responsibility of the match-arm validation pass.
function lookupUnionCasePayloadField(project Project, unionName String, caseName String, fieldIndex IntConstant) returns MaxonType
	if let et = try project.enumTypes.get(unionName) 'haveResolved'
		if let idx = try et.caseByName.get(caseName) 'haveCase'
			let c = try et.cases.get(idx) otherwise return MaxonType.unresolved
			let field = try c.payloadFields.get(fieldIndex as ElementCount) otherwise return MaxonType.unresolved
			return field.fieldType
		end 'haveCase'
	end 'haveResolved'
	if let ut = try project.unresolvedEnums.get(unionName) 'haveUnresolved'
		for c in ut.cases 'eachCase'
			if c.name == caseName 'hit'
				let field = try c.payloadFields.get(fieldIndex as ElementCount) otherwise return MaxonType.unresolved
				return field.fieldType
			end 'hit'
		end 'eachCase'
	end 'haveUnresolved'
	return MaxonType.unresolved
end 'lookupUnionCasePayloadField'

// Resolve a payload field type from `unresolved` to its concrete type,
// returning `MaxonType.unresolved` when the existing `fieldType` is
// already concrete (caller skips) or when nothing in the registries
// can fill it yet (caller defers to a later pass). Shared front-end
// for both `fillEnumPayloadRead` and `fillEnumPayloadStore`.
function tryResolvePayloadFieldType(project Project, producerTypes ProducerTypeMap, enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType) returns MaxonType
	if not isUnresolvedType(fieldType) 'haveType'
		return MaxonType.unresolved
	end 'haveType'
	let filled = resolveEnumPayloadFieldType(project, producerTypes: producerTypes, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType)
	if isUnresolvedType(filled) 'stillUnresolved'
		return MaxonType.unresolved
	end 'stillUnresolved'
	return filled
end 'tryResolvePayloadFieldType'

// Rewrite an enumPayloadRead's `fieldType` from `unresolved` to the
// resolved type, mirroring `fillVarDecl`. The op's `enumValName`
// provides the scrutinee's producer-type and the carried `caseName`
// selects the right field-type from the union's case table.
function fillEnumPayloadRead(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType, range SourceRange, producerTypes ProducerTypeMap)
	let filled = tryResolvePayloadFieldType(project, producerTypes: producerTypes, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType)
	if isUnresolvedType(filled) 'skip'
		return
	end 'skip'
	try module.ops.set(opIdx, value: MaxonOp.enumPayloadRead(result, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: filled, range: range)) otherwise panic("fillEnumPayloadRead: ops.set OOB at idx={opIdx}")
end 'fillEnumPayloadRead'

// Rewrite an enumPayloadStore's `fieldType` from `unresolved` to the
// resolved type. Same shape as `fillEnumPayloadRead`.
function fillEnumPayloadStore(project Project, module MaxonModule, opIdx OpIndex, enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType, newValueName ByteArray, range SourceRange, producerTypes ProducerTypeMap)
	let filled = tryResolvePayloadFieldType(project, producerTypes: producerTypes, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: fieldType)
	if isUnresolvedType(filled) 'skip'
		return
	end 'skip'
	try module.ops.set(opIdx, value: MaxonOp.enumPayloadStore(enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: filled, newValueName: newValueName, range: range)) otherwise panic("fillEnumPayloadStore: ops.set OOB at idx={opIdx}")
end 'fillEnumPayloadStore'

// Refine `expr(name, kind)` parts of a stringInterp op now that producer
// types are concrete. The parser inferred each kind from the parse-time
// value type, which for variables and method-call results is often
// `unresolved` and falls back to `InterpExprKind.i64`. After
// recordOpResult has run, producerTypes carries the real type — re-derive
// the kind from that and rewrite the part if it differs. Without this,
// e.g. `var s = "foo"; print("{s}")` lowers `{s}` as i64 and prints the
// heap pointer instead of the string contents.
function fillStringInterpKinds(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, parts StringInterpPartArray, range SourceRange, producerTypes ProducerTypeMap)
	var changed = false
	var newParts = StringInterpPartArray.create()
	for i in 0 upto parts.count() 'eachPart'
		let part = try parts.get(i) otherwise panic("fillStringInterpKinds: parts.get OOB at {i}")
		let refined = match part 'refine'
			literal gives part
			expr(name, kind, formatSpecId) gives refineInterpExprPart(project, original: part, name: name, kind: kind, formatSpecId: formatSpecId, producerTypes: producerTypes)
		end 'refine'
		if not interpPartsEqual(part, b: refined) 'diff'
			changed = true
		end 'diff'
		newParts.push(refined)
	end 'eachPart'
	if not changed 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.stringInterp(result, parts: newParts, range: range)) otherwise panic("fillStringInterpKinds: ops.set OOB at idx={opIdx}")
end 'fillStringInterpKinds'

function refineInterpExprPart(project Project, original StringInterpPart, name ByteArray, kind InterpExprKind, formatSpecId StringId, producerTypes ProducerTypeMap) returns StringInterpPart
	let resolvedType = lookupProducerType(producerTypes, name: name)
	if isUnresolvedType(resolvedType) 'noProducer'
		return original
	end 'noProducer'
	let refinedKind = interpKindForType(project, t: resolvedType, fallback: kind)
	return StringInterpPart.expr(name, kind: refinedKind, formatSpecId: formatSpecId)
end 'refineInterpExprPart'

function interpKindForType(project Project, t MaxonType, fallback InterpExprKind) returns InterpExprKind
	return match t 'k'
		boolean gives InterpExprKind.bool
		integer gives InterpExprKind.i64
		float gives InterpExprKind.f64
		string gives InterpExprKind.string
		named(id) gives interpKindForNamedTypeName(project, name: project.typeNames.get(id), fallback: fallback)
		function to opaquePointer gives fallback
	end 'k'
end 'interpKindForType'

function interpKindForNamedTypeName(project Project, name String, fallback InterpExprKind) returns InterpExprKind
	if name == "String" 'isString'
		return InterpExprKind.string
	end 'isString'
	if name == "Character" 'isChar'
		return InterpExprKind.character
	end 'isChar'
	if name == "bool" 'isBool'
		return InterpExprKind.bool
	end 'isBool'
	// Enum-typed value: lowering emits a select chain mapping the ordinal
	// to the declared case name. Has to come before the typealias check
	// because the parser registers every enum as a ranged-int typealias
	// (so its named-type can flow through cast machinery), and the alias
	// check would otherwise short-circuit and stringify the raw integer.
	if project.enumTypes.contains(name) 'isEnum'
		return InterpExprKind.enumName
	end 'isEnum'
	// User type that conforms to Stringable: lowering calls toString() via
	// the witness table and uses the returned String's buffer/length.
	// Anything implementing Stringable goes through this arm — including
	// types declared in user code (`type T implements Stringable`).
	// `project.conformances` is populated during parse, well before
	// BuildWitnessTables actually emits the witness blobs — checking
	// conformance here gives lowering the green light to take the
	// stringable path, and the witness label always exists by the time
	// lowering runs. Also runs before the typealias check: the parser
	// registers user struct types under their bare name in `typealiases`
	// only when the user wrote an explicit `typealias`; Stringable conformers
	// declared with `type T implements Stringable` never reach that map,
	// but be defensive about ordering in case extension-driven aliases land
	// later.
	if project.conformances.contains(name, interfaceName: "Stringable") 'isStringable'
		return InterpExprKind.stringable
	end 'isStringable'
	// Resolve user-defined typealiases (e.g. `typealias Real = float`) so
	// `print("{x}")` picks `mrt_f64_to_string` instead of falling back to the
	// i64 path. Without this, any aliased numeric return type (Math.pow
	// returns `Real`) gets stringified as an i64 and the runtime hangs /
	// produces garbage.
	if let stdType = try project.typealiases.get(name) 'hasAlias'
		if stdTypeIsFloat(stdType) 'isFloat'
			return InterpExprKind.f64
		end 'isFloat'
		return InterpExprKind.i64
	end 'hasAlias'
	return fallback
end 'interpKindForNamedTypeName'

function interpPartsEqual(a StringInterpPart, b StringInterpPart) returns bool
	return match a 'mA'
		literal(idA) gives match b 'mB1'
			literal(idB) gives idA == idB
			expr gives false
		end 'mB1'
		expr(_, kindA, fmtA) gives match b 'mB2'
			literal gives false
			expr(_, kindB, fmtB) gives kindA.ordinal == kindB.ordinal and fmtA == fmtB
		end 'mB2'
	end 'mA'
end 'interpPartsEqual'

function fillVarLoad(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, slotId VarSlot, slotType MaxonType, range SourceRange, producerTypes ProducerTypeMap, slotTypes SlotTypeMap, enclosingType String)
	let filled = try slotTypes.get(slotId) otherwise MaxonType.unresolved
	if isUnresolvedType(slotType) 'fillEmpty'
		// Slot type was recorded by an earlier varDecl into the slot-type
		// map. If still unresolved here, the slot's initializer also
		// failed to resolve — leave it; downstream validation surfaces
		// the unresolved chain.
		if isUnresolvedType(filled) 'stillUnresolved'
			return
		end 'stillUnresolved'
		try module.ops.set(opIdx, value: MaxonOp.varLoad(result, slotId: slotId, slotType: filled, range: range)) otherwise panic("fillVarLoad: ops.set OOB at idx={opIdx}")
		return
	end 'fillEmpty'
	// Phase A widening: when the slot's effective type is float (because
	// `recordVarStore` widened across arms) but the varLoad op still
	// carries the parser-stamped int type (parseMatchExpression sets
	// `resultType` from the first arm's literal), restamp so the load
	// reads f64 bits instead of i64. Also re-publish the load's producer
	// type — `buildProducerTypes` walks in block order, so the merge-
	// block varLoad ran before the arm-block varStores recorded the
	// wider type and producer map still says int. Downstream cmp/binop
	// validators consult producerTypes via `widenStampedOpType`.
	if isIntToFloatWidening(project, from: slotType, to: filled) 'widenInt2Float'
		try module.ops.set(opIdx, value: MaxonOp.varLoad(result, slotId: slotId, slotType: filled, range: range)) otherwise panic("fillVarLoad: ops.set OOB at idx={opIdx}")
		recordResultType(producerTypes, name: result, t: filled)
		return
	end 'widenInt2Float'
	// Generic-body seed promotion: `recordVarStore` upgraded the slot
	// from the literal-zero seed's `int` to `typeParameter(Element)`
	// when a try-success arm wrote a generic-method result owned by
	// the enclosing type. Restamp the varLoad's `slotType` and
	// re-publish the load's producer type so downstream method
	// dispatch on the loaded name sees the typeParameter (and routes
	// `prev.compare(pending)` to the per-Element witness instead of
	// `int.compare`). Mirrors the int→float widening above; gated on
	// the typeParameter being in scope — see `recordVarStore` for the
	// rationale.
	if (not maxonTypeIsTypeParameter(slotType)) and typeParamBelongsToEnclosing(project, t: filled, enclosingType: enclosingType) 'promoteTypeParam'
		try module.ops.set(opIdx, value: MaxonOp.varLoad(result, slotId: slotId, slotType: filled, range: range)) otherwise panic("fillVarLoad: ops.set OOB at idx={opIdx}")
		recordResultType(producerTypes, name: result, t: filled)
		return
	end 'promoteTypeParam'
	// Refine `named(X)` → `genericInstance(X, [...])` when the slot-type
	// map carries a more specific entry. The parser stamps the merge
	// varLoad of `try EXPR otherwise FALLBACK` with the call's declared
	// return type — `Self` collapses to `named(EnclosingType)` at parse
	// time, so the genericInstance shape only surfaces here once
	// `methodCallResultType`'s substitution has been recorded.
	let promoted = promoteNamedToGenericInstance(project, raw: slotType, candidate: filled)
	if not maxonTypesStructurallyEqual(promoted, b: slotType) 'didPromote'
		try module.ops.set(opIdx, value: MaxonOp.varLoad(result, slotId: slotId, slotType: promoted, range: range)) otherwise panic("fillVarLoad: ops.set OOB at idx={opIdx}")
	end 'didPromote'
end 'fillVarLoad'

function fillGlobalStore(module MaxonModule, opIdx OpIndex, name String, value ByteArray, slotType MaxonType, range SourceRange, producerTypes ProducerTypeMap)
	if not isUnresolvedType(slotType) 'noChange'
		return
	end 'noChange'
	let filled = lookupProducerType(producerTypes, name: value)
	if isUnresolvedType(filled) 'stillUnresolved'
		return
	end 'stillUnresolved'
	try module.ops.set(opIdx, value: MaxonOp.globalStore(name, value: value, slotType: filled, range: range)) otherwise panic("fillGlobalStore: ops.set OOB at idx={opIdx}")
end 'fillGlobalStore'

function fillConvert(module MaxonModule, opIdx OpIndex, result ByteArray, operand ByteArray, fromType MaxonType, toType MaxonType, implicit bool, range SourceRange, producerTypes ProducerTypeMap)
	if not isUnresolvedType(fromType) 'noChange'
		return
	end 'noChange'
	let filledFrom = lookupProducerType(producerTypes, name: operand)
	if isUnresolvedType(filledFrom) 'stillUnresolved'
		return
	end 'stillUnresolved'
	try module.ops.set(opIdx, value: MaxonOp.convert(result, operand: operand, fromType: filledFrom, toType: toType, implicit: implicit, range: range)) otherwise panic("fillConvert: ops.set OOB at idx={opIdx}")
end 'fillConvert'

function fillCmp(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, leftType MaxonType, rightType MaxonType, operandType MaxonType, range SourceRange, producerTypes ProducerTypeMap)
	let filledLeft = widenStampedOpType(project, producerTypes: producerTypes, stamped: leftType, source: left)
	let filledRight = widenStampedOpType(project, producerTypes: producerTypes, stamped: rightType, source: right)
	let filledOperand = pickOperandType(filledLeft, right: filledRight, current: operandType)
	let unchanged = maxonTypesStructurallyEqual(filledLeft, b: leftType) and maxonTypesStructurallyEqual(filledRight, b: rightType) and maxonTypesStructurallyEqual(filledOperand, b: operandType)
	if unchanged 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.cmp(result, left: left, right: right, predicate: predicate, leftType: filledLeft, rightType: filledRight, operandType: filledOperand, range: range)) otherwise panic("fillCmp: ops.set OOB at idx={opIdx}")
end 'fillCmp'

// Phase A widening helper: like `fillType`, but additionally re-stamps a
// concrete int-typed slot with the producer's float type when the producer
// has been widened (e.g. a match-result slot whose effective type became
// float because of a back-promoting arm). Without this, cmp/binop operand
// types stay stale at `int` and `validateCompareOp` fires E3005 on a load
// that actually produces a float SSA value.
function widenStampedOpType(project Project, producerTypes ProducerTypeMap, stamped MaxonType, source ByteArray) returns MaxonType
	if isUnresolvedType(stamped) 'fillUnresolved'
		return lookupProducerType(producerTypes, name: source)
	end 'fillUnresolved'
	let fromProducer = lookupProducerType(producerTypes, name: source)
	if isIntToFloatWidening(project, from: stamped, to: fromProducer) 'widen'
		return fromProducer
	end 'widen'
	return stamped
end 'widenStampedOpType'

function pickOperandType(left MaxonType, right MaxonType, current MaxonType) returns MaxonType
	if not isUnresolvedType(current) 'keepCurrent'
		return current
	end 'keepCurrent'
	if not isUnresolvedType(left) 'useLeft'
		return left
	end 'useLeft'
	if not isUnresolvedType(right) 'useRight'
		return right
	end 'useRight'
	panic("pickOperandType: cmp op has unresolved operandType after fillCmp and both filled operand types are unresolved — buildProducerTypes left a real producer untyped or the cmp predates its operands' producers")
end 'pickOperandType'

function fillBinop(module MaxonModule, opIdx OpIndex, result ByteArray, left ByteArray, right ByteArray, opKind BinOpKind, operandType MaxonType, range SourceRange, producerTypes ProducerTypeMap)
	if not isUnresolvedType(operandType) 'noChange'
		return
	end 'noChange'

	let filled = deriveBinopResultType(producerTypes, operandType: operandType, left: left, right: right)
	if isUnresolvedType(filled) 'stillUnresolved'
		panic("fillBinop: binop op '{String.from(result)}' has unresolved operandType after fillUnresolvedTypes and neither operand resolves through the producer-type map — left='{String.from(left)}' right='{String.from(right)}'. Likely a missing producer entry for a synthesized operand.")
	end 'stillUnresolved'

	try module.ops.set(opIdx, value: MaxonOp.binop(result, left: left, right: right, opKind: opKind, operandType: filled, range: range)) otherwise panic("fillBinop: ops.set OOB at idx={opIdx}")
end 'fillBinop'

function fillUnop(module MaxonModule, opIdx OpIndex, result ByteArray, operand ByteArray, opKind UnaryOpKind, operandType MaxonType, range SourceRange, producerTypes ProducerTypeMap)
	let filled = fillType(producerTypes, t: operandType, source: operand)
	if isUnresolvedType(filled) == isUnresolvedType(operandType) and not isUnresolvedType(operandType) 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.unop(result, operand: operand, opKind: opKind, operandType: filled, range: range)) otherwise panic("fillUnop: ops.set OOB at idx={opIdx}")
end 'fillUnop'

// Walk a call/methodCall arg-types vector and fill any unresolved entries
// from the producer-type map. Returns the (possibly new) arg-types vector
// and whether any entry was actually filled in. Shared by fillCall and
// fillMethodCall — the only difference between them was which op variant
// to emit when something changes.
function fillArgTypes(args ByteArrayArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, callerName String) returns (MaxonTypeArray, bool)
	var changed = false
	var newArgTypes = MaxonTypeArray.create()
	for i in 0 upto argTypes.count() 'each'
		let argType = try argTypes.get(i) otherwise panic("{callerName}: argTypes.get({i}) failed (count={argTypes.count()})")
		if isUnresolvedType(argType) 'fill'
			let arg = try args.get(i) otherwise panic("{callerName}: args.get({i}) failed")
			let filled = lookupProducerType(producerTypes, name: arg)
			newArgTypes.push(filled)
			if not isUnresolvedType(filled) 'wasFilled'
				changed = true
			end 'wasFilled'
		end 'fill' else 'keep'
			newArgTypes.push(argType)
		end 'keep'
	end 'each'
	return (newArgTypes, changed)
end 'fillArgTypes'

function fillCall(module MaxonModule, opIdx OpIndex, result ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, range SourceRange, producerTypes ProducerTypeMap)
	let (newArgTypes, changed) = fillArgTypes(args, argTypes: argTypes, producerTypes: producerTypes, callerName: "fillCall")
	if not changed 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.call(result, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: newArgTypes, argRanges: argRanges, range: range)) otherwise panic("fillCall: ops.set OOB at idx={opIdx}")
end 'fillCall'

function fillMethodCall(module MaxonModule, opIdx OpIndex, result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, range SourceRange, producerTypes ProducerTypeMap)
	let (newArgTypes, changed) = fillArgTypes(args, argTypes: argTypes, producerTypes: producerTypes, callerName: "fillMethodCall")
	if not changed 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.methodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: newArgTypes, argRanges: argRanges, range: range)) otherwise panic("fillMethodCall: ops.set OOB at idx={opIdx}")
end 'fillMethodCall'

// Phase 5 (multi-value-return error ABI): mirror of `fillMethodCall` for
// `tryMethodCall`. Re-emits the op with the SAME `errorBoundName` so the
// parser-emitted error-flag binding survives type resolution. Without this
// wrapper, the previous code path destructured `tryMethodCall` and called
// `fillMethodCall`, which writes back as `MaxonOp.methodCall` and silently
// drops the error-flag binding — downstream lowering then sees a plain
// methodCall and never calls `defineName(errorBoundName)`, producing the
// E3013 "unresolved value name" diagnostic when the parser-emitted `cmp`
// reads the never-bound flag.
function fillTryMethodCall(module MaxonModule, opIdx OpIndex, result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, range SourceRange, producerTypes ProducerTypeMap)
	let (newArgTypes, changed) = fillArgTypes(args, argTypes: argTypes, producerTypes: producerTypes, callerName: "fillTryMethodCall")
	if not changed 'noChange'
		return
	end 'noChange'
	try module.ops.set(opIdx, value: MaxonOp.tryMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: newArgTypes, argRanges: argRanges, errorBoundName: errorBoundName, range: range)) otherwise panic("fillTryMethodCall: ops.set OOB at idx={opIdx}")
end 'fillTryMethodCall'

export function isUnresolvedType(t MaxonType) returns bool
	return match t 'check'
		unresolved gives true
		boolean to function gives false
		typeParameter to opaquePointer gives false
	end 'check'
end 'isUnresolvedType'

// --- String-const consumer specialization ---
//
// After `unresolvedRead → stringConst` rewrites have run, the IR has
// `stringConst` producer ops whose results flow into `cmp` or
// `varDecl/varLoad` chains. This walk specializes the recognized
// consumers:
//   - `cmp(left, right, eq, …)` where both operands are stringConsts →
//     fold to `literal(0/1, integer)` via the cmp's existing operands.
//   - `varDecl(slot, stringConstResult, …)` records the slot's stringId
//     so subsequent `varLoad(result, slot, …)` aliases re-thread the id
//     into the consumer-rewrite chain.
// stringConst ops whose result feeds an unrecognized consumer survive
// to lowering as-is.

function specializeStringConstConsumers(module MaxonModule)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("specializeStringConstConsumers: funcIdx OOB")
		specializeFuncStringConsts(module, func: func)
	end 'eachFunc'
end 'specializeStringConstConsumers'

function specializeFuncStringConsts(module MaxonModule, func IrFunction)
	var nameStringIds = StringIdNameMap.create()
	var slotStringIds = SlotStringIdMap.create()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("specializeFuncStringConsts: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("specializeFuncStringConsts: opIdx OOB")
			specializeOp(module, opIdx: opIdx, op: op, nameStringIds: nameStringIds, slotStringIds: slotStringIds)
		end 'eachOp'
	end 'eachBlock'
end 'specializeFuncStringConsts'

function specializeOp(module MaxonModule, opIdx OpIndex, op MaxonOp, nameStringIds StringIdNameMap, slotStringIds SlotStringIdMap)
	match op 'specialize'
		stringConst(result, stringId, _) then nameStringIds.upsert(result, value: stringId)
		// Phase 7 step 6/7: charLiteral and byteStringLiteral both carry a
		// StringId, but their results are not String values — folding them
		// through the cmp specialization path would emit incorrect rewrites.
		// Skip them in the specializer; their normal lowering takes care of
		// constant materialization.
		charLiteral then return
		byteStringLiteral then return
		// Phase 7 step 5: an interpolated-string result is not a compile-time
		// stringConst — its bytes are computed at runtime. The specializer's
		// goal is to fold compile-time string constants through let/var slots
		// into cmp rewrites; an interp result has no fixed StringId, so
		// nothing to record here.
		stringInterp then return
		varDecl(slotId, value, _, _) then specializeVarDecl(slotStringIds, nameStringIds: nameStringIds, slotId: slotId, value: value)
		varLoad(result, slotId, _, _) then specializeVarLoad(slotStringIds, nameStringIds: nameStringIds, result: result, slotId: slotId)
		cmp(result, left, right, predicate, _, _, _, range) then specializeCmp(module, opIdx: opIdx, result: result, left: left, right: right, predicate: predicate, range: range, nameStringIds: nameStringIds)
		literal then return
		varStore then return
		globalLoad then return
		globalStore then return
		binop then return
		unop then return
		convert then return
		refEq then return
		condBr then return
		br then return
		call then return
		methodCall then return
		tryMethodCall then return
		ret then return
		panic then return
		panicDynamic then return
		structAlloc then return
		fieldLoad then return
		fieldStore then return
		selfFieldLoad then return
		selfFieldStore then return
		unresolvedRead then return
		unresolvedAssign then return
		enumMatchArm then return
		rangeMatchArm then return
		// Phase 9 Stage 2: union ops never carry a stringConst operand; the
		// specializer skips them. Stage 3+ may revisit if payload types
		// drive a string-fold opportunity.
		enumConstruct then return
		enumTag then return
		enumPayloadRead then return
		enumPayloadStore then return
		error then return
		throw then return
		tryCall then return
		rethrow then return
		// Stage E (closures): string-const consumer specialization for the
		// closure ops is not yet implemented. None of the four arms can
		// carry a string-const operand today (signatures are int-typed
		// pointers), but matching them explicitly keeps the exhaustive
		// match honest.
		functionRef then return
		closureCreate then return
		closureEnvLoad then return
		indirectCall then return
		forInIterable then return
		castCheck then return
	end 'specialize'
end 'specializeOp'

function specializeVarDecl(slotStringIds SlotStringIdMap, nameStringIds StringIdNameMap, slotId VarSlot, value ByteArray)
	if let stringId = try nameStringIds.get(value) 'has'
		slotStringIds.upsert(slotId, value: stringId)
	end 'has'
end 'specializeVarDecl'

function specializeVarLoad(slotStringIds SlotStringIdMap, nameStringIds StringIdNameMap, result ByteArray, slotId VarSlot)
	if let stringId = try slotStringIds.get(slotId) 'has'
		nameStringIds.upsert(result, value: stringId)
	end 'has'
end 'specializeVarLoad'

function specializeCmp(module MaxonModule, opIdx OpIndex, result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, range SourceRange, nameStringIds StringIdNameMap)
	if let leftId = try nameStringIds.get(left) 'leftIsStr'
		if let rightId = try nameStringIds.get(right) 'rightIsStr'
			let folded = stringCmpFold(predicate, leftId: leftId, rightId: rightId)
			try module.ops.set(opIdx, value: MaxonOp.literal(result, value: folded, valueType: MaxonType.integer, range: range)) otherwise panic("specializeCmp: ops.set OOB at idx={opIdx}")
		end 'rightIsStr'
	end 'leftIsStr'
end 'specializeCmp'

// Fold a compile-time string-vs-string comparison to 0/1. Only `eq`/`ne` are
// valid: ordering predicates (`<`, `<=`, `>`, `>=`) on strings are a type
// error caught upstream by validateCompareOp, so reaching this function with
// one is a compiler bug.
function stringCmpFold(predicate CmpPredicate, leftId StringId, rightId StringId) returns ParsedInt
	let equal = leftId == rightId
	return match predicate 'eval'
		eq gives boolToInt(equal)
		ne gives boolToInt(not equal)
		lt panic("stringCmpFold: ordering predicate 'lt' on string operands should have been rejected by validateCompareOp")
		le panic("stringCmpFold: ordering predicate 'le' on string operands should have been rejected by validateCompareOp")
		gt panic("stringCmpFold: ordering predicate 'gt' on string operands should have been rejected by validateCompareOp")
		ge panic("stringCmpFold: ordering predicate 'ge' on string operands should have been rejected by validateCompareOp")
	end 'eval'
end 'stringCmpFold'

function boolToInt(b bool) returns ParsedInt
	if b 'isTrue'
		return 1
	end 'isTrue'
	return 0
end 'boolToInt'

// --- Reference-equality dispatch ---
//
// The parser emits a regular `cmp` op for every `==` / `!=`. After
// fillUnresolvedTypes has run, both operand types are concrete and we
// can decide whether to rewrite the cmp into a struct-`.equals()`
// methodCall (for reference types) or leave it as a primitive cmp.
// `is` / `is not` already emit `refEq` directly; that op carries no
// types so a separate validation pass surfaces the
// "non-reference operand" diagnostic by walking refEq ops here.

function dispatchEqualityOps(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("dispatchEqualityOps: funcIdx OOB")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("dispatchEqualityOps: producerTypesPerFunc.get({funcIdx}) failed")
		dispatchFuncEqualityOps(project, module: module, func: func, producerTypes: producerTypes, filePath: filePath)
	end 'eachFunc'
end 'dispatchEqualityOps'

function dispatchFuncEqualityOps(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, filePath FilePath)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("dispatchFuncEqualityOps: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("dispatchFuncEqualityOps: opIdx OOB")
			dispatchEqualityForOp(project, module: module, opIdx: opIdx, op: op, producerTypes: producerTypes, filePath: filePath)
		end 'eachOp'
	end 'eachBlock'
end 'dispatchFuncEqualityOps'

function dispatchEqualityForOp(project Project, module MaxonModule, opIdx OpIndex, op MaxonOp, producerTypes ProducerTypeMap, filePath FilePath)
	if op.name == "cmp" 'isCmp'
		match op 'extract'
			cmp(result, left, right, predicate, leftType, rightType, _, range) then maybeRewriteCmpToEquals(project, module: module, opIdx: opIdx, result: result, left: left, right: right, predicate: predicate, leftType: leftType, rightType: rightType, range: range)
			default panic("unreachable: already checked name == cmp")
		end 'extract'
		return
	end 'isCmp'
	if op.name == "refEq" 'isRefEq'
		match op 'extract'
			refEq(_, left, right, _, range) then validateRefEqOperands(project, left: left, right: right, producerTypes: producerTypes, range: range, filePath: filePath)
			default panic("unreachable: already checked name == refEq")
		end 'extract'
	end 'isRefEq'
end 'dispatchEqualityForOp'

function maybeRewriteCmpToEquals(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, leftType MaxonType, rightType MaxonType, range SourceRange)
	if not maxonTypeIsRef(project, t: leftType) 'leftPrim'
		return
	end 'leftPrim'
	if not maxonTypeIsRef(project, t: rightType) 'rightPrim'
		return
	end 'rightPrim'
	// Only `==` (eq) and `!=` (ne) dispatch to `.equals()`; ordering
	// predicates (`<`, `<=`, `>`, `>=`) on struct types are a type error
	// caught downstream by validateCompareOp, so we leave those cmps as-is.
	let dispatch = match predicate 'classify'
		eq gives 1 as ParsedInt  // dispatch as ==
		ne gives -1  // dispatch as !=
		lt gives 0  // not dispatched
		le gives 0
		gt gives 0
		ge gives 0
	end 'classify'
	if dispatch == 0 'orderedOnRef'
		return
	end 'orderedOnRef'
	let isEq = dispatch == 1
	// Replace the cmp with a methodCall("equals"), and emit a follow-up
	// bitNot for `!=`. Both ops share the same source range as the
	// original cmp, anchored on the `==` / `!=` operator token.
	var equalsArgs = ByteArrayArray.create()
	equalsArgs.push(right)
	let equalsLabels = StringArray.create()
	var equalsArgTypes = MaxonTypeArray.create()
	equalsArgTypes.push(rightType)
	var equalsArgRanges = SourceRangeArray.create()
	equalsArgRanges.push(range)
	let methodName = project.calleeNames.intern("equals")
	if isEq 'eqDispatch'
		try module.ops.set(opIdx, value: MaxonOp.methodCall(result, receiver: left, methodName: methodName, args: equalsArgs, argLabels: equalsLabels, argTypes: equalsArgTypes, argRanges: equalsArgRanges, range: range)) otherwise panic("maybeRewriteCmpToEquals: ops.set OOB at idx={opIdx}")
		return
	end 'eqDispatch'
	// `!=`: rewrite into the methodCall first, then append a bitNot op
	// to negate its result. The bitNot ends up at the END of the ops
	// array (later than any consumer), but the consumer doesn't reach
	// the original `result` — it now reaches the bitNot's result. We
	// achieve this by giving the methodCall an intermediate name and
	// pointing the bitNot's result at the original `result`.
	let intermediateName = freshIntermediateNameForCmp(result)
	try module.ops.set(opIdx, value: MaxonOp.methodCall(intermediateName, receiver: left, methodName: methodName, args: equalsArgs, argLabels: equalsLabels, argTypes: equalsArgTypes, argRanges: equalsArgRanges, range: range)) otherwise panic("maybeRewriteCmpToEquals: ops.set OOB at idx={opIdx}")
	// Insert bitNot directly after the methodCall in the same block.
	insertBitNotAfter(module, opIdx: opIdx, result: result, operand: intermediateName, range: range)
end 'maybeRewriteCmpToEquals'

function freshIntermediateNameForCmp(result ByteArray) returns ByteArray
	// Synthesize a name based on the original result so the value-name
	// space stays roughly self-describing in IR dumps. The "$ne_"
	// prefix marks it as the masked methodCall feeding a bitNot.
	let synth = "$ne_{String.from(result)}"
	return synth.toByteArray()
end 'freshIntermediateNameForCmp'

function insertBitNotAfter(module MaxonModule, opIdx OpIndex, result ByteArray, operand ByteArray, range SourceRange)
	// Append a logicalNot op into the module's ops array AND register it
	// in whichever block owned the original cmp. We find the block by
	// scanning blockRefs — the cmp's index is in exactly one block's
	// opRefs. Logical-NOT (not bitwise) is required here: the operand is
	// the bool result of `equals`, and the consumer expects 0/1 — bitNot
	// on bool would produce -1/-2, both truthy.
	let bitNotIdx = module.ops.count()
	module.ops.push(MaxonOp.unop(result, operand: operand, opKind: UnaryOpKind.logicalNot, operandType: MaxonType.boolean, range: range))
	for blockRef in 0 upto module.blocks.count() 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("insertBitNotAfter: blockRef OOB")
		var insertPos = -1 as ParsedInt
		for posIdx in 0 upto block.opRefs.count() 'eachOpRef'
			let ref = try block.opRefs.get(posIdx) otherwise panic("insertBitNotAfter: posIdx OOB")
			if ref == opIdx 'foundCmp'
				insertPos = posIdx
				break
			end 'foundCmp'
		end 'eachOpRef'
		if insertPos >= 0 'doInsert'
			try block.opRefs.insert(insertPos + 1, value: bitNotIdx) otherwise panic("insertBitNotAfter: opRefs.insert OOB")
			return
		end 'doInsert'
	end 'eachBlock'
	panic("insertBitNotAfter: cmp op at idx={opIdx} not registered in any block")
end 'insertBitNotAfter'

// `is` / `is not` (refEq) requires both operands to be reference (struct)
// types. Operand types come from the producer-type map built earlier in
// this pass — by this point every cross-file struct ref has been resolved,
// so the check can't false-negative the way the parser's pre-migration
// version could.
function validateRefEqOperands(project Project, left ByteArray, right ByteArray, producerTypes ProducerTypeMap, range SourceRange, filePath FilePath)
	let leftType = lookupProducerType(producerTypes, name: left)
	let rightType = lookupProducerType(producerTypes, name: right)
	// Operand types still unresolved here means the producer chain itself
	// failed to resolve (e.g., a missing struct that already produced its
	// own diagnostic). Skip — the upstream error covers it.
	if isUnresolvedType(leftType) or isUnresolvedType(rightType) 'unresolved'
		return
	end 'unresolved'
	if maxonTypeIsRef(project, t: leftType) and maxonTypeIsRef(project, t: rightType) 'bothRef'
		return
	end 'bothRef'
	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "'is' requires reference types (structs), not primitive values", line: range.line, column: range.column, filePath: filePath)
end 'validateRefEqOperands'

// --- Arithmetic / bitwise binop operand-type validation ---
//
// Arithmetic operators (`+`, `-`, `*`, `/`, `mod`, `shl`, `shr`, `and`, `or`,
// `xor` as integer-bitwise) are not defined on struct-typed operands.
// `String` is the canonical struct case — users sometimes try `a + b` for
// string concatenation; the correct Maxon idiom is `"{a}{b}"` interpolation.
// Other structs (Character, user types) hit the same arm. Equality / ordering
// comparisons on structs route through `dispatchEqualityOps` /
// `maybeRewriteCmpToEquals` and so don't reach this check; the operand-type
// guard here only inspects `binop` ops.
function validateBinopOperandTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateBinopOperandTypes: funcIdx OOB")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateBinopOperandTypes: producerTypesPerFunc.get({funcIdx}) failed")
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateBinopOperandTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateBinopOperandTypes: opIdx OOB")
				if op.name != "binop" 'notBinop'
					continue
				end 'notBinop'
				match op 'extract'
					binop(_, left, right, opKind, operandType, range) then checkBinopOperands(project, left: left, right: right, opKind: opKind, operandType: operandType, range: range, producerTypes: producerTypes, filePath: filePath)
					default panic("unreachable: already checked name == binop")
				end 'extract'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateBinopOperandTypes'

function checkBinopOperands(project Project, left ByteArray, right ByteArray, opKind BinOpKind, operandType MaxonType, range SourceRange, producerTypes ProducerTypeMap, filePath FilePath)
	// Probe both operand sides since fillBinop's choice of `operandType` may
	// have favoured one operand; the actual offender we want to name in the
	// diagnostic is whichever side is a struct.
	let leftType = lookupProducerType(producerTypes, name: left)
	let rightType = lookupProducerType(producerTypes, name: right)
	let leftBlame = blameStructTypeName(project, t: leftType)
	if not leftBlame.isEmpty() 'leftBlamed'
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "operator '{binOpKindToSymbol(opKind)}' is not defined for type '{leftBlame}'", line: range.line, column: range.column, filePath: filePath)
		return
	end 'leftBlamed'
	let rightBlame = blameStructTypeName(project, t: rightType)
	if not rightBlame.isEmpty() 'rightBlamed'
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "operator '{binOpKindToSymbol(opKind)}' is not defined for type '{rightBlame}'", line: range.line, column: range.column, filePath: filePath)
		return
	end 'rightBlamed'
	// Fall back to the binop's own operandType field when neither operand
	// resolves through the producer-type map (synthesized binops where the
	// producer entry wasn't recorded).
	let opBlame = blameStructTypeName(project, t: operandType)
	if not opBlame.isEmpty() 'opBlamed'
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "operator '{binOpKindToSymbol(opKind)}' is not defined for type '{opBlame}'", line: range.line, column: range.column, filePath: filePath)
	end 'opBlamed'
end 'checkBinopOperands'

// Return the user-visible type name when `t` is a struct-typed operand that
// arithmetic / bitwise binops aren't defined on. `MaxonType.string` is the
// String primitive flag — early on, parser-emitted string ops carry this arm
// directly. Named structs (Character, user types) carry `named(id)` with the
// id resolving to a registered struct. Returns "" for primitives and for
// named arms that resolve to a non-struct (typealiases over int/float etc.).
function blameStructTypeName(project Project, t MaxonType) returns String
	return match t 'check'
		string gives "String"
		named(id) gives blameStructIfRegistered(project, id: id)
		boolean gives ""
		integer gives ""
		float gives ""
		function to opaquePointer gives ""
	end 'check'
end 'blameStructTypeName'

function blameStructIfRegistered(project Project, id TypeNameId) returns String
	let name = project.typeNames.get(id)
	if project.structTypes.contains(name) 'isStruct'
		return name
	end 'isStruct'
	return ""
end 'blameStructIfRegistered'

function binOpKindToSymbol(opKind BinOpKind) returns String
	return match opKind 'sym'
		add gives "+"
		sub gives "-"
		mul gives "*"
		div gives "/"
		mod gives "mod"
		bitAnd gives "and"
		bitOr gives "or"
		boolOr gives "or"
		bitXor gives "xor"
		shl gives "shl"
		shr gives "shr"
	end 'sym'
end 'binOpKindToSymbol'

// --- Self-field validation ---
//
// The parser emits selfFieldLoad / selfFieldStore ops without checking
// that the named field exists on the enclosing type. TypeResolution walks
// every method body's ops, derives the enclosing type from `func.name`
// (always `Type.method` for instance methods), and surfaces an "Unknown
// field" diagnostic when the recorded field name isn't present in the
// type's struct layout.

function validateSelfFields(project Project, module MaxonModule, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateSelfFields: funcIdx OOB")
		if let typeName = try enclosingTypeName(func.name) 'isMethod'
			let structType = try project.structTypes.get(typeName) otherwise continue
			validateFuncSelfFields(project, module: module, func: func, typeName: typeName, structType: structType, filePath: filePath)
		end 'isMethod'
	end 'eachFunc'
end 'validateSelfFields'

// Throws when the function name has no `.` (free function rather than a
// method). Caller uses `if let` to take the method-on-struct path.
function enclosingTypeName(funcName String) returns String throws EnclosingTypeError
	let dotIdx = try funcName.findLast(".") otherwise throw EnclosingTypeError.notAMethod
	return funcName.slice(funcName.startIndex(), endIndex: dotIdx)
end 'enclosingTypeName'

function validateFuncSelfFields(project Project, module MaxonModule, func IrFunction, typeName String, structType StructType, filePath FilePath)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("validateSelfFields: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("validateSelfFields: opIdx OOB")
			validateSelfFieldOp(project, op: op, typeName: typeName, structType: structType, filePath: filePath)
		end 'eachOp'
	end 'eachBlock'
end 'validateFuncSelfFields'

function validateSelfFieldOp(project Project, op MaxonOp, typeName String, structType StructType, filePath FilePath)
	if op.name == "selfFieldLoad" 'isLoad'
		match op 'extract'
			selfFieldLoad(_, fieldName, range) then validateSelfField(project, fieldName: String.from(fieldName), typeName: typeName, structType: structType, range: range, filePath: filePath)
			default panic("unreachable: already checked name == selfFieldLoad")
		end 'extract'
		return
	end 'isLoad'
	if op.name == "selfFieldStore" 'isStore'
		match op 'extract'
			selfFieldStore(fieldName, _, range) then validateSelfField(project, fieldName: String.from(fieldName), typeName: typeName, structType: structType, range: range, filePath: filePath)
			default panic("unreachable: already checked name == selfFieldStore")
		end 'extract'
	end 'isStore'
end 'validateSelfFieldOp'

function validateSelfField(project Project, fieldName String, typeName String, structType StructType, range SourceRange, filePath FilePath)
	if structType.fieldByName.contains(fieldName) 'known'
		return
	end 'known'
	reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown field '{fieldName}' in type '{typeName}'", line: range.line, column: range.column, filePath: filePath)
end 'validateSelfField'

// E3014: walk every fieldLoad/fieldStore and emit `cannot access unexported
// field` when the receiver's struct field is not marked `export` AND the
// access happens outside the type's own methods. Struct-literal init paths
// (`Value{field: ...}` lowered via `fieldStore` with `isInit: true`) stay
// unrestricted — the type's own shape determines which fields exist; only
// post-construction access is governed by visibility.
function validateFieldVisibility(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateFieldVisibility: funcIdx OOB")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateFieldVisibility: producerTypesPerFunc.get({funcIdx}) failed")
		// Compiler-synthesized helpers (struct-literal field-init, generic
		// monomorphization thunks, witness-table thunks) are attributed to
		// the virtual `stdlib-bootstrap.maxon` path. They synthesize field
		// reads/writes that aren't bound by source-level visibility — the
		// compiler is its own privileged access path. Skip them wholesale.
		if isStdlibBootstrapVirtualPath(func.sourceFilePath) 'syntheticHelper'
			continue
		end 'syntheticHelper'
		let enclosingType = try enclosingTypeName(func.name) otherwise ""
		// Synthesized functions (closure lifts, etc.) carry an empty
		// sourceFilePath; fall back to the module's compile-driver
		// filePath so diagnostics still anchor to a real file.
		var funcFilePath = filePath
		if not func.sourceFilePath.isEmpty() 'haveFuncPath'
			funcFilePath = func.sourceFilePath
		end 'haveFuncPath'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateFieldVisibility: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateFieldVisibility: opIdx OOB")
				if op.name == "fieldLoad" 'isLoad'
					match op 'extract'
						fieldLoad(_, receiver, fieldName, range) then validateFieldVisibilityOp(project, receiver: receiver, fieldName: String.from(fieldName), isInit: false, enclosingType: enclosingType, producerTypes: producerTypes, range: range, filePath: funcFilePath)
						default panic("unreachable: already checked name == fieldLoad")
					end 'extract'
				end 'isLoad' else if op.name == "fieldStore" 'isStore'
					match op 'extract'
						fieldStore(receiver, fieldName, _, isInit, range) then validateFieldVisibilityOp(project, receiver: receiver, fieldName: String.from(fieldName), isInit: isInit, enclosingType: enclosingType, producerTypes: producerTypes, range: range, filePath: funcFilePath)
						default panic("unreachable: already checked name == fieldStore")
					end 'extract'
				end 'isStore'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateFieldVisibility'

function validateFieldVisibilityOp(project Project, receiver ByteArray, fieldName String, isInit bool, enclosingType String, producerTypes ProducerTypeMap, range SourceRange, filePath FilePath)
	// Struct-literal init paths are always allowed; the type's shape
	// dictates what fields exist regardless of visibility.
	if isInit 'initAlwaysOk'
		return
	end 'initAlwaysOk'
	let receiverType = lookupProducerType(producerTypes, name: receiver)
	let structName = try maxonTypeStructName(project, t: receiverType) otherwise return
	// Inside the type's own methods every field is reachable — that's the
	// whole point of being a method on this type.
	if structName == enclosingType 'sameType'
		return
	end 'sameType'
	let structType = try project.structTypes.get(structName) otherwise return
	// Type-visibility gate: even before checking the field itself, the
	// reader must be able to see the receiver type. A cross-file static
	// factory (`InternalPoint.create(...)`) can return a value typed as
	// `InternalPoint` even when `InternalPoint` is file-scoped to its
	// declaring file — the C# bootstrap surfaces this at field-access time
	// as E4006 "Unknown type 'X' in field access chain". Mirror that here
	// so the cross-implementation diagnostic stays uniform.
	if not isVisibleFrom(structType.visibility, declFilePath: structType.sourceFilePath, readerFilePath: filePath) 'typeHidden'
		reportCompileError(project, code: ErrorCode.irInvalidFieldAccess, message: "Unknown type '{structName}' in field access chain", line: range.line, column: range.column, filePath: filePath)
		return
	end 'typeHidden'
	let fieldIdx = try structType.fieldByName.get(fieldName) otherwise return
	let field = try structType.fields.get(fieldIdx) otherwise return
	if field.isExported 'exported'
		return
	end 'exported'
	reportCompileError(project, code: ErrorCode.semanticUnexportedFieldAccess, message: "cannot access unexported field: '{fieldName}' outside of type '{structName}'", line: range.line, column: range.column, filePath: filePath)
end 'validateFieldVisibilityOp'

// --- Top-level let resolution ---
//
// The parser captures every top-level `let NAME = <init>` and `var NAME =
// <init>` (plus their `static` field analogues) as an
// `UnresolvedTopLevelDecl` entry without resolving identifier references in
// the initializer. This pass walks the registry with DFS + a visiting
// stack, evaluates each initializer in dependency order, and routes the
// result either to `project.topLevelConstants` (immutable lets) or
// `project.topLevelVars` (mutable vars) based on the entry's `mutable` flag.
// Cycles among let initializers surface as E2012 (parserCircularDependency).
//
// Project-wide and idempotent: only the first call drains the registry;
// later per-module calls walk an empty map.

function resolveAllTopLevelDecls(project Project)
	if project.unresolvedTopLevelDecls.count() == 0 'alreadyDone'
		return
	end 'alreadyDone'

	var evaluating = StringArray.create()

	// Snapshot key set up-front: we'll be removing entries as we evaluate
	// them, and iterating-while-removing is unsafe for the underlying map.
	var names = StringArray.create()
	for (name, _) in project.unresolvedTopLevelDecls 'collect'
		names.push(name)
	end 'collect'

	for name in names 'evalEach'
		_ = evaluateTopLevelDecl(project, name: name, evaluating: evaluating)
	end 'evalEach'

	// Drain anything still left (cycle victims): we leave them out of
	// `topLevelConstants` / `topLevelVars`, so downstream
	// `rewriteUnresolvedRead` reports the standard "Undefined name"
	// diagnostic for any reader that survives the parser-stage error gate.
	var leftover = StringArray.create()
	for (name, _) in project.unresolvedTopLevelDecls 'collectLeft'
		leftover.push(name)
	end 'collectLeft'
	for name in leftover 'drop'
		_ = project.unresolvedTopLevelDecls.remove(name)
	end 'drop'
end 'resolveAllTopLevelDecls'

// Evaluate a single top-level decl by name. Returns the folded
// ConstantValue so a caller stuck in a `nameRef` chain can keep walking
// without re-entering the registry. Routing to the destination map is
// dispatched on `entry.mutable`.
// `evaluating` is the DFS visit stack; the cycle diagnostic lists every
// name on the stack joined with ", " — matching the C# bootstrap's output
// at maxon-sharp/Compiler/2-Parser.cs:4517-4521.
function evaluateTopLevelDecl(project Project, name String, evaluating StringArray) returns ConstantValue
	if let cached = try project.topLevelConstants.get(name) 'cached'
		return cached.value
	end 'cached'

	let entry = try project.unresolvedTopLevelDecls.get(name) otherwise return ConstantValue.intValue(0)

	if evaluating.contains(name) 'cycle'
		let cycleNames = joinStringArray(evaluating, sep: ", ")
		reportCompileError(project, code: ErrorCode.parserCircularDependency, message: "Circular dependency detected among global constants: {cycleNames}", line: entry.line, column: entry.column, filePath: entry.filePath)
		return ConstantValue.intValue(0)
	end 'cycle'

	evaluating.push(name)
	let result = evaluateUnresolvedConstExpr(project, exprId: entry.rootExprId, evaluating: evaluating)
	_ = try evaluating.pop() otherwise panic("evaluateTopLevelDecl: stack underflow popping '{name}'")

	if entry.mutable 'asGlobal'
		let slotType = inferSlotTypeFromExpr(project, exprId: entry.rootExprId, value: result)
		let initialValue = constantValueToInitialBits(result)
		let info = TopLevelVarInfo.create(name, slotType: slotType, initialValue: initialValue, visibility: entry.visibility, sourceFilePath: entry.filePath)
		try project.topLevelVars.insert(name, value: info) otherwise ignore
	end 'asGlobal' else 'asConst'
		let constEntry = TopLevelConstant.create(result, visibility: entry.visibility, sourceFilePath: entry.filePath)
		try project.topLevelConstants.insert(name, value: constEntry) otherwise ignore
	end 'asConst'
	_ = project.unresolvedTopLevelDecls.remove(name)
	return result
end 'evaluateTopLevelDecl'

// Walk the expression arena recursively. Literal arms return their value
// directly; `nameRef(target)` recurses into `evaluateTopLevelDecl` so cycle
// detection composes naturally.
function evaluateUnresolvedConstExpr(project Project, exprId UnresolvedConstExprId, evaluating StringArray) returns ConstantValue
	let node = try project.unresolvedConstExprs.get(exprId) otherwise panic("evaluateUnresolvedConstExpr: arena get OOB at id={exprId}")
	match node 'eval'
		intLit(value) then return ConstantValue.intValue(value)
		boolLit(value) then return ConstantValue.intValue(1 if value else 0)
		stringLit(stringId) then return ConstantValue.stringValue(stringId)
		floatLit(bits) then return ConstantValue.floatValue(bits)
		nameRef(target) then return evaluateTopLevelDecl(project, name: target, evaluating: evaluating)
		enumCase(enumName, caseName) then return evaluateEnumCaseConst(project, enumName: enumName, caseName: caseName)
		asCast(operand, typeName) then return evaluateAsCast(project, operandId: operand, typeName: typeName, evaluating: evaluating)
		negate(operand) then return ConstantValue.intValue(0 - evalChildAsInt(project, exprId: operand, evaluating: evaluating))
		notOp(operand) then return ConstantValue.intValue(not evalChildAsInt(project, exprId: operand, evaluating: evaluating))
		add(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) + evalChildAsInt(project, exprId: right, evaluating: evaluating))
		sub(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) - evalChildAsInt(project, exprId: right, evaluating: evaluating))
		mul(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) * evalChildAsInt(project, exprId: right, evaluating: evaluating))
		compareEq(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) == evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		compareNeq(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) != evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		compareLt(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) < evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		compareLte(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) <= evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		compareGt(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) > evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		compareGte(left, right) then return ConstantValue.intValue(1 if evalChildAsInt(project, exprId: left, evaluating: evaluating) >= evalChildAsInt(project, exprId: right, evaluating: evaluating) else 0)
		logicalAnd(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) and evalChildAsInt(project, exprId: right, evaluating: evaluating))
		logicalXor(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) xor evalChildAsInt(project, exprId: right, evaluating: evaluating))
		logicalOr(left, right) then return ConstantValue.intValue(evalChildAsInt(project, exprId: left, evaluating: evaluating) or evalChildAsInt(project, exprId: right, evaluating: evaluating))
		// Phase 9 Stage 5: `structLit` arena entries only appear as the
		// root (or recursive sub-expression) of an enum-case struct-backing
		// literal. Top-level let/var initializers can't construct struct
		// literals — they go through the regular runtime parser
		// (`parseStructLiteral`) — so reaching this arm in the const-fold
		// walk is a parser-side invariant violation.
		structLit then panic("evaluateUnresolvedConstExpr: structLit reached the top-level constant evaluator — struct-backing literals are walked through the per-case struct accessor path instead")
	end 'eval'
end 'evaluateUnresolvedConstExpr'

// Look up `EnumName.caseName` in the project's already-populated
// topLevelConstants map (the enum-decl parser inserted these entries the
// moment it saw the case). Falls back to intValue(0) if the reference is
// dangling — TypeResolution's later validation walk catches the typo as a
// runtime-side `unresolvedRead` rejection.
function evaluateEnumCaseConst(project Project, enumName String, caseName String) returns ConstantValue
	let qualifiedName = "{enumName}.{caseName}"
	if let entry = try project.topLevelConstants.get(qualifiedName) 'found'
		return entry.value
	end 'found'
	return ConstantValue.intValue(0)
end 'evaluateEnumCaseConst'

// Apply an `as TypeName` cast to a const-folded operand. Built-in primitives
// (int/float/byte/bool) re-tag without changing the bit pattern. Identifier
// targets resolve through `project.typealiases`; ranged typealiases
// additionally validate the operand against the declared bounds. Range
// violations are reported below; unknown identifiers fall through and let
// the downstream load-site machinery surface the missing-type diagnostic
// (the cast is structurally valid; only the type name is wrong, which the
// global-var slot-type path catches when resolveTypes touches the named
// MaxonType).
function evaluateAsCast(project Project, operandId UnresolvedConstExprId, typeName String, evaluating StringArray) returns ConstantValue
	let inner = evaluateUnresolvedConstExpr(project, exprId: operandId, evaluating: evaluating)
	if isBuiltinPrimitiveTypeName(typeName) 'isPrim'
		return inner
	end 'isPrim'
	if let range = try project.typealiasRanges.get(typeName) 'hasRange'
		validateCastInRange(project, value: inner, range: range, typeName: typeName)
	end 'hasRange'
	return inner
end 'evaluateAsCast'

// True for the source-level keywords that name a primitive type without an
// alias — these are accepted as identity casts in const expressions, with
// no range check.
function isBuiltinPrimitiveTypeName(name String) returns bool
	return name == "int" or name == "float" or name == "bool" or name == "byte"
end 'isBuiltinPrimitiveTypeName'

// Range-check a const-folded operand against a typealias's declared bounds.
// Float operands are not range-validated here — float-backed aliases lack
// usable IEEE bounds in the const-fold representation, and the runtime
// cast still emits the validation at load sites.
function validateCastInRange(project Project, value ConstantValue, range TypealiasRange, typeName String)
	match value 'kind'
		intValue(v) then validateIntInRange(project, value: v, range: range, typeName: typeName)
		floatValue then return
		stringValue then return
	end 'kind'
end 'validateCastInRange'

function validateIntInRange(project Project, value IntConstant, range TypealiasRange, typeName String)
	// Unsigned-wrapped upper: `0 to u64.max` stores `range.upper` as the
	// wrapped value -1; with `range.lower >= 0` this represents the full
	// unsigned span, so any non-negative `value` is in range. (Mirrors the
	// parser's `isInvalidIntRange` unsigned-aware check.)
	let unsignedUpper = range.lower >= 0 and range.upper < 0
	let belowLower = value < range.lower
	var aboveUpper = false
	if unsignedUpper 'unsigned'
		aboveUpper = value < 0
	end 'unsigned' else 'signed'
		aboveUpper = value > range.upper
	end 'signed'
	if belowLower or aboveUpper 'oor'
		// No exact token span is available here — the cast was folded from
		// an UnresolvedConstExpr arena that doesn't carry source positions.
		// Anchor the diagnostic at a synthetic `__const_eval__` virtual path
		// so the message format matches other compile-error reports without
		// fabricating a real-file line:column the user can't open.
		let bootstrapPath = try FilePath.from("__const_eval__") otherwise panic("validateIntInRange: bootstrap virtual path rejected")
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Value {value} is outside the range of '{typeName}' ({range.lower} to {range.upper})", line: 0, column: 0, filePath: bootstrapPath)
	end 'oor'
end 'validateIntInRange'

// Recursive helper used by every arithmetic / unary / comparison /
// logical arm above. Composing the eval-then-unwrap pair into one call
// keeps the match arms short and keeps the "operand must be int"
// invariant in a single place. Every binary / unary operator node in
// `UnresolvedConstExpr` is only emitted after parseConstAtom has accepted
// an int- or bool-typed atom (booleans are stored as `intValue(0|1)`),
// so reaching a non-int operand here is an invariant violation, not a
// user error.
function evalChildAsInt(project Project, exprId UnresolvedConstExprId, evaluating StringArray) returns IntConstant
	return match evaluateUnresolvedConstExpr(project, exprId: exprId, evaluating: evaluating) 'kind'
		intValue(x) gives x
		default panic("const folder reached non-int operand: only intValue arms are valid for arithmetic / unary const folding")
	end 'kind'
end 'evalChildAsInt'

// Pick the source-level MaxonType the global's slot should carry. Four
// outermost arena nodes pin the type structurally (`asCast` names the
// target alias, `boolLit` / `floatLit` give the literal kind, `enumCase`
// names the enum). Every other arm falls back to the folded
// ConstantValue's runtime tag — sufficient for plain int / float
// arithmetic, comparisons, and `nameRef` chains that resolve through
// `topLevelConstants`.
function inferSlotTypeFromExpr(project Project, exprId UnresolvedConstExprId, value ConstantValue) returns MaxonType
	let node = try project.unresolvedConstExprs.get(exprId) otherwise panic("inferSlotTypeFromExpr: arena get OOB at id={exprId}")
	match node 'pick'
		asCast(_, typeName) then return slotTypeForCastTarget(project, typeName: typeName)
		boolLit then return MaxonType.boolean
		floatLit then return MaxonType.float
		enumCase(enumName, _) then return internMaxonType(project, name: enumName)
		intLit to logicalOr then return slotTypeFromConstantValue(value)
		// Phase 9 Stage 5: `structLit` arena entries are reserved for
		// enum-case struct backing literals and never appear at the root
		// of a top-level `let` / `var` initializer (caller path). Reach
		// this arm and we have a parser-side invariant violation.
		structLit then panic("inferSlotTypeFromExpr: structLit reached top-level slot-type inference — struct backings are not top-level constants")
	end 'pick'
end 'inferSlotTypeFromExpr'

function slotTypeForCastTarget(project Project, typeName String) returns MaxonType
	if typeName == "bool" 'b'
		return MaxonType.boolean
	end 'b'
	if typeName == "float" 'f'
		return MaxonType.float
	end 'f'
	if typeName == "int" or typeName == "byte" 'i'
		return MaxonType.integer
	end 'i'
	return internMaxonType(project, name: typeName)
end 'slotTypeForCastTarget'

function slotTypeFromConstantValue(value ConstantValue) returns MaxonType
	return match value 'kind'
		intValue gives MaxonType.integer
		floatValue gives MaxonType.float
		stringValue gives MaxonType.string
	end 'kind'
end 'slotTypeFromConstantValue'

// Pack a ConstantValue into the 8-byte payload `TopLevelVarInfo.initialValue`
// expects. Integer / bool values carry their value directly; float values
// store the IEEE 754 bits in the same i64 slot; strings would need a
// separate path (no .data slot today) and surface via a panic if reached.
function constantValueToInitialBits(value ConstantValue) returns IntConstant
	match value 'pack'
		intValue(v) then return v
		floatValue(bits) then return bits
		stringValue then panic("constantValueToInitialBits: string-typed top-level var initializer reached the global lowering path; static-variables only supports int / bool / float / enum / ranged-cast initializers")
	end 'pack'
end 'constantValueToInitialBits'

function joinStringArray(arr StringArray, sep String) returns String
	var result = ""
	var first = true
	for s in arr 'each'
		if first 'isFirst'
			result = "{s}"
			first = false
		end 'isFirst' else 'rest'
			result = "{result}{sep}{s}"
		end 'rest'
	end 'each'
	return result
end 'joinStringArray'

// Walk every top-level array-literal initializer's `globalStore` op and
// patch `topLevelVars[name].slotType` from the producer of the stored
// value — that producer is the `{arrayType}.init` call op the parser
// emitted as the literal's final synthesizing step. Looking up the
// callee's return type in `project.funcReturnTypes` recovers the concrete
// slot type without requiring `fillUnresolvedTypes` to run yet.
//
// Idempotent on entries whose slot type is already concrete (other paths
// through `resolveAllTopLevelDecls` infer the slot type from the const-fold
// arena), and bails cleanly for any globalStore whose producer can't be
// pin-pointed (e.g. a hypothetical future top-level decl that lowers
// through a different op shape).
function preResolveArrayLiteralSlotTypes(project Project, module MaxonModule)
	// Iterate per-function so the funcName context is preserved when we
	// look up the array-literal entry. A flat module.ops walk would lose
	// that context — and in batched compiles two `__module_init_<n>`
	// funcs can mint identical `$tN` value names because freshSynthName
	// resets per function, so a bare-name lookup would route to the
	// wrong literal's elements.
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("preResolveArrayLiteralSlotTypes: funcIdx OOB at {funcIdx}")
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("preResolveArrayLiteralSlotTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("preResolveArrayLiteralSlotTypes: ops.get OOB")
				if op.name != "globalStore" 'notStore'
					continue
				end 'notStore'
				match op 'pickStore'
					globalStore(name, value, _, _) then preResolveSlotFromGlobalStore(project, module: module, func: func, name: name, value: value)
					default panic("preResolveArrayLiteralSlotTypes: globalStore match failed")
				end 'pickStore'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'preResolveArrayLiteralSlotTypes'

function preResolveSlotFromGlobalStore(project Project, module MaxonModule, func IrFunction, name String, value ByteArray)
	let info = try project.topLevelVars.get(name) otherwise return
	if not isUnresolvedType(info.slotType) 'alreadyResolved'
		return
	end 'alreadyResolved'
	// Array-literal initializers are special-cased: the parser recorded
	// each literal's structural pieces in `arrayLiteralProducers`, and
	// the literal's element value names point at IR ops that are right
	// here in the same module. A self-contained mini-walk types the
	// elements (currently: stringConst → String, literal → its
	// valueType arm), unifies, and emits a concrete
	// `genericInstance(<arrayType>, [E])` — no dependency on the
	// producer-type pass that hasn't run yet. Falls through to the
	// regular `funcReturnTypes` lookup when the literal's elements
	// aren't all parser-typed (e.g. include a method-call result), at
	// which point `backfillTopLevelVarSlotTypes` finishes the job after
	// `fillUnresolvedTypes` runs.
	if let entry = try lookupArrayLiteralProducer(project, funcName: func.name, name: value) 'isArrayLit'
		if let element = try unifyArrayLiteralElementsFromModule(project, module: module, func: func, entry: entry) 'gotElement'
			let pinned = internSingleArgGenericInstance(project, baseTypeName: entry.arrayTypeName, elementType: element)
			patchTopLevelVarSlotType(project, name: name, slotType: pinned)
			return
		end 'gotElement'
	end 'isArrayLit'
	// Map-literal initializers: same parser-side sidecar pattern as
	// arrays, except the literal carries two axes. Both axes' element
	// types must unify before we can pin a concrete
	// `genericInstance(<mapType>, [Key, Value])` shape.
	if let entry = try lookupMapLiteralProducer(project, funcName: func.name, name: value) 'isMapLit'
		if let pinned = try unifyMapLiteralFromModule(project, module: module, func: func, entry: entry) 'gotMap'
			patchTopLevelVarSlotType(project, name: name, slotType: pinned)
			return
		end 'gotMap'
	end 'isMapLit'
	// Stage K.X.A: The value's producer is a call/tryCall the parser
	// emitted into the same `__module_init_<n>` function. Synthesized
	// names like `$t1` reset per-function, so a flat module-wide walk
	// would match any unrelated stdlib call with the same result name and
	// patch the slot to its return type. Restrict the search to this
	// func's blocks so the producer-lookup is unambiguous. Also accept
	// `tryCall` producers, since the parser may emit either shape for
	// throwing initializers.
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("preResolveSlotFromGlobalStore: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("preResolveSlotFromGlobalStore: ops.get OOB")
			if op.name != "call" and op.name != "tryCall" 'notCallShape'
				continue
			end 'notCallShape'
			match op 'extractCall'
				call(result, callee, _, _, _, _, _, _) then maybePatchFromCall(project, name: name, result: result, callee: callee, value: value)
				tryCall(result, callee, _, _, _, _, _, _, _) then maybePatchFromCall(project, name: name, result: result, callee: callee, value: value)
				default panic("preResolveSlotFromGlobalStore: name check accepted op shape but match did not extract")
			end 'extractCall'
		end 'eachOp'
	end 'eachBlock'
end 'preResolveSlotFromGlobalStore'

function maybePatchFromCall(project Project, name String, result ByteArray, callee ByteArray, value ByteArray)
	// Compare result-name slices: ByteArray equality matches the underlying
	// bytes, so `result == value` is true exactly when this call produced
	// the value the globalStore is about to store.
	if not (result == value) 'notProducer'
		return
	end 'notProducer'
	let calleeName = String.from(callee)
	if let retType = try project.funcReturnTypes.get(calleeName) 'gotReturn'
		match retType 'unwrap'
			value(inner) then patchTopLevelVarSlotType(project, name: name, slotType: inner)
			void then return
		end 'unwrap'
	end 'gotReturn'
end 'maybePatchFromCall'

function backfillTopLevelVarSlotTypes(project Project, module MaxonModule)
	// Pass 1: walk every globalStore per-function and patch the matching
	// topLevelVars entry. After this every entry whose initializer was
	// emitted into a `__module_init_<n>` function carries the concrete
	// `T` from `T.init(mm)` rather than the parser's placeholder
	// unresolved. Per-function iteration preserves the funcName context
	// used to disambiguate `arrayLiteralProducers` keys (see
	// `lookupArrayLiteralProducer` for the collision rationale).
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("backfillTopLevelVarSlotTypes: funcIdx OOB at {funcIdx}")
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("backfillTopLevelVarSlotTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("backfillTopLevelVarSlotTypes: ops.get OOB at idx={opIdx}")
				if op.name != "globalStore" 'notGlobalStore'
					continue
				end 'notGlobalStore'
				match op 'pickShape'
					globalStore(name, value, slotType, _) then refineTopLevelArrayLiteralSlotType(project, module: module, func: func, name: name, value: value, fallbackSlotType: slotType)
					default panic("backfillTopLevelVarSlotTypes: op.name == globalStore but match did not extract")
				end 'pickShape'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'

	// Pass 2: walk every globalLoad op and rewrite any whose slotType is
	// still unresolved using the now-concrete topLevelVars entry. The
	// `rewriteUnresolvedRead` pass that produced these globalLoads ran
	// against the parser's pre-backfill topLevelVars snapshot, so user
	// reads of an array-literal-initialized name carry an unresolved
	// slotType into lowering and trip `resolveMaxonTypeToStd`'s invariant.
	for opIdx in 0 upto module.ops.count() 'eachLoad'
		let op = try module.ops.get(opIdx) otherwise panic("backfillTopLevelVarSlotTypes: ops.get OOB at idx={opIdx}")
		if op.name != "globalLoad" 'notGlobalLoad'
			continue
		end 'notGlobalLoad'
		match op 'pickShape'
			globalLoad(result, name, slotType, range) then patchGlobalLoadSlotType(project, module: module, opIdx: opIdx, result: result, name: name, slotType: slotType, range: range)
			default panic("backfillTopLevelVarSlotTypes: op.name == globalLoad but match did not extract")
		end 'pickShape'
	end 'eachLoad'
end 'backfillTopLevelVarSlotTypes'

// Refine a top-level globalStore's slot type. Prefers the
// genericInstance recovered from re-walking the array-literal entry's
// elements with their now-fully-typed producer types; falls back to the
// fillGlobalStore-stamped slotType when the value isn't an array-literal
// init result. Without the re-walk, an array literal whose elements are
// references to other top-level lets (`let xs = [FIRST, SECOND]`) lands
// with `named(Array)` because element types weren't resolved at
// buildProducerTypes time.
function refineTopLevelArrayLiteralSlotType(project Project, module MaxonModule, func IrFunction, name String, value ByteArray, fallbackSlotType MaxonType)
	if let entry = try lookupArrayLiteralProducer(project, funcName: func.name, name: value) 'isArrayLit'
		if let element = try unifyArrayLiteralElementsFromTypedOps(project, module: module, func: func, entry: entry) 'gotElement'
			let pinned = internSingleArgGenericInstance(project, baseTypeName: entry.arrayTypeName, elementType: element)
			patchTopLevelVarSlotType(project, name: name, slotType: pinned)
			return
		end 'gotElement'
	end 'isArrayLit'
	if let entry = try lookupMapLiteralProducer(project, funcName: func.name, name: value) 'isMapLit'
		if let pinned = try unifyMapLiteralFromTypedOps(project, module: module, func: func, entry: entry) 'gotMap'
			patchTopLevelVarSlotType(project, name: name, slotType: pinned)
			return
		end 'gotMap'
	end 'isMapLit'
	patchTopLevelVarSlotType(project, name: name, slotType: fallbackSlotType)
end 'refineTopLevelArrayLiteralSlotType'

// Mirror of `unifyArrayLiteralElementsFromTypedOps` for map literals.
// Reads each axis's already-registered ArrayLiteralProducer entry and
// re-unifies its elements against the post-fillUnresolvedTypes op stamps.
function unifyMapLiteralFromTypedOps(project Project, module MaxonModule, func IrFunction, entry MapLiteralProducer) returns MaxonType throws ArrayLiteralLookupError
	let keyEntry = try project.arrayLiteralProducers.get(arrayLiteralProducerKey(func.name, valueName: entry.keyMmResultName)) otherwise throw ArrayLiteralLookupError.notFound
	let valueEntry = try project.arrayLiteralProducers.get(arrayLiteralProducerKey(func.name, valueName: entry.valueMmResultName)) otherwise throw ArrayLiteralLookupError.notFound
	let keyType = try unifyArrayLiteralElementsFromTypedOps(project, module: module, func: func, entry: keyEntry)
	let valueType = try unifyArrayLiteralElementsFromTypedOps(project, module: module, func: func, entry: valueEntry)
	return internTwoArgGenericInstance(project, baseTypeName: entry.mapTypeName, keyType: keyType, valueType: valueType)
end 'unifyMapLiteralFromTypedOps'

// Re-unify an array literal's element types against the module's
// post-fillUnresolvedTypes ops. Mirrors `unifyArrayLiteralElementsFromModule`
// but reads from the patched op stamps (varLoad/globalLoad slotTypes,
// methodCall result types via the func return registry) rather than the
// stale parse-time stamps. Used by `backfillTopLevelVarSlotTypes` to
// recover the genericInstance shape for top-level array literals whose
// elements are references to other top-level lets.
function unifyArrayLiteralElementsFromTypedOps(project Project, module MaxonModule, func IrFunction, entry ArrayLiteralProducer) returns MaxonType throws ArrayLiteralLookupError
	var unified = MaxonType.unresolved
	for i in 0 upto entry.elemNames.count() 'walk'
		let elemName = try entry.elemNames.get(i) otherwise panic("unifyArrayLiteralElementsFromTypedOps: elemNames.get OOB at {i}")
		let t = try typedResultOfValueInFunction(project, module: module, func: func, name: elemName) otherwise throw ArrayLiteralLookupError.cannotUnify
		if isUnresolvedType(unified) 'firstConcrete'
			unified = t
			continue
		end 'firstConcrete'
		if not maxonTypesStructurallyEqual(unified, b: t) 'mismatch'
			throw ArrayLiteralLookupError.cannotUnify
		end 'mismatch'
	end 'walk'
	if isUnresolvedType(unified) 'allUnresolved'
		throw ArrayLiteralLookupError.cannotUnify
	end 'allUnresolved'
	return unified
end 'unifyArrayLiteralElementsFromTypedOps'

// Find the producer op that defines `name` within `func` and return its
// now-concrete result type. Reads from the stamped slotType for
// varLoad/globalLoad ops and the parser's valueType for literal ops, so
// it inherits the resolution work `fillUnresolvedTypes` did. Scoped to
// `func` because `freshSynthName`'s per-function counter resets between
// functions — see `staticTypeOfValueInFunction` for the same rationale.
// Throws `cannotUnify` for op shapes whose result type can't be cheaply
// derived (call results would require a cache of the per-op resolution;
// not yet wired).
function typedResultOfValueInFunction(project Project, module MaxonModule, func IrFunction, name ByteArray) returns MaxonType throws ArrayLiteralLookupError
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("typedResultOfValueInFunction: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("typedResultOfValueInFunction: opIdx OOB at {opIdx}")
			if let t = try typedResultFromOpIfMatches(project, op: op, name: name) 'hit'
				return t
			end 'hit'
		end 'eachOp'
	end 'eachBlock'
	throw ArrayLiteralLookupError.cannotUnify
end 'typedResultOfValueInFunction'

function typedResultFromOpIfMatches(project Project, op MaxonOp, name ByteArray) returns MaxonType throws ArrayLiteralLookupError
	match op 'pick'
		literal(result, _, valueType, _) then return try staticTypedResult(name, result: result, t: valueType)
		stringConst(result, _, _) then return try staticTypedResult(name, result: result, t: stringConstResultType(project))
		charLiteral(result, _, _) then return try staticTypedResult(name, result: result, t: MaxonType.named(project.typeNames.intern("Character")))
		byteStringLiteral(result, _, _) then return try staticTypedResult(name, result: result, t: byteStringLiteralResultType(project))
		varLoad(result, _, slotType, _) then return try staticTypedResult(name, result: result, t: slotType)
		globalLoad(result, _, slotType, _) then return try staticTypedResult(name, result: result, t: slotType)
		stringInterp(result, _, _) then return try staticTypedResult(name, result: result, t: stringConstResultType(project))
		default throws ArrayLiteralLookupError.cannotUnify
	end 'pick'
end 'typedResultFromOpIfMatches'

function patchGlobalLoadSlotType(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, name String, slotType MaxonType, range SourceRange)
	if let info = try project.topLevelVars.get(name) 'hasEntry'
		if isUnresolvedType(info.slotType) 'stillUnresolved'
			return
		end 'stillUnresolved'
		// Always propagate the topLevelVar's now-concrete entry: Pass 1
		// of `backfillTopLevelVarSlotTypes` may have refined `named(X)`
		// → `genericInstance(X, [...])` for top-level array literals
		// whose elements only became typed after fillUnresolvedTypes.
		// fillUnresolvedTypes stamps the globalLoad's slotType from the
		// pre-refine entry, so we re-patch unconditionally here.
		if maxonTypesStructurallyEqual(info.slotType, b: slotType) 'alreadyMatches'
			return
		end 'alreadyMatches'
		try module.ops.set(opIdx, value: MaxonOp.globalLoad(result, name: name, slotType: info.slotType, range: range)) otherwise panic("patchGlobalLoadSlotType: ops.set OOB at idx={opIdx}")
	end 'hasEntry'
end 'patchGlobalLoadSlotType'

function patchTopLevelVarSlotType(project Project, name String, slotType MaxonType)
	if isUnresolvedType(slotType) 'stillUnresolved'
		return
	end 'stillUnresolved'
	if let info = try project.topLevelVars.get(name) 'hasEntry'
		if not isUnresolvedType(info.slotType) 'alreadyResolved'
			// Allow refinement when the new type is strictly more
			// specific: a bare `named(Array)` from the early pre-resolve
			// pass yields to the later `genericInstance(Array, [E])` the
			// backfill computes from the typed globalStore op. Other
			// transitions are rejected so an out-of-order producer-type
			// fill can't smash a known concrete type with garbage.
			if maxonTypeIsRefinementOf(project, existing: info.slotType, refined: slotType) 'isRefinement'
				let patched = TopLevelVarInfo.create(info.name, slotType: slotType, initialValue: info.initialValue, visibility: info.visibility, sourceFilePath: info.sourceFilePath)
				project.topLevelVars.upsert(name, value: patched)
			end 'isRefinement'
			return
		end 'alreadyResolved'
		let patched = TopLevelVarInfo.create(info.name, slotType: slotType, initialValue: info.initialValue, visibility: info.visibility, sourceFilePath: info.sourceFilePath)
		project.topLevelVars.upsert(name, value: patched)
	end 'hasEntry'
end 'patchTopLevelVarSlotType'

// True iff `refined` is strictly more specific than `existing` for
// top-level slot-type refinement purposes. Currently the only allowed
// promotion is `named(X)` → `genericInstance(X, [...])` — i.e. the
// pre-resolve pass guessed a bare named type from `funcReturnTypes` and
// the later backfill recovered the literal's element binding.
function maxonTypeIsRefinementOf(project Project, existing MaxonType, refined MaxonType) returns bool
	let existingName = existing.nameOrEmpty(project)
	let refinedName = refined.nameOrEmpty(project)
	if existingName.isEmpty() or refinedName.isEmpty() 'noName'
		return false
	end 'noName'
	if existingName != refinedName 'differentBase'
		return false
	end 'differentBase'
	return match existing 'pickExisting'
		named gives match refined 'pickRefined'
			genericInstance gives true
			boolean to string gives false
			named gives false
			function to unresolved gives false
			typeParameter gives false
			interface to opaquePointer gives false
		end 'pickRefined'
		boolean to string gives false
		function to opaquePointer gives false
	end 'pickExisting'
end 'maxonTypeIsRefinementOf'

// --- ABI param-vector expansion (function/interface companion slots) ---
//
// Decoupling of scope-slot id from ABI parameter index. The parser records a
// `ParamReservation` per user param (including `__self`), reserving one
// companion scope slot for every `named(alias)` param without deciding its
// type. Once aliases resolve, this pass walks each function's reservations in
// lockstep with its user-facing `maxonParamTypes`, decides — from the RESOLVED
// type — whether each param needs an env (function-typed) or witness
// (interface-fat) companion, and:
//   - rebuilds `maxonParamTypes` as the ABI vector (user param, then its
//     companion opaquePointer when present), updating `paramCount`;
//   - records `scopeSlotToAbiParamIndex` / `abiParamIndexToScopeSlot` so
//     lowering/Mem2Reg can translate between the parser's scope-slot space and
//     the ABI parameter index (which == param ValueId) without assuming they
//     are equal;
//   - finalizes each reservation's `companionKind`.
// Must run after alias resolution (`resolveAllStructTypes` et al.) and before
// `buildProducerTypes` / lowering / the content-hash stamp.
//
// Functions with empty `paramReservations` (synthesized helpers, lifted
// closures — whose trailing `__env` is position-derived) are left untouched:
// their `maxonParamTypes` already carries whatever ABI shape they need.

// Decide the companion a resolved parameter type requires. `named(alias)`
// params chase through the typealias registries: a function-type alias yields
// `env`, an interface(-fat) alias yields `witness`, anything else `none`.
function resolveParamCompanionKind(project Project, paramType MaxonType) returns ParamCompanionKind
	// Function-typed (directly, or via a typealias) -> env companion.
	let chasedFn = chaseTypealiasToFunctionType(project, t: paramType)
	if isFunctionMaxonType(chasedFn) 'isFn'
		return ParamCompanionKind.env
	end 'isFn'
	// Interface-fat (directly, or the alias resolves to an interface) ->
	// witness companion. `interfaceTypeIsFat` only matches the resolved
	// `MaxonType.interface(_)` arm, so resolve a `named(alias)` to its base
	// type name and re-intern (internMaxonType promotes interface names to
	// the `interface(_)` arm).
	if interfaceTypeIsFat(paramType) 'directIface'
		return ParamCompanionKind.witness
	end 'directIface'
	let aliasName = paramType.namedAliasNameOrEmpty(project)
	if not aliasName.isEmpty() 'namedParam'
		let baseName = try baseNameOfMaxonType(project, t: paramType) otherwise aliasName
		let reInterned = internMaxonType(project, name: baseName)
		if interfaceTypeIsFat(reInterned) 'aliasIface'
			return ParamCompanionKind.witness
		end 'aliasIface'
	end 'namedParam'
	return ParamCompanionKind.none
end 'resolveParamCompanionKind'

// Expand one function's ABI param vector and build its slot<->abi maps from
// the parser's reservations. See the section comment above.
function buildAbiParamMapForFunc(project Project, func IrFunction)
	if func.paramReservations.count() == 0 'noReservations'
		// Lifted closures / synthesized functions: keep maxonParamTypes as-is.
		return
	end 'noReservations'
	// Idempotency guard: runTypeResolution can run more than once over the
	// same module (e.g. stdlib then user, or re-entrant query paths), and
	// expanding an already-expanded maxonParamTypes would double-insert
	// companions and misalign every index. A populated scopeSlotToAbiParamIndex
	// means this function was already expanded; skip.
	if func.scopeSlotToAbiParamIndex.count() > 0 'alreadyExpanded'
		return
	end 'alreadyExpanded'

	// The reservations are 1:1 with the user-facing param types the parser
	// stored in maxonParamTypes (one per declared user param, __self included).
	let userParamCount = func.paramReservations.count()
	var abiTypes = MaxonTypeArray.create()
	var slotToAbi = ScopeSlotToAbiIndexMap.create()
	var abiToSlot = VarSlotArray.create()
	var updatedReservations = ParamReservationArray.create()

	for pi in 0 upto userParamCount 'eachParam'
		let reservation = try func.paramReservations.get(pi) otherwise panic("buildAbiParamMapForFunc: paramReservations.get OOB at {pi} in {func.name}")
		let paramType = try func.maxonParamTypes.get(pi) otherwise panic("buildAbiParamMapForFunc: maxonParamTypes.get OOB at {pi} in {func.name} (reservations/types length mismatch)")

		// Place the user param at the next ABI index.
		let paramAbiIdx = abiTypes.count()
		abiTypes.push(paramType)
		slotToAbi.upsert(reservation.paramSlot, value: paramAbiIdx)
		abiToSlot.push(reservation.paramSlot)

		// Decide the companion from the resolved type. A reservation only
		// carries a companion slot for `named(alias)` params; primitive
		// params never need one, so skip the decision when none was reserved.
		var kind = ParamCompanionKind.none
		if reservation.hasCompanion 'maybeCompanion'
			kind = resolveParamCompanionKind(project, paramType: paramType)
			if not isParamCompanionNone(kind) 'hasReal'
				let companionAbiIdx = abiTypes.count()
				abiTypes.push(MaxonType.opaquePointer)
				slotToAbi.upsert(reservation.companionSlot, value: companionAbiIdx)
				abiToSlot.push(reservation.companionSlot)
			end 'hasReal'
		end 'maybeCompanion'

		updatedReservations.push(ParamReservation.create(reservation.paramSlot, hasCompanion: reservation.hasCompanion, companionSlot: reservation.companionSlot, companionKind: kind))
	end 'eachParam'

	func.maxonParamTypes = abiTypes
	func.paramCount = abiTypes.count()
	func.scopeSlotToAbiParamIndex = slotToAbi
	func.abiParamIndexToScopeSlot = abiToSlot
	func.paramReservations = updatedReservations
end 'buildAbiParamMapForFunc'

// Module-level driver: expand every function's ABI param vector + maps.
function buildAbiParamMaps(project Project, module MaxonModule)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		var func = try module.functions.get(funcIdx) otherwise panic("buildAbiParamMaps: functions.get OOB at {funcIdx}")
		buildAbiParamMapForFunc(project, func: func)
	end 'eachFunc'
end 'buildAbiParamMaps'

// --- Pass entry ---

// Drains the project-wide unresolved-typealias registry, then walks the
// module's ops to (1) rewrite parser-emitted `unresolvedRead` /
// `unresolvedAssign` placeholders to their concrete forms, (2) fill any
// `MaxonType.unresolved` operands left by the parser using a
// producer-type map, and (3) validate convert / cmp endpoints against the
// now-fully-typed ops. The typealias drain is idempotent: only the first
// module's call does real work, every later module-level call walks an
// empty map.
export function runTypeResolution(project Project, module MaxonModule, filePath FilePath)
	// `resolvedCallees` and `callParamTypes` are keyed by OpIndex, which is
	// per-module. When the cache-miss stdlib build path runs `runTypeResolution`
	// on the stdlib MaxonModule, those maps get populated with entries keyed
	// by stdlib op indices. The user pipeline then runs `runTypeResolution`
	// on the (separate) user MaxonModule, but its op indices restart from 0
	// and collide with stdlib's. Without clearing, the parser-side
	// `try ... insert ... otherwise ignore` keeps the stale stdlib entries,
	// so user calls resolve to whatever stdlib happened to put at that index
	// (e.g. user's `print(...)` → `__ManagedMemory.length`). Reset both
	// op-keyed maps at the start of every resolution run so each module
	// starts from a clean slate.
	project.resolvedCallees = ResolvedCalleesMap.create()
	project.resolvedReceiverTypes = ResolvedReceiverTypesMap.create()
	project.callParamTypes = CallParamTypesMap.create()
	// Merge cross-file extension inner typealiases that the parser queued
	// because their target type hadn't been parsed yet. Must run before the
	// interface/struct drains so the aliases promote into the resolved
	// inner-alias maps. See drainPendingExtensionInnerAliases.
	drainPendingExtensionInnerAliases(project)
	resolveAllTypealiases(project)
	// Interfaces drain before structs/enums so the conformance walk in
	// `resolveAllStructTypes` / `resolveAllEnumTypes` can look up named
	// interfaces and compute substituted expected-method sets.
	resolveAllInterfaces(project)
	// Phase 11.1 step 5b: walk the still-unresolved struct/enum entries'
	// `implementedInterfaces` clauses and record matching entries into
	// `project.conformances`, plus minimum-viable method-presence
	// validation. Must run BEFORE the struct/enum drains because the
	// drains move entries out of the unresolved registries.
	validateConformances(project)
	// Phase 11.1 step 5c: process extension blocks' added conformances and
	// register them in `project.conformances`. Must run after the parser
	// has fully populated `funcReturnTypes` (so the method-presence check
	// sees parser-time function registrations) and before any consumer of
	// `project.conformances` (today: nothing — the table is fed but not
	// yet consumed; Step 6/7 will).
	processExtensions(project)
	// Phase 11.7: drain deferred where-clause checks now that
	// `project.conformances` is populated by validateConformances and
	// processExtensions. Runs before the struct drain so a constraint
	// violation surfaces before lowering attempts to use the bad alias.
	drainPendingConstraintChecks(project)
	// Now that constraint failures have been recorded, drain the deferred
	// unused-typealias queue. Aliases whose RHS failed validation are
	// suppressed to match the bootstrap's single-diagnostic shape.
	drainPendingUnusedTypealiases(project)
	resolveAllStructTypes(project)
	resolveAllEnumTypes(project)
	// Phase 9 function-backed enums: every case's bare function identifier
	// (recorded as `EnumCase.rawFunctionName` at parse time) is resolved
	// here against the now-populated funcSignatures/funcReturnTypes maps.
	// Each case gets its name rewritten to a fully qualified callable name
	// and the enum stamps its shared FunctionTypeId on `functionBackingTypeId`.
	resolveFunctionBackedEnumRefs(project)
	// Compute struct field offsets and total byteSize now that every named
	// type the parser saw has been promoted into `project.structTypes` /
	// `project.enumTypes` / `project.typealiases`. Must run before any
	// pass that reads `field.offset` or `st.byteSize` (notably
	// `buildLayoutDescriptors` and the fieldLoad/Store lowering in
	// `LowerMaxonToStd`).
	layoutAllStructs(project)
	// Top-level decls (lets and vars together) depend on enums (cases
	// registered as constants) and typealiases (`as TypeName` casts), so
	// they sequence after both drains. Lets and vars share one drain pass
	// so a `var x = LET_NAME + 1` initializer can recurse through any other
	// pending decl without ordering hazards.
	resolveAllTopLevelDecls(project)

	// Eagerly patch `topLevelVars[name].slotType` for entries the parser
	// registered with `MaxonType.unresolved` (currently only top-level
	// array-literal initializers). The slot type is recoverable from the
	// `T.init(mm)` call op the parser emitted into `__module_init_<n>`:
	// the call's qualified callee is `{arrayType}.init` and its return
	// type lives in `project.funcReturnTypes`. Doing this BEFORE
	// `rewriteUnresolvedOpsPerFunction` ensures user reads of `xs` get
	// rewritten to `globalLoad` ops whose slotType is already concrete,
	// which in turn lets `buildProducerTypes` record the correct receiver
	// type for any subsequent `xs.method(...)` call.
	preResolveArrayLiteralSlotTypes(project, module: module)

	// Per-function rewrite so visibility lookups can use the function's
	// declaring file as the reading context — when files are merged into
	// one MaxonModule, `filePath` (the runTypeResolution param) only
	// names the first source. Ops from other files would visibility-
	// check against the wrong path otherwise.
	rewriteUnresolvedOpsPerFunction(project, module: module, fallbackFilePath: filePath)

	// Now that every named-alias param type has resolved, expand each
	// function's ABI param vector with env/witness companions (driven by
	// the parser's per-param reservations) and build the scope-slot<->abi
	// maps. Runs before buildProducerTypes (the first fnTypeId/param
	// consumer) and before lowering, so every consumer sees the final
	// ABI shape + maps. See buildAbiParamMaps.
	buildAbiParamMaps(project, module: module)

	// Resolve indirect-call sites the parser emitted with the sentinel
	// fnTypeId=0 (callee was a `named(alias)` whose typealias hadn't
	// resolved at parse time). Runs here — after alias resolution and ABI
	// expansion, before buildProducerTypes (the first fnTypeId consumer,
	// which panics on functionTypes.get(0)). Patches each indirectCall +
	// its producer varLoad with the resolved function type, or emits E3005
	// when the callee doesn't resolve to a function. Replaces the former
	// pre-TypeResolution pass that could not see cross-file aliases.
	validateIndirectCallLabels(project, allModule: module)

	// Now that every unresolvedRead/Assign has been replaced with its concrete
	// op shape (globalLoad/globalStore/literal), build per-function producer-
	// type and slot-type maps and fill in any MaxonType.unresolved operands
	// the parser left behind. Maps are per-function because parser-emitted
	// synthetic names ($t0, $t1, ...) and slot ids reset between functions.
	var producerTypesPerFunc = ProducerTypeMapArray.create()
	var slotTypesPerFunc = SlotTypeMapArray.create()
	buildProducerTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc, slotTypesPerFunc: slotTypesPerFunc)
	// Stage E (closures): the parser records each `closureEnvLoad`'s
	// `captureType` from the outer scope's parser-recorded var type. When
	// that type was `unresolved` at parse time (typical for locals whose
	// initializer is a function call whose return type the parser doesn't
	// compute), the lifted body's downstream `fieldLoad` / `methodCall`
	// receivers see an unresolved receiver type and downstream lowering
	// trips the survives-past-TR guard. Patch each closureEnvLoad op's
	// `captureType` from the outer function's now-resolved slot type, then
	// re-build the lifted bodies' producer types so the fieldLoad chain
	// gets the right receiver type.
	patchClosureEnvLoadCaptureTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc, slotTypesPerFunc: slotTypesPerFunc)
	fillUnresolvedTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc, slotTypesPerFunc: slotTypesPerFunc)

	// Phase A widening: re-stamp varDecl ops whose recorded `slotType` is
	// `integer` but whose effective `slotTypes` entry (after
	// `recordVarStore` upgraded the slot across arms) became `float`.
	// Mirrors the C# bootstrap's match-expression seed-replacement pass —
	// keeps the lowering view consistent so `lowerVarStore` sees the wider
	// slot type and inserts the int→float promote on int-typed arms.
	widenVarDeclTypesFromSlotTypes(project, module: module, slotTypesPerFunc: slotTypesPerFunc)

	// Backfill `topLevelVars[name].slotType` for any entry whose slot was
	// registered with `MaxonType.unresolved` (currently only the array-literal
	// initializer path in the parser; other top-level vars resolve through
	// `resolveAllTopLevelDecls`'s `inferSlotTypeFromExpr`). Walks every
	// `globalStore` op the lowering pass would emit and reads the now-concrete
	// slotType the previous fillUnresolvedTypes pass stamped onto the op.
	// Without this, a subsequent `globalLoad` rewrite from user code reading
	// the same name carries forward an unresolved type and trips the
	// `resolveMaxonTypeToStd` invariant guard in lowering.
	backfillTopLevelVarSlotTypes(project, module: module)

	// Stage E (closures): the parser stamps lifted closure functions with
	// MaxonReturnType.value(MaxonType.unresolved) when the body's expression
	// type can't be derived without struct-field / function-return lookups.
	// Now that buildProducerTypes has made every value's type concrete,
	// patch each function's `maxonReturnType` from its `ret` op's value-name
	// producer type. Idempotent on already-concrete types — the patch only
	// runs when the existing return type is unresolved.
	resolveUnresolvedFunctionReturnTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc)

	// With every scrutinee's MaxonType now filled, resolve enumMatchArm
	// case names against the project's enum registry. On success we rewrite
	// in place with the resolved raw value; on miss we replace the op with
	// an `br(elseTarget)` after reporting the diagnostic so the block keeps
	// a valid terminator.
	resolveEnumMatchArms(project, module: module, filePath: filePath)

	// Specialize stringConst consumers (cmp folding, slot-aliased strings)
	// before lowering.
	specializeStringConstConsumers(module)

	// Dispatch struct-vs-struct `==` / `!=` to `.equals()`, and validate
	// `is` / `is not` operands. Runs after fillUnresolvedTypes so cmp
	// operand types are concrete and refEq operand producers are reachable
	// through the producer-type map.
	dispatchEqualityOps(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	// E3005: emit "operator 'X' is not defined for type 'T'" for any
	// arithmetic / bitwise binop whose operand type is a struct (String,
	// user-defined types). Mirrors the C# bootstrap's MaxonValueKind.Struct
	// guard in its binop emitter; the self-hosted parser doesn't reject
	// struct-typed binops at parse time (operandType may still be
	// `unresolved` then), so the check lives here after fillUnresolvedTypes
	// has filled in the concrete operand types.
	validateBinopOperandTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	validateSelfFields(project, module: module, filePath: filePath)

	// E3014: emit `cannot access unexported field` for fieldLoad/fieldStore
	// ops whose receiver's struct has the field marked non-exported AND the
	// access happens outside the type's own methods (struct-literal init
	// stays unrestricted — the type's shape determines what fields exist).
	// Runs after `fillUnresolvedTypes` so the receiver's MaxonType is
	// concrete; before lowering so the diagnostic fires before the IR
	// builds machine code for a still-erroneous access.
	validateFieldVisibility(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	// Visibility filtering: emit E3008 / E3088 for `call` ops whose only
	// matching candidate is hidden from the reading file. Runs before
	// arity check so a not-visible candidate doesn't double-report as
	// "wrong arity" against a now-localName-fallback that doesn't exist.
	validateCallVisibility(project, module: module, fallbackFilePath: filePath)

	// Visibility filtering for named-type references in `convert` ops
	// (`expr as TypeName`). When the typealias is hidden from the
	// reader, treat it as an undefined type so the C# bootstrap's
	// "Expected type name after 'as'" wording lands.
	validateNamedTypeVisibility(project, module: module, fallbackFilePath: filePath)

	// Reject calls / methodCalls whose argument count exceeds the registered
	// signature's user-param slot count. Without this, lowering trusts the
	// caller's arg vector and panics in the backend when the slot index walks
	// off the end of paramTypes. Runs per-function so receiver types can be
	// looked up against the same producer-type map fillUnresolvedTypes built.
	validateCallArities(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	// E3005 for methodCall ops: deferred from parse time so the resolved
	// receiver type can dictate enforcement. The C# bootstrap exempts
	// compiler builtins (e.g. `__ManagedMemory.*` methods) by passing
	// `allowAllPositional: true` in `ParseBuiltinMethodArgs`; mirror that
	// here by skipping any methodCall whose receiver resolves to a struct
	// type whose name begins with `__`. Free / qualified `call` ops keep
	// the parser-time check (their bare callee name is enough to identify
	// a builtin without receiver-type lookup).
	validateCallArgLabels(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	// E3059: re-emit the otherwise-type-mismatch check at TypeResolution time.
	// The parser version skips when either side names a type the project
	// hasn't seen yet (typealiases panic in convertCastCategory pre-resolution),
	// so an int-vs-float mismatch through `typealias Integer = int(...)` slips
	// through. By here, fillUnresolvedTypes has resolved producer types, so
	// the check can run safely against typealiased call results.
	validateTryOtherwiseTypes(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)

	// Per-call-site resolution: replicate the resolver chain lowering used to
	// run on the fly (typealias chase, overload disambiguation, receiver
	// substitution) and stash the results in `project.resolvedCallees` /
	// `project.callParamTypes` so the lowering pass becomes a pure consumer.
	// Must run after `fillUnresolvedTypes` (so receiver types in
	// `producerTypesPerFunc` are concrete) and after `validateCallArities`
	// (so arity errors are reported before any panic tripwire could fire).
	resolveAllCalls(project, module: module, producerTypesPerFunc: producerTypesPerFunc)

	// J.4f.2: closure literals with untyped parameters (`m.map(function(p) gives p)`)
	// stamp `MaxonType.unresolved` on the lifted function's param slot at
	// parse time — the parser cannot peek the callee's signature to learn
	// what `p` should be. Now that `resolveAllCalls` has filled
	// `callParamTypes` for every call site, walk methodCall/call ops whose
	// closure-typed argument's lifted function still has unresolved param
	// types and copy the concrete signature in. Without this, downstream
	// lowering would see `varLoad(slotType: unresolved)` inside the lifted
	// body and trip the `resolveMaxonTypeToStd` sentinel guard.
	propagateClosureArgTypesFromCalls(project, module: module, producerTypesPerFunc: producerTypesPerFunc, slotTypesPerFunc: slotTypesPerFunc)

	for opIdx in 0 upto module.ops.count() 'validateOps'
		let op = try module.ops.get(opIdx) otherwise panic("invariant: opIdx < module.ops.count() but get failed")
		if op.name == "cmp" 'isCmp'
			match op 'extract'
				cmp(_, _, _, _, leftType, rightType, _, range) then validateCompareOp(project, leftType: leftType, rightType: rightType, range: range, filePath: filePath)
				default panic("unreachable: already checked name == cmp")
			end 'extract'
		end 'isCmp'
	end 'validateOps'

	// Phase 11.7: a comparison operator on a type-parameter-typed operand
	// (e.g. `item == other` where both are `T` in `type Box uses T`) needs
	// the enclosing function's `where` clause to constrain `T : Equatable`
	// (for `==`/`!=`) or `T : Comparable` (for `<`/`<=`/`>`/`>=`). The C#
	// bootstrap raises E3005 at parse time via `ValidateTypeParameter-
	// Constraints`; the self-hosted parser defers the check until type
	// parameters are interned so the typeParameter arm is reliably visible
	// here. Running at TypeResolution catches the case before dead-code
	// elimination prunes the unmonomorphized generic body (e.g. `Box.eq`
	// declared but never instantiated still needs to fail with E3005).
	validateTypeParamComparisonConstraints(project, module: module, filePath: filePath)

	// Convert validation runs per-function so the literal-range walker can
	// stay function-local — synthetic value names (`$t1`, …) repeat across
	// functions, and a flat module-wide walk would alias unrelated literals.
	validateConvertOpsPerFunc(project, module: module, filePath: filePath)

	// Compile-time E3005 on `return LITERAL` where the literal is outside
	// the function's declared ranged-return-type range. Catches the static
	// half of return-value range checks; the dynamic half lives in
	// InsertRangeChecks.
	validateReturnLiterals(project, module: module, filePath: filePath)

	// Sentinel-leak check: every call's substituted paramTypes vector must
	// be fully resolved by here (no `MaxonType.unresolved` left over).
	// `unresolved` is the polymorphic-slot placeholder used by builtin
	// signatures (e.g. `__ManagedMemory.set/get/...`'s Element axis); a
	// concrete instantiation (`Array with Integer`) should have substituted
	// every such slot before lowering ever runs. A leak here points at a
	// resolver gap — turn it into an explicit compile error so lowering
	// doesn't either silently skip the type-check (`coerceArgToParam`'s
	// unresolved-passthrough) or trip a generic-instance panic later.
	validateNoUnresolvedAfterTypeResolution(project, module: module, filePath: filePath)

	// Resolver-contract tripwire: every `call` / `methodCall` / `tryCall` /
	// `tryMethodCall` op must either have a `resolvedCallees` entry (the
	// normal path) or dispatch through an intentionally-dynamic shape
	// (interface receiver → fat-pointer dispatch; typeParameter receiver →
	// witness dispatch). A miss here means the resolver or the
	// propagation chain left a hole — surface it now with a source range
	// instead of letting `lowerMethodCall` / `lowerCall` panic later.
	validateAllCallsResolved(project, module: module, producerTypesPerFunc: producerTypesPerFunc, filePath: filePath)
end 'runTypeResolution'

// Walk every function's `convert` ops, looking for compile-time literal
// out-of-range cases. Function-local so synthetic-name aliasing across
// functions doesn't cause false hits.
function validateConvertOpsPerFunc(project Project, module MaxonModule, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateConvertOpsPerFunc: funcIdx OOB")
		let funcFilePath = readerPathOrFallback(func, fallback: filePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateConvertOpsPerFunc: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateConvertOpsPerFunc: opIdx OOB")
				if op.name == "convert" 'isConvert'
					dispatchConvertValidation(project, module: module, func: func, op: op, filePath: funcFilePath)
				end 'isConvert'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateConvertOpsPerFunc'

function dispatchConvertValidation(project Project, module MaxonModule, func IrFunction, op MaxonOp, filePath FilePath)
	match op 'extract'
		convert(_, operand, fromType, toType, implicit, range) then validateConvertOp(project, module: module, func: func, operandName: operand, fromType: fromType, toType: toType, implicit: implicit, range: range, filePath: filePath)
		default panic("unreachable: caller checked name == convert")
	end 'extract'
end 'dispatchConvertValidation'

// Extract the named-typealias name from a MaxonReturnType, or empty when
// the return type isn't a `value(named(id))`. Avoids the
// genericInstanceIdBaseName panic on non-named shapes.
function returnTypeAliasName(project Project, returnType MaxonReturnType) returns String
	return match returnType 'extract'
		void gives ""
		value(inner) gives inner.namedAliasNameOrEmpty(project)
	end 'extract'
end 'returnTypeAliasName'

// Walk every function's `ret` ops; for each one whose value is a known
// literal, check it against the function's declared return-type alias
// range and emit E3005 on out-of-range.
function validateReturnLiterals(project Project, module MaxonModule, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateReturnLiterals: funcIdx OOB")
		// Only inspect functions whose return type is a `value(named(id))`;
		// other shapes (void, generic instance, type parameter, primitive)
		// don't carry a registered alias range. Skipping them avoids a
		// generic-instance-id panic for placeholder return types that
		// exist before monomorphization fills them in.
		let aliasName = returnTypeAliasName(project, returnType: func.maxonReturnType)
		if aliasName.isEmpty() 'noAlias'
			continue
		end 'noAlias'
		// Math.* and other Real-typed bodies have many in-range constant
		// returns; skip when the alias range is the full underlying-type
		// range (full i64 for ints, full f64 bit pattern for floats) so
		// we don't spend time walking literals that can't fail.
		let typealiasRange = try project.typealiasRanges.get(aliasName) otherwise continue
		if isAliasFullRange(project, aliasName: aliasName, range: typealiasRange) 'fullRange'
			continue
		end 'fullRange'
		let isFloat = aliasIsFloat(project, name: aliasName)
		let funcFilePath = readerPathOrFallback(func, fallback: filePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateReturnLiterals: blockRef OOB")
			if not block.hasTerminatorOp() 'noTerm'
				continue
			end 'noTerm'
			let termIdx = block.terminatorIndex()
			let termOp = try module.ops.get(termIdx) otherwise panic("validateReturnLiterals: termIdx OOB")
			if termOp.name == "ret" 'isRet'
				checkReturnLiteralOp(project, module: module, func: func, op: termOp, aliasName: aliasName, typealiasRange: typealiasRange, isFloat: isFloat, filePath: funcFilePath)
			end 'isRet'
		end 'eachBlock'
	end 'eachFunc'
end 'validateReturnLiterals'

function checkReturnLiteralOp(project Project, module MaxonModule, func IrFunction, op MaxonOp, aliasName String, typealiasRange TypealiasRange, isFloat bool, filePath FilePath)
	match op 'extract'
		ret(retVal, range) then checkReturnLiteralValue(project, module: module, func: func, retVal: retVal, range: range, aliasName: aliasName, typealiasRange: typealiasRange, isFloat: isFloat, filePath: filePath)
		default panic("unreachable: caller checked name == ret")
	end 'extract'
end 'checkReturnLiteralOp'

function checkReturnLiteralValue(project Project, module MaxonModule, func IrFunction, retVal ByteArray, range SourceRange, aliasName String, typealiasRange TypealiasRange, isFloat bool, filePath FilePath)
	let lit = findLiteralProducerInFunc(project, module: module, func: func, operandName: retVal)
	if not lit.found 'noLit'
		return
	end 'noLit'
	let outOfRange = literalOutOfRangeFloat(lit.value, range: typealiasRange) if isFloat else literalOutOfRangeInt(lit.value, range: typealiasRange)
	if not outOfRange 'inRange'
		return
	end 'inRange'
	let displayValue = formatLiteralValue(lit.value, isFloat: isFloat)
	let displayRange = formatTypealiasRange(project, aliasName: aliasName, range: typealiasRange)
	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Value {displayValue} is outside the range of '{aliasName}' ({displayRange})", line: range.line, column: range.column, filePath: filePath)
end 'checkReturnLiteralValue'

// Walk every call op's substituted paramTypes and surface a leak diagnostic
// if any slot still names `MaxonType.unresolved`. Keys off
// `project.callParamTypes` so methodCall / call / tryCall share one walk;
// ops without an entry never reach lowering's slot loop. The diagnostic uses
// the call op's own SourceRange (recoverable for the three call shapes;
// other ops aren't in callParamTypes so the partial extraction is safe).
function validateNoUnresolvedAfterTypeResolution(project Project, module MaxonModule, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateNoUnresolvedAfterTypeResolution: funcIdx OOB")
		let readerPath = readerPathOrFallback(func, fallback: filePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateNoUnresolvedAfterTypeResolution: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let paramTypes = try project.callParamTypes.get(opIdx) otherwise continue
				let op = try module.ops.get(opIdx) otherwise panic("validateNoUnresolvedAfterTypeResolution: opIdx OOB")
				// Phase 7: skip stale entries pointing at non-call ops.
				if op.name != "call" and op.name != "tryCall" and op.name != "methodCall" and op.name != "tryMethodCall" 'staleEntry'
					continue
				end 'staleEntry'
				let calleeName = callOpDisplayName(project, opIdx: opIdx, op: op)
				let opRange = callOpRange(op)
				for slot in 0 upto paramTypes.count() 'eachSlot'
					let pt = try paramTypes.get(slot) otherwise panic("validateNoUnresolvedAfterTypeResolution: paramTypes.get OOB at {slot}")
					if isUnresolvedType(pt) 'leaked'
						reportCompileError(project, code: ErrorCode.semanticTypeResolutionLeak, message: "TypeResolution leak: param slot {slot} of call '{calleeName}' remained MaxonType.unresolved — substitution failed to fill a polymorphic slot", line: opRange.line, column: opRange.column, filePath: readerPath)
					end 'leaked'
				end 'eachSlot'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateNoUnresolvedAfterTypeResolution'

// Resolver-contract tripwire (Phase 6 Step 12). Walks every function's
// call-shaped ops and confirms either:
//   * `project.resolvedCallees` has an entry for the op, OR
//   * the op is an intentionally-dynamic dispatch — methodCall/tryMethodCall
//     whose receiver MaxonType is an interface (fat-pointer dispatch) or
//     contains a typeParameter (witness dispatch); call/tryCall on a math
//     intrinsic or `__mm_alloc_count`, which `shouldSkipCallSite` removes
//     from the normal resolver path.
//
// A miss here means the resolver or `propagateClosureArgTypesFromCalls` left
// a hole that would otherwise reach `lowerMethodCall` / `lowerCall` and panic
// with an `invariant violated` message at a downstream stage. Reporting at
// TypeResolution gives a source range anchored at the original call site so
// the diagnostic points at user code, not at the lowering pass.
//
// We deliberately under-report when the receiver-type lookup is ambiguous:
// any `MaxonType.unresolved` receiver in `producerTypes` is treated as
// "not enough information to assert a regression" and skipped. The cost of
// under-reporting is a missed catch on a future regression; the cost of
// over-reporting is a hard block on legitimate code. The latter is worse.
function validateAllCallsResolved(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateAllCallsResolved: funcIdx OOB")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateAllCallsResolved: producerTypesPerFunc.get({funcIdx}) failed")
		let readerPath = readerPathOrFallback(func, fallback: filePath)
		let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateAllCallsResolved: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateAllCallsResolved: opIdx OOB")
				if not isCallShapedOpName(op.name) 'notCall'
					continue
				end 'notCall'
				if project.resolvedCallees.contains(opIdx) 'resolved'
					continue
				end 'resolved'
				if callOpHasIntentionalDynamicDispatch(project, op: op, producerTypes: producerTypes, enclosingType: enclosingType) 'dynamic'
					continue
				end 'dynamic'
				let calleeName = callOpDisplayName(project, opIdx: opIdx, op: op)
				let opRange = callOpRange(op)
				reportCompileError(project, code: ErrorCode.irUnresolvedCall, message: "internal: call op left unresolved by TypeResolution at opIdx={opIdx} (op='{op.name}', callee='{calleeName}') — resolver/propagation contract violated", line: opRange.line, column: opRange.column, filePath: readerPath)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateAllCallsResolved'

// True iff `name` is one of the four call-shaped op names. Centralised so
// the validator above and `validateNoUnresolvedAfterTypeResolution` don't
// drift on future op-name additions.
function isCallShapedOpName(name String) returns bool
	return name == "call" or name == "methodCall" or name == "tryCall" or name == "tryMethodCall"
end 'isCallShapedOpName'

// True when the op's dispatch shape is intentionally dynamic, so the
// resolver legitimately left no `resolvedCallees` entry:
//   * methodCall / tryMethodCall whose receiver MaxonType is interface or
//     references a typeParameter (directly or as a genericInstance arg);
//   * methodCall / tryMethodCall whose receiver MaxonType is unresolved
//     (under-report: we can't prove this is a bug without more context);
//   * call / tryCall whose callee bytes match `shouldSkipCallSite`
//     (math intrinsics, `__mm_alloc_count`).
function callOpHasIntentionalDynamicDispatch(project Project, op MaxonOp, producerTypes ProducerTypeMap, enclosingType String) returns bool
	if op.name == "methodCall" or op.name == "tryMethodCall" 'isMethodShape'
		let receiverName = extractMethodCallReceiverName(op)
		let rawReceiverType = lookupProducerType(producerTypes, name: receiverName)
		// Normalize through the same chase the resolver runs so a typealias
		// like `ElementIterable = Iterable with (Element, ElementIterator)`
		// unwraps to its genericInstance form — without this the validator
		// sees `named("ElementIterable")` and misses the interface dispatch.
		let receiverType = normalizeReceiverInContext(project, t: rawReceiverType, enclosingType: enclosingType)
		return maxonTypeIsDynamicDispatch(project, t: receiverType)
	end 'isMethodShape'
	if op.name == "call" or op.name == "tryCall" 'isCallShape'
		let bareCallee = extractCallCalleeName(op)
		return shouldSkipCallSite(bareCallee)
	end 'isCallShape'
	return false
end 'callOpHasIntentionalDynamicDispatch'

// Receiver value-name extractor for methodCall / tryMethodCall. The caller
// filters by op name, so a non-method shape here is a compiler bug.
function extractMethodCallReceiverName(op MaxonOp) returns ByteArray
	return match op 'pick'
		methodCall(_, receiver, _, _, _, _, _, _) gives receiver
		tryMethodCall(_, receiver, _, _, _, _, _, _, _) gives receiver
		default panic("extractMethodCallReceiverName: caller did not filter by methodCall/tryMethodCall (op='{op.name}')")
	end 'pick'
end 'extractMethodCallReceiverName'

// Callee bare-name extractor for call / tryCall. The caller filters by op
// name, so a non-call shape here is a compiler bug.
function extractCallCalleeName(op MaxonOp) returns String
	return match op 'pick'
		call(_, callee, _, _, _, _, _, _) gives String.from(callee)
		tryCall(_, callee, _, _, _, _, _, _, _) gives String.from(callee)
		default panic("extractCallCalleeName: caller did not filter by call/tryCall (op='{op.name}')")
	end 'pick'
end 'extractCallCalleeName'

// True when `t` indicates an intentionally-dynamic methodCall dispatch:
//   * `interface(_)` — fat-pointer dispatch in lowering;
//   * `typeParameter(_)` — witness dispatch in lowering;
//   * `genericInstance(...)` whose args transitively reference a
//     typeParameter — the body is still polymorphic at this point and the
//     resolver legitimately skips it (mono will fill in later);
//   * `unresolved` — under-report. We can't distinguish "resolver gap" from
//     "no producer recorded for synthetic name" cheaply at this stage.
function maxonTypeIsDynamicDispatch(project Project, t MaxonType) returns bool
	return match t 'pick'
		interface gives true
		typeParameter gives true
		genericInstance(gid) gives genericInstanceArgsContainTypeParameter(project, gid: gid)
		unresolved gives true
		boolean to string gives false
		function gives false
		named gives false
		constInt to opaquePointer gives false
	end 'pick'
end 'maxonTypeIsDynamicDispatch'

// True when any arg of the genericInstance contains a typeParameter (e.g.
// `Array with Element` where `Element` is the enclosing type's parameter).
// Walks one level deep — generic args can themselves be generic, but in
// practice methodCall receivers only need shallow detection because the
// monomorphizer collapses fully-concrete instantiations before this guard
// runs.
function genericInstanceArgsContainTypeParameter(project Project, gid GenericInstanceId) returns bool
	let (_, args) = project.genericInstances.get(gid)
	for a in args 'each'
		if maxonTypeContainsTypeParameter(project, t: a) 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'genericInstanceArgsContainTypeParameter'

// Recursive walk: `t` is or contains a typeParameter. Used by the
// receiver-dispatch guard so a `Foo with T` receiver type is recognised as
// witness-dispatched without flagging the call site.
function maxonTypeContainsTypeParameter(project Project, t MaxonType) returns bool
	return match t 'pick'
		typeParameter gives true
		genericInstance(gid) gives genericInstanceArgsContainTypeParameter(project, gid: gid)
		boolean to string gives false
		function gives false
		named gives false
		interface gives false
		unresolved gives false
		constInt to opaquePointer gives false
	end 'pick'
end 'maxonTypeContainsTypeParameter'

// Returns the callee's qualified name (preferring the resolved entry from
// TypeResolution; falling back to the parser-stamped bytes when none was
// recorded). Non-call ops never reach this helper (the caller filters by
// `callParamTypes` membership), so the dispatch list is exhaustive enough
// — the `default` branch is a hard panic so an unexpected op shape
// surfaces as a compiler bug, not silent fallback.
function callOpDisplayName(project Project, opIdx OpIndex, op MaxonOp) returns String
	let resolved = try project.resolvedCallees.get(opIdx) otherwise ""
	if not resolved.isEmpty() 'haveResolved'
		return resolved
	end 'haveResolved'
	return match op 'pick'
		call(_, callee, _, _, _, _, _, _) gives String.from(callee)
		tryCall(_, callee, _, _, _, _, _, _, _) gives String.from(callee)
		tryMethodCall(_, _, methodName, _, _, _, _, _, _) gives String.from(methodName)
		methodCall(_, _, methodName, _, _, _, _, _) gives String.from(methodName)
		default panic("callOpDisplayName: callParamTypes carries non-call op — invariant violation")
	end 'pick'
end 'callOpDisplayName'

// Returns the SourceRange off any of the three call-shaped ops.
// The caller is expected to filter out non-call ops first; this helper
// hard-panics if a non-call slips through (validates the upstream filter).
function callOpRange(op MaxonOp) returns SourceRange
	return match op 'pick'
		call(_, _, _, _, _, _, _, range) gives range
		tryCall(_, _, _, _, _, _, _, _, range) gives range
		tryMethodCall(_, _, _, _, _, _, _, _, range) gives range
		methodCall(_, _, _, _, _, _, _, range) gives range
		default panic("callOpRange: callParamTypes carries non-call op '{op.name}' — caller did not filter")
	end 'pick'
end 'callOpRange'

// Anchor visibility checks at the function's declaring file. Synthesized
// functions (no parser-stamped source path) fall back to the project's
// primary source so visibility checks against detached blocks still
// resolve to *some* file.
function readerPathOrFallback(func IrFunction, fallback FilePath) returns FilePath
	if func.sourceFilePath.toString().isEmpty() 'empty'
		return fallback
	end 'empty'
	return func.sourceFilePath
end 'readerPathOrFallback'

// --- Call-visibility validation ---
//
// Walks every function's `call` ops and checks the resolved qualified
// callee against the reader's file via `isVisibleFrom`. When the only
// candidate is hidden by visibility, emits E3008 (file-private or non-
// exported) or E3088 (module-scoped, wrong directory). The diagnostic
// matches the C# bootstrap's wording so cross-implementation tests share
// the same fragments.
//
// `qualifyCalleeForContext` already filters by visibility on the cross-
// namespace fallback path — when it fails to find a visible candidate
// it returns the local namespace name as a fallback. So this pass's
// signal is: the resolved qualified callee isn't in `funcReturnTypes`,
// AND `methodNameIndex` has at least one entry for the bare name. The
// hidden candidate's visibility tier dictates which error code to emit.
function validateCallVisibility(project Project, module MaxonModule, fallbackFilePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateCallVisibility: funcIdx < count but get failed")
		let readerPath = readerPathOrFallback(func, fallback: fallbackFilePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateCallVisibility: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateCallVisibility: opIdx OOB")
				if op.name == "call" 'isCall'
					match op 'extractCall'
						call(_, callee, callContext, _, _, _, _, range) then checkCallVisibility(project, callee: callee, callContext: callContext, currentNamespace: func.namespace, readerFilePath: readerPath, range: range)
						default panic("unreachable: already checked name == call")
					end 'extractCall'
				end 'isCall'
				// Instance method dispatch: the receiver type is already
				// visible (we hold a value of it), so the function's own
				// visibility tier applies. The resolved callee is in
				// `resolvedCallees`; missing entries mean type-resolution
				// gave up earlier and downstream diagnostics will surface
				// the underlying type error — nothing to validate here.
				if op.name == "methodCall" or op.name == "tryMethodCall" 'isMethodCall'
					match op 'extractMethod'
						methodCall(_, _, _, _, _, _, _, range) then checkMethodCallVisibility(project, opIdx: opIdx, readerFilePath: readerPath, range: range)
						tryMethodCall(_, _, _, _, _, _, _, _, range) then checkMethodCallVisibility(project, opIdx: opIdx, readerFilePath: readerPath, range: range)
						default panic("unreachable: already checked name is methodCall/tryMethodCall")
					end 'extractMethod'
				end 'isMethodCall'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateCallVisibility'

// Instance-method visibility: the resolved callee is keyed in
// `resolvedCallees`. If hidden from `readerFilePath`, emit E3008/E3088
// using the resolved qualified name (matching the C# bootstrap's
// "function 'Type.method' is not exported" diagnostic shape).
function checkMethodCallVisibility(project Project, opIdx OpIndex, readerFilePath FilePath, range SourceRange)
	let resolved = try project.resolvedCallees.get(opIdx) otherwise return
	if not project.funcReturnTypes.contains(resolved) 'unresolvedCallee'
		return
	end 'unresolvedCallee'
	let info = funcVisibilityOrDefault(project, qualifiedName: resolved)
	if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'visible'
		return
	end 'visible'
	reportHiddenCalleeError(project, displayName: resolved, tier: info.visibility, range: range, filePath: readerFilePath)
end 'checkMethodCallVisibility'

// True when `callee` is a `Type.method` form whose head segment names a
// struct that isn't visible to `readerFilePath`. Used by the qualified-
// call visibility gate to defer to the downstream type-visibility check
// at the field-access site so the diagnostic blames the inaccessible
// type rather than its (incidentally non-exported) method.
function calleeHeadTypeHiddenFromReader(project Project, callee String, readerFilePath FilePath) returns bool
	let dotPos = try callee.findFirst(".") otherwise return false
	let headName = callee.slice(StringIndex.create(0, bytePos: 0), endIndex: dotPos)
	if let structType = try project.structTypes.get(headName) 'haveStruct'
		return not isVisibleFrom(structType.visibility, declFilePath: structType.sourceFilePath, readerFilePath: readerFilePath)
	end 'haveStruct'
	return false
end 'calleeHeadTypeHiddenFromReader'

// Check a single `call` op for a visibility violation. Two paths:
//
// 1. Qualified call (`Type.method(...)`): the parser already wrote the
//    fully-qualified callee into the op. Look the function up directly
//    in `funcVisibilities` and emit E3008 / E3088 if it's hidden from
//    the reader. The bare diagnostic name is the trailing segment so
//    the error reads "function 'create' is not exported" instead of
//    "function 'InternalPoint.create' is not exported", matching the
//    C# bootstrap.
//
// 2. Bare call (`helper()`): when `qualifyCalleeForContext` couldn't
//    find a visible candidate it returns the local-namespace fallback,
//    which won't be in `funcReturnTypes`. Scan `methodNameIndex` for
//    the bare name; if a hidden candidate exists, emit the diagnostic
//    matching its tier. Missing entirely (no candidate at all) is left
//    to downstream undefined-name reporting.
function checkCallVisibility(project Project, callee ByteArray, callContext CallContext, currentNamespace String, readerFilePath FilePath, range SourceRange)
	let bareCallee = String.from(callee)
	// Math intrinsics are inlined and have no funcReturnTypes entry; they
	// are always reachable so visibility doesn't apply.
	if isMathIntrinsic(bareCallee) 'mathIntrinsic'
		return
	end 'mathIntrinsic'
	if isQualifiedCallContext(callContext) 'isQualified'
		// `bareCallee` is already qualified (`Type.method`). Diagnostic
		// uses the full qualified name so the user sees the exact text
		// they typed (`InternalPoint.create`).
		if not project.funcReturnTypes.contains(bareCallee) 'unknown'
			return
		end 'unknown'
		let info = funcVisibilityOrDefault(project, qualifiedName: bareCallee)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'visible'
			return
		end 'visible'
		// Defer to the field-access type-visibility gate when the head
		// segment is a struct that isn't visible to the reader: emitting
		// E3008 here would mask the more useful "Unknown type" diagnostic
		// the call-site would raise downstream when the caller tries to
		// use the returned value (field load, method call, etc). The
		// receiver type itself is the actual access barrier; the method's
		// own visibility is only meaningful once the type IS reachable.
		if calleeHeadTypeHiddenFromReader(project, callee: bareCallee, readerFilePath: readerFilePath) 'typeHidden'
			return
		end 'typeHidden'
		reportHiddenCalleeError(project, displayName: bareCallee, tier: info.visibility, range: range, filePath: readerFilePath)
		return
	end 'isQualified'
	let qualified = qualifyCalleeForContext(project, bare: bareCallee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath)
	if project.funcReturnTypes.contains(qualified) 'visible'
		// Existence isn't enough — the bare-call probe's cross-file
		// fallback in `qualifyCalleeForContextWithType` returns the
		// local-namespace fallback name when no visible candidate was
		// found, and that fallback IS registered in `funcReturnTypes`
		// when a sibling file in the same directory declares it. Run the
		// visibility check explicitly so the hidden sibling's E3008 fires
		// instead of being silently accepted.
		let info = funcVisibilityOrDefault(project, qualifiedName: qualified)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'qualifiedVisible'
			return
		end 'qualifiedVisible'
		reportHiddenCalleeError(project, displayName: bareCallee, tier: info.visibility, range: range, filePath: readerFilePath)
		return
	end 'visible'
	// `__`-prefixed references from outside the internals files always trip
	// the gate, regardless of the cache-restore visibility-info gap. Mirror
	// the name-based check in `qualifyCalleeForContextWithType` and report
	// the same "not exported" diagnostic as if `funcVisibilities` had been
	// preserved. This is the user-visible counterpart of `checkReservedDeclName`'s
	// declaration-side rule.
	if bareCallee.startsWith("__") and not readerCanCallStdlibInternals(readerFilePath) 'rejectInternalsRef'
		let stdlibCandidate = qualifyName("stdlib", name: bareCallee)
		if project.funcReturnTypes.contains(stdlibCandidate) 'haveInternalsCandidate'
			reportHiddenCalleeError(project, displayName: bareCallee, tier: Visibility.file, range: range, filePath: readerFilePath)
			return
		end 'haveInternalsCandidate'
	end 'rejectInternalsRef'
	// Bare call: resolved name doesn't exist; check whether a hidden
	// candidate would have matched if visibility allowed it. Two file-private
	// overloads of the same bare name (e.g. two sibling files each declaring
	// `stripTrailingCR` with a different first-param type) get mangled into
	// the overload bucket — at the call site, ONE of them is the visible
	// match for the reader. If any candidate is visible we must not report
	// any hidden sibling: overload resolution will dispatch to the visible
	// match. Only when EVERY candidate is hidden do we surface the diagnostic.
	//
	// Phase C: skip `__`-prefixed candidates for non-internals readers.
	// Symmetric with the filter in `qualifyCalleeForContextWithType` — a
	// user-side bare name like `count` must not be considered as bound to
	// `__ManagedList.count` (which would surface a "not exported"
	// diagnostic when the bare reference is actually a top-level var,
	// not a callee at all).
	let readerInternals = readerCanCallStdlibInternals(readerFilePath)
	let candidates = project.methodNameIndex.get(bareCallee)
	var hiddenInfo = FuncVisibilityInfo.create(Visibility.file, sourceFilePath: readerFilePath)
	var sawHidden = false
	for candidate in candidates 'eachCandidate'
		if not project.funcReturnTypes.contains(candidate) 'notFunc'
			continue
		end 'notFunc'
		if candidate.startsWith("__") and not readerInternals 'rejectInternalsCandidate'
			continue
		end 'rejectInternalsCandidate'
		let info = funcVisibilityOrDefault(project, qualifiedName: candidate)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'wouldBeVisible'
			// Visible candidate exists — overload dispatch will pick it
			// (or a sibling visible one). Suppress any hidden-sibling
			// diagnostic this site might otherwise raise.
			return
		end 'wouldBeVisible'
		if not sawHidden 'firstHidden'
			hiddenInfo = info
			sawHidden = true
		end 'firstHidden'
	end 'eachCandidate'
	if sawHidden 'reportHidden'
		reportHiddenCalleeError(project, displayName: bareCallee, tier: hiddenInfo.visibility, range: range, filePath: readerFilePath)
	end 'reportHidden'
end 'checkCallVisibility'

// Emit the hidden-callee diagnostic for `displayName` with wording that
// matches the visibility tier. `global` is unreachable because every
// global candidate satisfies `isVisibleFrom`, so reaching it indicates
// a bug in the tier filter and panics rather than silently swallowing.
function reportHiddenCalleeError(project Project, displayName String, tier Visibility, range SourceRange, filePath FilePath)
	match tier 'tier'
		global then panic("reportHiddenCalleeError: callee '{displayName}' tagged global but isVisibleFrom returned false")
		file then reportCompileError(project, code: ErrorCode.semanticSymbolNotExported, message: "function '{displayName}' is not exported", line: range.line, column: range.column, filePath: filePath)
		module then reportCompileError(project, code: ErrorCode.semanticSymbolNotInModuleScope, message: "function '{displayName}' is module-scoped and not visible from this directory", line: range.line, column: range.column, filePath: filePath)
	end 'tier'
end 'reportHiddenCalleeError'

// --- Named-type visibility validation ---
//
// Walks every `convert` op (the IR shape for `expr as TypeName`). When
// the target type is a named type (typealias, struct, or enum) that the
// reading file can't see, emit "Expected type name after 'as'" matching
// the C# bootstrap's wording. The walk is per-function so the reader
// path is the function's own file.
function validateNamedTypeVisibility(project Project, module MaxonModule, fallbackFilePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateNamedTypeVisibility: funcIdx < count but get failed")
		let readerPath = readerPathOrFallback(func, fallback: fallbackFilePath)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateNamedTypeVisibility: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateNamedTypeVisibility: opIdx OOB")
				if op.name == "convert" 'isConvert'
					match op 'extractConvert'
						convert(_, _, _, toType, _, range) then checkNamedTypeVisibility(project, t: toType, range: range, readerFilePath: readerPath)
						default panic("unreachable: already checked name == convert")
					end 'extractConvert'
				end 'isConvert'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateNamedTypeVisibility'

// Check whether a named MaxonType is visible from the reader's file. If
// the type resolves to a hidden typealias / struct / enum, report
// "Expected type name after 'as'" — same wording the C# bootstrap emits
// when the typealias isn't in scope.
function checkNamedTypeVisibility(project Project, t MaxonType, range SourceRange, readerFilePath FilePath)
	let typeName = t.nameOrEmpty(project)
	if typeName.isEmpty() 'notNamed'
		return
	end 'notNamed'
	// Typealias visibility — sidecar map. Missing entry treated as global
	// (stdlib aliases never populate the sidecar). The sidecar is now an
	// array of (visibility, sourceFilePath) entries; the alias is visible
	// if ANY entry is visible from the reader's file.
	if let aliasInfos = try project.typealiasVisibilities.get(typeName) 'aliasHit'
		var visible = false
		for aliasInfo in aliasInfos 'eachInfo'
			if isVisibleFrom(aliasInfo.visibility, declFilePath: aliasInfo.sourceFilePath, readerFilePath: readerFilePath) 'thisOk'
				visible = true
				break
			end 'thisOk'
		end 'eachInfo'
		if not visible 'aliasHidden'
			reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Expected type name after 'as'", line: range.line, column: range.column, filePath: readerFilePath)
			return
		end 'aliasHidden'
	end 'aliasHit'
	// Struct visibility.
	if let structType = try project.structTypes.get(typeName) 'structHit'
		if not isVisibleFrom(structType.visibility, declFilePath: structType.sourceFilePath, readerFilePath: readerFilePath) 'structHidden'
			reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Expected type name after 'as'", line: range.line, column: range.column, filePath: readerFilePath)
			return
		end 'structHidden'
	end 'structHit'
end 'checkNamedTypeVisibility'

// --- Per-call-site resolution ---
//
// Walks every function once, replicates the callee-resolution chain
// lowering used to perform on the fly (`qualifyCalleeForContext` →
// `chaseTypealiasInQualifiedCallee` → `resolveOverloadedCallee` for
// `call`; receiver-struct-name lookup + `resolveOverloadedCallee` for
// `methodCall`), and stores the resolved qualified name in
// `project.resolvedCallees` plus the per-arg substituted paramTypes in
// `project.callParamTypes`. Lowering then becomes a pure consumer of
// these tables — no name resolution and no per-arg substitution.
//
// Substitution context:
//   - inner-aliases: the callee's enclosing struct's `innerAliases` map
//     (e.g. Array's `ElementMemory` → `__ManagedMemory with Element`)
//   - type parameters: the receiver's `genericInstance` arg list bound
//     against the enclosing struct's `usesParams` (e.g. receiver
//     `Array with Integer` binds `Element → Integer`)
//
// Skipped (no entry inserted):
//   - bare callees prefixed with `__mm_` (lowered as runtime intrinsics)
//   - math intrinsics (sqrt/floor/ceil/round/abs/trunc/min/max — lowered
//     as Std unary/binary ops without going through call resolution)
//   - methodCalls whose receiver type didn't reduce to a concrete struct
//     (interface-dispatch stub path)
//   - resolved callees with no `funcSignatures` entry (lowering's
//     no-signature fallback emits the call verbatim with no coercion)
//
// Tripwire: a substituted paramType that still contains `typeParameter`
// or an `unresolved` arm at this point indicates a substitution gap —
// either the receiver carried no generic args when it should have, or
// the callee's enclosing struct's innerAliases map was incomplete. We
// panic loudly rather than silently passing an unresolved type to
// lowering, where it would surface as a less-actionable cast-category
// failure deep inside `coerceArgToParam`.
function resolveAllCalls(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray)
	// Note: the Stage K.X.C pre-clone path from main (`preCloneInterfaceExtensionImpls`)
	// is omitted on tryold because it depends on Stage K.3 Phase B
	// infrastructure (`IrInterface.extensionMethods`) that hasn't been
	// introduced on this branch. The `func.maxonParamTypes.count()` half
	// of K.X.C is applied directly in `extendSlotsForInterfaceWitnesses` /
	// `buildInterfaceWitnessSlotMap` (see LowerMaxonToStd.maxon).
	//
	// Walk by index rather than iterator because the body may append new
	// monomorphized clones onto `module.functions` (J.4b user-extension
	// monomorphization); iterating by index lets the loop pick them up on
	// the same pass so their internal calls resolve through the same
	// machinery the original bodies use. Newly-appended functions get
	// per-call producer types built on-demand inside the loop so their
	// `receiver.method(...)` calls resolve against substituted slot types.
	var funcIdx = 0
	while funcIdx < module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("resolveAllCalls: funcIdx < count but get failed")
		// Freshly synthesized functions (e.g. J.4b/c/d monomorphized clones)
		// don't have prebuilt producer-type entries; build them on demand
		// before they're consumed below so cloned receivers carry the right
		// slot types into methodCall resolution. We also run the same
		// unresolved-slot-fill backfill that the per-function walk runs for
		// originally-parsed bodies: clones inherit parser-stamped
		// `slotType: unresolved` on every varDecl / varLoad / globalStore,
		// and lowering reads the OP's slotType — not the producer-type map
		// — when stamping value-types. Without the backfill, `iter.current()`
		// on a cloned `Iterable.map` body sees the iter varLoad's slotType as
		// `unresolved`, the methodCall resolver finds no struct, and lowering
		// falls through to the interface-dispatch stub.
		if funcIdx >= producerTypesPerFunc.count() 'onDemand'
			var fresh = ProducerTypeMap.create()
			var slotTypes = SlotTypeMap.create()
			recordFuncOpResults(project, module: module, func: func, producerTypes: fresh, slotTypes: slotTypes)
			runFillUnresolvedTypesForFunc(project, module: module, func: func, producerTypes: fresh, slotTypes: slotTypes)
			// Re-record after fill so producer types pick up the now-filled
			// varDecl / varLoad slotTypes; the second pass is cheap because
			// the producer-type map is per-function and small.
			fresh = ProducerTypeMap.create()
			slotTypes = SlotTypeMap.create()
			recordFuncOpResults(project, module: module, func: func, producerTypes: fresh, slotTypes: slotTypes)
			producerTypesPerFunc.push(fresh)
		end 'onDemand'
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("resolveAllCalls: producerTypesPerFunc.get({funcIdx}) failed after on-demand build")
		let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
		resolveAllCallsForFunc(project, module: module, func: func, producerTypes: producerTypes, enclosingType: enclosingType)
		funcIdx = funcIdx + 1
	end 'eachFunc'
end 'resolveAllCalls'

// Walk every op in `func` and route it through `resolveOneCallOp`. Lifted
// out of `resolveAllCalls` so `propagateClosureArgTypesFromCalls` can
// re-resolve calls in a function whose producer-type map was rebuilt
// after closure-arg type propagation refined receiver types — without
// re-resolving, a methodCall whose receiver was `unresolved` at
// resolve-time but is now concrete leaves `resolvedCallees[opIdx]` unset
// and trips the lowering invariant at `lowerMethodCall`.
function resolveAllCallsForFunc(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, enclosingType String)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("resolveAllCallsForFunc: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("resolveAllCallsForFunc: opIdx OOB")
			resolveOneCallOp(project, module: module, op: op, opIdx: opIdx, producerTypes: producerTypes, currentNamespace: func.namespace, readerFilePath: func.sourceFilePath, enclosingTypeName: enclosingType, funcName: func.name)
		end 'eachOp'
	end 'eachBlock'
end 'resolveAllCallsForFunc'

// Per-op dispatcher: routes `call` / `methodCall` to its resolver and
// passes other ops through. Centralising here keeps the per-function
// walker above shape-agnostic and lets future op shapes (Stage E
// indirect calls) hook in with a single arm.
function resolveOneCallOp(project Project, module MaxonModule, op MaxonOp, opIdx OpIndex, producerTypes ProducerTypeMap, currentNamespace String, readerFilePath FilePath, enclosingTypeName String, funcName String)
	if op.name == "call" 'isCall'
		match op 'extract'
			call(result, callee, callContext, args, argLabels, argTypes, _, range) then resolveCallSite(project, opIdx: opIdx, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, result: result, producerTypes: producerTypes, currentNamespace: currentNamespace, readerFilePath: readerFilePath, enclosingTypeName: enclosingTypeName, funcName: funcName, range: range)
			default panic("unreachable: already checked op.name == call")
		end 'extract'
		return
	end 'isCall'
	if op.name == "methodCall" 'isMethodCall'
		match op 'extract'
			methodCall(_, receiver, methodName, args, argLabels, argTypes, _, range) then resolveMethodCallSite(project, module: module, opIdx: opIdx, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, producerTypes: producerTypes, enclosingTypeName: enclosingTypeName, readerFilePath: readerFilePath, funcName: funcName, range: range)
			default panic("unreachable: already checked op.name == methodCall")
		end 'extract'
		return
	end 'isMethodCall'
	// `tryCall` shares `call`'s shape (with an extra error-binding name we
	// don't need for resolution) and lowers via `lowerCall`, so it needs the
	// same sidetable entries.
	if op.name == "tryCall" 'isTryCall'
		match op 'extract'
			tryCall(result, callee, callContext, args, argLabels, argTypes, _, _, range) then resolveCallSite(project, opIdx: opIdx, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, result: result, producerTypes: producerTypes, currentNamespace: currentNamespace, readerFilePath: readerFilePath, enclosingTypeName: enclosingTypeName, funcName: funcName, range: range)
			default panic("unreachable: already checked op.name == tryCall")
		end 'extract'
		return
	end 'isTryCall'
	// `tryMethodCall` shares `methodCall`'s shape (with an extra error-binding
	// name we don't need for resolution) and lowers via `lowerMethodCall`, so
	// it needs the same sidetable entries.
	if op.name == "tryMethodCall" 'isTryMethodCall'
		match op 'extract'
			tryMethodCall(_, receiver, methodName, args, argLabels, argTypes, _, _, range) then resolveMethodCallSite(project, module: module, opIdx: opIdx, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, producerTypes: producerTypes, enclosingTypeName: enclosingTypeName, readerFilePath: readerFilePath, funcName: funcName, range: range)
			default panic("unreachable: already checked op.name == tryMethodCall")
		end 'extract'
		return
	end 'isTryMethodCall'
end 'resolveOneCallOp'

// `call` op resolution. Free / qualified callees (no implicit receiver):
// substitution carries no generic-arg bindings (receiverType =
// MaxonType.unresolved → empty subst), so type-parameter paramTypes
// won't resolve here. That is fine for non-generic free calls; for
// `Type.method(...)` static calls into a generic struct (e.g.
// `IntArray.create()`), the chase rewrites the head to the base struct
// and inner-aliases of the base do still resolve through
// `applyInnerAliasIfNamed`.
function resolveCallSite(project Project, opIdx OpIndex, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, result ByteArray, producerTypes ProducerTypeMap, currentNamespace String, readerFilePath FilePath, enclosingTypeName String, funcName String, range SourceRange)
	// Idempotency guard for the post-propagation re-resolve pass; see the
	// matching block in `resolveMethodCallSite`. `resolveCallSite` always
	// inserts to `resolvedCallees` before returning (every reachable path
	// hits the insert), so this guard is solely a duplicate-work +
	// duplicate-diagnostic shield on the second pass.
	if project.resolvedCallees.contains(opIdx) 'alreadyResolved'
		return
	end 'alreadyResolved'
	let bareCallee = String.from(callee)
	if shouldSkipCallSite(bareCallee) 'skip'
		return
	end 'skip'
	let (initialQualified, qualifyReceiverType) = qualifyCalleeForContextWithType(project, bare: bareCallee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, enclosingType: enclosingTypeName)
	// E3095 ambiguity: when a bare callee was resolved via the cross-file
	// fallback in `qualifyCalleeForContextWithType` and multiple definitions
	// are visible from this file, surface the ambiguity here — the immediate
	// callee site has both the SourceRange and the reader file path the
	// fallback itself lacks. See the staged probe in MaxonDialect.maxon.
	maybeEmitAmbiguousCrossFileCall(project, bare: bareCallee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, range: range)
	let (chased, chaseReceiverType) = chaseTypealiasInQualifiedCalleeWithType(project, callee: initialQualified, enclosingType: enclosingTypeName)
	// `qualifyCalleeForContextWithType`'s chase fires against the
	// user-written head (e.g. `ByteArray`) and recovers the full
	// `genericInstance(Array, [Byte])`. The second chase here re-runs
	// against the already-qualified head (`Array`), which loses the
	// arg list — so a non-unresolved qualifyReceiverType wins. The
	// second chase only contributes when the qualify pass left the
	// head unresolved (inner-aliases bound via the enclosing struct
	// name).
	var receiverType = qualifyReceiverType if not isUnresolvedType(qualifyReceiverType) else chaseReceiverType
	// Static factories (`<Type>.init(...)`) emit a parser-side qualified
	// call whose head segment is the literal type name — already-resolved
	// in `structTypes`, so both chases land on `named(<Type>)` (no
	// arg list). Recover the concrete `genericInstance(<Type>, [Args])`
	// from the call's RESULT producer type when both chases agree on the
	// base name: array-literal lowering pins the result via
	// `arrayLiteralResultType`, so the typed result carries the element
	// binding the chase couldn't recover from the bare callee.
	receiverType = promoteNamedToGenericInstance(project, raw: receiverType, candidate: lookupProducerType(producerTypes, name: result))
	var resolved = resolveOverloadedCallee(project, bareQualifiedName: chased, argTypes: argTypes, hasSelf: false, argLabels: argLabels)
	// Char-byte disambiguation: when the integer-fast-path char literal `'e'`
	// flows into an overload set that has both String and Character variants,
	// the raw `MaxonType.integer` arg makes neither variant uniquely match.
	// Retry with the int args that originated as char-byte literals retyped
	// to Character so the `$Character` variant is picked instead of leaving
	// the call ambiguous.
	if resolved == chased and project.overloadedNames.contains(chased) 'tryCharByteRetry'
		let retryArgTypes = retypeCharByteArgsToCharacter(project, args: args, argTypes: argTypes, hasSelf: false, funcName: funcName)
		if retryArgTypes.didSubstitute 'didRetype'
			resolved = resolveOverloadedCallee(project, bareQualifiedName: chased, argTypes: retryArgTypes.types, hasSelf: false, argLabels: argLabels)
		end 'didRetype'
	end 'tryCharByteRetry'
	// Ambiguous-overload detection: the resolver returned the bare overload
	// bucket name unchanged, meaning no variant matched by type and no
	// label-based fallback succeeded. Report E3007 with the candidate list
	// drawn from `overloadedNames`. The caller is responsible for adding a
	// named argument to disambiguate.
	if resolved == chased and project.overloadedNames.contains(chased) 'isAmbiguous'
		reportAmbiguousOverload(project, bareQualifiedName: chased, range: range, filePath: readerFilePath)
		try project.resolvedCallees.insert(opIdx, value: resolved) otherwise ignore
		return
	end 'isAmbiguous'
	try project.resolvedCallees.insert(opIdx, value: resolved) otherwise ignore
	if not isUnresolvedType(receiverType) 'haveReceiver'
		try project.resolvedReceiverTypes.insert(opIdx, value: receiverType) otherwise ignore
	end 'haveReceiver'
	let signature = try project.funcSignatures.get(resolved) otherwise return
	let substituted = substituteParamTypes(project, signature: signature, qualifiedCallee: resolved, receiverType: receiverType)
	try project.callParamTypes.insert(opIdx, value: substituted) otherwise ignore
end 'resolveCallSite'

// Char-byte overload retry: re-type every `MaxonType.integer` arg whose value
// name is recorded as a char-byte literal in `project.charByteLiterals` to
// `MaxonType.named("Character")`. Returns the rewritten type list along with
// a `didSubstitute` flag so the caller can skip the retry when no arg was
// char-byte-tainted (cheap exit, no extra resolver work).
type CharByteRetypedArgs
	export var types as MaxonTypeArray
	export var didSubstitute as bool

	export static function create(types MaxonTypeArray, didSubstitute bool) returns CharByteRetypedArgs
		return Self{types: types, didSubstitute: didSubstitute}
	end 'create'
end 'CharByteRetypedArgs'

// Char-byte receiver retype: when a method-call receiver value name is
// tagged as a char-byte literal (the single-byte char-literal fast path
// emits `MaxonType.integer` for `'x'`), treat its receiver type as
// `Character` for method-resolution purposes. Without this, calls like
// `c.asciiValue()` on a char-byte-typed `c` route through `int`'s
// extension table (where `asciiValue` doesn't exist) and the call's
// result type stays `<unresolved>`. Mirrors `retypeCharByteArgsToCharacter`
// but operates on the receiver slot instead of the arg list.
function retypeCharByteReceiver(project Project, receiver ByteArray, receiverType MaxonType, funcName String) returns MaxonType
	let isCharByte = match receiverType 'check'
		boolean gives false
		integer gives project.charByteLiterals.contains(charByteLiteralKey(funcName, valueName: receiver))
		float to opaquePointer gives false
	end 'check'
	if not isCharByte 'pass'
		return receiverType
	end 'pass'
	return MaxonType.named(project.typeNames.intern("Character"))
end 'retypeCharByteReceiver'

function retypeCharByteArgsToCharacter(project Project, args ByteArrayArray, argTypes MaxonTypeArray, hasSelf bool, funcName String) returns CharByteRetypedArgs
	var startIdx = 0
	if hasSelf 'skipSelf'
		startIdx = 1
	end 'skipSelf'
	var didSubstitute = false
	var newTypes = MaxonTypeArray.create()
	let characterType = MaxonType.named(project.typeNames.intern("Character"))
	for i in 0 upto argTypes.count() 'eachArg'
		let t = try argTypes.get(i) otherwise return CharByteRetypedArgs.create(argTypes, didSubstitute: false)
		if i < startIdx 'beforeUser'
			newTypes.push(t)
			continue
		end 'beforeUser'
		let argName = try args.get(i - startIdx) otherwise ByteArray.create()
		if argName.count() == 0 'noName'
			newTypes.push(t)
			continue
		end 'noName'
		let isCharByte = match t 'check'
			boolean gives false
			integer gives project.charByteLiterals.contains(charByteLiteralKey(funcName, valueName: argName))
			float to opaquePointer gives false
		end 'check'
		if isCharByte 'retype'
			newTypes.push(characterType)
			didSubstitute = true
			continue
		end 'retype'
		newTypes.push(t)
	end 'eachArg'
	return CharByteRetypedArgs.create(newTypes, didSubstitute: didSubstitute)
end 'retypeCharByteArgsToCharacter'

// Emit E3007 with the bare overload name and a Candidates list rendered
// from each variant's signature (parameter names paired with the source-
// rendered type). The wording mirrors the C# bootstrap so spec fragments
// pass with byte-identical stderr.
function reportAmbiguousOverload(project Project, bareQualifiedName String, range SourceRange, filePath FilePath)
	let bareName = extractBareName(bareQualifiedName)
	let candidates = renderOverloadCandidates(project, bareQualifiedName: bareQualifiedName)
	reportCompileError(project, code: ErrorCode.semanticAmbiguousOverload, message: "Ambiguous overload for '{bareName}': multiple overloads match. Candidates: {candidates}", line: range.line, column: range.column, filePath: filePath)
end 'reportAmbiguousOverload'

// E3095: emit when a bare-name call resolved via the cross-file fallback
// and more than one visible definition exists. Skipped when an earlier
// probe (sibling type, local namespace, stdlib namespace, or overload
// bucket) would have caught the call — those resolutions are unambiguous
// by construction. The user must qualify with the directory name
// (`dir.name()`) to disambiguate.
function maybeEmitAmbiguousCrossFileCall(project Project, bare String, callContext CallContext, currentNamespace String, readerFilePath FilePath, range SourceRange)
	if isQualifiedCallContext(callContext) 'qualified'
		return
	end 'qualified'
	let siblingTypeName = siblingTypeNameOfContext(callContext)
	if not siblingTypeName.isEmpty() 'sibling'
		return
	end 'sibling'
	if bare == "main" 'isMain'
		return
	end 'isMain'
	let localName = qualifyName(currentNamespace, name: bare)
	if project.funcReturnTypes.contains(localName) or project.overloadedNames.contains(localName) 'localHit'
		return
	end 'localHit'
	let stdlibName = qualifyName("stdlib", name: bare)
	if project.funcReturnTypes.contains(stdlibName) or project.overloadedNames.contains(stdlibName) 'stdlibHit'
		return
	end 'stdlibHit'
	let candidates = visibleCrossFileCandidates(project, bare: bare, readerFilePath: readerFilePath)
	// Deduplicate by canonical qualified name to avoid spurious ambiguity
	// when the same function appears under both a mangled-overload and a
	// bare entry in `methodNameIndex` (`reduceLeft`/`reduceLeft$Int`).
	var distinct = StringArray.create()
	for c in candidates 'eachCandidate'
		let canonical = stripFunctionOverloadSuffix(c)
		if not stringArrayContains(distinct, value: canonical) 'addOne'
			distinct.push(canonical)
		end 'addOne'
	end 'eachCandidate'
	if distinct.count() <= 1 'noAmbiguity'
		return
	end 'noAmbiguity'
	let candidateList = renderCrossFileCandidateList(distinct)
	reportCompileError(project, code: ErrorCode.semanticAmbiguousCrossFileCall, message: "Ambiguous bare-name call to '{bare}': multiple visible definitions found. Qualify with a directory name. Candidates: {candidateList}", line: range.line, column: range.column, filePath: readerFilePath)
end 'maybeEmitAmbiguousCrossFileCall'

function stringArrayContains(arr StringArray, value String) returns bool
	for i in 0 upto arr.count() 'each'
		let v = try arr.get(i) otherwise continue
		if v == value 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'stringArrayContains'

function renderCrossFileCandidateList(names StringArray) returns String
	var out = ""
	for i in 0 upto names.count() 'each'
		let n = try names.get(i) otherwise continue
		if i > 0 'separator'
			out = "{out}, "
		end 'separator'
		out = "{out}{n}"
	end 'each'
	return out
end 'renderCrossFileCandidateList'

// Strip the namespace prefix from a qualified name so diagnostics show
// the user-facing bare identifier (`create`) instead of the internal
// `function-overloads.create`. Returns the input unchanged when there's
// no dot — covers `main` and other unqualified roots.
function extractBareName(qualified String) returns String
	let bytes = qualified.toByteArray()
	let dotIdx = lastIndexOfDotByte(bytes)
	if dotIdx >= bytes.count() 'noDot'
		return qualified
	end 'noDot'
	return byteSliceToString(bytes, startIndex: dotIdx + 1, endIndex: bytes.count())
end 'extractBareName'

// Render `(name1 Type1), (name2 Type2)` for each variant in the bucket so
// E3007's "Candidates:" list shows each signature in source-level form.
function renderOverloadCandidates(project Project, bareQualifiedName String) returns String
	let variants = try project.overloadedNames.get(bareQualifiedName) otherwise return ""
	var out = ""
	for i in 0 upto variants.count() 'eachVariant'
		let v = try variants.get(i) otherwise continue
		let sig = try project.funcSignatures.get(v) otherwise continue
		if i > 0 'separator'
			out = "{out}, "
		end 'separator'
		out = "{out}({renderSignatureParams(project, sig: sig)})"
	end 'eachVariant'
	return out
end 'renderOverloadCandidates'

function renderSignatureParams(project Project, sig FuncSignature) returns String
	var startIdx = 0
	if signatureFirstParamIsSelf(sig) 'hasSelf'
		startIdx = 1
	end 'hasSelf'
	var out = ""
	for i in startIdx upto sig.paramNames.count() 'eachParam'
		let name = try sig.paramNames.get(i) otherwise return out
		let paramType = try sig.paramTypes.get(i) otherwise return out
		if i > startIdx 'separator'
			out = "{out}, "
		end 'separator'
		out = "{out}{name} {paramType.toString(project)}"
	end 'eachParam'
	return out
end 'renderSignatureParams'

// `methodCall` op resolution. The receiver's MaxonType comes from
// `producerTypes` (filled by `buildProducerTypes`/`fillUnresolvedTypes`
// earlier in the pipeline). After normalising named typealiases we
// extract the receiver's struct name; an empty result indicates an
// interface-dispatch site that lowering will route through its stub
// emitter, so we skip both the resolved-name and paramTypes inserts.
function resolveMethodCallSite(project Project, module MaxonModule, opIdx OpIndex, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, producerTypes ProducerTypeMap, enclosingTypeName String, readerFilePath FilePath, funcName String, range SourceRange)
	// Idempotency guard. `propagateClosureArgTypesFromCalls` re-runs the
	// call walker for every function after refining producer types, so any
	// op the first pass already wrote to `resolvedCallees` (including
	// error-emitting early-return paths that record a sentinel below)
	// would otherwise re-emit duplicate diagnostics. The silent-miss path
	// at the receiver-name check does NOT insert, which is precisely how a
	// methodCall whose receiver became concrete only post-propagation
	// re-enters this resolver on the second pass and resolves cleanly.
	if project.resolvedCallees.contains(opIdx) 'alreadyResolved'
		return
	end 'alreadyResolved'
	let rawReceiverType = retypeCharByteReceiver(project, receiver: receiver, receiverType: lookupProducerType(producerTypes, name: receiver), funcName: funcName)
	let receiverType = normalizeReceiverInContext(project, t: rawReceiverType, enclosingType: enclosingTypeName)
	// Phase 11.4 / Phase 7: primitive receiver (`int.toString()`,
	// `bool.equals(...)`, …) — fall back to the extension type
	// name (`int`, `float`, `bool`, `byte`). Mirrors the dispatch
	// fallback in lowerMethodCall so resolvedCallees / callParamTypes
	// get populated for every primitive-extension call site.
	var receiverStructName = ""
	if let direct = try maxonTypeStructName(project, t: receiverType) 'haveStruct'
		receiverStructName = direct
	end 'haveStruct'
	if receiverStructName.isEmpty() 'tryPrimitive'
		receiverStructName = try primitiveExtensionTypeNameWithProject(project, t: receiverType) otherwise return
	end 'tryPrimitive'
	let bareMethodName = String.from(methodName)
	let baseQualified = "{receiverStructName}.{bareMethodName}"
	var resolved = resolveOverloadedCallee(project, bareQualifiedName: baseQualified, argTypes: argTypes, hasSelf: false, argLabels: argLabels)
	// Char-byte disambiguation: same retry pattern as resolveCallSite. The
	// methodCall arg list has no receiver-pseudo-arg (instance dispatch
	// supplies the receiver out-of-band), so `hasSelf` stays false here.
	if resolved == baseQualified and project.overloadedNames.contains(baseQualified) 'tryCharByteRetry'
		let retryArgTypes = retypeCharByteArgsToCharacter(project, args: args, argTypes: argTypes, hasSelf: false, funcName: funcName)
		if retryArgTypes.didSubstitute 'didRetype'
			resolved = resolveOverloadedCallee(project, bareQualifiedName: baseQualified, argTypes: retryArgTypes.types, hasSelf: false, argLabels: argLabels)
		end 'didRetype'
	end 'tryCharByteRetry'
	// Ambiguous-overload detection for instance method calls (E3007).
	// Mirrors the free-call path's check: when the resolver returned the
	// bare overload bucket name and the bucket exists, we couldn't pick.
	if resolved == baseQualified and project.overloadedNames.contains(baseQualified) 'isAmbiguous'
		reportAmbiguousOverload(project, bareQualifiedName: baseQualified, range: range, filePath: readerFilePath)
		try project.resolvedCallees.insert(opIdx, value: resolved) otherwise ignore
		return
	end 'isAmbiguous'
	// When the concrete-type qualified name has no registered signature,
	// fall back to an extension method declared on an interface that the
	// receiver conforms to (`Countable.count` for an `IntList implements
	// Countable` receiver). Without this redirect the call would emit as
	// a reference to a non-existent `IntList.count`, which the X64 backend
	// can't capture a result for — leaving the call's resultId undefined
	// and tripping the SSA-coloring "no coloring assignment" panic.
	if not project.funcSignatures.contains(resolved) 'noDirectSig'
		if let extensionCallee = try findInterfaceExtensionCallee(project, typeName: receiverStructName, methodName: bareMethodName, argTypes: argTypes) 'foundExt'
			resolved = extensionCallee
		end 'foundExt'
	end 'noDirectSig'
	// J.4b: when the resolved callee is an interface-extension method
	// whose `where Item is Trait` constraints aren't satisfied by the
	// receiver's conformance bindings, surface E4006 with the conditional-
	// availability message rather than letting the call silently resolve
	// against the un-satisfied body. Mirrors the C# bootstrap's
	// `irInvalidFieldAccess` path. Skipped for unconditional extensions
	// (empty `whereClauses`) and for stdlib-declared interfaces (the
	// existing fat-pointer dispatch handles those today).
	if not unresolvedExtensionWhereClausesSatisfiedForCallee(project, callee: resolved, receiverType: receiverType) 'whereFailed'
		reportConditionalExtensionUnsatisfied(project, callee: resolved, receiverType: receiverType, methodName: bareMethodName, range: range, filePath: readerFilePath)
		// Insert a sentinel so the second-pass re-resolve (from
		// `propagateClosureArgTypesFromCalls`) sees this site as already
		// attempted and skips it — otherwise the diagnostic above would
		// fire twice. The value is the unresolved callee (it's not used
		// downstream because lowering will not reach a code-emit path for
		// this op given the reported error).
		try project.resolvedCallees.insert(opIdx, value: resolved) otherwise ignore
		return
	end 'whereFailed'
	// J.4b: per-receiver monomorphization for user-declared interface
	// extensions. When the resolved callee belongs to a user-declared
	// interface (i.e. `extension SomeInterface where ...`) and the receiver
	// is a concrete named/genericInstance type, clone the body with the
	// receiver's `withArgs` substituted in and re-point the resolved
	// callee at the monomorphized name. Stdlib-defined interface
	// extensions (Iterable.map / .filter etc.) are J.4c work; we restrict
	// to user-source declarations by skipping any interface whose
	// declaring file is the stdlib cache bootstrap path.
	let monoCallee = try maybeMonomorphizeUserExtension(project, module: module, calleeQualified: resolved, receiverType: receiverType) otherwise resolved
	resolved = monoCallee
	try project.resolvedCallees.insert(opIdx, value: resolved) otherwise ignore
	let signature = try project.funcSignatures.get(resolved) otherwise return
	let substituted = substituteParamTypes(project, signature: signature, qualifiedCallee: resolved, receiverType: receiverType)
	try project.callParamTypes.insert(opIdx, value: substituted) otherwise ignore
end 'resolveMethodCallSite'

// J.4b gate: attempt to monomorphize the call site's resolved callee
// against the concrete receiver type. Skips when the callee isn't an
// interface extension method, when the receiver isn't a concrete named /
// generic-instance type, or when the interface was declared in a stdlib
// source (stdlib-extension monomorphization is J.4c's scope). Returns
// the monomorphized name on success; throws the same error union the
// underlying cloner uses so callers can drop back to the un-monomorphized
// callee with a single `try ... otherwise` without a separate sentinel.
function maybeMonomorphizeUserExtension(project Project, module MaxonModule, calleeQualified String, receiverType MaxonType) returns String throws MonomorphError
	let calleeBytes = calleeQualified.toByteArray()
	let dotIdx = lastIndexOfDotByte(calleeBytes)
	if dotIdx >= calleeBytes.count() 'noDot'
		throw MonomorphError.notInterfaceCallee
	end 'noDot'
	let ifaceName = byteSliceToString(calleeBytes, startIndex: 0, endIndex: dotIdx)
	if not (project.interfaces.contains(ifaceName) or project.unresolvedInterfaces.contains(ifaceName)) 'notIface'
		throw MonomorphError.notInterfaceCallee
	end 'notIface'
	// J.4d: stdlib-declared interfaces (Iterable.map / .filter / .contains)
	// are now monomorphized too. The cloner falls back to the in-process
	// `stdlibParsedModule` when the source body isn't in the user module.
	return try monomorphizeInterfaceExtension(project, module: module, calleeQualified: calleeQualified, receiverType: receiverType) otherwise throw MonomorphError.notInterfaceCallee
end 'maybeMonomorphizeUserExtension'

// Walk every conformance whose typeName matches the receiver and probe
// `<InterfaceName>.<methodName>` against `funcSignatures`. Returns the
// first registered qualified name; throws `InterfaceExtensionLookupError.notFound`
// when no conforming interface declares this extension method. Conformance
// lookup hits the same registry that `typeConformsTo` uses, so transitive
// entries seeded by `validateConformances` (`B implements A` brings A's
// extensions to B) are visible without re-walking the
// interface-extends-interface chain.
function findInterfaceExtensionCallee(project Project, typeName String, methodName String, argTypes MaxonTypeArray) returns String throws InterfaceExtensionLookupError
	let total = project.conformances.count()
	for i in 0 upto total 'eachConf'
		let (confType, ifaceName, _) = project.conformances.get(i)
		if confType != typeName 'skipOther'
			continue
		end 'skipOther'
		let candidate = "{ifaceName}.{methodName}"
		let resolvedCandidate = resolveOverloadedCallee(project, bareQualifiedName: candidate, argTypes: argTypes, hasSelf: false)
		if project.funcSignatures.contains(resolvedCandidate) 'hit'
			return resolvedCandidate
		end 'hit'
	end 'eachConf'
	throw InterfaceExtensionLookupError.notFound
end 'findInterfaceExtensionCallee'

enum InterfaceExtensionLookupError implements Error
	notFound
end 'InterfaceExtensionLookupError'

// J.4b: true when the resolved callee is *not* an interface-extension
// method, OR is one whose `where` constraints are satisfied by the
// receiver's conformance bindings. Returns false only when we identify
// an interface-extension callee AND a constraint fails — so callers
// fall through to E4006 only on genuine availability misses, not on
// every methodCall that happens to pass through this branch.
function unresolvedExtensionWhereClausesSatisfiedForCallee(project Project, callee String, receiverType MaxonType) returns bool
	let calleeBytes = callee.toByteArray()
	let dotIdx = lastIndexOfDotByte(calleeBytes)
	if dotIdx >= calleeBytes.count() 'noDot'
		return true
	end 'noDot'
	let ifaceName = byteSliceToString(calleeBytes, startIndex: 0, endIndex: dotIdx)
	if not (project.interfaces.contains(ifaceName) or project.unresolvedInterfaces.contains(ifaceName)) 'notIface'
		return true
	end 'notIface'
	// Look up the extension's whereClauses for this specific
	// (interface, method) via the parser-recorded sidecar; absent
	// means the method was declared by an unconditional extension
	// (or wasn't declared in an extension at all). Either case is
	// "no constraints to check".
	let whereClauses = try project.extensionMethodWhereClauses.get(callee) otherwise return true
	if whereClauses.count() == 0 'noWhere'
		return true
	end 'noWhere'
	let subst = buildExtensionUsesParamSubstitution(project, receiverType: receiverType, ifaceName: ifaceName)
	return whereClauseSatisfied(project, constraints: whereClauses, subst: subst)
end 'unresolvedExtensionWhereClausesSatisfiedForCallee'

// J.4b: emit E4006 with the C#-bootstrap-compatible message for a
// methodCall site whose interface-extension `where` constraints aren't
// satisfied by the receiver's bindings. The message lists the
// constraint that failed and the concrete type that doesn't implement
// the required trait.
function reportConditionalExtensionUnsatisfied(project Project, callee String, receiverType MaxonType, methodName String, range SourceRange, filePath FilePath)
	let receiverName = baseNameOfReceiverType(project, selfType: receiverType)
	let calleeBytes = callee.toByteArray()
	let dotIdx = lastIndexOfDotByte(calleeBytes)
	let ifaceName = byteSliceToString(calleeBytes, startIndex: 0, endIndex: dotIdx) if dotIdx < calleeBytes.count() else ""
	var failedParam = ""
	var failedTrait = ""
	var failedConcreteName = ""
	let whereClauses = try project.extensionMethodWhereClauses.get(callee) otherwise WhereClauseArray.create()
	let subst = buildExtensionUsesParamSubstitution(project, receiverType: receiverType, ifaceName: ifaceName)
	for i in 0 upto whereClauses.count() 'eachClause'
		let c = try whereClauses.get(i) otherwise panic("reportConditionalExtensionUnsatisfied: whereClauses.get OOB at {i}")
		let paramId = project.typeParameters.intern(c.declaringTypeName, paramName: c.paramName)
		let concrete = subst.lookup(paramId)
		if not typeConformsTo(project, t: concrete, interfaceName: c.requiredTraitName) 'fail'
			failedParam = c.paramName
			failedTrait = c.requiredTraitName
			failedConcreteName = concrete.toString(project)
			break
		end 'fail'
	end 'eachClause'
	let msg = "Type '{receiverName}' has no field named '{methodName}' ('{methodName}' is available as a conditional extension where {failedParam} is {failedTrait}, but '{failedConcreteName}' does not implement '{failedTrait}')"
	reportCompileError(project, code: ErrorCode.irInvalidFieldAccess, message: msg, line: range.line, column: range.column, filePath: filePath)
end 'reportConditionalExtensionUnsatisfied'

// Build the substituted paramTypes vector for one call site by running
// every signature paramType through the existing
// `resolveCalleeParamTypeInContext` (single-slot substitution). A
// still-`typeParameter` arm after substitution is *not* an error — it
// occurs naturally when the caller is itself a generic body (e.g.
// `Array.from` calling `result.push(item)` with `Element` still free).
// Lowering treats those slots as ABI-uniform pass-through, identical
// to the cache-time `MaxonType.unresolved` builtin slots.
function substituteParamTypes(project Project, signature FuncSignature, qualifiedCallee String, receiverType MaxonType) returns MaxonTypeArray
	var substituted = MaxonTypeArray.create()
	for i in 0 upto signature.paramTypes.count() 'eachParam'
		let raw = try signature.paramTypes.get(i) otherwise panic("substituteParamTypes: signature.paramTypes.get({i}) failed for callee={qualifiedCallee}")
		let resolved = resolveCalleeParamTypeInContext(project, paramType: raw, calleeQualifiedName: qualifiedCallee, receiverType: receiverType)
		substituted.push(resolved)
	end 'eachParam'
	return substituted
end 'substituteParamTypes'

// J.4f.2: name → opIdx lookup table for a single function. Built by
// `propagateClosureArgTypesFromCalls` on demand so the lookup that connects
// `methodCall(args=[...])` to the matching `functionRef`/`closureCreate`
// producer doesn't have to re-scan the function for every argument.
typealias NameToOpIdxMap = Map with (ByteArray, OpIndex)

// J.4f.2 implementation: walk every methodCall/call/tryMethodCall/tryCall
// op in `module`. For each closure-typed argument whose lifted-function
// `paramTypes` still contain `MaxonType.unresolved`, copy the concrete
// signature from the call's `callParamTypes` substitution, patch the
// lifted function's scope/varLoad slotTypes/FuncSignature, re-intern the
// FunctionTypeId, update the producer op, and re-run the affected lifted
// body's producer-type pass + return-type resolution so downstream
// consumers see the now-concrete types.
function propagateClosureArgTypesFromCalls(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, slotTypesPerFunc SlotTypeMapArray)
	var liftedToRebuild = StringArray.create()
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("propagateClosureArgTypesFromCalls: funcIdx OOB")
		var producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("propagateClosureArgTypesFromCalls: producerTypesPerFunc.get({funcIdx}) failed")
		let nameToOpIdx = buildNameToOpIdxMap(module, func: func)
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("propagateClosureArgTypesFromCalls: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("propagateClosureArgTypesFromCalls: opIdx OOB")
				maybePropagateForCallOp(project, module: module, op: op, opIdx: opIdx, producerTypes: producerTypes, nameToOpIdx: nameToOpIdx, liftedToRebuild: liftedToRebuild)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'

	// Rebuild producer types + slot types for each lifted body we patched,
	// then re-stamp the lifted function's return type from the new
	// producers. Mirrors `patchClosureEnvLoadCaptureTypes`'s rebuild
	// epilogue so downstream consumers (fieldLoad / methodCall result
	// types) see the refreshed slot info.
	for funcIdx in 0 upto module.functions.count() 'rebuildLoop'
		var func = try module.functions.get(funcIdx) otherwise panic("propagateClosureArgTypesFromCalls: rebuild funcIdx OOB")
		if not liftedToRebuild.contains(func.name) 'skipFunc'
			continue
		end 'skipFunc'
		var freshProducers = ProducerTypeMap.create()
		var freshSlots = SlotTypeMap.create()
		recordFuncOpResults(project, module: module, func: func, producerTypes: freshProducers, slotTypes: freshSlots)
		try producerTypesPerFunc.set(funcIdx, value: freshProducers) otherwise panic("propagateClosureArgTypesFromCalls: producerTypesPerFunc.set OOB")
		try slotTypesPerFunc.set(funcIdx, value: freshSlots) otherwise panic("propagateClosureArgTypesFromCalls: slotTypesPerFunc.set OOB")

		// If the lifted function's return type was left at
		// `value(unresolved)` by the parser (it always is for an
		// untyped-param closure), stamp it from the ret value's freshly-
		// recorded producer type.
		let needsReturnResolve = match func.maxonReturnType 'check'
			void gives false
			value(inner) gives isUnresolvedType(inner)
		end 'check'
		if needsReturnResolve 'resolveRet'
			let resolved = findRetTypeFromProducers(module, func: func, producerTypes: freshProducers)
			if not isUnresolvedType(resolved) 'haveResolved'
				let newReturn = MaxonReturnType.value(resolved)
				func.maxonReturnType = newReturn
				project.funcReturnTypes.upsert(func.name, value: newReturn)
			end 'haveResolved'
		end 'resolveRet'
	end 'rebuildLoop'

	// Refresh producer types and re-resolve calls for EVERY function.
	// Two stale-producer sources sit between the initial `resolveAllCalls`
	// pass and lowering:
	//   1. The lifted-body rebuild above refines closure-arg slot types.
	//   2. `backfillTopLevelVarSlotTypes` (called pre-`resolveAllCalls`)
	//      mutates `globalLoad` op slotTypes inline without refreshing the
	//      per-function producer-type maps that `buildProducerTypes` had
	//      already stamped from the pre-backfill values.
	// Either source can leave a methodCall whose receiver was `unresolved`
	// at `resolveAllCalls` time but is concrete at lowering time —
	// `resolveMethodCallSite`'s silent-miss path (early-return when the
	// receiver isn't a struct/primitive yet) would skip the
	// `resolvedCallees` insert, and `lowerMethodCall`'s invariant tripwire
	// would then panic. Re-recording producers and re-running the call
	// walker is idempotent (`resolveOneCallOp` overwrites entries) and
	// covers both cases without having to track which functions were
	// touched by which refinement pass.
	for funcIdx in 0 upto module.functions.count() 'reresolveLoop'
		let func = try module.functions.get(funcIdx) otherwise panic("propagateClosureArgTypesFromCalls: reresolve funcIdx OOB")
		var freshProducers = ProducerTypeMap.create()
		var freshSlots = SlotTypeMap.create()
		recordFuncOpResults(project, module: module, func: func, producerTypes: freshProducers, slotTypes: freshSlots)
		// `resolveAllCalls`'s on-demand block only pushes onto
		// `producerTypesPerFunc` for newly-appended monomorphized clones
		// — `slotTypesPerFunc` lags behind. Push fresh entries when the
		// per-func arrays haven't caught up to the current function index,
		// then set them to the freshly-recorded maps.
		while producerTypesPerFunc.count() <= funcIdx 'padProducers'
			producerTypesPerFunc.push(ProducerTypeMap.create())
		end 'padProducers'
		while slotTypesPerFunc.count() <= funcIdx 'padSlots'
			slotTypesPerFunc.push(SlotTypeMap.create())
		end 'padSlots'
		try producerTypesPerFunc.set(funcIdx, value: freshProducers) otherwise panic("propagateClosureArgTypesFromCalls: reresolve producerTypesPerFunc.set OOB after pad")
		try slotTypesPerFunc.set(funcIdx, value: freshSlots) otherwise panic("propagateClosureArgTypesFromCalls: reresolve slotTypesPerFunc.set OOB after pad")
		let enclosingType = try enclosingTypeNameForCallee(project, callee: func.name) otherwise ""
		resolveAllCallsForFunc(project, module: module, func: func, producerTypes: freshProducers, enclosingType: enclosingType)
	end 'reresolveLoop'

	// After the lifted return types are concrete, walk closureCreate /
	// functionRef ops one more time so any FunctionTypeRegistry entry
	// whose return type was placeholder-unresolved gets re-stamped — the
	// param-patch above re-interned the registry entry with the
	// then-still-unresolved return type, so the registry entry for the
	// new id has a fresh-but-stale return field until this final patch.
	patchFunctionTypeRegistryReturns(project, module: module)
end 'propagateClosureArgTypesFromCalls'

// Build a result-name → opIdx index that covers ONLY the two op kinds
// that can produce a closure-literal value: `functionRef` and
// `closureCreate`. The propagation pass only needs to recover producer
// ops for these — every other op kind's result is irrelevant for closure
// arg-type inference, so a partial index keeps this pass cheap and avoids
// having to track the (large, churn-prone) full MaxonOp variant list.
function buildNameToOpIdxMap(module MaxonModule, func IrFunction) returns NameToOpIdxMap
	var nameToOpIdx = NameToOpIdxMap.create()
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("buildNameToOpIdxMap: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("buildNameToOpIdxMap: opIdx OOB")
			if op.name != "functionRef" and op.name != "closureCreate" 'skipKind'
				continue
			end 'skipKind'
			let result = match op 'extract'
				functionRef(r, _, _, _) gives r
				closureCreate(r, _, _, _, _, _) gives r
				default panic("buildNameToOpIdxMap: op.name in [functionRef, closureCreate] but match arm not picked up")
			end 'extract'
			if not result.isEmpty() 'recordIt'
				nameToOpIdx.upsert(result, value: opIdx)
			end 'recordIt'
		end 'eachOp'
	end 'eachBlock'
	return nameToOpIdx
end 'buildNameToOpIdxMap'

// Inspect one op in a caller function. If it's a methodCall/call (or its
// `try*` variant) with substituted callParamTypes registered, walk each
// argument; closure-typed args whose lifted function has unresolved param
// slots get patched from the substituted target signature.
function maybePropagateForCallOp(project Project, module MaxonModule, op MaxonOp, opIdx OpIndex, producerTypes ProducerTypeMap, nameToOpIdx NameToOpIdxMap, liftedToRebuild StringArray)
	// Pre-filter on op.name so the destructuring match below only handles
	// the four call shapes that participate in callParamTypes; a wildcard
	// `default` arm on the union would have to choose between throwing
	// and panicking, neither of which fits "skip this op".
	if op.name != "methodCall" and op.name != "tryMethodCall" and op.name != "call" and op.name != "tryCall" 'notACall'
		return
	end 'notACall'
	let (args, argTypes) = match op 'extract'
		methodCall(_, _, _, a, _, at, _, _) gives(a, at)
		tryMethodCall(_, _, _, a, _, at, _, _, _) gives(a, at)
		call(_, _, _, a, _, at, _, _) gives(a, at)
		tryCall(_, _, _, a, _, at, _, _, _) gives(a, at)
		default panic("maybePropagateForCallOp: op.name in [methodCall, tryMethodCall, call, tryCall] but match arm not picked up — variant drift?")
	end 'extract'
	if args.count() == 0 'noArgs'
		return
	end 'noArgs'
	if not project.callParamTypes.contains(opIdx) 'noParams'
		return
	end 'noParams'
	let substituted = try project.callParamTypes.get(opIdx) otherwise panic("maybePropagateForCallOp: callParamTypes.get failed after contains check at opIdx={opIdx}")
	// Substituted vector may include a leading `self` slot for instance
	// methods; pair against the trailing user-arg slots from the right
	// end so a Phase-7 receiver-prefixed signature matches the
	// argument-without-receiver vector that methodCall ops carry.
	let argCount = args.count()
	let subCount = substituted.count()
	if subCount < argCount 'shorter'
		return
	end 'shorter'
	let offset = subCount - argCount
	for i in 0 upto argCount 'eachArg'
		let argName = try args.get(i) otherwise panic("maybePropagateForCallOp: args.get({i}) failed")
		let argType = try argTypes.get(i) otherwise panic("maybePropagateForCallOp: argTypes.get({i}) failed")
		let expectedRaw = try substituted.get(i + offset) otherwise panic("maybePropagateForCallOp: substituted.get({i + offset}) failed")
		// Chase through a named function-type alias so a parameter declared as
		// `transform ElementTransform` still propagates the underlying
		// `function(Element) returns Element` shape to a closure literal at
		// the call site.
		let expected = chaseTypealiasToFunctionType(project, t: expectedRaw)
		if not isFunctionMaxonType(expected) 'expectedNotFn'
			continue
		end 'expectedNotFn'
		if not isFunctionMaxonType(argType) 'argNotFn'
			continue
		end 'argNotFn'
		let srcFnId = functionMaxonTypeId(argType)
		let (srcParams, _) = project.functionTypes.get(srcFnId)
		if not functionTypeHasUnresolved(srcParams) 'alreadyConcrete'
			continue
		end 'alreadyConcrete'
		let producerOpIdx = try nameToOpIdx.get(argName) otherwise continue
		patchOneClosureArg(project, module: module, producerOpIdx: producerOpIdx, expectedFn: expected, producerTypes: producerTypes, liftedToRebuild: liftedToRebuild)
	end 'eachArg'
end 'maybePropagateForCallOp'

// True iff `paramTypes` contains at least one `MaxonType.unresolved`. The
// FunctionTypeRegistry encodes a closure literal's signature; if any param
// slot is still unresolved here the closure was the untyped-param shape.
function functionTypeHasUnresolved(paramTypes MaxonTypeArray) returns bool
	for i in 0 upto paramTypes.count() 'each'
		let t = try paramTypes.get(i) otherwise panic("functionTypeHasUnresolved: paramTypes.get OOB at {i}")
		if isUnresolvedType(t) 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'functionTypeHasUnresolved'

// Patch a single closure-arg site: locate the lifted IrFunction by name,
// substitute its unresolved user-param types from `expectedFn`'s signature,
// update FuncSignature.paramTypes, scope's VarInfo, every varLoad's
// slotType, re-intern the FunctionTypeId, and rewrite the
// functionRef/closureCreate op + the producerTypes entry to carry the new id.
function patchOneClosureArg(project Project, module MaxonModule, producerOpIdx OpIndex, expectedFn MaxonType, producerTypes ProducerTypeMap, liftedToRebuild StringArray)
	let producerOp = try module.ops.get(producerOpIdx) otherwise panic("patchOneClosureArg: ops.get({producerOpIdx}) failed")
	// Only `functionRef` and `closureCreate` produce a `function(_)` SSA
	// value at this stage. Anything else means the call site's arg was
	// e.g. a varLoad of a function-typed local — patching the original
	// closure literal would have already happened when its source call
	// site was visited, so there's nothing to do here.
	if producerOp.name != "functionRef" and producerOp.name != "closureCreate" 'notAClosure'
		return
	end 'notAClosure'
	let (result, liftedName) = match producerOp 'extractClosure'
		functionRef(r, n, _, _) gives(r, n)
		closureCreate(r, n, _, _, _, _) gives(r, n)
		default panic("patchOneClosureArg: producer op kind drift — pre-filter said functionRef/closureCreate but match didn't bind")
	end 'extractClosure'

	// Locate the lifted IrFunction.
	var liftedIdx = -1
	for fIdx in 0 upto module.functions.count() 'find'
		let candidate = try module.functions.get(fIdx) otherwise panic("patchOneClosureArg: functions.get({fIdx}) failed")
		if candidate.name == liftedName 'match'
			liftedIdx = fIdx
			break
		end 'match'
	end 'find'
	if liftedIdx < 0 'notFound'
		return
	end 'notFound'
	var liftedFunc = try module.functions.get(liftedIdx) otherwise panic("patchOneClosureArg: functions.get({liftedIdx}) failed after locate")

	let targetFnId = functionMaxonTypeId(expectedFn)
	let (targetParams, targetReturn) = project.functionTypes.get(targetFnId)
	if not project.funcSignatures.contains(liftedName) 'noSig'
		return
	end 'noSig'
	let signature = try project.funcSignatures.get(liftedName) otherwise panic("patchOneClosureArg: funcSignatures.get({liftedName}) failed after contains check")
	let userParamCount = signature.paramTypes.count()
	if userParamCount > targetParams.count() 'mismatchedArity'
		return
	end 'mismatchedArity'

	// Build the new user-param types: replace each unresolved slot from
	// the target's matching slot; preserve any that the parser already
	// resolved (in the mixed-typed-and-untyped case).
	var newUserParams = MaxonTypeArray.create()
	var anyChanged = false
	for i in 0 upto userParamCount 'eachParam'
		let cur = try signature.paramTypes.get(i) otherwise panic("patchOneClosureArg: signature.paramTypes.get({i}) failed")
		let next = try targetParams.get(i) otherwise panic("patchOneClosureArg: targetParams.get({i}) failed")
		if isUnresolvedType(cur) and not isUnresolvedType(next) 'patch'
			newUserParams.push(next)
			anyChanged = true
		end 'patch' else 'keep'
			newUserParams.push(cur)
		end 'keep'
	end 'eachParam'
	if not anyChanged 'nothingToDo'
		return
	end 'nothingToDo'

	// Replace the lifted FuncSignature.
	let newSig = FuncSignature.create(signature.paramNames, paramTypes: newUserParams, paramDefaults: signature.paramDefaults)
	project.funcSignatures.upsert(liftedName, value: newSig)

	// Patch the lifted IrFunction's maxonParamTypes — same layout as the
	// signature plus the trailing `__env` slot (parser always appends one
	// `MaxonType.integer` to every closure body). Preserve the env slot
	// verbatim.
	var newIrParams = MaxonTypeArray.create()
	for i in 0 upto userParamCount 'newUserSlot'
		let t = try newUserParams.get(i) otherwise panic("patchOneClosureArg: newUserParams.get({i}) failed")
		newIrParams.push(t)
	end 'newUserSlot'
	for i in userParamCount upto liftedFunc.maxonParamTypes.count() 'envTail'
		let t = try liftedFunc.maxonParamTypes.get(i) otherwise panic("patchOneClosureArg: liftedFunc.maxonParamTypes.get({i}) failed")
		newIrParams.push(t)
	end 'envTail'
	liftedFunc.maxonParamTypes = newIrParams

	// Patch the lifted function's scope: for each user param name, install
	// a VarInfo with the new MaxonType while preserving slot id + mutable.
	for i in 0 upto userParamCount 'patchScope'
		let pName = try signature.paramNames.get(i) otherwise panic("patchOneClosureArg: paramNames.get({i}) failed")
		if pName == "_" 'discardParam'
			continue
		end 'discardParam'
		if not liftedFunc.scope.contains(pName) 'notInScope'
			continue
		end 'notInScope'
		let info = liftedFunc.scope.getInfo(pName)
		let newType = try newUserParams.get(i) otherwise panic("patchOneClosureArg: newUserParams.get({i}) failed during scope patch")
		let newInfo = VarInfo.create(pName, varType: newType, mutable: info.mutable, slot: info.slot)
		liftedFunc.scope.installVerbatim(newInfo)
	end 'patchScope'

	// Patch every varLoad op in the lifted body whose slotId matches a
	// user-param slot AND whose slotType is unresolved. Slot ids 0..N-1
	// correspond to user params in declaration order — parseClosure
	// declares params first in a fresh scope, so the mapping is direct.
	for blockRef in liftedFunc.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("patchOneClosureArg: blockRef OOB on lifted body")
		for bodyOpIdx in block.opRefs 'eachOp'
			let bodyOp = try module.ops.get(bodyOpIdx) otherwise panic("patchOneClosureArg: bodyOp opIdx OOB")
			patchVarLoadSlotTypeIfMatches(module, opIdx: bodyOpIdx, op: bodyOp, newUserParams: newUserParams)
		end 'eachOp'
	end 'eachBlock'

	// Re-intern the FunctionTypeId for the new signature. The captured
	// return type stays as it was — the rebuild epilogue re-stamps it
	// from the body's producers once we know it.
	let newFnTypeId = internFunctionType(project, paramTypes: newUserParams, returnType: targetReturn)
	let newFnType = MaxonType.function(newFnTypeId)

	// Rewrite the producer op so downstream consumers (lowering's
	// indirect-call sites) read the patched fnTypeId. Keep the same
	// result name and source range; the closureCreate variant additionally
	// preserves the captured-names/types arrays.
	match producerOp 'rewriteOp'
		functionRef(r, n, _, range) then rewriteFunctionRef(module, opIdx: producerOpIdx, result: r, funcName: n, fnTypeId: newFnTypeId, range: range)
		closureCreate(r, n, _, names, types, range) then rewriteClosureCreate(module, opIdx: producerOpIdx, result: r, funcName: n, fnTypeId: newFnTypeId, capturedNames: names, capturedTypes: types, range: range)
		default panic("patchOneClosureArg: producer op no longer functionRef/closureCreate")
	end 'rewriteOp'

	// Refresh the closure's producer type so consumers that already
	// queried `lookupProducerType(closureResult)` re-read the new fnId.
	recordResultType(producerTypes, name: result, t: newFnType)

	if not liftedToRebuild.contains(liftedName) 'addOnce'
		liftedToRebuild.push(liftedName)
	end 'addOnce'
end 'patchOneClosureArg'

// Patch one body-op's varLoad slotType when its slotId is a user-param
// slot AND the parser-stamped slotType was unresolved. Other ops pass
// through untouched.
function patchVarLoadSlotTypeIfMatches(module MaxonModule, opIdx OpIndex, op MaxonOp, newUserParams MaxonTypeArray)
	if op.name != "varLoad" 'notVarLoad'
		return
	end 'notVarLoad'
	match op 'check'
		varLoad(r, slotId, slotType, range) then patchVarLoadIfParamSlot(module, opIdx: opIdx, result: r, slotId: slotId, slotType: slotType, range: range, newUserParams: newUserParams)
		default panic("patchVarLoadSlotTypeIfMatches: op.name was varLoad but match arm didn't bind — variant drift?")
	end 'check'
end 'patchVarLoadSlotTypeIfMatches'

// Apply the patch if the varLoad's slotId falls in the user-param range
// and its slotType is currently unresolved. User-param slot ids are
// 0..userParamCount-1 — parseClosure declares params first in a fresh
// scope so this mapping is stable.
function patchVarLoadIfParamSlot(module MaxonModule, opIdx OpIndex, result ByteArray, slotId VarSlot, slotType MaxonType, range SourceRange, newUserParams MaxonTypeArray)
	let userParamCount = newUserParams.count()
	if slotId >= userParamCount 'notAParamSlot'
		return
	end 'notAParamSlot'
	if not isUnresolvedType(slotType) 'alreadyConcrete'
		return
	end 'alreadyConcrete'
	let newType = try newUserParams.get(slotId) otherwise panic("patchVarLoadIfParamSlot: newUserParams.get({slotId}) failed after bound check")
	if isUnresolvedType(newType) 'noNewType'
		return
	end 'noNewType'
	try module.ops.set(opIdx, value: MaxonOp.varLoad(result, slotId: slotId, slotType: newType, range: range)) otherwise panic("patchVarLoadIfParamSlot: ops.set OOB at idx={opIdx}")
end 'patchVarLoadIfParamSlot'

// Rewrite a `functionRef` op with a new `fnTypeId`. Used after re-interning
// the closure's signature so the indirect-call producer-op carries the
// updated id.
function rewriteFunctionRef(module MaxonModule, opIdx OpIndex, result ByteArray, funcName String, fnTypeId FunctionTypeId, range SourceRange)
	try module.ops.set(opIdx, value: MaxonOp.functionRef(result, funcName: funcName, fnTypeId: fnTypeId, range: range)) otherwise panic("rewriteFunctionRef: ops.set OOB at idx={opIdx}")
end 'rewriteFunctionRef'

// Rewrite a `closureCreate` op with a new `fnTypeId`, preserving captured
// names + types. Mirror of `rewriteFunctionRef` for the capturing variant.
function rewriteClosureCreate(module MaxonModule, opIdx OpIndex, result ByteArray, funcName String, fnTypeId FunctionTypeId, capturedNames StringArray, capturedTypes MaxonTypeArray, range SourceRange)
	try module.ops.set(opIdx, value: MaxonOp.closureCreate(result, funcName: funcName, fnTypeId: fnTypeId, capturedNames: capturedNames, capturedTypes: capturedTypes, range: range)) otherwise panic("rewriteClosureCreate: ops.set OOB at idx={opIdx}")
end 'rewriteClosureCreate'

// `call` ops we skip entirely — these never reach `slotArgsForCall` in
// lowering, so caching their resolution is wasted work. The list mirrors
// the early-return prefix checks in `lowerCall` itself.
//
// `__mm_alloc_count` lowers to a `globalAddr + load` rather than a call,
// so resolving it through the regular pipeline would just waste a
// resolvedCallees entry. The other `__mm_*` names (alloc/decref/incref/free)
// are now real stdlib functions in `stdlib/Internals.maxon` and DO need
// normal resolution.
function shouldSkipCallSite(bareCallee String) returns bool
	if bareCallee == "__mm_alloc_count" 'isCountIntrinsic'
		return true
	end 'isCountIntrinsic'
	return isMathIntrinsicName(bareCallee)
end 'shouldSkipCallSite'

// The math-primitive callees that lowering inlines as Std unary/binary
// ops. Centralised so `shouldSkipCallSite` and `lowerMathIntrinsic` agree
// on the set without either side accidentally drifting.
function isMathIntrinsicName(name String) returns bool
	return name == "sqrt" or name == "floor" or name == "ceil" or name == "round" or name == "abs" or name == "trunc" or name == "min" or name == "max"
end 'isMathIntrinsicName'

// --- Arity validation ---
//
// Walks every function once, looks up each `call` / `methodCall` op's
// signature in `project.funcSignatures`, and reports E3036 when the source
// arg count exceeds the user-param-slot count (signature param count minus
// the receiver/self slot offset). Calls / methods with no registered
// signature (interface dispatch, missing functions) are skipped — those
// fall through lowering's no-signature path which doesn't panic.
function validateCallArities(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateCallArities: funcIdx < count but get failed")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateCallArities: producerTypesPerFunc.get({funcIdx}) failed")
		// Use the function's own declaring file as the reader path so
		// cross-namespace callee qualification can filter by visibility
		// against the function being checked. The pass-level `filePath`
		// stays as the diagnostics fallback.
		let readerPath = func.sourceFilePath
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateCallArities: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateCallArities: opIdx OOB")
				validateCallArityOp(project, op: op, producerTypes: producerTypes, currentNamespace: func.namespace, readerFilePath: readerPath, filePath: filePath)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateCallArities'

// --- E3005: named-argument-required validation for methodCall ops ---
//
// Method calls (`receiver.method(args)`) have the named-arg-required check
// deferred from parse time so the resolved receiver type can dictate
// enforcement. The C# bootstrap parser exempts compiler-builtin method
// calls from the "second and subsequent positional args must be named" rule
// by passing `allowAllPositional: true` in `ParseBuiltinMethodArgs`. The
// self-hosted parser cannot tell `mm.set(idx, val)` (where
// `mm: __ManagedMemory`) from `widget.set(idx, val)` at parse time without
// resolving the receiver, so it skips the check on methodCall sites and
// this pass re-applies it after fillUnresolvedTypes has resolved producer
// types.
//
// `call` and `indirectCall` ops keep the parser-time check because the
// bare callee name is enough to identify a builtin: any callee whose top-
// level segment starts with `__` is a compiler builtin (project convention
// — `__ManagedMemory`, `__ManagedList`, etc.). User-defined names cannot
// start with `__` because the prefix is reserved for builtins.
//
// The diagnostic location uses the offending arg's per-arg range that the
// parser captured in `argRanges`, matching the original parse-time
// emission position (the first token of the unnamed positional arg).
function validateCallArgLabels(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateCallArgLabels: funcIdx < count but get failed")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateCallArgLabels: producerTypesPerFunc.get({funcIdx}) failed")
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("validateCallArgLabels: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("validateCallArgLabels: opIdx OOB")
				if op.name == "methodCall" or op.name == "tryMethodCall" 'isMethodCall'
					match op 'extractMC'
						methodCall(_, receiver, _, args, argLabels, _, argRanges, _) then validateMethodCallArgLabels(project, receiver: receiver, args: args, argLabels: argLabels, argRanges: argRanges, producerTypes: producerTypes, filePath: filePath)
						tryMethodCall(_, receiver, _, args, argLabels, _, argRanges, _, _) then validateMethodCallArgLabels(project, receiver: receiver, args: args, argLabels: argLabels, argRanges: argRanges, producerTypes: producerTypes, filePath: filePath)
						default panic("unreachable: already checked name in [methodCall, tryMethodCall]")
					end 'extractMC'
				end 'isMethodCall'
				if op.name == "call" or op.name == "tryCall" 'isCall'
					match op 'extractC'
						call(_, callee, _, args, argLabels, _, argRanges, _) then validateQualifiedCallArgLabels(project, callee: callee, args: args, argLabels: argLabels, argRanges: argRanges, filePath: filePath)
						tryCall(_, callee, _, args, argLabels, _, argRanges, _, _) then validateQualifiedCallArgLabels(project, callee: callee, args: args, argLabels: argLabels, argRanges: argRanges, filePath: filePath)
						default panic("unreachable: already checked name in [call, tryCall]")
					end 'extractC'
				end 'isCall'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'validateCallArgLabels'

// E3005 for qualified static calls (`Type.method(...)`). The parser routes
// every qualified call through the deferred path because it cannot tell a
// builtin like `__ManagedMemory.create(...)` (or its typealias
// `ByteMemory.create(...)`) from a user-defined static. Here, after typealias
// resolution, we look at the callee's type prefix and skip the check when
// the prefix resolves to a `__`-prefixed builtin type — matching the C#
// bootstrap's `allowAllPositional: true` for builtin static methods.
function validateQualifiedCallArgLabels(project Project, callee ByteArray, args ByteArrayArray, argLabels StringArray, argRanges SourceRangeArray, filePath FilePath)
	let calleeStr = String.from(callee)
	let calleeBytes = calleeStr.toByteArray()
	var dotIdx = -1 as ParsedInt
	for i in 0 upto calleeBytes.count() 'scan'
		let b = try calleeBytes.get(i) otherwise return
		if b == '.' 'hit'
			dotIdx = i
			break
		end 'hit'
	end 'scan'
	// Free / unqualified calls (no dot in callee) are out of scope here —
	// those go through the parser's parseCallArgsRaw default path which
	// already enforces the rule, and were never re-routed into the
	// deferred path.
	if dotIdx < 0 'noDot'
		return
	end 'noDot'
	let prefixBytes = try calleeBytes.slice(0, endIndex: dotIdx) otherwise return
	let prefix = String.from(prefixBytes)
	// Builtin types are `__`-prefixed by convention; user-defined names
	// cannot start with `__`.
	if prefix.startsWith("__") 'isBuiltin'
		return
	end 'isBuiltin'
	// A typealias resolving to a `__`-prefixed builtin (e.g.
	// `typealias ByteMemory = __ManagedMemory with Byte`) shows up in
	// `project.genericTypealiases` after the resolver drain.
	if let resolved = try project.genericTypealiases.get(prefix) 'isGenAlias'
		let resolvedName = resolved.nameOrEmpty(project)
		if resolvedName.startsWith("__") 'aliasIsBuiltin'
			return
		end 'aliasIsBuiltin'
	end 'isGenAlias'
	// Or it shows up as an inner alias on a struct (`typealias ByteMemory
	// = __ManagedMemory with Byte` inside `type Character ... end`).
	for (_, st) in project.structTypes 'eachStruct'
		if let innerResolved = try st.innerAliases.get(prefix) 'innerHit'
			let innerName = innerResolved.nameOrEmpty(project)
			if innerName.startsWith("__") 'innerIsBuiltin'
				return
			end 'innerIsBuiltin'
		end 'innerHit'
	end 'eachStruct'
	for i in 1 upto args.count() 'each'
		let label = try argLabels.get(i) otherwise ""
		if not label.isEmpty() 'hasLabel'
			continue
		end 'hasLabel'
		let range = try argRanges.get(i) otherwise SourceRange.none()
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: range.line, column: range.column, filePath: filePath)
		return
	end 'each'
end 'validateQualifiedCallArgLabels'

function validateMethodCallArgLabels(project Project, receiver ByteArray, args ByteArrayArray, argLabels StringArray, argRanges SourceRangeArray, producerTypes ProducerTypeMap, filePath FilePath)
	let receiverType = lookupProducerType(producerTypes, name: receiver)
	let structName = try maxonTypeStructName(project, t: receiverType) otherwise ""
	if structName.isEmpty() 'unresolvedReceiver'
		// Receiver type didn't resolve through buildProducerTypes — common
		// for selfFieldLoad sources (the producer-type map doesn't record
		// self-field load result types). Without a resolved receiver we
		// cannot distinguish builtin-method calls from user-method calls,
		// so skip the check rather than emit a false positive on stdlib
		// `__ManagedMemory.*` builtins. This mirrors `validateCallArities`'s
		// same-shape early-return on unresolved receivers.
		return
	end 'unresolvedReceiver'
	// Compiler builtins use the `__` prefix convention
	// (`__ManagedMemory`, `__ManagedList`, …); user-defined names cannot
	// start with `__` because the prefix is reserved.
	if structName.startsWith("__") 'isBuiltin'
		return
	end 'isBuiltin'
	for i in 1 upto args.count() 'each'
		let label = try argLabels.get(i) otherwise ""
		if not label.isEmpty() 'hasLabel'
			continue
		end 'hasLabel'
		let range = try argRanges.get(i) otherwise SourceRange.none()
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: range.line, column: range.column, filePath: filePath)
		return
	end 'each'
end 'validateMethodCallArgLabels'

// --- E3059: try/otherwise type-mismatch validation ---
//
// The parser allocates a slot named "__try_<label>_result" for every
// `try CALL otherwise FALLBACK` site, with two stores into it: one
// success-side (the call result) and one fallback-side (the otherwise
// expression). By TypeResolution time the producer-type map has
// resolved typealiased call results, so we can compare the two stores'
// cast categories and emit E3059 on a mismatch — catching the
// `mayFail() returns Integer otherwise 5.0` case the parser-side check
// must skip (typealiases panic in convertCastCategory pre-resolution).
//
// The check identifies the success-side store by matching its value
// name against a preceding tryCall op's result, so the diagnostic
// always says "expected = call type, got = fallback type" regardless
// of block-emission order.
typealias TrySlotSet = Set with VarSlot
typealias SlotCastCategoryMap = Map with (VarSlot, CastCategory)
typealias SlotSourceRangeMap = Map with (VarSlot, SourceRange)
typealias SlotMaxonTypeMap = Map with (VarSlot, MaxonType)
typealias TryCallResultSet = Set with ByteArray

// Track everything we need per try-result slot to validate the fallback
// store: which slots are try-result slots, the success-side category, and
// the success-side store range used for the diagnostic location. The
// `expectedType` map carries the success-side resolved MaxonType so the
// fallback-range check can identify ranged-typealias success types and
// compare the literal fallback against their bounds.
type TryResultIndex
	export var slots as TrySlotSet
	export var tryCallResults as TryCallResultSet
	export var expectedCat as SlotCastCategoryMap
	export var expectedRange as SlotSourceRangeMap
	export var expectedType as SlotMaxonTypeMap

	export static function create() returns TryResultIndex
		return Self{slots: TrySlotSet.create(), tryCallResults: TryCallResultSet.create(), expectedCat: SlotCastCategoryMap.create(), expectedRange: SlotSourceRangeMap.create(), expectedType: SlotMaxonTypeMap.create()}
	end 'create'
end 'TryResultIndex'

function validateTryOtherwiseTypes(project Project, module MaxonModule, producerTypesPerFunc ProducerTypeMapArray, filePath FilePath)
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		let func = try module.functions.get(funcIdx) otherwise panic("validateTryOtherwiseTypes: funcIdx < count but get failed")
		let producerTypes = try producerTypesPerFunc.get(funcIdx) otherwise panic("validateTryOtherwiseTypes: producerTypesPerFunc.get({funcIdx}) failed")

		var index = TryResultIndex.create()
		collectTryResultSlots(func.scope, slots: index.slots)
		if index.slots.count() == 0 'nothingToCheck'
			continue
		end 'nothingToCheck'

		// Pass 1: collect names produced by tryCall ops so we can later tell
		// success-side stores (value came from tryCall) apart from fallback-
		// side stores (any other producer).
		collectTryCallResults(module, func: func, results: index.tryCallResults)
		// Pass 2: walk varStores into try-result slots; for success-side stores
		// record the expected category. We need this before pass 3 because the
		// fallback store can appear in an earlier block than the success store.
		recordSuccessStoreCategories(project, module: module, func: func, producerTypes: producerTypes, index: index)
		// Pass 3: with the expected category for each slot known, compare each
		// fallback store against it and emit E3059 on mismatch.
		validateFallbackStoreCategories(project, module: module, func: func, producerTypes: producerTypes, index: index, filePath: filePath)
	end 'eachFunc'
end 'validateTryOtherwiseTypes'

// Mark every slot whose name matches the parser's `__try_<label>_result`
// pattern. Subsequent passes only inspect these slots.
function collectTryResultSlots(scope Scope, slots TrySlotSet)
	for (name, info) in scope.allVars() 'collect'
		if not name.startsWith("__try_") 'notTry'
			continue
		end 'notTry'
		if not name.endsWith("_result") 'notResult'
			continue
		end 'notResult'
		slots.insert(info.slot)
	end 'collect'
end 'collectTryResultSlots'

function collectTryCallResults(module MaxonModule, func IrFunction, results TryCallResultSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("collectTryCallResults: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("collectTryCallResults: opIdx OOB")
			if op.name != "tryCall" and op.name != "tryMethodCall" 'notTryCall'
				continue
			end 'notTryCall'
			match op 'extract'
				tryCall(result, _, _, _, _, _, _, _, _) then results.insert(result)
				tryMethodCall(result, _, _, _, _, _, _, _, _) then results.insert(result)
				default panic("unreachable: already checked name in [tryCall, tryMethodCall]")
			end 'extract'
		end 'eachOp'
	end 'eachBlock'
end 'collectTryCallResults'

function recordSuccessStoreCategories(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, index TryResultIndex)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("recordSuccessStoreCategories: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("recordSuccessStoreCategories: opIdx OOB")
			if op.name != "varStore" 'notStore'
				continue
			end 'notStore'
			match op 'extract'
				varStore(slotId, value, range) then recordExpectedTryCategory(project, slotId: slotId, value: value, range: range, producerTypes: producerTypes, index: index)
				default panic("unreachable: already checked name == varStore")
			end 'extract'
		end 'eachOp'
	end 'eachBlock'
end 'recordSuccessStoreCategories'

function validateFallbackStoreCategories(project Project, module MaxonModule, func IrFunction, producerTypes ProducerTypeMap, index TryResultIndex, filePath FilePath)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("validateFallbackStoreCategories: blockRef OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("validateFallbackStoreCategories: opIdx OOB")
			if op.name != "varStore" 'notStore'
				continue
			end 'notStore'
			match op 'extract'
				varStore(slotId, value, range) then validateFallbackCategory(project, module: module, func: func, slotId: slotId, value: value, range: range, producerTypes: producerTypes, index: index, filePath: filePath)
				default panic("unreachable: already checked name == varStore")
			end 'extract'
		end 'eachOp'
	end 'eachBlock'
end 'validateFallbackStoreCategories'

enum CategoryResolution implements Error
	unresolved
end 'CategoryResolution'

// Resolve a producer name to its CastCategory if the type is fully resolved
// and known to the project. Throws CategoryResolution.unresolved otherwise so
// callers can `try ... otherwise return` to skip the check.
function resolveCategoryForValue(project Project, producerTypes ProducerTypeMap, value ByteArray) returns CastCategory throws CategoryResolution
	let valType = lookupProducerType(producerTypes, name: value)
	if isUnresolvedType(valType) 'unresolved'
		throw CategoryResolution.unresolved
	end 'unresolved'
	if not maxonTypeIsKnown(project, t: valType) 'unknown'
		throw CategoryResolution.unresolved
	end 'unknown'
	return convertCastCategory(project, t: valType)
end 'resolveCategoryForValue'

function recordExpectedTryCategory(project Project, slotId VarSlot, value ByteArray, range SourceRange, producerTypes ProducerTypeMap, index TryResultIndex)
	if not index.slots.contains(slotId) 'notTrySlot'
		return
	end 'notTrySlot'
	if not index.tryCallResults.contains(value) 'notSuccessStore'
		return
	end 'notSuccessStore'
	let cat = try resolveCategoryForValue(project, producerTypes: producerTypes, value: value) otherwise return
	index.expectedCat.upsert(slotId, value: cat)
	index.expectedRange.upsert(slotId, value: range)
	// Record the resolved MaxonType so the fallback range-check can
	// identify a ranged-typealias success type — needed for the
	// `otherwise -1` ↔ `int(0 to 127)` diagnostic at fallback validation
	// time.
	index.expectedType.upsert(slotId, value: lookupProducerType(producerTypes, name: value))
end 'recordExpectedTryCategory'

function validateFallbackCategory(project Project, module MaxonModule, func IrFunction, slotId VarSlot, value ByteArray, range SourceRange, producerTypes ProducerTypeMap, index TryResultIndex, filePath FilePath)
	if not index.slots.contains(slotId) 'notTrySlot'
		return
	end 'notTrySlot'
	if index.tryCallResults.contains(value) 'isSuccessStore'
		return
	end 'isSuccessStore'
	if not index.expectedCat.contains(slotId) 'noExpected'
		return
	end 'noExpected'
	let actualCat = try resolveCategoryForValue(project, producerTypes: producerTypes, value: value) otherwise return
	let expectedCat = try index.expectedCat.get(slotId) otherwise panic("validateFallbackCategory: slot in expectedCat but get failed")
	let expectedRange = try index.expectedRange.get(slotId) otherwise range
	if expectedCat == actualCat 'sameCategory'
		checkFallbackLiteralRange(project, module: module, func: func, slotId: slotId, value: value, expectedRange: expectedRange, index: index, filePath: filePath)
		return
	end 'sameCategory'
	// Allow numeric coercions: int↔byte across the success/fallback edges.
	if castCategoryIsIntegerFamily(expectedCat) and castCategoryIsIntegerFamily(actualCat) 'bothIntegerFamily'
		checkFallbackLiteralRange(project, module: module, func: func, slotId: slotId, value: value, expectedRange: expectedRange, index: index, filePath: filePath)
		return
	end 'bothIntegerFamily'
	let expectedName = castCategoryName(expectedCat)
	let actualName = castCategoryName(actualCat)
	reportCompileError(project, code: ErrorCode.semanticOtherwiseTypeMismatch, message: "type mismatch: 'otherwise type '{actualName}' does not match expected type '{expectedName}''", line: expectedRange.line, column: expectedRange.column, filePath: filePath)
end 'validateFallbackCategory'

// Compile-time range check on the fallback expression of `try X otherwise V`
// when the success-side type is a ranged typealias. Mirrors
// `checkConvertLiteralRange` for `LITERAL as RangedAlias`: walks the producer
// chain for the fallback value, decodes the literal (including a leading
// `-`), and emits E3005 when it falls outside the registered range. Float
// aliases are handled the same way the convert path handles them.
function checkFallbackLiteralRange(project Project, module MaxonModule, func IrFunction, slotId VarSlot, value ByteArray, expectedRange SourceRange, index TryResultIndex, filePath FilePath)
	if not index.expectedType.contains(slotId) 'noType'
		return
	end 'noType'
	let expectedType = try index.expectedType.get(slotId) otherwise return
	let aliasName = expectedType.namedAliasNameOrEmpty(project)
	if aliasName.isEmpty() 'notNamed'
		return
	end 'notNamed'
	let typealiasRange = try project.typealiasRanges.get(aliasName) otherwise return
	if isAliasFullRange(project, aliasName: aliasName, range: typealiasRange) 'fullRange'
		return
	end 'fullRange'
	let lit = findLiteralProducerInFunc(project, module: module, func: func, operandName: value)
	if not lit.found 'noLit'
		return
	end 'noLit'
	let isFloat = aliasIsFloat(project, name: aliasName)
	let outOfRange = literalOutOfRangeFloat(lit.value, range: typealiasRange) if isFloat else literalOutOfRangeInt(lit.value, range: typealiasRange)
	if not outOfRange 'inRange'
		return
	end 'inRange'
	let displayValue = formatLiteralValue(lit.value, isFloat: isFloat)
	let displayRange = formatTypealiasRange(project, aliasName: aliasName, range: typealiasRange)
	reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "otherwise value {displayValue} is outside the range of '{aliasName}' ({displayRange})", line: expectedRange.line, column: expectedRange.column, filePath: filePath)
end 'checkFallbackLiteralRange'

function validateCallArityOp(project Project, op MaxonOp, producerTypes ProducerTypeMap, currentNamespace String, readerFilePath FilePath, filePath FilePath)
	if op.name == "call" 'isCall'
		match op 'extractCall'
			call(_, callee, callContext, args, argLabels, _, _, range) then checkFreeCallArity(project, qualifiedCallee: qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath), args: args, argLabels: argLabels, range: range, filePath: filePath)
			default panic("unreachable: already checked name == call")
		end 'extractCall'
	end 'isCall'
	if op.name == "methodCall" 'isMethodCall'
		match op 'extractMethod'
			methodCall(_, receiver, methodName, args, argLabels, _, _, range) then checkMethodCallArity(project, receiverType: lookupProducerType(producerTypes, name: receiver), methodName: methodName, args: args, argLabels: argLabels, range: range, filePath: filePath)
			default panic("unreachable: already checked name == methodCall")
		end 'extractMethod'
	end 'isMethodCall'
	if op.name == "tryMethodCall" 'isTryMethodCall'
		match op 'extractTryMethod'
			tryMethodCall(_, receiver, methodName, args, argLabels, _, _, _, range) then checkMethodCallArity(project, receiverType: lookupProducerType(producerTypes, name: receiver), methodName: methodName, args: args, argLabels: argLabels, range: range, filePath: filePath)
			default panic("unreachable: already checked name == tryMethodCall")
		end 'extractTryMethod'
	end 'isTryMethodCall'
end 'validateCallArityOp'

function checkMethodCallArity(project Project, receiverType MaxonType, methodName ByteArray, args ByteArrayArray, argLabels StringArray, range SourceRange, filePath FilePath)
	let structName = try maxonTypeStructName(project, t: receiverType) otherwise return
	let qualifiedCallee = "{structName}.{String.from(methodName)}"
	checkCallArity(project, qualifiedCallee: qualifiedCallee, args: args, argLabels: argLabels, paramStartIndex: 1, range: range, filePath: filePath)
end 'checkMethodCallArity'

// Free / sibling-instance call entry — looks at the resolved signature's
// first param to decide whether to skip the implicit `__self` slot, mirroring
// LowerMaxonToStd.lowerCall. Without this, sibling calls like `double()`
// inside a method body trip the new "missing argument for parameter
// '__self'" check.
function checkFreeCallArity(project Project, qualifiedCallee String, args ByteArrayArray, argLabels StringArray, range SourceRange, filePath FilePath)
	let signature = try project.funcSignatures.get(qualifiedCallee) otherwise return
	var paramStart = 0
	if signatureFirstParamIsSelf(signature) 'siblingInstance'
		paramStart = 1
	end 'siblingInstance'
	checkCallArity(project, qualifiedCallee: qualifiedCallee, args: args, argLabels: argLabels, paramStartIndex: paramStart, range: range, filePath: filePath)
end 'checkFreeCallArity'

// Walks the signature and reports E3036 for either too-many or missing-required
// arg-count problems, plus E3003 when a named-arg label doesn't map to a
// parameter. Mirrors the slotArgsForCall fold so the diagnostic agrees with
// what lowering will actually do.
function checkCallArity(project Project, qualifiedCallee String, args ByteArrayArray, argLabels StringArray, paramStartIndex ParsedInt, range SourceRange, filePath FilePath)
	let signature = try project.funcSignatures.get(qualifiedCallee) otherwise return
	let userParamCount = signature.paramNames.count() - paramStartIndex
	if userParamCount < 0 'badSig'
		return
	end 'badSig'
	let userArgCount = args.count()
	if userArgCount > userParamCount 'tooMany'
		reportCompileError(project, code: ErrorCode.semanticWrongArgCount, message: "too many arguments to '{qualifiedCallee}': expected {userParamCount}, got at least {userArgCount}", line: range.line, column: range.column, filePath: filePath)
		return
	end 'tooMany'

	// Mark each user-facing slot filled by either a positional arg (slot == i)
	// or a named arg whose label resolves through the signature's nameToIndex.
	// Unknown labels surface as E3003 here so the lowering pass doesn't have
	// to repeat the diagnostic — and so the missing-arg loop below doesn't
	// fire on a slot that the user thought they had filled by name.
	var slotFilled = BoolArray.create()
	for _ in 0 upto userParamCount 'initFilled'
		slotFilled.push(false)
	end 'initFilled'
	var sawUnknownLabel = false
	for i in 0 upto userArgCount 'placeArgs'
		let label = try argLabels.get(i) otherwise ""
		var slot = i
		if not label.isEmpty() 'hasLabel'
			let resolved = try signature.nameToIndex.get(label) otherwise -1
			if resolved < 0 'unknown'
				reportCompileError(project, code: ErrorCode.semanticUndefinedVariable, message: "unknown parameter name: '{label}'", line: range.line, column: range.column, filePath: filePath)
				sawUnknownLabel = true
				continue
			end 'unknown'
			slot = resolved - paramStartIndex
		end 'hasLabel'
		if slot < 0 or slot >= userParamCount 'outOfRange'
			continue
		end 'outOfRange'
		try slotFilled.set(slot, value: true) otherwise panic("invariant: slotFilled.set OOB")
	end 'placeArgs'

	// Unknown-label E3003 is the primary diagnostic — suppress the
	// missing-arg follow-up since it's almost always a downstream artifact
	// of the typo and would just repeat noise.
	if sawUnknownLabel 'hadUnknown'
		return
	end 'hadUnknown'

	for slot in 0 upto userParamCount 'eachSlot'
		let filled = try slotFilled.get(slot) otherwise panic("invariant: slotFilled sized to userParamCount")
		if filled 'ok'
			continue
		end 'ok'
		let paramIdx = slot + paramStartIndex
		let pd = try signature.paramDefaults.get(paramIdx) otherwise ParamDefault.none
		if paramDefaultHasValue(pd) 'hasDefault'
			continue
		end 'hasDefault'
		let paramName = try signature.paramNames.get(paramIdx) otherwise ""
		reportCompileError(project, code: ErrorCode.semanticWrongArgCount, message: "missing argument for parameter '{paramName}'", line: range.line, column: range.column, filePath: filePath)
		return
	end 'eachSlot'
end 'checkCallArity'

// Phase 11.1 (step 5): conformance lookup and where-clause checking.
//
// `Constraints.maxon` answers two questions on top of the substitution
// primitive in `Substitution.maxon`:
//
//   1. "Does this concrete type conform to this interface?" â€” the
//      `typeConformsTo` family. Built-in primitives (Int, Bool, Float, String)
//      hard-conform to the universal traits (Equatable, Hashable, Comparable,
//      Cloneable). Named types defer to `project.conformances` (populated by
//      the validateConformances + processExtensions passes during
//      TypeResolution). `genericInstance` types defer to their base â€” this is
//      a structural lookup; conditional conformances are enforced at the call
//      site by `whereClauseSatisfied`. Type-parameter types defer to the
//      param's declared constraints in `project.typeParameters`.
//
//   2. "Are every where-clause's required traits satisfied for this
//      substitution?" â€” `whereClauseSatisfied`. Walks the constraint set,
//      pulls each clause's `(declaringTypeName, paramName)` to recover the
//      type-param id, looks up the bound concrete in `subst`, and asks
//      `typeConformsTo`. Used by Step 6/7 when emitting conditional
//      conformance witness tables and by Step 4's resolution pass when a
//      generic call site needs to verify the call's type-args satisfy the
//      callee's constraints.
//
// This file performs no IR mutation, no diagnostic emission, and no caching:
// it answers questions about already-recorded metadata. Diagnostic-friendly
// wrappers (the ones that emit E3015 / E3016 / etc) live in TypeResolution
// and call into this file.

// Built-in primitive types automatically conform to a small core of
// universal traits. Hard-coded for now â€” the trait surface is small enough
// that a name switch is clearer than a registration table. Step 7+ may grow
// this when it surfaces additional builtin conformances (e.g. tuple types
// adopting Hashable when their fields are Hashable).
//
// All numeric/boolean primitives (bool, int, float, byte) implement
// Equatable, Hashable, Comparable, Cloneable. String is the exception:
// it implements Equatable, Hashable, Cloneable (declared in
// `stdlib/String.maxon`) but NOT Comparable â€” there's no `String.compare`
// method, and unicode ordering isn't a single well-defined operation.
// `stringConformsTo` overrides the universal builtin set to reflect this.
function builtinConformsTo(interfaceName String) returns bool
	if interfaceName == "Equatable" 'eq'
		return true
	end 'eq'
	if interfaceName == "Hashable" 'hashable'
		return true
	end 'hashable'
	if interfaceName == "Comparable" 'comparable'
		return true
	end 'comparable'
	if interfaceName == "Cloneable" 'cloneable'
		return true
	end 'cloneable'
	return false
end 'builtinConformsTo'

// String-specific conformance set. String is Equatable/Hashable/Cloneable
// but NOT Comparable â€” see `builtinConformsTo` comment. Without splitting
// this out, generic helpers constrained by `where T is Comparable` would
// silently accept String and then trip "no witness table for (String,
// Comparable)" at lowering time.
function stringConformsTo(interfaceName String) returns bool
	if interfaceName == "Comparable" 'noCompare'
		return false
	end 'noCompare'
	return builtinConformsTo(interfaceName)
end 'stringConformsTo'

// Top-level dispatcher. Every consumer that asks "does this type satisfy
// this interface" calls through here; the per-arm helpers below specialize
// to the kind of `MaxonType` involved.
//
// For the `function` arm we always return false: function types don't
// conform to anything in Phase 11.1's surface. Step 7's interface-typed
// values may grow this when first-class function-typed conformances are
// needed, but no stdlib code requires it today.
//
// For `unresolved` we return false rather than panicking: the caller
// (typically a downstream constraint-validation walk) wants the
// "does not conform" verdict to flow through to its own diagnostic.
export function typeConformsTo(project Project, t MaxonType, interfaceName String) returns bool
	return match t 'check'
		boolean gives builtinConformsTo(interfaceName)
		integer gives builtinConformsTo(interfaceName)
		float gives builtinConformsTo(interfaceName)
		string gives stringConformsTo(interfaceName)
		named(id) gives namedConformsTo(project, id: id, interfaceName: interfaceName)
		genericInstance(gid) gives genericInstanceConformsTo(project, gid: gid, interfaceName: interfaceName)
		typeParameter(id) gives typeParamConformsTo(project, id: id, interfaceName: interfaceName)
		interface(id) gives interfaceConformsTo(project, id: id, interfaceName: interfaceName)
		function gives false
		unresolved gives false
		// `constInt` is a compile-time integer carried in genericInstance
		// args (sized typealiases); it never participates in conformance.
		constInt gives false
		// `opaquePointer` is an ABI-bookkeeping slot, never user-visible;
		// it doesn't participate in conformance.
		opaquePointer gives false
	end 'check'
end 'typeConformsTo'

// Named type: a struct, enum, or typealias. Conformance lives in
// `project.conformances`, populated by TypeResolution's
// `validateConformances` pass when the type declared `implements I` and by
// `processExtensions` for added conformances.
//
// A bare `named(id)` may also be a generic typealias (e.g.
// `typealias ByteArray = Array with Byte`); the alias itself has no
// recorded conformance â€” the underlying generic instance does, gated by
// any conditional `where`-clause on the conformer's extension. Chase
// `genericTypealiases` one level and recurse so the lookup hits the
// generic-instance arm with the substitution intact.
function namedConformsTo(project Project, id TypeNameId, interfaceName String) returns bool
	let typeName = project.typeNames.get(id)
	if let aliasTarget = try project.genericTypealiases.get(typeName) 'isGenericAlias'
		return typeConformsTo(project, t: aliasTarget, interfaceName: interfaceName)
	end 'isGenericAlias'
	// Ranged-primitive typealiases (`typealias Integer = int(...)`) resolve
	// to a StdType primitive; chase through the typealias registry so the
	// builtin-conformance check at the primitive arm fires. Without this,
	// `Integer` would never satisfy `Equatable` even though `int` does.
	if let aliasStdType = try project.typealiases.get(typeName) 'isPrimAlias'
		let primitive = stdTypeToMaxonPrimitive(aliasStdType)
		return typeConformsTo(project, t: primitive, interfaceName: interfaceName)
	end 'isPrimAlias'
	return project.conformances.contains(typeName, interfaceName: interfaceName)
end 'namedConformsTo'

// Map a StdType primitive back to its corresponding MaxonType arm so the
// recursion in `namedConformsTo` can hit the primitive auto-conformance
// branch. The mapping mirrors the StdType enum order in
// `IR/Std/StdDialect.maxon`: `i1` â†’ boolean, `i8..u64` â†’ integer,
// `f32`/`f64` â†’ float.
function stdTypeToMaxonPrimitive(t StdType) returns MaxonType
	return match t 'pick'
		i1 gives MaxonType.boolean
		i8 to u64 gives MaxonType.integer
		f32 gives MaxonType.float
		f64 gives MaxonType.float
	end 'pick'
end 'stdTypeToMaxonPrimitive'

// Generic instance: structural conformance lookup against the base type
// gated by any conditional where-clause on the matching extension.
// `Array with Int` conforms to `Iterable` iff `Array` itself conforms.
// `Array with Int` conforms to `Hashable` iff (1) `Array` itself records
// the `Hashable` conformance AND (2) every where-clause from the
// extension that introduced the conformance is satisfied by the gid's
// type-args.
function genericInstanceConformsTo(project Project, gid GenericInstanceId, interfaceName String) returns bool
	let (baseId, gidArgs) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	if not project.conformances.contains(baseName, interfaceName: interfaceName) 'noBase'
		return false
	end 'noBase'
	return conditionalConformanceWhereClauseSatisfied(project, baseName: baseName, interfaceName: interfaceName, gidArgs: gidArgs)
end 'genericInstanceConformsTo'

// Walk the parser-recorded extensions, find the one that introduced
// `(baseName, interfaceName)`, and check every where-clause against the
// gid's concrete args. An unconditional conformance (no matching
// extension found, or extension with no where-clauses) passes trivially.
//
// The extension's parameter names live in `targetTypeParams` (or
// `getParamNames(baseName)` when the extension inherits the target's
// parameter names verbatim, which is the common case). The gid's args
// are positional in `getParamNames(baseName)` order.
function conditionalConformanceWhereClauseSatisfied(project Project, baseName String, interfaceName String, gidArgs MaxonTypeArray) returns bool
	let extensions = project.unresolvedExtensions
	for ei in 0 upto extensions.count() 'eachExt'
		let ext = try extensions.get(ei) otherwise panic("conditionalConformanceWhereClauseSatisfied: extensions.get OOB at {ei}")
		if ext.targetTypeName != baseName 'notTarget'
			continue
		end 'notTarget'
		var matches = false
		for ci in 0 upto ext.addedConformances.count() 'eachConf'
			let conf = try ext.addedConformances.get(ci) otherwise panic("conditionalConformanceWhereClauseSatisfied: addedConformances.get OOB at {ci}")
			if conf.interfaceName == interfaceName 'hit'
				matches = true
				break
			end 'hit'
		end 'eachConf'

		if not matches 'noMatch'
			continue
		end 'noMatch'
		if ext.whereClauses.count() == 0 'unconditional'
			return true
		end 'unconditional'
		if extensionWhereClausesSatisfied(project, ext: ext, baseName: baseName, gidArgs: gidArgs) 'pass'
			return true
		end 'pass'
	end 'eachExt'

	// No matching extension found â€” the conformance was declared directly
	// on the type with no `where`-clause gating, so the structural lookup
	// already succeeded above. Treat as unconditionally satisfied.
	return true
end 'conditionalConformanceWhereClauseSatisfied'

// Resolve each `WhereClause` against the gid's positional args by pairing
// the conformer's declared `usesParams` (e.g. `Element` for `Array`) with
// `gidArgs`. Bare paramName matched against the clause's `paramName`.
function extensionWhereClausesSatisfied(project Project, ext UnresolvedExtension, baseName String, gidArgs MaxonTypeArray) returns bool
	var paramNames = ext.targetTypeParams
	if paramNames.count() == 0 'inheritFromTarget'
		paramNames = project.typeParameters.getParamNames(baseName)
	end 'inheritFromTarget'
	if paramNames.count() != gidArgs.count() 'arityMismatch'
		// Phase-ordering bug â€” the gid's arity must match the conformer's
		// declared param count. Falling through with `false` keeps the
		// caller's diagnostic flow intact rather than crashing the resolver.
		return false
	end 'arityMismatch'
	for ci in 0 upto ext.whereClauses.count() 'eachClause'
		let clause = try ext.whereClauses.get(ci) otherwise panic("extensionWhereClausesSatisfied: whereClauses.get OOB at {ci}")
		var bound = MaxonType.unresolved
		var bindingFound = false
		for pi in 0 upto paramNames.count() 'pair'
			let pn = try paramNames.get(pi) otherwise panic("extensionWhereClausesSatisfied: paramNames.get OOB at {pi}")
			if pn == clause.paramName 'hit'
				bound = try gidArgs.get(pi) otherwise panic("extensionWhereClausesSatisfied: gidArgs.get OOB at {pi}")
				bindingFound = true
				break
			end 'hit'
		end 'pair'

		if not bindingFound 'unbound'
			// The where-clause names a param that isn't on the conforming
			// type â€” likely a parser/resolver inconsistency. Conservatively
			// fail the conformance so the caller surfaces a diagnostic.
			return false
		end 'unbound'
		if not typeConformsTo(project, t: bound, interfaceName: clause.requiredTraitName) 'fail'
			return false
		end 'fail'
	end 'eachClause'

	return true
end 'extensionWhereClausesSatisfied'

// Type parameter: its constraints live as a String list on the
// type-parameter registry, populated by the parser when a `where T is Trait`
// clause was seen. A type-parameter conforms to `interfaceName` exactly
// when the trait appears in its declared constraint set â€” the parser
// already deduped constraint names, so this is a single linear scan.
function typeParamConformsTo(project Project, id TypeParamId, interfaceName String) returns bool
	let constraints = project.typeParameters.getConstraints(id)
	for i in 0 upto constraints.count() 'scan'
		let c = try constraints.get(i) otherwise panic("typeParamConformsTo: constraints.get OOB at {i}")
		if c == interfaceName 'hit'
			return true
		end 'hit'
	end 'scan'
	return false
end 'typeParamConformsTo'

// Interface-typed existential value (`var x Iterable with Int`): the value
// itself carries an interface name. By definition the value conforms to
// its own interface. For the inheritance walk (`BidirectionalIterator`
// extends `Iterator`, so a `BidirectionalIterator` value also conforms to
// `Iterator`) we walk `extendsNames` transitively. Step 7 needs this when
// it emits witness tables for the parent interface alongside the child's.
function interfaceConformsTo(project Project, id InterfaceTypeId, interfaceName String) returns bool
	let valueIfaceName = project.interfaceRegistry.getName(id)
	if valueIfaceName == interfaceName 'self'
		return true
	end 'self'
	return interfaceExtendsTransitive(project, ifaceName: valueIfaceName, target: interfaceName)
end 'interfaceConformsTo'

// Walk `ifaceName`'s `extends` chain looking for `target`. The interface
// registry is populated by TypeResolution's `resolveAllInterfaces` drain,
// so by the time a constraint check runs every interface is reachable.
// Linear walk is fine â€” interface inheritance is shallow in practice
// (Iterator -> BidirectionalIterator is the deepest path in stdlib).
function interfaceExtendsTransitive(project Project, ifaceName String, target String) returns bool
	let iface = try project.interfaces.get(ifaceName) otherwise return false
	for i in 0 upto iface.extendsNames.count() 'scan'
		let parent = try iface.extendsNames.get(i) otherwise panic("interfaceExtendsTransitive: extendsNames.get OOB at {i}")
		if parent == target 'directHit'
			return true
		end 'directHit'
		if interfaceExtendsTransitive(project, ifaceName: parent, target: target) 'transHit'
			return true
		end 'transHit'
	end 'scan'
	return false
end 'interfaceExtendsTransitive'

// Verify every where-clause is satisfied under a substitution. Each clause
// names the type-param scope it belongs to (Phase 11.1's WhereClause carries
// `declaringTypeName`); the (declaringTypeName, paramName) tuple is the
// type-param id key, so we re-intern through that to recover the id, look
// up the substitution's binding, and ask `typeConformsTo`.
//
// A clause whose `declaringTypeName` is empty is a legacy parser entry from
// before step 5 â€” we treat it as a satisfied no-op rather than panicking
// so old callers continue to work; the parser change to set the
// declaringTypeName on every emitted WhereClause is in the same step.
//
// A clause whose param resolves to `unresolved` (no binding in the
// substitution) is treated as unsatisfied â€” the caller is expected to
// supply a complete substitution before asking; an incomplete
// substitution in this slot is a programming error one tier up, not a
// silent pass.
export function whereClauseSatisfied(project Project, constraints WhereClauseArray, subst TypeSubstitution) returns bool
	for i in 0 upto constraints.count() 'scan'
		let c = try constraints.get(i) otherwise panic("whereClauseSatisfied: constraints.get OOB at {i}")
		if c.declaringTypeName.isEmpty() 'noScope'
			continue
		end 'noScope'
		let paramId = project.typeParameters.intern(c.declaringTypeName, paramName: c.paramName)
		let concrete = subst.lookup(paramId)
		if not typeConformsTo(project, t: concrete, interfaceName: c.requiredTraitName) 'fail'
			return false
		end 'fail'
	end 'scan'
	return true
end 'whereClauseSatisfied'

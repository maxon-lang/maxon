// Semantic validation pass over the MlirModule.
// Checks program structure requirements before lowering.

// Sentinel returned by findMainReturnType when main exists but has no return type.
function noReturnTypeSentinel() returns ByteArray
    var s = ByteArray{}
    // "__none__"
    s.push(95)
    s.push(95)
    s.push(110)
    s.push(111)
    s.push(110)
    s.push(101)
    s.push(95)
    s.push(95)
    return s
end 'noReturnTypeSentinel'

function exitCodeBytes() returns ByteArray
    var s = ByteArray{}
    // "ExitCode"
    s.push(69)
    s.push(120)
    s.push(105)
    s.push(116)
    s.push(67)
    s.push(111)
    s.push(100)
    s.push(101)
    return s
end 'exitCodeBytes'

function mainBytes() returns ByteArray
    var s = ByteArray{}
    // "main"
    s.push(109)
    s.push(97)
    s.push(105)
    s.push(110)
    return s
end 'mainBytes'

function dotMainBytes() returns ByteArray
    var s = ByteArray{}
    // ".main"
    s.push(46)
    s.push(109)
    s.push(97)
    s.push(105)
    s.push(110)
    return s
end 'dotMainBytes'

export function runSemanticChecks(module MlirModule) throws CompileError
    // Walk module.functions looking for one named "main" or ending with ".main"
    let mainReturnType = findMainReturnType(module)
    if mainReturnType.count() == 0 'noMain'
        try raiseSemanticError(ErrorCode.semanticNoMain, message: "No 'main' function found")
    end 'noMain' else 'hasMain'
        let expected = exitCodeBytes()
        if not bytesEqual(mainReturnType, b: expected) 'wrongType'
            try raiseSemanticError(ErrorCode.semanticMainWrongReturnType, message: "Function 'main' must return ExitCode")
        end 'wrongType'
    end 'hasMain'
end 'runSemanticChecks'

function findMainReturnType(module MlirModule) returns ByteArray
    var i = 0
    let mn = mainBytes()
    let dm = dotMainBytes()
    while i < module.functions.count() 'scan'
        let func = try module.functions.get(i) otherwise 'skip'
            i = i + 1
            continue
        end 'skip'
        if bytesEqual(func.name, b: mn) or endsWithBytes(func.name, suffix: dm) 'isMain'
            if func.returnType.count() == 0 'noReturn'
                return noReturnTypeSentinel()
            end 'noReturn'
            return func.returnType
        end 'isMain'
        i = i + 1
    end 'scan'
    var empty = ByteArray{}
    return empty
end 'findMainReturnType'

function endsWithBytes(haystack ByteArray, suffix ByteArray) returns bool
    let hLen = haystack.count()
    let sLen = suffix.count()
    if sLen > hLen 'tooShort'
        return false
    end 'tooShort'
    var i = 0
    while i < sLen 'cmp'
        let hByte = try haystack.get(hLen - sLen + i) otherwise 0
        let sByte = try suffix.get(i) otherwise 1
        if hByte != sByte 'mismatch'
            return false
        end 'mismatch'
        i = i + 1
    end 'cmp'
    return true
end 'endsWithBytes'

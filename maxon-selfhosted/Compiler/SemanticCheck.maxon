// Semantic validation pass over Maxon dialect ops.
// Checks program structure requirements before lowering.

// Sentinel returned by findMainReturnType when main exists but has no return type.
function noReturnTypeSentinel() returns ByteArray
    var s = ByteArray{}
    // "__none__"
    s.push(95)
    s.push(95)
    s.push(110)
    s.push(111)
    s.push(110)
    s.push(101)
    s.push(95)
    s.push(95)
    return s
end 'noReturnTypeSentinel'

function exitCodeBytes() returns ByteArray
    var s = ByteArray{}
    // "ExitCode"
    s.push(69)
    s.push(120)
    s.push(105)
    s.push(116)
    s.push(67)
    s.push(111)
    s.push(100)
    s.push(101)
    return s
end 'exitCodeBytes'

function mainBytes() returns ByteArray
    var s = ByteArray{}
    // "main"
    s.push(109)
    s.push(97)
    s.push(105)
    s.push(110)
    return s
end 'mainBytes'

function dotMainBytes() returns ByteArray
    var s = ByteArray{}
    // ".main"
    s.push(46)
    s.push(109)
    s.push(97)
    s.push(105)
    s.push(110)
    return s
end 'dotMainBytes'

export function runSemanticChecks(ops MaxonOpArray) throws CompileError
    let mainReturnType = findMainReturnType(ops)

    if mainReturnType.count() == 0 'noMain'
        try raiseSemanticError(ErrorCode.semanticNoMain, message: "No 'main' function found")
    end 'noMain' else 'hasMain'
        let expected = exitCodeBytes()
        if not bytesEqual(mainReturnType, b: expected) 'wrongType'
            try raiseSemanticError(ErrorCode.semanticMainWrongReturnType, message: "Function 'main' must return ExitCode")
        end 'wrongType'
    end 'hasMain'
end 'runSemanticChecks'

// Scans ops for a funcBegin named "main" and returns its return type.
// Returns empty ByteArray if no main function found.
function findMainReturnType(ops MaxonOpArray) returns ByteArray
    var i = 0
    while i < ops.count() 'scan'
        let op = try ops.get(i) otherwise 'skip'
            i = i + 1
            continue
        end 'skip'
        let result = getMainReturnType(op)
        if result.count() > 0 'found'
            return result
        end 'found'
        i = i + 1
    end 'scan'
    var empty = ByteArray{}
    return empty
end 'findMainReturnType'

// If op is a funcBegin for "main", returns its return type (or sentinel if none).
// Returns empty ByteArray for non-main or non-funcBegin ops.
function getMainReturnType(op MaxonOp) returns ByteArray
    var result = ByteArray{}
    match op 'check'
        funcBegin(name, returnType) then result = matchMainFunc(name, returnType: returnType)
        literal(resultId, value) then break 'check'
        floatLiteral(resultId, rawBits) then break 'check'
        returnOp(retValId) then break 'check'
        varDecl(slotId, valueId) then break 'check'
        varLoad(resultId, slotId) then break 'check'
        add(resultId, leftId, rightId) then break 'check'
        sub(resultId, leftId, rightId) then break 'check'
        mul(resultId, leftId, rightId) then break 'check'
        cmpEq(resultId, leftId, rightId) then break 'check'
        cmpNe(resultId, leftId, rightId) then break 'check'
        cmpLt(resultId, leftId, rightId) then break 'check'
        cmpLe(resultId, leftId, rightId) then break 'check'
        cmpGt(resultId, leftId, rightId) then break 'check'
        cmpGe(resultId, leftId, rightId) then break 'check'
        floatCmpEq(resultId, leftId, rightId) then break 'check'
        condBr(condId, thenLabel, elseLabel) then break 'check'
        br(targetLabel) then break 'check'
        label(name) then break 'check'
        printLiteral(data) then break 'check'
        printInt(valueId) then break 'check'
        funcEnd then break 'check'
        call(resultId, callee) then break 'check'
    end 'check'
    return result
end 'getMainReturnType'

function matchMainFunc(name ByteArray, returnType ByteArray) returns ByteArray
    let mn = mainBytes()
    let dm = dotMainBytes()
    if bytesEqual(name, b: mn) or endsWithBytes(name, suffix: dm) 'isMain'
        if returnType.count() == 0 'noReturn'
            return noReturnTypeSentinel()
        end 'noReturn'
        return returnType
    end 'isMain'
    var empty = ByteArray{}
    return empty
end 'matchMainFunc'

function endsWithBytes(haystack ByteArray, suffix ByteArray) returns bool
    let hLen = haystack.count()
    let sLen = suffix.count()
    if sLen > hLen 'tooShort'
        return false
    end 'tooShort'
    var i = 0
    while i < sLen 'cmp'
        let hByte = try haystack.get(hLen - sLen + i) otherwise 0
        let sByte = try suffix.get(i) otherwise 1
        if hByte != sByte 'mismatch'
            return false
        end 'mismatch'
        i = i + 1
    end 'cmp'
    return true
end 'endsWithBytes'

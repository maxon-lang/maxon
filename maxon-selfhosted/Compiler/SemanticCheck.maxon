// Semantic validation pass over the MaxonModule.
// Checks program structure requirements before lowering.

// Per-pass alias for guard-name sets used by E3087's contains/get
// redundancy lint. File-private to mirror DeadFunctionElimination's
// own `StringSet` typealias — re-exporting generic typealiases across
// files isn't supported yet.
typealias StringSet = Set with String

// Op-index domain widened with a "no producer found" sentinel of -1. A
// single 64-bit type cannot represent both -1 and u64.max, so we widen the
// upper bound to i64.max — matches the SchedInt / DefMapIndex workaround
// in InstructionScheduler and CommuteForCoalescing.
typealias OpIndexOrMissing = int(i64.min to i64.max)

// Argument / parameter position index for the E3005 arg-type check.
typealias ArgIndex = int(0 to u64.max)

export function runSemanticChecks(project Project, module MaxonModule, isStdlib bool = false)
	logDebug(LogCategory.semantic, message: function() gives "semcheck: functions={module.functions.count()}")

	// Phase 3b: enforce E3016 — every type with a non-empty
	// `expectedMethods` (computed by Phase 3a from its `implements` clause)
	// must declare a method matching each expected entry by name. Signature
	// matching is deferred to a follow-up; missing-name detection is enough
	// to surface the "Partial interface implementation" diagnostic.
	checkInterfaceConformance(project)

	// E4014: reject recursive type-reference cycles. Maxon's refcount ownership
	// model needs acyclic type graphs for deterministic destruction, so a type
	// may not transitively contain itself through struct fields, union
	// associated values, or container element types. User types only (stdlib
	// types are acyclic by construction and re-checking them would break
	// cache-parity).
	//
	// Placement differs deliberately from the C# bootstrap's `TypeCycleCheckPass`,
	// which runs as an MLIR pass AFTER monomorphization and reads container edges
	// off each monomorphized `Array<E>` struct's TypeParams. The self-hosted
	// check runs here, in semantic-check (pre-monomorphization), and reconstructs
	// container edges by resolving a field's alias to its generic instance and
	// reading the element args (`containerElementUserTypes`). This keeps the
	// check independent of the monomorphizer having run; `structTypes` /
	// `enumTypes` / `genericInstances` are already fully populated by the
	// preceding `resolveTypes` pass.
	if not isStdlib 'cycleCheckUserOnly'
		checkTypeReferenceCycles(project)
	end 'cycleCheckUserOnly'

	// Phase 4e error-handling rules: E3054 (main cannot throw),
	// E3055 (try on non-throwing function), E3057 (missing try on throwing call).
	checkErrorHandlingRules(project, module: module)

	// Tier 4: E3073 — every `async f()` must target a function that can yield
	// (contains an await / I/O yield point, transitively). Mirrors the C#
	// bootstrap's CheckAsyncYielding.
	checkAsyncYielding(project, module: module)

	// E3087: lint `if x.contains(k) ... try x.get(k) otherwise ...` patterns.
	// Mirrors the C# bootstrap's CheckRedundantContainsGet — see the
	// per-function helper below for the full algorithm.
	checkRedundantContainsGet(project, module: module)

	// Phase 15a: compute per-function purity, then walk every call/tryCall op
	// tagged by the parser (via `project.discardedBareCallResults` /
	// `discardedLetCallResults`) and emit E3064 (pure result must be used) or
	// E3065 (impure result needs `_=`). Purity is required by the check, so
	// it runs first.
	//
	// Skip both passes for stdlib modules: the spec applies to user code only
	// (stdlib internals reuse `_ =` patterns that the cache-off path would
	// otherwise re-tag, breaking cache-parity). User code's check still sees
	// stdlib callees via `project.funcReturnTypes` so E3065/E3064 still fire
	// correctly when a user discards a stdlib call result.
	if not isStdlib 'userOnly'
		// E3005 (argument type mismatch) ran at the tail of the resolveTypes
		// pass (see `runResolveTypesAndStamp`), before the E3012 unused-var
		// drain, so a bad-argument call bound to an unused `let` surfaces the
		// type error rather than "unused variable". That pass also populated
		// `project.callsWithArgErrors`, which the discard lint below reads to
		// suppress E3064/E3065 on calls already flagged with a type error.
		// Purity is required by the discard check, so it runs first.
		computePurity(project, module: module)
		checkDiscardedResults(project, module: module)
	end 'userOnly'

	for func in module.functions 'scan'
		if func.name == "main" 'isMain'
			logTrace(LogCategory.semantic, message: function() gives "semcheck: main returnType={maxonReturnTypeToString(project, ref: func.maxonReturnType)}")
			if maxonReturnTypeToString(project, ref: func.maxonReturnType) != "ExitCode" 'wrongType'
				reportSemanticError(project, code: ErrorCode.semanticMainWrongReturnType, message: "Function 'main' must return ExitCode")
			end 'wrongType'
			return
		end 'isMain'
	end 'scan'

	reportSemanticError(project, code: ErrorCode.semanticNoMain, message: "No 'main' function found")
end 'runSemanticChecks'

// Phase 3b conformance check: walk every struct and enum, and for any with
// expected method signatures (from a resolved `implements` clause), verify
// the type declares a method matching each expected entry. Methods are stored
// in `project.funcReturnTypes` / `project.funcSignatures` under the qualified
// name `{TypeName}.{method}`. Missing methods produce one diagnostic shape;
// wrong-signature methods (declared but with mismatched parameter or return
// types) produce a second shape. Both are emitted as E3016 in a single
// diagnostic per type, mirroring the C# bootstrap's behaviour.
function checkInterfaceConformance(project Project)
	for (_, st) in project.structTypes 'eachStruct'
		if st.expectedMethods.count() == 0 'noExpect'
			continue
		end 'noExpect'
		checkConformanceForType(project, typeName: st.name, expected: st.expectedMethods, line: st.nameLine, column: st.nameColumn, filePath: st.sourceFilePath)
	end 'eachStruct'

	for (_, et) in project.enumTypes 'eachEnum'
		if et.expectedMethods.count() == 0 'noExpect'
			continue
		end 'noExpect'
		checkConformanceForType(project, typeName: et.name, expected: et.expectedMethods, line: et.nameLine, column: et.nameColumn, filePath: et.sourceFilePath)
	end 'eachEnum'
end 'checkInterfaceConformance'

// One reference edge in the type-cycle graph: `label` is the user-facing path
// segment (e.g. `next: Node`, or a bare element name `Folder`) and `target` is
// the type name the edge points at.
type TypeRefEdge
	export var label as String
	export var target as String

	export static function create(label String, target String) returns TypeRefEdge
		return Self{label: label, target: target}
	end 'create'
end 'TypeRefEdge'

typealias TypeRefEdgeArray = Array with TypeRefEdge
typealias TypeRefGraph = Map with (String, TypeRefEdgeArray)

// A type found to participate in a reference cycle, with its formatted path and
// declaration site. Collected so the check can report only the earliest-declared
// cyclic type (mutual recursion forms one cycle reachable from either end).
type CycleCandidate
	export var typeName as String
	export var path as String
	export var line as LineNumber
	export var column as ColumnNumber
	export var filePath as FilePath

	export static function create(typeName String, path String, line LineNumber, column ColumnNumber, filePath FilePath) returns CycleCandidate
		return Self{typeName: typeName, path: path, line: line, column: column, filePath: filePath}
	end 'create'
end 'CycleCandidate'

typealias CycleCandidateArray = Array with CycleCandidate

// E4014 cycle check: build a directed reachability graph over user-defined
// types (struct fields, union associated values, container element types), then
// for every user type look for a cycle back to itself and report the shortest
// path. Mirrors the C# bootstrap's `TypeCycleCheckPass`.
function checkTypeReferenceCycles(project Project)
	var graph = TypeRefGraph.create()
	buildTypeReferenceGraph(project, graph: graph)

	// Collect every user type that participates in a cycle, then report only
	// the one declared earliest in source (mutually-recursive `A`/`B` form one
	// cycle reachable from either end — reporting both would double-diagnose a
	// single error). The C# bootstrap throws on the first cycle it finds; the
	// earliest-declaration rule makes that deterministic regardless of the
	// type-registry map's iteration order.
	var candidates = CycleCandidateArray.create()
	for (_, st) in project.structTypes 'eachStruct'
		collectCycleCandidate(graph, candidates: candidates, typeName: st.name, line: st.nameLine, column: st.nameColumn, filePath: st.sourceFilePath)
	end 'eachStruct'
	for (_, et) in project.enumTypes 'eachEnum'
		collectCycleCandidate(graph, candidates: candidates, typeName: et.name, line: et.nameLine, column: et.nameColumn, filePath: et.sourceFilePath)
	end 'eachEnum'

	if candidates.count() == 0 'noCycles'
		return
	end 'noCycles'

	var best = try candidates.get(0) otherwise panic("checkTypeReferenceCycles: candidates.get(0) failed after count check")
	for i in 1 upto candidates.count() 'pickEarliest'
		let cand = try candidates.get(i) otherwise panic("checkTypeReferenceCycles: candidates.get OOB at {i}")
		if cycleCandidateEarlier(cand, other: best) 'earlier'
			best = cand
		end 'earlier'
	end 'pickEarliest'
	reportCompileError(project, code: ErrorCode.irTypeCycle, message: "type '{best.typeName}' contains a reference cycle (via {best.path}); recursive type references are not allowed", line: best.line, column: best.column, filePath: best.filePath)
end 'checkTypeReferenceCycles'

// True when `a` is declared before `b` (lower file path, then line, then column).
function cycleCandidateEarlier(a CycleCandidate, other CycleCandidate) returns bool
	let pa = a.filePath.toString()
	let pb = other.filePath.toString()
	if pa != pb 'differentFile'
		return stringLexLess(pa, b: pb)
	end 'differentFile'
	if a.line != other.line 'differentLine'
		return a.line < other.line
	end 'differentLine'
	return a.column < other.column
end 'cycleCandidateEarlier'

// Record `typeName` as a cycle candidate when it reaches itself in the graph.
function collectCycleCandidate(graph TypeRefGraph, candidates CycleCandidateArray, typeName String, line LineNumber, column ColumnNumber, filePath FilePath)
	if isStdlibFunctionPath(filePath) 'skipStdlib'
		return
	end 'skipStdlib'
	let cycle = findShortestTypeCycle(graph, startType: typeName)
	if cycle.count() == 0 'noCycle'
		return
	end 'noCycle'
	var path = ""
	for i in 0 upto cycle.count() 'joinPath'
		let seg = try cycle.get(i) otherwise panic("collectCycleCandidate: cycle.get OOB at {i}")
		if i > 0 'sep'
			path.append(" → ")
		end 'sep'
		path.append(seg)
	end 'joinPath'
	candidates.push(CycleCandidate.create(typeName, path: path, line: line, column: column, filePath: filePath))
end 'collectCycleCandidate'

// Populate `graph` with one entry per user struct/enum that has outgoing type
// references. Container fields contribute a synthetic node for the container
// (keyed by its alias display name) with edges to each user-type element.
function buildTypeReferenceGraph(project Project, graph TypeRefGraph)
	for (_, st) in project.structTypes 'eachStruct'
		if isStdlibFunctionPath(st.sourceFilePath) 'skipStdlibStruct'
			continue
		end 'skipStdlibStruct'
		var edges = TypeRefEdgeArray.create()
		for field in st.fields 'eachField'
			addTypeReferenceEdges(project, graph: graph, edges: edges, fieldLabel: field.name, fieldType: field.fieldType)
		end 'eachField'
		if edges.count() > 0 'hasEdges'
			try graph.insert(st.name, value: edges) otherwise ignore
		end 'hasEdges'
	end 'eachStruct'

	for (_, et) in project.enumTypes 'eachEnum'
		if isStdlibFunctionPath(et.sourceFilePath) 'skipStdlibEnum'
			continue
		end 'skipStdlibEnum'
		var edges = TypeRefEdgeArray.create()
		for enumCase in et.cases 'eachCase'
			for payload in enumCase.payloadFields 'eachPayload'
				let fieldPath = "{enumCase.name}.{payload.name}"
				addTypeReferenceEdges(project, graph: graph, edges: edges, fieldLabel: fieldPath, fieldType: payload.fieldType)
			end 'eachPayload'
		end 'eachCase'
		if edges.count() > 0 'hasEnumEdges'
			try graph.insert(et.name, value: edges) otherwise ignore
		end 'hasEnumEdges'
	end 'eachEnum'
end 'buildTypeReferenceGraph'

// Add the ownership edges a single field/payload of type `fieldType` contributes:
//   - a direct `named(UserType)` field → one edge `label: UserType` → UserType.
//   - a container field (alias or generic instance of Array/Map/Set/etc) → an
//     edge `label: <aliasDisplay>` to a synthetic container node, plus that
//     container node's edges to each user-type element (labeled by the element
//     name). The container node is keyed by its display name so the same alias
//     used by several fields shares one node.
function addTypeReferenceEdges(project Project, graph TypeRefGraph, edges TypeRefEdgeArray, fieldLabel String, fieldType MaxonType)
	let directName = userTypeNameOrEmpty(project, t: fieldType)
	if not directName.isEmpty() 'isDirect'
		edges.push(TypeRefEdge.create("{fieldLabel}: {directName}", target: directName))
		return
	end 'isDirect'
	let elements = containerElementUserTypes(project, t: fieldType)
	if elements.count() == 0 'noContainer'
		return
	end 'noContainer'
	let containerDisplay = fieldType.toString(project)
	edges.push(TypeRefEdge.create("{fieldLabel}: {containerDisplay}", target: containerDisplay))
	var containerEdges = TypeRefEdgeArray.create()
	if let existing = try graph.get(containerDisplay) 'hasExisting'
		containerEdges = existing
	end 'hasExisting'
	for i in 0 upto elements.count() 'eachElem'
		let elem = try elements.get(i) otherwise panic("addTypeReferenceEdges: elements.get OOB at {i}")
		if not containerEdgeExists(containerEdges, target: elem) 'newEdge'
			containerEdges.push(TypeRefEdge.create(elem, target: elem))
		end 'newEdge'
	end 'eachElem'
	try graph.insert(containerDisplay, value: containerEdges) otherwise ignore
end 'addTypeReferenceEdges'

function containerEdgeExists(edges TypeRefEdgeArray, target String) returns bool
	for e in edges 'scan'
		if e.target == target 'hit'
			return true
		end 'hit'
	end 'scan'
	return false
end 'containerEdgeExists'

// The user struct/enum name `t` directly names, or "" when `t` is not a bare
// reference to a user-defined struct/enum (primitive, container, alias-to-
// container, type-parameter, …).
function userTypeNameOrEmpty(project Project, t MaxonType) returns String
	let name = t.namedAliasNameOrEmpty(project)
	if name.isEmpty() 'notNamed'
		return ""
	end 'notNamed'
	if project.structTypes.contains(name) or project.enumTypes.contains(name) 'isUserType'
		return name
	end 'isUserType'
	return ""
end 'userTypeNameOrEmpty'

// Element user-type names referenced by a container-typed field. Resolves a
// type-alias to its underlying generic instance, then returns each generic
// argument that names a user struct/enum.
function containerElementUserTypes(project Project, t MaxonType) returns StringArray
	var result = StringArray.create()
	let resolved = resolveAliasForCompare(project, t: t)
	if not maxonTypeIsGenericInstance(resolved) 'notGeneric'
		return result
	end 'notGeneric'
	let args = genericInstanceArgsOf(project, t: resolved)
	for i in 0 upto args.count() 'eachArg'
		let arg = try args.get(i) otherwise panic("containerElementUserTypes: args.get OOB at {i}")
		let elemName = arg.namedAliasNameOrEmpty(project)
		if not elemName.isEmpty() 'hasName'
			if project.structTypes.contains(elemName) or project.enumTypes.contains(elemName) 'isUserElem'
				result.push(elemName)
			end 'isUserElem'
		end 'hasName'
	end 'eachArg'
	return result
end 'containerElementUserTypes'

// BFS for the shortest cycle from `startType` back to itself. Returns the path
// segments (`[startType, "next: Node"]` for a direct self-ref) or an empty
// array when `startType` cannot reach itself.
function findShortestTypeCycle(graph TypeRefGraph, startType String) returns StringArray
	let startEdges = try graph.get(startType) otherwise return StringArray.create()

	// Seed the queue from each direct neighbour, returning immediately on a
	// direct self-reference.
	var queueTargets = StringArray.create()
	var queuePaths = TypeRefPathArray.create()
	for edge in startEdges 'seed'
		if edge.target == startType 'directSelf'
			var direct = StringArray.create()
			direct.push(startType)
			direct.push(edge.label)
			return direct
		end 'directSelf'
		var seedPath = StringArray.create()
		seedPath.push(startType)
		seedPath.push(edge.label)
		queueTargets.push(edge.target)
		queuePaths.push(seedPath)
	end 'seed'

	var visited = StringSet.create()
	var head = 0
	while head < queueTargets.count() 'bfs'
		let current = try queueTargets.get(head) otherwise panic("findShortestTypeCycle: queueTargets.get OOB")
		let currentPath = try queuePaths.get(head) otherwise panic("findShortestTypeCycle: queuePaths.get OOB")
		head = head + 1
		if visited.contains(current) 'seen'
			continue
		end 'seen'
		visited.insert(current)
		let edges = try graph.get(current) otherwise TypeRefEdgeArray.create()
		for edge in edges 'eachEdge'
			if edge.target == startType 'foundCycle'
				var found = currentPath.clone()
				found.push(edge.label)
				return found
			end 'foundCycle'
			if not visited.contains(edge.target) 'enqueue'
				var nextPath = currentPath.clone()
				nextPath.push(edge.label)
				queueTargets.push(edge.target)
				queuePaths.push(nextPath)
			end 'enqueue'
		end 'eachEdge'
	end 'bfs'

	return StringArray.create()
end 'findShortestTypeCycle'

typealias TypeRefPathArray = Array with StringArray

// Compare each expected signature against the type's declared methods.
// Existence is checked via `project.funcReturnTypes.contains` since the parser
// registers every method there under `{TypeName}.{methodName}`. Methods that
// exist are compared for parameter and return type compatibility against the
// interface's expected signature; mismatches produce the "wrong signature"
// arm of E3016. The "missing method(s)" arm wins over the "wrong signature"
// arm when both are non-empty so the user sees the more fundamental gap
// first, matching the C# bootstrap's diagnostic ordering.
function checkConformanceForType(project Project, typeName String, expected InterfaceMethodSigArray, line LineNumber, column ColumnNumber, filePath FilePath)
	var missing = StringArray.create()
	var wrongSig = StringArray.create()
	for sig in expected 'eachExpected'
		let qualified = "{typeName}.{sig.name}"
		// Two paths exist for the actual implementation: the bare qualified
		// name (un-overloaded method), or one of the overload bucket entries
		// (when the user wrote multiple methods with the same name — e.g.
		// `toString()` for Stringable plus `toString(format)` for
		// FormattedStringable). Try the bare key first, then walk the
		// bucket and pick the entry whose signature matches `sig`.
		let bareHit = project.funcReturnTypes.contains(qualified)
		let matchKey = qualified if bareHit else findOverloadMatchingSignature(project, qualified: qualified, sig: sig)
		if matchKey.isEmpty() 'absent'
			var entry = formatMethodSig(project, sig: sig)
			if not sig.sourceInterfaceName.isEmpty() and sig.sourceInterfaceName != sig.directInterfaceName 'fromExtends'
				entry = "{entry} (from {sig.sourceInterfaceName})"
			end 'fromExtends'
			missing.push(entry)
			continue
		end 'absent'
		// Static interface methods are validated by the compiler directly; no
		// runtime witness is dispatched against them, so a signature-shape
		// mismatch can't cause a call-site type confusion. Skip them here to
		// match the C# bootstrap's `if (method.IsStatic) ... continue` branch.
		// However, throws-clause conformance is still validated for static
		// methods (matching C#'s ValidateThrowsConformance call inside the
		// IsStatic branch).
		if sig.isStatic 'isStatic'
			validateThrowsConformance(project, sig: sig, actualName: matchKey, typeName: typeName, line: line, column: column, filePath: filePath)
			continue
		end 'isStatic'
		let actualReturn = try project.funcReturnTypes.get(matchKey) otherwise panic("checkConformanceForType: funcReturnTypes.get '{matchKey}' missing despite contains")
		let actualSig = try project.funcSignatures.get(matchKey) otherwise panic("checkConformanceForType: funcSignatures.get '{matchKey}' missing despite contains")
		if not signatureMatches(project, expected: sig, actualParamNames: actualSig.paramNames, actualParamTypes: actualSig.paramTypes, actualReturn: actualReturn) 'mismatch'
			let actualFormatted = formatActualSignature(project, methodName: sig.name, paramNames: actualSig.paramNames, paramTypes: actualSig.paramTypes, returnType: actualReturn)
			wrongSig.push("{actualFormatted} (expected {formatMethodSig(project, sig: sig)})")
		end 'mismatch' else 'sigOk'
			// Throws-clause conformance only after a structural-signature match
			// (mirrors C# `else if (method.ThrowsTypeName != null)` branch).
			validateThrowsConformance(project, sig: sig, actualName: matchKey, typeName: typeName, line: line, column: column, filePath: filePath)
		end 'sigOk'
	end 'eachExpected'

	if missing.count() > 0 'missingFirst'
		reportCompileError(project, code: ErrorCode.semanticPartialInterfaceImpl, message: buildMissingMessage(typeName, missing: missing), line: line, column: column, filePath: filePath)
		return
	end 'missingFirst'

	if wrongSig.count() > 0 'mismatchOnly'
		reportCompileError(project, code: ErrorCode.semanticPartialInterfaceImpl, message: buildWrongSignatureMessage(typeName, wrongSig: wrongSig), line: line, column: column, filePath: filePath)
	end 'mismatchOnly'
end 'checkConformanceForType'

// Validate that a conforming method's `throws` clause satisfies the
// interface's expected throws contract. Two failure shapes, both reported
// as E3016:
//   1. Interface requires `throws X` but the actual method has no throws
//      clause — surface "must throw 'X' as required by interface 'Y'".
//   2. The actual throws type names a registered enum that does NOT
//      conform to Error — surface "throws 'Z' which does not conform to
//      Error". Throws types that aren't enums (e.g. union or the bare
//      `Error` interface itself) are accepted, mirroring the C# bootstrap
//      which only rejects enum throws types missing Error conformance.
function validateThrowsConformance(project Project, sig InterfaceMethodSig, actualName String, typeName String, line LineNumber, column ColumnNumber, filePath FilePath)
	let requiredThrows = match sig.throwsTypeName 'expected'
		none gives ""
		throwing(name) gives name
	end 'expected'
	if requiredThrows.isEmpty() 'noRequirement'
		return
	end 'noRequirement'

	let actualThrows = try project.funcThrowsTypes.get(actualName) otherwise ThrowsClause.none
	let actualName2 = match actualThrows 'actual'
		none gives ""
		throwing(name) gives name
	end 'actual'
	if actualName2.isEmpty() 'missingThrows'
		reportCompileError(project, code: ErrorCode.semanticPartialInterfaceImpl, message: "Method '{typeName}.{sig.name}' must throw '{requiredThrows}' as required by interface '{sig.directInterfaceName}'", line: line, column: column, filePath: filePath)
		return
	end 'missingThrows'

	// Only enum throws types are validated against Error conformance —
	// non-enum throws types (e.g. unions, the `Error` interface itself,
	// or unresolved names) pass through unchecked, matching the C#
	// bootstrap's `if (throwsTypeEntry is IrEnumType throwsEnum && ...)` guard.
	if not project.enumTypes.contains(actualName2) 'notEnum'
		return
	end 'notEnum'
	if project.conformances.contains(actualName2, interfaceName: "Error") 'isError'
		return
	end 'isError'
	reportCompileError(project, code: ErrorCode.semanticPartialInterfaceImpl, message: "Method '{typeName}.{sig.name}' throws '{actualName2}' which does not conform to Error", line: line, column: column, filePath: filePath)
end 'validateThrowsConformance'

// Walk the overload bucket for a method name and return the registered key
// whose signature matches `sig`. Returns "" when no matching overload
// exists. Mirrors `signatureMatches`'s logic so the conformance check sees
// the same shape the call-site dispatch will pick.
function findOverloadMatchingSignature(project Project, qualified String, sig InterfaceMethodSig) returns String
	let bucket = try project.overloadedNames.get(qualified) otherwise return ""
	for i in 0 upto bucket.count() 'eachMangled'
		let key = try bucket.get(i) otherwise panic("findOverloadMatchingSignature: bucket.get OOB at {i}")
		if not project.funcReturnTypes.contains(key) 'stale'
			continue
		end 'stale'
		let actualReturn = try project.funcReturnTypes.get(key) otherwise panic("findOverloadMatchingSignature: funcReturnTypes.get '{key}' missing despite contains")
		let actualSig = try project.funcSignatures.get(key) otherwise panic("findOverloadMatchingSignature: funcSignatures.get '{key}' missing despite contains")
		if signatureMatches(project, expected: sig, actualParamNames: actualSig.paramNames, actualParamTypes: actualSig.paramTypes, actualReturn: actualReturn) 'matches'
			return key
		end 'matches'
	end 'eachMangled'
	return ""
end 'findOverloadMatchingSignature'

// Compare an expected interface signature against an actual implementation's
// param names, param types, and return type. The actual paramTypes carry an
// implicit leading `__self` for instance methods; we skip it before the
// element-wise compare since the interface signature never names self. Param
// names are compared too because Maxon's named-argument calling convention
// makes the parameter name part of the public contract — interface implementers
// must keep the names the same as the interface or call sites that go through
// the interface will fail to bind.
function signatureMatches(project Project, expected InterfaceMethodSig, actualParamNames StringArray, actualParamTypes MaxonTypeArray, actualReturn MaxonReturnType) returns bool
	let skipSelf = 1 if actualParamNames.count() > 0 and (try actualParamNames.get(0) otherwise "") == "__self" else 0
	let actualUserCount = actualParamNames.count() - skipSelf
	if actualUserCount != expected.paramTypes.count() 'arity'
		return false
	end 'arity'
	for i in 0 upto expected.paramTypes.count() 'each'
		let expName = try expected.paramNames.get(i) otherwise panic("signatureMatches: expected.paramNames.get OOB at {i}")
		let expType = try expected.paramTypes.get(i) otherwise panic("signatureMatches: expected.paramTypes.get OOB at {i}")
		let actName = try actualParamNames.get(i + skipSelf) otherwise panic("signatureMatches: actualParamNames.get OOB at {i}")
		let actType = try actualParamTypes.get(i + skipSelf) otherwise panic("signatureMatches: actualParamTypes.get OOB at {i}")
		if expName != actName 'nameMismatch'
			return false
		end 'nameMismatch'
		if not maxonTypesMatchForConformance(project, expected: expType, actual: actType) 'typeMismatch'
			return false
		end 'typeMismatch'
	end 'each'
	return maxonReturnTypesMatchForConformance(project, expected: expected.returnType, actual: actualReturn)
end 'signatureMatches'

// Conformance-side type comparison. Stricter than plain structural equality
// at one specific cross-scope shape: interface method signatures are parsed
// with `currentTypeParams = []` (interface bodies don't push their
// `usesParams` into the in-scope type-param table), so a type-parameter
// reference inside the signature lands as `MaxonType.named("Element")`
// rather than `MaxonType.typeParameter(...)`. The implementing type's
// methods, by contrast, are parsed with `currentTypeParams = ["Element",
// ...]`, so the same identifier lands as `typeParameter(id)`. Strict
// structural equality would reject the otherwise-correct conformance.
// Treat `named("X")` and `typeParameter(id)` as equal when `id`'s declared
// param name is `X`. All other arms fall back to plain structural equality.
//
// For `genericInstance` arms, the same looseness has to apply per-arg:
// `Iterator with (Source, Element)` substitutes `Element → __Tuple2 with
// (Source, Element)` and the resulting return arms reference `Source` /
// `Element` as `named` in the expected side and as `typeParameter` in the
// implementer's body. Walk arg lists element-wise with the same predicate.
function maxonTypesMatchForConformance(project Project, expected MaxonType, actual MaxonType) returns bool
	if maxonTypesStructurallyEqual(expected, b: actual) 'eq'
		return true
	end 'eq'
	// Generic-instance arms compare structurally with the per-arg looseness
	// applied recursively. Without this, a `current() returns __Tuple2 with
	// (Source, Element)` impl on a `Iterator with (Source, Element)` conformer
	// surfaces as a wrong-signature E3016 because the expected side's args
	// are `named` and the actual side's are `typeParameter`.
	let giMatch = tryMatchGenericInstanceArms(project, expected: expected, actual: actual)
	if giMatch.handled 'giResult'
		return giMatch.result
	end 'giResult'
	let expName = match expected 'expCase'
		named(id) gives project.typeNames.get(id)
		boolean to string gives ""
		function to cstring gives ""
	end 'expCase'
	if expName.isEmpty() 'noExpName'
		return false
	end 'noExpName'
	let actParamName = match actual 'actCase'
		typeParameter(id) gives project.typeParameters.getName(id)
		boolean to string gives ""
		named gives ""
		function gives ""
		unresolved gives ""
		genericInstance to cstring gives ""
	end 'actCase'
	return not actParamName.isEmpty() and actParamName == expName
end 'maxonTypesMatchForConformance'

// Three-state result so the caller can distinguish "both arms are
// genericInstance and the arg-wise compare ran" from "neither arm is a
// genericInstance, fall through to the named/typeParameter looseness".
type GenericInstanceMatchResult
	export var handled as bool
	export var result as bool

	export static function pass() returns GenericInstanceMatchResult
		return Self{handled: false, result: false}
	end 'pass'

	export static function decided(result bool) returns GenericInstanceMatchResult
		return Self{handled: true, result: result}
	end 'decided'
end 'GenericInstanceMatchResult'

// When both `expected` and `actual` are `genericInstance` arms, compare them
// structurally: same base name + same arg arity + arg-wise conformance match.
// Returns a `handled: false` sentinel when either arm isn't a generic
// instance so the caller can fall through to the existing named/
// typeParameter looseness path.
function tryMatchGenericInstanceArms(project Project, expected MaxonType, actual MaxonType) returns GenericInstanceMatchResult
	let expGidOpt = extractGenericInstanceGid(expected)
	let actGidOpt = extractGenericInstanceGid(actual)
	if not expGidOpt.present or not actGidOpt.present 'notGi'
		return GenericInstanceMatchResult.pass()
	end 'notGi'
	return compareGenericInstanceContents(project, expGid: expGidOpt.gid, actGid: actGidOpt.gid)
end 'tryMatchGenericInstanceArms'

// Optional<GenericInstanceId> shape. Maxon's `match` arms can't bind a
// pattern variable in some arms and pass through in others when the result
// type needs to differ, so a tiny carrier struct lets callers tell "this
// arm was a genericInstance and the gid is X" from "this arm wasn't a
// genericInstance" without painting all the non-gi arms with a sentinel.
type OptionalGenericInstanceId
	export var present as bool
	export var gid as GenericInstanceId

	export static function none() returns OptionalGenericInstanceId
		return Self{present: false, gid: 0}
	end 'none'

	export static function some(gid GenericInstanceId) returns OptionalGenericInstanceId
		return Self{present: true, gid: gid}
	end 'some'
end 'OptionalGenericInstanceId'

function extractGenericInstanceGid(t MaxonType) returns OptionalGenericInstanceId
	return match t 'arm'
		genericInstance(id) gives OptionalGenericInstanceId.some(id)
		boolean to unresolved gives OptionalGenericInstanceId.none()
		typeParameter gives OptionalGenericInstanceId.none()
		interface to cstring gives OptionalGenericInstanceId.none()
	end 'arm'
end 'extractGenericInstanceGid'

// Compare two generic-instance gids structurally: base ids must match, and
// each arg slot must satisfy the conformance-side type predicate (so a
// `named("Element")` on the expected side accepts a `typeParameter` whose
// name is `Element` on the actual side, mirroring the top-level rule).
function compareGenericInstanceContents(project Project, expGid GenericInstanceId, actGid GenericInstanceId) returns GenericInstanceMatchResult
	let (expBase, expArgs) = project.genericInstances.get(expGid)
	let (actBase, actArgs) = project.genericInstances.get(actGid)
	if expBase != actBase 'baseMismatch'
		return GenericInstanceMatchResult.decided(false)
	end 'baseMismatch'
	if expArgs.count() != actArgs.count() 'arityMismatch'
		return GenericInstanceMatchResult.decided(false)
	end 'arityMismatch'
	for i in 0 upto expArgs.count() 'eachArg'
		let ea = try expArgs.get(i) otherwise panic("compareGenericInstanceContents: expArgs.get OOB at {i}")
		let aa = try actArgs.get(i) otherwise panic("compareGenericInstanceContents: actArgs.get OOB at {i}")
		if not maxonTypesMatchForConformance(project, expected: ea, actual: aa) 'mismatch'
			return GenericInstanceMatchResult.decided(false)
		end 'mismatch'
	end 'eachArg'
	return GenericInstanceMatchResult.decided(true)
end 'compareGenericInstanceContents'

function maxonReturnTypesMatchForConformance(project Project, expected MaxonReturnType, actual MaxonReturnType) returns bool
	return match expected 'cmp'
		void gives match actual 'aVoid'
			void gives true
			value gives false
		end 'aVoid'
		value(innerExp) gives match actual 'aVal'
			void gives false
			value(innerAct) gives maxonTypesMatchForConformance(project, expected: innerExp, actual: innerAct)
		end 'aVal'
	end 'cmp'
end 'maxonReturnTypesMatchForConformance'

// Render a `(p1 T1, p2 T2)` parameter list, skipping the first `startIndex`
// slots. The actual-signature path passes startIndex=1 to elide the implicit
// `__self` slot instance methods carry; the interface side passes 0.
function formatParamList(project Project, paramNames StringArray, paramTypes MaxonTypeArray, startIndex MachineWord) returns String
	var paramList = ""
	for i in startIndex upto paramNames.count() 'eachParam'
		if i > startIndex 'sep'
			paramList.append(", ")
		end 'sep'
		let pname = try paramNames.get(i) otherwise panic("formatParamList: paramNames.get OOB at {i}")
		let ptype = try paramTypes.get(i) otherwise panic("formatParamList: paramTypes.get OOB at {i}")
		paramList.append("{pname} {ptype.toString(project)}")
	end 'eachParam'
	return paramList
end 'formatParamList'

// Render the trailing ` returns T` clause (or ` returns void`).
function formatReturnPart(project Project, returnType MaxonReturnType) returns String
	return match returnType 'ret'
		void gives " returns void"
		value(inner) gives " returns {inner.toString(project)}"
	end 'ret'
end 'formatReturnPart'

// Render a function's actual signature in the same shape as `formatMethodSig`
// produces for the interface's expected entry. Skips a leading `__self` slot
// so instance methods print as `name(p1 T1, p2 T2) returns R` without leaking
// the implicit self parameter into user-facing diagnostics.
function formatActualSignature(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType) returns String
	let skipSelf = 1 if paramNames.count() > 0 and (try paramNames.get(0) otherwise "") == "__self" else 0
	let paramList = formatParamList(project, paramNames: paramNames, paramTypes: paramTypes, startIndex: skipSelf)
	return "{methodName}({paramList}){formatReturnPart(project, returnType: returnType)}"
end 'formatActualSignature'

// Render an InterfaceMethodSig as a one-line declaration string in the
// shape the C# bootstrap emits:
//
//     name(p1 Type1, p2 Type2) returns Ret throws ErrType
//
// Empty parameter list collapses to `name()`. Void return types render as
// ` returns void` to match the C# bootstrap's `FormatResolved`. A
// non-throwing method omits the `throws` clause.
function formatMethodSig(project Project, sig InterfaceMethodSig) returns String
	let paramList = formatParamList(project, paramNames: sig.paramNames, paramTypes: sig.paramTypes, startIndex: 0)
	let throwsPart = match sig.throwsTypeName 'fmt'
		none gives ""
		throwing(n) gives " throws {n}"
	end 'fmt'
	return "{sig.name}({paramList}){formatReturnPart(project, returnType: sig.returnType)}{throwsPart}"
end 'formatMethodSig'

// Compose the full E3016 diagnostic body. Each missing entry sits on its own
// line, indented by two spaces and prefixed with `- `, matching the C#
// bootstrap's `string.Join("\n", ...)` output.
function buildMissingMessage(typeName String, missing StringArray) returns String
	var msg = "Partial interface implementation: type '{typeName}' is missing {missing.count()} method(s):"
	for entry in missing 'eachMissing'
		msg.append("\n  - {entry}")
	end 'eachMissing'
	return msg
end 'buildMissingMessage'

// Compose the wrong-signature E3016 body. Same indentation shape as
// `buildMissingMessage` so test scrapers and downstream parsers handle the
// two arms uniformly.
function buildWrongSignatureMessage(typeName String, wrongSig StringArray) returns String
	var msg = "Partial interface implementation: type '{typeName}' has {wrongSig.count()} method(s) with wrong signature:"
	for entry in wrongSig 'eachWrong'
		msg.append("\n  - {entry}")
	end 'eachWrong'
	return msg
end 'buildWrongSignatureMessage'

// Drain the parser's deferred E3012 candidates. For each candidate function:
//   1. If a prior diagnostic landed inside this function's source range,
//      skip the entry — the C# bootstrap throws on the first error it sees,
//      so a primary error inside a body suppresses any secondary unused-var
//      diagnostic for the same body. Other functions in the same file (e.g.
//      a clean `doNothing` next to a noisy `main`) still report normally.
//   2. Otherwise, walk the parameter slots first (when not suppressed by
//      `skipParamCheck`), then the local slots, and emit one E3012 against
//      the first unreferenced name encountered. Reporting every unused
//      candidate would add noise that isn't in the spec; the bootstrap
//      throws on the first.
export function checkPendingUnusedVars(project Project, module MaxonModule)
	for entry in project.pendingUnusedChecks 'eachEntry'
		if functionHasPriorDiagnostic(project, entry: entry) 'skipFn'
			continue
		end 'skipFn'

		// Precedence within one function body mirrors the C# bootstrap's
		// throw-on-first-error ordering: E3012 (unused) is reported at body
		// finish before E3078 (var-from-immutable, thrown at the var-decl site
		// in C#) and E3077 (var-should-be-let, the last body-finish check). The
		// self-hosted pipeline defers all three to here, so we emit at most one
		// per entry and stop at the first that fires.
		let startIndex = entry.paramCount if entry.skipParamCheck else 0
		let endIndex = entry.candidates.count()
		var reported = false
		var i = startIndex
		while i < endIndex and not reported 'scan'
			let candidate = try entry.candidates.get(i) otherwise panic("checkPendingUnusedVars: candidates.get OOB at {i}")
			if not entry.referenced.contains(candidate.name) 'unused'
				reportCompileError(project, code: ErrorCode.semanticUnusedVariable, message: "unused variable: '{candidate.name}'", line: candidate.line, column: candidate.column, filePath: entry.filePath)
				reported = true
			end 'unused'
			i = i + 1
		end 'scan'

		if not reported 'tryVarFromImmutable'
			reported = checkVarFromImmutableForEntry(project, module: module, entry: entry)
		end 'tryVarFromImmutable'

		if not reported 'tryVarShouldBeLet'
			reported = checkVarShouldBeLetForEntry(project, entry: entry)
		end 'tryVarShouldBeLet'
	end 'eachEntry'
end 'checkPendingUnusedVars'

// E3078 (var-from-immutable) for one deferred entry. Emits at most one
// diagnostic and returns true when it fired. A candidate fires when its
// resolved binding type is a reference type (struct / enum / function); value
// types (int/float/bool/byte) are independent copies and skip the check. The
// resolved type is read from the binding's now-filled `varDecl` slotType.
function checkVarFromImmutableForEntry(project Project, module MaxonModule, entry PendingUnusedCheck) returns bool
	for cand in entry.varFromImmutable 'eachCand'
		if not bindingSlotTypeIsReferenceType(project, module: module, funcName: cand.funcName, slotId: cand.slotId) 'notReference'
			continue
		end 'notReference'
		let message = "cannot assign immutable variable '{cand.sourceVarName}' to mutable binding '{cand.bindingName}'; use 'let' instead of 'var', or use clone()" if not cand.fromImmutableRoot else "cannot assign from immutable variable to mutable binding '{cand.bindingName}'; use 'let' instead of 'var', or use clone()"
		reportCompileError(project, code: ErrorCode.semanticVarFromImmutable, message: message, line: cand.line, column: cand.column, filePath: entry.filePath)
		return true
	end 'eachCand'
	return false
end 'checkVarFromImmutableForEntry'

// E3077 (var-should-be-let) for one deferred entry. Walks the mutable-var
// candidates in declaration order; the first one that is referenced (so it
// isn't an E3012 unused case) yet never reassigned reports should-be-let.
// Returns true when it fired. The referenced check preserves E3012 precedence:
// an unused `var` was already handled by the unused scan above, but a `var`
// that the unused scan skipped (because it IS referenced) is the should-be-let
// candidate here.
function checkVarShouldBeLetForEntry(project Project, entry PendingUnusedCheck) returns bool
	for cand in entry.mutableCandidates 'eachCand'
		if not entry.referenced.contains(cand.name) 'unusedHandledElsewhere'
			continue
		end 'unusedHandledElsewhere'
		if entry.reassigned.contains(cand.name) 'wasReassigned'
			continue
		end 'wasReassigned'
		reportCompileError(project, code: ErrorCode.semanticVarShouldBeLet, message: "variable '{cand.name}' is never reassigned; use 'let' instead of 'var'", line: cand.line, column: cand.column, filePath: entry.filePath)
		return true
	end 'eachCand'
	return false
end 'checkVarShouldBeLetForEntry'

// True when the binding declared at `slotId` in `funcName` has a resolved
// reference type — a named struct or enum, or a function type. Reads the
// (now type-resolved) `varDecl` op's slotType. Value primitives, unresolved
// types, and named typealiases that resolve to primitives all return false so
// E3078 only fires for genuine reference-type copies.
function bindingSlotTypeIsReferenceType(project Project, module MaxonModule, funcName String, slotId VarSlot) returns bool
	for func in module.functions 'eachFunc'
		if func.name != funcName 'differentFunc'
			continue
		end 'differentFunc'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("bindingSlotTypeIsReferenceType: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("bindingSlotTypeIsReferenceType: opIdx OOB")
				if op.name == "varDecl" 'isVarDecl'
					let isMatch = match op 'declShape'
						varDecl(declSlot, _, slotType, _) gives declSlot == slotId and maxonTypeIsReferenceType(project, t: slotType)
						default panic("bindingSlotTypeIsReferenceType: op.name == varDecl but match failed")
					end 'declShape'
					if isMatch 'found'
						return true
					end 'found'
				end 'isVarDecl'
			end 'eachOp'
		end 'eachBlock'
		return false
	end 'eachFunc'
	return false
end 'bindingSlotTypeIsReferenceType'

// True when `t` is a reference type for E3078 purposes: a function type, or a
// `named(...)` type that resolves (through typealiases) to a user struct or
// enum. Primitives, generic instances, interfaces, type parameters, and
// unresolved types are not reference-copy sources here.
function maxonTypeIsReferenceType(project Project, t MaxonType) returns bool
	if isFunctionMaxonType(t) 'fnType'
		return true
	end 'fnType'
	let name = t.namedAliasNameOrEmpty(project)
	if name.isEmpty() 'notNamed'
		return false
	end 'notNamed'
	// A `named(...)` slotType that resolves to a user struct or enum is a
	// reference type. A named typealias to a primitive (e.g. `Integer`,
	// `ExitCode`) is not in either registry, so value-typed copies (the
	// `var-from-immutable-integer-ok` / `var-from-immutable-value-field-ok`
	// specs) correctly skip the check.
	return project.structTypes.contains(name) or project.enumTypes.contains(name)
end 'maxonTypeIsReferenceType'

// True when `project.diagnostics` carries any entry whose filePath matches
// the pending entry's path AND whose line falls within the entry's source
// range. Used to short-circuit the deferred unused-variable check on a per-
// function basis: a clean function in a file that contains a noisy one
// still emits its E3012, while the noisy function's own unused names get
// suppressed as cascade noise.
//
// Diagnostics with `line == 0` are file-scoped (e.g. TypeResolution's cast
// validator anchors at file level); they're treated as "in every body" so
// we don't emit a stray E3012 in a function whose body contains the actual
// cast — line/column zero is the only signal we have at this layer.
function functionHasPriorDiagnostic(project Project, entry PendingUnusedCheck) returns bool
	let myPath = entry.filePath.toString()
	for d in project.diagnostics 'eachDiag'
		if d.filePath.toString() != myPath 'differentFile'
			continue
		end 'differentFile'
		if d.line == 0 'fileScoped'
			return true
		end 'fileScoped'
		if d.line >= entry.startLine and d.line <= entry.endLine 'insideRange'
			return true
		end 'insideRange'
	end 'eachDiag'
	return false
end 'functionHasPriorDiagnostic'

// Phase 4e error-handling rules.
// Walks every function in the module and checks:
//   E3054 — main cannot declare a throws clause.
//   E3057 — plain `call` op targets a throwing function (user forgot `try`).
//   E3055 — `tryCall` op targets a non-throwing function (spurious `try`).
//
// funcThrowsTypes maps qualified function names to their declared throws type
// (empty string = non-throwing). Functions not in the map (stdlib intrinsics,
// synthesized helpers) are skipped and treated as non-throwing for E3057.
function checkErrorHandlingRules(project Project, module MaxonModule)
	for func in module.functions 'eachFunc'
		// E3054: main cannot declare a throws clause.
		let mainThrows = match func.throwsTypeName 'check'
			none gives false
			throwing gives true
		end 'check'
		if func.name == "main" and mainThrows 'mainThrows'
			reportCompileError(project, code: ErrorCode.semanticMainCannotThrow, message: "main cannot throw: 'main'", line: func.nameLine, column: func.nameColumn, filePath: func.sourceFilePath)
		end 'mainThrows'
		let readerFilePath = func.sourceFilePath
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkErrorHandlingRules: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("checkErrorHandlingRules: opIdx OOB")
				if op.name == "call" 'isCall'
					match op 'checkCallOp'
						call(_, callee, callContext, _, _, _, _, range) then checkCallForThrowsViolation(project, callee: callee, callContext: callContext, funcNamespace: func.namespace, readerFilePath: readerFilePath, range: range)
						default panic("checkErrorHandlingRules: op.name == call but match failed")
					end 'checkCallOp'
				end 'isCall'
				if op.name == "tryCall" 'isTryCall'
					match op 'checkTryCallOp'
						tryCall(_, callee, callContext, _, _, _, _, _, range) then checkTryCallForNonThrowingViolation(project, callee: callee, callContext: callContext, funcNamespace: func.namespace, readerFilePath: readerFilePath, range: range)
						default panic("checkErrorHandlingRules: op.name == tryCall but match failed")
					end 'checkTryCallOp'
				end 'isTryCall'
				if op.name == "methodCall" 'isMethodCall'
					match op 'checkMethodCallOp'
						methodCall(result, _, methodName, _, _, _, _, range) then checkMethodCallForThrowsViolation(project, opIdx: opIdx, result: result, methodName: methodName, readerFilePath: readerFilePath, range: range)
						default panic("checkErrorHandlingRules: op.name == methodCall but match failed")
					end 'checkMethodCallOp'
				end 'isMethodCall'
				if op.name == "tryMethodCall" 'isTryMethodCall'
					match op 'checkTryMethodCallOp'
						tryMethodCall(_, _, _, _, _, _, _, _, range) then checkTryMethodCallForNonThrowingViolation(project, opIdx: opIdx, readerFilePath: readerFilePath, range: range)
						default panic("checkErrorHandlingRules: op.name == tryMethodCall but match failed")
					end 'checkTryMethodCallOp'
				end 'isTryMethodCall'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'checkErrorHandlingRules'

// Tier 4 (E3073): every `async f()` must target a function that yields. A
// function yields if it contains an await / try-await / async-call op, calls a
// known I/O yield stub, or transitively calls a function that yields. Mirrors
// the C# bootstrap's CheckAsyncYielding (fixed-point over the call graph).
//
// At the Maxon-IR level the spec's yield point is a `call File.exists(...)` —
// `isAsyncYieldStub` recognizes the user-facing stdlib yield functions (and the
// underlying runtime primitives) directly, so a caller of `File.exists` is
// classified as yielding without needing the stdlib body's runtime call to be
// visible to this pass.
function checkAsyncYielding(project Project, module MaxonModule)
	// Fast path: no async-call sites → nothing to validate.
	if not moduleHasAsyncCall(module) 'noAsync'
		return
	end 'noAsync'

	// Build the per-function "yields" set and the callee call-graph in one walk.
	var yields = StringSet.create()
	var edges = CallerEdgeMap.create()
	for func in module.functions 'eachFunc'
		var callees = FuncNameArray.create()
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkAsyncYielding: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("checkAsyncYielding: opIdx OOB")
				classifyYieldOp(project, op: op, func: func, yields: yields, callees: callees)
			end 'eachOp'
			if block.hasTerminatorOp() 'hasTerm'
				let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("checkAsyncYielding: termIdx OOB")
				classifyYieldOp(project, op: termOp, func: func, yields: yields, callees: callees)
			end 'hasTerm'
		end 'eachBlock'
		edges.upsert(func.name, value: callees)
	end 'eachFunc'

	// Fixed-point: a function yields if any of its (already-qualified) callees
	// yields.
	let funcCount = module.functions.count()
	var changed = true
	while changed 'propagate'
		changed = false
		var i = 0
		while i < funcCount 'eachCaller'
			let caller = try module.functions.get(i) otherwise panic("checkAsyncYielding: caller.get OOB")
			if yields.contains(caller.name) 'already'
				i = i + 1
				continue
			end 'already'
			let callees = try edges.get(caller.name) otherwise FuncNameArray.create()
			for callee in callees 'eachCallee'
				if yields.contains(callee) 'calleeYields'
					yields.insert(caller.name)
					changed = true
					break
				end 'calleeYields'
			end 'eachCallee'
			i = i + 1
		end 'eachCaller'
	end 'propagate'

	// Report: each async-call whose (qualified) callee neither yields nor is a
	// known yield stub.
	for func in module.functions 'reportFunc'
		for blockRef in func.blockRefs 'reportBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkAsyncYielding: report blockRef OOB")
			for opIdx in block.opRefs 'reportOp'
				let op = try module.ops.get(opIdx) otherwise panic("checkAsyncYielding: report opIdx OOB")
				maybeReportNonYieldingAsync(project, op: op, func: func, yields: yields)
			end 'reportOp'
		end 'reportBlock'
	end 'reportFunc'
end 'checkAsyncYielding'

function moduleHasAsyncCall(module MaxonModule) returns bool
	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("moduleHasAsyncCall: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("moduleHasAsyncCall: opIdx OOB")
				if op.name == "asyncCall" 'found'
					return true
				end 'found'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
	return false
end 'moduleHasAsyncCall'

// Classify one op for the yields walk: async/await ops make the containing
// function yield; call/tryCall ops either mark a yield (I/O stub callee) or
// contribute a qualified callee edge for the fixed-point.
function classifyYieldOp(project Project, op MaxonOp, func IrFunction, yields StringSet, callees FuncNameArray)
	if op.name == "awaitPromise" or op.name == "tryAwait" 'isAwait'
		yields.insert(func.name)
		return
	end 'isAwait'
	if op.name == "asyncCall" 'isAsync'
		match op 'a'
			asyncCall(_, callee, callContext, _, _, _, _, _, _, _, _) then handleYieldCallEdge(project, callee: callee, callContext: callContext, func: func, yields: yields, callees: callees)
			default panic("classifyYieldOp: op.name == asyncCall but match failed")
		end 'a'
		return
	end 'isAsync'
	if op.name == "call" 'isCall'
		match op 'c'
			call(_, callee, callContext, _, _, _, _, _) then handleYieldCallEdge(project, callee: callee, callContext: callContext, func: func, yields: yields, callees: callees)
			default panic("classifyYieldOp: op.name == call but match failed")
		end 'c'
		return
	end 'isCall'
	if op.name == "tryCall" 'isTryCall'
		match op 't'
			tryCall(_, callee, callContext, _, _, _, _, _, _) then handleYieldCallEdge(project, callee: callee, callContext: callContext, func: func, yields: yields, callees: callees)
			default panic("classifyYieldOp: op.name == tryCall but match failed")
		end 't'
		return
	end 'isTryCall'
end 'classifyYieldOp'

// An async-call op also makes its containing function yield (it awaits the
// spawned promise's completion implicitly), so route the spawn-site callee
// through the same edge handler while marking the caller as yielding.
function handleYieldCallEdge(project Project, callee ByteArray, callContext CallContext, func IrFunction, yields StringSet, callees FuncNameArray)
	let qualified = qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: func.namespace, readerFilePath: func.sourceFilePath)
	if isAsyncYieldStub(qualified) 'isStub'
		yields.insert(func.name)
		return
	end 'isStub'
	callees.push(qualified)
end 'handleYieldCallEdge'

function maybeReportNonYieldingAsync(project Project, op MaxonOp, func IrFunction, yields StringSet)
	if op.name != "asyncCall" 'notAsync'
		return
	end 'notAsync'
	match op 'k'
		asyncCall(_, callee, callContext, _, _, _, _, _, _, callSourceText, range) then reportIfNonYielding(project, callee: callee, callContext: callContext, callSourceText: callSourceText, range: range, func: func, yields: yields)
		default panic("maybeReportNonYieldingAsync: op.name == asyncCall but match failed")
	end 'k'
end 'maybeReportNonYieldingAsync'

function reportIfNonYielding(project Project, callee ByteArray, callContext CallContext, callSourceText String, range SourceRange, func IrFunction, yields StringSet)
	let qualified = qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: func.namespace, readerFilePath: func.sourceFilePath)
	if yields.contains(qualified) or isAsyncYieldStub(qualified) 'yields'
		return
	end 'yields'
	reportCompileError(project, code: ErrorCode.asyncNonYielding, message: "'{callSourceText}' — function never yields; 'async' is for I/O-concurrent work only", line: range.line, column: range.column, filePath: func.sourceFilePath)
end 'reportIfNonYielding'

// The set of callee names (user-facing stdlib yield functions + underlying
// runtime primitives) whose call suspends the green thread. Mirrors the C#
// bootstrap's IoStubs, expressed at the Maxon-IR call-callee granularity.
function isAsyncYieldStub(name String) returns bool
	let stubs = ["File.exists", "File.read", "File.delete", "maxon_file_exists", "maxon_file_read", "maxon_file_delete", "maxon_sleep", "stdlib.sleep", "Subprocess.run", "maxon_subprocess_wait_collect"]
	for s in stubs 'each'
		if name == s 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'isAsyncYieldStub'

// E3057: calling a throwing function without `try`.
// The callee is the unqualified name; qualify it before looking up in funcThrowsTypes.
function checkCallForThrowsViolation(project Project, callee ByteArray, callContext CallContext, funcNamespace String, readerFilePath FilePath, range SourceRange)
	let bareCallee = String.from(callee)
	let qualifiedCallee = qualifyCalleeForContext(project, bare: bareCallee, callContext: callContext, currentNamespace: funcNamespace, readerFilePath: readerFilePath)
	let throwsType = try project.funcThrowsTypes.get(qualifiedCallee) otherwise return
	if not throwsClauseIsThrowing(throwsType) 'nonThrowing'
		return
	end 'nonThrowing'
	// Surface the unqualified call-site name so cross-namespace diagnostics
	// match what the user actually typed.
	reportCompileError(project, code: ErrorCode.semanticThrowingFunctionRequiresTry, message: "throwing function requires try: '{bareCallee}'", line: range.line, column: range.column, filePath: readerFilePath)
end 'checkCallForThrowsViolation'

// E3057 for method calls: `recv.method()` where `method` throws but the call
// site has no `try`. Like `checkTryMethodCallForNonThrowingViolation`, the
// receiver's owning type is only known after resolution, so we key the throws
// lookup off `resolvedCallees[opIdx]`. A site with no resolved callee
// (unresolved receiver — already an upstream error) is left alone. The
// diagnostic surfaces the bare method name the user typed.
function checkMethodCallForThrowsViolation(project Project, opIdx OpIndex, result ByteArray, methodName ByteArray, readerFilePath FilePath, range SourceRange)
	// The iterator-producing source of a `for ... in <expr>` loop is an
	// implicit-try position (the loop routes its errors to loop exit), so skip
	// it — mirrors the C# bootstrap's `_inTryContext` for-in silencing.
	if project.forInSourceCallResults.contains(String.from(result)) 'forInSource'
		return
	end 'forInSource'
	let resolved = try project.resolvedCallees.get(opIdx) otherwise return
	let qualifiedCallee = stripCalleeMangling(resolved)
	let throwsType = try project.funcThrowsTypes.get(qualifiedCallee) otherwise return
	if not throwsClauseIsThrowing(throwsType) 'nonThrowing'
		return
	end 'nonThrowing'
	reportCompileError(project, code: ErrorCode.semanticThrowingFunctionRequiresTry, message: "throwing function requires try: '{String.from(methodName)}'", line: range.line, column: range.column, filePath: readerFilePath)
end 'checkMethodCallForThrowsViolation'

// E3055: using `try` on a non-throwing function.
// Only fires when the qualified callee is explicitly registered with an empty throws type.
function checkTryCallForNonThrowingViolation(project Project, callee ByteArray, callContext CallContext, funcNamespace String, readerFilePath FilePath, range SourceRange)
	let qualifiedCallee = qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: funcNamespace, readerFilePath: readerFilePath)
	let throwsType = try project.funcThrowsTypes.get(qualifiedCallee) otherwise return
	if throwsClauseIsThrowing(throwsType) 'isThrowing'
		return
	end 'isThrowing'
	reportCompileError(project, code: ErrorCode.semanticTryRequiresThrowingFunction, message: "try requires a throwing function: '{qualifiedCallee}' does not throw'", line: range.line, column: range.column, filePath: readerFilePath)
end 'checkTryCallForNonThrowingViolation'

// E3055 for method calls: `try recv.method()` where `method` does not throw.
// A method call's qualified callee is resolved by TypeResolution into
// `resolvedCallees[opIdx]` (the `tryCall` path can qualify from the bare name
// + context, but a method receiver's owning type is only known after
// resolution, so we key off the resolved name here). A site with no resolved
// callee (unresolved receiver — already an upstream error) is left alone.
function checkTryMethodCallForNonThrowingViolation(project Project, opIdx OpIndex, readerFilePath FilePath, range SourceRange)
	let resolved = try project.resolvedCallees.get(opIdx) otherwise return
	let qualifiedCallee = stripCalleeMangling(resolved)
	let throwsType = try project.funcThrowsTypes.get(qualifiedCallee) otherwise return
	if throwsClauseIsThrowing(throwsType) 'isThrowing'
		return
	end 'isThrowing'
	reportCompileError(project, code: ErrorCode.semanticTryRequiresThrowingFunction, message: "try requires a throwing function: '{qualifiedCallee}' does not throw'", line: range.line, column: range.column, filePath: readerFilePath)
end 'checkTryMethodCallForNonThrowingViolation'

// E3087: walks every function and reports `if x.contains(k) ... try x.get(k)
// otherwise ...` patterns as redundant. The lint targets the double-lookup
// shape any container exposing both a membership probe and a fallible
// retrieval falls into (Map, Set, Array via index, …) — the user-facing
// rewrite `if let v = try x.get(k) ... 'lbl'` performs the same logic with
// one lookup.
//
// Detection per condBr-terminated block:
//   1. Find the methodCall in this block whose result fed condBr.cond and
//      whose unqualified method name is `contains`.
//   2. Build canonical access paths for the contains call's receiver and
//      first argument (the key) by walking back through varLoad / fieldLoad
//      / selfFieldLoad / globalLoad producers in the SAME block. Paths
//      that hit an unsupported producer (call result, binop, literal, …)
//      are unmatchable and suppress the lint.
//   3. Scan the thenTarget block linearly. Stop as soon as we see a write
//      that could invalidate the membership probe (a varStore on a slot
//      named in the path, a fieldStore on a field named in the path, a
//      selfFieldStore likewise, OR a method call on the same receiver path
//      that isn't a `get` with matching key). If we hit a tryMethodCall
//      whose receiver path AND key path match the contains call AND whose
//      unqualified method name is `get`, fire E3087.
function checkRedundantContainsGet(project Project, module MaxonModule)
	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkRedundantContainsGet: blockRef OOB")
			if not block.hasTerminatorOp() 'noTerm'
				continue
			end 'noTerm'
			let termIdx = block.terminatorIndex()
			let termOp = try module.ops.get(termIdx) otherwise panic("checkRedundantContainsGet: terminator opIdx OOB")
			if termOp.name != "condBr" 'notCondBr'
				continue
			end 'notCondBr'
			match termOp 'unwrapCondBr'
				condBr(cond, thenTarget, _, _) then maybeEmitRedundantContainsGet(project, module: module, func: func, block: block, condName: cond, thenTarget: thenTarget)
				default panic("checkRedundantContainsGet: op.name == condBr but match failed")
			end 'unwrapCondBr'
		end 'eachBlock'
	end 'eachFunc'
end 'checkRedundantContainsGet'

function maybeEmitRedundantContainsGet(project Project, module MaxonModule, func IrFunction, block IrBlock, condName ByteArray, thenTarget BlockId)
	// Scan back through this block's ops for the methodCall that produced
	// `condName`. The condition value must be in the same block — methodCall
	// results are block-local synthesized names.
	let containsIdx = try findMethodCallProducingName(module, block: block, name: condName) otherwise return
	let containsOp = try module.ops.get(containsIdx) otherwise panic("maybeEmitRedundantContainsGet: containsOpIdx OOB")
	let info = extractMethodCallInfo(containsOp)
	if String.from(info.methodNameBytes) != "contains" 'notContains'
		return
	end 'notContains'
	if info.args.count() < 1 'noKey'
		return
	end 'noKey'

	let slotNames = buildSlotNameTable(func)
	let containsLimit = containsIdx
	let receiverPath = buildAccessPath(module, block: block, limitOpIdx: containsLimit, name: info.receiver, slotNames: slotNames)
	if receiverPath.isEmpty() 'unresolvableReceiver'
		return
	end 'unresolvableReceiver'
	let containsKeyName = try info.args.get(0) otherwise panic("maybeEmitRedundantContainsGet: args.get(0) failed despite count>=1")
	let keyPath = buildAccessPath(module, block: block, limitOpIdx: containsLimit, name: containsKeyName, slotNames: slotNames)
	if keyPath.isEmpty() 'unresolvableKey'
		return
	end 'unresolvableKey'

	let thenBlock = try findBlockByIdInFunc(module, func: func, blockId: thenTarget) otherwise return

	// Guard sets used to detect intervening writes that could invalidate
	// the membership probe. `guardedSlotNames` collects the root variable
	// names in either path; `guardedFields` collects every dotted segment.
	var guardedSlotNames = StringSet.create()
	var guardedFields = StringSet.create()
	splitPathIntoGuards(receiverPath, slotNames: guardedSlotNames, fields: guardedFields)
	splitPathIntoGuards(keyPath, slotNames: guardedSlotNames, fields: guardedFields)

	let containsCalleeFmt = stripCalleeMangling(try project.resolvedCallees.get(containsIdx) otherwise "contains")

	for opIdx in thenBlock.opRefs 'eachThenOp'
		let op = try module.ops.get(opIdx) otherwise panic("maybeEmitRedundantContainsGet: thenBlock op OOB")
		if storeInvalidatesGuards(op, slotNames: slotNames, guardedSlotNames: guardedSlotNames, guardedFields: guardedFields) 'invalidatesGuards'
			break
		end 'invalidatesGuards'
		if not isMethodCallVariant(op) 'notMethodCall'
			continue
		end 'notMethodCall'

		let inner = extractMethodCallInfo(op)
		let innerLimit = opIdx as OpIndexOrMissing
		let innerReceiverPath = buildAccessPath(module, block: thenBlock, limitOpIdx: innerLimit, name: inner.receiver, slotNames: slotNames)
		if innerReceiverPath.isEmpty() 'unresolvableInnerReceiver'
			// Receiver could alias the contains receiver via a route we
			// can't statically reconcile (e.g. through a call result);
			// stay conservative and stop scanning.
			break
		end 'unresolvableInnerReceiver'
		if innerReceiverPath != receiverPath 'differentReceiver'
			continue
		end 'differentReceiver'

		if inner.isTry and String.from(inner.methodNameBytes) == "get" and inner.args.count() >= 1 'isTryGetCall'
			let innerKeyName = try inner.args.get(0) otherwise panic("maybeEmitRedundantContainsGet: inner.args.get(0) failed despite count>=1")
			let innerKeyPath = buildAccessPath(module, block: thenBlock, limitOpIdx: innerLimit, name: innerKeyName, slotNames: slotNames)
			if innerKeyPath == keyPath 'matched'
				let getCalleeFmt = stripCalleeMangling(try project.resolvedCallees.get(opIdx) otherwise "get")
				let msg = "redundant '{containsCalleeFmt}' followed by '{getCalleeFmt}' on '{receiverPath}': use 'if let v = try {receiverPath}.get({keyPath})' (or 'if var') instead — performs one lookup instead of two"
				reportCompileError(project, code: ErrorCode.semanticRedundantContainsGet, message: msg, line: info.range.line, column: info.range.column, filePath: func.sourceFilePath)
				return
			end 'matched'
		end 'isTryGetCall'

		// Any other call on the same receiver path could invalidate the
		// membership check (mutation, removal, etc.). Stop scanning to
		// avoid both false positives and double-reports.
		break
	end 'eachThenOp'
end 'maybeEmitRedundantContainsGet'

// Carrier for the fields a methodCall/tryMethodCall site exposes to the
// redundant-contains-get walker. Bundling them lets the destructuring
// match arm body fit into a single statement (one helper call instead of
// a multi-line arm body).
type MethodCallInfo
	export let receiver as ByteArray
	export let methodNameBytes as ByteArray
	export let args as ByteArrayArray
	export let isTry as bool
	export let range as SourceRange

	static function create(receiver ByteArray, methodNameBytes ByteArray, args ByteArrayArray, isTry bool, range SourceRange) returns Self
		return Self{receiver: receiver, methodNameBytes: methodNameBytes, args: args, isTry: isTry, range: range}
	end 'create'

	static function empty() returns Self
		return Self{receiver: ByteArray.create(), methodNameBytes: ByteArray.create(), args: ByteArrayArray.create(), isTry: false, range: SourceRange.none()}
	end 'empty'
end 'MethodCallInfo'

function extractMethodCallInfo(op MaxonOp) returns MethodCallInfo
	return match op 'kind'
		methodCall(_, r, mn, a, _, _, _, rg) gives MethodCallInfo.create(r, methodNameBytes: mn, args: a, isTry: false, range: rg)
		tryMethodCall(_, r, mn, a, _, _, _, _, rg) gives MethodCallInfo.create(r, methodNameBytes: mn, args: a, isTry: true, range: rg)
		default panic("extractMethodCallInfo: caller filters non-methodCall ops via isMethodCallVariant")
	end 'kind'
end 'extractMethodCallInfo'

function isMethodCallVariant(op MaxonOp) returns bool
	return op.name == "methodCall" or op.name == "tryMethodCall"
end 'isMethodCallVariant'

// True when `op` writes to one of the names/fields the membership probe
// depends on (varStore on a guarded slot, fieldStore on a guarded field,
// selfFieldStore on a guarded field, globalStore on a guarded global
// name). Used by the then-block scan to stop early before a stale
// `contains` answer can flow into a `get` call.
function storeInvalidatesGuards(op MaxonOp, slotNames SlotNameArray, guardedSlotNames StringSet, guardedFields StringSet) returns bool
	// Dispatch by op.name to avoid an exhaustive MaxonOp match: only the
	// four store-shaped ops can invalidate the membership probe; every
	// other op shape is harmless and returns false unconditionally.
	if op.name == "varStore" 'isVarStore'
		return match op 'extract'
			varStore(slotId, _, _) gives slotIsGuarded(slotId, slotNames: slotNames, guards: guardedSlotNames)
			default panic("storeInvalidatesGuards: name==varStore but match arm missed it")
		end 'extract'
	end 'isVarStore'
	if op.name == "fieldStore" 'isFieldStore'
		return match op 'extract'
			fieldStore(_, fieldName, _, _, _) gives guardedFields.contains(String.from(fieldName))
			default panic("storeInvalidatesGuards: name==fieldStore but match arm missed it")
		end 'extract'
	end 'isFieldStore'
	if op.name == "selfFieldStore" 'isSelfFieldStore'
		return match op 'extract'
			selfFieldStore(fieldName, _, _) gives guardedFields.contains(String.from(fieldName))
			default panic("storeInvalidatesGuards: name==selfFieldStore but match arm missed it")
		end 'extract'
	end 'isSelfFieldStore'
	if op.name == "globalStore" 'isGlobalStore'
		return match op 'extract'
			globalStore(name, _, _, _) gives guardedSlotNames.contains(name)
			default panic("storeInvalidatesGuards: name==globalStore but match arm missed it")
		end 'extract'
	end 'isGlobalStore'
	return false
end 'storeInvalidatesGuards'

// Thrown by findMethodCallProducingName when no methodCall in `block`
// produces an SSA name equal to the queried one. The condition value of
// a condBr need not be a methodCall result (a comparison result, varLoad,
// cmp folding, etc. is far more common), so callers treat a miss as
// "this condBr doesn't match the lint shape" and skip the block.
union ProducerLookupError implements Error
	noProducer
end 'ProducerLookupError'

// Walk `block.opRefs` and return the op index of the methodCall whose
// result ByteArray equals `name`.
function findMethodCallProducingName(module MaxonModule, block IrBlock, name ByteArray) returns OpIndex throws ProducerLookupError
	for opIdx in block.opRefs 'scan'
		let op = try module.ops.get(opIdx) otherwise panic("findMethodCallProducingName: opRefs entry OOB")
		if op.name != "methodCall" 'notMethodCall'
			continue
		end 'notMethodCall'
		let matches = match op 'mc'
			methodCall(result, _, _, _, _, _, _, _) gives byteArraysEqual(result, b: name)
			default panic("findMethodCallProducingName: name==methodCall guard above already filtered other shapes")
		end 'mc'
		if matches 'hit'
			return opIdx
		end 'hit'
	end 'scan'
	throw ProducerLookupError.noProducer
end 'findMethodCallProducingName'

// Locate the IrBlock with the given BlockId within `func.blockRefs`. Returns
// the block, or throws when the id isn't owned by this function (a malformed
// condBr that escapes its own function body).
union BlockLookupError implements Error
	notInFunc
end 'BlockLookupError'

function findBlockByIdInFunc(module MaxonModule, func IrFunction, blockId BlockId) returns IrBlock throws BlockLookupError
	for blockRef in func.blockRefs 'scan'
		let block = try module.blocks.get(blockRef) otherwise panic("findBlockByIdInFunc: blockRef OOB")
		if block.id == blockId 'hit'
			return block
		end 'hit'
	end 'scan'
	throw BlockLookupError.notInFunc
end 'findBlockByIdInFunc'

// Build a slot→source-name table from the function's scope so varLoad
// producers can render their source variable name. The scope's primary
// key is name, so this is the only direction that requires a walk.
typealias SlotNameArray = Array with String

function buildSlotNameTable(func IrFunction) returns SlotNameArray
	var table = SlotNameArray.create()
	for (_, info) in func.scope.allVars() 'eachVar'
		let needed = info.slot + 1
		while table.count() < needed 'grow'
			table.push("")
		end 'grow'
		try table.set(info.slot, value: info.name) otherwise panic("buildSlotNameTable: set OOB despite grow")
	end 'eachVar'
	return table
end 'buildSlotNameTable'

// Walk producers within `block` starting from the op that defines `name`
// (searched at indices strictly before `limitOpIdx` in `block.opRefs`)
// and accumulate a canonical access path like "m", "holder.cache", or
// "self.byName". Returns "" when the producer chain hits an op that
// isn't a supported root (call/binop/literal/cmp/etc.) — those values
// are not safely matchable as receivers/keys.
function buildAccessPath(module MaxonModule, block IrBlock, name ByteArray, limitOpIdx OpIndexOrMissing, slotNames SlotNameArray) returns String
	// Find the producer of `name` within `block` (at an opRef strictly
	// preceding `limitOpIdx`). opRefs are appended in emission order so
	// the first match traveling backward is the producer.
	var producerIdx = u64.max as OpIndex
	var found = false
	for opIdx in block.opRefs 'scan'
		if (opIdx as OpIndexOrMissing) >= limitOpIdx 'reachedLimit'
			break
		end 'reachedLimit'
		let op = try module.ops.get(opIdx) otherwise panic("buildAccessPath: opRef OOB")
		if opProducesName(op, name: name) 'isProducer'
			producerIdx = opIdx
			found = true
		end 'isProducer'
	end 'scan'
	if not found 'noProducer'
		return ""
	end 'noProducer'

	let producer = try module.ops.get(producerIdx) otherwise panic("buildAccessPath: producerIdx OOB after found=true")
	// Dispatch by op.name: only four producer shapes encode a canonical
	// access path; anything else returns "" so the lint stays conservative.
	if producer.name == "varLoad" 'isVarLoad'
		return match producer 'extract'
			varLoad(_, slotId, _, _) gives slotPathFromTable(slotNames, slotId: slotId)
			default panic("buildAccessPath: name==varLoad but match arm missed it")
		end 'extract'
	end 'isVarLoad'
	if producer.name == "selfFieldLoad" 'isSelfFieldLoad'
		return match producer 'extract'
			selfFieldLoad(_, fieldName, _) gives "self.{String.from(fieldName)}"
			default panic("buildAccessPath: name==selfFieldLoad but match arm missed it")
		end 'extract'
	end 'isSelfFieldLoad'
	if producer.name == "fieldLoad" 'isFieldLoad'
		return match producer 'extract'
			fieldLoad(_, recv, fieldName, _) gives fieldChainPath(module, block: block, recv: recv, fieldName: fieldName, limitOpIdx: producerIdx, slotNames: slotNames)
			default panic("buildAccessPath: name==fieldLoad but match arm missed it")
		end 'extract'
	end 'isFieldLoad'
	if producer.name == "globalLoad" 'isGlobalLoad'
		return match producer 'extract'
			globalLoad(_, gname, _, _) gives gname
			default panic("buildAccessPath: name==globalLoad but match arm missed it")
		end 'extract'
	end 'isGlobalLoad'
	return ""
end 'buildAccessPath'

function fieldChainPath(module MaxonModule, block IrBlock, recv ByteArray, fieldName ByteArray, limitOpIdx OpIndexOrMissing, slotNames SlotNameArray) returns String
	let inner = buildAccessPath(module, block: block, name: recv, limitOpIdx: limitOpIdx, slotNames: slotNames)
	if inner.isEmpty() 'innerUnresolvable'
		return ""
	end 'innerUnresolvable'
	return "{inner}.{String.from(fieldName)}"
end 'fieldChainPath'

function slotPathFromTable(slotNames SlotNameArray, slotId VarSlot) returns String
	// A slot the parser registered via Scope.declare always appears in
	// allVars, so an empty entry means the slot is compiler-synthesized
	// (e.g. for-in iterator slots) and unmatchable for this lint.
	if slotId >= slotNames.count() 'oob'
		return ""
	end 'oob'
	return try slotNames.get(slotId) otherwise ""
end 'slotPathFromTable'

// True when `op` defines an SSA name equal to `name`. Only the producer
// kinds the access-path walker understands need a positive answer here —
// other producers are treated as `default false`, which routes their
// users through the "unresolvable" tail of buildAccessPath.
function opProducesName(op MaxonOp, name ByteArray) returns bool
	if op.name == "varLoad" 'isVarLoad'
		return match op 'extract'
			varLoad(result, _, _, _) gives byteArraysEqual(result, b: name)
			default panic("opProducesName: name==varLoad guard above already filtered other shapes")
		end 'extract'
	end 'isVarLoad'
	if op.name == "selfFieldLoad" 'isSelfFieldLoad'
		return match op 'extract'
			selfFieldLoad(result, _, _) gives byteArraysEqual(result, b: name)
			default panic("opProducesName: name==selfFieldLoad guard above already filtered other shapes")
		end 'extract'
	end 'isSelfFieldLoad'
	if op.name == "fieldLoad" 'isFieldLoad'
		return match op 'extract'
			fieldLoad(result, _, _, _) gives byteArraysEqual(result, b: name)
			default panic("opProducesName: name==fieldLoad guard above already filtered other shapes")
		end 'extract'
	end 'isFieldLoad'
	if op.name == "globalLoad" 'isGlobalLoad'
		return match op 'extract'
			globalLoad(result, _, _, _) gives byteArraysEqual(result, b: name)
			default panic("opProducesName: name==globalLoad guard above already filtered other shapes")
		end 'extract'
	end 'isGlobalLoad'
	return false
end 'opProducesName'

// Split `path` ("root.f1.f2" or "root") into the leading root segment
// (recorded in `slotNames`) and each trailing field segment (recorded in
// `fields`). The split lets a single linear thenBlock walk detect a
// guarded reassignment in O(1) per op without re-parsing the path.
function splitPathIntoGuards(path String, slotNames StringSet, fields StringSet)
	let parts = path.split(".")
	for i in 0 upto parts.count() 'eachPart'
		let part = try parts.get(i) otherwise panic("splitPathIntoGuards: parts.get OOB despite i < count")
		if part.isEmpty() 'emptyPart'
			continue
		end 'emptyPart'
		if i == 0 'first'
			slotNames.insert(part)
		end 'first' else 'rest'
			fields.insert(part)
		end 'rest'
	end 'eachPart'
end 'splitPathIntoGuards'

// True when `slotId` maps to a name in the guard set. Synthetic slots
// (no name registered) trivially miss — they can't appear in any path.
function slotIsGuarded(slotId VarSlot, slotNames SlotNameArray, guards StringSet) returns bool
	if slotId >= slotNames.count() 'oob'
		return false
	end 'oob'
	let name = try slotNames.get(slotId) otherwise return false
	if name.isEmpty() 'synthetic'
		return false
	end 'synthetic'
	return guards.contains(name)
end 'slotIsGuarded'

// Strip the `$<suffix>` overload-mangling tail from a resolved callee
// like `Map.contains` / `Map.contains$0_String`. The C# bootstrap performs
// the same strip in StripCalleeNamespace before emitting the diagnostic so
// the user sees `Map.contains`, not the synthetic mangled form. We do
// NOT strip a leading namespace dot because the self-hosted resolver
// emits `{TypeName}.{method}` directly (no `stdlib.` prefix).
//
// `module` (visible to the Compiler/ subtree) so the IR-pass
// RejectWasmSubprocess can reuse it instead of re-deriving the same one-liner.
module function stripCalleeMangling(callee String) returns String
	let dollarIdx = try callee.findFirst("$") otherwise return callee
	return callee.slice(callee.startIndex(), endIndex: dollarIdx)
end 'stripCalleeMangling'

// --------------------------------------------------------------------------
// Phase 15a: purity analysis (mirrors C# PurityAnalysisPass).
//
// `func.isPure` is true iff the function has no side effects, no global or
// parameter mutation, and only calls pure functions. The analysis runs in
// three steps:
//
//   1. Direct-impurity classification: walk each function body once.
//      Functions with no return type or empty body are impure by default
//      (a void function exists only for its effects). Functions whose body
//      contains an op known to mutate state (globalStore, selfFieldStore,
//      callRuntime via callees prefixed `mrt_`, the impure managed-mem
//      builtins, or a call into a known I/O intrinsic) are impure.
//
//   2. Transitive propagation: any pure function that calls a function the
//      direct step marked impure becomes impure itself. Fixed-point reached
//      via a worklist of newly-impure functions; the reverse-edge walk uses
//      a callers map built from the call graph.
//
// Functions not appearing in `module.functions` (stdlib intrinsics whose
// IR was restored from the cache) are conservatively treated as impure
// when called — they were written outside the spec's purity contract.
// The C# bootstrap takes the same stance.
// --------------------------------------------------------------------------

// Callees that make any caller impure. This is the union of:
//   - I/O intrinsics surfaced via __Builtins.* (writeStdout, writeStderr,
//     readStdin) — touch the OS directly.
//   - The "impure managed-mem builtins" list from PurityAnalysisPass.cs:77.
//     These names appear as the `callee` of a `call`/`tryCall` op before
//     lowering rewrites them into runtime helpers.
//   - Any `mrt_*` runtime call — runtime helpers are the OS-call boundary
//     and always count as side-effects.
// The `mrt_*` prefix is checked separately because there are dozens of
// runtime names and listing each one would rot.
typealias ImpureCalleeSet = Set with String

function buildImpureCalleeSet() returns ImpureCalleeSet
	var s = ImpureCalleeSet.create()
	// I/O intrinsics. `print(s)` lowers to `Print.print` which calls
	// `__Builtins.writeStdout` — so the transitive walk picks it up.
	s.insert("__Builtins.writeStdout")
	s.insert("__Builtins.writeStderr")
	s.insert("__Builtins.readStdin")
	// Throwing managed-mem builtins that mutate state. Read-only builtins
	// (get, byteAt, slice, create, length, capacity, etc.) are excluded.
	s.insert("__managed_mem_set")
	s.insert("__managed_mem_remove")
	s.insert("__managed_mem_set_byte")
	s.insert("__managed_mem_grow")
	s.insert("__managed_mem_set_length")
	s.insert("__managed_mem_shift_right")
	s.insert("__managed_mem_shift_left")
	s.insert("__managed_mem_append")
	s.insert("__managed_mem_clear")
	// Managed-list mutations.
	s.insert("__managed_list_reinsert_first")
	s.insert("__managed_list_reinsert_last")
	s.insert("__managed_list_reinsert_after")
	s.insert("__managed_list_reinsert_before")
	return s
end 'buildImpureCalleeSet'

// Did `func`'s body contain any op that makes it directly impure?
// Inspects each op for the impurity shapes called out in C# PurityAnalysisPass:
//   - globalStore: mutates a top-level `var`.
//   - selfFieldStore: writes `self.x = ...` inside an instance method.
//     The C# bootstrap detects this via a separate ParameterMutationAnalysis
//     pass; self-hosted infers it from the op directly because every
//     self-field write lowers to this dedicated op.
//   - rangeCheckPanic: routes to a runtime call that aborts.
//   - call/tryCall whose callee is in the impure-callee set OR has the
//     `mrt_` runtime prefix.
function isFunctionDirectlyImpure(module MaxonModule, func IrFunction, impureCallees ImpureCalleeSet) returns bool
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("isFunctionDirectlyImpure: blockRef {blockRef} OOB")
		for opIdx in block.opRefs 'eachOp'
			let op = try module.ops.get(opIdx) otherwise panic("isFunctionDirectlyImpure: opIdx OOB")
			if isOpDirectlyImpure(op, impureCallees: impureCallees) 'impure'
				return true
			end 'impure'
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("isFunctionDirectlyImpure: termIdx OOB")
			if isOpDirectlyImpure(termOp, impureCallees: impureCallees) 'termImpure'
				return true
			end 'termImpure'
		end 'hasTerm'
	end 'eachBlock'
	return false
end 'isFunctionDirectlyImpure'

function isOpDirectlyImpure(op MaxonOp, impureCallees ImpureCalleeSet) returns bool
	// globalStore — every `topLevelVar = expr` reassignment.
	if op.name == "globalStore" 'isGlobalStore'
		return true
	end 'isGlobalStore'
	// selfFieldStore — `self.x = expr` inside a method. Treated as
	// param-mutation (the receiver is the implicit `self` param).
	if op.name == "selfFieldStore" 'isSelfStore'
		return true
	end 'isSelfStore'
	// Any call/tryCall to a known impure callee. Extract the callee bytes
	// first; the call/tryCall match expressions can't carry side-effecting
	// `return`s in `gives`-arms, so the helper makes the shape destructure
	// non-conditional.
	let calleeName = calleeNameFromOp(op)
	if calleeName == "" 'noCallee'
		return false
	end 'noCallee'
	return calleeIsImpure(calleeName, impureCallees: impureCallees)
end 'isOpDirectlyImpure'

// Return the callee name from a call/tryCall op, or "" for any other op.
// Used by both the direct-impurity and the call-edge collection passes.
function calleeNameFromOp(op MaxonOp) returns String
	if op.name == "call" 'isCall'
		return match op 'callShape'
			call(_, callee, _, _, _, _, _, _) gives String.from(callee)
			default panic("calleeNameFromOp: op.name == call but match failed")
		end 'callShape'
	end 'isCall'
	if op.name == "tryCall" 'isTryCall'
		return match op 'tryCallShape'
			tryCall(_, callee, _, _, _, _, _, _, _) gives String.from(callee)
			default panic("calleeNameFromOp: op.name == tryCall but match failed")
		end 'tryCallShape'
	end 'isTryCall'
	return ""
end 'calleeNameFromOp'

// True when the unqualified callee name is in the static impure list OR
// has the `mrt_` runtime prefix (every runtime helper is a side-effect).
function calleeIsImpure(callee String, impureCallees ImpureCalleeSet) returns bool
	if impureCallees.contains(callee) 'inSet'
		return true
	end 'inSet'
	// `mrt_*` callees are runtime helpers — all considered impure.
	if callee.startsWith("mrt_") 'isRuntime'
		return true
	end 'isRuntime'
	return false
end 'calleeIsImpure'

// Caller→callees index for the transitive propagation. Keyed on the
// qualified caller name; the value is the list of bare or qualified callee
// names found in that caller's body. Edges are collected from every
// call/tryCall op (statically-resolvable or not — the callee string at
// this stage may be unqualified, but two calls to the same unqualified
// name compose the same edge, which is harmless for purity propagation).
typealias FuncNameArray = Array with String
typealias CallerEdgeMap = Map with (String, FuncNameArray)

function buildCalleeEdges(module MaxonModule) returns CallerEdgeMap
	var edges = CallerEdgeMap.create()
	for func in module.functions 'eachFunc'
		var callees = FuncNameArray.create()
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("buildCalleeEdges: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("buildCalleeEdges: opIdx OOB")
				collectCalleeName(op, calleesOut: callees)
			end 'eachOp'
			if block.hasTerminatorOp() 'hasTerm'
				let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("buildCalleeEdges: termIdx OOB")
				collectCalleeName(termOp, calleesOut: callees)
			end 'hasTerm'
		end 'eachBlock'
		edges.upsert(func.name, value: callees)
	end 'eachFunc'
	return edges
end 'buildCalleeEdges'

function collectCalleeName(op MaxonOp, calleesOut FuncNameArray)
	let name = calleeNameFromOp(op)
	if name != "" 'hasName'
		calleesOut.push(name)
	end 'hasName'
end 'collectCalleeName'

export function computePurity(project Project, module MaxonModule)
	let impureCallees = buildImpureCalleeSet()

	// Step 1: direct-impurity classification. Default `isPure: true` (from
	// IrFunction.create); flip to false on any disqualifying condition.
	// Iteration is by-index so we can mutate the entry in place.
	let funcCount = module.functions.count()
	var i = 0
	while i < funcCount 'directScan'
		var func = try module.functions.get(i) otherwise panic("computePurity: functions.get OOB at {i}")
		// Void return: function exists only for its effects → impure.
		let isVoid = match func.maxonReturnType 'rt'
			void gives true
			value gives false
		end 'rt'
		if isVoid 'isVoid'
			func.isPure = false
			try module.functions.set(i, value: func) otherwise panic("computePurity: functions.set OOB at {i}")
			i = i + 1
			continue
		end 'isVoid'
		// Empty body — restored stdlib intrinsics with no IR, declarations
		// only. Treat as impure conservatively.
		if func.blockRefs.count() == 0 'emptyBody'
			func.isPure = false
			try module.functions.set(i, value: func) otherwise panic("computePurity: functions.set OOB at {i}")
			i = i + 1
			continue
		end 'emptyBody'
		// Parser-tagged parameter mutation (direct reassignment of a param,
		// or self-field-store inside an instance method). The C# bootstrap
		// computes this in a separate ParameterMutationAnalysis pass; self-
		// hosted records it at the assignment site in the parser.
		if project.paramMutatingFunctions.contains(func.name) 'mutatesParam'
			func.isPure = false
			try module.functions.set(i, value: func) otherwise panic("computePurity: functions.set OOB at {i}")
			i = i + 1
			continue
		end 'mutatesParam'
		if isFunctionDirectlyImpure(module, func: func, impureCallees: impureCallees) 'directlyImpure'
			func.isPure = false
			try module.functions.set(i, value: func) otherwise panic("computePurity: functions.set OOB at {i}")
		end 'directlyImpure'
		i = i + 1
	end 'directScan'

	// Step 2: transitive propagation. Build callee edges per function, then
	// walk: any function calling an impure function becomes impure. Iterate
	// to fixed point.
	let edges = buildCalleeEdges(module)
	var changed = true
	while changed 'propagate'
		changed = false
		var j = 0
		while j < funcCount 'eachCaller'
			var caller = try module.functions.get(j) otherwise panic("computePurity: caller.get OOB at {j}")
			if not caller.isPure 'alreadyImpure'
				j = j + 1
				continue
			end 'alreadyImpure'
			let callees = try edges.get(caller.name) otherwise FuncNameArray.create()
			var becameImpure = false
			for callee in callees 'eachCallee'
				if callee == caller.name 'selfCall'
					continue
				end 'selfCall'
				if calleeIsImpure(callee, impureCallees: impureCallees) 'directImp'
					becameImpure = true
					break
				end 'directImp'
				// Resolve the callee name against module functions. The
				// callee field may be bare or qualified — try direct match
				// first, then qualified-with-caller-namespace.
				let calleePure = lookupCalleePurity(module, calleeName: callee, callerNamespace: caller.namespace, impureCallees: impureCallees)
				if not calleePure 'isImpure'
					becameImpure = true
					break
				end 'isImpure'
			end 'eachCallee'
			if becameImpure 'flip'
				caller.isPure = false
				try module.functions.set(j, value: caller) otherwise panic("computePurity: caller.set OOB at {j}")
				changed = true
			end 'flip'
			j = j + 1
		end 'eachCaller'
	end 'propagate'
end 'computePurity'

// Look up a callee's purity by name. Resolves bare names against the
// caller's namespace and falls back to a direct match. The stdlib I/O
// family (`print` / `printError` / `readLine`) and direct-impure callees
// are flagged regardless of whether the callee is in `module.functions`.
// `unresolvedDefault` controls what to return when the callee isn't found
// in `module.functions`: the propagation pass (`computePurity`) defaults
// to `true` because the body might be a pure stdlib helper; the report
// pass (`checkDiscardedResults`) defaults to `false` so unresolved callees
// don't fire false-positive E3064s and instead route to the E3065 path
// when bare-discarded.
function lookupCalleePurity(module MaxonModule, calleeName String, callerNamespace String, impureCallees ImpureCalleeSet) returns bool
	return lookupCalleePurityImpl(module, calleeName: calleeName, callerNamespace: callerNamespace, impureCallees: impureCallees, unresolvedDefault: true)
end 'lookupCalleePurity'

function lookupCalleePurityImpl(module MaxonModule, calleeName String, callerNamespace String, impureCallees ImpureCalleeSet, unresolvedDefault bool) returns bool
	// Stdlib I/O entrypoint or runtime helper — always impure even when
	// the body isn't in this MaxonModule.
	if calleeIsImpure(calleeName, impureCallees: impureCallees) 'isStdlibImpure'
		return false
	end 'isStdlibImpure'
	if calleeName == "print" or calleeName == "printError" or calleeName == "readLine" 'isPrintFamily'
		return false
	end 'isPrintFamily'
	for func in module.functions 'each'
		if func.name == calleeName 'directHit'
			return func.isPure
		end 'directHit'
		// Namespace-qualified: `{namespace}.{bare}` for free functions in
		// the same module.
		if callerNamespace != "" 'hasNs'
			let qualified = "{callerNamespace}.{calleeName}"
			if func.name == qualified 'qualifiedHit'
				return func.isPure
			end 'qualifiedHit'
		end 'hasNs'
	end 'each'
	return unresolvedDefault
end 'lookupCalleePurityImpl'

// --------------------------------------------------------------------------
// Phase 15a: discarded-results check (E3064 / E3065). Mirrors
// SemanticCheckPass.CheckDiscardedResults in the C# bootstrap.
//
// Walks every call/tryCall op in every function. If the op's result name is
// in `project.discardedBareCallResults` or `discardedLetCallResults`, the
// callee was discarded at parse time. The fired diagnostic depends on the
// callee's purity (computed above) and the discard form:
//
//   - Pure callee + any discard form → E3064 "result of pure function 'X' must be used"
//   - Impure callee + bare discard → E3065 "result of 'X' is not used (use '_ = expr' to discard)"
//   - Impure callee + `_=` discard → silent (the discard is the user's opt-in)
//
// Chainable methods (1st param `self`, return type matches receiver) are
// exempt from both diagnostics — builder-pattern discards are valid.
// --------------------------------------------------------------------------

// ============================================================
// E3005 argument-type validation
// ============================================================
//
// Walks every user-function call op and checks each argument's parser-inferred
// type against the resolved parameter type stashed in `project.callParamTypes`.
// Runs at semantic-check time (before DFE, before the discarded-result lint) so
// type errors in dead/unreached code are caught and the E3005 surfaces ahead of
// the E3064/E3065 discarded-result lint on the same call.
//
// The compatibility predicate mirrors lowering's `coerceArgToParam` for
// primitives (cast-category equality + implicit conversions) and ADDS the
// element-type comparison lowering lacks: two generic collections of the same
// base are compatible only when their element args are pairwise compatible, so
// `IntArray.append(StringArray)` is rejected. Conservative everywhere a type is
// unresolved / a type parameter / an interface / a bare base collection (a
// `Self` param whose substitution dropped the element) — those defer to
// lowering and never produce a false E3005.
export function checkCallArgumentTypes(project Project, module MaxonModule)
	for func in module.functions 'eachFunc'
		if isStdlibFunctionPath(func.sourceFilePath) 'isStdlib'
			continue
		end 'isStdlib'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkCallArgumentTypes: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("checkCallArgumentTypes: opIdx OOB")
				checkOneCallArgs(project, op: op, opIdx: opIdx, callerName: func.name, readerFilePath: func.sourceFilePath)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'checkCallArgumentTypes'

// One call op. The receiver offset is 1 for method calls (param 0 is the
// implicit receiver, which has no user-arg) and 0 for plain calls.
function checkOneCallArgs(project Project, op MaxonOp, opIdx OpIndex, callerName String, readerFilePath FilePath)
	if op.name == "call" 'isCall'
		match op 'c'
			call(result, _, _, args, _, argTypes, argRanges, _) then validateCallArgs(project, opIdx: opIdx, result: result, args: args, argTypes: argTypes, argRanges: argRanges, paramOffset: 0, callerName: callerName, readerFilePath: readerFilePath)
			default panic("checkOneCallArgs: op.name == call but match failed")
		end 'c'
		return
	end 'isCall'
	if op.name == "tryCall" 'isTryCall'
		match op 'tc'
			tryCall(result, _, _, args, _, argTypes, argRanges, _, _) then validateCallArgs(project, opIdx: opIdx, result: result, args: args, argTypes: argTypes, argRanges: argRanges, paramOffset: 0, callerName: callerName, readerFilePath: readerFilePath)
			default panic("checkOneCallArgs: op.name == tryCall but match failed")
		end 'tc'
		return
	end 'isTryCall'
	if op.name == "methodCall" 'isMethodCall'
		match op 'mc'
			methodCall(result, _, _, args, _, argTypes, argRanges, _) then validateCallArgs(project, opIdx: opIdx, result: result, args: args, argTypes: argTypes, argRanges: argRanges, paramOffset: 1, callerName: callerName, readerFilePath: readerFilePath)
			default panic("checkOneCallArgs: op.name == methodCall but match failed")
		end 'mc'
		return
	end 'isMethodCall'
	if op.name == "tryMethodCall" 'isTryMethodCall'
		match op 'tmc'
			tryMethodCall(result, _, _, args, _, argTypes, argRanges, _, _) then validateCallArgs(project, opIdx: opIdx, result: result, args: args, argTypes: argTypes, argRanges: argRanges, paramOffset: 1, callerName: callerName, readerFilePath: readerFilePath)
			default panic("checkOneCallArgs: op.name == tryMethodCall but match failed")
		end 'tmc'
	end 'isTryMethodCall'
end 'checkOneCallArgs'

function validateCallArgs(project Project, opIdx OpIndex, result ByteArray, args ByteArrayArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, paramOffset ArgIndex, callerName String, readerFilePath FilePath)
	let paramTypes = try project.callParamTypes.get(opIdx) otherwise return
	let paramNames = paramNamesForCall(project, opIdx: opIdx)

	// `__Builtins.*` runtime intrinsics report argument mismatches in the
	// runtime-symbol form ("type mismatch: __Builtins.maxon_x argument N
	// expects 'cstring' but got 'ByteMemory'") rather than the param-name
	// form — the runtime, not a Maxon signature, owns the contract. Route
	// these through the dedicated checker and skip the generic loop so we
	// don't emit both messages for one bad argument.
	if validateBuiltinsIntrinsicArgs(project, opIdx: opIdx, result: result, args: args, argTypes: argTypes, argRanges: argRanges, paramOffset: paramOffset, paramTypes: paramTypes, callerName: callerName, readerFilePath: readerFilePath) 'wasBuiltins'
		return
	end 'wasBuiltins'

	for i in 0 upto args.count() 'eachArg'
		let pIdx = i + paramOffset
		if pIdx >= paramTypes.count() 'paramOob'
			continue
		end 'paramOob'
		let rawParamType = try paramTypes.get(pIdx) otherwise continue
		let paramType = refineSelfParam(project, opIdx: opIdx, paramType: rawParamType, paramOffset: paramOffset)
		let argType = try argTypes.get(i) otherwise continue
		if argTypesCompatible(project, argType: argType, paramType: paramType) 'ok'
			continue
		end 'ok'
		let paramName = paramNameAt(paramNames, index: pIdx)
		let range = try argRanges.get(i) otherwise SourceRange.none()
		let expectedName = endpointName(project, t: paramType, other: argType)
		let gotName = endpointName(project, t: argType, other: paramType)
		reportArgTypeMismatch(project, message: "argument type mismatch for '{paramName}': expected '{expectedName}', got '{gotName}'", range: range, result: result, callerName: callerName, readerFilePath: readerFilePath)
	end 'eachArg'
end 'validateCallArgs'

// Record an E3005 for one bad call argument and flag the enclosing call so the
// discard lint suppresses E3064/E3065 on it. A more specific checker (e.g. the
// parser's `fromRawValue` literal-arg validation) may already have reported an
// E3005 at this exact location — in that case skip the message but still record
// the arg error so the call is recognized as already-flagged.
function reportArgTypeMismatch(project Project, message String, range SourceRange, result ByteArray, callerName String, readerFilePath FilePath)
	if not hasTypeMismatchDiagnosticAt(project, filePath: readerFilePath, line: range.line, column: range.column) 'notYetReported'
		reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: message, line: range.line, column: range.column, filePath: readerFilePath)
	end 'notYetReported'
	if result.count() > 0 'haveResult'
		project.callsWithArgErrors.insert("{callerName}::{String.from(result)}")
	end 'haveResult'
end 'reportArgTypeMismatch'

// True when an E3005 (type-mismatch) diagnostic has already been recorded at
// this exact file/line/column — used to suppress a redundant generic E3005 on
// an argument a more specific checker already flagged.
function hasTypeMismatchDiagnosticAt(project Project, filePath FilePath, line LineNumber, column ColumnNumber) returns bool
	for d in project.diagnostics 'each'
		if d.code.rawValue == ErrorCode.semanticTypeMismatch.rawValue and d.line == line and d.column == column and d.filePath == filePath 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'hasTypeMismatchDiagnosticAt'

// E3005 for `__Builtins.*` runtime intrinsics, in the runtime-symbol message
// form the bootstrap uses (`CheckRuntimeArgType`/`FailArgType` in
// maxon-sharp/Compiler/2-Parser.cs). Returns true iff the resolved callee is a
// `__Builtins.*` intrinsic with a runtime symbol — the generic checker then
// skips the call. The expected type is named at the runtime level (`i64` for an
// `integer` param, `cstring`, or the bare `__ManagedMemory` struct name); the
// actual type uses its source display (so a `ByteMemory` arg reads "ByteMemory",
// an int reads "int", a cstring reads "cstring").
function validateBuiltinsIntrinsicArgs(project Project, opIdx OpIndex, result ByteArray, args ByteArrayArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, paramOffset ArgIndex, paramTypes MaxonTypeArray, callerName String, readerFilePath FilePath) returns bool
	let callee = try project.resolvedCallees.get(opIdx) otherwise return false
	if not callee.startsWith("__Builtins.") 'notBuiltins'
		return false
	end 'notBuiltins'
	let dotIdx = try callee.findFirst(".") otherwise return false
	let afterDot = try callee.indexAfter(dotIdx) otherwise return false
	let methodName = callee.slice(afterDot, endIndex: callee.endIndex())
	// Reuse lowering's authoritative method→runtime-symbol table so the error
	// message and the emitted runtime call name agree. Intrinsics with no
	// runtime symbol (e.g. the bespoke `writeStdout`) miss here and fall back
	// to the generic param-name diagnostic.
	let hit = try lookupSubprocessBuiltin(methodName) otherwise return false
	let runtimeName = hit.callee

	for i in 0 upto args.count() 'eachArg'
		let pIdx = i + paramOffset
		if pIdx >= paramTypes.count() 'paramOob'
			continue
		end 'paramOob'
		let paramType = try paramTypes.get(pIdx) otherwise continue
		let argType = try argTypes.get(i) otherwise continue
		if argTypesCompatible(project, argType: argType, paramType: paramType) 'ok'
			continue
		end 'ok'
		let range = try argRanges.get(i) otherwise SourceRange.none()
		let expectedName = builtinsExpectedTypeName(project, t: paramType)
		let gotName = sourceTypeDisplay(project, t: argType)
		reportArgTypeMismatch(project, message: "type mismatch: __Builtins.{runtimeName} argument {i} expects '{expectedName}' but got '{gotName}'", range: range, result: result, callerName: callerName, readerFilePath: readerFilePath)
	end 'eachArg'
	return true
end 'validateBuiltinsIntrinsicArgs'

// Runtime-level name for a `__Builtins.*` intrinsic param type, matching the
// strings the bootstrap declares in its `CompilerBuiltins` table: an `integer`
// param is `i64`, `cstring` stays `cstring`, and a managed-memory param keeps
// its bare `__ManagedMemory` name. Anything else falls back to its source name.
function builtinsExpectedTypeName(project Project, t MaxonType) returns String
	return match t 'k'
		integer gives "i64"
		cstring gives "cstring"
		boolean gives sourceTypeDisplay(project, t: t)
		float to opaquePointer gives sourceTypeDisplay(project, t: t)
	end 'k'
end 'builtinsExpectedTypeName'

// A `Self`-typed parameter substitutes to the bare base collection (`Array`)
// when the receiver's element type is dropped during substitution. Refine it
// back to the receiver's concrete type (`Array with Int`) so element mismatches
// are caught and the diagnostic names the receiver's alias. Only applies to
// method calls whose param is a bare base collection and whose recorded
// receiver type is a generic instance of the same base.
function refineSelfParam(project Project, opIdx OpIndex, paramType MaxonType, paramOffset ArgIndex) returns MaxonType
	if paramOffset == 0 'notMethodCall'
		return paramType
	end 'notMethodCall'
	if not isBaseCollectionNamed(project, t: paramType) 'notBareBase'
		return paramType
	end 'notBareBase'
	let receiverType = try project.resolvedReceiverTypes.get(opIdx) otherwise return paramType
	let recv = resolveAliasForCompare(project, t: receiverType)
	if not maxonTypeIsGenericInstance(recv) 'recvNotGeneric'
		return paramType
	end 'recvNotGeneric'
	let paramBase = paramType.namedAliasNameOrEmpty(project)
	if collectionBaseName(project, t: recv) != paramBase 'baseMismatch'
		return paramType
	end 'baseMismatch'
	return recv
end 'refineSelfParam'

function paramNamesForCall(project Project, opIdx OpIndex) returns StringArray
	let callee = try project.resolvedCallees.get(opIdx) otherwise return StringArray.create()
	let sig = try project.funcSignatures.get(callee) otherwise return StringArray.create()
	return sig.paramNames
end 'paramNamesForCall'

function paramNameAt(paramNames StringArray, index ArgIndex) returns String
	return try paramNames.get(index) otherwise ""
end 'paramNameAt'

// True when an argument of `argType` may flow into a parameter of `paramType`.
// Returns true (compatible) for everything not provably wrong, so the check
// never adds a false E3005.
function argTypesCompatible(project Project, argType MaxonType, paramType MaxonType) returns bool
	if isUnresolvedType(argType) or isUnresolvedType(paramType) 'unresolved'
		return true
	end 'unresolved'
	if argEndpointIsDynamic(argType) or argEndpointIsDynamic(paramType) 'dynamic'
		return true
	end 'dynamic'
	let arg = resolveAliasForCompare(project, t: argType)
	let param = resolveAliasForCompare(project, t: paramType)
	if argEndpointIsDynamic(arg) or argEndpointIsDynamic(param) 'dynamicResolved'
		return true
	end 'dynamicResolved'
	// Lowering's char-byte → Character coercion: a single-byte char literal is
	// typed `int` on the fast path but legitimately initializes a `Character`
	// param. `coerceArgToParam` accepts it via a runtime materialization.
	if isIntType(arg) and namedTypeIs(project, t: param, name: "Character") 'charByte'
		return true
	end 'charByte'
	// Synthesized union companion types (`<Union>.unionCases`) interact with
	// their union in compiler-generated code in ways the surface type check
	// shouldn't second-guess. Defer to lowering.
	if isUnionCasesCompanion(project, t: arg) or isUnionCasesCompanion(project, t: param) 'unionCases'
		return true
	end 'unionCases'

	let argGeneric = maxonTypeIsGenericInstance(arg)
	let paramGeneric = maxonTypeIsGenericInstance(param)
	let argBaseColl = isBaseCollectionNamed(project, t: arg)
	let paramBaseColl = isBaseCollectionNamed(project, t: param)

	// Bare-named-vs-generic of the same base: a parameter declared as a bare
	// non-collection type (`node __ManagedListNode`) accepts an argument that is
	// a generic instance of that same base (`__ManagedListNode with Item`), and
	// vice versa. The bare side carries no element binding to compare against,
	// so this admits ANY same-base bare↔generic pair without element checking —
	// the conservative (compatible) choice consistent with the rest of this
	// predicate, since a bare param that dropped its element legitimately cannot
	// constrain the element. The motivating case is node-returning managed-list
	// methods (`insertFirst` → `__ManagedListNode with Item`) flowing into
	// `remove(node __ManagedListNode)`. Gated to non-collection bases so genuine
	// collections (Array/Map/Set/List/Vector) keep their element-arg checking in
	// `collectionEndpointsCompatible` below.
	if not argBaseColl and not paramBaseColl 'maybeBareGenericPair'
		if argGeneric and isNamedNonCollection(project, t: param) and collectionBaseName(project, t: arg) == param.namedAliasNameOrEmpty(project) 'argGenericParamBare'
			return true
		end 'argGenericParamBare'
		if paramGeneric and isNamedNonCollection(project, t: arg) and collectionBaseName(project, t: param) == arg.namedAliasNameOrEmpty(project) 'paramGenericArgBare'
			return true
		end 'paramGenericArgBare'
	end 'maybeBareGenericPair'

	// Collection endpoints (a generic instance, or a bare base-collection name
	// from a `Self` param whose substitution dropped the element type).
	if argGeneric or paramGeneric or argBaseColl or paramBaseColl 'collectionInvolved'
		return collectionEndpointsCompatible(project, arg: arg, param: param, argGeneric: argGeneric, paramGeneric: paramGeneric, argBaseColl: argBaseColl, paramBaseColl: paramBaseColl)
	end 'collectionInvolved'

	// Two named struct / enum types: compatible only when their names match.
	let argStruct = namedStructOrEnumName(project, t: arg)
	let paramStruct = namedStructOrEnumName(project, t: param)
	if not argStruct.isEmpty() and not paramStruct.isEmpty() 'bothNamed'
		return argStruct == paramStruct
	end 'bothNamed'
	if argStruct.isEmpty() != paramStruct.isEmpty() 'oneNamed'
		return false
	end 'oneNamed'

	// Primitives: lowering's rule — same cast category, or an implicit
	// conversion bridges them.
	let argCat = convertCastCategory(project, t: arg)
	let paramCat = convertCastCategory(project, t: param)
	if argCat == paramCat 'sameCat'
		return true
	end 'sameCat'
	return implicitlyConvertible(argCat, to: paramCat)
end 'argTypesCompatible'

// Compatibility for a pair where at least one side is a collection (generic
// instance or bare base-collection name).
function collectionEndpointsCompatible(project Project, arg MaxonType, param MaxonType, argGeneric bool, paramGeneric bool, argBaseColl bool, paramBaseColl bool) returns bool
	// A non-collection on the other side is always incompatible (e.g. passing
	// an `int` where an `Array` is expected).
	if not (argGeneric or argBaseColl) 'argNotColl'
		return false
	end 'argNotColl'
	if not (paramGeneric or paramBaseColl) 'paramNotColl'
		return false
	end 'paramNotColl'
	// A bare base-collection on either side carries no element to compare —
	// a `Self` param that lost its element accepts any same-base collection.
	// Compare base names when both are concrete generic instances; treat a
	// bare base as a wildcard for its base.
	let argBase = collectionBaseName(project, t: arg)
	let paramBase = collectionBaseName(project, t: param)
	if argBase != paramBase 'differentBase'
		return false
	end 'differentBase'
	if argBaseColl or paramBaseColl 'eitherBare'
		return true
	end 'eitherBare'
	// Both concrete generic instances of the same base: element args must be
	// pairwise compatible (recursive — so `Integer` ≈ `int` inside a `Map`).
	return genericArgsCompatible(project, arg: arg, param: param)
end 'collectionEndpointsCompatible'

// Pairwise-compatible element args of two same-base generic instances.
function genericArgsCompatible(project Project, arg MaxonType, param MaxonType) returns bool
	let argArgs = genericInstanceArgsOf(project, t: arg)
	let paramArgs = genericInstanceArgsOf(project, t: param)
	if argArgs.count() != paramArgs.count() 'arity'
		return false
	end 'arity'
	for i in 0 upto argArgs.count() 'eachElem'
		let a = try argArgs.get(i) otherwise panic("genericArgsCompatible: argArgs.get OOB after arity check")
		let p = try paramArgs.get(i) otherwise panic("genericArgsCompatible: paramArgs.get OOB after arity check")
		if not argTypesCompatible(project, argType: a, paramType: p) 'mismatch'
			return false
		end 'mismatch'
	end 'eachElem'
	return true
end 'genericArgsCompatible'

function genericInstanceArgsOf(project Project, t MaxonType) returns MaxonTypeArray
	return match t 'k'
		genericInstance(id) gives genericInstanceArgsById(project, id: id)
		boolean to typeParameter gives MaxonTypeArray.create()
		interface to cstring gives MaxonTypeArray.create()
	end 'k'
end 'genericInstanceArgsOf'

function genericInstanceArgsById(project Project, id GenericInstanceId) returns MaxonTypeArray
	let (_, args) = project.genericInstances.get(id)
	return args
end 'genericInstanceArgsById'

// Base name of a collection endpoint: the generic instance's base, or the bare
// collection name itself.
function collectionBaseName(project Project, t MaxonType) returns String
	return match t 'k'
		boolean to string gives ""
		named(id) gives project.typeNames.get(id)
		function to typeParameter gives ""
		genericInstance(id) gives genericInstanceIdBaseName(project, id: id)
		interface to cstring gives ""
	end 'k'
end 'collectionBaseName'

// True when `t` is a bare `named(...)` whose name is a known collection base
// (`Array`/`Map`/…) — the shape a `Self` param collapses to when substitution
// dropped the element type. Distinct from a struct/enum named type.
function isBaseCollectionNamed(project Project, t MaxonType) returns bool
	let name = t.namedAliasNameOrEmpty(project)
	if name.isEmpty() 'notNamed'
		return false
	end 'notNamed'
	return name == "Array" or name == "Map" or name == "Set" or name == "List" or name == "Vector"
end 'isBaseCollectionNamed'

// True when `t` is a bare `named(X)` that is not one of the base collection
// names — i.e. a plain builtin / user struct name carrying no element binding,
// such as `__ManagedListNode`. Used by `argTypesCompatible` to accept a
// generic instance of the same base flowing into a bare-named parameter.
function isNamedNonCollection(project Project, t MaxonType) returns bool
	if not maxonTypeIsNamed(t) 'notNamed'
		return false
	end 'notNamed'
	if isBaseCollectionNamed(project, t: t) 'isCollection'
		return false
	end 'isCollection'
	return not t.namedAliasNameOrEmpty(project).isEmpty()
end 'isNamedNonCollection'

function isIntType(t MaxonType) returns bool
	return match t 'k'
		integer gives true
		boolean gives false
		float to cstring gives false
	end 'k'
end 'isIntType'

// True when `t` is a `named(...)` whose source name is `name`.
function namedTypeIs(project Project, t MaxonType, name String) returns bool
	return t.namedAliasNameOrEmpty(project) == name
end 'namedTypeIs'

// True for a synthesized `<Union>.unionCases` companion type the parser emits
// for every union; comparisons involving it are compiler bookkeeping.
function isUnionCasesCompanion(project Project, t MaxonType) returns bool
	return t.namedAliasNameOrEmpty(project).endsWith(".unionCases")
end 'isUnionCasesCompanion'

// True for type-parameter or interface endpoints — dynamic shapes deferred to
// lowering. Reuses the exported `maxonTypeIsTypeParameter`.
function argEndpointIsDynamic(t MaxonType) returns bool
	if maxonTypeIsTypeParameter(t) 'isParam'
		return true
	end 'isParam'
	return match t 'k'
		interface gives true
		boolean to genericInstance gives false
		constInt to cstring gives false
	end 'k'
end 'argEndpointIsDynamic'

// Chase a `named(alias)` to its resolved generic-instance form when the alias
// is a registered generic typealias (`ItemArray = Array with Item`), so an
// alias-spelled arg and a resolved param of the same type don't look different.
function resolveAliasForCompare(project Project, t MaxonType) returns MaxonType
	let name = t.namedAliasNameOrEmpty(project)
	if name.isEmpty() 'notNamed'
		return t
	end 'notNamed'
	return try project.genericTypealiases.get(name) otherwise t
end 'resolveAliasForCompare'

// The struct/enum name a `named(...)` type refers to, or "" for a primitive
// (ranged-int / float / bool) alias, a collection base, or a non-named type.
function namedStructOrEnumName(project Project, t MaxonType) returns String
	let name = t.namedAliasNameOrEmpty(project)
	if name.isEmpty() 'notNamed'
		return ""
	end 'notNamed'
	if project.structTypes.contains(name) or project.enumTypes.contains(name) 'isStructOrEnum'
		return name
	end 'isStructOrEnum'
	return ""
end 'namedStructOrEnumName'

// Display name for one E3005 endpoint, matching lowering's `mismatchTypeName`
// rule: when BOTH endpoints are primitive numeric/bool families, print the base
// category name (`int`/`float`/`bool`) so the message doesn't restate a
// typealias the caller didn't write; otherwise print the source-level name —
// preferring a user typealias for a resolved generic instance (`StringArray`
// for `Array with String`) over the structural spelling.
function endpointName(project Project, t MaxonType, other MaxonType) returns String
	if isGenuinePrimitive(project, t: t) and isGenuinePrimitive(project, t: other) 'bothPrimitive'
		return castCategoryName(convertCastCategory(project, t: t))
	end 'bothPrimitive'
	return sourceTypeDisplay(project, t: t)
end 'endpointName'

// True for a genuine scalar primitive — a bare `boolean`/`integer`/`float`/
// `string` MaxonType, or a `named(...)` alias that resolves to a ranged
// numeric/bool primitive (`Integer = int(...)`). NOT a struct, enum, or
// collection (those collapse to `CastCategory.int` at the Std level but must
// keep their source name in diagnostics).
function isGenuinePrimitive(project Project, t MaxonType) returns bool
	return match t 'k'
		boolean gives true
		integer gives true
		float gives true
		string gives true
		named(id) gives namedIsPrimitiveAlias(project, name: project.typeNames.get(id))
		function to cstring gives false
	end 'k'
end 'isGenuinePrimitive'

// A `named(name)` is a primitive alias when it's a registered typealias that is
// neither a struct/enum nor a generic (collection) alias — i.e. a ranged
// numeric / bool alias like `Integer` or `Score`.
function namedIsPrimitiveAlias(project Project, name String) returns bool
	if project.structTypes.contains(name) or project.enumTypes.contains(name) 'isStructEnum'
		return false
	end 'isStructEnum'
	if project.genericTypealiases.contains(name) 'isGeneric'
		return false
	end 'isGeneric'
	return project.typealiases.contains(name)
end 'namedIsPrimitiveAlias'

// Source-level display: a resolved generic instance maps back to a user alias
// when one exists; everything else prints its own `toString`.
function sourceTypeDisplay(project Project, t MaxonType) returns String
	if maxonTypeIsGenericInstance(t) 'generic'
		let alias = aliasNameForGenericType(project, t: t)
		if not alias.isEmpty() 'haveAlias'
			return alias
		end 'haveAlias'
	end 'generic'
	return t.toString(project)
end 'sourceTypeDisplay'

// A user typealias whose resolved type is structurally `t`. Prefers a bare,
// non-namespaced name (`StringArray`) over a stdlib-qualified one. Empty when
// no alias matches (e.g. an inline `Array with X`).
function aliasNameForGenericType(project Project, t MaxonType) returns String
	var fallback = ""
	for (name, resolved) in project.genericTypealiases 'eachAlias'
		if maxonTypesStructurallyEqual(resolved, b: t) 'match'
			if not name.contains(".") 'bareName'
				return name
			end 'bareName'
			if fallback.isEmpty() 'recordFallback'
				fallback = name
			end 'recordFallback'
		end 'match'
	end 'eachAlias'
	if not fallback.isEmpty() 'haveGlobal'
		return fallback
	end 'haveGlobal'
	// Type-scoped aliases (e.g. `ByteMemory = __ManagedMemory with Byte`
	// declared inside `String`) live in their owner's `innerAliases`, not the
	// global map. Probe those so a field of such a type names its alias
	// (`ByteMemory`) in diagnostics rather than the expanded `__ManagedMemory
	// with Byte`. Prefer the alias's bare name — inner aliases are keyed by it.
	for (_, structEntry) in project.structTypes 'eachStruct'
		for (aliasName, resolved) in structEntry.innerAliases 'eachInner'
			if maxonTypesStructurallyEqual(resolved, b: t) 'innerMatch'
				return aliasName
			end 'innerMatch'
		end 'eachInner'
	end 'eachStruct'
	return ""
end 'aliasNameForGenericType'

export function checkDiscardedResults(project Project, module MaxonModule)
	// Short-circuit if the parser never tagged any discards. Avoids the
	// per-function walk on the common all-results-used case.
	if project.discardedBareCallResults.count() == 0 and project.discardedLetCallResults.count() == 0 'noTags'
		return
	end 'noTags'
	let impureCallees = buildImpureCalleeSet()
	for func in module.functions 'eachFunc'
		// Skip stdlib functions: the discarded-results lint is for user code
		// only. Stdlib internals reuse `_ =` patterns and bare statement-
		// position calls in ways that don't fit the user-facing spec; cache-
		// parity tests would otherwise diverge between the cache-off path
		// (which re-parses stdlib and re-runs this check) and the cache-on
		// path (which restores stdlib without re-running the check).
		if isStdlibFunctionPath(func.sourceFilePath) 'isStdlib'
			continue
		end 'isStdlib'
		let readerFilePath = func.sourceFilePath
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("checkDiscardedResults: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("checkDiscardedResults: opIdx OOB")
				checkOneCallForDiscard(project, module: module, opIdx: opIdx, op: op, callerName: func.name, callerNamespace: func.namespace, readerFilePath: readerFilePath, impureCallees: impureCallees)
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
end 'checkDiscardedResults'

// True when `path` points at a stdlib source file (bootstrap or any of the
// whitelisted `stdlib/*.maxon` files). Used to keep the discarded-results
// check (and other user-only diagnostics) from firing on stdlib internals.
export function isStdlibFunctionPath(path FilePath) returns bool
	let s = path.toString()
	if s == "stdlib-bootstrap.maxon" 'isBootstrap'
		return true
	end 'isBootstrap'
	// Any path containing `stdlib/` (or `stdlib\` on Windows) is stdlib.
	return s.contains("stdlib/") or s.contains("stdlib\\")
end 'isStdlibFunctionPath'

function checkOneCallForDiscard(project Project, module MaxonModule, opIdx OpIndex, op MaxonOp, callerName String, callerNamespace String, readerFilePath FilePath, impureCallees ImpureCalleeSet)
	if op.name == "call" 'isCall'
		match op 'callShape'
			call(result, callee, _, _, _, _, _, range) then maybeReportDiscarded(project, module: module, result: result, callee: callee, callerName: callerName, callerNamespace: callerNamespace, range: range, readerFilePath: readerFilePath, impureCallees: impureCallees)
			default panic("checkOneCallForDiscard: op.name == call but match failed")
		end 'callShape'
	end 'isCall'
	if op.name == "tryCall" 'isTryCall'
		match op 'tryCallShape'
			tryCall(result, callee, _, _, _, _, _, _, range) then maybeReportDiscarded(project, module: module, result: result, callee: callee, callerName: callerName, callerNamespace: callerNamespace, range: range, readerFilePath: readerFilePath, impureCallees: impureCallees)
			default panic("checkOneCallForDiscard: op.name == tryCall but match failed")
		end 'tryCallShape'
	end 'isTryCall'
	if op.name == "methodCall" 'isMethodCall'
		match op 'methodCallShape'
			methodCall(result, _, methodName, _, _, _, _, range) then maybeReportDiscardedMethodCall(project, module: module, opIdx: opIdx, result: result, methodName: methodName, callerName: callerName, callerNamespace: callerNamespace, range: range, readerFilePath: readerFilePath, impureCallees: impureCallees)
			default panic("checkOneCallForDiscard: op.name == methodCall but match failed")
		end 'methodCallShape'
	end 'isMethodCall'
	if op.name == "tryMethodCall" 'isTryMethodCall'
		match op 'tryMethodCallShape'
			tryMethodCall(result, _, methodName, _, _, _, _, _, range) then maybeReportDiscardedMethodCall(project, module: module, opIdx: opIdx, result: result, methodName: methodName, callerName: callerName, callerNamespace: callerNamespace, range: range, readerFilePath: readerFilePath, impureCallees: impureCallees)
			default panic("checkOneCallForDiscard: op.name == tryMethodCall but match failed")
		end 'tryMethodCallShape'
	end 'isTryMethodCall'
end 'checkOneCallForDiscard'

// Method-call variant of `maybeReportDiscarded` that first exempts calls whose
// receiver is a builtin managed type (`__ManagedList`, `__ManagedListNode`,
// `__ManagedMemory`). Mirrors the C# bootstrap, which returns early after
// `TryEmitBuiltinTypeMethod` without discarded-result tracking: builtin methods
// like `__ManagedList.insertFirst` return a node/value the caller routinely
// ignores (the list holds the reference), so a bare statement-position call is
// the canonical usage, not a forgotten result. The receiver type comes from
// `resolvedReceiverTypes` (keyed by the call's opIdx, populated by
// `resolveMethodCallSite`), which covers every receiver shape — not just direct
// var/global loads.
function maybeReportDiscardedMethodCall(project Project, module MaxonModule, opIdx OpIndex, result ByteArray, methodName ByteArray, callerName String, callerNamespace String, range SourceRange, readerFilePath FilePath, impureCallees ImpureCalleeSet)
	if let receiverType = try project.resolvedReceiverTypes.get(opIdx) 'haveReceiver'
		if maxonTypeIsBuiltinManagedBase(project, t: receiverType) 'builtinReceiver'
			return
		end 'builtinReceiver'
	end 'haveReceiver'
	maybeReportDiscarded(project, module: module, result: result, callee: methodName, callerName: callerName, callerNamespace: callerNamespace, range: range, readerFilePath: readerFilePath, impureCallees: impureCallees)
end 'maybeReportDiscardedMethodCall'

// True when `t` (after chasing typealiases) is one of the builtin managed base
// types: `__ManagedList`, `__ManagedListNode`, `__ManagedMemory`. Mirrors the
// chase in `managedBuiltinBaseName` but without the parser-only inner-alias
// state, which top-level / function-scope receivers never need.
function maxonTypeIsBuiltinManagedBase(project Project, t MaxonType) returns bool
	var cur = t
	for _ in 0 upto 5 'chase'
		let name = cur.nameOrEmpty(project)
		if name.isEmpty() 'noName'
			return false
		end 'noName'
		if name == "__ManagedList" or name == "__ManagedListNode" or name == "__ManagedMemory" 'isBuiltin'
			return true
		end 'isBuiltin'
		if let aliased = try project.genericTypealiases.get(name) 'isAlias'
			cur = aliased
		end 'isAlias' else 'notAlias'
			return false
		end 'notAlias'
	end 'chase'
	return false
end 'maxonTypeIsBuiltinManagedBase'

function maybeReportDiscarded(project Project, module MaxonModule, result ByteArray, callee ByteArray, callerName String, callerNamespace String, range SourceRange, readerFilePath FilePath, impureCallees ImpureCalleeSet)
	if result.count() == 0 'noResult'
		return
	end 'noResult'
	let resultStr = String.from(result)
	let key = "{callerName}::{resultStr}"
	// A call already flagged with an argument-type error (E3005) shouldn't also
	// be reported as a discarded result — that's noise on a broken call.
	if project.callsWithArgErrors.contains(key) 'hasArgError'
		return
	end 'hasArgError'
	let isBare = project.discardedBareCallResults.contains(key)
	let isLet = project.discardedLetCallResults.contains(key)
	if not (isBare or isLet) 'notDiscarded'
		return
	end 'notDiscarded'
	let bareCallee = stripCalleeMangling(String.from(callee))
	// Void-returning callees have no result to "discard" — skip silently.
	// `doNothing()` as a bare statement is the canonical example: the
	// function exists for its side effects, the discard is implicit.
	if calleeIsVoid(project, bareCallee: bareCallee, callerNamespace: callerNamespace) 'voidCallee'
		return
	end 'voidCallee'
	// Chainable carve-out: methods returning their own receiver type can be
	// freely discarded (builder pattern). The check is conservative — if
	// the callee can't be resolved, we don't fire either diagnostic to
	// avoid noisy false-positives on unresolved-call paths.
	if isChainableCallee(project, module: module, calleeName: bareCallee) 'chainable'
		return
	end 'chainable'
	// Look up callee purity. Same lookup strategy as the transitive pass.
	let calleePure = lookupCalleePurityForReport(module, bareCallee: bareCallee, callerNamespace: callerNamespace, impureCallees: impureCallees)
	let displayName = formatCalleeNameForDiscard(bareCallee)
	if calleePure 'pure'
		// E3064 fires for both bare and let-discards — pure results MUST be used.
		reportCompileError(project, code: ErrorCode.semanticDiscardedPureResult, message: "result of pure function '{displayName}' must be used", line: range.line, column: range.column, filePath: readerFilePath)
		return
	end 'pure'
	// Impure callee: bare discard fires E3065; `_=` discard is the documented
	// way to silence the warning, so it stays silent.
	if isBare 'bareImpure'
		reportCompileError(project, code: ErrorCode.semanticDiscardedImpureResult, message: "result of '{displayName}' is not used (use '_ = expr' to discard)", line: range.line, column: range.column, filePath: readerFilePath)
	end 'bareImpure'
end 'maybeReportDiscarded'

// True when the callee's declared return type is `void`. Looks up the
// callee in `project.funcReturnTypes`, which is the project-wide registry
// populated by both the parser (user functions) and the stdlib cache
// restore path. Methods are keyed by their qualified `{TypeName}.method`
// name; bare callees from methodCall ops need their receiver type appended
// before lookup — but since methodCall already encodes only the method
// name on the op, the qualified key has to be probed across every
// `*.{methodName}` entry. This is O(N) per check; for the typical project
// (a few thousand functions) it stays fast enough.
function calleeIsVoid(project Project, bareCallee String, callerNamespace String) returns bool
	// Direct probe by bare name (works for `foo()` calls on free functions).
	if returnTypeIsVoid(project, qualifiedName: bareCallee) 'bareHit'
		return true
	end 'bareHit'
	// Namespace-qualified probe (`callerNamespace.bareCallee`).
	if callerNamespace != "" 'hasNs'
		if returnTypeIsVoid(project, qualifiedName: "{callerNamespace}.{bareCallee}") 'nsHit'
			return true
		end 'nsHit'
	end 'hasNs'
	// Method-call shape: the callee is just the method name; scan every
	// registered function whose name ends in `.{bareCallee}` and report
	// void if any matches. Multiple matches are uncommon (each receiver
	// type defines at most one method by the same name), but if they
	// disagree on return type the conservative answer is "void" — falsely
	// suppressing a diagnostic is better than firing one spuriously on
	// idiomatic mutator calls like `arr.push("x")`.
	//
	// Overload-mangled keys: when two same-named methods coexist the parser
	// re-keys both under their mangled forms (`Array.sort$`,
	// `Array.sort$SortComparator`). The original `.sort` suffix no longer
	// ends the key, so the bare endsWith match misses both. Accept either
	// `.{bareCallee}` (unmangled) or `.{bareCallee}$...` (mangled) so the
	// scan finds every overload.
	let methodSuffix = ".{bareCallee}"
	let mangledPrefix = "{methodSuffix}$"
	for (key, rt) in project.funcReturnTypes 'each'
		if not (key.endsWith(methodSuffix) or key.contains(mangledPrefix)) 'notMethod'
			continue
		end 'notMethod'
		let isVoid = match rt 'rtkind'
			void gives true
			value gives false
		end 'rtkind'
		if isVoid 'foundVoid'
			return true
		end 'foundVoid'
	end 'each'
	return false
end 'calleeIsVoid'

function returnTypeIsVoid(project Project, qualifiedName String) returns bool
	let rt = try project.funcReturnTypes.get(qualifiedName) otherwise return false
	return match rt 'rtkind'
		void gives true
		value gives false
	end 'rtkind'
end 'returnTypeIsVoid'

// Strip the leading namespace segment from a qualified callee name, matching
// the C# FormatCalleeName helper: `"ns.Type.method"` → `"Type.method"`,
// `"ns.func"` → `"func"`, `"func"` → `"func"`.
function formatCalleeNameForDiscard(callee String) returns String
	let dotIdx = try callee.findFirst(".") otherwise return callee
	let afterDot = try callee.indexAfter(dotIdx) otherwise return callee
	return callee.slice(afterDot, endIndex: callee.endIndex())
end 'formatCalleeNameForDiscard'

// Does the callee match the "chainable" pattern: first param is `self`, and
// the return type's name equals the receiver's type name? The method-table
// keys methods by `{TypeName}.{method}`; if we can recover `TypeName` from
// the callee and the matching IrFunction's return type, we can apply the
// carve-out. When the callee isn't matched (free function, stdlib helper),
// returns false so the discard check still fires.
function isChainableCallee(project Project, module MaxonModule, calleeName String) returns bool
	// Two shapes the parser passes through:
	//   - Qualified `"Counter.increment"` (from call ops on a static method).
	//   - Bare method name `"increment"` (from methodCall ops — the receiver
	//     isn't part of the callee bytes; type resolution stores the
	//     receiver elsewhere). We probe both.
	if calleeName.contains(".") 'qualified'
		return isChainableQualified(project, module: module, qualified: calleeName)
	end 'qualified'
	// Bare method name: walk the module for any function `"T.calleeName"`
	// whose return type equals T. If multiple candidates match, the discard
	// site is chainable as long as one does — the user's source-level
	// method-resolution can only have picked one, so we err on the
	// permissive side (false positive on the carve-out is preferred to a
	// noisy E3064 false-positive).
	for func in module.functions 'each'
		let dotIdx = try func.name.findFirst(".") otherwise continue
		let methodPart = try func.name.indexAfter(dotIdx) otherwise continue
		let methodSuffix = func.name.slice(methodPart, endIndex: func.name.endIndex())
		if methodSuffix != calleeName 'notThisMethod'
			continue
		end 'notThisMethod'
		if isChainableQualified(project, module: module, qualified: func.name) 'yes'
			return true
		end 'yes'
	end 'each'
	return false
end 'isChainableCallee'

function isChainableQualified(project Project, module MaxonModule, qualified String) returns bool
	for func in module.functions 'each'
		if func.name != qualified 'noMatch'
			continue
		end 'noMatch'
		if func.paramCount < 1 'noParams'
			return false
		end 'noParams'
		let receiverType = receiverTypeNameFromCallee(qualified)
		if receiverType == "" 'noReceiver'
			return false
		end 'noReceiver'
		let returnTypeName = maxonReturnTypeName(project, rt: func.maxonReturnType)
		return returnTypeName == receiverType
	end 'each'
	return false
end 'isChainableQualified'

// Receiver type name from a qualified callee name like `"Counter.increment"`
// → `"Counter"`. Returns "" if no dot exists.
function receiverTypeNameFromCallee(callee String) returns String
	let dotIdx = try callee.findFirst(".") otherwise return ""
	return callee.slice(callee.startIndex(), endIndex: dotIdx)
end 'receiverTypeNameFromCallee'

// Stringify a MaxonReturnType for the chainable check. `void` returns ""
// so the equality with a receiver type can never succeed. `value(t)`
// extracts the bare name from `named(id)` via the project's type-name
// interner; non-named types return "".
function maxonReturnTypeName(project Project, rt MaxonReturnType) returns String
	return match rt 'rt'
		void gives ""
		value(t) gives maxonTypeBareName(project, t: t)
	end 'rt'
end 'maxonReturnTypeName'

function maxonTypeBareName(project Project, t MaxonType) returns String
	if t.name != "named" 'notNamed'
		return ""
	end 'notNamed'
	match t 'pickName'
		named(id) then return project.typeNames.get(id)
		default panic("maxonTypeBareName: name guard but match failed")
	end 'pickName'
end 'maxonTypeBareName'

// Discard-check purity lookup — same strategy as the propagation pass
// (`lookupCalleePurity`), but defaults unresolved callees to *impure*
// rather than pure. Unresolved callees in the report path are stdlib
// helpers or methods whose bodies weren't analyzed; firing E3064 on
// them would be a false positive. Defaulting to impure routes bare
// discards through the documented E3065 "use `_ =` to discard" path
// and silences `_=` discards on the same callees.
function lookupCalleePurityForReport(module MaxonModule, bareCallee String, callerNamespace String, impureCallees ImpureCalleeSet) returns bool
	return lookupCalleePurityImpl(module, calleeName: bareCallee, callerNamespace: callerNamespace, impureCallees: impureCallees, unresolvedDefault: false)
end 'lookupCalleePurityForReport'

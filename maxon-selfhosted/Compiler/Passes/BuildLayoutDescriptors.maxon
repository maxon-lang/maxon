// Phase 11.2 pass: emit a 56-byte LayoutDescriptor blob for every concrete
// `genericInstance` MaxonType the project has interned. The descriptor is
// the runtime contract Phase 11.4's generic-body lowering reads via
// constant-offset loads — see `Compiler/IR/LayoutDescriptor.maxon` for the
// byte shape and per-field invariants.
//
// Pass runs at the Maxon phase, after deadFunctionElimination has narrowed
// the live function set but before lowerMaxonToStd lowers any bodies, so
// the synthesized copy/destroy thunks land in the same pipeline stages as
// every user function.
//
// Phase 11.2 alone unlocks no specs. The thunks emitted here are stubs —
// no code path calls them yet — so their bodies do nothing useful. Phase
// 11.4 will rewrite them as the generic body lowering grows the
// `loadLayoutDescriptor` / `descriptorField` op family. The static rdata
// emission, the funcAbs64InRdata reloc registration, and the livenessRoots
// seeding ARE the contract this phase establishes — those have to be in
// place before 11.4 can wire up call-site materialization.

typealias VisitedSet = Set with GenericInstanceId
typealias AsciiByte = int(0 to u8.max)

export function buildLayoutDescriptors(project Project, maxonModule MaxonModule, globalData GlobalDataTable)
	// Pre-intern `Interface with [confArgs]` gids for every conformance
	// that carries `with` args. The conformance binding implicitly creates
	// a per-instance generic shape that interface-extension call sites
	// need a layout descriptor for (e.g. `intList.has(20)` where
	// `IntList implements HasItems with Integer` resolves the layout via
	// `(HasItems, [Integer])`). Without this seeding, the gid is never
	// interned through normal use-site flow and lowering panics when it
	// tries to load a missing descriptor.
	seedConformanceLayouts(project)

	// Emit the two shared singleton element-layout descriptors the field-array
	// projection selects between (`__layout_elem_managed` / `__layout_elem_raw`).
	// Unconditional + idempotent: they're 56-byte blobs and a `loadLayoutDescriptor`
	// against either label must always resolve, so we never gate their emission on
	// whether a multi-type-param aggregate happens to be present this run.
	emitElementLayoutSingletons(globalData, project: project)

	let count = project.genericInstances.count()
	if count == 0 'noWork'
		return
	end 'noWork'

	logDebug(LogCategory.ir, message: function() gives "buildLayoutDescriptors: walking {count} interned generic instances")

	// Worklist seeds from every gid the parser/resolver has interned. The
	// `walkInstantiations` helper would be redundant in steady state — the
	// registry already enumerates every reachable instance — but we still
	// run it so a future change that interns only the outermost wrapper
	// (and elides its arg-list children) doesn't silently drop descriptors.
	var visited = VisitedSet.create()
	for gid in 0 upto count 'eachInstance'
		walkInstantiations(project, t: MaxonType.genericInstance(gid), out: visited)
	end 'eachInstance'

	// Emit descriptors in a deterministic, gid-ORDER-INDEPENDENT order
	// (sorted by mangled descriptor label) rather than raw gid order. The
	// `project.genericInstances` gid numbering is NOT stable across build
	// scenarios: a COLD build interns stdlib instances in compile-discovery
	// order (the stdlib is compiled in the user's own project), while a WARM
	// build re-interns them in cache disk-read order (depth-first over the
	// serialized registry in `readGenericInstanceRegistry`). The two orderings
	// assign different gids to the same instance (e.g. `Array<String>` is gid 6
	// cold / gid 8 warm), so a gid-ordered emit lays the descriptor BLOBS into
	// `project.globalData` — and therefore `.rdata` — in a build-dependent
	// order, breaking cold==warm cache parity. Sorting by the mangled label
	// (a pure function of the instance's structural shape) makes the `.rdata`
	// layout depend only on WHICH descriptors are present, not on the gid
	// interning order that produced them.
	var orderedGids = GenericInstanceIdArray.create()
	for gid in 0 upto count 'collect'
		if visited.contains(gid) 'reachable'
			orderedGids.push(gid)
		end 'reachable'
	end 'collect'
	sortGidsByLabel(project, gids: orderedGids)

	for gid in orderedGids 'emit'
		emitDescriptorForInstance(project, maxonModule: maxonModule, globalData: globalData, gid: gid)
	end 'emit'
end 'buildLayoutDescriptors'

// Insertion-sort `gids` ascending by their mangled descriptor label
// (`__layout_<mangled>`), the build-order-independent key
// `buildLayoutDescriptors` emits in. Distinct gids always mangle to distinct
// labels (the mangling is injective over concrete instances), so the order is
// total and deterministic.
function sortGidsByLabel(project Project, gids GenericInstanceIdArray)
	let n = gids.count()
	for i in 1 upto n 'sort'
		let key = try gids.get(i) otherwise panic("sortGidsByLabel: gids.get({i}) failed (count={n})")
		let keyLabel = mangleInstance(project, gid: key)
		var j = i
		while j > 0 'shift'
			let prev = try gids.get(j - 1) otherwise panic("sortGidsByLabel: gids.get({j - 1}) failed")
			let prevLabel = mangleInstance(project, gid: prev)
			// `prevLabel <= keyLabel` — the non-strict form of the shared
			// byte-wise comparator (`stringLexLess` is strict `<`).
			if not stringLexLess(keyLabel, b: prevLabel) 'inPlace'
				break
			end 'inPlace'
			try gids.set(j, value: prev) otherwise panic("sortGidsByLabel: gids.set({j}) OOB")
			j = j - 1
		end 'shift'
		try gids.set(j, value: key) otherwise panic("sortGidsByLabel: gids.set({j}) OOB")
	end 'sort'
end 'sortGidsByLabel'

// Walk every conformance and pre-intern the `Interface with [args]` gid
// so the downstream descriptor emit picks it up. Conformances without
// `with` args don't carry a generic shape and stay unseeded — their
// interface methods receive no implicit layout param.
function seedConformanceLayouts(project Project)
	let total = project.conformances.count()
	for i in 0 upto total 'eachConf'
		let confArgs = try project.conformances.withArgsList.get(i) otherwise panic("seedConformanceLayouts: withArgsList.get OOB at {i}")
		if confArgs.count() == 0 'noArgs'
			continue
		end 'noArgs'
		if anyMaxonTypeIsConditional(confArgs) 'conditional'
			continue
		end 'conditional'
		let ifaceName = try project.conformances.interfaceNames.get(i) otherwise panic("seedConformanceLayouts: interfaceNames.get OOB at {i}")
		let baseId = project.typeNames.intern(ifaceName)
		_ = project.genericInstances.intern(baseId, args: confArgs)
	end 'eachConf'
end 'seedConformanceLayouts'

// Emit the two fixed-label singleton element-layout descriptors the field-array
// projection (`materializeLayoutForGid`) selects between. A multi-type-param
// aggregate (e.g. `Map with (Integer, Box)`) forwards ONE aggregate layout to
// every field-array's generic `Array.reserve`, whose only use of the forwarded
// layout is the element-destroy stamp reading `flags@24` bit 0. The aggregate's
// bit 0 is the OR over all args, so the wrong arrays (the `Integer` keys array)
// would get `&__mm_decref` stamped and walk raw integers at teardown (the
// `Map<Integer, Box>` nil-deref crash). The projection instead forwards one of
// these singletons whose bit 0 reflects only the specific field's element.
//
// Both are registered into `globalData` (so the writer emits the bytes and
// `loadLayoutDescriptor` against the label resolves) and into
// `project.staticRdataValues` (so a cache-restored build re-emits them on the
// fresh per-run `globalData`). They carry no copy/destroy thunk slots, so they
// need no `funcAbs64InRdata` relocs or witness-conditional roots — a
// `loadLayoutDescriptor` pins the blob directly via Std-DFE.
function emitElementLayoutSingletons(globalData GlobalDataTable, project Project)
	emitOneElementLayoutSingleton(globalData, project: project, label: LAYOUT_ELEM_MANAGED_LABEL, hasHeapRefs: true)
	emitOneElementLayoutSingleton(globalData, project: project, label: LAYOUT_ELEM_RAW_LABEL, hasHeapRefs: false)
end 'emitElementLayoutSingletons'

function emitOneElementLayoutSingleton(globalData GlobalDataTable, project Project, label String, hasHeapRefs bool)
	let bytes = encodeLayoutDescriptor(elementLayoutSingleton(hasHeapRefs))
	addNamedGlobalData(globalData, name: label, data: bytes)
	project.staticRdataValues.upsert(label, value: bytes)
end 'emitOneElementLayoutSingleton'

function emitDescriptorForInstance(project Project, maxonModule MaxonModule, globalData GlobalDataTable, gid GenericInstanceId)
	let mangled = mangleInstance(project, gid: gid)
	let descriptorLabel = "__layout_{mangled}"
	let copyName = "__layout_copy_{mangled}"
	let destroyName = "__layout_destroy_{mangled}"

	if project.layoutDescriptors.contains(gid) 'alreadyEmitted'
		// Cache restore path: the descriptor's bytes were captured in
		// `project.staticRdataValues` when the stdlib was built, but
		// `globalData` is fresh per compile. Re-add so `buildRdataSection`
		// emits the bytes and reloc lookups don't silently fall through to
		// offset 0. `addNamedGlobalData` is idempotent on name.
		let label = project.layoutDescriptors.labelFor(gid)
		let bytes = try project.staticRdataValues.get(label) otherwise return
		addNamedGlobalData(globalData, name: label, data: bytes)
		// CRITICAL (mirrors the witness cache-restore path in
		// `emitWitnessForConformance`): the copy/destroy thunk RELOCS and the
		// witness-conditional ROOTS live on per-pipeline-run state
		// (`globalData.pendingRdataRelocs` / the conditional-root set), which the
		// stdlib cache does NOT carry — only the descriptor bytes and the thunk
		// BODIES are cached. Without re-pushing them here, the +32/+40 copy/destroy
		// slots are never patched (stay 0) and the destroy thunk is never linked
		// (no conditional root promotes it), so an element-drop through a
		// CACHE-RESTORED descriptor (`__layout_Array_Character`, which is baked into
		// the stdlib cache because `Array<Character>` is instantiated inside stdlib)
		// calls `[layout+40] == 0` → rip=0 (the `Set/Array with Character` membership
		// crash). `int`/`Box` descriptors are NOT cached, so they hit the fresh path
		// below and were never affected. The thunk bodies are already in the cache,
		// so do NOT re-synthesize them.
		//
		// The copy/destroy thunk names MUST be derived from the CACHED LABEL, not from
		// `mangleInstance(gid)` recomputed at the top of this function. On restore the
		// gid is re-interned into the USER project's id space, where the SAME
		// `(baseId, args)` shape can re-mangle differently — concretely, a cached
		// `__layout_Array_String` gid restores with a CONDITIONAL `typeParameter(Element)`
		// arg, so `mangleInstance` yields `Array_Element` and `copyName` would become
		// `__layout_copy_Array_Element` — a thunk that was never synthesized (conditional
		// gids skip synthesis), so its `funcAbs64InRdata` reloc dangles and
		// `patchOneFuncAbs64InRdata` panics ("no .text symbol"). The cached LABEL is the
		// authoritative concrete name the stdlib build synthesized the thunk under, so
		// build the thunk names from it.
		let restoredCopyName = layoutThunkNameFromLabel(label, kind: "copy")
		let restoredDestroyName = layoutThunkNameFromLabel(label, kind: "destroy")
		registerLayoutThunkRelocsAndRoots(project, globalData: globalData, descriptorLabel: label, copyName: restoredCopyName, destroyName: restoredDestroyName)
		return
	end 'alreadyEmitted'

	// Conditional instances (any arg is an unbound type parameter) don't
	// have a concrete layout — they're placeholders that 11.4 will resolve
	// at the call site once the type-arg is fixed. Emitting a descriptor
	// for them collides because two distinct conditional gids whose
	// type-parameter args share a name (`__ManagedMemory<Element>` from
	// two different `uses Element` declarations) mangle to the same
	// `__layout_*` label. The PE/ELF/MachO writers tolerate the duplicate
	// silently via Map upsert; the wasm linear-data layout doesn't.
	let (_, gidArgs) = project.genericInstances.get(gid)
	if anyMaxonTypeIsConditional(gidArgs) 'conditional'
		return
	end 'conditional'
	// Stage K.X.wasm: `anyMaxonTypeIsConditional` only catches the literal
	// top-level `typeParameter` arm; it does NOT recurse into
	// `genericInstance` args. A wrapping gid like `WithIterIterator with
	// (MapIterator with (Key, Value), ...)` would slip through and emit a
	// `__layout_*` descriptor for what is still a parametric shape. The
	// deeper recursive check catches this.
	if anyNamedArgIsParametric(project, args: gidArgs) 'parametricNamed'
		return
	end 'parametricNamed'

	let descriptor = computeLayoutDescriptor(project, gid: gid, copyName: copyName, destroyName: destroyName)
	let bytes = encodeLayoutDescriptor(descriptor)

	addNamedGlobalData(globalData, name: descriptorLabel, data: bytes)
	project.staticRdataValues.upsert(descriptorLabel, value: bytes)

	registerLayoutThunkRelocsAndRoots(project, globalData: globalData, descriptorLabel: descriptorLabel, copyName: copyName, destroyName: destroyName)

	synthesizeCopyThunk(project, maxonModule: maxonModule, gid: gid, name: copyName)
	synthesizeDestroyThunk(project, maxonModule: maxonModule, gid: gid, name: destroyName)

	project.layoutDescriptors.intern(gid, label: descriptorLabel)
end 'emitDescriptorForInstance'

// Register the per-pipeline-run state both descriptor legs (fresh-emit and
// cache-restore) need but the stdlib cache does not carry: the two
// `funcAbs64InRdata` relocs that patch the copy/destroy thunk VAs into the
// descriptor's fixed +32/+40 slots, and the witness-conditional roots that keep
// those thunks linked iff a live function loads the descriptor. Mirrors the
// witness path's unconditional reloc + conditional-root re-push
// (`emitWitnessForConformance`), so a cache-restored descriptor's element-drop
// slot is patched exactly like a freshly-emitted one.
//
// The relocs' `rdataLabel` points at the descriptor itself so
// `resolveRdataRelocations` resolves their `rdataOffset` from the same
// rdata-offset map that backs every other rdata relocation. Std-DFE promotes the
// copy/destroy thunks to definite roots iff a live function emits
// `loadLayoutDescriptor(descriptorLabel)`; if no user code reaches the descriptor,
// both the rdata blob and the thunks are correctly dropped.
// Derive a layout copy/destroy thunk name (`__layout_copy_<mangled>` /
// `__layout_destroy_<mangled>`) from a descriptor LABEL (`__layout_<mangled>`).
// Used by the cache-restore leg, where the cached label is the authoritative
// concrete mangling and `mangleInstance(gid)` cannot be trusted (the restored gid
// may carry conditional type-parameter args that re-mangle differently). The label
// always begins with the `__layout_` prefix (`emitDescriptorForInstance` /
// `emitOneElementLayoutSingleton`); splice `<kind>_` after it.
function layoutThunkNameFromLabel(label String, kind String) returns String
	if not label.startsWith("__layout_") 'unexpected'
		panic("layoutThunkNameFromLabel: descriptor label '{label}' does not start with '__layout_'")
	end 'unexpected'
	// Splice `<kind>_` after the leading `__layout_`. The prefix appears only at the
	// start (mangled type names never contain `__layout_`), so a single replace of the
	// prefix is an exact, unambiguous rewrite.
	return label.replace("__layout_", with: "__layout_{kind}_")
end 'layoutThunkNameFromLabel'

function registerLayoutThunkRelocsAndRoots(project Project, globalData GlobalDataTable, descriptorLabel String, copyName String, destroyName String)
	pushFuncAbs64Reloc(globalData, rdataLabel: descriptorLabel, funcName: copyName, offsetInLabel: LAYOUT_OFFSET_COPY_FUNC)
	pushFuncAbs64Reloc(globalData, rdataLabel: descriptorLabel, funcName: destroyName, offsetInLabel: LAYOUT_OFFSET_DESTROY_FUNC)
	pushWitnessConditionalRoot(project, rdataLabel: descriptorLabel, funcName: copyName)
	pushWitnessConditionalRoot(project, rdataLabel: descriptorLabel, funcName: destroyName)
end 'registerLayoutThunkRelocsAndRoots'

// Compute the concrete layout for a GenericInstance. Phase 11.2 baseline:
// look up the base struct in `project.structTypes` and use its `byteSize`;
// fall back to pointer-sized when the base isn't a registered struct
// (built-ins like `__ManagedMemory`, opaque generic wrappers). Refined in
// Phase 11.4 once `buildSubstitution` is wired into a real per-field walk.
function computeLayoutDescriptor(project Project, gid GenericInstanceId, copyName String, destroyName String) returns LayoutDescriptor
	let (baseId, args) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	var size = 8 as MachineWord
	var alignment = 8 as MachineWord
	if let st = try project.structTypes.get(baseName) 'isStruct'
		size = st.byteSize
		if size < 8 'minAlign'
			alignment = size
		end 'minAlign'
	end 'isStruct'
	let elementSize = primitiveElementSize(project, args: args)
	let hasHeapRefs = instanceHasHeapRefs(project, args: args)
	let perArgHeapRefBits = computePerArgHeapRefBits(project, args: args)
	return LayoutDescriptor.create(size, alignment: alignment, elementSize: elementSize, hasHeapRefs: hasHeapRefs, perArgHeapRefBits: perArgHeapRefBits, copyFuncName: copyName, destroyFuncName: destroyName, fieldOffsetsPtr: "")
end 'computeLayoutDescriptor'

// Pack one HAS_HEAP_REFS bit per type-arg: bit i is set iff `args[i]` is a
// heap-managed type. The aggregate descriptor's `flags@24` carries these
// above the per-arg shift so a multi-type-param field-array call site can
// project the exact element's heap-ref status (the `Map<Integer, Box>` keys
// vs values disambiguation — see `materializeLayoutForGid`). Only the low 56
// bits are encodable (`flags` is a single qword and bit 0 is the aggregate
// OR), so args beyond index 55 leave their bit unencodable; that is far
// beyond any real generic arity, so we cap the walk there rather than
// silently shifting into / past bit 63.
function computePerArgHeapRefBits(project Project, args MaxonTypeArray) returns MachineWord
	var bits = 0 as MachineWord
	let maxEncodableArgs = 56
	var limit = args.count()
	if limit > maxEncodableArgs 'cap'
		limit = maxEncodableArgs
	end 'cap'
	for i in 0 upto limit 'each'
		let a = try args.get(i) otherwise panic("computePerArgHeapRefBits: args.get OOB at {i}")
		if argTypeHasHeapRefs(project, t: a) 'isHeap'
			bits = bits or (1 shl (i as ParsedInt))
		end 'isHeap'
	end 'each'
	return bits
end 'computePerArgHeapRefBits'

// Recover an "element size" hint: when the instance has exactly one type
// argument (the typical container shape — `Array with T`, `__ManagedMemory
// with T`), report that argument's primitive width. Multi-arg or zero-arg
// instances get 0 — matches the descriptor invariant "0 for non-container
// types".
function primitiveElementSize(project Project, args MaxonTypeArray) returns MachineWord
	if args.count() != 1 'notSingleton'
		return 0
	end 'notSingleton'
	let only = try args.get(0) otherwise panic("primitiveElementSize: args.get(0) failed despite count==1")
	return primitiveWidth(project, t: only)
end 'primitiveElementSize'

// Element-byte-width for a MaxonType. For named types (typealiases / structs /
// enums) resolve through the project's StdType registry so a narrow enum or
// `int(0 to u8.max)` typealias correctly reports its 1-, 2-, or 4-byte storage
// width. Bare `MaxonType.integer` is `i64` by definition (it's an unconstrained
// integer literal at the type level) so it stays at 8. Pointer-shaped types
// (strings, function values, genericInstance, interface, typeParameter) all
// lower to an i64 ABI slot and so report 8.
export function primitiveWidth(project Project, t MaxonType) returns MachineWord
	return match t 'w'
		boolean gives 1
		integer gives 8
		float gives 8
		string gives 8
		character gives 8
		named gives storeWidthBytes(storeWidthOfStdType(resolveMaxonTypeToStd(project, ref: t)))
		function to cstring gives 8
	end 'w'
end 'primitiveWidth'

// True iff any type argument is itself a heap-managed value — a string, a
// reference-counted generic instance, an interface existential, OR a `named`
// user struct (every struct is heap-allocated + refcount-managed). The runtime
// element-walk reads the resulting HAS_HEAP_REFS bit to decide whether to stamp
// `&__mm_decref` on a container's backing buffer, so a `named`-element container
// (`Array with Box`) MUST report true here or its elements leak — see
// `argTypeHasHeapRefs` / `namedArgHasHeapRefs` for the per-arg decision.
function instanceHasHeapRefs(project Project, args MaxonTypeArray) returns bool
	for i in 0 upto args.count() 'each'
		let a = try args.get(i) otherwise panic("instanceHasHeapRefs: args.get OOB at {i}")
		if argTypeHasHeapRefs(project, t: a) 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'instanceHasHeapRefs'

// True iff a layout-descriptor element/key type holds a heap reference the
// container's destructor must walk. A `named` USER STRUCT counts (every struct is
// heap-allocated + refcount-managed — `structNameIsHeapManaged`); without this an
// `Array with Box` / a `Map with (String, Box)` got HAS_HEAP_REFS=false, so the
// runtime element-walk never stamped `&__mm_decref` and every managed element leaked.
// `string`/`genericInstance`/`interface` are heap-managed by shape; primitives and a
// still-unbound `typeParameter` are not (the latter is monomorphized away before a
// descriptor is emitted — see `instanceHasUnboundTypeParam`).
function argTypeHasHeapRefs(project Project, t MaxonType) returns bool
	return match t 'h'
		string gives true
		character gives true
		// `Promise with T` elements are raw green-thread handles, NOT mm
		// objects (see structNameIsHeapManaged) — an element walk over them
		// would decref `[gt - 8]` slab memory (the promise-array teardown
		// over-release). Every other generic instance is heap-managed.
		genericInstance(id) gives (genericInstanceIdBaseName(project, id: id) != "Promise")
		interface gives true
		named(id) gives namedArgHasHeapRefs(project, name: project.typeNames.get(id))
		boolean to float gives false
		function gives false
		unresolved gives false
		typeParameter gives false
		constInt to cstring gives false
	end 'h'
end 'argTypeHasHeapRefs'

// A `named` layout-descriptor arg holds a heap reference when it is a user struct
// (`structNameIsHeapManaged`) OR a typealias that RESOLVES to one — a generic-container
// alias (`typealias IntArray = Array with Integer`) reaches here as `named("IntArray")`,
// NOT the underlying `genericInstance`, so a bare struct check would miss it and the
// enclosing container (`Array with IntArray`) would get HAS_HEAP_REFS=false → no element
// walk → every nested container element leaks. Chase the generic-typealias target and
// recurse. Ranged/scalar typealiases (`typealias Integer = int(...)`) resolve to a
// primitive and correctly stay non-heap.
function namedArgHasHeapRefs(project Project, name String) returns bool
	if structNameIsHeapManaged(project, structName: name) 'isStruct'
		return true
	end 'isStruct'
	if let aliasTarget = try project.genericTypealiases.get(name) 'isGenericAlias'
		return argTypeHasHeapRefs(project, t: aliasTarget)
	end 'isGenericAlias'
	return false
end 'namedArgHasHeapRefs'

// True iff any element references an unbound type-parameter. Used to
// gate per-call-site materialization in Phase 11.4: layout descriptors
// (for generic-instance args) and witness tables (for `withArgs` of
// conditional conformances) must NOT be emitted statically when the
// shape is still parametric — see `emitDescriptorForInstance` for the
// label-collision rationale.
export function anyMaxonTypeIsConditional(types MaxonTypeArray) returns bool
	for i in 0 upto types.count() 'each'
		let a = try types.get(i) otherwise panic("anyMaxonTypeIsConditional: types.get OOB at {i}")
		if maxonTypeIsConditional(a) 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'anyMaxonTypeIsConditional'

export function maxonTypeIsConditional(t MaxonType) returns bool
	return match t 'check'
		typeParameter gives true
		boolean to function gives false
		// `unresolved` is the polymorphic-slot sentinel used by builtin
		// signatures (see registerManagedMemoryMethods). A writer-side
		// `__ManagedMemory with unresolved` (or similar) is a placeholder
		// shape, not a ground type — `BuildWitnessTables` / `BuildLayoutDescriptors`
		// must skip it so witness-thunk synthesis never receives the
		// `unresolved` arm at `emitThunkWitnessLoadForBoundType`.
		unresolved gives true
		genericInstance to cstring gives false
	end 'check'
end 'maxonTypeIsConditional'

// Stage K.X.wasm: deeper conditional-arg check that `maxonTypeIsConditional`
// can't catch. Treats every type-parameter-bearing reference as parametric:
//   - a bare `named(Element)` where `Element` is a typeParameter on the
//     enclosing scope, or a bare reference to a generic type
//   - a `genericInstance(...)` whose nested args are themselves parametric
//     under the same rules (e.g. `MapIterator with (Key, Value)` where Key
//     and Value are MapIterator's own typeParameters)
//
// `anyMaxonTypeIsConditional` only catches the literal-typeParameter arm
// at the top level; it does NOT recurse into genericInstance args. Both
// `BuildWitnessTables.gidIsConditional` and
// `BuildLayoutDescriptors.emitDescriptorForInstance` need the deeper check
// so a wrapping gid like `WithIterIterator with (MapIterator with (Key, Value), ...)`
// is correctly recognised as parametric.
export function anyNamedArgIsParametric(project Project, args MaxonTypeArray) returns bool
	for a in args 'each'
		if namedArgIsParametric(project, t: a) 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'anyNamedArgIsParametric'

function namedArgIsParametric(project Project, t MaxonType) returns bool
	return match t 'pick'
		named(id) gives isNamedIdParametric(project, id: id)
		genericInstance(gid) gives anyNamedArgIsParametric(project, args: genericInstanceArgs(project, gid: gid))
		boolean gives false
		integer gives false
		float gives false
		string gives false
		character gives false
		function gives false
		unresolved gives true
		typeParameter gives true
		interface to cstring gives false
	end 'pick'
end 'namedArgIsParametric'

function isNamedIdParametric(project Project, id TypeNameId) returns bool
	let name = project.typeNames.get(id)
	if project.structTypes.contains(name) 'isStruct'
		// Generic struct referenced bare (e.g. `named(MapIterator)`
		// instead of `genericInstance(MapIterator with (Key,Value))`)
		// is still parametric — its concrete shape depends on the
		// caller-supplied type-arg list, so per-instance emission
		// must skip it. Non-generic struct (no `uses` clause) is a
		// real ground type and not parametric.
		return project.typeParameters.getParamNames(name).count() > 0
	end 'isStruct'
	if project.enumTypes.contains(name) or project.unresolvedEnums.contains(name) 'isEnum'
		// Mirror the struct check: a generic enum referenced bare is
		// parametric. Most enums in the stdlib are non-generic, but
		// the rule is symmetric.
		return project.typeParameters.getParamNames(name).count() > 0
	end 'isEnum'
	if project.typealiases.contains(name) 'isRangedAlias'
		return false
	end 'isRangedAlias'
	if project.genericTypealiases.contains(name) 'isGenericAlias'
		return false
	end 'isGenericAlias'
	return true
end 'isNamedIdParametric'

function genericInstanceArgs(project Project, gid GenericInstanceId) returns MaxonTypeArray
	let (_, args) = project.genericInstances.get(gid)
	return args
end 'genericInstanceArgs'

// Build a deterministic, valid-C-identifier mangling for a generic
// instance. `genericInstanceIdToString` already produces a
// human-readable spelling but the result includes spaces, parentheses,
// and commas; this routine sanitizes those into underscores so the
// label round-trips through every linker we target.
function mangleInstance(project Project, gid GenericInstanceId) returns String
	let (baseId, args) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	var result = sanitizeIdentifier(baseName)
	for i in 0 upto args.count() 'eachArg'
		let a = try args.get(i) otherwise panic("mangleInstance: args.get OOB at {i}")
		result = "{result}_{mangleType(project, t: a)}"
	end 'eachArg'
	return result
end 'mangleInstance'

function mangleType(project Project, t MaxonType) returns String
	return match t 'm'
		boolean gives "Bool"
		integer gives "Int"
		float gives "Float"
		string gives sanitizeIdentifier(builtinStringLiteralTypeName())
		character gives sanitizeIdentifier(builtinCharLiteralTypeName())
		named(id) gives sanitizeIdentifier(project.typeNames.get(id))
		function gives "Fn"
		unresolved gives "Unresolved"
		typeParameter(id) gives sanitizeIdentifier(project.typeParameters.getName(id))
		genericInstance(gid) gives mangleInstance(project, gid: gid)
		interface(id) gives sanitizeIdentifier(project.interfaceRegistry.getName(id))
		constInt(value) gives "N{value}"
		opaquePointer to cstring gives "OpaquePtr"
	end 'm'
end 'mangleType'

// Replace every byte that isn't [A-Za-z0-9_] with '_'. Empty input becomes
// "anon" so the mangled label is never zero-length. Exported so the
// witness-table builder shares the exact same mangling rules — labels
// generated by both passes get linked together by the writer and need to
// agree byte-for-byte on the sanitization.
export function sanitizeIdentifier(name String) returns String
	if name.isEmpty() 'empty'
		return "anon"
	end 'empty'
	let bytes = name.toByteArray()
	var out = ByteArray.create()
	out.reserve(bytes.count())
	for i in 0 upto bytes.count() 'eachByte'
		let b = try bytes.get(i) otherwise panic("sanitizeIdentifier: bytes.get OOB at {i}")
		out.push(safeIdentifierByte(b))
	end 'eachByte'
	return String.from(out)
end 'sanitizeIdentifier'

function safeIdentifierByte(b AsciiByte) returns AsciiByte
	let underscore = 0x5F as AsciiByte
	if isAsciiAlphaNum(b) 'keep'
		return b
	end 'keep'
	return underscore
end 'safeIdentifierByte'

function isAsciiAlphaNum(b AsciiByte) returns bool
	let zero = 0x30 as AsciiByte
	let nine = 0x39 as AsciiByte
	let upperA = 0x41 as AsciiByte
	let upperZ = 0x5A as AsciiByte
	let lowerA = 0x61 as AsciiByte
	let lowerZ = 0x7A as AsciiByte
	let underscore = 0x5F as AsciiByte
	if b >= zero and b <= nine 'digit'
		return true
	end 'digit'
	if b >= upperA and b <= upperZ 'upper'
		return true
	end 'upper'
	if b >= lowerA and b <= lowerZ 'lower'
		return true
	end 'lower'
	return b == underscore
end 'isAsciiAlphaNum'

// Stage a `funcAbs64InRdata` reloc on globalData so a per-target writer
// can later patch the absolute VA into the rdata slot. Used by both this
// pass and BuildWitnessTables (layout-descriptor copy/destroy slots and
// witness-table method slots share the same patch shape).
export function pushFuncAbs64Reloc(globalData GlobalDataTable, rdataLabel String, funcName String, offsetInLabel ByteOffset)
	let kind = RdataRelocKind.funcAbs64InRdata(funcName, rdataLabel: rdataLabel, offsetInLabel: offsetInLabel)
	globalData.pendingRdataRelocs.push(RdataRelocation.create(0, rdataLabel: rdataLabel, kind: kind))
end 'pushFuncAbs64Reloc'

// Stage K.4: register `funcName` as a witness-conditional root keyed by
// `rdataLabel` (a witness-table label or layout-descriptor label).
// Std-DFE promotes the function to a definite root the moment it sees a
// `loadWitnessTable` or `loadLayoutDescriptor` op naming the same label
// in a live function. Used by both this pass (copy/destroy thunks per
// descriptor) and BuildWitnessTables (method impls per witness table).
export function pushWitnessConditionalRoot(project Project, rdataLabel String, funcName String)
	if var bucket = try project.witnessConditionalRoots.get(rdataLabel) 'haveBucket'
		bucket.push(funcName)
		project.witnessConditionalRoots.upsert(rdataLabel, value: bucket)
	end 'haveBucket' else 'freshBucket'
		var bucket = StringArray.create()
		bucket.push(funcName)
		project.witnessConditionalRoots.upsert(rdataLabel, value: bucket)
	end 'freshBucket'
end 'pushWitnessConditionalRoot'

// Per-thunk synthetic value name. Each thunk has its own block and its
// own value-name namespace at the Maxon level, but salting with the
// thunk's name keeps `--dump-stages` output readable.
function synthName(thunkName String, suffix String) returns ByteArray
	return "{thunkName}__{suffix}".toByteArray()
end 'synthName'

// True iff the gid's args contain any heap-ref-bearing type. Drives the
// "single-word + incref" copy shape and the "single-word load into
// String-typed local" destroy shape for non-struct generic instances.
function instanceArgsHaveHeapRefs(project Project, gid GenericInstanceId) returns bool
	let (_, args) = project.genericInstances.get(gid)
	return instanceHasHeapRefs(project, args: args)
end 'instanceArgsHaveHeapRefs'

// Boilerplate: create an IrFunction shell for a thunk, register one
// entry block, and bind the parameter slots. Returns (func, entryBlock).
//
// `returnsInteger=true` declares the thunk with an i64 return so wasm's
// `call_indirect` sees a `(args...) -> i64` signature — required for the
// destroy thunk because `lowerDropTypeParam` emits a non-void indirect
// call (the destructor's "(i64) -> i64" ABI matches `__destruct_<Union>`'s
// shape and the `mm_alloc` destructor slot's declared type). Copy thunks
// stay void: they're called directly via `func.call`, not through a
// fixed-signature call_indirect site, so a void declaration matches the
// body's `ret 0` getting elided.
function startThunkFunc(maxonModule MaxonModule, name String, paramCount ParamCount, returnsInteger bool = false) returns (IrFunction, IrBlock)
	var paramTypes = MaxonTypeArray.create()
	for _ in 0 upto paramCount 'eachParam'
		paramTypes.push(MaxonType.integer)
	end 'eachParam'
	var returnType = MaxonReturnType.void
	if returnsInteger 'pickReturn'
		returnType = MaxonReturnType.value(MaxonType.integer)
	end 'pickReturn'
	var func = IrFunction.create(name, maxonReturnType: returnType, paramCount: paramCount, maxonParamTypes: paramTypes, returnLine: 0)
	func.namespace = ""
	func.visibility = Visibility.global
	let block = maxonModule.addBlock(func, label: "entry")
	return (func, block)
end 'startThunkFunc'

// Append a `MaxonOp.call` to the runtime helper at qualifiedName and
// register its opIdx in `project.resolvedCallees` so lowerMaxonToStd's
// post-TypeResolution invariant (every call op has a resolved callee
// stashed by the resolver pass) is satisfied. The runtime helpers have
// no `funcSignatures` entry, so lowering takes the no-signature
// `emitUnsignedCall` branch and emits a plain Std-level call against
// the bare runtime symbol — exactly what we need.
function emitRuntimeCall(project Project, maxonModule MaxonModule, block IrBlock, resultName ByteArray, callee String, args ByteArrayArray)
	let opIdx = maxonModule.ops.count()
	let calleeBytes = project.calleeNames.intern(callee)
	var argLabels = StringArray.create()
	for _ in 0 upto args.count() 'fillLabels'
		argLabels.push("")
	end 'fillLabels'
	var argTypes = MaxonTypeArray.create()
	var argRanges = SourceRangeArray.create()
	for _ in 0 upto args.count() 'fillTypes'
		argTypes.push(MaxonType.integer)
		argRanges.push(SourceRange.none())
	end 'fillTypes'
	maxonModule.appendOp(block, op: MaxonOp.call(resultName, callee: calleeBytes, callContext: CallContext.qualified, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.none()))
	try project.resolvedCallees.insert(opIdx, value: callee) otherwise ignore
end 'emitRuntimeCall'

// Emit a load+(optional incref)+store sequence for a single 8-byte word
// at offset `offset` from src/dst. Used by both the single-word copy
// shape and the per-field struct copy shape. `srcName`/`dstName` are
// the names of the src/dst pointer values already bound in the block.
// `tag` is a per-call name suffix to keep synth names unique within
// the thunk's value namespace.
function emitWordCopyAtOffset(project Project, maxonModule MaxonModule, block IrBlock, thunkName String, srcName ByteArray, dstName ByteArray, offset FieldOffset, fieldHasHeapRef bool, tag String)
	var srcAt = srcName
	var dstAt = dstName
	if offset != 0 'needAdjust'
		let offConst = synthName(thunkName, suffix: "off_{tag}")
		maxonModule.appendOp(block, op: MaxonOp.literal(offConst, value: offset, valueType: MaxonType.integer, range: SourceRange.none()))
		let srcAdjusted = synthName(thunkName, suffix: "src_{tag}")
		maxonModule.appendOp(block, op: MaxonOp.binop(srcAdjusted, left: srcName, right: offConst, opKind: BinOpKind.add, operandType: MaxonType.integer, range: SourceRange.none()))
		let dstAdjusted = synthName(thunkName, suffix: "dst_{tag}")
		maxonModule.appendOp(block, op: MaxonOp.binop(dstAdjusted, left: dstName, right: offConst, opKind: BinOpKind.add, operandType: MaxonType.integer, range: SourceRange.none()))
		srcAt = srcAdjusted
		dstAt = dstAdjusted
	end 'needAdjust'

	let valueName = synthName(thunkName, suffix: "v_{tag}")
	var loadArgs = ByteArrayArray.create()
	loadArgs.push(srcAt)
	emitRuntimeCall(project, maxonModule: maxonModule, block: block, resultName: valueName, callee: "__layout_word_load", args: loadArgs)

	if fieldHasHeapRef 'incref'
		let increfResult = synthName(thunkName, suffix: "incref_{tag}")
		var increfArgs = ByteArrayArray.create()
		increfArgs.push(valueName)
		emitRuntimeCall(project, maxonModule: maxonModule, block: block, resultName: increfResult, callee: "mm_incref", args: increfArgs)
	end 'incref'

	let storeResult = synthName(thunkName, suffix: "store_{tag}")
	var storeArgs = ByteArrayArray.create()
	storeArgs.push(dstAt)
	storeArgs.push(valueName)
	emitRuntimeCall(project, maxonModule: maxonModule, block: block, resultName: storeResult, callee: "__layout_word_store", args: storeArgs)
end 'emitWordCopyAtOffset'

// Read the single 8-byte word at offset and release it via the null-tolerant
// `__mm_decref_maybenull_helper` (a moved-out / never-assigned field slot reads
// exactly 0; any other non-pointer junk still faults loudly inside the strict
// `mm_decref` it routes to). The destroy-side mirror of `emitWordCopyAtOffset`'s
// hand-emitted `mm_incref` — thunk loads are below the inserter's classify
// surface, so the release must be explicit here.
function emitWordDestroyAtOffset(project Project, maxonModule MaxonModule, block IrBlock, thunkName String, valueName ByteArray, offset FieldOffset, tag String)
	var valueAt = valueName
	if offset != 0 'needAdjust'
		let offConst = synthName(thunkName, suffix: "doff_{tag}")
		maxonModule.appendOp(block, op: MaxonOp.literal(offConst, value: offset, valueType: MaxonType.integer, range: SourceRange.none()))
		let adjusted = synthName(thunkName, suffix: "dat_{tag}")
		maxonModule.appendOp(block, op: MaxonOp.binop(adjusted, left: valueName, right: offConst, opKind: BinOpKind.add, operandType: MaxonType.integer, range: SourceRange.none()))
		valueAt = adjusted
	end 'needAdjust'

	let loaded = synthName(thunkName, suffix: "dv_{tag}")
	var loadArgs = ByteArrayArray.create()
	loadArgs.push(valueAt)
	emitRuntimeCall(project, maxonModule: maxonModule, block: block, resultName: loaded, callee: "__layout_word_load", args: loadArgs)

	let released = synthName(thunkName, suffix: "drel_{tag}")
	var decArgs = ByteArrayArray.create()
	decArgs.push(loaded)
	emitRuntimeCall(project, maxonModule: maxonModule, block: block, resultName: released, callee: "__mm_decref_maybenull_helper", args: decArgs)
end 'emitWordDestroyAtOffset'

// Synthesize the body of __layout_copy_<m>(src ptr, dst ptr) for a
// concrete generic instance gid. Body shape is driven by the resolved
// type of the instance:
//
//   - Struct-shaped (baseName ∈ project.structTypes): per-field walk;
//     each field is a single 8-byte word (Maxon's struct fields are
//     pointer-sized). Heap-bearing fields incref before storing into
//     dst — the layout-routed copy is the moral equivalent of a
//     stdlib `clone()`, so an incref restores invariants.
//   - Heap-ref-bearing single word (any gid arg is heap-managed —
//     covers `__ManagedMemory with String`, `Array with String`, etc.):
//     load+incref+store the single 8-byte word.
//   - Otherwise (primitive single word, e.g. `Array with Int`):
//     load+store, no refcount touching.
function synthesizeCopyThunk(project Project, maxonModule MaxonModule, gid GenericInstanceId, name String)
	var (func, block) = startThunkFunc(maxonModule, name: name, paramCount: 2)

	let srcLoad = synthName(name, suffix: "srcLoad")
	let dstLoad = synthName(name, suffix: "dstLoad")
	maxonModule.appendOp(block, op: MaxonOp.varLoad(srcLoad, slotId: 0, slotType: MaxonType.integer, range: SourceRange.none()))
	maxonModule.appendOp(block, op: MaxonOp.varLoad(dstLoad, slotId: 1, slotType: MaxonType.integer, range: SourceRange.none()))

	let (baseId, args) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	if let st = try project.structTypes.get(baseName) 'isStruct'
		let subst = buildSubstitution(project, declaringTypeName: baseName, args: args)
		for i in 0 upto st.fields.count() 'eachField'
			let field = try st.fields.get(i) otherwise panic("synthesizeCopyThunk: fields.get OOB at {i}")
			if not field.offsetResolved 'unresolved'
				panic("synthesizeCopyThunk: field '{field.name}' on struct '{baseName}' has unresolved offset — layoutAllStructs pass did not run")
			end 'unresolved'
			let concrete = substituteType(project, t: field.fieldType, subst: subst)
			let isHeap = argTypeHasHeapRefs(project, t: concrete)
			emitWordCopyAtOffset(project, maxonModule: maxonModule, block: block, thunkName: name, srcName: srcLoad, dstName: dstLoad, offset: field.offset, fieldHasHeapRef: isHeap, tag: "f{i}")
		end 'eachField'
	end 'isStruct' else 'singleWord'
		let isHeap = instanceArgsHaveHeapRefs(project, gid: gid)
		emitWordCopyAtOffset(project, maxonModule: maxonModule, block: block, thunkName: name, srcName: srcLoad, dstName: dstLoad, offset: 0, fieldHasHeapRef: isHeap, tag: "w0")
	end 'singleWord'

	let zeroName = synthName(name, suffix: "zero")
	maxonModule.appendOp(block, op: MaxonOp.literal(zeroName, value: 0, valueType: MaxonType.integer, range: SourceRange.none()))
	maxonModule.setTerminator(block, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	maxonModule.functions.push(func)
end 'synthesizeCopyThunk'

// Synthesize the body of __layout_destroy_<m>(value ptr). Shape:
//
//   - Pure-primitive instance (no heap-bearing args, non-struct base):
//     `ret 0` — nothing to release.
//   - Heap-ref-bearing single word: load the 8-byte word and release it
//     via `__mm_decref_maybenull_helper` (null-guarded — a moved-out /
//     never-assigned field slot reads 0).
//   - Struct-shaped: per-field walk; for each heap-ref-bearing field
//     (after substituting the instance's type args), load + release.
//     Non-heap fields contribute nothing.
//
// The release is hand-emitted, mirroring `emitWordCopyAtOffset`'s
// hand-emitted `mm_incref`: thunk bodies are synthesized below the
// classify surface the refcount inserter reads, so the inserter never
// releases their loads. The thunk doubles as the box DESTRUCTOR for
// generic-shared `Self{...}` allocations with type-param fields (see
// `structAllocLayoutDestructorApplies` in LowerMaxonToStd) — its
// `(i64) -> i64` shape matches the `mm_alloc` destructor-slot ABI.
function synthesizeDestroyThunk(project Project, maxonModule MaxonModule, gid GenericInstanceId, name String)
	var (func, block) = startThunkFunc(maxonModule, name: name, paramCount: 1, returnsInteger: true)

	let valueLoad = synthName(name, suffix: "valLoad")
	maxonModule.appendOp(block, op: MaxonOp.varLoad(valueLoad, slotId: 0, slotType: MaxonType.integer, range: SourceRange.none()))

	let (baseId, args) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	if let st = try project.structTypes.get(baseName) 'isStruct'
		let subst = buildSubstitution(project, declaringTypeName: baseName, args: args)
		for i in 0 upto st.fields.count() 'eachField'
			let field = try st.fields.get(i) otherwise panic("synthesizeDestroyThunk: fields.get OOB at {i}")
			if not field.offsetResolved 'unresolved'
				panic("synthesizeDestroyThunk: field '{field.name}' on struct '{baseName}' has unresolved offset — layoutAllStructs pass did not run")
			end 'unresolved'
			let concrete = substituteType(project, t: field.fieldType, subst: subst)
			if argTypeHasHeapRefs(project, t: concrete) 'isHeap'
				emitWordDestroyAtOffset(project, maxonModule: maxonModule, block: block, thunkName: name, valueName: valueLoad, offset: field.offset, tag: "f{i}")
			end 'isHeap'
		end 'eachField'
	end 'isStruct' else 'singleWord'
		if instanceArgsHaveHeapRefs(project, gid: gid) 'hasHeap'
			emitWordDestroyAtOffset(project, maxonModule: maxonModule, block: block, thunkName: name, valueName: valueLoad, offset: 0, tag: "w0")
		end 'hasHeap'
	end 'singleWord'

	let zeroName = synthName(name, suffix: "zero")
	maxonModule.appendOp(block, op: MaxonOp.literal(zeroName, value: 0, valueType: MaxonType.integer, range: SourceRange.none()))
	maxonModule.setTerminator(block, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	maxonModule.functions.push(func)
end 'synthesizeDestroyThunk'

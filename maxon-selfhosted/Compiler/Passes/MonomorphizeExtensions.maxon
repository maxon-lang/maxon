// J.4b: per-receiver monomorphization of user-declared interface-extension
// methods. When a call site like `intList.has(20)` resolves to
// `HasItems.has` (an interface-extension method) and the receiver is a
// concrete struct/named type, we synthesize a dedicated
// `{ReceiverType}.{methodName}` function by cloning the extension's body
// with the interface's `usesParam` typeParameters substituted to the
// receiver's `implements <Iface> with [args]` arguments and
// `interface(<Iface>)`-typed values rewritten to `named(<ReceiverType>)`.
//
// The cloned function is registered alongside the original in
// `project.funcSignatures` / `funcReturnTypes` / `funcVisibilities` /
// `funcThrowsTypes`, its body is appended to the MaxonModule, and the
// triggering call site's `resolvedCallees` entry is rewritten to the new
// qualified name so lowering takes the direct-call path instead of
// fat-pointer dispatch.
//
// Why this lives in a dedicated pass and not as a Maxon-IR-level inlining:
// the extension body references the interface's typeParameters (`Element`)
// and may call other interface methods (`current()`, `advance()`) that
// re-resolve through the concrete receiver's conformance. Monomorphization
// makes the body's iterator-protocol calls dispatch directly via
// `{ReceiverType}.current` / `{ReceiverType}.advance` (the conformance's
// declared methods), avoiding the fat-pointer indirection.

// One-stop result of monomorphizing a single (receiverType, ifaceCallee)
// pair. The `qualifiedName` is the registered key for the new function;
// callers re-point `resolvedCallees[opIdx]` at it.
export type MonomorphResult
	export var qualifiedName as String

	export static function create(qualifiedName String) returns MonomorphResult
		return Self{qualifiedName: qualifiedName}
	end 'create'
end 'MonomorphResult'

export enum MonomorphError implements Error
	notInterfaceCallee
	noSourceFunction
	noConformance
	receiverNotNamed
end 'MonomorphError'

// Per-project monomorphization cache. Keyed by `{receiverType}::{ifaceCallee}`
// so the second call site that asks for the same pair short-circuits to the
// already-registered name. Lives on Project alongside other compile-state
// sidecars; see `Project.maxon`.
export type MonomorphCache
	export var keys as StringArray
	export var values as StringArray

	export static function create() returns MonomorphCache
		return Self{keys: StringArray.create(), values: StringArray.create()}
	end 'create'

	export function contains(key String) returns bool
		for i in 0 upto keys.count() 'scan'
			let k = try keys.get(i) otherwise panic("MonomorphCache.contains: keys.get OOB at {i}")
			if k == key 'hit'
				return true
			end 'hit'
		end 'scan'
		return false
	end 'contains'

	export function get(key String) returns String
		for i in 0 upto keys.count() 'scan'
			let k = try keys.get(i) otherwise panic("MonomorphCache.get: keys.get OOB at {i}")
			if k == key 'hit'
				return try values.get(i) otherwise panic("MonomorphCache.get: values desync at {i}")
			end 'hit'
		end 'scan'
		panic("MonomorphCache.get: missing key '{key}' — caller must check contains() first")
	end 'get'

	export function set(key String, value String)
		keys.push(key)
		values.push(value)
	end 'set'
end 'MonomorphCache'

// Entry point. Given a call site whose `resolvedCallee` is an
// interface-extension method (e.g. `HasItems.has`) and a concrete receiver
// type (e.g. `IntList`), clone the source body into a dedicated
// `{receiverType}.{methodName}` function. Returns the new qualified name
// on success; throws on any structural reason the clone can't proceed
// (missing source function, no conformance, etc.).
//
// Idempotent: subsequent calls with the same (receiverType, calleeQualified)
// pair return the cached name without re-emitting the body.
export function monomorphizeInterfaceExtension(project Project, module MaxonModule, calleeQualified String, receiverType MaxonType) returns String throws MonomorphError
	let receiverTypeName = baseNameOfReceiverType(project, selfType: receiverType)
	if receiverTypeName.isEmpty() 'noName'
		throw MonomorphError.receiverNotNamed
	end 'noName'

	let calleeBytes = calleeQualified.toByteArray()
	let dotIdx = lastIndexOfDotByte(calleeBytes)
	if dotIdx >= calleeBytes.count() 'noDot'
		throw MonomorphError.notInterfaceCallee
	end 'noDot'
	let ifaceName = byteSliceToString(calleeBytes, startIndex: 0, endIndex: dotIdx)
	let methodName = byteSliceToString(calleeBytes, startIndex: dotIdx + 1, endIndex: calleeBytes.count())
	if not (project.interfaces.contains(ifaceName) or project.unresolvedInterfaces.contains(ifaceName)) 'notIface'
		throw MonomorphError.notInterfaceCallee
	end 'notIface'

	let monoQualified = "{receiverTypeName}.{methodName}"
	let cacheKey = "{receiverTypeName}::{calleeQualified}"

	if project.monomorphCache.contains(cacheKey) 'cached'
		return project.monomorphCache.get(cacheKey)
	end 'cached'

	// Pre-register the cache entry to break recursive monomorphization
	// (a method body that calls itself transitively must see the new
	// name during its own clone). The body is appended below, but the
	// registry entry is enough for any nested resolution.
	project.monomorphCache.set(cacheKey, value: monoQualified)

	// Locate the source IrFunction. User-declared interface extensions live in
	// the user module; stdlib-declared ones (`Iterable.map`, `Iterable.filter`,
	// `Iterable.contains`, ...) live in the process-wide `stdlibParsedModule`
	// snapshot. Try the user module first so an interface extension shadowed
	// in user code resolves to the user copy. If found in the stdlib module,
	// hand the cloner that source module's `blocks` / `ops` storage too —
	// `cloneAndAppendMonomorph` walks `srcBlock.opRefs` against the source's
	// module, then appends to the destination user module.
	var srcModule = module
	var srcFuncIdx = 0 as FuncIndex
	if let userFuncIdx = try findFunctionIndexByName(module, name: calleeQualified) 'userHit'
		srcFuncIdx = userFuncIdx
	end 'userHit' else 'tryStdlib'
		// J.4e: getStdlibParsedModule returns a fresh MaxonModule whose
		// MaxonType ids live in `project`'s id-space — the cross-project
		// translator handles the sandbox-to-user re-interning so the cloner
		// can substitute and walk types without an additional translation
		// step. Cache the translated snapshot per project so back-to-back
		// monomorphizations don't redo the walk.
		let stdlibModule = getStdlibParsedModule(project)
		srcFuncIdx = try findFunctionIndexByName(stdlibModule, name: calleeQualified) otherwise throw MonomorphError.noSourceFunction
		srcModule = stdlibModule
	end 'tryStdlib'

	// Build the type substitution: each interface usesParam → the
	// conformance's matching `with` arg. The conformance's withArgs are
	// resolved through the receiver's own substitution (a generic
	// receiver carries its typeParams through its conformance row).
	let subst = buildExtensionUsesParamSubstitution(project, receiverType: receiverType, ifaceName: ifaceName)

	let srcFunc = try srcModule.functions.get(srcFuncIdx) otherwise panic("monomorphizeInterfaceExtension: srcFuncIdx OOB after find")

	// Clone the source IrFunction with substituted types. `srcModule` supplies
	// the blocks/ops backing the source body; the cloned blocks/ops are
	// appended onto the destination user `module` so the new function flows
	// through every later compile pass alongside user-declared callees.
	cloneAndAppendMonomorph(project, dstModule: module, srcModule: srcModule, srcFunc: srcFunc, monoQualified: monoQualified, receiverTypeName: receiverTypeName, ifaceName: ifaceName, subst: subst)

	return monoQualified
end 'monomorphizeInterfaceExtension'

// Linear scan over module.functions to find a function by qualified name.
// Returns the index; throws when not found.
export function findFunctionIndexByName(module MaxonModule, name String) returns FuncIndex throws MonomorphError
	for i in 0 upto module.functions.count() 'scan'
		let f = try module.functions.get(i) otherwise panic("findFunctionIndexByName: functions.get OOB at {i}")
		if f.name == name 'hit'
			return i
		end 'hit'
	end 'scan'
	throw MonomorphError.noSourceFunction
end 'findFunctionIndexByName'

// Clone `srcFunc` into a fresh IrFunction registered as `monoQualified`,
// appending its blocks and ops onto `module` with appropriate offsets and
// type substitution applied to every embedded MaxonType. Registers the
// new function in `project.funcSignatures` / `funcReturnTypes` /
// `funcVisibilities` / `funcThrowsTypes` and pushes it onto
// `module.functions`.
function cloneAndAppendMonomorph(project Project, dstModule MaxonModule, srcModule MaxonModule, srcFunc IrFunction, monoQualified String, receiverTypeName String, ifaceName String, subst TypeSubstitution)
	let ifaceTypeId = project.interfaceRegistry.intern(ifaceName)
	let ifaceType = MaxonType.interface(ifaceTypeId)
	let receiverNamed = MaxonType.named(project.typeNames.intern(receiverTypeName))

	// Closure-specialization queue. Filled by the `closureCreate` /
	// `functionRef` arms in `substituteOp` as they walk the parent body's
	// ops; drained after the parent's blocks are cloned to emit per-receiver
	// clones of each referenced closure body. The queue is local to this
	// monomorphization so the same closure body referenced from a second
	// monomorphization (for a different receiver) gets a fresh entry +
	// fresh per-receiver clone, while same-receiver-same-closure references
	// from multiple call sites in this parent collapse to one clone via
	// `specializeClosureName`'s in-queue dedup.
	var closureQueue = ClosureSpecArray.create()

	// Build the slot-id remap. The source function may have hidden
	// `__witness_<param>` slots that the parser pre-allocated for
	// interface-typed params (the parser's ABI expansion). After
	// substitution those interfaces vanish, so we drop the witness slots
	// and renumber every remaining slot consecutively. Cloned ops walk
	// through `remapSlot` so every `varDecl` / `varLoad` / `varStore` /
	// `forInIterable.iterSlot` references the new dense slot space.
	let slotRemap = buildSlotRemap(srcFunc)

	// Substituted user-arity paramTypes (drives `FuncSignature` registration)
	// and the ABI-expanded shape that lands on `IrFunction.maxonParamTypes`.
	// The signature keeps the source-level shape so default-insertion +
	// overload resolution see the declared params. The ABI shape mirrors
	// Parser.maxon's expansion in `parseFunction`: after every function-typed
	// param we append an `i64` env-pointer slot, and after every fat
	// interface-typed param an `i64` witness slot. Lowering's per-function
	// slot-walk at LowerMaxonToStd.maxon:1609 reads `maxonParamTypes` directly
	// so the (fn, env) pairing in `fnEnvVarNames` materializes correctly.
	var newSigParamTypes = MaxonTypeArray.create()
	var newAbiParamTypes = MaxonTypeArray.create()
	var newParamNamesForSig = StringArray.create()
	var newParamDefaults = ParamDefaultArray.create()
	// slot<->abi decoupling: build the clone's reservations + slot<->abi maps
	// here, in lockstep with the ABI vector. The clone runs AFTER the
	// module-wide buildAbiParamMaps pass, so it must produce these itself.
	// Source scope slots come from the source's paramReservations (1:1 with
	// srcSig.paramTypes, __self included); resolve them through slotRemap into
	// the clone's dense slot space. The companion KIND is decided from the
	// SUBSTITUTED type (an interface param may fold to a plain type -> no
	// companion), matching the ABI-vector decision below exactly.
	var newReservations = ParamReservationArray.create()
	var slotToAbi = ScopeSlotToAbiIndexMap.create()
	var abiToSlot = VarSlotArray.create()
	let srcSig = try project.funcSignatures.get(srcFunc.name) otherwise panic("cloneAndAppendMonomorph: source signature '{srcFunc.name}' missing")
	let haveSrcReservations = srcFunc.paramReservations.count() == srcSig.paramTypes.count()
	for i in 0 upto srcSig.paramTypes.count() 'eachUserParam'
		let pt = try srcSig.paramTypes.get(i) otherwise panic("cloneAndAppendMonomorph: srcSig.paramTypes.get OOB at {i}")
		let pn = try srcSig.paramNames.get(i) otherwise panic("cloneAndAppendMonomorph: srcSig.paramNames.get OOB at {i}")
		let pd = try srcSig.paramDefaults.get(i) otherwise ParamDefault.none
		let substituted = substituteWithIfaceFold(project, t: pt, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed)
		newSigParamTypes.push(substituted)
		newParamNamesForSig.push(pn)
		newParamDefaults.push(pd)

		// Resolve this param's clone scope slot from the source reservation.
		var paramCloneSlot = i as VarSlot
		var hasCompanion = false
		var companionCloneSlot = 0 as VarSlot
		if haveSrcReservations 'haveRes'
			let srcRes = try srcFunc.paramReservations.get(i) otherwise panic("cloneAndAppendMonomorph: paramReservations.get OOB at {i}")
			paramCloneSlot = slotRemap.resolve(srcRes.paramSlot)
			hasCompanion = srcRes.hasCompanion
			if srcRes.hasCompanion 'resolveCompanion'
				companionCloneSlot = slotRemap.resolve(srcRes.companionSlot)
			end 'resolveCompanion'
		end 'haveRes'

		// Place the user param at the next ABI index + map it to its clone slot.
		let paramAbiIdx = newAbiParamTypes.count()
		newAbiParamTypes.push(substituted)
		slotToAbi.upsert(paramCloneSlot, value: paramAbiIdx)
		abiToSlot.push(paramCloneSlot)

		// Mirror parser ABI expansion / buildAbiParamMaps: function-typed param
		// -> env companion, fat interface-typed param -> witness companion.
		var kind = ParamCompanionKind.none
		if isFunctionMaxonType(substituted) 'addEnv'
			kind = ParamCompanionKind.env
		end 'addEnv' else if interfaceTypeIsFat(substituted) 'addWitnessSlot'
			kind = ParamCompanionKind.witness
		end 'addWitnessSlot'
		if not isParamCompanionNone(kind) 'placeCompanion'
			let companionAbiIdx = newAbiParamTypes.count()
			newAbiParamTypes.push(MaxonType.integer)
			// Use the reserved companion clone slot when the source carried one;
			// otherwise the companion has no scope slot (shouldn't happen for a
			// named-alias param that resolved to fn/interface, but stays safe).
			if hasCompanion 'mapCompanion'
				slotToAbi.upsert(companionCloneSlot, value: companionAbiIdx)
				abiToSlot.push(companionCloneSlot)
			end 'mapCompanion' else 'noCompanionSlot'
				abiToSlot.push(companionCloneSlot)
			end 'noCompanionSlot'
		end 'placeCompanion'

		newReservations.push(ParamReservation.create(paramCloneSlot, hasCompanion: hasCompanion, companionSlot: companionCloneSlot, companionKind: kind))
	end 'eachUserParam'

	// Substitute the return type.
	let newReturnType = substituteReturnType(project, raw: srcFunc.maxonReturnType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed)

	// Allocate the new IrFunction. paramCount is the ABI-expanded count so
	// the Std-level param ABI sees the env/witness companions; the user-
	// visible signature stays at `newSigParamTypes.count()`.
	let paramCount = newAbiParamTypes.count()
	var newFunc = IrFunction.create(monoQualified, maxonReturnType: newReturnType, paramCount: paramCount, maxonParamTypes: newAbiParamTypes, returnLine: srcFunc.returnLine, throwsTypeName: srcFunc.throwsTypeName)
	newFunc.namespace = srcFunc.namespace
	newFunc.visibility = srcFunc.visibility
	newFunc.sourceFilePath = srcFunc.sourceFilePath
	newFunc.nameLine = srcFunc.nameLine
	newFunc.nameColumn = srcFunc.nameColumn
	newFunc.nextBlockId = srcFunc.nextBlockId
	// slot<->abi decoupling: stamp the clone's reservations + maps built above.
	newFunc.paramReservations = newReservations
	newFunc.scopeSlotToAbiParamIndex = slotToAbi
	newFunc.abiParamIndexToScopeSlot = abiToSlot

	// Rebuild Scope with substituted varTypes. Slot ids are remapped
	// through `slotRemap` so the cloned scope's slots are dense (no
	// witness gaps) and every op that references a slotId in the cloned
	// body still resolves correctly. Self-field aliases are re-declared
	// against the receiver type's field offsets recovered from
	// `project.structTypes`.
	let newScope = cloneScopeWithSubst(project, srcScope: srcFunc.scope, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, receiverTypeName: receiverTypeName, slotRemap: slotRemap)
	newFunc.scope = newScope

	// Clone blocks + ops onto `dstModule` and register them on `newFunc`.
	// The parent-body clone discards the (srcOpIdx, newOpIdx) call-op
	// pairing — only closure-body clones need it for downstream
	// resolvedCallees rewriting.
	_ = cloneBlocksWithSubst(project, srcModule: srcModule, srcFunc: srcFunc, dstModule: dstModule, newFunc: newFunc, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, slotRemap: slotRemap, queue: closureQueue, receiverTypeName: receiverTypeName, ifaceName: ifaceName)

	// Register the new function's signature so resolver / lowering /
	// inliner can look it up via the same path a parser-declared method
	// uses.
	let newSig = FuncSignature.create(newParamNamesForSig, paramTypes: newSigParamTypes, paramDefaults: newParamDefaults)
	try project.funcReturnTypes.insert(monoQualified, value: newReturnType) otherwise ignore
	try project.funcSignatures.insert(monoQualified, value: newSig) otherwise ignore
	project.methodNameIndex.record(monoQualified)
	try project.funcVisibilities.insert(monoQualified, value: FuncVisibilityInfo.create(srcFunc.visibility, sourceFilePath: srcFunc.sourceFilePath)) otherwise ignore
	try project.funcThrowsTypes.insert(monoQualified, value: srcFunc.throwsTypeName) otherwise ignore

	dstModule.functions.push(newFunc)

	// Drain the closure-specialization queue: for every closure referenced
	// from the parent body's `closureCreate`/`functionRef` ops, emit a
	// per-receiver clone of the closure body under the specialized name.
	// Each recursive clone walks its source body through `substituteOp`,
	// which may push further entries onto the queue for nested closure
	// refs; the loop processes those until the queue is empty.
	drainClosureSpecQueue(project, dstModule: dstModule, queue: closureQueue, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
end 'cloneAndAppendMonomorph'

// Process every queued ClosureSpecEntry by cloning the source closure body
// under its receiver-specialized name. The clone walks the source body's
// blocks/ops the same way `cloneAndAppendMonomorph` walks the parent's,
// passing the same substitution + the same queue (so nested closure refs
// cascade naturally) down through `substituteOp`. The destination is
// always `dstModule` — even when the source closure body lived in
// `stdlibParsedModule`, the specialized clone lands alongside the user
// monomorphizations so codegen sees one module.
function drainClosureSpecQueue(project Project, dstModule MaxonModule, queue ClosureSpecArray, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, receiverTypeName String, ifaceName String)
	// FIFO drain. Process by index instead of `for entry in queue` so
	// entries pushed during the body of the loop (nested closure refs)
	// get processed in the same drain.
	var i = 0
	while i < queue.count() 'drain'
		let entry = try queue.get(i) otherwise panic("drainClosureSpecQueue: queue.get OOB at {i}")
		i = i + 1

		// Idempotency: another monomorphization in the same compile run
		// may have already specialized this closure for this receiver
		// type via a separate `cloneAndAppendMonomorph` call (e.g.
		// recursive monomorphization). If so, skip — the
		// receiver-qualified name uniquely identifies the clone.
		if let _ = try findFunctionIndexByName(dstModule, name: entry.specName) 'alreadyEmitted'
			continue
		end 'alreadyEmitted'

		emitSpecializedClosure(project, dstModule: dstModule, srcModule: entry.srcModule, srcFunc: entry.srcFunc, specName: entry.specName, queue: queue, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
	end 'drain'
end 'drainClosureSpecQueue'

// Clone `srcFunc` (a lifted closure body) into a fresh IrFunction named
// `specName`, applying the active substitution and appending the cloned
// blocks/ops onto `dstModule`. Mirrors `cloneAndAppendMonomorph`'s block
// walk minus the witness-slot / signature-paramType massaging — closure
// bodies don't carry `__witness_<param>` slots and their signatures are
// already in the user-facing shape. The hidden `__env i64` trailing param
// flows through verbatim.
function emitSpecializedClosure(project Project, dstModule MaxonModule, srcModule MaxonModule, srcFunc IrFunction, specName String, queue ClosureSpecArray, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, receiverTypeName String, ifaceName String)
	// Build the slot remap for the closure body. Closures don't have
	// `__witness___self` slots (they're not interface-extension method
	// bodies in their own right), but `buildSlotRemap` still produces
	// a dense renumbering — for a closure that's effectively an
	// identity map. Reusing the helper keeps slot-id handling
	// consistent across all monomorphized bodies.
	let slotRemap = buildSlotRemap(srcFunc)

	// Substitute the return type. Closures lifted from generic extensions
	// can return a type-parameter-typed value (e.g. `function() gives
	// self.something()` with a Self-typed receiver); the substitution
	// rewrites those just like parent-body return types.
	let newReturnType = substituteReturnType(project, raw: srcFunc.maxonReturnType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed)

	// Substitute each entry in maxonParamTypes. The hidden `__env i64`
	// trailing param is MaxonType.opaquePointer (parser stamps it at
	// Parser.maxon:13348) — substitution leaves it alone. User params
	// may carry type-parameter or interface-typed slots; we rewrite
	// them through the same fold.
	var newParamTypes = MaxonTypeArray.create()
	for i in 0 upto srcFunc.maxonParamTypes.count() 'eachParam'
		let pt = try srcFunc.maxonParamTypes.get(i) otherwise panic("emitSpecializedClosure: maxonParamTypes.get OOB at {i}")
		newParamTypes.push(substituteWithIfaceFold(project, t: pt, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed))
	end 'eachParam'

	var newFunc = IrFunction.create(specName, maxonReturnType: newReturnType, paramCount: srcFunc.paramCount, maxonParamTypes: newParamTypes, returnLine: srcFunc.returnLine, throwsTypeName: srcFunc.throwsTypeName)
	newFunc.namespace = srcFunc.namespace
	newFunc.visibility = srcFunc.visibility
	newFunc.sourceFilePath = srcFunc.sourceFilePath
	newFunc.nameLine = srcFunc.nameLine
	newFunc.nameColumn = srcFunc.nameColumn
	newFunc.nextBlockId = srcFunc.nextBlockId

	// Rebuild the closure body's Scope with substituted varTypes. Closure
	// bodies don't have self-field aliases, so the receiverTypeName +
	// receiverStruct lookup at `cloneScopeWithSubst` is a no-op for them
	// — but the rest of the helper (slot remap, payload bindings, regular
	// vars) applies identically. Pass the receiver type name even though
	// it won't be consulted for closure scopes; the helper handles missing
	// struct entries by dropping the alias, which is the desired behavior
	// for closure bodies that happen to have a self-field-shaped binding
	// from a captured outer scope (none in practice today).
	let newScope = cloneScopeWithSubst(project, srcScope: srcFunc.scope, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, receiverTypeName: receiverTypeName, slotRemap: slotRemap)
	newFunc.scope = newScope

	// Walk blocks/ops the same way `cloneAndAppendMonomorph` does, capturing
	// the (srcOpIdx, newOpIdx) pairing for every cloned call-shaped op.
	// Translate `project.resolvedCallees` afterwards so every cloned `call`/
	// `methodCall`/`tryCall`/`tryMethodCall` whose original resolution
	// pointed at the abstract `{ifaceName}.method` points at the concrete
	// `{receiverTypeName}.method` for THIS specialization. Without this,
	// lowering sees the cloned op's new opIdx with no `resolvedCallees`
	// entry and either panics (`lowerCall` invariant) or — worse — finds a
	// stale entry from the source op's opIdx that resolves to whichever
	// concrete receiver the original closure was first resolved against.
	let clonedCallOps = cloneBlocksWithSubst(project, srcModule: srcModule, srcFunc: srcFunc, dstModule: dstModule, newFunc: newFunc, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, slotRemap: slotRemap, queue: queue, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
	rewriteClonedResolvedCallees(project, dstModule: dstModule, pairs: clonedCallOps, ifaceName: ifaceName, receiverTypeName: receiverTypeName)

	// Register the specialized closure's signature. The source closure has
	// an entry in `project.funcSignatures` from parse time; we substitute
	// its paramTypes and re-register under the specialized name. The user
	// arity is the source signature's count (does not include the hidden
	// __env), so the resulting FuncSignature matches what callers built
	// at call-construction time. `paramDefaults` carry through — closure
	// params don't have defaults today but the field is present.
	let srcSig = try project.funcSignatures.get(srcFunc.name) otherwise panic("emitSpecializedClosure: source closure signature '{srcFunc.name}' missing")
	var newSigParamTypes = MaxonTypeArray.create()
	for i in 0 upto srcSig.paramTypes.count() 'eachSigParam'
		let pt = try srcSig.paramTypes.get(i) otherwise panic("emitSpecializedClosure: srcSig.paramTypes.get OOB at {i}")
		newSigParamTypes.push(substituteWithIfaceFold(project, t: pt, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed))
	end 'eachSigParam'
	let newSig = FuncSignature.create(srcSig.paramNames, paramTypes: newSigParamTypes, paramDefaults: srcSig.paramDefaults)
	try project.funcReturnTypes.insert(specName, value: newReturnType) otherwise ignore
	try project.funcSignatures.insert(specName, value: newSig) otherwise ignore
	project.methodNameIndex.record(specName)
	try project.funcVisibilities.insert(specName, value: FuncVisibilityInfo.create(srcFunc.visibility, sourceFilePath: srcFunc.sourceFilePath)) otherwise ignore
	try project.funcThrowsTypes.insert(specName, value: srcFunc.throwsTypeName) otherwise ignore

	dstModule.functions.push(newFunc)
end 'emitSpecializedClosure'

// Clone `srcFunc`'s blocks + ops onto `dstModule` and register them on
// `newFunc.blockRefs`. Walks the source function's blockRefs in order; for
// each block allocates a fresh IrBlock, clones every op through
// `substituteOp`, materializes the cloned terminator via `relocateTerminator`,
// and appends the new block to `dstModule.blocks`. Returns the (srcOpIdx,
// newOpIdx) pairs for every cloned call-shaped op (per
// `opNeedsResolvedCalleeRewrite`) so callers that need to translate
// `project.resolvedCallees` can do so afterwards. Parent-body callers that
// don't care about the pairing discard the return value.
function cloneBlocksWithSubst(project Project, srcModule MaxonModule, srcFunc IrFunction, dstModule MaxonModule, newFunc IrFunction, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, slotRemap SlotRemap, queue ClosureSpecArray, receiverTypeName String, ifaceName String) returns OpIndexPairArray
	var clonedCallOps = OpIndexPairArray.create()
	for blockRefIdx in 0 upto srcFunc.blockRefs.count() 'eachBlockRef'
		let srcBlockIdx = try srcFunc.blockRefs.get(blockRefIdx) otherwise panic("cloneBlocksWithSubst: blockRefs.get OOB at {blockRefIdx}")
		let srcBlock = try srcModule.blocks.get(srcBlockIdx) otherwise panic("cloneBlocksWithSubst: blocks.get OOB at {srcBlockIdx}")
		var newBlock = IrBlock.create(srcBlock.id, label: srcBlock.label)
		for srcOpIdx in srcBlock.opRefs 'eachOp'
			let srcOp = try srcModule.ops.get(srcOpIdx) otherwise panic("cloneBlocksWithSubst: ops.get OOB at {srcOpIdx}")
			let clonedOp = substituteOp(project, op: srcOp, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, slotRemap: slotRemap, queue: queue, parentSrcModule: srcModule, dstModule: dstModule, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
			let newOpIdx = dstModule.ops.count()
			dstModule.ops.push(clonedOp)
			newBlock.opRefs.append(newOpIdx)
			if opNeedsResolvedCalleeRewrite(srcOp) 'isCall'
				clonedCallOps.push(OpIndexPair.create(srcOpIdx, dstOpIdx: newOpIdx))
			end 'isCall'
		end 'eachOp'
		newBlock.terminator = match srcBlock.terminator 'relocate'
			unset gives Terminator.unset
			dead gives Terminator.dead
			fallthrough gives Terminator.fallthrough
			opIndex gives relocateTerminator(project, srcModule: srcModule, dstModule: dstModule, srcOpIdx: srcBlock.terminatorIndex(), subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, slotRemap: slotRemap, queue: queue, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
		end 'relocate'
		let newBlockIdx = dstModule.blocks.count()
		dstModule.blocks.push(newBlock)
		dstModule.blockSourceInfo.push(BlockSourceInfo.empty())
		newFunc.blockRefs.append(newBlockIdx)
	end 'eachBlockRef'
	return clonedCallOps
end 'cloneBlocksWithSubst'

// Materialize the cloned terminator op AFTER cloning the block's regular
// ops so the source terminator's op index has already been visited by
// the regular `eachOp` loop above. Returns the relocated Terminator.
// The src terminator's op was already pushed into module.ops during the
// op walk; this helper just computes the new op-index for that position.
function relocateTerminator(project Project, srcModule MaxonModule, dstModule MaxonModule, srcOpIdx OpIndex, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, slotRemap SlotRemap, queue ClosureSpecArray, receiverTypeName String, ifaceName String) returns Terminator
	// The block's terminator op index points at a position in `srcModule.ops`
	// that we already processed in the op walk: each op gets a brand-new
	// trailing entry in `dstModule.ops`. Clone+append the terminator op afresh
	// against the destination module and return the appended index — keeps the
	// terminator referent inside the destination's op-table even when the
	// source body came from `stdlibParsedModule`.
	let srcOp = try srcModule.ops.get(srcOpIdx) otherwise panic("relocateTerminator: ops.get OOB at {srcOpIdx}")
	let clonedOp = substituteOp(project, op: srcOp, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed, slotRemap: slotRemap, queue: queue, parentSrcModule: srcModule, dstModule: dstModule, receiverTypeName: receiverTypeName, ifaceName: ifaceName)
	let newOpIdx = dstModule.ops.count()
	dstModule.ops.push(clonedOp)
	return Terminator.opIndex(newOpIdx)
end 'relocateTerminator'

// Map from source-function slot id → cloned-function slot id. The clone
// drops every `__witness_<param>` slot the parser pre-allocated for
// interface-typed params, so consecutive slots above the witness
// renumber down by the count of witness slots dropped to their left.
// Implemented as a parallel-array since per-function slot counts are
// small.
export type SlotRemap
	export var srcIds as VarSlotArray
	export var dstIds as VarSlotArray

	export static function create() returns SlotRemap
		return Self{srcIds: VarSlotArray.create(), dstIds: VarSlotArray.create()}
	end 'create'

	export function add(srcId VarSlot, dstId VarSlot)
		srcIds.push(srcId)
		dstIds.push(dstId)
	end 'add'

	export function isDropped(srcId VarSlot) returns bool
		for i in 0 upto srcIds.count() 'scan'
			let s = try srcIds.get(i) otherwise panic("SlotRemap.isDropped: srcIds.get OOB at {i}")
			if s == srcId 'hit'
				return false
			end 'hit'
		end 'scan'
		return true
	end 'isDropped'

	// Resolve a source slot to the cloned slot. Returns the source id
	// unchanged when no mapping is registered — most slots don't need
	// remapping (the witness drop only shifts ids past the witness).
	// This sentinel-passthrough behaviour is safe because cloned ops
	// never see a dropped slot directly (they reference user-declared
	// names, not the parser's hidden witness companion).
	export function resolve(srcId VarSlot) returns VarSlot
		for i in 0 upto srcIds.count() 'scan'
			let s = try srcIds.get(i) otherwise panic("SlotRemap.resolve: srcIds.get OOB at {i}")
			if s == srcId 'hit'
				return try dstIds.get(i) otherwise panic("SlotRemap.resolve: dstIds desync at {i}")
			end 'hit'
		end 'scan'
		return srcId
	end 'resolve'
end 'SlotRemap'

export typealias VarSlotArray = Array with VarSlot

// Walk srcFunc.scope.allVars() in slot-id order, dropping any
// `__witness_<param>` synthetic slot, and assign each surviving slot
// a fresh dense slot id starting at 0. The resulting map drives every
// op-clone's slot renumber and the rebuilt scope's `nextSlot`.
function buildSlotRemap(srcFunc IrFunction) returns SlotRemap
	var remap = SlotRemap.create()
	let total = srcFunc.scope.nextSlot
	if total == 0 'empty'
		return remap
	end 'empty'
	let allVars = srcFunc.scope.allVars()
	// Mark which slot ids are occupied in one pass over the scope vars, then
	// walk 0..total in slot order. The Maxon Map iterator doesn't guarantee
	// insertion order, so iterating `allVars` directly could shuffle slot ids;
	// the occupied-bit array keeps the renumber deterministic while replacing
	// the former per-slot full-map scan (O(slots × vars)) with O(slots + vars).
	var slotOccupied = BoolArray.create()
	slotOccupied.resize(total)
	for (_, info) in allVars 'markOccupied'
		if info.slot < total 'inRange'
			try slotOccupied.set(info.slot, value: true) otherwise panic("buildSlotRemap: slotOccupied.set OOB despite info.slot < total")
		end 'inRange'
	end 'markOccupied'

	var dstSlot = 0 as VarSlot
	for srcSlot in 0 upto total 'eachSlot'
		if not (try slotOccupied.get(srcSlot) otherwise false) 'unmapped'
			continue
		end 'unmapped'
		// slot<->abi decoupling: the parser reserves ONE `__companion_<param>`
		// scope slot per named-alias param (env OR witness, decided later).
		// KEEP these in the remap so the clone scope retains the param+companion
		// structure that lowering's fnEnvVarNames / interfaceWitnessSlots load
		// via the rebuilt slot<->abi maps (see the map-build loop below). The
		// companion may turn out unused after substitution (param folds to a
		// plain type) — an unused remapped scope slot is harmless (no body op
		// and no map entry reference it).
		remap.add(srcSlot, dstId: dstSlot)
		dstSlot = dstSlot + 1
	end 'eachSlot'
	return remap
end 'buildSlotRemap'

// Apply substitution + interface→named folding to a MaxonType. Centralized
// so every call site rewrites types through a single helper.
export function substituteWithIfaceFold(project Project, t MaxonType, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType) returns MaxonType
	let substituted = substituteType(project, t: t, subst: subst)
	return foldInterfaceToReceiver(substituted, ifaceType: ifaceType, receiverNamed: receiverNamed)
end 'substituteWithIfaceFold'

// Rewrite `interface(Iface)` to the concrete receiver's `named(...)` arm.
// All other arms pass through unchanged.
function foldInterfaceToReceiver(t MaxonType, ifaceType MaxonType, receiverNamed MaxonType) returns MaxonType
	return match t 'fold'
		interface gives receiverNamed if maxonTypesStructurallyEqual(t, b: ifaceType) else t
		boolean to function gives t
		unresolved gives t
		typeParameter gives t
		genericInstance gives t
		constInt to cstring gives t
	end 'fold'
end 'foldInterfaceToReceiver'

// Substitute a MaxonReturnType.
function substituteReturnType(project Project, raw MaxonReturnType, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType) returns MaxonReturnType
	return match raw 'k'
		void gives MaxonReturnType.void
		value(inner) gives MaxonReturnType.value(substituteWithIfaceFold(project, t: inner, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed))
	end 'k'
end 'substituteReturnType'

// Clone the source function's Scope, walking every VarInfo and rewriting
// its varType through the substitution. Self-field aliases are re-declared
// from the receiver type's fields so a `self.x` reference (which lowers
// through fieldLoad with the offset stored on the VarInfo) resolves
// against the receiver's struct layout rather than the extension's
// abstract Self.
function cloneScopeWithSubst(project Project, srcScope Scope, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, receiverTypeName String, slotRemap SlotRemap) returns Scope
	var dst = Scope.create()
	let srcVars = srcScope.allVars()
	var maxDstSlot = 0 as VarSlot
	for (name, info) in srcVars 'eachVar'
		if slotRemap.isDropped(info.slot) 'skipDropped'
			continue
		end 'skipDropped'
		let dstSlot = slotRemap.resolve(info.slot)
		if dstSlot >= maxDstSlot 'updateMax'
			maxDstSlot = dstSlot + 1
		end 'updateMax'
		var newType = substituteWithIfaceFold(project, t: info.varType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed)
		if info.isSelfField 'selfField'
			// Self-field aliases need the receiver type's field offset, not the
			// interface's (interfaces have no fields). Re-resolve through the
			// receiver's struct type record so the cloned op stream's
			// `selfFieldLoad`/`selfFieldStore` ops still find the right slot.
			// If the receiver isn't a registered struct (e.g. generic instance
			// whose base stayed unresolved) or the field name isn't on the
			// struct, drop the alias — lowering will surface a clean diagnostic
			// rather than us carrying the interface's offset-of-zero forward.
			if let receiverStruct = try project.structTypes.get(receiverTypeName) 'haveStruct'
				if let resolvedField = try findFieldOnStruct(receiverStruct, fieldName: name) 'haveField'
					newType = substituteWithIfaceFold(project, t: resolvedField.fieldType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed)
					dst.installVerbatim(VarInfo.createSelfField(name, varType: newType, slot: dstSlot, offset: resolvedField.offset))
				end 'haveField'
				continue
			end 'haveStruct'
			continue
		end 'selfField'
		if info.isPayloadBinding 'payload'
			dst.installVerbatim(VarInfo.createPayloadBinding(name, varType: newType, mutable: info.mutable, slot: dstSlot, scrutineeName: info.payloadScrutineeName, fieldIndex: info.payloadFieldIndex, caseName: info.payloadCaseName))
			continue
		end 'payload'
		dst.installVerbatim(VarInfo.create(name, varType: newType, mutable: info.mutable, slot: dstSlot))
	end 'eachVar'
	dst.setNextSlot(maxDstSlot)
	return dst
end 'cloneScopeWithSubst'

// Result shape for `findFieldOnStruct`: the field's substituted type plus
// the receiver-struct offset that `selfFieldLoad`/`selfFieldStore` need.
export type FieldInfoForClone
	export var fieldType as MaxonType
	export var offset as FieldOffset

	export static function create(fieldType MaxonType, offset FieldOffset) returns FieldInfoForClone
		return Self{fieldType: fieldType, offset: offset}
	end 'create'
end 'FieldInfoForClone'

export enum MonomorphFieldLookupError implements Error
	notFound
end 'MonomorphFieldLookupError'

// Lookup-by-name on a struct's fields. Pulled out of `cloneScopeWithSubst`
// so the cloner stays focused on substitution while still surfacing a
// throwing miss the caller can turn into "drop the alias".
function findFieldOnStruct(structType StructType, fieldName String) returns FieldInfoForClone throws MonomorphFieldLookupError
	for f in structType.fields 'eachField'
		if f.name == fieldName 'hit'
			return FieldInfoForClone.create(f.fieldType, offset: f.offset)
		end 'hit'
	end 'eachField'
	throw MonomorphFieldLookupError.notFound
end 'findFieldOnStruct'

// One queued per-receiver closure specialization. Produced when the cloner
// walks a `closureCreate` or `functionRef` op inside a monomorphized
// extension body; consumed by `drainClosureSpecQueue` which clones the
// closure body under the specialized name and re-runs substitution against
// the same (receiver, interface) pair so the body's interface-typed calls
// re-resolve through the concrete receiver.
//
// `srcModule` is the module that owns `srcFunc`'s blocks/ops (user module
// or `stdlibParsedModule`). Captured separately because the source closure
// body may live in a different module than the parent it was discovered in
// — same fallback the parent uses at monomorphizeInterfaceExtension's
// `tryStdlib` branch.
export type ClosureSpecEntry
	export var srcName as String
	export var specName as String
	export var srcFunc as IrFunction
	export var srcModule as MaxonModule

	export static function create(srcName String, specName String, srcFunc IrFunction, srcModule MaxonModule) returns ClosureSpecEntry
		return Self{srcName: srcName, specName: specName, srcFunc: srcFunc, srcModule: srcModule}
	end 'create'
end 'ClosureSpecEntry'

export typealias ClosureSpecArray = Array with ClosureSpecEntry

// (src, dst) opIdx pair for cloned call ops that need their
// `project.resolvedCallees` entry re-keyed under the new opIdx with the
// receiver-substituted callee. Collected during the op-clone walk;
// drained by `rewriteClonedResolvedCallees` once the walk completes.
export type OpIndexPair
	export var srcOpIdx as OpIndex
	export var dstOpIdx as OpIndex

	export static function create(srcOpIdx OpIndex, dstOpIdx OpIndex) returns OpIndexPair
		return Self{srcOpIdx: srcOpIdx, dstOpIdx: dstOpIdx}
	end 'create'
end 'OpIndexPair'

export typealias OpIndexPairArray = Array with OpIndexPair

// Rewrite a `call`/`tryCall` op's callee bytes when the original callee
// is a sibling-qualified interface method (e.g. `Tagger.tag`) — the
// monomorphized body must call the concrete receiver's method
// (`Three.tag`). Bare unqualified callees (e.g. `tag` before resolution
// stamped a qualifier) and concrete-qualified callees that already point
// at non-interface methods pass through unchanged.
//
// We intern the rewritten name through `project.calleeNames` so identity
// comparisons elsewhere in the pipeline keep working — the interner is
// the canonical source of stable ByteArray pointers.
function substituteCalleeBytes(project Project, callee ByteArray, ifaceName String, receiverTypeName String) returns ByteArray
	let calleeStr = String.from(callee)
	let ifacePrefix = "{ifaceName}."
	if not calleeStr.startsWith(ifacePrefix) 'noMatch'
		return callee
	end 'noMatch'
	let bytes = calleeStr.toByteArray()
	let prefixLen = ifacePrefix.toByteArray().count()
	let methodSuffix = byteSliceToString(bytes, startIndex: prefixLen, endIndex: bytes.count())
	let rewritten = "{receiverTypeName}.{methodSuffix}"
	return project.calleeNames.intern(rewritten)
end 'substituteCalleeBytes'

// Rewrite a `call`/`tryCall` op's CallContext for a monomorphized body.
// The parser stamps unqualified callees inside a `type/extension Foo`
// block with `sibling(Foo)`; after monomorphization the body is logically
// inside a `type/extension Bar` (the concrete receiver), so the sibling
// context must follow. Without this, type resolution would re-qualify a
// bare `tag()` call to the still-abstract `Tagger.tag` and lowering
// would either dispatch via interface (when the resolver populates a
// receiver type) or call the interface-method symbol directly (when it
// doesn't), neither of which gives us per-receiver dispatch.
//
// `free` and `qualified` contexts pass through unchanged: they don't
// depend on a type namespace at resolution time.
//
// `sibling(name)` only re-targets when `name == ifaceName`. Closures
// nested inside the lifted body may have their own type-namespace from
// some other source (e.g. a struct constructor that happens to live in
// the closure body); rewriting unrelated sibling contexts would break
// their resolution.
function substituteCallContext(callContext CallContext, ifaceName String, receiverTypeName String) returns CallContext
	return match callContext 'k'
		free gives CallContext.free
		qualified gives CallContext.qualified
		sibling(typeName) gives CallContext.sibling(receiverTypeName) if typeName == ifaceName else CallContext.sibling(typeName)
	end 'k'
end 'substituteCallContext'

// Predicate: does this op need its `resolvedCallees` translation when its
// containing function is cloned for a specific receiver? True for every
// `call` / `methodCall` shape; false for everything else.
function opNeedsResolvedCalleeRewrite(op MaxonOp) returns bool
	let n = op.name
	return n == "call" or n == "methodCall" or n == "tryCall" or n == "tryMethodCall"
end 'opNeedsResolvedCalleeRewrite'

// For every cloned call op, copy `project.resolvedCallees[srcOpIdx]` to
// the new opIdx — substituting `{ifaceName}.method` with
// `{receiverTypeName}.method` when the original resolution pointed at an
// interface method. The substitution is what makes the per-receiver
// closure clone call the concrete `Three.tag` / `Seven.tag` instead of
// sharing whatever resolution the source op happened to land on.
//
// Source ops without an entry in `resolvedCallees` (e.g. an ambiguous
// call site that already emitted E3007) are skipped: lowering would
// have panicked on the original too, so the cloned op's missing entry
// surfaces the same problem in the same place.
function rewriteClonedResolvedCallees(project Project, dstModule MaxonModule, pairs OpIndexPairArray, ifaceName String, receiverTypeName String)
	for pair in pairs 'each'
		// Compute the desired qualified callee from the cloned op's callee
		// + callContext. We've already rewritten `sibling(ifaceName)` to
		// `sibling(receiverTypeName)` in `substituteCallContext`, so the
		// op's stored context drives the correct resolution.
		let clonedOp = try dstModule.ops.get(pair.dstOpIdx) otherwise continue
		let qualifiedTarget = qualifiedCalleeFromClonedCall(project, op: clonedOp, ifaceName: ifaceName, receiverTypeName: receiverTypeName)
		if qualifiedTarget.isEmpty() 'noTarget'
			// Not a call shape we can pre-resolve; leave resolvedCallees
			// to the post-clone walker.
			continue
		end 'noTarget'
		try project.resolvedCallees.insert(pair.dstOpIdx, value: qualifiedTarget) otherwise ignore
		// Mirror `resolvedReceiverTypes` from src when present — call ops
		// usually don't carry one (free-call shape), but methodCall does.
		if let srcReceiverType = try project.resolvedReceiverTypes.get(pair.srcOpIdx) 'haveRecvType'
			try project.resolvedReceiverTypes.insert(pair.dstOpIdx, value: srcReceiverType) otherwise ignore
		end 'haveRecvType'
		if let srcParamTypes = try project.callParamTypes.get(pair.srcOpIdx) 'haveParamTypes'
			try project.callParamTypes.insert(pair.dstOpIdx, value: srcParamTypes) otherwise ignore
		end 'haveParamTypes'
	end 'each'
end 'rewriteClonedResolvedCallees'

// Compute the qualified callee that a cloned call op should resolve to,
// given its callee bytes and substituted callContext. Returns "" when the
// op is not a call-shape or when we don't have enough info to pre-resolve.
function qualifiedCalleeFromClonedCall(project Project, op MaxonOp, ifaceName String, receiverTypeName String) returns String
	let extracted = extractCalleeAndContext(op)
	if extracted.calleeStr.isEmpty() 'notACall'
		return ""
	end 'notACall'
	let bare = extracted.calleeStr
	// Already-qualified callee with the interface prefix: rewrite to receiver.
	let ifacePrefix = "{ifaceName}."
	if bare.startsWith(ifacePrefix) 'qualifiedIface'
		let bareBytes = bare.toByteArray()
		let prefixLen = ifacePrefix.toByteArray().count()
		let methodSuffix = byteSliceToString(bareBytes, startIndex: prefixLen, endIndex: bareBytes.count())
		return "{receiverTypeName}.{methodSuffix}"
	end 'qualifiedIface'
	// Bare callee inside a `sibling(receiverTypeName)` context: qualify to receiver.
	let siblingTypeName = siblingTypeNameOfContext(extracted.context)
	if siblingTypeName == receiverTypeName 'siblingMatch'
		let candidate = "{receiverTypeName}.{bare}"
		if project.funcReturnTypes.contains(candidate) 'isRegistered'
			return candidate
		end 'isRegistered'
		if project.overloadedNames.contains(candidate) 'isOverloaded'
			return candidate
		end 'isOverloaded'
	end 'siblingMatch'
	return ""
end 'qualifiedCalleeFromClonedCall'

// Carrier for extractCalleeAndContext output. `calleeStr` is empty when
// the op isn't a call shape.
type CalleeAndContext
	export var calleeStr as String
	export var context as CallContext

	export static function create(calleeStr String, context CallContext) returns CalleeAndContext
		return Self{calleeStr: calleeStr, context: context}
	end 'create'

	export static function none() returns CalleeAndContext
		return Self{calleeStr: "", context: CallContext.free}
	end 'none'
end 'CalleeAndContext'

function extractCalleeAndContext(op MaxonOp) returns CalleeAndContext
	let n = op.name
	if n == "call" 'isCall'
		match op 'm'
			call(_, callee, callContext, _, _, _, _, _) then return CalleeAndContext.create(String.from(callee), context: callContext)
			default panic("extractCalleeAndContext: name=call but match failed")
		end 'm'
	end 'isCall'
	if n == "tryCall" 'isTryCall'
		match op 'm'
			tryCall(_, callee, callContext, _, _, _, _, _, _) then return CalleeAndContext.create(String.from(callee), context: callContext)
			default panic("extractCalleeAndContext: name=tryCall but match failed")
		end 'm'
	end 'isTryCall'
	return CalleeAndContext.none()
end 'extractCalleeAndContext'

// Compute the receiver-specialized name for a closure and, if not already
// queued or already emitted, push a ClosureSpecEntry so the drain loop
// produces the cloned body. Returns the specialized name (which the caller
// stamps onto the outgoing `closureCreate`/`functionRef` op's funcName).
//
// Dedup is by `specName`: the same closure referenced from multiple call
// sites in one parent body, OR a closure already specialized in a prior
// monomorphization for the same receiver, both short-circuit to a single
// emission. The dedup walks `dstModule.functions` linearly because the
// monomorphization cache works at the (receiver, calleeQualified) level
// — not the closure level — so we have no Map to consult.
function specializeClosureName(srcName String, receiverTypeName String, queue ClosureSpecArray, parentSrcModule MaxonModule, dstModule MaxonModule, project Project) returns String
	let specName = "{srcName}${receiverTypeName}"

	// Dedup against the in-flight queue.
	for entry in queue 'eachQueued'
		if entry.specName == specName 'hit'
			return specName
		end 'hit'
	end 'eachQueued'

	// Dedup against already-emitted functions (e.g. a second
	// monomorphization for the same receiver type encounters the
	// already-cloned closure).
	if let _ = try findFunctionIndexByName(dstModule, name: specName) 'alreadyEmitted'
		return specName
	end 'alreadyEmitted'

	// Locate the source closure body. Try the destination user module
	// first (closures lifted from user code live there), then the
	// parent's owning module (covers stdlib-defined closures when the
	// parent monomorphization sourced from `stdlibParsedModule`), then
	// `stdlibParsedModule` outright. This mirrors the parent-lookup
	// order in `monomorphizeInterfaceExtension`.
	if let userIdx = try findFunctionIndexByName(dstModule, name: srcName) 'userHit'
		let srcFunc = try dstModule.functions.get(userIdx) otherwise panic("specializeClosureName: dstModule.functions.get OOB after findFunctionIndexByName")
		queue.push(ClosureSpecEntry.create(srcName, specName: specName, srcFunc: srcFunc, srcModule: dstModule))
		return specName
	end 'userHit' else 'tryParent'
		if let parentIdx = try findFunctionIndexByName(parentSrcModule, name: srcName) 'parentHit'
			let srcFunc = try parentSrcModule.functions.get(parentIdx) otherwise panic("specializeClosureName: parentSrcModule.functions.get OOB after findFunctionIndexByName")
			queue.push(ClosureSpecEntry.create(srcName, specName: specName, srcFunc: srcFunc, srcModule: parentSrcModule))
			return specName
		end 'parentHit' else 'tryStdlib'
			let stdlibModule = getStdlibParsedModule(project)
			let stdlibIdx = try findFunctionIndexByName(stdlibModule, name: srcName) otherwise panic("specializeClosureName: closure body '{srcName}' not found in user module, parent source module, or stdlib parsed module")
			let srcFunc = try stdlibModule.functions.get(stdlibIdx) otherwise panic("specializeClosureName: stdlibModule.functions.get OOB after findFunctionIndexByName")
			queue.push(ClosureSpecEntry.create(srcName, specName: specName, srcFunc: srcFunc, srcModule: stdlibModule))
			return specName
		end 'tryStdlib'
	end 'tryParent'
end 'specializeClosureName'

// Closure references encountered during interface-extension monomorphization.
//
// Each `closureCreate` / `functionRef` arm rewrites the op's `funcName` to
// the receiver-specialized form and queues a ClosureSpecEntry on the
// cloner-local `queue`. The post-clone `drainClosureSpecQueue` walks the
// queue and clones each closure body under its specialized name, applying
// the same substitution. Nested closure refs encountered during a recursive
// clone cascade naturally — `specializeClosureName` pushes them onto the
// same queue, which the drain loop processes until empty.
//
// Why always-specialize (no "is the closure body generic?" gate): the
// receiver-qualified name `_$closure_N$Receiver` can't collide with any
// other receiver's clone or with the original unspecialized body, so we
// avoid every counter-coordination edge case the C# bootstrap's gated
// version had to worry about. Lifted closure bodies are tiny; one extra
// clone per (closure, receiver) pair is negligible compile cost. Byte-
// identical clones can be deduped by a later DCE pass if it becomes a
// concern; it isn't today.
function rewriteClosureRefOnMonomorph(result ByteArray, funcName String, fnTypeId FunctionTypeId, range SourceRange, receiverTypeName String, queue ClosureSpecArray, parentSrcModule MaxonModule, dstModule MaxonModule, project Project) returns MaxonOp
	let specName = specializeClosureName(funcName, receiverTypeName: receiverTypeName, queue: queue, parentSrcModule: parentSrcModule, dstModule: dstModule, project: project)
	return MaxonOp.functionRef(result, funcName: specName, fnTypeId: fnTypeId, range: range)
end 'rewriteClosureRefOnMonomorph'

function rewriteClosureCreateOnMonomorph(result ByteArray, funcName String, fnTypeId FunctionTypeId, capturedNames StringArray, capturedTypes MaxonTypeArray, range SourceRange, receiverTypeName String, queue ClosureSpecArray, parentSrcModule MaxonModule, dstModule MaxonModule, project Project) returns MaxonOp
	let specName = specializeClosureName(funcName, receiverTypeName: receiverTypeName, queue: queue, parentSrcModule: parentSrcModule, dstModule: dstModule, project: project)
	return MaxonOp.closureCreate(result, funcName: specName, fnTypeId: fnTypeId, capturedNames: capturedNames, capturedTypes: capturedTypes, range: range)
end 'rewriteClosureCreateOnMonomorph'

// Clone a MaxonOp with the supplied substitution applied to every
// embedded MaxonType field. Centralised arm-by-arm transform so every op
// shape is handled explicitly — a missing arm raises an unhandled-arm
// compiler error rather than silently passing through an op with stale
// generic types.
//
// `queue` accumulates ClosureSpecEntry records as `closureCreate` and
// `functionRef` arms encounter closure references that must be specialized
// per receiver. `parentSrcModule` is the module that owned the parent body
// being cloned (used by `specializeClosureName` as the second lookup
// fallback when the closure body isn't in `dstModule`). `dstModule` is the
// user module where the specialized clone will be emitted. `receiverTypeName`
// is the concrete type's name, used as the per-receiver suffix.
function substituteOp(project Project, op MaxonOp, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType, slotRemap SlotRemap, queue ClosureSpecArray, parentSrcModule MaxonModule, dstModule MaxonModule, receiverTypeName String, ifaceName String) returns MaxonOp
	return match op 'k'
		literal(result, value, valueType, range) gives MaxonOp.literal(result, value: value, valueType: substituteWithIfaceFold(project, t: valueType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		stringConst gives op
		charLiteral gives op
		byteStringLiteral gives op
		stringInterp gives op
		varDecl(slotId, value, slotType, range) gives MaxonOp.varDecl(slotRemap.resolve(slotId), value: value, slotType: substituteWithIfaceFold(project, t: slotType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		varLoad(result, slotId, slotType, range) gives MaxonOp.varLoad(result, slotId: slotRemap.resolve(slotId), slotType: substituteWithIfaceFold(project, t: slotType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		varStore(slotId, value, range) gives MaxonOp.varStore(slotRemap.resolve(slotId), value: value, range: range)
		globalLoad(result, name, slotType, range) gives MaxonOp.globalLoad(result, name: name, slotType: substituteWithIfaceFold(project, t: slotType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		globalStore(name, value, slotType, range) gives MaxonOp.globalStore(name, value: value, slotType: substituteWithIfaceFold(project, t: slotType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		binop(result, left, right, opKind, operandType, range) gives MaxonOp.binop(result, left: left, right: right, opKind: opKind, operandType: substituteWithIfaceFold(project, t: operandType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		unop(result, operand, opKind, operandType, range) gives MaxonOp.unop(result, operand: operand, opKind: opKind, operandType: substituteWithIfaceFold(project, t: operandType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		convert(result, operand, fromType, toType, implicit, range) gives MaxonOp.convert(result, operand: operand, fromType: substituteWithIfaceFold(project, t: fromType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), toType: substituteWithIfaceFold(project, t: toType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), implicit: implicit, range: range)
		castCheck gives op
		cmp(result, left, right, predicate, leftType, rightType, operandType, range) gives MaxonOp.cmp(result, left: left, right: right, predicate: predicate, leftType: substituteWithIfaceFold(project, t: leftType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), rightType: substituteWithIfaceFold(project, t: rightType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), operandType: substituteWithIfaceFold(project, t: operandType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		refEq gives op
		condBr gives op
		br gives op
		call(result, callee, callContext, args, argLabels, argTypes, argRanges, range) gives MaxonOp.call(result, callee: substituteCalleeBytes(project, callee: callee, ifaceName: ifaceName, receiverTypeName: receiverTypeName), callContext: substituteCallContext(callContext, ifaceName: ifaceName, receiverTypeName: receiverTypeName), args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, range: range)
		methodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, range) gives MaxonOp.methodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, range: range)
		ret gives op
		panic gives op
		panicDynamic gives op
		structAlloc gives op
		fieldLoad gives op
		fieldStore gives op
		selfFieldLoad gives op
		selfFieldStore gives op
		unresolvedRead gives op
		unresolvedAssign gives op
		enumMatchArm(scrutineeName, caseName, scrutineeType, rawValue, isFloat, resolved, thenTarget, elseTarget, bindingNames, range) gives MaxonOp.enumMatchArm(scrutineeName, caseName: caseName, scrutineeType: substituteWithIfaceFold(project, t: scrutineeType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), rawValue: rawValue, isFloat: isFloat, resolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, bindingNames: bindingNames, range: range)
		enumConstruct gives op
		enumTag gives op
		enumPayloadRead(result, enumValName, caseName, fieldIndex, fieldType, range) gives MaxonOp.enumPayloadRead(result, enumValName: enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: substituteWithIfaceFold(project, t: fieldType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		enumPayloadStore(enumValName, caseName, fieldIndex, fieldType, newValueName, range) gives MaxonOp.enumPayloadStore(enumValName, caseName: caseName, fieldIndex: fieldIndex, fieldType: substituteWithIfaceFold(project, t: fieldType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), newValueName: newValueName, range: range)
		rangeMatchArm gives op
		error gives op
		throw gives op
		tryCall(result, callee, callContext, args, argLabels, argTypes, argRanges, errorBoundName, range) gives MaxonOp.tryCall(result, callee: substituteCalleeBytes(project, callee: callee, ifaceName: ifaceName, receiverTypeName: receiverTypeName), callContext: substituteCallContext(callContext, ifaceName: ifaceName, receiverTypeName: receiverTypeName), args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, errorBoundName: errorBoundName, range: range)
		tryMethodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, errorBoundName, range) gives MaxonOp.tryMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, errorBoundName: errorBoundName, range: range)
		rethrow gives op
		functionRef(result, funcName, fnTypeId, range) gives rewriteClosureRefOnMonomorph(result, funcName: funcName, fnTypeId: fnTypeId, range: range, receiverTypeName: receiverTypeName, queue: queue, parentSrcModule: parentSrcModule, dstModule: dstModule, project: project)
		closureCreate(result, funcName, fnTypeId, capturedNames, capturedTypes, range) gives rewriteClosureCreateOnMonomorph(result, funcName: funcName, fnTypeId: fnTypeId, capturedNames: capturedNames, capturedTypes: substituteTypeArray(project, types: capturedTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range, receiverTypeName: receiverTypeName, queue: queue, parentSrcModule: parentSrcModule, dstModule: dstModule, project: project)
		closureEnvLoad(result, captureIndex, captureName, captureType, range) gives MaxonOp.closureEnvLoad(result, captureIndex: captureIndex, captureName: captureName, captureType: substituteWithIfaceFold(project, t: captureType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		indirectCall(result, callee, fnTypeId, args, argLabels, argTypes, argRanges, range) gives MaxonOp.indirectCall(result, callee: callee, fnTypeId: fnTypeId, args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, range: range)
		forInIterable(iterName, iterSlot, iterType, sourceValue, sourceType, bodyBlockId, exitBlockId, label, range) gives MaxonOp.forInIterable(iterName, iterSlot: slotRemap.resolve(iterSlot), iterType: substituteWithIfaceFold(project, t: iterType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), sourceValue: sourceValue, sourceType: substituteWithIfaceFold(project, t: sourceType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), bodyBlockId: bodyBlockId, exitBlockId: exitBlockId, label: label, range: range)
		asyncCall(result, callee, callContext, args, argLabels, argTypes, argRanges, innerType, calleeThrows, callSourceText, range) gives MaxonOp.asyncCall(result, callee: substituteCalleeBytes(project, callee: callee, ifaceName: ifaceName, receiverTypeName: receiverTypeName), callContext: substituteCallContext(callContext, ifaceName: ifaceName, receiverTypeName: receiverTypeName), args: args, argLabels: argLabels, argTypes: substituteTypeArray(project, types: argTypes, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), argRanges: argRanges, innerType: substituteWithIfaceFold(project, t: innerType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), calleeThrows: calleeThrows, callSourceText: callSourceText, range: range)
		awaitPromise(result, promise, innerType, promiseType, range) gives MaxonOp.awaitPromise(result, promise: promise, innerType: substituteWithIfaceFold(project, t: innerType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), promiseType: substituteWithIfaceFold(project, t: promiseType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), range: range)
		tryAwait(result, promise, innerType, promiseType, errorBoundName, range) gives MaxonOp.tryAwait(result, promise: promise, innerType: substituteWithIfaceFold(project, t: innerType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), promiseType: substituteWithIfaceFold(project, t: promiseType, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed), errorBoundName: errorBoundName, range: range)
		cancelPromise gives op
	end 'k'
end 'substituteOp'

// Apply substitution to each entry of a MaxonTypeArray, producing a fresh
// array. Used by ops that carry `argTypes` / `capturedTypes` parallel-to-
// args lists. Always returns a new array even when no entry changed —
// downstream consumers may mutate the array in place (today they don't,
// but defensive ownership avoids future aliasing bugs at low cost).
function substituteTypeArray(project Project, types MaxonTypeArray, subst TypeSubstitution, ifaceType MaxonType, receiverNamed MaxonType) returns MaxonTypeArray
	var fresh = MaxonTypeArray.create()
	for t in types 'each'
		fresh.push(substituteWithIfaceFold(project, t: t, subst: subst, ifaceType: ifaceType, receiverNamed: receiverNamed))
	end 'each'
	return fresh
end 'substituteTypeArray'

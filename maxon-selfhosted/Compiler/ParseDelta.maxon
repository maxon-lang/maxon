	delta.tupleAllocGidsKeys.push(key)
end 'recordTupleAllocGidUpsert'

export function recordModuleInitFuncPush(project Project, filePath FilePath, name String)
	var delta = ensureDelta(project, filePath: filePath)
	delta.moduleInitFuncsAppended.push(name)
end 'recordModuleInitFuncPush'


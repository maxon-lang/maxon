// Self-hosted Maxon compiler core.

// Convenience wrapper: compiles a file or directory and returns the output executable path.
export function compile(path String, target TargetTriple) returns String throws CompileError
    var project = createProject(path, isSingleFile: false, target: target)
    return try compileProject(project)
end 'compile'

// Compiles a project and returns the output executable path.
export function compileProject(project Project) returns String throws CompileError
    logDebug(LogCategory.compiler, message: "Starting incremental compilation")

    if not project.dbInitialized 'init'
        project.db = QueryDatabase{
            currentRevision: 1,
            sourceFiles: SourceFileMap{},
            sourcePaths: StringArray{},
            tokenCache: TokenCacheMap{},
            parseCache: ParseCacheMap{},
            allMaxonOpsCache: MaxonOpsMemo{value: MaxonOpArray{}, computedAt: 0, verifiedAt: 0},
            allStdOpsCache: StdOpsMemo{value: StdOpArray{}, computedAt: 0, verifiedAt: 0},
            codeCache: CodeMemo{value: CodeResult{code: ByteBuffer{}, mainCallFixupOffset: 0, osFixups: OsFixups.none}, computedAt: 0, verifiedAt: 0},
            dependencies: DependencyArray{},
            activeQueryStack: QueryKeyArray{},
            tokenHits: 0, tokenMisses: 0,
            parseHits: 0, parseMisses: 0,
            allMaxonOpsHits: 0, allMaxonOpsMisses: 0,
            allStdOpsHits: 0, allStdOpsMisses: 0,
            codeHits: 0, codeMisses: 0
        }
        project.dbInitialized = true
    end 'init'

    try loadSourceFiles(project, path: project.rootPath)

    logDebug(LogCategory.compiler, message: "Loaded {project.db.sourcePaths.count()} source files (revision {project.db.currentRevision})")

    let codeResult = try queryCodeResult(project)

    let firstPath = try project.db.sourcePaths.get(0) otherwise 'noFiles'
        throw CompileError.noSourceFiles
    end 'noFiles'

    let ext = executableExtension(project.target)
    let outputPath = changeExtension(firstPath, ext: ext)
    writeExecutable(outputPath, codeResult: codeResult, target: project.target)

    logInfo(LogCategory.compiler, message: "Wrote {codeResult.code.count()} bytes code to {outputPath}")
    return outputPath
end 'compileProject'

// Notify the query database that a single file has changed (for IDE use).
export function fileChanged(project Project, path String, content ByteArray)
    if project.dbInitialized 'ready'
        setSourceFile(project, path: path, content: content)
    end 'ready'
end 'fileChanged'

// --- Source file loading ---

// ByteBuffer (Array with Byte) and ByteArray (Array with Utf8Byte) share the same memory layout
export function bytesToByteArray(buf ByteBuffer) returns ByteArray
    return ByteArray{managed: buf.managed}
end 'bytesToByteArray'

function loadSourceFiles(project Project, path String) throws CompileError
    if File.exists(path) 'isFile'
        logTrace(LogCategory.compiler, message: "Loading single file: {path}")
        let bytes = try File.readBinary(path) otherwise 'readErr'
            throw CompileError.readError
        end 'readErr'
        setSourceFile(project, path: path, content: bytesToByteArray(bytes))
    end 'isFile' else if Directory.exists(path) 'isDir'
        logTrace(LogCategory.compiler, message: "Loading directory: {path}")
        let dirEntries = try Directory.list(path) otherwise 'listErr'
            throw CompileError.directoryNotFound
        end 'listErr'

        for name in dirEntries 'loop'
            if name.endsWith(".maxon") 'isMaxon'
                let filePath = "{path}\\{name}"
                logTrace(LogCategory.compiler, message: "Loading file: {filePath}")
                let bytes = try File.readBinary(filePath) otherwise 'skip'
                    continue
                end 'skip'
                setSourceFile(project, path: filePath, content: bytesToByteArray(bytes))
            end 'isMaxon'
        end 'loop'
    end 'isDir' else 'notFound'
        throw CompileError.fileNotFound
    end 'notFound'

    if project.db.sourcePaths.count() == 0 'noFiles'
        throw CompileError.noSourceFiles
    end 'noFiles'
end 'loadSourceFiles'

function changeExtension(path String, ext String) returns String
    let dotIdx = try path.findLast(".") otherwise path.endIndex()
    let base = path.slice(path.startIndex(), endIndex: dotIdx)
    return base.concat(ext)
end 'changeExtension'

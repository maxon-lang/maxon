// Convenience wrapper: compiles a file or directory and returns the output executable path.
// When `irDump.enabled()` is true, the project-wide query cache is bypassed
// so the pipeline re-runs and the printer hooks observe fresh modules.
export function compile(path FilePath, target Target, coverage bool = false, irDump IrDumpOptions = IrDumpOptions.disabled(), irOutputPath FilePath = FilePath from "") returns FilePath throws CompileError
	var project = createProject(path, target: target)
	project.coverageEnabled = coverage
	project.irDump = irDump
	let outputPath = try compileProject(project)

	// Write the final .ir file for --emit-ir. The code cache is populated by
	// compileProject above; caching is disabled when emitFinal is true so the
	// module reflects the just-finished compile. skipStdlib: true matches
	// the C# compiler's --emit-ir filter.
	if irDump.emitFinal 'hasEmit'
		let codeResult = project.db.codeCache.value
		let ir = finalIrString(project, codeResult: codeResult, skipStdlib: true)
		try File.writeText(irOutputPath, content: ir) otherwise 'writeErr'
			logInfo(LogCategory.compiler, message: () gives "emit-ir: failed to write {irOutputPath}")
		end 'writeErr'
	end 'hasEmit'

	return outputPath
end 'compile'

// Pick the IR string appropriate for `--emit-ir` / the CompiledIR section of
// spec fragments. Native targets print the fully-lowered TargetModule;
// WASM bypasses target lowering so we fall back to the MIR.
export function finalIrString(project Project, codeResult CodeResult, skipStdlib bool) returns String
	if project.target.cpu == CpuArch.wasm32 'isWasm'
		return mirModuleToString(codeResult.mirModule, skipStdlib: skipStdlib)
	end 'isWasm'
	return targetModuleToString(codeResult.targetModule, skipStdlib: skipStdlib, cpu: project.target.cpu)
end 'finalIrString'

// Emit the companion .covmap so the aggregator can join per-site counters
// to source lines. Non-coverage builds stay byte-for-byte identical to
// pre-coverage builds — this writes nothing when coverage is disabled.
// `covMapPath` is the destination; callers that want the default "next to
// the exe" placement pass outputPath.changeExtension(".covmap").
function writeCovMapTo(project Project, covMapPath FilePath)
	if not project.coverageEnabled 'skip'
		return
	end 'skip'
	try writeCovMap(project.covSites, path: covMapPath) otherwise 'noWrite'
		logInfo(LogCategory.compiler, message: () gives "Failed to write covmap to {covMapPath}")
	end 'noWrite'
end 'writeCovMapTo'

// Compiles source code directly from memory (no temp file) and returns IR.
// The caller picks `covMapPath`. `maxon build --coverage` wants the covmap
// next to the exe (outputPath.changeExtension(".covmap")); the spec runner
// redirects it into its per-suite .coverage directory. When coverage is off
// the path is ignored — no file is written.
export function compileSourceWithIr(source String, virtualPath FilePath, target Target, outputPath FilePath, coverage bool, covMapPath FilePath) returns CompileWithIrResult throws CompileError
	var project = createProject(outputPath, target: target)
	project.coverageEnabled = coverage
	fileChanged(project, path: virtualPath, content: source)

	return try finishInMemoryCompile(project, outputPath: outputPath, covMapPath: covMapPath)
end 'compileSourceWithIr'

// One in-memory file passed to the multi-file compile entry point. Defined
// here (not borrowed from the test runner) so the compiler stays free of
// `Testing/` types — callers populate this from whatever source-of-truth
// they have (spec-parsed fragments, language server, etc.).
export type VirtualSourceFile
	export var path FilePath
	export var source String

	export static function create(path FilePath, source String) returns VirtualSourceFile
		return Self{path: path, source: source}
	end 'create'
end 'VirtualSourceFile'

export typealias VirtualSourceFileArray = Array with VirtualSourceFile

// Multi-file variant of `compileSourceWithIr`: feed each pre-resolved
// virtual file to the project as a distinct compilation unit. Used by spec
// tests that author `// --- file: name.maxon` markers so cross-file
// references (exports, module visibility within a directory subtree)
// resolve the same way they would in a real on-disk project. The caller is
// responsible for choosing virtual paths whose layout matches the test's
// intent (e.g. siblings under one dir vs. nested subdirectories).
export function compileMultiFileSourceWithIr(files VirtualSourceFileArray, target Target, outputPath FilePath, coverage bool, covMapPath FilePath) returns CompileWithIrResult throws CompileError
	if files.count() == 0 'noFiles'
		throw CompileError.noSourceFiles(outputPath)
	end 'noFiles'

	var project = createProject(outputPath, target: target)
	project.coverageEnabled = coverage
	for file in files 'eachFile'
		fileChanged(project, path: file.path, content: file.source)
	end 'eachFile'

	return try finishInMemoryCompile(project, outputPath: outputPath, covMapPath: covMapPath)
end 'compileMultiFileSourceWithIr'

// Shared tail for the in-memory compile entry points: run the code query,
// write the executable, emit the covmap, and capture IR.
function finishInMemoryCompile(project Project, outputPath FilePath, covMapPath FilePath) returns CompileWithIrResult throws CompileError
	logInfo(LogCategory.compiler, message: () gives "Starting in-memory compilation")
	let codeResult = try queryCodeResult(project)
	writeExecutable(outputPath, codeResult: codeResult, target: project.target, stdlibCache: getStdlibCacheData())
	logInfo(LogCategory.compiler, message: () gives "Wrote {codeResult.code.count()} bytes code to {outputPath}")

	writeCovMapTo(project, covMapPath: covMapPath)

	let ir = finalIrString(project, codeResult: codeResult, skipStdlib: true)
	return CompileWithIrResult.create(outputPath, ir: ir)
end 'finishInMemoryCompile'

export type CompileWithIrResult
	export var outputPath FilePath
	export var ir String

	export static function create(outputPath FilePath, ir String) returns CompileWithIrResult
		return Self{outputPath: outputPath, ir: ir}
	end 'create'
end 'CompileWithIrResult'

// Compiles a project and returns the output executable path.
export function compileProject(project Project) returns FilePath throws CompileError
	logInfo(LogCategory.compiler, message: () gives "Starting incremental compilation")

	try loadSourceFiles(project, path: project.rootPath)

	let codeResult = try queryCodeResult(project)

	let ext = executableExtension(project.target)
	let outputPath = try resolveBuildOutputPath(project, ext: ext)

	writeExecutable(outputPath, codeResult: codeResult, target: project.target, stdlibCache: getStdlibCacheData())

	logInfo(LogCategory.compiler, message: () gives "Wrote {codeResult.code.count()} bytes code to {outputPath}")

	writeCovMapTo(project, covMapPath: outputPath.changeExtension(".covmap"))

	return outputPath
end 'compileProject'

// Resolves the output path: uses build name if available, otherwise falls back to first source file.
function resolveBuildOutputPath(project Project, ext String) returns FilePath throws CompileError
	if let buildName = try parseBuildName(project.rootPath) 'hasBuildName'
		return project.rootPath.join("{buildName}{ext}")
	end 'hasBuildName'
	let firstPath = try project.db.sourcePaths.get(0) otherwise panic("resolveBuildOutputPath: sourcePaths empty — loadSourceFiles should have thrown")
	return firstPath.changeExtension(ext)
end 'resolveBuildOutputPath'

// Parses build.maxon in the project root to extract the build name.
// Throws `BuildNameError.notFound` if no build.maxon or no build("...") call
// is present — callers use `if let` to take the named-build path and fall
// through to deriving the output name from the first source file.
function parseBuildName(projectRoot FilePath) returns String throws BuildNameError
	let buildPath = projectRoot.join("build.maxon")
	let content = try File.readText(buildPath) otherwise throw BuildNameError.notFound
	let marker = "build(\""
	var nameStart = try content.findFirst(marker) otherwise throw BuildNameError.notFound
	// Skip past 'build("' (7 chars) to get to the name
	for _ in 0 upto 7 'skipMarker'
		nameStart = try content.indexAfter(nameStart) otherwise throw BuildNameError.notFound
	end 'skipMarker'
	let rest = content.slice(nameStart, endIndex: content.endIndex())
	let nameEnd = try rest.findFirst("\"") otherwise throw BuildNameError.notFound
	return rest.slice(rest.startIndex(), endIndex: nameEnd)
end 'parseBuildName'

enum BuildNameError implements Error
	notFound
end 'BuildNameError'

// --- Source file loading ---

function loadSourceFiles(project Project, path FilePath) throws CompileError
	if File.exists(path) 'isFile'
		logTrace(LogCategory.compiler, message: () gives "Loading single file: {path}")

		if isIgnoredPath(path) 'ignored'
			return
		end 'ignored'

		let rawContent = try File.readText(path) otherwise throw CompileError.readError(path)

		let content = stripTestFragments(path, content: rawContent)
		fileChanged(project, path: path, content: content)
	end 'isFile' else if Directory.exists(path) 'isDir'
		logTrace(LogCategory.compiler, message: () gives "Loading directory: {path}")

		if isIgnoredPath(path) 'ignored'
			return
		end 'ignored'

		let dirEntries = try Directory.list(path) otherwise throw CompileError.directoryNotFound(path)

		for entry in dirEntries 'loop'
			let name = entry.filename()
			if name == "build.maxon" 'isBuildFile'
				continue
			end 'isBuildFile'
			if name.endsWith(".maxon") 'isMaxon'
				logTrace(LogCategory.compiler, message: () gives "Loading file: {entry}")

				let content = try File.readText(entry) otherwise continue

				fileChanged(project, path: entry, content: content)
			end 'isMaxon'
		end 'loop'

		// Path does not exist.
	end 'isDir' else 'notFound'
		throw CompileError.fileNotFound(path)
	end 'notFound'

	if project.db.sourcePaths.count() == 0 'noFiles'
		throw CompileError.noSourceFiles(path)
	end 'noFiles'
end 'loadSourceFiles'

// Spec `.test` files contain Maxon source followed by one or more `---`
// separators delimiting the expected output. Strip everything from the first
// separator onward so `maxon build foo.test` compiles only the source section.
function stripTestFragments(path FilePath, content String) returns String
	if path.fileExtension() != ".test" 'notTest'
		return content
	end 'notTest'
	let separator = "\n---"
	let sepIndex = try content.findFirst(separator) otherwise return content
	return content.slice(content.startIndex(), endIndex: sepIndex)
end 'stripTestFragments'

function isIgnoredPath(path FilePath) returns bool
	var dir = try path.parent() otherwise return false
	while true 'walk'
		if File.exists(dir.join(".maxonignore")) 'found'
			return true
		end 'found'
		dir = try dir.parent() otherwise return false
	end 'walk'
	return false
end 'isIgnoredPath'

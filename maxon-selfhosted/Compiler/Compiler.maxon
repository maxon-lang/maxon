// Convenience wrapper: compiles a file or directory and returns the output executable path.
// When `irDump.enabled()` is true, the project-wide query cache is bypassed
// so the pipeline re-runs and the printer hooks observe fresh modules.
export function compile(path FilePath, target Target, coverage bool = false, irDump IrDumpOptions = IrDumpOptions.disabled(), irOutputPath FilePath = FilePath from "") returns FilePath throws CompileError
	var project = createProject(path, target: target)
	project.coverageEnabled = coverage
	project.irDump = irDump
	let outputPath = try compileProject(project)

	// Write the final .ir file for --emit-ir. The code cache is populated by
	// compileProject above; caching is disabled when emitFinal is true so the
	// module reflects the just-finished compile. skipStdlib: true matches
	// the C# compiler's --emit-ir filter.
	if irDump.emitFinal 'hasEmit'
		let codeResult = project.db.codeCache.value
		let ir = finalIrString(project, codeResult: codeResult, skipStdlib: true)
		try File.writeText(irOutputPath, content: ir) otherwise 'writeErr'
			logInfo(LogCategory.compiler, message: function() gives "emit-ir: failed to write {irOutputPath}")
		end 'writeErr'
	end 'hasEmit'

	return outputPath
end 'compile'

// Pick the IR string appropriate for `--emit-ir` / the CompiledIR section of
// spec fragments. Native targets print the fully-lowered TargetModule;
// WASM bypasses target lowering so we fall back to the MIR.
//
// When `skipStdlib` is false, append the stdlib's post-DCE StdModule
// snapshot so spec tests with `IncludeStdlibIr: true` can inspect how
// optimization passes shaped the stdlib functions called from user code.
// Stdlib functions live in a separate cached StdModule (compiled once and
// linked from the on-disk cache) and aren't carried in the user pipeline's
// targetModule/mirModule, so they have to be rendered from the loader's
// snapshot rather than the user's final IR.
export function finalIrString(project Project, codeResult CodeResult, skipStdlib bool) returns String
	var ir = ""
	if project.target.cpu == CpuArch.wasm32 'isWasm'
		ir = mirModuleToString(codeResult.mirModule, skipStdlib: skipStdlib)
	end 'isWasm' else 'isNative'
		ir = targetModuleToString(codeResult.targetModule, skipStdlib: skipStdlib, cpu: project.target.cpu)
	end 'isNative'
	if not skipStdlib 'appendStdlib'
		let stdlibModule = getCachedStdlibStdModule()
		if stdlibModule.functions.count() > 0 'haveStdlib'
			let reachable = collectReachableStdlibFunctions(codeResult, stdlibModule: stdlibModule)
			if reachable.count() > 0 'haveReachable'
				ir = "{ir}\n// Stdlib StdModule (post-dce, post-inliner — pre-MIR-lowering, reachable from main only)\n{stdModuleToStringFiltered(stdlibModule, allowedNames: reachable)}"
			end 'haveReachable'
		end 'haveStdlib'
	end 'appendStdlib'
	return ir
end 'finalIrString'

// Walk the user pipeline's final IR (MIR for wasm, TargetModule for native)
// to collect statically-called stdlib function names, then close over the
// stdlib StdModule's own call ops so transitive callees show up too. The
// returned set is the input to `stdModuleToStringFiltered` so the
// IncludeStdlibIr snapshot stays focused on what the test actually exercises
// rather than dumping every stdlib function the cache happens to hold.
function collectReachableStdlibFunctions(codeResult CodeResult, stdlibModule StdModule) returns StdlibFuncNameSet
	var stdlibNames = StdlibFuncNameSet.create()
	for func in stdlibModule.functions 'index'
		stdlibNames.insert(func.name)
	end 'index'

	// MIR is populated for both wasm and native pipelines (the native flow
	// holds it on `codeResult.mirModule` alongside the target module), so
	// walking MIR gives us a single seeding path that works for either CPU.
	let seeds = collectUserCallNamesFromMir(codeResult.mirModule)

	var reachable = StdlibFuncNameSet.create()
	var worklist = StringArray.create()
	for name in seeds 'seedWorklist'
		if stdlibNames.contains(name) and not reachable.contains(name) 'isNew'
			reachable.insert(name)
			worklist.push(name)
		end 'isNew'
	end 'seedWorklist'

	var nameToFunc = StdlibFuncByName.create()
	for func in stdlibModule.functions 'buildIndex'
		nameToFunc.upsert(func.name, value: func)
	end 'buildIndex'

	var wi = 0
	while wi < worklist.count() 'walk'
		let name = try worklist.get(wi) otherwise 'skip'
			wi = wi + 1
			continue
		end 'skip'
		wi = wi + 1
		let func = try nameToFunc.get(name) otherwise continue
		for blockRef in func.blockRefs 'eachBlock'
			let block = try stdlibModule.blocks.get(blockRef) otherwise continue
			for opIdx in block.opRefs 'eachOp'
				let op = try stdlibModule.ops.get(opIdx) otherwise continue
				let calleeName = match op 'extract'
					call(c) gives extractStaticCalleeName(c)
					arith gives ""
					control gives ""
					memory gives ""
					system gives ""
				end 'extract'
				if not calleeName.isEmpty() and stdlibNames.contains(calleeName) and not reachable.contains(calleeName) 'newCallee'
					reachable.insert(calleeName)
					worklist.push(calleeName)
				end 'newCallee'
			end 'eachOp'
		end 'eachBlock'
	end 'walk'

	return reachable
end 'collectReachableStdlibFunctions'

typealias StdlibFuncByName = Map with (String, IrFunction)

function extractStaticCalleeName(op StdCallOp) returns String
	return match op 'shape'
		call(_, callee, _) gives callee
		tryCall(_, callee, _, _) gives callee
		tailCall(callee, _) gives callee
		ret gives ""
		indirectCall gives ""
		witnessCall gives ""
		funcRef gives ""
		param gives ""
		errorReturn gives ""
	end 'shape'
end 'extractStaticCalleeName'

function mirCallCalleeName(op MirOp) returns String
	return match op 'shape'
		call(_, callee, _) gives callee
		tryCall(_, callee, _, _) gives callee
		movImm to branch gives ""
		indirectCall to loadFramePtr gives ""
		osExit to osLockRelease gives ""
		errorReturn gives ""
	end 'shape'
end 'mirCallCalleeName'

function collectUserCallNamesFromMir(module MirModule) returns StringArray
	var seeds = StringArray.create()
	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise continue
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise continue
				let name = mirCallCalleeName(op)
				if not name.isEmpty() 'haveName'
					seeds.push(name)
				end 'haveName'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'
	return seeds
end 'collectUserCallNamesFromMir'

// Emit the companion .covmap so the aggregator can join per-site counters
// to source lines. Non-coverage builds stay byte-for-byte identical to
// pre-coverage builds — this writes nothing when coverage is disabled.
// `covMapPath` is the destination; callers that want the default "next to
// the exe" placement pass outputPath.changeExtension(".covmap").
function writeCovMapTo(project Project, covMapPath FilePath)
	if not project.coverageEnabled 'skip'
		return
	end 'skip'
	try writeCovMap(project.covSites, path: covMapPath) otherwise 'noWrite'
		logInfo(LogCategory.compiler, message: function() gives "Failed to write covmap to {covMapPath}")
	end 'noWrite'
end 'writeCovMapTo'

// Compiles source code directly from memory (no temp file) and returns IR.
// The caller picks `covMapPath`. `maxon build --coverage` wants the covmap
// next to the exe (outputPath.changeExtension(".covmap")); the spec runner
// redirects it into its per-suite .coverage directory. When coverage is off
// the path is ignored — no file is written.
export function compileSourceWithIr(source String, virtualPath FilePath, target Target, outputPath FilePath, coverage bool, covMapPath FilePath, includeStdlibIr bool = false) returns CompileWithIrResult throws CompileError
	let setupStart = passTimerStart()
	// Single-file fragment: rootPath = the file's parent directory (decision #3
	// in the directory-as-module redesign — single-file compiles have no module
	// prefix). Falls back to outputPath only when the virtual file has no
	// parent (defensive — runner always hands us an absolute path).
	let rootPath = try virtualPath.parent() otherwise outputPath
	var project = createProject(rootPath, target: target)
	project.coverageEnabled = coverage
	fileChanged(project, path: virtualPath, content: source)
	recordPassSince("__compile-setup", startMs: setupStart)

	return try finishInMemoryCompile(project, outputPath: outputPath, covMapPath: covMapPath, includeStdlibIr: includeStdlibIr)
end 'compileSourceWithIr'

// One in-memory file passed to the multi-file compile entry point. Defined
// here (not borrowed from the test runner) so the compiler stays free of
// `Testing/` types — callers populate this from whatever source-of-truth
// they have (spec-parsed fragments, language server, etc.).
export type VirtualSourceFile
	export var path as FilePath
	export var source as String

	export static function create(path FilePath, source String) returns VirtualSourceFile
		return Self{path: path, source: source}
	end 'create'
end 'VirtualSourceFile'

export typealias VirtualSourceFileArray = Array with VirtualSourceFile

// Multi-file variant of `compileSourceWithIr`: feed each pre-resolved
// virtual file to the project as a distinct compilation unit. Used by spec
// tests that author `// --- file: name.maxon` markers so cross-file
// references (exports, module visibility within a directory subtree)
// resolve the same way they would in a real on-disk project. The caller is
// responsible for choosing virtual paths whose layout matches the test's
// intent (e.g. siblings under one dir vs. nested subdirectories).
export function compileMultiFileSourceWithIr(files VirtualSourceFileArray, projectRoot FilePath, target Target, outputPath FilePath, coverage bool, covMapPath FilePath, includeStdlibIr bool = false) returns CompileWithIrResult throws CompileError
	if files.count() == 0 'noFiles'
		throw CompileError.noSourceFiles(outputPath)
	end 'noFiles'

	// Multi-file fragment: callers anchor the root explicitly (the spec
	// runner uses the fragment directory; on-disk builds use the project's
	// top-level). Using a fixed anchor matches the C# bootstrap's
	// `multiFileRoot = tempDir` behavior so `feature/helper.maxon` and
	// `feature/sub/deep.maxon` both derive their namespaces relative to the
	// same root (yielding `feature` and `feature.sub` respectively) — a
	// "deepest common ancestor" heuristic instead would collapse two
	// siblings under their nearest shared parent and lose those segments.
	var project = createProject(projectRoot, target: target)
	project.coverageEnabled = coverage
	for file in files 'eachFile'
		fileChanged(project, path: file.path, content: file.source)
	end 'eachFile'

	return try finishInMemoryCompile(project, outputPath: outputPath, covMapPath: covMapPath, includeStdlibIr: includeStdlibIr)
end 'compileMultiFileSourceWithIr'

// Shared tail for the in-memory compile entry points: run the code query,
// write the executable, emit the covmap, and capture IR.
function finishInMemoryCompile(project Project, outputPath FilePath, covMapPath FilePath, includeStdlibIr bool = false) returns CompileWithIrResult throws CompileError
	logInfo(LogCategory.compiler, message: function() gives "Starting in-memory compilation")
	let codeStart = passTimerStart()
	let codeResult = try queryCodeResult(project)
	recordPassSince("__queryCodeResult", startMs: codeStart)

	let writeStart = passTimerStart()
	writeExecutable(outputPath, codeResult: codeResult, target: project.target, stdlibCache: getStdlibCacheData())
	recordPassSince("__writeExecutable", startMs: writeStart)
	logInfo(LogCategory.compiler, message: function() gives "Wrote {codeResult.code.count()} bytes code to {outputPath}")

	writeCovMapTo(project, covMapPath: covMapPath)

	let irStart = passTimerStart()
	let ir = finalIrString(project, codeResult: codeResult, skipStdlib: not includeStdlibIr)
	recordPassSince("__finalIrString", startMs: irStart)
	return CompileWithIrResult.create(outputPath, ir: ir)
end 'finishInMemoryCompile'

export type CompileWithIrResult
	export var outputPath as FilePath
	export var ir as String

	export static function create(outputPath FilePath, ir String) returns CompileWithIrResult
		return Self{outputPath: outputPath, ir: ir}
	end 'create'
end 'CompileWithIrResult'

// Compiles a project and returns the output executable path.
export function compileProject(project Project) returns FilePath throws CompileError
	logInfo(LogCategory.compiler, message: function() gives "Starting incremental compilation")

	try loadSourceFiles(project, path: project.rootPath)

	let codeResult = try queryCodeResult(project)

	let ext = executableExtension(project.target)
	let outputPath = try resolveBuildOutputPath(project, ext: ext)

	writeExecutable(outputPath, codeResult: codeResult, target: project.target, stdlibCache: getStdlibCacheData())

	logInfo(LogCategory.compiler, message: function() gives "Wrote {codeResult.code.count()} bytes code to {outputPath}")

	writeCovMapTo(project, covMapPath: outputPath.changeExtension(".covmap"))

	return outputPath
end 'compileProject'

// Resolves the output path: uses build name if available, otherwise falls back to first source file.
function resolveBuildOutputPath(project Project, ext String) returns FilePath throws CompileError
	if let buildName = try parseBuildName(project.rootPath) 'hasBuildName'
		return project.rootPath.join("{buildName}{ext}")
	end 'hasBuildName'
	let firstPath = try project.db.sourcePaths.get(0) otherwise panic("resolveBuildOutputPath: sourcePaths empty — loadSourceFiles should have thrown")
	return firstPath.changeExtension(ext)
end 'resolveBuildOutputPath'

// Parses build.maxon in the project root to extract the build name.
// Throws `BuildNameError.notFound` if no build.maxon or no build("...") call
// is present — callers use `if let` to take the named-build path and fall
// through to deriving the output name from the first source file.
function parseBuildName(projectRoot FilePath) returns String throws BuildNameError
	let buildPath = projectRoot.join("build.maxon")
	let content = try File.readText(buildPath) otherwise throw BuildNameError.notFound
	let marker = "build(\""
	var nameStart = try content.findFirst(marker) otherwise throw BuildNameError.notFound
	// Skip past 'build("' (7 chars) to get to the name
	for _ in 0 upto 7 'skipMarker'
		nameStart = try content.indexAfter(nameStart) otherwise throw BuildNameError.notFound
	end 'skipMarker'
	let rest = content.slice(nameStart, endIndex: content.endIndex())
	let nameEnd = try rest.findFirst("\"") otherwise throw BuildNameError.notFound
	return rest.slice(rest.startIndex(), endIndex: nameEnd)
end 'parseBuildName'

enum BuildNameError implements Error
	notFound
end 'BuildNameError'

// --- Source file loading ---

function loadSourceFiles(project Project, path FilePath) throws CompileError
	if File.exists(path) 'isFile'
		logTrace(LogCategory.compiler, message: function() gives "Loading single file: {path}")

		if isIgnoredPath(path) 'ignored'
			return
		end 'ignored'

		let rawContent = try File.readText(path) otherwise throw CompileError.readError(path)

		let content = stripTestFragments(path, content: rawContent)
		fileChanged(project, path: path, content: content)
	end 'isFile' else if Directory.exists(path) 'isDir'
		logTrace(LogCategory.compiler, message: function() gives "Loading directory: {path}")

		if isIgnoredPath(path) 'ignored'
			return
		end 'ignored'

		let dirEntries = try Directory.list(path) otherwise throw CompileError.directoryNotFound(path)

		for entry in dirEntries 'loop'
			let name = entry.filename()
			if name == "build.maxon" 'isBuildFile'
				continue
			end 'isBuildFile'
			if name.endsWith(".maxon") 'isMaxon'
				logTrace(LogCategory.compiler, message: function() gives "Loading file: {entry}")

				let content = try File.readText(entry) otherwise continue

				fileChanged(project, path: entry, content: content)
			end 'isMaxon'
		end 'loop'

		// Path does not exist.
	end 'isDir' else 'notFound'
		throw CompileError.fileNotFound(path)
	end 'notFound'

	if project.db.sourcePaths.count() == 0 'noFiles'
		throw CompileError.noSourceFiles(path)
	end 'noFiles'
end 'loadSourceFiles'

// Spec `.test` files contain Maxon source followed by one or more `---`
// separators delimiting the expected output. Strip everything from the first
// separator onward so `maxon build foo.test` compiles only the source section.
function stripTestFragments(path FilePath, content String) returns String
	if path.fileExtension() != ".test" 'notTest'
		return content
	end 'notTest'
	let separator = "\n---"
	let sepIndex = try content.findFirst(separator) otherwise return content
	return content.slice(content.startIndex(), endIndex: sepIndex)
end 'stripTestFragments'

function isIgnoredPath(path FilePath) returns bool
	var dir = try path.parent() otherwise return false
	while true 'walk'
		if File.exists(dir.join(".maxonignore")) 'found'
			return true
		end 'found'
		dir = try dir.parent() otherwise return false
	end 'walk'
	return false
end 'isIgnoredPath'

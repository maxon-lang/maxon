	return (StdSystemOp.dropTypeParam(slotValueId, layoutValueId: layoutValueId), offset + 16)
end 'readStdSysDropTypeParam'

// --- StdOp outer union ---

function writeStdOp(buf ByteArray, op StdOp) throws CacheCorruption
	writeDword(buf, value: op.ordinal)
	match op 'outer'
		arith(inner) then writeStdArithOp(buf, op: inner)
		control(inner) then writeStdControlOp(buf, op: inner)
		call(inner) then try writeStdCallOp(buf, op: inner)
		memory(inner) then writeStdMemoryOp(buf, op: inner)
		system(inner) then try writeStdSystemOp(buf, op: inner)
	end 'outer'
end 'writeStdOp'

function readStdOp(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	let pos = offset + 4
	return match kase 'outer'
		arith gives try readStdOpArith(buf, offset: pos)
		control gives try readStdOpControl(buf, offset: pos)
		call gives try readStdOpCall(buf, offset: pos)
		memory gives try readStdOpMemory(buf, offset: pos)
		system gives try readStdOpSystem(buf, offset: pos)
	end 'outer'
end 'readStdOp'

function readStdOpArith(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let (inner, p) = try readStdArithOp(buf, offset: offset)
	return (StdOp.arith(inner), p)
end 'readStdOpArith'

function readStdOpControl(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let (inner, p) = try readStdControlOp(buf, offset: offset)
	return (StdOp.control(inner), p)
end 'readStdOpControl'

function readStdOpCall(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let (inner, p) = try readStdCallOp(buf, offset: offset)
	return (StdOp.call(inner), p)
end 'readStdOpCall'

function readStdOpMemory(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let (inner, p) = try readStdMemoryOp(buf, offset: offset)
	return (StdOp.memory(inner), p)
end 'readStdOpMemory'

function readStdOpSystem(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset) throws CacheCorruption
	let (inner, p) = try readStdSystemOp(buf, offset: offset)
	return (StdOp.system(inner), p)
end 'readStdOpSystem'

// --- Terminator ---

function writeIrTerminator(buf ByteArray, term Terminator)
	writeDword(buf, value: term.ordinal)
	match term 'term'
		unset then break
		dead then break
		fallthrough then break
		opIndex(index) then writeQword(buf, value: index)
	end 'term'
end 'writeIrTerminator'

function readIrTerminator(buf ByteArray, offset ByteOffset) returns (Terminator, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try Terminator.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	let pos = offset + 4
	return match kase 'term'
		unset gives(Terminator.unset, pos)
		dead gives(Terminator.dead, pos)
		fallthrough gives(Terminator.fallthrough, pos)
		opIndex gives readIrTerminatorOpIndex(buf, offset: pos)
	end 'term'
end 'readIrTerminator'

function readIrTerminatorOpIndex(buf ByteArray, offset ByteOffset) returns (Terminator, ByteOffset)
	let index = readQword(buf, offset: offset)
	return (Terminator.opIndex(index), offset + 8)
end 'readIrTerminatorOpIndex'

// --- IrBlockArg ---

function writeIrBlockArg(buf ByteArray, arg IrBlockArg)
	writeQword(buf, value: arg.valueId)
	writeStdTypeTag(buf, t: arg.argType)
	writeDword(buf, value: blockArgReturnRoleTag(arg.returnRole))
end 'writeIrBlockArg'

function readIrBlockArg(buf ByteArray, offset ByteOffset) returns (IrBlockArg, ByteOffset) throws CacheCorruption
	let valueId = readQword(buf, offset: offset)
	let (argType, p) = readStdTypeTag(buf, offset: offset + 8)
	let roleTag = readDword(buf, offset: p)
	let role = try blockArgReturnRoleFromTag(roleTag)
	return (IrBlockArg.create(valueId, argType: argType, returnRole: role), p + 4)
end 'readIrBlockArg'

function blockArgReturnRoleTag(role BlockArgReturnRole) returns MachineWord
	return match role 'tag'
		none gives 0
		primaryReturn gives 1
		errorFlag gives 2
	end 'tag'
end 'blockArgReturnRoleTag'

function blockArgReturnRoleFromTag(tag MachineWord) returns BlockArgReturnRole throws CacheCorruption
	match tag 'parse'
		0 then return BlockArgReturnRole.none
		1 then return BlockArgReturnRole.primaryReturn
		2 then return BlockArgReturnRole.errorFlag
		default throws CacheCorruption.invalidEncoding
	end 'parse'
end 'blockArgReturnRoleFromTag'

// --- IrBlock ---

function writeIrBlock(buf ByteArray, block IrBlock) throws CacheCorruption
	writeQword(buf, value: block.id)
	try writeString(buf, s: block.label)
	writeDword(buf, value: block.opRefs.count())
	for opIdx in block.opRefs 'eachOpRef'
		writeQword(buf, value: opIdx)
	end 'eachOpRef'
	writeIrTerminator(buf, term: block.terminator)
	writeDword(buf, value: block.blockArgs.count())
	for arg in block.blockArgs 'eachArg'
		writeIrBlockArg(buf, arg: arg)
	end 'eachArg'
	// branchEdges are populated only at the Target phase by lowerMirToTarget
	// and never at the Std phase the inliner runs against. Skipping them
	// keeps the codec smaller; the field is initialized empty on read.
end 'writeIrBlock'

function readIrBlock(buf ByteArray, offset ByteOffset) returns (IrBlock, ByteOffset) throws CacheCorruption
	let id = readQword(buf, offset: offset)
	var pos = offset + 8
	let (label, p1) = try readString(buf, offset: pos)
	pos = p1
	var block = IrBlock.create(id, label: label)
	let opRefCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto opRefCount 'eachOpRef'
		let opIdx = readQword(buf, offset: pos)
		pos = pos + 8
		block.opRefs.append(opIdx)
	end 'eachOpRef'
	let (term, p2) = try readIrTerminator(buf, offset: pos)
	pos = p2
	block.terminator = term
	let argCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto argCount 'eachArg'
		let (arg, p3) = try readIrBlockArg(buf, offset: pos)
		pos = p3
		block.blockArgs.push(arg)
	end 'eachArg'
	return (block, pos)
end 'readIrBlock'

// --- IrFunction (Std-phase shape only) ---
//
// The codec persists exactly the fields the inliner reads + the fields the
// merge step relocates. Maxon-phase fields (scope, maxonReturnType,
// maxonParamTypes, throwsTypeName) are reset to defaults on read because
// merging into the user's StdModule for the Std-level inliner pass never
// surfaces them. slotMaxonTypes stays empty for stdlib functions in the
// inlinable subset (single-block accessors typically have zero slots after
// mem2reg).

function writeStdIrFunction(buf ByteArray, func IrFunction) throws CacheCorruption
	try writeString(buf, s: func.name)
	// Synthesized functions (e.g. `__layout_copy_*`, `__destruct_*`) leave
	// `namespace` and `sourceFilePath` empty — route both through the
	// optional-string codec rather than the mandatory writeString,
	// otherwise the cache write throws CacheCorruption.invalidEncoding
	// and the persistence is silently skipped at every clean build.
	try writeOptionalStringDefaultEmpty(buf, value: func.namespace)
	writeVisibility(buf, v: func.visibility)
	try writeOptionalFilePath(buf, p: func.sourceFilePath)
	writeDword(buf, value: func.paramCount)
	writeStdReturnType(buf, rt: func.returnType)
	writeStdTypeArrayCodec(buf, arr: func.paramTypes)
	writeDword(buf, value: func.blockRefs.count())
	for br in func.blockRefs 'eachBlockRef'
		writeQword(buf, value: br)
	end 'eachBlockRef'
	writeQword(buf, value: func.nextBlockId)
	writeBoolByte(buf, b: func.hasImplicitLayoutParam)
	try writeWhereClauseArray(buf, arr: func.implicitWitnessConstraints)
	// Phase 2 closure-capture-count localization: lifted closure bodies
	// carry their capture count on the IrFunction itself, replacing the
	// project-wide `closureCaptureCounts` map.
	writeQword(buf, value: func.closureCaptureCount)
	// Cache v74: the four refcount-insertion per-value side-tables
	// (`valueOwnership`/`valueManaged`/`valueTypeParam`/`valueTypeParamName`,
	// keyed by ValueId). LowerMaxonToStd populates these; the user-pipeline
	// inliner's `threadInlinedOwnership` reads them when splicing a cached stdlib
	// body into user code. Omitting them left a cache-restored function with EMPTY
	// tables, so inlined alloc results (e.g. `StringIndex.create`'s box) defaulted
	// to `notManaged` and the inserter never dropped them — the cache-parity leak
	// where the SAME program is leak-free from source but leaks against the cache.
	// Each is a count-prefixed run, index-ordered (the setters grow on demand, so
	// restoring 0..count-1 in order is exact).
	writeDword(buf, value: func.valueOwnership.count())
	for cls in func.valueOwnership 'eachOwnership'
		writeOwnershipClass(buf, c: cls)
	end 'eachOwnership'
	writeDword(buf, value: func.valueManaged.count())
	for m in func.valueManaged 'eachManaged'
		writeBoolByte(buf, b: m)
	end 'eachManaged'
	writeDword(buf, value: func.valueTypeParam.count())
	for tp in func.valueTypeParam 'eachTypeParam'
		writeBoolByte(buf, b: tp)
	end 'eachTypeParam'
	writeDword(buf, value: func.valueTypeParamName.count())
	for tpName in func.valueTypeParamName 'eachTypeParamName'
		// Most entries are "" (only type-parameter values carry a name), and the
		// mandatory string codec rejects a length-0 payload (CacheCorruption →
		// "skipping persist", silently disabling the cache). Use the optional-string
		// codec that round-trips "" via the `absent` tag.
		try writeOptionalStringDefaultEmpty(buf, value: tpName)
	end 'eachTypeParamName'
end 'writeStdIrFunction'

function readStdIrFunction(buf ByteArray, offset ByteOffset) returns (IrFunction, ByteOffset) throws CacheCorruption
	let (name, p1) = try readString(buf, offset: offset)
	// `namespace` round-trips through the optional-string codec because
	// synthesized functions (e.g. `__layout_copy_*`) leave it empty — see
	// the matching writer for the rationale.
	let (namespace, p2) = try readOptionalStringDefaultEmpty(buf, offset: p1)
	var pos = p2
	let (visibility, p3) = try readVisibility(buf, offset: pos)
	pos = p3
	let (sourceFilePath, p4) = try readOptionalFilePath(buf, offset: pos)
	pos = p4
	let paramCount = readDword(buf, offset: pos)
	pos = pos + 4
	let (returnType, p5) = readStdReturnType(buf, offset: pos)
	pos = p5
	let (paramTypes, p6) = readStdTypeArrayCodec(buf, offset: pos)
	pos = p6
	var func = IrFunction.createFromStd(name, returnType: returnType, paramCount: paramCount, paramTypes: paramTypes, returnLine: 0)
	func.namespace = namespace
	func.visibility = visibility
	func.sourceFilePath = sourceFilePath
	let blockRefCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto blockRefCount 'eachBlockRef'
		let br = readQword(buf, offset: pos)
		pos = pos + 8
		func.blockRefs.append(br)
	end 'eachBlockRef'
	let nextBlockId = readQword(buf, offset: pos)
	pos = pos + 8
	func.nextBlockId = nextBlockId
	let (hasLayout, p7) = readBoolByte(buf, offset: pos)
	pos = p7
	let (witnessConstraints, p8) = try readWhereClauseArray(buf, offset: pos)
	pos = p8
	func.hasImplicitLayoutParam = hasLayout
	func.implicitWitnessConstraints = witnessConstraints
	let captureCount = readQword(buf, offset: pos)
	pos = pos + 8
	func.closureCaptureCount = captureCount
	// Cache v74: restore the four refcount-insertion per-value side-tables in the
	// exact order written. Index-ordered restore is exact because the setters
	// grow the parallel array on demand (see writeStdIrFunction for why these must
	// round-trip — the cache-parity inlined-alloc leak).
	let ownershipCount = readDword(buf, offset: pos)
	pos = pos + 4
	for i in 0 upto ownershipCount 'restoreOwnership'
		let (cls, pNext) = try readOwnershipClass(buf, offset: pos)
		pos = pNext
		func.setValueOwnership(i, cls: cls)
	end 'restoreOwnership'
	let managedCount = readDword(buf, offset: pos)
	pos = pos + 4
	for i in 0 upto managedCount 'restoreManaged'
		let (m, pNext) = readBoolByte(buf, offset: pos)
		pos = pNext
		func.setValueManaged(i, managed: m)
	end 'restoreManaged'
	let typeParamCount = readDword(buf, offset: pos)
	pos = pos + 4
	for i in 0 upto typeParamCount 'restoreTypeParam'
		let (tp, pNext) = readBoolByte(buf, offset: pos)
		pos = pNext
		func.setValueTypeParam(i, isTypeParam: tp)
	end 'restoreTypeParam'
	let typeParamNameCount = readDword(buf, offset: pos)
	pos = pos + 4
	for i in 0 upto typeParamNameCount 'restoreTypeParamName'
		let (tpName, pNext) = try readOptionalStringDefaultEmpty(buf, offset: pos)
		pos = pNext
		func.setValueTypeParamName(i, paramName: tpName)
	end 'restoreTypeParamName'
	return (func, pos)
end 'readStdIrFunction'

// --- StdModule ---

function writeStdModule(buf ByteArray, module StdModule) throws CacheCorruption
	writeDword(buf, value: module.functions.count())
	for f in module.functions 'eachFunc'
		try writeStdIrFunction(buf, func: f)
	end 'eachFunc'
	writeDword(buf, value: module.blocks.count())
	for blk in module.blocks 'eachBlock'
		try writeIrBlock(buf, block: blk)
	end 'eachBlock'
	writeDword(buf, value: module.ops.count())
	for op in module.ops 'eachOp'
		try writeStdOp(buf, op: op)
	end 'eachOp'
end 'writeStdModule'

function readStdModule(buf ByteArray, offset ByteOffset) returns (StdModule, ByteOffset) throws CacheCorruption
	var module = StdModule.create()
	var pos = offset
	let funcCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto funcCount 'eachFunc'
		let (f, p) = try readStdIrFunction(buf, offset: pos)
		pos = p
		module.functions.push(f)
	end 'eachFunc'
	let blockCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto blockCount 'eachBlock'
		let (blk, p) = try readIrBlock(buf, offset: pos)
		pos = p
		module.blocks.push(blk)
		// blockSourceInfo is parallel to blocks; pad with empty so the
		// invariant `blocks.count() == blockSourceInfo.count()` holds.
		// Coverage instrumentation reads this array and would otherwise
		// trip on a length mismatch even though the inlined stdlib
		// functions get dropped before instrumentCoverage runs.
		module.blockSourceInfo.push(BlockSourceInfo.empty())
	end 'eachBlock'
	let opCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto opCount 'eachOp'
		let (op, p) = try readStdOp(buf, offset: pos)
		pos = p
		module.ops.push(op)
	end 'eachOp'
	return (module, pos)
end 'readStdModule'

	let (signed, posAfterSigned) = readBoolByte(buf, offset: posAfterWidth)
	let (isFloat, p) = readBoolByte(buf, offset: posAfterSigned)
	return (StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: off, width: width, signed: signed, isFloat: isFloat), p)
end 'readStdSysLoadIndirect'


// StdlibCache: pre-compiled stdlib with per-function machine code linking.
//
// Each stdlib function is compiled to machine code and stored as a relocatable
// object in the cache file. At link time, reachability analysis selects only
// the needed functions and appends their code bytes to the output.
//
// Cache format: header + per-function objects + globalData + parser metadata.

export typealias CacheChecksum = int(0 to u64.max)
export typealias StdlibFuncIndexMap = Map with(String, MachineWord)
export typealias StdlibFuncNameSet = Set with String

let CACHE_MAGIC_0 = 0x4D  // 'M'
let CACHE_MAGIC_1 = 0x58  // 'X'
let CACHE_MAGIC_2 = 0x43  // 'C'
let CACHE_MAGIC_3 = 0x00  // '\0'

// v5: added funcSignatures table so cached stdlib functions surface their
// param names + defaults to TypeResolution's arity validator (arity errors
// for stdlib calls used to silently no-op when the cache was warm because
// project.funcSignatures is only populated when stdlib source is reparsed).
// v7: round-trip generic-aware MaxonType arms (typeParameter,
// genericInstance, interface) with their full payload, and persist each
// struct's `innerAliases` map. Earlier versions collapsed the
// generic-aware arms to a printable name and dropped innerAliases on
// restore, so cache hits surfaced unresolved inner-alias names like
// `MaxonType.named("ElementMemory")` to the lowering pass.
// v8: persist Phase 11 conformance/interface/registry state. Without this
// step, the user-code pipeline runs `validateConformances` /
// `processExtensions` against an empty stdlib (cache hit drops every
// stdlib-side `unresolvedExtensions` / `unresolvedStructTypes` entry),
// so primitive extensions like `extension int implements Comparable` never
// land in `project.conformances`. Persisting `interfaces`, `conformances`,
// `typeParameters`, `interfaceRegistry`, `genericInstances`,
// `genericTypealiases`, `layoutDescriptors`, `witnessTables`,
// `livenessRoots`, and `staticRdataValues` makes the cached-stdlib project
// state identical to a fresh-from-source build for every consumer 11.4's
// lowering reads.
// v10: persist the stdlib's post-dce StdModule snapshot so the user
// pipeline's inliner pass can splice stdlib accessor bodies (Array.get,
// ArrayIterator.advance/current, Optional.unwrap, etc.) into user
// callers. Without this, the inliner's `funcMap` only sees user
// functions and every cross-module accessor call stays a `func.call`,
// which costs two indirect calls per iteration in a tight `for n in
// arr` loop.
let CACHE_FORMAT_VERSION = 13

// ============================================================
// Types
// ============================================================

// Adr fixup for ARM64: patch an ADR instruction to point at a named function.
// Stored in the cache so the linker can adjust offsets when linking.
export type CachedAdrFixup
	export var instrOffset CodeOffset
	export var destReg MachineWord
	export var targetName String

	export static function create(instrOffset CodeOffset, destReg MachineWord, targetName String) returns CachedAdrFixup
		return Self{instrOffset: instrOffset, destReg: destReg, targetName: targetName}
	end 'create'
end 'CachedAdrFixup'

export typealias CachedAdrFixupArray = Array with CachedAdrFixup

// A single relocatable function: its machine code + unresolved fixups.
export type ObjectFunction
	export var name String
	export var returnType StdReturnType
	export var paramCount ParamCount
	export var paramTypes StdTypeArray
	export var code ByteArray
	export var callFixups CallFixupArray
	export var rdataRelocs RdataRelocationArray
	export var relocations RelocationArray
	// ARM64-specific: ADR fixups for function address loading
	export var adrFixups CachedAdrFixupArray

	export static function create(name String, returnType StdReturnType, paramCount ParamCount) returns ObjectFunction
		return Self{
			name: name,
			returnType: returnType,
			paramCount: paramCount,
			paramTypes: StdTypeArray.create(),
			code: ByteArray.create(),
			callFixups: CallFixupArray.create(),
			rdataRelocs: RdataRelocationArray.create(),
			relocations: RelocationArray.create(),
			adrFixups: CachedAdrFixupArray.create()
		}
	end 'create'
end 'ObjectFunction'

export typealias ObjectFunctionArray = Array with ObjectFunction

// All data needed to link pre-compiled stdlib into a user program.
export type StdlibCacheData
	export var functions ObjectFunctionArray
	export var wasmFunctions WasmObjectFunctionArray
	export var globalData GlobalDataTable
	// Parser metadata
	export var typealiases TypealiasMap
	export var typealiasRanges TypealiasRangeMap
	export var funcReturnTypes FuncReturnTypeMap
	export var funcSignatures FuncSignatureMap
	export var structTypes StructTypeMap
	export var topLevelConstants ConstantMap
	// Snapshot of the source project's type-name interner at capture time.
	// MaxonType.named(id) values stored in funcReturnTypes / structTypes
	// embed an interner-local id; the user project's interner has its own
	// id space, so restoreStdlibMetadata uses this map to translate captured
	// ids back to names and re-intern them in the destination project.
	export var typeNameTable StringArray
	// Discovery cache for the BuiltinArrayLiteral protocol. The parser writes
	// `[1, 2, 3]` literals through whichever stdlib type implements
	// `BuiltinArrayLiteral`; the discovery walk runs once, at parse time, over
	// `project.unresolvedStructTypes`. On a cache hit those entries are gone
	// (the parser doesn't re-parse stdlib), so we persist the discovered name
	// here and the loader re-publishes it after restore. Empty string means
	// no implementing type was observed in this stdlib.
	export var builtinArrayLiteralTypeName String
	// Phase 11.4 (cache v8): per-registry snapshots so cached-stdlib user
	// builds see the same `project.*` state a fresh-from-source build would.
	// Without these the user-code pipeline can't dispatch through
	// stdlib-declared conformances (e.g. `extension int implements Comparable`)
	// because `processExtensions`/`validateConformances` ran during the
	// cache-build pipeline, not during user-code resolution.
	export var interfaces IrInterfaceMap
	export var conformances ConformanceRegistry
	export var typeParameters TypeParamRegistry
	export var interfaceRegistry InterfaceTypeRegistry
	export var genericInstances GenericInstanceRegistry
	export var genericTypealiases GenericTypealiasMap
	export var layoutDescriptors LayoutDescriptorRegistry
	export var witnessTables WitnessTableRegistry
	export var livenessRoots StringArray
	// Phase 11.4: snapshot of `Project.genericFunctionImplicitArity` so
	// cached-stdlib user builds see which stdlib functions need synthetic
	// layout/witness args appended at call sites. Without this, per-function
	// lowering (where stdlib funcs aren't in the local stdModule) can't
	// discover the callee's hasImplicitLayoutParam and emits an under-arity
	// call op — silent ABI corruption on x64, validator rejection on wasm.
	export var genericFunctionImplicitArity GenericFunctionImplicitArityMap
	export var staticRdataValues StaticRdataValueMap
	// Phase 11.6 (cache v10): the stdlib's StdModule at the post-dce
	// point of its build pipeline. The user-code pipeline merges this
	// into its own StdModule for the inliner pass so stdlib accessor
	// bodies are visible at user call sites; merged functions are
	// dropped after inlining so the linker-side stdlib cache stays the
	// sole source of stdlib machine code.
	export var inlinerStdModule StdModule

	export static function create() returns StdlibCacheData
		return Self{
			functions: ObjectFunctionArray.create(),
			wasmFunctions: WasmObjectFunctionArray.create(),
			globalData: createGlobalDataTable(),
			typealiases: TypealiasMap.create(),
			typealiasRanges: TypealiasRangeMap.create(),
			funcReturnTypes: FuncReturnTypeMap.create(),
			funcSignatures: FuncSignatureMap.create(),
			structTypes: StructTypeMap.create(),
			topLevelConstants: ConstantMap.create(),
			typeNameTable: StringArray.create(),
			builtinArrayLiteralTypeName: "",
			interfaces: IrInterfaceMap.create(),
			conformances: ConformanceRegistry.create(),
			typeParameters: TypeParamRegistry.create(),
			interfaceRegistry: InterfaceTypeRegistry.create(),
			genericInstances: GenericInstanceRegistry.create(),
			genericTypealiases: GenericTypealiasMap.create(),
			layoutDescriptors: LayoutDescriptorRegistry.create(),
			witnessTables: WitnessTableRegistry.create(),
			livenessRoots: StringArray.create(),
			genericFunctionImplicitArity: GenericFunctionImplicitArityMap.create(),
			staticRdataValues: StaticRdataValueMap.create(),
			inlinerStdModule: StdModule.create()
		}
	end 'create'
end 'StdlibCacheData'

// Result of loading a cache file.
export type StdlibCacheResult
	export var data StdlibCacheData
	export var valid bool

	export static function create(data StdlibCacheData, valid bool) returns StdlibCacheResult
		return Self{data: data, valid: valid}
	end 'create'
end 'StdlibCacheResult'

// ============================================================
// Checksum
// ============================================================

// FNV-1a 32-bit hash over the supplied stdlib source files, the in-memory
// bootstrap source, and the runtime.std contents. Position-mixing (each byte
// is xor'd then multiplied by the FNV prime) so a stale cache won't survive a
// byte swap, file reorder, or anything else the old additive sum collided on.
// Caller controls which files participate (so the cache key matches the
// on-disk whitelist) and passes the bootstrap + runtime path explicitly so
// the cache invalidates whenever any of them change.
//
// runtimePath may be empty (no runtime found / cross-tooling); in that case
// only stdlib files + bootstrap participate, which still matches the build
// path's behavior of skipping signature injection when runtime is absent.
let FNV_OFFSET_BASIS = 0x811C9DC5
let FNV_PRIME = 0x01000193

function fnvUpdate(state CacheChecksum, b MachineWord) returns CacheChecksum
	let mixed = state xor b
	return (mixed * FNV_PRIME) and 0xFFFFFFFF
end 'fnvUpdate'

export function computeStdlibChecksum(files FilePathArray, bootstrap String, runtimePath FilePath) returns CacheChecksum
	var checksum = FNV_OFFSET_BASIS
	for filePath in files 'eachFile'
		let bytes = try File.readBinary(filePath) otherwise continue
		for b in bytes 'eachByte'
			checksum = fnvUpdate(checksum, b: b)
		end 'eachByte'
		// Length separator so a byte stolen from one file and prepended to the
		// next doesn't produce the same hash as the original split.
		checksum = fnvUpdate(checksum, b: 0)
	end 'eachFile'
	for bb in bootstrap.bytes() 'eachBootstrapByte'
		checksum = fnvUpdate(checksum, b: bb)
	end 'eachBootstrapByte'
	checksum = fnvUpdate(checksum, b: 0)
	if not runtimePath.isEmpty() 'hasRuntime'
		let rtBytes = try File.readBinary(runtimePath) otherwise ByteArray.create()
		for rb in rtBytes 'eachRuntimeByte'
			checksum = fnvUpdate(checksum, b: rb)
		end 'eachRuntimeByte'
	end 'hasRuntime'
	return checksum
end 'computeStdlibChecksum'

// Get compiler executable fingerprint: file size and modification time.
export function getCompilerFingerprint() returns (MachineWord, MachineWord)
	let exePath = Process.executablePath()
	let info = try File.info(exePath) otherwise return (0, 0)

	return (info.size, info.modifiedTime)
end 'getCompilerFingerprint'

// ============================================================
// Write cache
// ============================================================

export function writeStdlibCache(project Project, path FilePath, data StdlibCacheData, target Target, contentChecksum CacheChecksum)
	var buf = ByteArray.create()
	buf.reserve(4096)

	// Header
	buf.push(CACHE_MAGIC_0)
	buf.push(CACHE_MAGIC_1)
	buf.push(CACHE_MAGIC_2)
	buf.push(CACHE_MAGIC_3)
	writeDword(buf, value: CACHE_FORMAT_VERSION)
	writeDword(buf, value: contentChecksum)

	let (compilerSize, compilerMtime) = getCompilerFingerprint()
	writeDword(buf, value: compilerSize)
	writeQword(buf, value: compilerMtime)

	writeCpuArch(buf, cpu: target.cpu)
	writeOs(buf, os: target.os)
	writeDword(buf, value: data.functions.count())

	// Per-function objects
	for func in data.functions 'eachFunc'
		writeString(buf, s: func.name)
		writeStdReturnType(buf, rt: func.returnType)
		writeDword(buf, value: func.paramCount)

		// Param types
		writeDword(buf, value: func.paramTypes.count())
		for pt in func.paramTypes 'eachParamType'
			writeStdTypeTag(buf, t: pt)
		end 'eachParamType'

		// Code bytes
		writeDword(buf, value: func.code.count())
		buf.append(func.code)

		// Call fixups
		writeDword(buf, value: func.callFixups.count())
		for fixup in func.callFixups 'eachFixup'
			writeDword(buf, value: fixup.codeOffset)
			writeString(buf, s: fixup.targetName)
		end 'eachFixup'

		// Rdata relocations
		writeDword(buf, value: func.rdataRelocs.count())
		for reloc in func.rdataRelocs 'eachRdata'
			writeDword(buf, value: reloc.codeOffset)
			writeString(buf, s: reloc.rdataLabel)
			writeRdataRelocKind(buf, kind: reloc.kind)
		end 'eachRdata'

		// IAT/GOT relocations
		writeDword(buf, value: func.relocations.count())
		for reloc in func.relocations 'eachReloc'
			writeDword(buf, value: reloc.codeOffset)
			writeDword(buf, value: reloc.slotIndex)
		end 'eachReloc'

		// ARM64 ADR fixups
		writeDword(buf, value: func.adrFixups.count())
		for fixup in func.adrFixups 'eachAdr'
			writeDword(buf, value: fixup.instrOffset)
			writeDword(buf, value: fixup.destReg)
			writeString(buf, s: fixup.targetName)
		end 'eachAdr'
	end 'eachFunc'

	// WASM per-function objects
	writeDword(buf, value: data.wasmFunctions.count())
	for func in data.wasmFunctions 'eachWasmFunc'
		writeString(buf, s: func.name)
		writeStdReturnType(buf, rt: func.returnType)
		writeDword(buf, value: func.paramCount)
		writeDword(buf, value: func.paramTypes.count())
		for pt in func.paramTypes 'eachParamType'
			writeStdTypeTag(buf, t: pt)
		end 'eachParamType'

		// Throwing-function ABI: empty string = non-throwing.
		writeString(buf, s: func.throwsTypeName)

		// Body bytes
		writeDword(buf, value: func.body.count())
		buf.append(func.body)

		// WASM call fixups
		writeDword(buf, value: func.callFixups.count())
		for fixup in func.callFixups 'eachFixup'
			writeDword(buf, value: fixup.bodyOffset)
			writeString(buf, s: fixup.targetName)
		end 'eachFixup'
	end 'eachWasmFunc'

	// GlobalData
	writeDword(buf, value: data.globalData.names.count())
	for i in 0 upto data.globalData.names.count() 'eachGlobal'
		let name = try data.globalData.names.get(i) otherwise panic("writeCache eachGlobal: loop index {i} < names.count() just succeeded but get({i}) failed (count={data.globalData.names.count()})")
		let value = try data.globalData.values.get(i) otherwise panic("writeCache eachGlobal: globalData.values must parallel names but get({i}) failed (count={data.globalData.values.count()}, names.count={data.globalData.names.count()})")
		writeString(buf, s: name)
		writeDword(buf, value: value.count())
		buf.append(value)
	end 'eachGlobal'

	// Typealiases
	writeDword(buf, value: data.typealiases.count())
	for (name, baseType) in data.typealiases 'eachAlias'
		writeString(buf, s: name)
		writeStdTypeTag(buf, t: baseType)
	end 'eachAlias'

	// Typealias ranges
	writeDword(buf, value: data.typealiasRanges.count())
	for (name, range) in data.typealiasRanges 'eachRange'
		writeString(buf, s: name)
		writeQword(buf, value: range.lower)
		writeQword(buf, value: range.upper)
	end 'eachRange'

	// Function return types
	writeDword(buf, value: data.funcReturnTypes.count())
	for (name, rt) in data.funcReturnTypes 'eachRt'
		writeString(buf, s: name)
		writeMaxonReturnType(project, buf: buf, rt: rt)
	end 'eachRt'

	// Function signatures (param names + types + defaults). Persisted so
	// TypeResolution.checkCallArity can validate stdlib-call sites without
	// needing to re-parse stdlib source — see CACHE_FORMAT_VERSION = 5 note.
	writeDword(buf, value: data.funcSignatures.count())
	for (name, signature) in data.funcSignatures 'eachSig'
		writeString(buf, s: name)
		writeDword(buf, value: signature.paramNames.count())
		for paramName in signature.paramNames 'eachParamName'
			writeString(buf, s: paramName)
		end 'eachParamName'
		for paramType in signature.paramTypes 'eachParamType'
			writeMaxonType(project, buf: buf, t: paramType)
		end 'eachParamType'
		for paramDefault in signature.paramDefaults 'eachParamDefault'
			writeParamDefault(buf, pd: paramDefault)
		end 'eachParamDefault'
	end 'eachSig'

	// Struct types
	writeDword(buf, value: data.structTypes.count())
	for (name, st) in data.structTypes 'eachStruct'
		writeString(buf, s: name)
		writeDword(buf, value: st.byteSize)
		writeDword(buf, value: st.fields.count())

		for field in st.fields 'eachField'
			writeString(buf, s: field.name)
			writeMaxonType(project, buf: buf, t: field.fieldType)
			writeDword(buf, value: field.offset)
		end 'eachField'

		// Cache v7: persist the per-struct inner-typealias map so cache-hit
		// lowering can resolve names like `ElementMemory` (declared inside
		// `type Array uses Element`) the same way a cache-miss parse would.
		// Without this round-trip, `applyInnerAliasIfNamed` sees an empty
		// map post-restore and lets the bare placeholder reach
		// `namedIdCastCategory`, which panics.
		writeDword(buf, value: st.innerAliases.count())
		for (aliasName, aliasType) in st.innerAliases 'eachInnerAlias'
			writeString(buf, s: aliasName)
			writeMaxonType(project, buf: buf, t: aliasType)
		end 'eachInnerAlias'
	end 'eachStruct'

	// Top-level constants. Visibility / sourceFilePath are not serialized:
	// every stdlib constant is implicitly `exported` and originates at the
	// stdlib bootstrap path; readStdlibCache stamps those defaults in.
	writeDword(buf, value: data.topLevelConstants.count())
	for (name, entry) in data.topLevelConstants 'eachConst'
		writeString(buf, s: name)
		writeConstantValue(project, buf: buf, cv: entry.value)
	end 'eachConst'

	// BuiltinArrayLiteral discovery. Empty string means no implementing type
	// was observed in this stdlib build. Persisted so the parser can resolve
	// `[a, b, c]` after a cache hit, where the `unresolvedStructTypes`
	// registry has been drained and the conformance metadata is otherwise
	// gone.
	writeString(buf, s: data.builtinArrayLiteralTypeName)

	// Cache v8: Phase 11 conformance + registry state. Order matters on the
	// read side — typeParameters / interfaceRegistry / genericInstances are
	// interned by structural identity, so writing them here in the same order
	// the source project recorded them makes the destination's `intern` calls
	// hand back identical ids during restore. Other registries
	// (interfaces, conformances, genericTypealiases, layoutDescriptors,
	// witnessTables, staticRdataValues, livenessRoots) carry their own keys
	// and don't depend on insertion order for correctness.
	writeTypeParamRegistry(buf, registry: data.typeParameters)
	writeInterfaceTypeRegistry(buf, registry: data.interfaceRegistry)
	writeGenericInstanceRegistry(project, buf: buf, registry: data.genericInstances)
	writeInterfaceMap(project, buf: buf, m: data.interfaces)
	writeConformanceRegistry(project, buf: buf, registry: data.conformances)
	writeGenericTypealiasMap(project, buf: buf, m: data.genericTypealiases)
	writeLayoutDescriptorRegistry(buf, registry: data.layoutDescriptors)
	writeWitnessTableRegistry(buf, registry: data.witnessTables)
	writeStringArray(buf, arr: data.livenessRoots)
	writeGenericFunctionImplicitArityMap(buf, m: data.genericFunctionImplicitArity)
	writeStaticRdataValueMap(buf, m: data.staticRdataValues)
	// Cache v10: the stdlib's post-dce StdModule snapshot for cross-
	// module inlining at user pipeline time.
	writeStdModule(buf, module: data.inlinerStdModule)

	// Ensure parent directory (and any missing ancestors) exist
	let parentDir = try path.parent() otherwise FilePath from ""
	if not parentDir.isEmpty() 'hasParent'
		_ = Directory.create(parentDir)
	end 'hasParent'

	try File.writeBinary(path, content: buf) otherwise 'writeErr'
		logInfo(LogCategory.compiler, message: () gives "Failed to write stdlib cache to {path}")
	end 'writeErr'
end 'writeStdlibCache'

// ============================================================
// Read cache
// ============================================================

export function readStdlibCache(project Project, path FilePath, target Target, expectedChecksum CacheChecksum) returns StdlibCacheResult
	let invalid = StdlibCacheResult.create(StdlibCacheData.create(), valid: false)

	let buf = try File.readBinary(path) otherwise return invalid

	// Validate header
	if buf.count() < 36 'tooSmall'
		return invalid
	end 'tooSmall'

	// buf.count() >= 36 just verified, so the four magic-byte reads share one invariant.
	var m0 = 0 as byte
	var m1 = 0 as byte
	var m2 = 0 as byte
	var m3 = 0 as byte
	try 'readMagic'
		m0 = buf.get(0)
		m1 = buf.get(1)
		m2 = buf.get(2)
		m3 = buf.get(3)
	end 'readMagic' otherwise(e) 'badMagic2'
		match e 'kind'
			indexOutOfBounds then panic("loadCache: buf.count() >= 36 just verified but magic-byte read OOB")
			emptySlot then panic("loadCache: magic byte slot empty (push-init invariant)")
		end 'kind'
	end 'badMagic2'

	if m0 != CACHE_MAGIC_0 or m1 != CACHE_MAGIC_1 or m2 != CACHE_MAGIC_2 or m3 != CACHE_MAGIC_3 'badMagic'
		return invalid
	end 'badMagic'

	let version = readDword(buf, offset: 4)
	if version != CACHE_FORMAT_VERSION 'badVersion'
		logInfo(LogCategory.compiler, message: () gives "Stdlib cache version mismatch (found {version}, expected {CACHE_FORMAT_VERSION}); regenerating")
		return invalid
	end 'badVersion'

	let checksum = readDword(buf, offset: 8)
	if checksum != expectedChecksum 'badChecksum'
		return invalid
	end 'badChecksum'

	// Compiler fingerprint
	let cachedCompilerSize = readDword(buf, offset: 12)
	let cachedCompilerMtime = readQword(buf, offset: 16)
	let (currentCompilerSize, currentCompilerMtime) = getCompilerFingerprint()

	if cachedCompilerSize != currentCompilerSize or cachedCompilerMtime != currentCompilerMtime 'staleCompiler'
		return invalid
	end 'staleCompiler'

	// Target
	let (cachedCpu, _) = readCpuArch(buf, offset: 24)
	let (cachedOs, _) = readOs(buf, offset: 28)

	if cachedCpu.rawValue != target.cpu.rawValue or cachedOs.rawValue != target.os.rawValue 'badTarget'
		return invalid
	end 'badTarget'

	let functionCount = readDword(buf, offset: 32)
	var pos = 36

	var data = StdlibCacheData.create()

	// Read per-function objects
	for _ in 0 upto functionCount 'eachFunc'
		let (name, p1) = readString(buf, offset: pos)
		pos = p1
		let (returnType, p1b) = readStdReturnType(buf, offset: pos)
		pos = p1b
		let paramCount = readDword(buf, offset: pos)
		pos = pos + 4

		var func = ObjectFunction.create(name, returnType: returnType, paramCount: paramCount)

		// Param types
		let paramTypeCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto paramTypeCount 'eachParamType'
			let (pt, ptPos) = readStdTypeTag(buf, offset: pos)
			pos = ptPos
			func.paramTypes.push(pt)
		end 'eachParamType'

		// Code bytes
		let codeLen = readDword(buf, offset: pos)
		pos = pos + 4

		func.code.reserve(codeLen)
		for _ in 0 upto codeLen 'copyCode'
			let b = try buf.get(pos) otherwise panic("loadCache copyCode: cache buffer truncated (pos={pos}, buf.count={buf.count()}, codeLen={codeLen})")
			func.code.push(b)
			pos = pos + 1
		end 'copyCode'

		// Call fixups
		let fixupCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto fixupCount 'eachFixup'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (targetName, p2) = readString(buf, offset: pos)
			pos = p2
			func.callFixups.push(CallFixup.create(codeOffset, targetName: targetName))
		end 'eachFixup'

		// Rdata relocations
		let rdataCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto rdataCount 'eachRdata'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (rdataLabel, p3) = readString(buf, offset: pos)
			pos = p3
			let (kind, p4) = readRdataRelocKind(buf, offset: pos)
			pos = p4
			func.rdataRelocs.push(RdataRelocation.create(codeOffset, rdataLabel: rdataLabel, kind: kind))
		end 'eachRdata'

		// IAT/GOT relocations
		let relocCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto relocCount 'eachReloc'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let slotIndex = readDword(buf, offset: pos)
			pos = pos + 4
			func.relocations.push(Relocation.create(codeOffset, slotIndex: slotIndex))
		end 'eachReloc'

		// ARM64 ADR fixups
		let adrCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto adrCount 'eachAdr'
			let instrOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let destReg = readDword(buf, offset: pos)
			pos = pos + 4
			let (targetName, p2b) = readString(buf, offset: pos)
			pos = p2b
			func.adrFixups.push(CachedAdrFixup.create(instrOffset, destReg: destReg, targetName: targetName))
		end 'eachAdr'

		data.functions.push(func)
	end 'eachFunc'

	// WASM per-function objects
	let wasmFuncCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto wasmFuncCount 'eachWasmFunc'
		let (wName, wp1) = readString(buf, offset: pos)
		pos = wp1
		let (wReturnType, wp2) = readStdReturnType(buf, offset: pos)
		pos = wp2
		let wParamCount = readDword(buf, offset: pos)
		pos = pos + 4
		let wParamTypeCount = readDword(buf, offset: pos)
		pos = pos + 4

		var wFunc = WasmObjectFunction.create(wName, returnType: wReturnType, paramCount: wParamCount, paramTypes: StdTypeArray.create())

		for _ in 0 upto wParamTypeCount 'eachParamType'
			let (pt, wp3) = readStdTypeTag(buf, offset: pos)
			pos = wp3
			wFunc.paramTypes.push(pt)
		end 'eachParamType'

		let (wThrowsTypeName, wpThrows) = readString(buf, offset: pos)
		pos = wpThrows
		wFunc.throwsTypeName = wThrowsTypeName

		// Body bytes
		let wBodyLen = readDword(buf, offset: pos)
		pos = pos + 4
		wFunc.body.reserve(wBodyLen)
		for _ in 0 upto wBodyLen 'copyBody'
			let b = try buf.get(pos) otherwise panic("loadCache copyBody: cache buffer truncated (pos={pos}, buf.count={buf.count()}, wBodyLen={wBodyLen})")
			wFunc.body.push(b)
			pos = pos + 1
		end 'copyBody'

		// WASM call fixups
		let wFixupCount = readDword(buf, offset: pos)
		pos = pos + 4
		for _ in 0 upto wFixupCount 'eachFixup'
			let wOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (wTarget, wp4) = readString(buf, offset: pos)
			pos = wp4
			wFunc.callFixups.push(WasmCallFixup.create(wOffset, targetName: wTarget))
		end 'eachFixup'

		data.wasmFunctions.push(wFunc)
	end 'eachWasmFunc'

	// GlobalData
	let globalCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto globalCount 'eachGlobal'
		let (name, p5) = readString(buf, offset: pos)
		pos = p5
		let dataLen = readDword(buf, offset: pos)
		pos = pos + 4

		var bytes = ByteArray.create()
		bytes.reserve(dataLen)
		for _ in 0 upto dataLen 'copyData'
			let b = try buf.get(pos) otherwise panic("loadCache copyData: cache buffer truncated (pos={pos}, buf.count={buf.count()}, dataLen={dataLen})")
			bytes.push(b)
			pos = pos + 1
		end 'copyData'

		addNamedGlobalData(data.globalData, name: name, data: bytes)
	end 'eachGlobal'

	// Typealiases
	let aliasCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto aliasCount 'eachAlias'
		let (name, p6) = readString(buf, offset: pos)
		pos = p6
		let (stdType, p7) = readStdTypeTag(buf, offset: pos)
		pos = p7
		try data.typealiases.insert(name, value: stdType) otherwise ignore
	end 'eachAlias'

	// Typealias ranges
	let rangeCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto rangeCount 'eachRange'
		let (name, p8) = readString(buf, offset: pos)
		pos = p8
		let lower = readQword(buf, offset: pos)
		pos = pos + 8
		let upper = readQword(buf, offset: pos)
		pos = pos + 8
		try data.typealiasRanges.insert(name, value: TypealiasRange.create(lower, upper: upper)) otherwise ignore
	end 'eachRange'

	// Function return types
	let rtCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto rtCount 'eachRt'
		let (name, p9) = readString(buf, offset: pos)
		pos = p9
		let (rt, p10) = readMaxonReturnType(project, buf: buf, offset: pos)
		pos = p10
		try data.funcReturnTypes.insert(name, value: rt) otherwise ignore
	end 'eachRt'

	// Function signatures
	let sigCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto sigCount 'eachSig'
		let (sigName, pSig0) = readString(buf, offset: pos)
		pos = pSig0
		let paramCount = readDword(buf, offset: pos)
		pos = pos + 4
		var paramNames = StringArray.create()
		for _ in 0 upto paramCount 'eachParamName'
			let (paramName, pSig1) = readString(buf, offset: pos)
			pos = pSig1
			paramNames.push(paramName)
		end 'eachParamName'
		var paramTypes = MaxonTypeArray.create()
		for _ in 0 upto paramCount 'eachParamType'
			let (pt, pSig2) = readMaxonType(project, buf: buf, offset: pos)
			pos = pSig2
			paramTypes.push(pt)
		end 'eachParamType'
		var paramDefaults = ParamDefaultArray.create()
		for _ in 0 upto paramCount 'eachParamDefault'
			let (pd, pSig3) = readParamDefault(buf, offset: pos)
			pos = pSig3
			paramDefaults.push(pd)
		end 'eachParamDefault'
		try data.funcSignatures.insert(sigName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	end 'eachSig'

	// Stdlib decls don't carry visibility / sourceFilePath in the cache
	// codec — every entry is implicitly `global` and originates at the
	// shared stdlib bootstrap path. Stamping these defaults here lets
	// user code reach stdlib symbols regardless of where the user's
	// reading file lives. Declared before the struct loop so the
	// `StructType.create` call below can stamp it in.
	let stdlibBootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("readStdlibCache: bootstrap path rejected")

	// Struct types
	let structCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto structCount 'eachStruct'
		let (name, p11) = readString(buf, offset: pos)
		pos = p11
		let byteSize = readDword(buf, offset: pos)
		pos = pos + 4
		let fieldCount = readDword(buf, offset: pos)
		pos = pos + 4

		var fields = StructFieldArray.create()

		for _ in 0 upto fieldCount 'eachField'
			let (fieldName, p12) = readString(buf, offset: pos)
			pos = p12
			let (fieldType, p13) = readMaxonType(project, buf: buf, offset: pos)
			pos = p13
			let fieldOffset = readDword(buf, offset: pos)
			pos = pos + 4
			fields.push(StructField.create(fieldName, fieldType: fieldType, offset: fieldOffset))
		end 'eachField'

		// Cache v7: read back the per-struct inner-typealias map. The
		// resolved MaxonTypes were re-interned into the destination
		// project's registries by `readMaxonType` above, so the resulting
		// map is directly usable by `applyInnerAliasIfNamed` without any
		// translation step.
		let innerAliasCount = readDword(buf, offset: pos)
		pos = pos + 4
		var innerAliases = ResolvedInnerAliasMap.create()
		for _ in 0 upto innerAliasCount 'eachInnerAlias'
			let (aliasName, pIa1) = readString(buf, offset: pos)
			pos = pIa1
			let (aliasType, pIa2) = readMaxonType(project, buf: buf, offset: pos)
			pos = pIa2
			try innerAliases.insert(aliasName, value: aliasType) otherwise ignore
		end 'eachInnerAlias'

		let st = StructType.create(name, fields: fields, byteSize: byteSize, visibility: Visibility.global, sourceFilePath: stdlibBootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: innerAliases)
		try data.structTypes.insert(name, value: st) otherwise ignore
	end 'eachStruct'

	// Top-level constants
	let constCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto constCount 'eachConst'
		let (name, p14) = readString(buf, offset: pos)
		pos = p14
		let (cv, p15) = readConstantValue(project, buf: buf, offset: pos)
		pos = p15
		let entry = TopLevelConstant.create(cv, visibility: Visibility.global, sourceFilePath: stdlibBootstrapPath)
		try data.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'eachConst'

	// BuiltinArrayLiteral discovery.
	let (builtinArrayLiteralName, pBal) = readString(buf, offset: pos)
	pos = pBal
	data.builtinArrayLiteralTypeName = builtinArrayLiteralName

	// Cache v8: read Phase 11 conformance + registry state in the same order
	// the writer emitted it. The MaxonType helpers (`readMaxonType` etc.)
	// re-intern named/typeParameter/genericInstance/interface arms through
	// the destination project's registries during the walk, so by the time
	// we reach here every captured registry is in the destination project's
	// id space — no post-translation step needed for these fields.
	let (typeParamReg, pTpr) = readTypeParamRegistry(buf, offset: pos)
	pos = pTpr
	data.typeParameters = typeParamReg
	let (ifaceReg, pIfr) = readInterfaceTypeRegistry(buf, offset: pos)
	pos = pIfr
	data.interfaceRegistry = ifaceReg
	let (gInstReg, pGir) = readGenericInstanceRegistry(project, buf: buf, offset: pos)
	pos = pGir
	data.genericInstances = gInstReg
	let (ifaceMap, pIm) = readInterfaceMap(project, buf: buf, offset: pos)
	pos = pIm
	data.interfaces = ifaceMap
	let (confReg, pCr) = readConformanceRegistry(project, buf: buf, offset: pos)
	pos = pCr
	data.conformances = confReg
	let (gtm, pGtm) = readGenericTypealiasMap(project, buf: buf, offset: pos)
	pos = pGtm
	data.genericTypealiases = gtm
	let (ldr, pLdr) = readLayoutDescriptorRegistry(buf, offset: pos)
	pos = pLdr
	data.layoutDescriptors = ldr
	let (wtr, pWtr) = readWitnessTableRegistry(buf, offset: pos)
	pos = pWtr
	data.witnessTables = wtr
	let (lr, pLr) = readStringArray(buf, offset: pos)
	pos = pLr
	data.livenessRoots = lr
	let (gfia, pGfia) = readGenericFunctionImplicitArityMap(buf, offset: pos)
	pos = pGfia
	data.genericFunctionImplicitArity = gfia
	let (srv, pSrv) = readStaticRdataValueMap(buf, offset: pos)
	pos = pSrv
	data.staticRdataValues = srv
	// Cache v10: read the stdlib's post-dce StdModule for the user
	// pipeline's inliner pass.
	let (inlinerMod, pIm2) = readStdModule(buf, offset: pos)
	pos = pIm2
	data.inlinerStdModule = inlinerMod

	// Populate data.typeNameTable from the destination project's interner so
	// `restoreStdlibMetadata`'s translation step is a no-op identity. The
	// disk format encodes named types as strings (writeMaxonType emits
	// `(tag, name)`), and `readMaxonType` reinterns each name into the
	// destination project — so by the time we get here, every named type id
	// in `data.*` already points into `project.typeNames`. Mirroring those
	// names into `data.typeNameTable` makes restore see `table[id] == name`,
	// so the named-id translation round-trips through `intern(name)` and
	// returns the same id. Without this, `data.typeNameTable` is empty and
	// `restoreStdlibMetadata` panics on the first cached named return type
	// (e.g. `Math.exp returns Real`).
	for name in project.typeNames.names 'mirrorTable'
		data.typeNameTable.push(name)
	end 'mirrorTable'

	return StdlibCacheResult.create(data, valid: true)
end 'readStdlibCache'

// ============================================================
// Linker: reachability analysis (shared across all targets)
// ============================================================

// Compute which stdlib functions are needed given a set of seed function names.
// Performs transitive closure over call dependencies and adr fixup dependencies.
// Returns the set of needed function names.
export function computeNeededStdlibFunctions(seeds StringArray, stdlibCache StdlibCacheData) returns StdlibFuncNameSet
	var funcNameToIndex = StdlibFuncIndexMap.create()

	for (iter, func) in stdlibCache.functions.withIterator() 'buildIndex'
		funcNameToIndex.upsert(func.name, value: iter.index())
	end 'buildIndex'

	var needed = StdlibFuncNameSet.create()
	var worklist = StringArray.create()

	// Seed from caller-provided names
	for name in seeds 'seed'
		if funcNameToIndex.contains(name) and not needed.contains(name) 'isStdlib'
			needed.insert(element: name)
			worklist.push(name)
		end 'isStdlib'
	end 'seed'

	// Transitive closure
	var wi = 0

	while wi < worklist.count() 'walkDeps'
		let nameRef = try worklist.get(wi) otherwise 'skipWalk'
			wi = wi + 1
			continue
		end 'skipWalk'
		let name = "{nameRef}"
		wi = wi + 1

		let funcIdx = try funcNameToIndex.get(name) otherwise continue

		let func = try stdlibCache.functions.get(funcIdx) otherwise continue

		var newDeps = StringArray.create()

		for fixup in func.callFixups 'eachDep'
			if funcNameToIndex.contains(fixup.targetName) and not needed.contains(fixup.targetName) 'newDep'
				needed.insert(element: fixup.targetName)
				newDeps.push(fixup.targetName)
			end 'newDep'
		end 'eachDep'

		for fixup in func.adrFixups 'eachAdrDep'
			if funcNameToIndex.contains(fixup.targetName) and not needed.contains(fixup.targetName) 'newAdrDep'
				needed.insert(element: fixup.targetName)
				newDeps.push(fixup.targetName)
			end 'newAdrDep'
		end 'eachAdrDep'

		for dep in newDeps 'addDeps'
			worklist.push(dep)
		end 'addDeps'
	end 'walkDeps'

	return needed
end 'computeNeededStdlibFunctions'

// Merge global data entries referenced by the linked stdlib functions.
export function mergeStdlibGlobalData(globalData GlobalDataTable, rdataRelocs RdataRelocationArray, stdlibCache StdlibCacheData)
	var neededGlobals = StdlibFuncNameSet.create()

	for fixup in rdataRelocs 'findGlobals'
		neededGlobals.insert(element: fixup.rdataLabel)
	end 'findGlobals'

	for i in 0 upto stdlibCache.globalData.names.count() 'mergeGlobals'
		let name = try stdlibCache.globalData.names.get(i) otherwise continue

		if not neededGlobals.contains(name) 'notNeeded'
			continue
		end 'notNeeded'

		let existing = lookupGlobalData(globalData, name: name)
		if existing.count() == 0 'notPresent'
			let data = try stdlibCache.globalData.values.get(i) otherwise continue
			addNamedGlobalData(globalData, name: name, data: data)
		end 'notPresent'
	end 'mergeGlobals'
end 'mergeStdlibGlobalData'

// ============================================================
// Restore stdlib metadata into a project for user parsing
// ============================================================

// Translate a captured MaxonType into the destination project's id space.
// Every `named(id)` is reinterned through the destination project's typeNames
// using `data.typeNameTable`. Generic-aware arms (`typeParameter`,
// `genericInstance`, `interface`) recurse through the captured registries
// (`data.typeParameters`, `data.genericInstances`, `data.interfaceRegistry`)
// to look up the source-id's logical key (declName/paramName for
// type parameters, baseName + arg list for generic instances, name for
// interfaces) and re-intern that key into the destination project. This is
// required because the in-memory `cachedStdlibCacheData` snapshot is
// populated by `captureStdlibMetadata` (which copies source-project ids
// directly), and the disk-cache read path uses the same `data.*` registries
// keyed by the warmup project's id space — neither matches the per-test
// destination project's id space.
function translateMaxonType(project Project, data StdlibCacheData, t MaxonType) returns MaxonType
	// No stdlib function takes a function-typed parameter today, so the
	// `function` arm should never fire in practice. The match below is
	// preceded by an explicit panic guard so the round-trip stays loud
	// rather than silently corrupting the translated type if a future
	// stdlib function adds one.
	if isFunctionMaxonType(t) 'unsupported'
		panic("translateMaxonType: function types are not cached yet (Stage A scope)")
	end 'unsupported'
	return match t 'translate'
		boolean gives MaxonType.boolean
		integer gives MaxonType.integer
		float gives MaxonType.float
		string gives MaxonType.string
		unresolved gives MaxonType.unresolved
		named(id) gives translateNamedTypeId(project, table: data.typeNameTable, id: id)
		function gives MaxonType.unresolved
		typeParameter(id) gives translateCapturedTypeParameter(project, data: data, id: id)
		genericInstance(id) gives translateCapturedGenericInstance(project, data: data, id: id)
		interface(id) gives translateCapturedInterface(project, data: data, id: id)
	end 'translate'
end 'translateMaxonType'

function translateNamedTypeId(project Project, table StringArray, id TypeNameId) returns MaxonType
	let name = try table.get(id) otherwise panic("translateNamedTypeId: captured id {id} out of range (table count={table.count()}) — captureStdlibMetadata snapshot is missing entries")
	return MaxonType.named(project.typeNames.intern(name))
end 'translateNamedTypeId'

// Translate a captured `typeParameter(id)`. The captured registry stores the
// `(declaringTypeName, paramName)` pair at `id`; re-intern that pair into the
// destination project so the result references the destination-project id
// for the same logical type parameter.
function translateCapturedTypeParameter(project Project, data StdlibCacheData, id TypeParamId) returns MaxonType
	let declName = data.typeParameters.getDeclaringTypeName(id)
	let paramName = data.typeParameters.getName(id)
	let destId = project.typeParameters.intern(declName, paramName: paramName)
	return MaxonType.typeParameter(destId)
end 'translateCapturedTypeParameter'

// Translate a captured `genericInstance(id)`. Wraps the shared
// `translateCapturedGenericInstanceId` helper in `MaxonType.genericInstance`.
function translateCapturedGenericInstance(project Project, data StdlibCacheData, id GenericInstanceId) returns MaxonType
	return MaxonType.genericInstance(translateCapturedGenericInstanceId(project, data: data, id: id))
end 'translateCapturedGenericInstance'

// Translate a captured `interface(id)`. The captured registry is just a
// name-keyed parallel array; re-intern the name into the destination
// project's `interfaceRegistry`.
function translateCapturedInterface(project Project, data StdlibCacheData, id InterfaceTypeId) returns MaxonType
	let name = data.interfaceRegistry.getName(id)
	let destId = project.interfaceRegistry.intern(name)
	return MaxonType.interface(destId)
end 'translateCapturedInterface'

// Translate a captured GenericInstanceId to a destination GenericInstanceId.
// The captured registry stores `(baseId, args)` where `baseId` indexes into
// the captured typeNameTable and each arg is itself a captured MaxonType.
// Re-intern the base name into the destination project's typeNames,
// recursively translate each arg, then intern the resulting
// `(destBaseId, destArgs)` pair into the destination project's
// `genericInstances` registry. Shared by `translateCapturedGenericInstance`
// (which wraps the result in MaxonType) and `LayoutDescriptorRegistry`
// translation (which needs the bare GenericInstanceId).
function translateCapturedGenericInstanceId(project Project, data StdlibCacheData, id GenericInstanceId) returns GenericInstanceId
	let (sourceBaseId, sourceArgs) = data.genericInstances.get(id)
	let baseName = try data.typeNameTable.get(sourceBaseId) otherwise panic("translateCapturedGenericInstanceId: typeNameTable.get OOB for baseId={sourceBaseId} (table count={data.typeNameTable.count()})")
	let destBaseId = project.typeNames.intern(baseName)
	let destArgs = translateCapturedTypeArray(project, data: data, src: sourceArgs)
	return project.genericInstances.intern(destBaseId, args: destArgs)
end 'translateCapturedGenericInstanceId'

// Translate every captured MaxonType in `src` through `translateMaxonType`
// into a fresh MaxonTypeArray in the destination project's id space.
function translateCapturedTypeArray(project Project, data StdlibCacheData, src MaxonTypeArray) returns MaxonTypeArray
	var dst = MaxonTypeArray.create()
	for t in src 'eachT'
		dst.push(translateMaxonType(project, data: data, t: t))
	end 'eachT'
	return dst
end 'translateCapturedTypeArray'

// Translate a captured MaxonReturnType: void passes through; value(inner)
// gets its inner MaxonType reinterned via translateMaxonType.
function translateMaxonReturnType(project Project, data StdlibCacheData, rt MaxonReturnType) returns MaxonReturnType
	return match rt 'translate'
		void gives MaxonReturnType.void
		value(inner) gives MaxonReturnType.value(translateMaxonType(project, data: data, t: inner))
	end 'translate'
end 'translateMaxonReturnType'

// Translate a captured InterfaceMethodSig: paramTypes and returnType carry
// captured MaxonTypes. Other fields (name / paramNames / throwsTypeName /
// line / column) are name- or position-keyed and pass through unchanged.
function translateInterfaceMethodSig(project Project, data StdlibCacheData, sig InterfaceMethodSig) returns InterfaceMethodSig
	let destParamTypes = translateCapturedTypeArray(project, data: data, src: sig.paramTypes)
	let destReturn = translateMaxonReturnType(project, data: data, rt: sig.returnType)
	return InterfaceMethodSig.create(sig.name, paramNames: sig.paramNames, paramTypes: destParamTypes, returnType: destReturn, throwsTypeName: sig.throwsTypeName, isStatic: sig.isStatic, line: sig.line, column: sig.column)
end 'translateInterfaceMethodSig'

// Translate a captured IrInterface: each method sig's paramTypes / returnType
// MaxonTypes are reinterned through the destination project. Other fields
// (name / extendsNames / usesParams / visibility / filePath / line / column)
// pass through unchanged because they're name- or position-keyed.
function translateIrInterface(project Project, data StdlibCacheData, iface IrInterface) returns IrInterface
	var destMethods = InterfaceMethodSigArray.create()
	for m in iface.methods 'eachM'
		destMethods.push(translateInterfaceMethodSig(project, data: data, sig: m))
	end 'eachM'
	return IrInterface.create(iface.name, extendsNames: iface.extendsNames, usesParams: iface.usesParams, methods: destMethods, visibility: iface.visibility, line: iface.line, column: iface.column, filePath: iface.filePath)
end 'translateIrInterface'

// Translate a captured StructType: every field's MaxonType has its captured
// ids reinterned in the destination project. innerAliases values are also
// translated — without this, a struct's `Array.innerAliases["ArrayIter"]`
// would retain a captured `genericInstance` whose base id pointed into the
// source typeNames at a slot whose value differed in the destination.
function translateStructType(project Project, data StdlibCacheData, st StructType) returns StructType
	var fields = StructFieldArray.create()
	for f in st.fields 'eachField'
		fields.push(StructField.create(f.name, fieldType: translateMaxonType(project, data: data, t: f.fieldType), offset: f.offset))
	end 'eachField'
	var translatedInner = ResolvedInnerAliasMap.create()
	for (aliasName, aliasType) in st.innerAliases 'eachInner'
		try translatedInner.insert(aliasName, value: translateMaxonType(project, data: data, t: aliasType)) otherwise ignore
	end 'eachInner'
	var translatedExpected = InterfaceMethodSigArray.create()
	for sig in st.expectedMethods 'eachExpected'
		translatedExpected.push(translateInterfaceMethodSig(project, data: data, sig: sig))
	end 'eachExpected'
	return StructType.create(st.name, fields: fields, byteSize: st.byteSize, visibility: st.visibility, sourceFilePath: st.sourceFilePath, nameLine: st.nameLine, nameColumn: st.nameColumn, expectedMethods: translatedExpected, innerAliases: translatedInner)
end 'translateStructType'

// Capture parser metadata from a project into a StdlibCacheData.
export function captureStdlibMetadata(project Project, data StdlibCacheData)
	// Snapshot the type-name interner so restoreStdlibMetadata can translate
	// captured ids back to names — every MaxonType.named id in the captured
	// metadata indexes into this table.
	for name in project.typeNames.names 'snapshotTypeNames'
		data.typeNameTable.push(name)
	end 'snapshotTypeNames'

	for (name, baseType) in project.typealiases 'copyAliases'
		try data.typealiases.insert(name, value: baseType) otherwise ignore
	end 'copyAliases'

	for (name, range) in project.typealiasRanges 'copyRanges'
		try data.typealiasRanges.insert(name, value: range) otherwise ignore
	end 'copyRanges'

	for (name, rt) in project.funcReturnTypes 'copyRts'
		try data.funcReturnTypes.insert(name, value: rt) otherwise ignore
	end 'copyRts'

	for (name, sig) in project.funcSignatures 'copySigs'
		try data.funcSignatures.insert(name, value: sig) otherwise ignore
	end 'copySigs'

	for (name, st) in project.structTypes 'copyStructs'
		try data.structTypes.insert(name, value: st) otherwise ignore
	end 'copyStructs'

	for (name, entry) in project.topLevelConstants 'copyConsts'
		try data.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'copyConsts'

	// BuiltinArrayLiteral discovery — sourced from the parser's static via the
	// loader-side accessor. Populated during the cache-miss parse, then carried
	// here so cache-hit runs in the same process (and the on-disk cache write
	// below) see the discovered name without re-parsing stdlib.
	data.builtinArrayLiteralTypeName = getCachedBuiltinArrayLiteralTypeName()

	// Cache v8: snapshot Phase 11 conformance + registry state. These
	// registries are populated during the cache-build pipeline's
	// `resolveTypes` (interfaces / conformances / typeParameters /
	// genericInstances / interfaceRegistry / genericTypealiases) and
	// `buildLayoutDescriptors` / `buildWitnessTables` passes (layoutDescriptors
	// / witnessTables / livenessRoots / staticRdataValues). Without
	// persisting them here, cache-hit user builds run with empty
	// conformance state — primitive `extension int implements Comparable`
	// and friends never reach `project.conformances`.
	captureRegistries(project, data: data)
end 'captureStdlibMetadata'

// Phase 11.4 (cache v8): copy each registry from the cache-build project
// into the cache buffer. Using the project's API (intern / insert / etc.)
// rather than struct copy preserves the parallel-array invariants — every
// registry uses linear-scan dedup, so a value-copy snapshot is identical
// to a fresh registry built by replaying the same intern calls.
function captureRegistries(project Project, data StdlibCacheData)
	for i in 0 upto project.typeParameters.count() 'eachTp'
		let declName = project.typeParameters.getDeclaringTypeName(i)
		let paramName = project.typeParameters.getName(i)
		_ = data.typeParameters.intern(declName, paramName: paramName)
		// Constraints (where-clause traits) are persisted because the
		// Constraints / where-clause path consults them at user-code call
		// sites. Stdlib's parser fills these during interface processing,
		// so a cache hit must reproduce them exactly.
		let cs = project.typeParameters.getConstraints(i)
		for c in cs 'eachConstraint'
			data.typeParameters.addConstraint(i, traitName: c)
		end 'eachConstraint'
	end 'eachTp'

	for i in 0 upto project.interfaceRegistry.count() 'eachIface'
		_ = data.interfaceRegistry.intern(project.interfaceRegistry.getName(i))
	end 'eachIface'

	for i in 0 upto project.genericInstances.count() 'eachGi'
		let (baseId, args) = project.genericInstances.get(i)
		_ = data.genericInstances.intern(baseId, args: args)
	end 'eachGi'

	for (name, iface) in project.interfaces 'eachInterface'
		try data.interfaces.insert(name, value: iface) otherwise ignore
	end 'eachInterface'

	for i in 0 upto project.conformances.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = project.conformances.get(i)
		_ = data.conformances.intern(typeName, interfaceName: ifaceName, withArgs: withArgs)
	end 'eachConf'

	for (name, t) in project.genericTypealiases 'eachGta'
		try data.genericTypealiases.insert(name, value: t) otherwise ignore
	end 'eachGta'

	for i in 0 upto project.layoutDescriptors.count() 'eachLd'
		let gid = try project.layoutDescriptors.instanceIds.get(i) otherwise panic("captureRegistries: layoutDescriptors.instanceIds.get OOB at {i}")
		let label = try project.layoutDescriptors.labels.get(i) otherwise panic("captureRegistries: layoutDescriptors.labels desync at {i}")
		data.layoutDescriptors.intern(gid, label: label)
	end 'eachLd'

	for i in 0 upto project.witnessTables.count() 'eachWt'
		let e = project.witnessTables.get(i)
		data.witnessTables.intern(e.typeName, interfaceName: e.interfaceName, label: e.label, methodImplNames: e.methodImplNames, parentWitnessLabel: e.parentWitnessLabel, isFatBoxed: e.isFatBoxed)
	end 'eachWt'

	for r in project.livenessRoots 'eachRoot'
		data.livenessRoots.push(r)
	end 'eachRoot'

	for (name, arity) in project.genericFunctionImplicitArity 'eachArity'
		try data.genericFunctionImplicitArity.insert(name, value: arity) otherwise ignore
	end 'eachArity'

	for (label, bytes) in project.staticRdataValues 'eachRdata'
		try data.staticRdataValues.insert(label, value: bytes) otherwise ignore
	end 'eachRdata'
end 'captureRegistries'

export function restoreStdlibMetadata(project Project, data StdlibCacheData)
	// Restore typealiases
	for (name, baseType) in data.typealiases 'restoreAliases'
		try project.typealiases.insert(name, value: baseType) otherwise ignore
	end 'restoreAliases'

	// Restore typealias ranges
	for (name, range) in data.typealiasRanges 'restoreRanges'
		try project.typealiasRanges.insert(name, value: range) otherwise ignore
	end 'restoreRanges'

	// Restore function return types and seed the method-name index in
	// lockstep so DFE's methodCall handling sees stdlib methods alongside
	// user-defined ones without a separate post-pass. MaxonType.named ids
	// embedded in the cached return types belong to the source project's
	// interner, so translate each through the captured typeNameTable into a
	// fresh id in the destination project before storing.
	for (name, rt) in data.funcReturnTypes 'restoreRts'
		let translated = translateMaxonReturnType(project, data: data, rt: rt)
		try project.funcReturnTypes.insert(name, value: translated) otherwise ignore
		project.methodNameIndex.record(name)
	end 'restoreRts'

	// Function signatures carry MaxonTypes embedded in paramTypes — same
	// captured-id concern as funcReturnTypes, so each signature is rebuilt
	// with the destination project's id space.
	for (name, sig) in data.funcSignatures 'restoreSigs'
		let translatedTypes = translateCapturedTypeArray(project, data: data, src: sig.paramTypes)
		try project.funcSignatures.insert(name, value: FuncSignature.create(sig.paramNames, paramTypes: translatedTypes, paramDefaults: sig.paramDefaults)) otherwise ignore
	end 'restoreSigs'

	// Rebuild `overloadedNames` from the restored signature names.
	// The overload bucket is populated by the parser when a second `function
	// foo` registers under the same qualified name — rekeyExistingFunction
	// re-mangles both entries to `foo$<suffix>` and pushes them onto
	// `project.overloadedNames[foo]`. The cache persists the post-mangle
	// signature names but not the bucket itself, so without this rebuild a
	// user-code call site looks up `Array.contains` and finds no variants
	// — overload resolution returns the bare name, the linker can't find
	// a body, and codegen produces a value-less call that trips the
	// register allocator.
	rebuildOverloadedNames(project)

	// Restore struct types. Field MaxonTypes carry the same captured-id
	// problem as funcReturnTypes — translate every named id through the
	// typeNameTable before insertion.
	for (name, st) in data.structTypes 'restoreStructs'
		let translated = translateStructType(project, data: data, st: st)
		try project.structTypes.insert(name, value: translated) otherwise ignore
	end 'restoreStructs'

	// Restore top-level constants
	for (name, entry) in data.topLevelConstants 'restoreConsts'
		try project.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'restoreConsts'

	// Republish BuiltinArrayLiteral discovery so the parser-side cache is live
	// for the user-code parse that follows. Empty string means stdlib didn't
	// declare an implementing type (or this cache predates v6); the parser
	// will emit a diagnostic on the first array literal in that case.
	setCachedBuiltinArrayLiteralTypeName(data.builtinArrayLiteralTypeName)

	// Cache v8: replay Phase 11 conformance + registry state. The on-disk
	// codec re-interns named/typeParameter/genericInstance/interface arms
	// through the destination project as it reads, so the captured
	// registries already carry destination-id-space MaxonTypes; copying
	// them onto `project` is a direct merge.
	restoreRegistries(project, data: data)
end 'restoreStdlibMetadata'

// Walk every signature name now in `project.funcSignatures` and rebuild
// `project.overloadedNames` by grouping mangled names under their bare
// qualified prefix. A signature named `Array.contains$Element` lands on
// `overloadedNames["Array.contains"]` alongside `Array.contains$ElementArray`.
// Names without a `$` are not overloaded and are skipped.
function rebuildOverloadedNames(project Project)
	for (name, _) in project.funcSignatures 'eachSig'
		let bare = stripFirstDollarPrefix(name)
		if bare.isEmpty() 'noDollar'
			continue
		end 'noDollar'
		var bucket = try project.overloadedNames.get(bare) otherwise QualifiedNameArray.create()
		var alreadyPresent = false
		for entry in bucket 'scanDup'
			if entry == name 'dup'
				alreadyPresent = true
				break
			end 'dup'
		end 'scanDup'
		if alreadyPresent 'skipDup'
			continue
		end 'skipDup'
		bucket.push(name)
		project.overloadedNames.upsert(bare, value: bucket)
	end 'eachSig'
end 'rebuildOverloadedNames'

function stripFirstDollarPrefix(s String) returns String
	let bytes = s.toByteArray()
	let dollarByte = 0x24 as byte
	var i = 0
	while i < bytes.count() 'scan'
		let b = try bytes.get(i) otherwise return ""
		if b == dollarByte 'hit'
			let head = try bytes.slice(0, endIndex: i) otherwise return ""
			return String.from(head)
		end 'hit'
		i = i + 1
	end 'scan'
	return ""
end 'stripFirstDollarPrefix'

// Phase 11.4 (cache v8): merge each captured registry into the destination
// project. Order matches the writer (typeParameters → interfaceRegistry →
// genericInstances → interfaces → conformances → genericTypealiases →
// layoutDescriptors → witnessTables → livenessRoots → staticRdataValues).
// Each merge is idempotent so a second restore (e.g. multiple compilation
// units in one process) is a no-op.
function restoreRegistries(project Project, data StdlibCacheData)
	// typeParameters and interfaceRegistry are name-keyed — re-interning by
	// `(declaringTypeName, paramName)` / `name` reproduces the source ordering
	// in the destination project's id space iff the destination is empty when
	// we start. (Stdlib bootstrap pre-parsed declarations may have allocated
	// some entries; intern still returns the right id for those.)
	for i in 0 upto data.typeParameters.count() 'eachTp'
		let declName = data.typeParameters.getDeclaringTypeName(i)
		let paramName = data.typeParameters.getName(i)
		let destId = project.typeParameters.intern(declName, paramName: paramName)
		let cs = data.typeParameters.getConstraints(i)
		for c in cs 'eachConstraint'
			project.typeParameters.addConstraint(destId, traitName: c)
		end 'eachConstraint'
	end 'eachTp'

	for i in 0 upto data.interfaceRegistry.count() 'eachIface'
		_ = project.interfaceRegistry.intern(data.interfaceRegistry.getName(i))
	end 'eachIface'

	// genericInstances entries reference captured `(baseId, args)` where
	// `baseId` is a captured typeNameTable index and each arg is a captured
	// MaxonType. Re-intern each through the destination project's registries
	// (via the shared helper) so subsequent lookups return ids whose payload
	// is meaningful in the destination id space.
	for i in 0 upto data.genericInstances.count() 'eachGi'
		_ = translateCapturedGenericInstanceId(project, data: data, id: i)
	end 'eachGi'

	// IrInterface entries store method signatures whose paramTypes / returnType
	// carry captured ids. Rebuild each method sig with translated MaxonTypes.
	for (name, iface) in data.interfaces 'eachInterface'
		try project.interfaces.insert(name, value: translateIrInterface(project, data: data, iface: iface)) otherwise ignore
	end 'eachInterface'

	// Conformance withArgs are MaxonTypeArrays — translate each entry's args
	// before interning so the destination registry's args reference
	// destination-project ids.
	for i in 0 upto data.conformances.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = data.conformances.get(i)
		let destWithArgs = translateCapturedTypeArray(project, data: data, src: withArgs)
		_ = project.conformances.intern(typeName, interfaceName: ifaceName, withArgs: destWithArgs)
	end 'eachConf'

	// genericTypealiases values are MaxonTypes (the resolved alias target).
	// Translate each before insertion.
	for (name, t) in data.genericTypealiases 'eachGta'
		try project.genericTypealiases.insert(name, value: translateMaxonType(project, data: data, t: t)) otherwise ignore
	end 'eachGta'

	// layoutDescriptors are keyed by GenericInstanceId. The captured `gid`
	// references `data.genericInstances` (source id space); translate to the
	// destination's gid by walking through the captured payload and re-interning.
	for i in 0 upto data.layoutDescriptors.count() 'eachLd'
		let sourceGid = try data.layoutDescriptors.instanceIds.get(i) otherwise panic("restoreRegistries: layoutDescriptors.instanceIds.get OOB at {i}")
		let label = try data.layoutDescriptors.labels.get(i) otherwise panic("restoreRegistries: layoutDescriptors.labels desync at {i}")
		let destGid = translateCapturedGenericInstanceId(project, data: data, id: sourceGid)
		project.layoutDescriptors.intern(destGid, label: label)
	end 'eachLd'

	for i in 0 upto data.witnessTables.count() 'eachWt'
		let e = data.witnessTables.get(i)
		project.witnessTables.intern(e.typeName, interfaceName: e.interfaceName, label: e.label, methodImplNames: e.methodImplNames, parentWitnessLabel: e.parentWitnessLabel, isFatBoxed: e.isFatBoxed)
	end 'eachWt'

	for r in data.livenessRoots 'eachRoot'
		project.livenessRoots.push(r)
	end 'eachRoot'

	// Phase 11.4: replay the generic-function implicit-arity map so the
	// per-function lowering can decide synthetic-arg-append at every call
	// site, not just for callees in the local stdModule.
	for (name, arity) in data.genericFunctionImplicitArity 'eachArity'
		try project.genericFunctionImplicitArity.insert(name, value: arity) otherwise ignore
	end 'eachArity'

	for (label, bytes) in data.staticRdataValues 'eachRdata'
		try project.staticRdataValues.insert(label, value: bytes) otherwise ignore
	end 'eachRdata'
end 'restoreRegistries'

// ============================================================
// Cache v8 codec helpers — Phase 11 registry round-trip.
// ============================================================
//
// Each codec mirrors the parallel-array shape of the registry it serializes.
// MaxonType / MaxonReturnType use the existing `writeMaxonType` /
// `readMaxonType` helpers in MaxonDialect.maxon — those re-intern through
// the destination project's registries during read, so callers don't need
// a separate `translateMaxonType` step on these fields.

// --- Visibility ---

function writeVisibility(buf ByteArray, v Visibility)
	writeDword(buf, value: v.rawValue)
end 'writeVisibility'

function readVisibility(buf ByteArray, offset ByteOffset) returns (Visibility, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let v = try Visibility.fromRawValue(raw) otherwise panic("corrupt cache: unknown Visibility tag {raw}")
	return (v, offset + 4)
end 'readVisibility'

// --- FilePath ---

function writeFilePath(buf ByteArray, p FilePath)
	writeString(buf, s: p.toString())
end 'writeFilePath'

function readFilePath(buf ByteArray, offset ByteOffset) returns (FilePath, ByteOffset)
	let (s, p) = readString(buf, offset: offset)
	let path = try FilePath.from(s) otherwise FilePath from ""
	return (path, p)
end 'readFilePath'

// --- StringArray ---

function writeStringArray(buf ByteArray, arr StringArray)
	writeDword(buf, value: arr.count())
	for s in arr 'eachString'
		writeString(buf, s: s)
	end 'eachString'
end 'writeStringArray'

function readStringArray(buf ByteArray, offset ByteOffset) returns (StringArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = StringArray.create()
	for _ in 0 upto count 'eachString'
		let (s, p) = readString(buf, offset: pos)
		pos = p
		arr.push(s)
	end 'eachString'
	return (arr, pos)
end 'readStringArray'

function writeMaxonTypeArray(project Project, buf ByteArray, arr MaxonTypeArray)
	writeDword(buf, value: arr.count())
	for t in arr 'eachType'
		writeMaxonType(project, buf: buf, t: t)
	end 'eachType'
end 'writeMaxonTypeArray'

function readMaxonTypeArray(project Project, buf ByteArray, offset ByteOffset) returns (MaxonTypeArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = MaxonTypeArray.create()
	for _ in 0 upto count 'eachType'
		let (t, p) = readMaxonType(project, buf: buf, offset: pos)
		pos = p
		arr.push(t)
	end 'eachType'
	return (arr, pos)
end 'readMaxonTypeArray'

// --- TypeParamRegistry ---

function writeTypeParamRegistry(buf ByteArray, registry TypeParamRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachEntry'
		writeString(buf, s: registry.getDeclaringTypeName(i))
		writeString(buf, s: registry.getName(i))
		let cs = registry.getConstraints(i)
		writeStringArray(buf, arr: cs)
	end 'eachEntry'
end 'writeTypeParamRegistry'

function readTypeParamRegistry(buf ByteArray, offset ByteOffset) returns (TypeParamRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = TypeParamRegistry.create()
	for _ in 0 upto count 'eachEntry'
		let (declName, p1) = readString(buf, offset: pos)
		pos = p1
		let (paramName, p2) = readString(buf, offset: pos)
		pos = p2
		let id = registry.intern(declName, paramName: paramName)
		let (constraints, p3) = readStringArray(buf, offset: pos)
		pos = p3
		for c in constraints 'eachConstraint'
			registry.addConstraint(id, traitName: c)
		end 'eachConstraint'
	end 'eachEntry'
	return (registry, pos)
end 'readTypeParamRegistry'

// --- InterfaceTypeRegistry ---

function writeInterfaceTypeRegistry(buf ByteArray, registry InterfaceTypeRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachName'
		writeString(buf, s: registry.getName(i))
	end 'eachName'
end 'writeInterfaceTypeRegistry'

function readInterfaceTypeRegistry(buf ByteArray, offset ByteOffset) returns (InterfaceTypeRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = InterfaceTypeRegistry.create()
	for _ in 0 upto count 'eachName'
		let (name, p) = readString(buf, offset: pos)
		pos = p
		_ = registry.intern(name)
	end 'eachName'
	return (registry, pos)
end 'readInterfaceTypeRegistry'

// --- GenericInstanceRegistry ---

function writeGenericInstanceRegistry(project Project, buf ByteArray, registry GenericInstanceRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachInst'
		let (baseId, args) = registry.get(i)
		// Persist the base name (not the local id) so the reader re-interns
		// through the destination project's `typeNames` and gets a meaningful
		// id in its own id space.
		writeString(buf, s: project.typeNames.get(baseId))
		writeMaxonTypeArray(project, buf: buf, arr: args)
	end 'eachInst'
end 'writeGenericInstanceRegistry'

function readGenericInstanceRegistry(project Project, buf ByteArray, offset ByteOffset) returns (GenericInstanceRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = GenericInstanceRegistry.create()
	for _ in 0 upto count 'eachInst'
		let (baseName, p1) = readString(buf, offset: pos)
		pos = p1
		let (args, p2) = readMaxonTypeArray(project, buf: buf, offset: pos)
		pos = p2
		let baseId = project.typeNames.intern(baseName)
		_ = registry.intern(baseId, args: args)
	end 'eachInst'
	return (registry, pos)
end 'readGenericInstanceRegistry'

// --- IrInterface map ---

function writeInterfaceMethodSig(project Project, buf ByteArray, sig InterfaceMethodSig)
	writeString(buf, s: sig.name)
	writeStringArray(buf, arr: sig.paramNames)
	writeMaxonTypeArray(project, buf: buf, arr: sig.paramTypes)
	writeMaxonReturnType(project, buf: buf, rt: sig.returnType)
	writeString(buf, s: sig.throwsTypeName)
	writeBoolByte(buf, b: sig.isStatic)
	writeDword(buf, value: sig.line)
	writeDword(buf, value: sig.column)
end 'writeInterfaceMethodSig'

function readInterfaceMethodSig(project Project, buf ByteArray, offset ByteOffset) returns (InterfaceMethodSig, ByteOffset)
	let (name, p1) = readString(buf, offset: offset)
	let (paramNames, p2) = readStringArray(buf, offset: p1)
	let (paramTypes, p3) = readMaxonTypeArray(project, buf: buf, offset: p2)
	let (returnType, p4) = readMaxonReturnType(project, buf: buf, offset: p3)
	let (throwsTypeName, p5) = readString(buf, offset: p4)
	let (isStatic, p6) = readBoolByte(buf, offset: p5)
	let line = readDword(buf, offset: p6)
	let column = readDword(buf, offset: p6 + 4)
	return (InterfaceMethodSig.create(name, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType, throwsTypeName: throwsTypeName, isStatic: isStatic, line: line, column: column), p6 + 8)
end 'readInterfaceMethodSig'

function writeInterfaceMap(project Project, buf ByteArray, m IrInterfaceMap)
	writeDword(buf, value: m.count())
	for (name, iface) in m 'eachIface'
		writeString(buf, s: name)
		writeString(buf, s: iface.name)
		writeStringArray(buf, arr: iface.extendsNames)
		writeStringArray(buf, arr: iface.usesParams)
		writeDword(buf, value: iface.methods.count())
		for sig in iface.methods 'eachMethod'
			writeInterfaceMethodSig(project, buf: buf, sig: sig)
		end 'eachMethod'
		writeVisibility(buf, v: iface.visibility)
		writeDword(buf, value: iface.line)
		writeDword(buf, value: iface.column)
		writeFilePath(buf, p: iface.filePath)
	end 'eachIface'
end 'writeInterfaceMap'

function readInterfaceMap(project Project, buf ByteArray, offset ByteOffset) returns (IrInterfaceMap, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = IrInterfaceMap.create()
	for _ in 0 upto count 'eachIface'
		let (key, p1) = readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = readString(buf, offset: pos)
		pos = p2
		let (extendsNames, p3) = readStringArray(buf, offset: pos)
		pos = p3
		let (usesParams, p4) = readStringArray(buf, offset: pos)
		pos = p4
		let methodCount = readDword(buf, offset: pos)
		pos = pos + 4
		var methods = InterfaceMethodSigArray.create()
		for _ in 0 upto methodCount 'eachMethod'
			let (sig, p5) = readInterfaceMethodSig(project, buf: buf, offset: pos)
			pos = p5
			methods.push(sig)
		end 'eachMethod'
		let (visibility, p6) = readVisibility(buf, offset: pos)
		pos = p6
		let line = readDword(buf, offset: pos)
		pos = pos + 4
		let column = readDword(buf, offset: pos)
		pos = pos + 4
		let (filePath, p7) = readFilePath(buf, offset: pos)
		pos = p7
		let iface = IrInterface.create(ifaceName, extendsNames: extendsNames, usesParams: usesParams, methods: methods, visibility: visibility, line: line, column: column, filePath: filePath)
		try m.insert(key, value: iface) otherwise ignore
	end 'eachIface'
	return (m, pos)
end 'readInterfaceMap'

// --- ConformanceRegistry ---

function writeConformanceRegistry(project Project, buf ByteArray, registry ConformanceRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = registry.get(i)
		writeString(buf, s: typeName)
		writeString(buf, s: ifaceName)
		writeMaxonTypeArray(project, buf: buf, arr: withArgs)
	end 'eachConf'
end 'writeConformanceRegistry'

function readConformanceRegistry(project Project, buf ByteArray, offset ByteOffset) returns (ConformanceRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = ConformanceRegistry.create()
	for _ in 0 upto count 'eachConf'
		let (typeName, p1) = readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = readString(buf, offset: pos)
		pos = p2
		let (withArgs, p3) = readMaxonTypeArray(project, buf: buf, offset: pos)
		pos = p3
		_ = registry.intern(typeName, interfaceName: ifaceName, withArgs: withArgs)
	end 'eachConf'
	return (registry, pos)
end 'readConformanceRegistry'

// --- GenericTypealiasMap ---

function writeGenericTypealiasMap(project Project, buf ByteArray, m GenericTypealiasMap)
	writeDword(buf, value: m.count())
	for (name, t) in m 'eachAlias'
		writeString(buf, s: name)
		writeMaxonType(project, buf: buf, t: t)
	end 'eachAlias'
end 'writeGenericTypealiasMap'

function readGenericTypealiasMap(project Project, buf ByteArray, offset ByteOffset) returns (GenericTypealiasMap, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = GenericTypealiasMap.create()
	for _ in 0 upto count 'eachAlias'
		let (name, p1) = readString(buf, offset: pos)
		pos = p1
		let (t, p2) = readMaxonType(project, buf: buf, offset: pos)
		pos = p2
		try m.insert(name, value: t) otherwise ignore
	end 'eachAlias'
	return (m, pos)
end 'readGenericTypealiasMap'

// --- LayoutDescriptorRegistry ---

function writeLayoutDescriptorRegistry(buf ByteArray, registry LayoutDescriptorRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachLd'
		let gid = try registry.instanceIds.get(i) otherwise panic("writeLayoutDescriptorRegistry: instanceIds.get OOB at {i}")
		let label = try registry.labels.get(i) otherwise panic("writeLayoutDescriptorRegistry: labels desync at {i}")
		writeQword(buf, value: gid)
		writeString(buf, s: label)
	end 'eachLd'
end 'writeLayoutDescriptorRegistry'

function readLayoutDescriptorRegistry(buf ByteArray, offset ByteOffset) returns (LayoutDescriptorRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = LayoutDescriptorRegistry.create()
	for _ in 0 upto count 'eachLd'
		let gid = readQword(buf, offset: pos)
		pos = pos + 8
		let (label, p) = readString(buf, offset: pos)
		pos = p
		registry.intern(gid, label: label)
	end 'eachLd'
	return (registry, pos)
end 'readLayoutDescriptorRegistry'

// --- WitnessTableRegistry ---

function writeWitnessTableRegistry(buf ByteArray, registry WitnessTableRegistry)
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachWt'
		let e = registry.get(i)
		writeString(buf, s: e.typeName)
		writeString(buf, s: e.interfaceName)
		writeString(buf, s: e.label)
		writeStringArray(buf, arr: e.methodImplNames)
		writeString(buf, s: e.parentWitnessLabel)
		var fatRaw = 0 as MachineWord
		if e.isFatBoxed 'isFat'
			fatRaw = 1
		end 'isFat'
		writeDword(buf, value: fatRaw)
	end 'eachWt'
end 'writeWitnessTableRegistry'

function readWitnessTableRegistry(buf ByteArray, offset ByteOffset) returns (WitnessTableRegistry, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = WitnessTableRegistry.create()
	for _ in 0 upto count 'eachWt'
		let (typeName, p1) = readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = readString(buf, offset: pos)
		pos = p2
		let (label, p3) = readString(buf, offset: pos)
		pos = p3
		let (methodImplNames, p4) = readStringArray(buf, offset: pos)
		pos = p4
		let (parentLabel, p5) = readString(buf, offset: pos)
		pos = p5
		let isFatRaw = readDword(buf, offset: pos)
		pos = pos + 4
		let isFatBoxed = isFatRaw != 0
		registry.intern(typeName, interfaceName: ifaceName, label: label, methodImplNames: methodImplNames, parentWitnessLabel: parentLabel, isFatBoxed: isFatBoxed)
	end 'eachWt'
	return (registry, pos)
end 'readWitnessTableRegistry'

// --- GenericFunctionImplicitArityMap ---

function writeGenericFunctionImplicitArityMap(buf ByteArray, m GenericFunctionImplicitArityMap)
	writeDword(buf, value: m.count())
	for (name, arity) in m 'eachEntry'
		writeString(buf, s: name)
		writeDword(buf, value: arity as MachineWord)
	end 'eachEntry'
end 'writeGenericFunctionImplicitArityMap'

function readGenericFunctionImplicitArityMap(buf ByteArray, offset ByteOffset) returns (GenericFunctionImplicitArityMap, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = GenericFunctionImplicitArityMap.create()
	for _ in 0 upto count 'eachEntry'
		let (name, p1) = readString(buf, offset: pos)
		pos = p1
		let arity = readDword(buf, offset: pos)
		pos = pos + 4
		try m.insert(name, value: arity as ParsedInt) otherwise ignore
	end 'eachEntry'
	return (m, pos)
end 'readGenericFunctionImplicitArityMap'

// --- StaticRdataValueMap ---

function writeStaticRdataValueMap(buf ByteArray, m StaticRdataValueMap)
	writeDword(buf, value: m.count())
	for (label, bytes) in m 'eachEntry'
		writeString(buf, s: label)
		writeDword(buf, value: bytes.count())
		buf.append(bytes)
	end 'eachEntry'
end 'writeStaticRdataValueMap'

function readStaticRdataValueMap(buf ByteArray, offset ByteOffset) returns (StaticRdataValueMap, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = StaticRdataValueMap.create()
	for _ in 0 upto count 'eachEntry'
		let (label, p1) = readString(buf, offset: pos)
		pos = p1
		let len = readDword(buf, offset: pos)
		pos = pos + 4
		var bytes = ByteArray.create()
		bytes.reserve(len)
		for _ in 0 upto len 'copyByte'
			let b = try buf.get(pos) otherwise panic("readStaticRdataValueMap: buffer truncated at {pos}")
			bytes.push(b)
			pos = pos + 1
		end 'copyByte'
		try m.insert(label, value: bytes) otherwise ignore
	end 'eachEntry'
	return (m, pos)
end 'readStaticRdataValueMap'

// ============================================================
// Cache v10 codec helpers — Phase 11.6 stdlib StdModule round-trip.
// ============================================================
//
// Persists the stdlib's post-dce StdModule so the user pipeline's inliner
// pass can splice stdlib accessor bodies. Symmetric pairs: each
// `write<TypeName>` matches the value's variants and emits ordinal +
// payload; each `read<TypeName>` reads the ordinal, lifts via
// `unionCases.fromRawValue`, and dispatches to a per-variant helper that
// returns the freshly-constructed union value plus the post-read offset.
// Match arms in this language are single-statement, so the read side
// factors every multi-statement arm into a `read<Variant>Inner` helper.

// --- Bool byte helper ---
//
// Single-byte encoding for bool fields. Persisting a 1-bit flag in 8
// bytes via writeQword would cost ~6KB across a typical stdlib's worth
// of system ops. One byte per flag keeps the codec compact.

function writeBoolByte(buf ByteArray, b bool)
	if b 'isTrue'
		buf.push(1 as byte)
	end 'isTrue' else 'isFalse'
		buf.push(0 as byte)
	end 'isFalse'
end 'writeBoolByte'

function readBoolByte(buf ByteArray, offset ByteOffset) returns (bool, ByteOffset)
	let b = try buf.get(offset) otherwise panic("readBoolByte: buf truncated at {offset}")
	return (b != 0, offset + 1)
end 'readBoolByte'

// --- ValueIdArray ---

function writeValueIdArrayCodec(buf ByteArray, arr ValueIdArray)
	writeDword(buf, value: arr.count())
	for v in arr 'each'
		writeQword(buf, value: v)
	end 'each'
end 'writeValueIdArrayCodec'

function readValueIdArrayCodec(buf ByteArray, offset ByteOffset) returns (ValueIdArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = ValueIdArray.create()
	for _ in 0 upto count 'each'
		let v = readQword(buf, offset: pos)
		pos = pos + 8
		arr.push(v)
	end 'each'
	return (arr, pos)
end 'readValueIdArrayCodec'

// --- StdTypeArray ---

function writeStdTypeArrayCodec(buf ByteArray, arr StdTypeArray)
	writeDword(buf, value: arr.count())
	for t in arr 'each'
		writeStdTypeTag(buf, t: t)
	end 'each'
end 'writeStdTypeArrayCodec'

function readStdTypeArrayCodec(buf ByteArray, offset ByteOffset) returns (StdTypeArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = StdTypeArray.create()
	for _ in 0 upto count 'each'
		let (t, p) = readStdTypeTag(buf, offset: pos)
		pos = p
		arr.push(t)
	end 'each'
	return (arr, pos)
end 'readStdTypeArrayCodec'

// --- StdArithConst / StdArithUnaryOp / StdArithBinaryOp ---

function writeStdArithConst(buf ByteArray, c StdArithConst)
	writeDword(buf, value: c.opcode.ordinal)
	writeQword(buf, value: c.resultId)
	writeQword(buf, value: c.value)
end 'writeStdArithConst'

function readStdArithConst(buf ByteArray, offset ByteOffset) returns (StdArithConst, ByteOffset)
	let opRaw = readDword(buf, offset: offset)
	let opcode = liftStdArithConstOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let value = readQword(buf, offset: offset + 12)
	return (StdArithConst.create(opcode: opcode, resultId: resultId, value: value as ParsedInt), offset + 20)
end 'readStdArithConst'

function liftStdArithConstOpcode(raw MachineWord) returns StdArithConstOpcode
	let kase = try StdArithConstOpcode.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdArithConstOpcode {raw}")
	return match kase 'oc'
		constI64 gives StdArithConstOpcode.constI64
		constF64 gives StdArithConstOpcode.constF64
	end 'oc'
end 'liftStdArithConstOpcode'

function writeStdArithUnaryOp(buf ByteArray, u StdArithUnaryOp)
	writeDword(buf, value: u.opcode.ordinal)
	writeQword(buf, value: u.resultId)
	writeQword(buf, value: u.operandId)
end 'writeStdArithUnaryOp'

function readStdArithUnaryOp(buf ByteArray, offset ByteOffset) returns (StdArithUnaryOp, ByteOffset)
	let opRaw = readDword(buf, offset: offset)
	let opcode = liftStdArithUnaryOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let operandId = readQword(buf, offset: offset + 12)
	return (StdArithUnaryOp.create(opcode: opcode, resultId: resultId, operandId: operandId), offset + 20)
end 'readStdArithUnaryOp'

function liftStdArithUnaryOpcode(raw MachineWord) returns StdArithUnaryOpcode
	let kase = try StdArithUnaryOpcode.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdArithUnaryOpcode {raw}")
	return match kase 'oc'
		negI64 gives StdArithUnaryOpcode.negI64
		bitNotI64 gives StdArithUnaryOpcode.bitNotI64
		fpToSiI64 gives StdArithUnaryOpcode.fpToSiI64
		siToFpF64 gives StdArithUnaryOpcode.siToFpF64
		sqrtF64 gives StdArithUnaryOpcode.sqrtF64
		floorF64 gives StdArithUnaryOpcode.floorF64
		ceilF64 gives StdArithUnaryOpcode.ceilF64
		roundF64 gives StdArithUnaryOpcode.roundF64
		absF64 gives StdArithUnaryOpcode.absF64
	end 'oc'
end 'liftStdArithUnaryOpcode'

function writeStdArithBinaryOp(buf ByteArray, b StdArithBinaryOp)
	writeDword(buf, value: b.opcode.ordinal)
	writeQword(buf, value: b.resultId)
	writeQword(buf, value: b.leftId)
	writeQword(buf, value: b.rightId)
end 'writeStdArithBinaryOp'

function readStdArithBinaryOp(buf ByteArray, offset ByteOffset) returns (StdArithBinaryOp, ByteOffset)
	let opRaw = readDword(buf, offset: offset)
	let opcode = liftStdArithBinaryOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let leftId = readQword(buf, offset: offset + 12)
	let rightId = readQword(buf, offset: offset + 20)
	return (StdArithBinaryOp.create(opcode: opcode, resultId: resultId, leftId: leftId, rightId: rightId), offset + 28)
end 'readStdArithBinaryOp'

function liftStdArithBinaryOpcode(raw MachineWord) returns StdArithBinaryOpcode
	let kase = try StdArithBinaryOpcode.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdArithBinaryOpcode {raw}")
	return match kase 'oc'
		addI64 gives StdArithBinaryOpcode.addI64
		subI64 gives StdArithBinaryOpcode.subI64
		mulI64 gives StdArithBinaryOpcode.mulI64
		divI64 gives StdArithBinaryOpcode.divI64
		remI64 gives StdArithBinaryOpcode.remI64
		andI64 gives StdArithBinaryOpcode.andI64
		orI64 gives StdArithBinaryOpcode.orI64
		orI1 gives StdArithBinaryOpcode.orI1
		xorI64 gives StdArithBinaryOpcode.xorI64
		shlI64 gives StdArithBinaryOpcode.shlI64
		shrI64 gives StdArithBinaryOpcode.shrI64
		addF64 gives StdArithBinaryOpcode.addF64
		subF64 gives StdArithBinaryOpcode.subF64
		mulF64 gives StdArithBinaryOpcode.mulF64
		divF64 gives StdArithBinaryOpcode.divF64
		cmpI64Eq gives StdArithBinaryOpcode.cmpI64Eq
		cmpI64Ne gives StdArithBinaryOpcode.cmpI64Ne
		cmpI64Lt gives StdArithBinaryOpcode.cmpI64Lt
		cmpI64Le gives StdArithBinaryOpcode.cmpI64Le
		cmpI64Gt gives StdArithBinaryOpcode.cmpI64Gt
		cmpI64Ge gives StdArithBinaryOpcode.cmpI64Ge
		cmpI64Ugt gives StdArithBinaryOpcode.cmpI64Ugt
		cmpF64Eq gives StdArithBinaryOpcode.cmpF64Eq
		cmpF64Ne gives StdArithBinaryOpcode.cmpF64Ne
		cmpF64Lt gives StdArithBinaryOpcode.cmpF64Lt
		cmpF64Le gives StdArithBinaryOpcode.cmpF64Le
		cmpF64Gt gives StdArithBinaryOpcode.cmpF64Gt
		cmpF64Ge gives StdArithBinaryOpcode.cmpF64Ge
	end 'oc'
end 'liftStdArithBinaryOpcode'

// --- StdArithOp ---

function writeStdArithOp(buf ByteArray, op StdArithOp)
	writeDword(buf, value: op.ordinal)
	match op 'arith'
		const(c) then writeStdArithConst(buf, c: c)
		unary(u) then writeStdArithUnaryOp(buf, u: u)
		binary(bin) then writeStdArithBinaryOp(buf, b: bin)
	end 'arith'
end 'writeStdArithOp'

function readStdArithOp(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdArithOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdArithOp tag {raw}")
	return match kase 'arith'
		const gives readStdArithOpConst(buf, offset: offset + 4)
		unary gives readStdArithOpUnary(buf, offset: offset + 4)
		binary gives readStdArithOpBinary(buf, offset: offset + 4)
	end 'arith'
end 'readStdArithOp'

function readStdArithOpConst(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset)
	let (c, p) = readStdArithConst(buf, offset: offset)
	return (StdArithOp.const(c), p)
end 'readStdArithOpConst'

function readStdArithOpUnary(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset)
	let (u, p) = readStdArithUnaryOp(buf, offset: offset)
	return (StdArithOp.unary(u), p)
end 'readStdArithOpUnary'

function readStdArithOpBinary(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset)
	let (binOp, p) = readStdArithBinaryOp(buf, offset: offset)
	return (StdArithOp.binary(binOp), p)
end 'readStdArithOpBinary'

// --- StdControlOp ---

function writeStdControlOp(buf ByteArray, op StdControlOp)
	writeDword(buf, value: op.ordinal)
	match op 'cf'
		br(target, argIds) then writeStdControlBr(buf, target: target, argIds: argIds)
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) then writeStdControlCondBr(buf, condId: condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds)
	end 'cf'
end 'writeStdControlOp'

function writeStdControlBr(buf ByteArray, target BlockId, argIds ValueIdArray)
	writeQword(buf, value: target)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdControlBr'

function writeStdControlCondBr(buf ByteArray, condId ValueId, thenTarget BlockId, thenArgIds ValueIdArray, elseTarget BlockId, elseArgIds ValueIdArray)
	writeQword(buf, value: condId)
	writeQword(buf, value: thenTarget)
	writeValueIdArrayCodec(buf, arr: thenArgIds)
	writeQword(buf, value: elseTarget)
	writeValueIdArrayCodec(buf, arr: elseArgIds)
end 'writeStdControlCondBr'

function readStdControlOp(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdControlOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdControlOp tag {raw}")
	return match kase 'cf'
		br gives readStdControlOpBr(buf, offset: offset + 4)
		condBr gives readStdControlOpCondBr(buf, offset: offset + 4)
	end 'cf'
end 'readStdControlOp'

function readStdControlOpBr(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset)
	let target = readQword(buf, offset: offset)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 8)
	return (StdControlOp.br(target, argIds: argIds), p)
end 'readStdControlOpBr'

function readStdControlOpCondBr(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset)
	let condId = readQword(buf, offset: offset)
	let thenTarget = readQword(buf, offset: offset + 8)
	let (thenArgIds, p1) = readValueIdArrayCodec(buf, offset: offset + 16)
	let elseTarget = readQword(buf, offset: p1)
	let (elseArgIds, p2) = readValueIdArrayCodec(buf, offset: p1 + 8)
	return (StdControlOp.condBr(condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds), p2)
end 'readStdControlOpCondBr'

// --- StdCallOp ---

function writeStdCallOp(buf ByteArray, op StdCallOp)
	writeDword(buf, value: op.ordinal)
	match op 'call'
		ret(retValId) then writeQword(buf, value: retValId)
		call(resultId, callee, argIds) then writeStdCallCall(buf, resultId: resultId, callee: callee, argIds: argIds)
		tryCall(resultId, callee, argIds, errorFlagId) then writeStdCallTryCall(buf, resultId: resultId, callee: callee, argIds: argIds, errorFlagId: errorFlagId)
		indirectCall(resultId, calleeId, argIds) then writeStdCallIndirect(buf, resultId: resultId, calleeId: calleeId, argIds: argIds)
		funcRef(resultId, funcName) then writeStdCallFuncRef(buf, resultId: resultId, funcName: funcName)
		tailCall(callee, argIds) then writeStdCallTail(buf, callee: callee, argIds: argIds)
		param(resultId, paramIndex, paramType) then writeStdCallParam(buf, resultId: resultId, paramIndex: paramIndex, paramType: paramType)
		errorReturn(retValId, errorFlagId) then writeStdCallErrorReturn(buf, retValId: retValId, errorFlagId: errorFlagId)
	end 'call'
end 'writeStdCallOp'

function writeStdCallCall(buf ByteArray, resultId ValueId, callee String, argIds ValueIdArray)
	writeQword(buf, value: resultId)
	writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallCall'

function writeStdCallTryCall(buf ByteArray, resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId)
	writeQword(buf, value: resultId)
	writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
	writeQword(buf, value: errorFlagId)
end 'writeStdCallTryCall'

function writeStdCallIndirect(buf ByteArray, resultId ValueId, calleeId ValueId, argIds ValueIdArray)
	writeQword(buf, value: resultId)
	writeQword(buf, value: calleeId)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallIndirect'

function writeStdCallFuncRef(buf ByteArray, resultId ValueId, funcName String)
	writeQword(buf, value: resultId)
	writeString(buf, s: funcName)
end 'writeStdCallFuncRef'

function writeStdCallTail(buf ByteArray, callee String, argIds ValueIdArray)
	writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallTail'

function writeStdCallParam(buf ByteArray, resultId ValueId, paramIndex VarSlot, paramType StdType)
	writeQword(buf, value: resultId)
	writeQword(buf, value: paramIndex)
	writeStdTypeTag(buf, t: paramType)
end 'writeStdCallParam'

function writeStdCallErrorReturn(buf ByteArray, retValId ValueId, errorFlagId ValueId)
	writeQword(buf, value: retValId)
	writeQword(buf, value: errorFlagId)
end 'writeStdCallErrorReturn'

function readStdCallOp(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdCallOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdCallOp tag {raw}")
	return match kase 'call'
		ret gives readStdCallRet(buf, offset: offset + 4)
		call gives readStdCallCall(buf, offset: offset + 4)
		tryCall gives readStdCallTryCall(buf, offset: offset + 4)
		indirectCall gives readStdCallIndirect(buf, offset: offset + 4)
		funcRef gives readStdCallFuncRef(buf, offset: offset + 4)
		tailCall gives readStdCallTail(buf, offset: offset + 4)
		param gives readStdCallParam(buf, offset: offset + 4)
		errorReturn gives readStdCallErrorReturn(buf, offset: offset + 4)
	end 'call'
end 'readStdCallOp'

function readStdCallRet(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let retValId = readQword(buf, offset: offset)
	return (StdCallOp.ret(retValId), offset + 8)
end 'readStdCallRet'

function readStdCallCall(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (callee, p1) = readString(buf, offset: offset + 8)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	return (StdCallOp.call(resultId, callee: callee, argIds: argIds), p2)
end 'readStdCallCall'

function readStdCallTryCall(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (callee, p1) = readString(buf, offset: offset + 8)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	let errorFlagId = readQword(buf, offset: p2)
	return (StdCallOp.tryCall(resultId, callee: callee, argIds: argIds, errorFlagId: errorFlagId), p2 + 8)
end 'readStdCallTryCall'

function readStdCallIndirect(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let calleeId = readQword(buf, offset: offset + 8)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 16)
	return (StdCallOp.indirectCall(resultId, calleeId: calleeId, argIds: argIds), p)
end 'readStdCallIndirect'

function readStdCallFuncRef(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (funcName, p) = readString(buf, offset: offset + 8)
	return (StdCallOp.funcRef(resultId, funcName: funcName), p)
end 'readStdCallFuncRef'

function readStdCallTail(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let (callee, p1) = readString(buf, offset: offset)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	return (StdCallOp.tailCall(callee, argIds: argIds), p2)
end 'readStdCallTail'

function readStdCallParam(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let paramIndex = readQword(buf, offset: offset + 8)
	let (paramType, p) = readStdTypeTag(buf, offset: offset + 16)
	return (StdCallOp.param(resultId, paramIndex: paramIndex, paramType: paramType), p)
end 'readStdCallParam'

function readStdCallErrorReturn(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let retValId = readQword(buf, offset: offset)
	let errorFlagId = readQword(buf, offset: offset + 8)
	return (StdCallOp.errorReturn(retValId, errorFlagId: errorFlagId), offset + 16)
end 'readStdCallErrorReturn'

// --- StdMemoryOp ---

function writeStdMemoryOp(buf ByteArray, op StdMemoryOp)
	writeDword(buf, value: op.ordinal)
	match op 'mem'
		storeSlot(slotId, valueId) then writeStdMemoryStore(buf, slotId: slotId, valueId: valueId)
		loadSlot(resultId, slotId) then writeStdMemoryLoad(buf, resultId: resultId, slotId: slotId)
	end 'mem'
end 'writeStdMemoryOp'

function writeStdMemoryStore(buf ByteArray, slotId VarSlot, valueId ValueId)
	writeQword(buf, value: slotId)
	writeQword(buf, value: valueId)
end 'writeStdMemoryStore'

function writeStdMemoryLoad(buf ByteArray, resultId ValueId, slotId VarSlot)
	writeQword(buf, value: resultId)
	writeQword(buf, value: slotId)
end 'writeStdMemoryLoad'

function readStdMemoryOp(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdMemoryOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdMemoryOp tag {raw}")
	return match kase 'mem'
		storeSlot gives readStdMemoryStore(buf, offset: offset + 4)
		loadSlot gives readStdMemoryLoad(buf, offset: offset + 4)
	end 'mem'
end 'readStdMemoryOp'

function readStdMemoryStore(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset)
	let slotId = readQword(buf, offset: offset)
	let valueId = readQword(buf, offset: offset + 8)
	return (StdMemoryOp.storeSlot(slotId, valueId: valueId), offset + 16)
end 'readStdMemoryStore'

function readStdMemoryLoad(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let slotId = readQword(buf, offset: offset + 8)
	return (StdMemoryOp.loadSlot(resultId, slotId: slotId), offset + 16)
end 'readStdMemoryLoad'

// --- StdSystemOp ---
//
// The largest variant set: every system op is serialized tag + payload.
// Each variant has both a `writeStdSys<Variant>` and a
// `readStdSys<Variant>` helper because the language requires single-
// statement match arms.

function writeStdSystemOp(buf ByteArray, op StdSystemOp)
	writeDword(buf, value: op.ordinal)
	match op 'sys'
		syscall(resultId, number, argIds) then writeStdSysSyscall(buf, resultId: resultId, number: number, argIds: argIds)
		iatCall(resultId, slotIndex, argIds) then writeStdSysIatCall(buf, resultId: resultId, slotIndex: slotIndex, argIds: argIds)
		globalAddr(resultId, name) then writeStdSysGlobalAddr(buf, resultId: resultId, name: name)
		memcpy(dstId, srcId, lenId) then writeStdSysMemcpy(buf, dstId: dstId, srcId: srcId, lenId: lenId)
		stackAddr(resultId, slotId) then writeStdSysStackAddr(buf, resultId: resultId, slotId: slotId)
		storeByte(baseId, offsetId, byteId) then writeStdSysStoreByte(buf, baseId: baseId, offsetId: offsetId, byteId: byteId)
		loadByte(resultId, baseId, offsetId) then writeStdSysLoadByte(buf, resultId: resultId, baseId: baseId, offsetId: offsetId)
		osExit(codeId) then writeQword(buf, value: codeId)
		osWrite(ptrId, lenId) then writeStdSysOsWrite(buf, ptrId: ptrId, lenId: lenId)
		free(ptrId) then writeQword(buf, value: ptrId)
		osWriteErr(ptrId, lenId) then writeStdSysOsWriteErr(buf, ptrId: ptrId, lenId: lenId)
		osOpenWrite(resultId, pathPtrId, pathLenId) then writeStdSysOsOpenWrite(buf, resultId: resultId, pathPtrId: pathPtrId, pathLenId: pathLenId)
		osWriteFd(fdId, ptrId, lenId) then writeStdSysOsWriteFd(buf, fdId: fdId, ptrId: ptrId, lenId: lenId)
		osClose(fdId) then writeQword(buf, value: fdId)
		osGetEnv(resultId, namePtrId, nameLenId, outBufPtrId, outBufLenId) then writeStdSysOsGetEnv(buf, resultId: resultId, namePtrId: namePtrId, nameLenId: nameLenId, outBufPtrId: outBufPtrId, outBufLenId: outBufLenId)
		loadFramePtr(resultId) then writeQword(buf, value: resultId)
		loadIndirect(resultId, addrId, offset, isFloat) then writeStdSysLoadIndirect(buf, resultId: resultId, addrId: addrId, offset: offset, isFloat: isFloat)
		funcAddr(resultId, name) then writeStdSysFuncAddr(buf, resultId: resultId, name: name)
		storeIndirect(addrId, offset, valueId, isFloat) then writeStdSysStoreIndirect(buf, addrId: addrId, offset: offset, valueId: valueId, isFloat: isFloat)
		drop(valueId) then writeQword(buf, value: valueId)
		osAllocPages(resultId, sizeId) then writeStdSysOsAllocPages(buf, resultId: resultId, sizeId: sizeId)
		osAllocPagesLarge(resultId, sizeId) then writeStdSysOsAllocPagesLarge(buf, resultId: resultId, sizeId: sizeId)
		osFreePages(ptrId, sizeId) then writeStdSysOsFreePages(buf, ptrId: ptrId, sizeId: sizeId)
		atomicInc(addrId) then writeQword(buf, value: addrId)
		atomicDec(addrId) then writeQword(buf, value: addrId)
		atomicXadd(resultId, addrId, valId) then writeStdSysAtomicXadd(buf, resultId: resultId, addrId: addrId, valId: valId)
		osLockInit(addrId) then writeQword(buf, value: addrId)
		osLockAcquire(addrId) then writeQword(buf, value: addrId)
		osLockRelease(addrId) then writeQword(buf, value: addrId)
		boxValue(resultId, valueId, sizeId) then writeStdSysBoxValue(buf, resultId: resultId, valueId: valueId, sizeId: sizeId)
		unboxValue(resultId, ptrId, sizeId) then writeStdSysUnboxValue(buf, resultId: resultId, ptrId: ptrId, sizeId: sizeId)
		loadLayoutDescriptor(resultId, label) then writeStdSysLoadLayoutDescriptor(buf, resultId: resultId, label: label)
		loadWitnessTable(resultId, label) then writeStdSysLoadWitnessTable(buf, resultId: resultId, label: label)
		descriptorField(resultId, descAddrId, field) then writeStdSysDescriptorField(buf, resultId: resultId, descAddrId: descAddrId, field: field)
		witnessMethod(resultId, witnessAddrId, methodIndex) then writeStdSysWitnessMethod(buf, resultId: resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex)
		dropTypeParam(slotValueId, layoutValueId) then writeStdSysDropTypeParam(buf, slotValueId: slotValueId, layoutValueId: layoutValueId)
	end 'sys'
end 'writeStdSystemOp'

function writeStdSysSyscall(buf ByteArray, resultId ValueId, number MachineWord, argIds ValueIdArray)
	writeQword(buf, value: resultId)
	writeQword(buf, value: number)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdSysSyscall'

function writeStdSysIatCall(buf ByteArray, resultId ValueId, slotIndex MachineWord, argIds ValueIdArray)
	writeQword(buf, value: resultId)
	writeQword(buf, value: slotIndex)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdSysIatCall'

function writeStdSysGlobalAddr(buf ByteArray, resultId ValueId, name String)
	writeQword(buf, value: resultId)
	writeString(buf, s: name)
end 'writeStdSysGlobalAddr'

function writeStdSysMemcpy(buf ByteArray, dstId ValueId, srcId ValueId, lenId ValueId)
	writeQword(buf, value: dstId)
	writeQword(buf, value: srcId)
	writeQword(buf, value: lenId)
end 'writeStdSysMemcpy'

function writeStdSysStackAddr(buf ByteArray, resultId ValueId, slotId VarSlot)
	writeQword(buf, value: resultId)
	writeQword(buf, value: slotId)
end 'writeStdSysStackAddr'

function writeStdSysStoreByte(buf ByteArray, baseId ValueId, offsetId ValueId, byteId ValueId)
	writeQword(buf, value: baseId)
	writeQword(buf, value: offsetId)
	writeQword(buf, value: byteId)
end 'writeStdSysStoreByte'

function writeStdSysLoadByte(buf ByteArray, resultId ValueId, baseId ValueId, offsetId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: baseId)
	writeQword(buf, value: offsetId)
end 'writeStdSysLoadByte'

function writeStdSysOsWrite(buf ByteArray, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWrite'

function writeStdSysOsWriteErr(buf ByteArray, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWriteErr'

function writeStdSysOsOpenWrite(buf ByteArray, resultId ValueId, pathPtrId ValueId, pathLenId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: pathPtrId)
	writeQword(buf, value: pathLenId)
end 'writeStdSysOsOpenWrite'

function writeStdSysOsWriteFd(buf ByteArray, fdId ValueId, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWriteFd'

function writeStdSysOsGetEnv(buf ByteArray, resultId ValueId, namePtrId ValueId, nameLenId ValueId, outBufPtrId ValueId, outBufLenId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: namePtrId)
	writeQword(buf, value: nameLenId)
	writeQword(buf, value: outBufPtrId)
	writeQword(buf, value: outBufLenId)
end 'writeStdSysOsGetEnv'

function writeStdSysLoadIndirect(buf ByteArray, resultId ValueId, addrId ValueId, offset MachineWord, isFloat bool)
	writeQword(buf, value: resultId)
	writeQword(buf, value: addrId)
	writeQword(buf, value: offset)
	writeBoolByte(buf, b: isFloat)
end 'writeStdSysLoadIndirect'

function writeStdSysFuncAddr(buf ByteArray, resultId ValueId, name String)
	writeQword(buf, value: resultId)
	writeString(buf, s: name)
end 'writeStdSysFuncAddr'

function writeStdSysStoreIndirect(buf ByteArray, addrId ValueId, offset MachineWord, valueId ValueId, isFloat bool)
	writeQword(buf, value: addrId)
	writeQword(buf, value: offset)
	writeQword(buf, value: valueId)
	writeBoolByte(buf, b: isFloat)
end 'writeStdSysStoreIndirect'

function writeStdSysOsAllocPages(buf ByteArray, resultId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsAllocPages'

function writeStdSysOsAllocPagesLarge(buf ByteArray, resultId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsAllocPagesLarge'

function writeStdSysOsFreePages(buf ByteArray, ptrId ValueId, sizeId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsFreePages'

function writeStdSysAtomicXadd(buf ByteArray, resultId ValueId, addrId ValueId, valId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: addrId)
	writeQword(buf, value: valId)
end 'writeStdSysAtomicXadd'

function writeStdSysBoxValue(buf ByteArray, resultId ValueId, valueId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: valueId)
	writeQword(buf, value: sizeId)
end 'writeStdSysBoxValue'

function writeStdSysUnboxValue(buf ByteArray, resultId ValueId, ptrId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: sizeId)
end 'writeStdSysUnboxValue'

function writeStdSysLoadLayoutDescriptor(buf ByteArray, resultId ValueId, label String)
	writeQword(buf, value: resultId)
	writeString(buf, s: label)
end 'writeStdSysLoadLayoutDescriptor'

function writeStdSysLoadWitnessTable(buf ByteArray, resultId ValueId, label String)
	writeQword(buf, value: resultId)
	writeString(buf, s: label)
end 'writeStdSysLoadWitnessTable'

function writeStdSysDescriptorField(buf ByteArray, resultId ValueId, descAddrId ValueId, field DescriptorField)
	writeQword(buf, value: resultId)
	writeQword(buf, value: descAddrId)
	writeDword(buf, value: field.ordinal)
end 'writeStdSysDescriptorField'

function writeStdSysWitnessMethod(buf ByteArray, resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord)
	writeQword(buf, value: resultId)
	writeQword(buf, value: witnessAddrId)
	writeQword(buf, value: methodIndex)
end 'writeStdSysWitnessMethod'

function writeStdSysDropTypeParam(buf ByteArray, slotValueId ValueId, layoutValueId ValueId)
	writeQword(buf, value: slotValueId)
	writeQword(buf, value: layoutValueId)
end 'writeStdSysDropTypeParam'

function readStdSystemOp(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdSystemOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdSystemOp tag {raw}")
	let pos = offset + 4
	return match kase 'sys'
		syscall gives readStdSysSyscall(buf, offset: pos)
		iatCall gives readStdSysIatCall(buf, offset: pos)
		globalAddr gives readStdSysGlobalAddr(buf, offset: pos)
		memcpy gives readStdSysMemcpy(buf, offset: pos)
		stackAddr gives readStdSysStackAddr(buf, offset: pos)
		storeByte gives readStdSysStoreByte(buf, offset: pos)
		loadByte gives readStdSysLoadByte(buf, offset: pos)
		osExit gives readStdSysOsExit(buf, offset: pos)
		osWrite gives readStdSysOsWrite(buf, offset: pos)
		free gives readStdSysFree(buf, offset: pos)
		osWriteErr gives readStdSysOsWriteErr(buf, offset: pos)
		osOpenWrite gives readStdSysOsOpenWrite(buf, offset: pos)
		osWriteFd gives readStdSysOsWriteFd(buf, offset: pos)
		osClose gives readStdSysOsClose(buf, offset: pos)
		osGetEnv gives readStdSysOsGetEnv(buf, offset: pos)
		loadFramePtr gives readStdSysLoadFramePtr(buf, offset: pos)
		loadIndirect gives readStdSysLoadIndirect(buf, offset: pos)
		funcAddr gives readStdSysFuncAddr(buf, offset: pos)
		storeIndirect gives readStdSysStoreIndirect(buf, offset: pos)
		drop gives readStdSysDrop(buf, offset: pos)
		osAllocPages gives readStdSysOsAllocPages(buf, offset: pos)
		osAllocPagesLarge gives readStdSysOsAllocPagesLarge(buf, offset: pos)
		osFreePages gives readStdSysOsFreePages(buf, offset: pos)
		atomicInc gives readStdSysAtomicInc(buf, offset: pos)
		atomicDec gives readStdSysAtomicDec(buf, offset: pos)
		atomicXadd gives readStdSysAtomicXadd(buf, offset: pos)
		osLockInit gives readStdSysOsLockInit(buf, offset: pos)
		osLockAcquire gives readStdSysOsLockAcquire(buf, offset: pos)
		osLockRelease gives readStdSysOsLockRelease(buf, offset: pos)
		boxValue gives readStdSysBoxValue(buf, offset: pos)
		unboxValue gives readStdSysUnboxValue(buf, offset: pos)
		loadLayoutDescriptor gives readStdSysLoadLayoutDescriptor(buf, offset: pos)
		loadWitnessTable gives readStdSysLoadWitnessTable(buf, offset: pos)
		descriptorField gives readStdSysDescriptorField(buf, offset: pos)
		witnessMethod gives readStdSysWitnessMethod(buf, offset: pos)
		dropTypeParam gives readStdSysDropTypeParam(buf, offset: pos)
	end 'sys'
end 'readStdSystemOp'

function readStdSysSyscall(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let number = readQword(buf, offset: offset + 8)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 16)
	return (StdSystemOp.syscall(resultId, number: number, argIds: argIds), p)
end 'readStdSysSyscall'

function readStdSysIatCall(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let slotIndex = readQword(buf, offset: offset + 8)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 16)
	return (StdSystemOp.iatCall(resultId, slotIndex: slotIndex, argIds: argIds), p)
end 'readStdSysIatCall'

function readStdSysGlobalAddr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (name, p) = readString(buf, offset: offset + 8)
	return (StdSystemOp.globalAddr(resultId, name: name), p)
end 'readStdSysGlobalAddr'

function readStdSysMemcpy(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let dstId = readQword(buf, offset: offset)
	let srcId = readQword(buf, offset: offset + 8)
	let lenId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.memcpy(dstId, srcId: srcId, lenId: lenId), offset + 24)
end 'readStdSysMemcpy'

function readStdSysStackAddr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let slotId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.stackAddr(resultId, slotId: slotId), offset + 16)
end 'readStdSysStackAddr'

function readStdSysStoreByte(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let baseId = readQword(buf, offset: offset)
	let offsetId = readQword(buf, offset: offset + 8)
	let byteId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.storeByte(baseId, offsetId: offsetId, byteId: byteId), offset + 24)
end 'readStdSysStoreByte'

function readStdSysLoadByte(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let baseId = readQword(buf, offset: offset + 8)
	let offsetId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.loadByte(resultId, baseId: baseId, offsetId: offsetId), offset + 24)
end 'readStdSysLoadByte'

function readStdSysOsExit(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let codeId = readQword(buf, offset: offset)
	return (StdSystemOp.osExit(codeId), offset + 8)
end 'readStdSysOsExit'

function readStdSysOsWrite(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let ptrId = readQword(buf, offset: offset)
	let lenId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.osWrite(ptrId, lenId: lenId), offset + 16)
end 'readStdSysOsWrite'

function readStdSysFree(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let ptrId = readQword(buf, offset: offset)
	return (StdSystemOp.free(ptrId), offset + 8)
end 'readStdSysFree'

function readStdSysOsWriteErr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let ptrId = readQword(buf, offset: offset)
	let lenId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.osWriteErr(ptrId, lenId: lenId), offset + 16)
end 'readStdSysOsWriteErr'

function readStdSysOsOpenWrite(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let pathPtrId = readQword(buf, offset: offset + 8)
	let pathLenId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.osOpenWrite(resultId, pathPtrId: pathPtrId, pathLenId: pathLenId), offset + 24)
end 'readStdSysOsOpenWrite'

function readStdSysOsWriteFd(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let fdId = readQword(buf, offset: offset)
	let ptrId = readQword(buf, offset: offset + 8)
	let lenId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.osWriteFd(fdId, ptrId: ptrId, lenId: lenId), offset + 24)
end 'readStdSysOsWriteFd'

function readStdSysOsClose(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let fdId = readQword(buf, offset: offset)
	return (StdSystemOp.osClose(fdId), offset + 8)
end 'readStdSysOsClose'

function readStdSysOsGetEnv(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let namePtrId = readQword(buf, offset: offset + 8)
	let nameLenId = readQword(buf, offset: offset + 16)
	let outBufPtrId = readQword(buf, offset: offset + 24)
	let outBufLenId = readQword(buf, offset: offset + 32)
	return (StdSystemOp.osGetEnv(resultId, namePtrId: namePtrId, nameLenId: nameLenId, outBufPtrId: outBufPtrId, outBufLenId: outBufLenId), offset + 40)
end 'readStdSysOsGetEnv'

function readStdSysLoadFramePtr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	return (StdSystemOp.loadFramePtr(resultId), offset + 8)
end 'readStdSysLoadFramePtr'

function readStdSysLoadIndirect(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let addrId = readQword(buf, offset: offset + 8)
	let off = readQword(buf, offset: offset + 16)
	let (isFloat, p) = readBoolByte(buf, offset: offset + 24)
	return (StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: off, isFloat: isFloat), p)
end 'readStdSysLoadIndirect'

function readStdSysFuncAddr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (name, p) = readString(buf, offset: offset + 8)
	return (StdSystemOp.funcAddr(resultId, name: name), p)
end 'readStdSysFuncAddr'

function readStdSysStoreIndirect(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	let off = readQword(buf, offset: offset + 8)
	let valueId = readQword(buf, offset: offset + 16)
	let (isFloat, p) = readBoolByte(buf, offset: offset + 24)
	return (StdSystemOp.storeIndirect(addrId, offset: off, valueId: valueId, isFloat: isFloat), p)
end 'readStdSysStoreIndirect'

function readStdSysDrop(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let valueId = readQword(buf, offset: offset)
	return (StdSystemOp.drop(valueId), offset + 8)
end 'readStdSysDrop'

function readStdSysOsAllocPages(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let sizeId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.osAllocPages(resultId, sizeId: sizeId), offset + 16)
end 'readStdSysOsAllocPages'

function readStdSysOsAllocPagesLarge(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let sizeId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.osAllocPagesLarge(resultId, sizeId: sizeId), offset + 16)
end 'readStdSysOsAllocPagesLarge'

function readStdSysOsFreePages(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let ptrId = readQword(buf, offset: offset)
	let sizeId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.osFreePages(ptrId, sizeId: sizeId), offset + 16)
end 'readStdSysOsFreePages'

function readStdSysAtomicInc(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	return (StdSystemOp.atomicInc(addrId), offset + 8)
end 'readStdSysAtomicInc'

function readStdSysAtomicDec(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	return (StdSystemOp.atomicDec(addrId), offset + 8)
end 'readStdSysAtomicDec'

function readStdSysAtomicXadd(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let addrId = readQword(buf, offset: offset + 8)
	let valId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.atomicXadd(resultId, addrId: addrId, valId: valId), offset + 24)
end 'readStdSysAtomicXadd'

function readStdSysOsLockInit(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	return (StdSystemOp.osLockInit(addrId), offset + 8)
end 'readStdSysOsLockInit'

function readStdSysOsLockAcquire(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	return (StdSystemOp.osLockAcquire(addrId), offset + 8)
end 'readStdSysOsLockAcquire'

function readStdSysOsLockRelease(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let addrId = readQword(buf, offset: offset)
	return (StdSystemOp.osLockRelease(addrId), offset + 8)
end 'readStdSysOsLockRelease'

function readStdSysBoxValue(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let valueId = readQword(buf, offset: offset + 8)
	let sizeId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.boxValue(resultId, valueId: valueId, sizeId: sizeId), offset + 24)
end 'readStdSysBoxValue'

function readStdSysUnboxValue(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let ptrId = readQword(buf, offset: offset + 8)
	let sizeId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.unboxValue(resultId, ptrId: ptrId, sizeId: sizeId), offset + 24)
end 'readStdSysUnboxValue'

function readStdSysLoadLayoutDescriptor(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (label, p) = readString(buf, offset: offset + 8)
	return (StdSystemOp.loadLayoutDescriptor(resultId, label: label), p)
end 'readStdSysLoadLayoutDescriptor'

function readStdSysLoadWitnessTable(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let (label, p) = readString(buf, offset: offset + 8)
	return (StdSystemOp.loadWitnessTable(resultId, label: label), p)
end 'readStdSysLoadWitnessTable'

function readStdSysDescriptorField(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let descAddrId = readQword(buf, offset: offset + 8)
	let fieldRaw = readDword(buf, offset: offset + 16)
	let field = try DescriptorField.allCases.get(fieldRaw) otherwise panic("corrupt cache: unknown DescriptorField {fieldRaw}")
	return (StdSystemOp.descriptorField(resultId, descAddrId: descAddrId, field: field), offset + 20)
end 'readStdSysDescriptorField'

function readStdSysWitnessMethod(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let witnessAddrId = readQword(buf, offset: offset + 8)
	let methodIndex = readQword(buf, offset: offset + 16)
	return (StdSystemOp.witnessMethod(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex), offset + 24)
end 'readStdSysWitnessMethod'

function readStdSysDropTypeParam(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let slotValueId = readQword(buf, offset: offset)
	let layoutValueId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.dropTypeParam(slotValueId, layoutValueId: layoutValueId), offset + 16)
end 'readStdSysDropTypeParam'

// --- StdOp outer union ---

function writeStdOp(buf ByteArray, op StdOp)
	writeDword(buf, value: op.ordinal)
	match op 'outer'
		arith(inner) then writeStdArithOp(buf, op: inner)
		control(inner) then writeStdControlOp(buf, op: inner)
		call(inner) then writeStdCallOp(buf, op: inner)
		memory(inner) then writeStdMemoryOp(buf, op: inner)
		system(inner) then writeStdSystemOp(buf, op: inner)
	end 'outer'
end 'writeStdOp'

function readStdOp(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try StdOp.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown StdOp tag {raw}")
	let pos = offset + 4
	return match kase 'outer'
		arith gives readStdOpArith(buf, offset: pos)
		control gives readStdOpControl(buf, offset: pos)
		call gives readStdOpCall(buf, offset: pos)
		memory gives readStdOpMemory(buf, offset: pos)
		system gives readStdOpSystem(buf, offset: pos)
	end 'outer'
end 'readStdOp'

function readStdOpArith(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let (inner, p) = readStdArithOp(buf, offset: offset)
	return (StdOp.arith(inner), p)
end 'readStdOpArith'

function readStdOpControl(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let (inner, p) = readStdControlOp(buf, offset: offset)
	return (StdOp.control(inner), p)
end 'readStdOpControl'

function readStdOpCall(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let (inner, p) = readStdCallOp(buf, offset: offset)
	return (StdOp.call(inner), p)
end 'readStdOpCall'

function readStdOpMemory(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let (inner, p) = readStdMemoryOp(buf, offset: offset)
	return (StdOp.memory(inner), p)
end 'readStdOpMemory'

function readStdOpSystem(buf ByteArray, offset ByteOffset) returns (StdOp, ByteOffset)
	let (inner, p) = readStdSystemOp(buf, offset: offset)
	return (StdOp.system(inner), p)
end 'readStdOpSystem'

// --- Terminator ---

function writeIrTerminator(buf ByteArray, term Terminator)
	writeDword(buf, value: term.ordinal)
	match term 'term'
		unset then break
		dead then break
		fallthrough then break
		opIndex(index) then writeQword(buf, value: index)
	end 'term'
end 'writeIrTerminator'

function readIrTerminator(buf ByteArray, offset ByteOffset) returns (Terminator, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let kase = try Terminator.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown Terminator tag {raw}")
	let pos = offset + 4
	return match kase 'term'
		unset gives (Terminator.unset, pos)
		dead gives (Terminator.dead, pos)
		fallthrough gives (Terminator.fallthrough, pos)
		opIndex gives readIrTerminatorOpIndex(buf, offset: pos)
	end 'term'
end 'readIrTerminator'

function readIrTerminatorOpIndex(buf ByteArray, offset ByteOffset) returns (Terminator, ByteOffset)
	let index = readQword(buf, offset: offset)
	return (Terminator.opIndex(index), offset + 8)
end 'readIrTerminatorOpIndex'

// --- IrBlockArg ---

function writeIrBlockArg(buf ByteArray, arg IrBlockArg)
	writeQword(buf, value: arg.valueId)
	writeStdTypeTag(buf, t: arg.argType)
end 'writeIrBlockArg'

function readIrBlockArg(buf ByteArray, offset ByteOffset) returns (IrBlockArg, ByteOffset)
	let valueId = readQword(buf, offset: offset)
	let (argType, p) = readStdTypeTag(buf, offset: offset + 8)
	return (IrBlockArg.create(valueId, argType: argType), p)
end 'readIrBlockArg'

// --- IrBlock ---

function writeIrBlock(buf ByteArray, block IrBlock)
	writeQword(buf, value: block.id)
	writeString(buf, s: block.label)
	writeDword(buf, value: block.opRefs.count())
	for opIdx in block.opRefs 'eachOpRef'
		writeQword(buf, value: opIdx)
	end 'eachOpRef'
	writeIrTerminator(buf, term: block.terminator)
	writeDword(buf, value: block.blockArgs.count())
	for arg in block.blockArgs 'eachArg'
		writeIrBlockArg(buf, arg: arg)
	end 'eachArg'
	// branchEdges are populated only at the Target phase by lowerMirToTarget
	// and never at the Std phase the inliner runs against. Skipping them
	// keeps the codec smaller; the field is initialized empty on read.
end 'writeIrBlock'

function readIrBlock(buf ByteArray, offset ByteOffset) returns (IrBlock, ByteOffset)
	let id = readQword(buf, offset: offset)
	var pos = offset + 8
	let (label, p1) = readString(buf, offset: pos)
	pos = p1
	var block = IrBlock.create(id, label: label)
	let opRefCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto opRefCount 'eachOpRef'
		let opIdx = readQword(buf, offset: pos)
		pos = pos + 8
		block.opRefs.append(opIdx)
	end 'eachOpRef'
	let (term, p2) = readIrTerminator(buf, offset: pos)
	pos = p2
	block.terminator = term
	let argCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto argCount 'eachArg'
		let (arg, p3) = readIrBlockArg(buf, offset: pos)
		pos = p3
		block.blockArgs.push(arg)
	end 'eachArg'
	return (block, pos)
end 'readIrBlock'

// --- IrFunction (Std-phase shape only) ---
//
// The codec persists exactly the fields the inliner reads + the fields the
// merge step relocates. Maxon-phase fields (scope, maxonReturnType,
// maxonParamTypes, throwsTypeName) are reset to defaults on read because
// merging into the user's StdModule for the Std-level inliner pass never
// surfaces them. slotMaxonTypes stays empty for stdlib functions in the
// inlinable subset (single-block accessors typically have zero slots after
// mem2reg).

function writeStdIrFunction(buf ByteArray, func IrFunction)
	writeString(buf, s: func.name)
	writeString(buf, s: func.namespace)
	writeVisibility(buf, v: func.visibility)
	writeFilePath(buf, p: func.sourceFilePath)
	writeDword(buf, value: func.paramCount)
	writeStdReturnType(buf, rt: func.returnType)
	writeStdTypeArrayCodec(buf, arr: func.paramTypes)
	writeDword(buf, value: func.blockRefs.count())
	for br in func.blockRefs 'eachBlockRef'
		writeQword(buf, value: br)
	end 'eachBlockRef'
	writeQword(buf, value: func.nextBlockId)
	writeBoolByte(buf, b: func.hasImplicitLayoutParam)
	writeBoolByte(buf, b: func.hasImplicitWitnessParam)
end 'writeStdIrFunction'

function readStdIrFunction(buf ByteArray, offset ByteOffset) returns (IrFunction, ByteOffset)
	let (name, p1) = readString(buf, offset: offset)
	var pos = p1
	let (namespace, p2) = readString(buf, offset: pos)
	pos = p2
	let (visibility, p3) = readVisibility(buf, offset: pos)
	pos = p3
	let (sourceFilePath, p4) = readFilePath(buf, offset: pos)
	pos = p4
	let paramCount = readDword(buf, offset: pos)
	pos = pos + 4
	let (returnType, p5) = readStdReturnType(buf, offset: pos)
	pos = p5
	let (paramTypes, p6) = readStdTypeArrayCodec(buf, offset: pos)
	pos = p6
	var func = IrFunction.createFromStd(name, returnType: returnType, paramCount: paramCount, paramTypes: paramTypes, returnLine: 0)
	func.namespace = namespace
	func.visibility = visibility
	func.sourceFilePath = sourceFilePath
	let blockRefCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto blockRefCount 'eachBlockRef'
		let br = readQword(buf, offset: pos)
		pos = pos + 8
		func.blockRefs.append(br)
	end 'eachBlockRef'
	let nextBlockId = readQword(buf, offset: pos)
	pos = pos + 8
	func.nextBlockId = nextBlockId
	let (hasLayout, p7) = readBoolByte(buf, offset: pos)
	pos = p7
	let (hasWitness, p8) = readBoolByte(buf, offset: pos)
	pos = p8
	func.hasImplicitLayoutParam = hasLayout
	func.hasImplicitWitnessParam = hasWitness
	return (func, pos)
end 'readStdIrFunction'

// --- StdModule ---

function writeStdModule(buf ByteArray, module StdModule)
	writeDword(buf, value: module.functions.count())
	for f in module.functions 'eachFunc'
		writeStdIrFunction(buf, func: f)
	end 'eachFunc'
	writeDword(buf, value: module.blocks.count())
	for blk in module.blocks 'eachBlock'
		writeIrBlock(buf, block: blk)
	end 'eachBlock'
	writeDword(buf, value: module.ops.count())
	for op in module.ops 'eachOp'
		writeStdOp(buf, op: op)
	end 'eachOp'
end 'writeStdModule'

function readStdModule(buf ByteArray, offset ByteOffset) returns (StdModule, ByteOffset)
	var module = StdModule.create()
	var pos = offset
	let funcCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto funcCount 'eachFunc'
		let (f, p) = readStdIrFunction(buf, offset: pos)
		pos = p
		module.functions.push(f)
	end 'eachFunc'
	let blockCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto blockCount 'eachBlock'
		let (blk, p) = readIrBlock(buf, offset: pos)
		pos = p
		module.blocks.push(blk)
		// blockSourceInfo is parallel to blocks; pad with empty so the
		// invariant `blocks.count() == blockSourceInfo.count()` holds.
		// Coverage instrumentation reads this array and would otherwise
		// trip on a length mismatch even though the inlined stdlib
		// functions get dropped before instrumentCoverage runs.
		module.blockSourceInfo.push(BlockSourceInfo.empty())
	end 'eachBlock'
	let opCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto opCount 'eachOp'
		let (op, p) = readStdOp(buf, offset: pos)
		pos = p
		module.ops.push(op)
	end 'eachOp'
	return (module, pos)
end 'readStdModule'

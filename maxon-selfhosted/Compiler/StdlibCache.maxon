// StdlibCache: pre-compiled stdlib with per-function machine code linking.
//
// Each stdlib function is compiled to machine code and stored as a relocatable
// object in the cache file. At link time, reachability analysis selects only
// the needed functions and appends their code bytes to the output.
//
// Cache format: header + per-function objects + globalData + parser metadata.

export typealias CacheChecksum = int(0 to u64.max)
export typealias StdlibFuncIndexMap = Map with (String, MachineWord)
export typealias StdlibFuncNameSet = Set with String

// `decodeStdlibCache`'s id-space rebuild snapshots per-(declaringType,param)
// constraints into a flat lookup so the rebuild can re-attach them at the
// project-aligned ids without mutating the cached registry.
typealias CachedConstraintMap = Map with (String, StringArray)

let CACHE_MAGIC_0 = 0x4D  // 'M'
let CACHE_MAGIC_1 = 0x58  // 'X'
let CACHE_MAGIC_2 = 0x43  // 'C'
let CACHE_MAGIC_3 = 0x00  // '\0'

// v5: added funcSignatures table so cached stdlib functions surface their
// param names + defaults to TypeResolution's arity validator (arity errors
// for stdlib calls used to silently no-op when the cache was warm because
// project.funcSignatures is only populated when stdlib source is reparsed).
// v7: round-trip generic-aware MaxonType arms (typeParameter,
// genericInstance, interface) with their full payload, and persist each
// struct's `innerAliases` map. Earlier versions collapsed the
// generic-aware arms to a printable name and dropped innerAliases on
// restore, so cache hits surfaced unresolved inner-alias names like
// `MaxonType.named("ElementMemory")` to the lowering pass.
// v8: persist Phase 11 conformance/interface/registry state. Without this
// step, the user-code pipeline runs `validateConformances` /
// `processExtensions` against an empty stdlib (cache hit drops every
// stdlib-side `unresolvedExtensions` / `unresolvedStructTypes` entry),
// so primitive extensions like `extension int implements Comparable` never
// land in `project.conformances`. Persisting `interfaces`, `conformances`,
// `typeParameters`, `interfaceRegistry`, `genericInstances`,
// `genericTypealiases`, `layoutDescriptors`, `witnessTables`,
// `livenessRoots`, and `staticRdataValues` makes the cached-stdlib project
// state identical to a fresh-from-source build for every consumer 11.4's
// lowering reads.
// v10: persist the stdlib's post-dce StdModule snapshot so the user
// pipeline's inliner pass can splice stdlib accessor bodies (Array.get,
// ArrayIterator.advance/current, Optional.unwrap, etc.) into user
// callers. Without this, the inliner's `funcMap` only sees user
// functions and every cross-module accessor call stays a `func.call`,
// which costs two indirect calls per iteration in a tight `for n in
// arr` loop.
// v14: added StdArithUnaryOpcode.bitcastF64ToI64 (the codec must learn its
// lifted/encoded raw value) plus byteStringLiteral now wraps in an Array
// struct (changes the lowered shape of `b"..."`).
// v15: whitelisted stdlib/helpers/string/grapheme.maxon (Phase 7 finish, Step 2).
// v16: whitelisted stdlib/helpers/string/views.maxon (Phase 7 finish, Step 3).
// v17: persist per-typealias visibility + sourceFilePath sidecar so file-
// private stdlib aliases don't round-trip as if globally exported.
// v18: whitelisted stdlib/CharacterSet.maxon, stdlib/Character.maxon, and
// stdlib/String.maxon (Phase 7 finish, Step 4). Synthesized stand-in for
// `String`/`Character`/`Codepoint` were dropped from the bootstrap source.
// v19: fix data.genericInstances / data.typeParameters / data.interfaceRegistry
// id-space drift on cache restore. `readMaxonType` interns nested generic
// instances directly into `project.genericInstances`, so any cached
// `genericInstance(id)` references the project registry — but
// `readGenericInstanceRegistry` was building a separate `data.genericInstances`
// with its own (different) ordering. `translateCapturedGenericInstanceId`
// then did `data.genericInstances.get(id)` and got a wrong payload, causing
// e.g. `Array.innerAliases["ArrayIter"]` to resolve to `__ManagedMemory with
// Element` post-restore. Fix: at the end of `decodeStdlibCache`, replace
// `data.genericInstances` / `data.typeParameters` / `data.interfaceRegistry`
// with fresh registries mirrored verbatim from `project.*`, so translation
// becomes an identity round-trip.
// v20: typealias visibility sidecar now uses the shared writeVisibility
// codec (4-byte dword) instead of an ad-hoc 1-byte tag, matching every
// other Visibility-typed field.
// v21: runtime function bodies (mrt_panic, mrt_write_*, __slab_*, mm_*,
// __managed_mem_*, __layout_word_*, __destruct___ManagedMemory) are now
// pre-compiled into the cache as ObjectFunctions alongside stdlib bodies.
// The user-side augmentWithRuntime supplies signature-only stubs for these
// names and merges only the entry-point variant (mrt_start /
// mrt_start_with_coverage) as a real body so patchMrtStartWithModuleInits
// can wire per-project __module_init_* calls. Linker reachability
// (computeNeededStdlibFunctions) inherits per-function inclusion for
// runtime callees automatically — they're keyed by name like every other
// ObjectFunction. Old caches are incompatible because they exclude
// runtime bodies; the version bump forces a rebuild.
// v27: persist BuiltinDictionaryLiteral discovery alongside
// BuiltinArrayLiteral so map-literal (`[k: v, ...]`) desugaring survives a
// cache hit. Old caches don't carry the dictionary field; the version bump
// forces a rebuild.
// v28: persist TypeParamRegistry.declaringTypeParamLists so getParamNames
// returns source-declaration order (Map.Key before Map.Value) regardless of
// what order interns happened in.
// v32: persist `StructField.offsetResolved` so the new TypeResolution
// `layoutAllStructs` pass can tell parser-time placeholder offsets from
// real ones. Cached struct fields carry the real offsets the C# bootstrap
// (or a prior self-hosted run) already computed, so on read they are
// flagged `offsetResolved: true` and the layout pass leaves them alone.
// v33: `StdSystemOp.loadIndirect` gains a `signed: bool` field for sign-
// extending narrow loads. The encoded payload grows by one byte.
// v34: constant-array-to-rdata fast path. New `__rdata_arr_*` labels
// land in `project.staticRdataValues` and `pipeline.globalData`; stdlib
// array literals routed through them produce different rdata bytes than
// the pre-pass runtime-allocated builds.
// v35: per-field `StructField.isExported` flag for E3014
// `semanticUnexportedFieldAccess`. Encoded payload grows by one byte per
// field.
// v36: removed the compiler-internal `__ManagedMemory.makeCharFromBytes`
// method registration; the function moved to `stdlib/Internals.maxon` as
// `__makeCharFromBytes`. Old caches list the builtin and would re-emit the
// removed panic stub.
// v37: added `stdlib/Builtins.maxon` to the whitelist so the four
// `__*_fromString` helpers (`__int_fromString`, `__float_fromString`,
// `__bool_fromString`, `__byte_fromString`) plus the literal-marker
// interface bodies (`BuiltinStringLiteral.init`, `Parsable.fromString`,
// the `InitableFrom*` family, `ParseError`, the `__Managed*Error` enums,
// `ParsedInt`, `ParsedFloat`) live in the cached stdlib metadata; the
// bootstrap source dropped the stub versions of those interfaces.
// v44: whitelisted stdlib/CommandLine.maxon (Stage E step 4); structurally
// no on-disk format change, but the registry-decode path now also interns
// each writer-side `GenericInstanceId` into `project.genericInstances` and
// records a writer→project translation table. Old v43 caches were created
// before that fix and would re-tripper the `data.genericInstances.get:
// invalid id N` panic on a build with extra whitelisted stdlib files.
// v45: Phase 15f added synth `Process` + `FilePath` types and the
// `__Builtins.executablePath` intrinsic to the stdlib bootstrap. The synth
// types register fresh `Process.executablePath`/`FilePath` signatures into
// the cached stdlib metadata; v44 caches lack those entries and would miss
// the wrap-MM-in-FilePath call lowered into user code.
// v49: Stage J.4a — whitelist `stdlib/Interfaces.maxon` and drop the
// cross-cutting interface family (`Error`, `Iterator`, `Iterable`, etc.) +
// `Ordering`/`IterationError`/`HashValue`/`IterStep` from the bootstrap synth.
// The real interface signatures (notably `Iterable.createIterator() returns
// Iter` with NO `throws` clause) differ from the bootstrap stubs, and the
// interface now carries extension methods (`Iterable.map/filter/contains/
// withIterator`) that v48 caches don't know about.
// v50: Stage J.4c — persist `project.unresolvedExtensions` and
// `project.extensionMethodWhereClauses` so cache-hit user builds see the
// stdlib's struct- and interface-extension metadata (including where-clauses)
// for the per-receiver monomorphizer's gating + diagnostic paths.
// v51: Stage J.4f.3 — added StdArithUnaryOpcode.bitcastI64ToF64 (the codec
// must learn its lifted/encoded raw value) so float-typed reads from
// type-erased managed memory can recover the float bits.
// v53: Phase 15c — whitelisted real FilePath/File/Directory stdlib;
// registered __ManagedFile/__ManagedDirectory types.
// v55: whitelisted stdlib/Print.maxon; dropped the synthesized `print(value
// String)` from the stdlib bootstrap source.
// v56: whitelisted stdlib/Console.maxon (buffered Stdin reader on top of
// __Builtins.readStdin).
// v57: implemented panic-message interpolation lowering (MaxonOp.panicDynamic).
// No new whitelist entries, but the cache encodes the new op variant.
// v58: whitelisted stdlib/Json.maxon. Three parser fixes were required to
// admit it: (a) parseFloatBits's normalization loop no longer overflows on
// `i64.max`-magnitude float literals, (b) panic-at-function-end is treated
// as terminating (suppresses E3013), and (c) `__field_init_*` helpers
// materialize string-const default values, (d) parseLocalFieldAssignment
// routes `selfField.x = ...` through selfFieldLoad instead of the unmapped
// local-var slot.
// v59: whitelisted stdlib/Subprocess.maxon.
// v60: whitelisted stdlib/Builtins.maxon. Trimmed marker-interface family,
// Parsable, ParsedInt/ParsedFloat, and __*_fromString helpers from the
// synthesized bootstrap — Builtins.maxon now supplies them. __Tuple2/3
// stay synthesized. Required a fix to synthesizeOneWitnessThunk to skip the
// receiver slot for static interface requirements (Builtins.maxon's marker
// interfaces declare `static function init(...)`, which would otherwise add
// a spurious leading arg to the thunk's tail call into Array.init).
// v61: wired __ManagedList / __ManagedListNode builtin types and whitelisted
// stdlib/List.maxon.
// v62: wired __ManagedSocket builtin type and whitelisted stdlib/TcpClient.maxon.
// v63: whitelisted stdlib/HttpClient.maxon + helpers/http/httpHelpers.maxon.
// v64: extended IrFunction codec to include `closureCaptureCount` (Phase 2
// closure-capture-count localization).
// v66: G.2 stdlib whitelist removal — parser unconditionally rewrites
// `<TypeName>.fromRawValue(...)` / `.fromName(...)` to the per-enum
// helper symbol, and a new post-parse pass (`validateEnumLookupCalls`)
// synthesizes the helper / emits E3034 / restores the natural callee
// after every file has been parsed. Cache contents are structurally
// unchanged but the bump forces a rebuild so older caches built under
// the pre-G.2 ordering (where the rewrite required the enum's
// declaration file to parse first) get invalidated even if the source
// checksum matches by coincidence.
// v67: H.2 indirect-call label validation moved to post-parse pass.
// Parser emits `indirectCall` with sentinel `fnTypeId = 0` when the
// callee's typealias hasn't yet resolved at parse time; new
// `validateIndirectCallLabels` pass re-chases the alias against the
// fully-populated typealias registry, patches the indirectCall +
// producer varLoad, or emits a diagnostic. Cache contents structurally
// unchanged; bump invalidates older caches that may have stored an
// indirectCall with the previous (eager) parse-time fnTypeId.
// v68: precomputed per-function Std-DFE edge table (`stdFuncEdges`). The
// cache build extracts each cached function's call edges + witness/layout
// label demands once (a pure function of the body), so the load-time
// Std-DFE consults a flat table instead of re-walking the cached Std-IR
// snapshot to re-derive reachability. New trailing blob; bump invalidates
// older caches that lack the table.
// v69: new `osClockMs` StdSystemOp (monotonic-clock-ms primitive) inserted
// between osGetArgc and osGetArgv in the union, shifting every later
// StdSystemOp ordinal. The serialized system-op tag is the union ordinal, so
// caches written before the shift would mis-deserialize; bump to invalidate.
// v70 (Concept C): persisted argument-consume facts (`funcParamConsumes` +
// `funcReturnsConsumedArg`) computed by `analyzeParamConsumes` over the stdlib,
// so a user build reads the structural per-parameter consume bits for non-inlined
// consuming stdlib callees instead of falling back to the callee-name allowlists.
// New trailing tables; bump invalidates older caches that lack them.
// v71: layout descriptors now pack per-type-arg HAS_HEAP_REFS bits into
// `flags@24` (bits 8+), and BuildLayoutDescriptors emits two fixed-label
// singleton element layouts (`__layout_elem_managed` / `__layout_elem_raw`).
// The descriptor flag-bit semantics and the set of cached rdata blobs changed,
// so older caches must be regenerated.
// v72: persisted RETURN-BORROW facts (`funcReturnsBorrow`) computed by
// `analyzeReturnBorrows` over the stdlib, so a user build restores a stdlib
// function's borrow-returning status (notably the bodyless-in-user-build
// element loaders `__managed_mem_get` / `__managed_mem_cursor_current`)
// instead of re-deriving it from a name allowlist. New trailing table; bump
// invalidates older caches that lack it.
// v73: persisted ELEMENT-LOADER chain-boundary facts (`funcIsElementLoader`) —
// the functions that call the shared `__managed_mem_load_sized` load primitive,
// computed by `analyzeReturnBorrows`. Restores the wrapper-retain boundary on the
// user build (bodies absent) so the borrow→owned retain fires exactly once,
// replacing the hardcoded loader-name list. New trailing table; bump invalidates
// older caches that lack it.
// v74: persist the four refcount-insertion per-value side-tables on each cached
// stdlib `IrFunction` (`valueOwnership`/`valueManaged`/`valueTypeParam`/
// `valueTypeParamName`). `writeStdIrFunction` previously omitted them, so a
// cache-restored function had EMPTY tables; when the user-pipeline inliner spliced
// a cached stdlib body into user code, `threadInlinedOwnership` read the empty
// tables and classified inlined alloc results (e.g. `StringIndex.create`'s box)
// as `notManaged` → the inserter never dropped them. Result: the SAME program is
// leak-free when stdlib is compiled from source but LEAKS against the cache — the
// shared root cause of the mass spec-test exit-101 failures. New trailing per-func
// run; bump invalidates older caches that lack it.
// v75: `analyzeParamConsumes` now sets the consume bit for every TYPE-PARAMETER-
// typed parameter (the callee-owns-generic-params convention), so cached
// `funcParamConsumes` from older builds disagree with the inserter's caller-side
// transfer accounting (the String-keyed `m.get("a")` double-drop). Same format,
// different facts; bump forces recompute.
// v76: generic-shared `Self{...}` allocations with type-param fields stamp the
// layout descriptor's destroy thunk as their destructor, layout destroy thunks
// emit a real `__mm_decref_maybenull_helper` per heap-bearing field, and the
// borrow-liveness nav edge skips arg-0-consuming factories — cached v75 bodies
// carry the old null-destructor allocs and over-extended borrow refcounting.
// v77: `analyzeReturnBorrows` now classifies the all-borrow-call merge phi
// (`List.walkTo`'s loop over the seeded node walkers) as borrow-returning, so
// cached `funcReturnsBorrow` sets and the inserter's caller-side accounting
// from v76 disagree (the `List.get` element over-release). Same format,
// different facts; bump forces recompute. Also adds the trailing
// `funcReturnsReceiverInterior` set (format change).
// v78: `lowerCreateCursor` classifies the cursor `callReturnRc1` (the empty-
// collection throw path now releases it) — cached v77 bodies strand the cursor
// + its retained source on that path.
// v79: `lowerFieldStore` emits a typed decref-old on every NON-INIT store to a
// heap-managed field (the builder-pattern reassign leak) — cached v78 stdlib
// bodies lack the release and disagree with from-source builds.
let CACHE_FORMAT_VERSION = 79

// ============================================================
// Types
// ============================================================

// Adr fixup for ARM64: patch an ADR instruction to point at a named function.
// Stored in the cache so the linker can adjust offsets when linking.
export type CachedAdrFixup
	export var instrOffset as CodeOffset
	export var destReg as MachineWord
	export var targetName as String

	export static function create(instrOffset CodeOffset, destReg MachineWord, targetName String) returns CachedAdrFixup
		return Self{instrOffset: instrOffset, destReg: destReg, targetName: targetName}
	end 'create'
end 'CachedAdrFixup'

export typealias CachedAdrFixupArray = Array with CachedAdrFixup

// A single relocatable function: its machine code + unresolved fixups.
export type ObjectFunction
	export var name as String
	export var returnType as StdReturnType
	export var paramCount as ParamCount
	export var paramTypes as StdTypeArray
	export var code as ByteArray
	export var callFixups as CallFixupArray
	export var rdataRelocs as RdataRelocationArray
	export var relocations as RelocationArray
	// ARM64-specific: ADR fixups for function address loading
	export var adrFixups as CachedAdrFixupArray

	export static function create(name String, returnType StdReturnType, paramCount ParamCount) returns ObjectFunction
		return Self{
			name: name,
			returnType: returnType,
			paramCount: paramCount,
			paramTypes: StdTypeArray.create(),
			code: ByteArray.create(),
			callFixups: CallFixupArray.create(),
			rdataRelocs: RdataRelocationArray.create(),
			relocations: RelocationArray.create(),
			adrFixups: CachedAdrFixupArray.create()
		}
	end 'create'
end 'ObjectFunction'

export typealias ObjectFunctionArray = Array with ObjectFunction

// Precomputed Std-DFE reachability edges for one cached stdlib function.
// On a cache-hit compile the stdlib bodies are served from the cache and
// dropped from the user Std module before Std-DFE runs, so Std-DFE can't
// see the call edges / witness-layout demands inside them by walking IR.
// The set of edges each function contributes is a pure function of its body
// (it does not depend on the user program), so the cache build computes it
// once (via `extractFuncEdges`) and serializes it here; Std-DFE consults
// this flat table at load time instead of re-walking the cached Std-IR
// snapshot. The three lists mirror the two promotion paths in Std-DFE's
// `promoteLabelsFromSystemOp`:
//   - `callees`            — names pushed by `markFromStdCallOp` (direct
//                            call / tryCall / tailCall callee, funcRef name).
//   - `conditionalRootLabels` — `loadWitnessTable` / `loadLayoutDescriptor`
//                            labels, which pin the label AND promote every
//                            `witnessConditionalRoots[label]` impl.
//   - `plainLabels`        — `globalAddr` names, which only pin the label.
export type CachedFuncEdges
	export var callees as StringArray
	export var conditionalRootLabels as StringArray
	export var plainLabels as StringArray

	export static function create() returns CachedFuncEdges
		return Self{
			callees: StringArray.create(),
			conditionalRootLabels: StringArray.create(),
			plainLabels: StringArray.create()
		}
	end 'create'
end 'CachedFuncEdges'

// Name → precomputed Std-DFE edge record for every cached stdlib function.
export typealias CachedFuncEdgeMap = Map with (String, CachedFuncEdges)

// Discovery cache for the BuiltinArrayLiteral protocol. The `none` arm
// records "no implementing type was observed in this stdlib build" without
// pretending an empty string is the absent value; the `found(name)` arm
// carries the discovered struct's name. Encoded on disk through
// `writeOptionalString` / `readOptionalString` (1-byte tag + optional
// length-prefixed payload), mirroring the ParentWitnessLabel / ThrowsClause
// pattern.
export union BuiltinArrayLiteralName
	none
	found(name String)
end 'BuiltinArrayLiteralName'

// Discovery cache for the BuiltinDictionaryLiteral protocol — same shape as
// BuiltinArrayLiteralName, see `cachedBuiltinDictionaryLiteralTypeName` in
// StdlibLoader for the parser-side static this mirrors.
export union BuiltinDictionaryLiteralName
	none
	found(name String)
end 'BuiltinDictionaryLiteralName'

// Discovery cache for the BuiltinCharLiteral protocol — same shape as
// BuiltinArrayLiteralName, see `cachedBuiltinCharLiteralTypeName` in StdlibLoader
// for the parser-side static this mirrors.
export union BuiltinCharLiteralName
	none
	found(name String)
end 'BuiltinCharLiteralName'

// Discovery cache for the BuiltinStringLiteral protocol — same shape as
// BuiltinArrayLiteralName, see `cachedBuiltinStringLiteralTypeName` in StdlibLoader.
export union BuiltinStringLiteralName
	none
	found(name String)
end 'BuiltinStringLiteralName'

// All data needed to link pre-compiled stdlib into a user program.
export type StdlibCacheData
	export var functions as ObjectFunctionArray
	export var wasmFunctions as WasmObjectFunctionArray
	export var globalData as GlobalDataTable
	// Parser metadata
	export var typealiases as TypealiasMap
	// Cache v17: per-typealias visibility + sourceFilePath sidecar. Each
	// alias name maps to an array of entries — one per declaring file —
	// so file-private declarations from multiple stdlib files all survive
	// a cache round-trip. Without this, file-private aliases collapse to
	// `(global, stdlib-bootstrap path)` on restore and trip the parser's
	// E2001 shadowing check.
	export var typealiasVisibilities as TypealiasVisibilityMap
	export var typealiasRanges as TypealiasRangeMap
	// Mirror of `project.typealiasCastCategories` so the cache restore path
	// re-populates the user-declared cast category for ranged-primitive
	// aliases (e.g. ExitCode keeps `int` even though it stores as u8).
	export var typealiasCastCategories as TypealiasCastCategoryMap
	export var funcReturnTypes as FuncReturnTypeMap
	export var funcSignatures as FuncSignatureMap
	// Cache v70 (Concept C): the structural argument-CONSUME facts computed by
	// `analyzeParamConsumes` over the full stdlib during cache warming. Persisted so a
	// user build (where the consuming stdlib bodies are signature-only stubs) reads the
	// real per-parameter consume bits instead of re-deriving them (or falling back to
	// the retired callee-name allowlists). `funcParamConsumes` is keyed by qualified
	// function name → per-parameter BoolArray; `funcReturnsConsumedArg` is the
	// transparent-wrapper return-side name set. Names/bits reference no type-interner
	// id, so they round-trip verbatim (no `translateMaxonType` needed).
	export var funcParamConsumes as FuncParamConsumesMap
	export var funcReturnsConsumedArg as FuncReturnsBorrowSet
	// Cache v72: persisted RETURN-BORROW facts (`funcReturnsBorrow`) computed by
	// `analyzeReturnBorrows` over the stdlib, so the user build restores a stdlib
	// function's borrow-returning status (notably the bodyless-in-user-build element
	// loaders `__managed_mem_get` / `__managed_mem_cursor_current`, whose actual bodies
	// return a param-derived load) instead of re-deriving it from a name allowlist.
	// Same `Set<String>` shape as `funcReturnsConsumedArg`; names round-trip verbatim.
	export var funcReturnsBorrow as FuncReturnsBorrowSet
	// Cache v77: persisted RECEIVER-INTERIOR return facts
	// (`funcReturnsReceiverInterior`) — the liveness-only superset of the borrow
	// set (`List.walkTo` returns an ACQUIRED node whose value the chain still
	// owns). Restored on the user build so `recordNavBorrow` extends the receiver
	// past opaque interior-returning calls. Same `Set<String>` shape.
	export var funcReturnsReceiverInterior as FuncReturnsBorrowSet
	// Cache v73: persisted ELEMENT-LOADER chain-boundary facts (`funcIsElementLoader`)
	// computed by `analyzeReturnBorrows` (the functions that call the shared
	// `__managed_mem_load_sized` load primitive). Restored on the user build so the
	// wrapper-retain boundary fires exactly once without a hardcoded loader-name list.
	// Same `Set<String>` shape; names round-trip verbatim.
	export var funcIsElementLoader as FuncReturnsBorrowSet
	// Cache v47: persisted throws-clause per qualified function name so
	// `try X.method() otherwise (e)` can recover the bare-enum / union
	// throws type at parse time even when stdlib was loaded from cache
	// instead of re-parsed. Without this, `funcThrowsTypes.get(qualified)`
	// returns `none` for every stdlib method and the `(e)` binding falls
	// back to `integer`, breaking the downstream `match e` dispatch (E3005).
	export var funcThrowsTypes as FuncThrowsTypeMap
	export var structTypes as StructTypeMap
	// Cache v47: persisted enum-type registry so cache-hit user code can
	// match-dispatch on stdlib enum cases (e.g. `match e ... keyAlreadyExists
	// then ...` against `MapError`). Without this, `project.enumTypes` is
	// empty post-restore and `resolveEnumMatchArms` rejects every stdlib-
	// throws scrutinee with E3005 "match scrutinee must be an enum-typed
	// value". Mirrors the structTypes round-trip — fields decoded against
	// the destination project's interner via the captured typeNameTable.
	export var enumTypes as EnumTypeMap
	export var topLevelConstants as ConstantMap
	// Snapshot of the source project's type-name interner at capture time.
	// MaxonType.named(id) values stored in funcReturnTypes / structTypes
	// embed an interner-local id; the user project's interner has its own
	// id space, so restoreStdlibMetadata uses this map to translate captured
	// ids back to names and re-intern them in the destination project.
	export var typeNameTable as StringArray
	// Discovery cache for the BuiltinArrayLiteral protocol. The parser writes
	// `[1, 2, 3]` literals through whichever stdlib type implements
	// `BuiltinArrayLiteral`; the discovery walk runs once, at parse time, over
	// `project.unresolvedStructTypes`. On a cache hit those entries are gone
	// (the parser doesn't re-parse stdlib), so we persist the discovered name
	// here and the loader re-publishes it after restore. The `none` arm means
	// no implementing type was observed in this stdlib build; `found(name)`
	// carries the discovered name.
	export var builtinArrayLiteralTypeName as BuiltinArrayLiteralName
	// Mirror of `builtinArrayLiteralTypeName` for the BuiltinDictionaryLiteral
	// protocol. Persisted so map literals (`[k: v, ...]`) survive a cache hit.
	export var builtinDictionaryLiteralTypeName as BuiltinDictionaryLiteralName
	// Mirror for the BuiltinCharLiteral protocol. Persisted so char literals
	// (`'x'`) resolve to the discovered type across a cache hit.
	export var builtinCharLiteralTypeName as BuiltinCharLiteralName
	// Mirror for the BuiltinStringLiteral protocol. Persisted so string literals
	// (`"..."`) and the `string` primitive arm resolve across a cache hit.
	export var builtinStringLiteralTypeName as BuiltinStringLiteralName
	// Phase 11.4 (cache v8): per-registry snapshots so cached-stdlib user
	// builds see the same `project.*` state a fresh-from-source build would.
	// Without these the user-code pipeline can't dispatch through
	// stdlib-declared conformances (e.g. `extension int implements Comparable`)
	// because `processExtensions`/`validateConformances` ran during the
	// cache-build pipeline, not during user-code resolution.
	export var interfaces as IrInterfaceMap
	export var conformances as ConformanceRegistry
	export var typeParameters as TypeParamRegistry
	export var interfaceRegistry as InterfaceTypeRegistry
	// Cache v49: snapshot of the cache-build project's `functionTypes` so the
	// in-process restore path can translate captured `MaxonType.function(id)`
	// values into the destination project's id space. The disk-cache decode
	// path interns function-types directly into `project.functionTypes` via
	// `readMaxonType`, then mirrors the result here in lockstep so
	// `translateMaxonType`'s identity round-trip returns the same id. Required
	// because `stdlib/Interfaces.maxon` declares `Iterable.map`/`filter`/
	// `contains` with function-typed parameters.
	export var functionTypes as FunctionTypeRegistry
	export var genericInstances as GenericInstanceRegistry
	export var genericTypealiases as GenericTypealiasMap
	export var layoutDescriptors as LayoutDescriptorRegistry
	export var witnessTables as WitnessTableRegistry
	export var livenessRoots as StringArray
	// v55: stdlib-side `project.moduleInitFuncs` snapshot. Restored on
	// cache hit so the user pipeline's parser can numbering past the
	// stdlib init names baked into the cached function table (avoiding
	// `__module_init_0` collisions) AND so `pruneDeadModuleInits` sees
	// the same set of inits as a cache-off build — keeping cache-parity
	// binaries byte-identical.
	export var moduleInitFuncs as StringArray
	// v55: stdlib-side `project.initToStoredVars` snapshot. Pairs with
	// `moduleInitFuncs` so the Std-level dead-init pass knows which
	// vars each cached stdlib init writes, and can drop the init when
	// nothing user-reachable references those vars.
	export var initToStoredVars as InitToStoredVarsMap
	// v55: stdlib-side `project.topLevelVars` snapshot. Restored so
	// `registerGlobalVarsForDataSection` adds the stdlib's `__data_*`
	// slots into user `globalData.dataSectionEntries` on cache-hit
	// identically to cache-off — without this, the `.data` section
	// layout differs (cache-off has extra slots that cache-on lacks),
	// shifting every subsequent slot's offset and making the
	// cache-parity check fail on every RIP-relative reference in `.text`.
	export var topLevelVars as TopLevelVarMap
	// Phase 11.4: snapshot of `Project.genericFunctionImplicitArity` so
	// cached-stdlib user builds see which stdlib functions need synthetic
	// layout/witness args appended at call sites. Without this, per-function
	// lowering (where stdlib funcs aren't in the local stdModule) can't
	// discover the callee's hasImplicitLayoutParam and emits an under-arity
	// call op — silent ABI corruption on x64, validator rejection on wasm.
	export var genericFunctionImplicitArity as GenericFunctionImplicitArityMap
	export var staticRdataValues as StaticRdataValueMap
	// Cache v50 (J.4c): persisted `project.unresolvedExtensions` so cache-hit
	// user builds see the stdlib's struct- / interface-extension metadata
	// (target type name, type-param rebindings, added conformances, where-
	// clauses, visibility, decl position). Required by `Constraints.
	// conditionalConformanceWhereClauseSatisfied` so a user-code call that
	// instantiates a stdlib generic (`Array with Int`) gates correctly
	// against the conditional conformance's where-clauses.
	export var unresolvedExtensions as UnresolvedExtensionArray
	// Cache v50 (J.4c): parser-recorded `extension <T>.<method>` where-
	// clause map. Mirrors `project.extensionMethodWhereClauses`. Used by
	// `unresolvedExtensionWhereClausesSatisfiedForCallee` to surface E4006
	// when a conditional-extension method's constraints aren't met by the
	// receiver's bindings.
	export var extensionMethodWhereClauses as WhereClauseMapByName
	// Phase 11.6 (cache v10): the stdlib's StdModule at the post-dce
	// point of its build pipeline. The user-code pipeline merges this
	// into its own StdModule for the inliner pass so stdlib accessor
	// bodies are visible at user call sites; merged functions are
	// dropped after inlining so the linker-side stdlib cache stays the
	// sole source of stdlib machine code.
	export var inlinerStdModule as StdModule
	// Precomputed Std-DFE reachability edges, one record per function in
	// `inlinerStdModule`. Extracted once at cache-build time (so the
	// load-time Std-DFE consults this flat table instead of re-walking the
	// cached Std-IR snapshot to re-derive reachability). See `CachedFuncEdges`.
	export var stdFuncEdges as CachedFuncEdgeMap
	// In-memory only. Maps each writer-side `GenericInstanceId` (the raw
	// qword serialized in `layoutDescriptors`/`witnessTables` payloads) to
	// the equivalent destination-`project.genericInstances` id assigned
	// when `readGenericInstanceRegistry` re-interned the writer's entries.
	// Necessary because `readMaxonGenericInstance` interns args recursively
	// before the outer entry is interned, so the destination project's id
	// space does not preserve the writer's id ordering. Built during
	// decode; consumed by `translateWriterGenericInstanceId` in
	// `restoreRegistries`. Not serialised — recomputable from the on-disk
	// registry list at every cache load.
	export var writerGidToProjectGid as GenericInstanceIdArray
	// In-memory only. Maps each writer-side `GenericInstanceId` to its entry
	// in `data.genericInstances`' CURRENT id space. The two spaces coincide
	// on the in-memory capture path (the capture mirror preserves writer
	// ordering), but diverge on the disk path: after the read re-mirrors
	// `data.genericInstances` from the first reading project (the
	// identity-translation trick), writer ordering is lost there — the
	// read-time writer→project map is the only surviving record of it.
	// `restoreRegistries` rebuilds `writerGidToProjectGid` for each
	// destination project by translating THIS map's data-space entries;
	// rebuilding positionally from `data.genericInstances` instead silently
	// attached `__layout_*` labels to the wrong generic instances whenever
	// recursive arg interning had reordered the reader's id assignments
	// (e.g. `Array with String` restored with `__layout_Array_SlotState`,
	// so its element walk never ran and every element leaked).
	export var writerGidToDataGid as GenericInstanceIdArray

	export static function create() returns StdlibCacheData
		return Self{
			functions: ObjectFunctionArray.create(),
			wasmFunctions: WasmObjectFunctionArray.create(),
			globalData: createGlobalDataTable(),
			typealiases: TypealiasMap.create(),
			typealiasVisibilities: TypealiasVisibilityMap.create(),
			typealiasRanges: TypealiasRangeMap.create(),
			typealiasCastCategories: TypealiasCastCategoryMap.create(),
			funcReturnTypes: FuncReturnTypeMap.create(),
			funcSignatures: FuncSignatureMap.create(),
			funcParamConsumes: FuncParamConsumesMap.create(),
			funcReturnsConsumedArg: FuncReturnsBorrowSet.create(),
			funcReturnsBorrow: FuncReturnsBorrowSet.create(),
			funcReturnsReceiverInterior: FuncReturnsBorrowSet.create(),
			funcIsElementLoader: FuncReturnsBorrowSet.create(),
			funcThrowsTypes: FuncThrowsTypeMap.create(),
			structTypes: StructTypeMap.create(),
			enumTypes: EnumTypeMap.create(),
			topLevelConstants: ConstantMap.create(),
			typeNameTable: StringArray.create(),
			builtinArrayLiteralTypeName: BuiltinArrayLiteralName.none,
			builtinDictionaryLiteralTypeName: BuiltinDictionaryLiteralName.none,
			builtinCharLiteralTypeName: BuiltinCharLiteralName.none,
			builtinStringLiteralTypeName: BuiltinStringLiteralName.none,
			interfaces: IrInterfaceMap.create(),
			conformances: ConformanceRegistry.create(),
			typeParameters: TypeParamRegistry.create(),
			interfaceRegistry: InterfaceTypeRegistry.create(),
			functionTypes: FunctionTypeRegistry.create(),
			genericInstances: GenericInstanceRegistry.create(),
			genericTypealiases: GenericTypealiasMap.create(),
			layoutDescriptors: LayoutDescriptorRegistry.create(),
			witnessTables: WitnessTableRegistry.create(),
			livenessRoots: StringArray.create(),
			moduleInitFuncs: StringArray.create(),
			initToStoredVars: InitToStoredVarsMap.create(),
			topLevelVars: TopLevelVarMap.create(),
			genericFunctionImplicitArity: GenericFunctionImplicitArityMap.create(),
			staticRdataValues: StaticRdataValueMap.create(),
			unresolvedExtensions: UnresolvedExtensionArray.create(),
			extensionMethodWhereClauses: WhereClauseMapByName.create(),
			inlinerStdModule: StdModule.create(),
			stdFuncEdges: CachedFuncEdgeMap.create(),
			writerGidToProjectGid: GenericInstanceIdArray.create(),
			writerGidToDataGid: GenericInstanceIdArray.create()
		}
	end 'create'
end 'StdlibCacheData'

// Result of loading a cache file.
export type StdlibCacheResult
	export var data as StdlibCacheData
	export var valid as bool

	export static function create(data StdlibCacheData, valid bool) returns StdlibCacheResult
		return Self{data: data, valid: valid}
	end 'create'
end 'StdlibCacheResult'

// ============================================================
// Checksum
// ============================================================

// FNV-1a 32-bit hash over the supplied stdlib source files, the in-memory
// bootstrap source, and the runtime.std contents. Position-mixing (each byte
// is xor'd then multiplied by the FNV prime) so a stale cache won't survive a
// byte swap, file reorder, or anything else the old additive sum collided on.
// Caller controls which files participate (so the cache key matches the
// on-disk whitelist) and passes the bootstrap + runtime path explicitly so
// the cache invalidates whenever any of them change.
//
// runtimePath may be empty (no runtime found / cross-tooling); in that case
// only stdlib files + bootstrap participate, which still matches the build
// path's behavior of skipping signature injection when runtime is absent.
let FNV_OFFSET_BASIS = 0x811C9DC5
let FNV_PRIME = 0x01000193

function fnvUpdate(state CacheChecksum, b MachineWord) returns CacheChecksum
	let mixed = state xor b
	return (mixed * FNV_PRIME) and 0xFFFFFFFF
end 'fnvUpdate'

export function computeStdlibChecksum(files FilePathArray, runtimePath FilePath) returns CacheChecksum
	var checksum = FNV_OFFSET_BASIS
	for filePath in files 'eachFile'
		let bytes = try File.readBinary(filePath) otherwise continue
		for b in bytes 'eachByte'
			checksum = fnvUpdate(checksum, b: b)
		end 'eachByte'
		// Length separator so a byte stolen from one file and prepended to the
		// next doesn't produce the same hash as the original split.
		checksum = fnvUpdate(checksum, b: 0)
	end 'eachFile'
	if not runtimePath.isEmpty() 'hasRuntime'
		let rtBytes = try File.readBinary(runtimePath) otherwise ByteArray.create()
		for rb in rtBytes 'eachRuntimeByte'
			checksum = fnvUpdate(checksum, b: rb)
		end 'eachRuntimeByte'
	end 'hasRuntime'
	return checksum
end 'computeStdlibChecksum'

// Get compiler executable fingerprint: file size and modification time.
export function getCompilerFingerprint() returns (MachineWord, MachineWord)
	let exePath = try Process.executablePath() otherwise return (0, 0)
	let info = try File.info(exePath) otherwise return (0, 0)

	return (info.size, info.modifiedTime)
end 'getCompilerFingerprint'

// ============================================================
// ThrowsClause cache field helpers
// ============================================================
//
// `IrFunction.throwsTypeName` and `InterfaceMethodSig.throwsTypeName` are
// `ThrowsClause` unions whose absent arm (`none`) must be distinguishable
// from a (hypothetical) present-but-empty name on disk. The on-disk
// representation is a tag-prefixed optional string written through
// `writeOptionalString` / `readOptionalString` (1-byte tag + optional length-
// prefixed payload). Step 8 will tighten `writeString` / `readString` to
// reject length-0 payloads; this helper keeps each call site a single line
// and centralises the tag/payload dispatch.
//
// Step 5 keeps Step 8's recovery boundary out of the cache reader call chain:
// a corrupt tag panics here rather than threading `throws CacheCorruption`
// through every intermediate `read*` helper. Step 8 will revisit this and
// route the throw up to the cache driver instead.
function writeThrowsClauseField(buf ByteArray, clause ThrowsClause) throws CacheCorruption
	match clause 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		throwing(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeThrowsClauseField'

function readThrowsClauseField(buf ByteArray, offset ByteOffset) returns (ThrowsClause, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (ThrowsClause.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (ThrowsClause.throwing(name), nextPos)
end 'readThrowsClauseField'

// Mirrors writeThrowsClauseField for WitnessTable.parentWitnessLabel:
// `none` writes a 0-byte tag; `present(n)` writes a 1-byte tag plus the
// payload string. Step 8 will swap the panic for a `throws CacheCorruption`
// once the cache decoder chain plumbs the throw end-to-end.
function writeParentWitnessLabelField(buf ByteArray, label ParentWitnessLabel) throws CacheCorruption
	match label 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		present(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeParentWitnessLabelField'

function readParentWitnessLabelField(buf ByteArray, offset ByteOffset) returns (ParentWitnessLabel, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (ParentWitnessLabel.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (ParentWitnessLabel.present(name), nextPos)
end 'readParentWitnessLabelField'

// Mirrors writeThrowsClauseField for StdlibCacheData.builtinArrayLiteralTypeName:
// `none` writes a 0-byte tag; `found(n)` writes a 1-byte tag plus the payload
// string. Step 8 will swap the panic for a `throws CacheCorruption` once the
// cache decoder chain plumbs the throw end-to-end.
function writeBuiltinArrayLiteralNameField(buf ByteArray, value BuiltinArrayLiteralName) throws CacheCorruption
	match value 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		found(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeBuiltinArrayLiteralNameField'

function readBuiltinArrayLiteralNameField(buf ByteArray, offset ByteOffset) returns (BuiltinArrayLiteralName, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (BuiltinArrayLiteralName.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (BuiltinArrayLiteralName.found(name), nextPos)
end 'readBuiltinArrayLiteralNameField'

// Mirrors writeBuiltinArrayLiteralNameField for the dictionary literal cache.
function writeBuiltinDictionaryLiteralNameField(buf ByteArray, value BuiltinDictionaryLiteralName) throws CacheCorruption
	match value 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		found(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeBuiltinDictionaryLiteralNameField'

function readBuiltinDictionaryLiteralNameField(buf ByteArray, offset ByteOffset) returns (BuiltinDictionaryLiteralName, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (BuiltinDictionaryLiteralName.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (BuiltinDictionaryLiteralName.found(name), nextPos)
end 'readBuiltinDictionaryLiteralNameField'

// Mirrors writeBuiltinArrayLiteralNameField for the char literal cache.
function writeBuiltinCharLiteralNameField(buf ByteArray, value BuiltinCharLiteralName) throws CacheCorruption
	match value 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		found(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeBuiltinCharLiteralNameField'

function readBuiltinCharLiteralNameField(buf ByteArray, offset ByteOffset) returns (BuiltinCharLiteralName, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (BuiltinCharLiteralName.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (BuiltinCharLiteralName.found(name), nextPos)
end 'readBuiltinCharLiteralNameField'

// Mirrors writeBuiltinArrayLiteralNameField for the string literal cache.
function writeBuiltinStringLiteralNameField(buf ByteArray, value BuiltinStringLiteralName) throws CacheCorruption
	match value 'enc'
		none then try writeOptionalString(buf, present: false, value: "")
		found(n) then try writeOptionalString(buf, present: true, value: n)
	end 'enc'
end 'writeBuiltinStringLiteralNameField'

function readBuiltinStringLiteralNameField(buf ByteArray, offset ByteOffset) returns (BuiltinStringLiteralName, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return (BuiltinStringLiteralName.none, offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	let (name, nextPos) = result
	return (BuiltinStringLiteralName.found(name), nextPos)
end 'readBuiltinStringLiteralNameField'

// ============================================================
// Write cache
// ============================================================

// Step 8 boundary: every `writeString` / `writeOptionalString` call beneath
// this entry point can throw `CacheCorruption.invalidEncoding` — see
// `Serialize.writeString`'s mandatory-non-empty invariant. We swallow the
// throw at the top level here, log a diagnostic, and skip persisting the
// cache. The build itself still completes correctly because the cache is
// an optimisation, not a correctness requirement; the next clean run will
// retry the write from a fresh in-memory state.
export function writeStdlibCache(project Project, path FilePath, data StdlibCacheData, target Target, contentChecksum CacheChecksum)
	var buf = ByteArray.create()
	buf.reserve(4096)
	try encodeStdlibCacheBody(project, buf: buf, data: data, target: target, contentChecksum: contentChecksum) otherwise (e) 'corrupt'
		match e 'kind'
			absent then logError(LogCategory.compiler, message: function() gives "writeStdlibCache: unexpected `absent` from optional-string codec — skipping persist")
			invalidEncoding then logError(LogCategory.compiler, message: function() gives "writeStdlibCache: malformed in-memory cache state (length-0 mandatory string) — skipping persist")
		end 'kind'
		return
	end 'corrupt'

	// Ensure parent directory (and any missing ancestors) exist
	let parentDir = try path.parent() otherwise FilePath from ""
	if not parentDir.isEmpty() 'hasParent'
		_ = Directory.create(parentDir)
	end 'hasParent'

	try File.writeBinary(path, content: buf) otherwise 'writeErr'
		logError(LogCategory.compiler, message: function() gives "Failed to write stdlib cache to {path}")
	end 'writeErr'
end 'writeStdlibCache'

function encodeStdlibCacheBody(project Project, buf ByteArray, data StdlibCacheData, target Target, contentChecksum CacheChecksum) throws CacheCorruption
	// Header
	buf.push(CACHE_MAGIC_0)
	buf.push(CACHE_MAGIC_1)
	buf.push(CACHE_MAGIC_2)
	buf.push(CACHE_MAGIC_3)
	writeDword(buf, value: CACHE_FORMAT_VERSION)
	writeDword(buf, value: contentChecksum)

	let (compilerSize, compilerMtime) = getCompilerFingerprint()
	writeDword(buf, value: compilerSize)
	writeQword(buf, value: compilerMtime)

	writeCpuArch(buf, cpu: target.cpu)
	writeOs(buf, os: target.os)
	writeDword(buf, value: data.functions.count())

	// Per-function objects
	for func in data.functions 'eachFunc'
		try writeString(buf, s: func.name)
		writeStdReturnType(buf, rt: func.returnType)
		writeDword(buf, value: func.paramCount)

		// Param types
		writeDword(buf, value: func.paramTypes.count())
		for pt in func.paramTypes 'eachParamType'
			writeStdTypeTag(buf, t: pt)
		end 'eachParamType'

		// Code bytes
		writeDword(buf, value: func.code.count())
		buf.append(func.code)

		// Call fixups
		writeDword(buf, value: func.callFixups.count())
		for fixup in func.callFixups 'eachFixup'
			writeDword(buf, value: fixup.codeOffset)
			try writeString(buf, s: fixup.targetName)
		end 'eachFixup'

		// Rdata relocations
		writeDword(buf, value: func.rdataRelocs.count())
		for reloc in func.rdataRelocs 'eachRdata'
			writeDword(buf, value: reloc.codeOffset)
			try writeString(buf, s: reloc.rdataLabel)
			writeRdataRelocKind(buf, kind: reloc.kind)
		end 'eachRdata'

		// IAT/GOT relocations
		writeDword(buf, value: func.relocations.count())
		for reloc in func.relocations 'eachReloc'
			writeDword(buf, value: reloc.codeOffset)
			writeDword(buf, value: reloc.slotIndex)
		end 'eachReloc'

		// ARM64 ADR fixups
		writeDword(buf, value: func.adrFixups.count())
		for fixup in func.adrFixups 'eachAdr'
			writeDword(buf, value: fixup.instrOffset)
			writeDword(buf, value: fixup.destReg)
			try writeString(buf, s: fixup.targetName)
		end 'eachAdr'
	end 'eachFunc'

	// WASM per-function objects
	writeDword(buf, value: data.wasmFunctions.count())
	for func in data.wasmFunctions 'eachWasmFunc'
		try writeString(buf, s: func.name)
		writeStdReturnType(buf, rt: func.returnType)
		writeDword(buf, value: func.paramCount)
		writeDword(buf, value: func.paramTypes.count())
		for pt in func.paramTypes 'eachParamType'
			writeStdTypeTag(buf, t: pt)
		end 'eachParamType'

		// Throwing-function ABI: tag-prefixed optional name (none = non-throwing).
		try writeThrowsClauseField(buf, clause: func.throwsTypeName)

		// Body bytes
		writeDword(buf, value: func.body.count())
		buf.append(func.body)

		// WASM call fixups
		writeDword(buf, value: func.callFixups.count())
		for fixup in func.callFixups 'eachFixup'
			writeDword(buf, value: fixup.bodyOffset)
			try writeString(buf, s: fixup.targetName)
		end 'eachFixup'

		// WASM type-section fixups (indirect-call signature indices). Each
		// entry persists the bodyOffset and the encoded function-type
		// signature bytes. On cache restore the user-build re-runs the
		// type-section fixup walker to patch the body.
		writeDword(buf, value: func.typeFixups.count())
		for tyFix in func.typeFixups 'eachTyFix'
			writeDword(buf, value: tyFix.bodyOffset)
			writeDword(buf, value: tyFix.signatureBytes.count())
			buf.append(tyFix.signatureBytes)
		end 'eachTyFix'

		// Cache v29: WASM funcAddr table-index fixups. One entry per i32.const
		// byte sequence emitted by `funcAddr` that targets a function whose
		// final wasm table index isn't known until the user-build assembles
		// the module (e.g. stdlib's `__managed_mem_create` taking the address
		// of `stdlib.__destruct___ManagedMemory`).
		writeDword(buf, value: func.funcAddrFixups.count())
		for addrFix in func.funcAddrFixups 'eachAddrFix'
			writeDword(buf, value: addrFix.bodyOffset)
			try writeString(buf, s: addrFix.targetName)
		end 'eachAddrFix'

		// Cache v46: WASM globalAddr linear-memory offset fixups. The user
		// pipeline merges its data ahead of the stdlib chunks, so the
		// cache-time offsets stored at lower time don't reflect the final
		// layout. Each fixup carries the body offset of the 5-byte fixed-
		// width i64.const payload plus the symbol name that the user-build
		// resolves via globalDataOffsets.
		writeDword(buf, value: func.globalAddrFixups.count())
		for gAddrFix in func.globalAddrFixups 'eachGAddrFix'
			writeDword(buf, value: gAddrFix.bodyOffset)
			try writeString(buf, s: gAddrFix.targetName)
		end 'eachGAddrFix'
	end 'eachWasmFunc'

	// GlobalData
	writeDword(buf, value: data.globalData.names.count())
	for i in 0 upto data.globalData.names.count() 'eachGlobal'
		let name = try data.globalData.names.get(i) otherwise panic("writeCache eachGlobal: loop index {i} < names.count() just succeeded but get({i}) failed (count={data.globalData.names.count()})")
		let value = try data.globalData.values.get(i) otherwise panic("writeCache eachGlobal: globalData.values must parallel names but get({i}) failed (count={data.globalData.values.count()}, names.count={data.globalData.names.count()})")
		try writeString(buf, s: name)
		writeDword(buf, value: value.count())
		buf.append(value)
	end 'eachGlobal'

	// Typealiases
	writeDword(buf, value: data.typealiases.count())
	for (name, baseType) in data.typealiases 'eachAlias'
		try writeString(buf, s: name)
		writeStdTypeTag(buf, t: baseType)
	end 'eachAlias'

	// Cache v17: typealias visibility sidecar — name → array of (visibility,
	// sourceFilePath) entries. One entry per declaring file.
	writeDword(buf, value: data.typealiasVisibilities.count())
	for (name, infos) in data.typealiasVisibilities 'eachAliasVis'
		try writeString(buf, s: name)
		writeDword(buf, value: infos.count())
		for info in infos 'eachInfo'
			writeVisibility(buf, v: info.visibility)
			try writeString(buf, s: info.sourceFilePath.toString())
		end 'eachInfo'
	end 'eachAliasVis'

	// Typealias ranges
	writeDword(buf, value: data.typealiasRanges.count())
	for (name, range) in data.typealiasRanges 'eachRange'
		try writeString(buf, s: name)
		writeQword(buf, value: range.lower)
		writeQword(buf, value: range.upper)
	end 'eachRange'

	// Typealias cast categories — stored as the CastCategory enum's ordinal
	// so the on-disk encoding is stable across name changes (the enum cases
	// would have to be reordered for the value to drift).
	writeDword(buf, value: data.typealiasCastCategories.count())
	for (name, category) in data.typealiasCastCategories 'eachCategory'
		try writeString(buf, s: name)
		writeDword(buf, value: category.ordinal)
	end 'eachCategory'

	// Function return types
	writeDword(buf, value: data.funcReturnTypes.count())
	for (name, rt) in data.funcReturnTypes 'eachRt'
		try writeString(buf, s: name)
		try writeMaxonReturnType(project, buf: buf, rt: rt)
	end 'eachRt'

	// Function signatures (param names + types + defaults). Persisted so
	// TypeResolution.checkCallArity can validate stdlib-call sites without
	// needing to re-parse stdlib source — see CACHE_FORMAT_VERSION = 5 note.
	writeDword(buf, value: data.funcSignatures.count())
	for (name, signature) in data.funcSignatures 'eachSig'
		try writeString(buf, s: name)
		writeDword(buf, value: signature.paramNames.count())
		for paramName in signature.paramNames 'eachParamName'
			try writeString(buf, s: paramName)
		end 'eachParamName'
		for paramType in signature.paramTypes 'eachParamType'
			try writeMaxonType(project, buf: buf, t: paramType)
		end 'eachParamType'
		for paramDefault in signature.paramDefaults 'eachParamDefault'
			try writeParamDefault(buf, pd: paramDefault)
		end 'eachParamDefault'
	end 'eachSig'

	// Cache v70 (Concept C): per-function argument-consume bits. name → BoolArray
	// (a length-prefixed run of bool bytes). No type-interner ids, so no codec helper
	// beyond string + bool-byte. Followed by the transparent-wrapper name set.
	writeDword(buf, value: data.funcParamConsumes.count())
	for (name, bits) in data.funcParamConsumes 'eachConsume'
		try writeString(buf, s: name)
		writeDword(buf, value: bits.count())
		for b in bits 'eachConsumeBit'
			writeBoolByte(buf, b: b)
		end 'eachConsumeBit'
	end 'eachConsume'
	writeDword(buf, value: data.funcReturnsConsumedArg.count())
	for wrapperName in data.funcReturnsConsumedArg 'eachWrapper'
		try writeString(buf, s: wrapperName)
	end 'eachWrapper'

	// Cache v72: return-borrow function-name set (same shape as the wrapper set above).
	writeDword(buf, value: data.funcReturnsBorrow.count())
	for borrowName in data.funcReturnsBorrow 'eachBorrow'
		try writeString(buf, s: borrowName)
	end 'eachBorrow'

	// Cache v77: receiver-interior return set (same shape).
	writeDword(buf, value: data.funcReturnsReceiverInterior.count())
	for interiorName in data.funcReturnsReceiverInterior 'eachInterior'
		try writeString(buf, s: interiorName)
	end 'eachInterior'

	// Cache v73: element-loader chain-boundary function-name set (same shape).
	writeDword(buf, value: data.funcIsElementLoader.count())
	for loaderName in data.funcIsElementLoader 'eachLoader'
		try writeString(buf, s: loaderName)
	end 'eachLoader'

	// Cache v47: per-function throws-clause. Mirrors the funcReturnTypes
	// layout — string key + ThrowsClause field via the absent/throwing codec.
	writeDword(buf, value: data.funcThrowsTypes.count())
	for (name, throwsClause) in data.funcThrowsTypes 'eachThrows'
		try writeString(buf, s: name)
		try writeThrowsClauseField(buf, clause: throwsClause)
	end 'eachThrows'

	// Struct types
	writeDword(buf, value: data.structTypes.count())
	for (name, st) in data.structTypes 'eachStruct'
		try writeString(buf, s: name)
		writeDword(buf, value: st.byteSize)
		writeDword(buf, value: st.fields.count())

		for field in st.fields 'eachField'
			try writeString(buf, s: field.name)
			try writeMaxonType(project, buf: buf, t: field.fieldType)
			writeDword(buf, value: field.offset)
			writeBoolByte(buf, b: field.isMutable)
			// Cache v32: round-trip the layout-pass sentinel so cached fields
			// keep the `offsetResolved: true` flag that the producing run's
			// `layoutAllStructs` pass stamped.
			writeBoolByte(buf, b: field.offsetResolved)
			// Cache v35: round-trip the per-field `export` flag used by the
			// E3014 unexported-field-access diagnostic.
			writeBoolByte(buf, b: field.isExported)
		end 'eachField'

		// Cache v7: persist the per-struct inner-typealias map so cache-hit
		// lowering can resolve names like `ElementMemory` (declared inside
		// `type Array uses Element`) the same way a cache-miss parse would.
		// Without this round-trip, `applyInnerAliasIfNamed` sees an empty
		// map post-restore and lets the bare placeholder reach
		// `namedIdCastCategory`, which panics.
		writeDword(buf, value: st.innerAliases.count())
		for (aliasName, aliasType) in st.innerAliases 'eachInnerAlias'
			try writeString(buf, s: aliasName)
			try writeMaxonType(project, buf: buf, t: aliasType)
		end 'eachInnerAlias'
	end 'eachStruct'

	// Cache v47: enum types. Required so cache-hit user code can dispatch
	// on stdlib enum cases via `match`. Mirrors the struct loop's writer
	// shape — name + flags + case array. Visibility/sourceFilePath are not
	// persisted; the reader stamps `global` + stdlib bootstrap path the
	// same way structTypes does. Payload-field types are written via
	// `writeMaxonType` for the typeNameTable round-trip. `rawStringValue`
	// and `backingStructName` route through `writeOptionalString` because
	// they're empty strings for plain enum cases — the mandatory `writeString`
	// codec rejects empty strings.
	writeDword(buf, value: data.enumTypes.count())
	for (name, et) in data.enumTypes 'eachEnum'
		try writeString(buf, s: name)
		writeBoolByte(buf, b: et.isFloatBacked)
		writeBoolByte(buf, b: et.isStringBacked)
		writeBoolByte(buf, b: et.isCharBacked)
		writeBoolByte(buf, b: et.isUnion)
		writeDword(buf, value: et.cases.count())
		for ec in et.cases 'eachCase'
			try writeString(buf, s: ec.name)
			writeDword(buf, value: ec.ordinal)
			writeQword(buf, value: ec.rawValue)
			try writeOptionalStringDefaultEmpty(buf, value: ec.rawStringValue)
			try writeOptionalStringDefaultEmpty(buf, value: ec.backingStructName)
			writeDword(buf, value: ec.payloadFields.count())
			for pf in ec.payloadFields 'eachPayload'
				try writeString(buf, s: pf.name)
				try writeMaxonType(project, buf: buf, t: pf.fieldType)
			end 'eachPayload'
		end 'eachCase'
	end 'eachEnum'

	// Top-level constants. Visibility / sourceFilePath are not serialized:
	// every stdlib constant is implicitly `exported` and originates at the
	// stdlib bootstrap path; readStdlibCache stamps those defaults in.
	writeDword(buf, value: data.topLevelConstants.count())
	for (name, entry) in data.topLevelConstants 'eachConst'
		try writeString(buf, s: name)
		try writeConstantValue(project, buf: buf, cv: entry.value)
	end 'eachConst'

	// BuiltinArrayLiteral / BuiltinDictionaryLiteral discovery. The `none` arm
	// means no implementing type was observed in this stdlib build. Persisted
	// so the parser can resolve `[a, b, c]` and `[k: v, ...]` after a cache
	// hit, where the `unresolvedStructTypes` registry has been drained and the
	// conformance metadata is otherwise gone.
	try writeBuiltinArrayLiteralNameField(buf, value: data.builtinArrayLiteralTypeName)
	try writeBuiltinDictionaryLiteralNameField(buf, value: data.builtinDictionaryLiteralTypeName)
	try writeBuiltinCharLiteralNameField(buf, value: data.builtinCharLiteralTypeName)
	try writeBuiltinStringLiteralNameField(buf, value: data.builtinStringLiteralTypeName)

	// Cache v8: Phase 11 conformance + registry state. Order matters on the
	// read side — typeParameters / interfaceRegistry / genericInstances are
	// interned by structural identity, so writing them here in the same order
	// the source project recorded them makes the destination's `intern` calls
	// hand back identical ids during restore. Other registries
	// (interfaces, conformances, genericTypealiases, layoutDescriptors,
	// witnessTables, staticRdataValues, livenessRoots) carry their own keys
	// and don't depend on insertion order for correctness.
	try writeTypeParamRegistry(buf, registry: data.typeParameters)
	try writeInterfaceTypeRegistry(buf, registry: data.interfaceRegistry)
	try writeGenericInstanceRegistry(project, buf: buf, registry: data.genericInstances)
	try writeInterfaceMap(project, buf: buf, m: data.interfaces)
	try writeConformanceRegistry(project, buf: buf, registry: data.conformances)
	try writeGenericTypealiasMap(project, buf: buf, m: data.genericTypealiases)
	try writeLayoutDescriptorRegistry(buf, registry: data.layoutDescriptors)
	try writeWitnessTableRegistry(buf, registry: data.witnessTables)
	try writeStringArray(buf, arr: data.livenessRoots)
	// v55: stdlib's `__module_init_<n>` registry + write-set tracking +
	// top-level var map. Lets cache-on user builds match cache-off byte-
	// for-byte, both for dead-init pruning AND for `.data` section layout.
	try writeStringArray(buf, arr: data.moduleInitFuncs)
	try writeInitToStoredVarsMap(buf, m: data.initToStoredVars)
	try writeTopLevelVarMap(project, buf: buf, m: data.topLevelVars)
	try writeGenericFunctionImplicitArityMap(buf, m: data.genericFunctionImplicitArity)
	try writeStaticRdataValueMap(buf, m: data.staticRdataValues)
	// Cache v50 (J.4c): stdlib-side extension metadata. Written before the
	// StdModule blob so the decoder's pos chain stays straightforward and the
	// expensive StdModule decode happens last.
	try writeUnresolvedExtensionArray(buf, arr: data.unresolvedExtensions)
	try writeWhereClauseMapByName(buf, m: data.extensionMethodWhereClauses)
	// Cache v68: precomputed Std-DFE edge table. A flat string map (cheap to
	// decode), written before the StdModule blob so the expensive StdModule
	// decode still happens last and the decoder's pos chain stays linear.
	try writeStdFuncEdgeMap(buf, m: data.stdFuncEdges)
	// Cache v10: the stdlib's post-dce StdModule snapshot for cross-
	// module inlining at user pipeline time.
	try writeStdModule(buf, module: data.inlinerStdModule)
end 'encodeStdlibCacheBody'

// ============================================================
// Read cache
// ============================================================

// Step 8 boundary: any `readString` / `readOptionalString` call beneath
// this entry point can throw `CacheCorruption.invalidEncoding` if the cache
// file is malformed. We catch the throw, log an informational diagnostic
// identifying the cache as corrupt, and return the existing
// `StdlibCacheResult { valid: false }` sentinel — the loader treats this
// the same as a missing cache file and falls back to the cold path.
export function readStdlibCache(project Project, path FilePath, target Target, expectedChecksum CacheChecksum) returns StdlibCacheResult
	let invalid = StdlibCacheResult.create(StdlibCacheData.create(), valid: false)

	let buf = try File.readBinary(path) otherwise return invalid

	let result = try decodeStdlibCache(project, buf: buf, target: target, expectedChecksum: expectedChecksum) otherwise (e) 'corrupt'
		match e 'kind'
			absent then logInfo(LogCategory.compiler, message: function() gives "Stdlib cache at {path} reports unexpected `absent` from optional-string codec; treating as corrupt and rebuilding")
			invalidEncoding then logInfo(LogCategory.compiler, message: function() gives "Stdlib cache at {path} is corrupt (CacheCorruption.invalidEncoding); rebuilding from source")
		end 'kind'
		return invalid
	end 'corrupt'
	return result
end 'readStdlibCache'

// Slice `len` bytes out of `buf` starting at `offset`, append them to
// `dst`, and return the new offset. Replaces the per-byte loop pattern
// `for _ in 0 upto len 'copy' { dst.push(try buf.get(pos)); pos += 1 }`.
// Panics on OOB — caller must have validated `offset + len <= buf.count()`
// either explicitly or by reading the length prefix from a well-formed
// buffer (the caller's invariant is the same one that justifies the
// per-byte panic in the loop form).
function copyBytesInto(dst ByteArray, buf ByteArray, offset ByteOffset, len ByteOffset) returns ByteOffset
	let endIndex = offset + len
	let chunk = try buf.slice(offset, endIndex: endIndex) otherwise panic("copyBytesInto: slice OOB (offset={offset}, len={len}, buf.count={buf.count()})")
	dst.append(chunk)
	return endIndex
end 'copyBytesInto'

function decodeStdlibCache(project Project, buf ByteArray, target Target, expectedChecksum CacheChecksum) returns StdlibCacheResult throws CacheCorruption
	let invalid = StdlibCacheResult.create(StdlibCacheData.create(), valid: false)

	// Validate header
	if buf.count() < 36 'tooSmall'
		return invalid
	end 'tooSmall'

	// buf.count() >= 36 just verified, so the four magic-byte reads share one invariant.
	var m0 = 0
	var m1 = 0
	var m2 = 0
	var m3 = 0
	try 'readMagic'
		m0 = buf.get(0)
		m1 = buf.get(1)
		m2 = buf.get(2)
		m3 = buf.get(3)
	end 'readMagic' otherwise (e) 'badMagic2'
		match e 'kind'
			indexOutOfBounds then panic("loadCache: buf.count() >= 36 just verified but magic-byte read OOB")
			emptySlot then panic("loadCache: magic byte slot empty (push-init invariant)")
		end 'kind'
	end 'badMagic2'

	if m0 != CACHE_MAGIC_0 or m1 != CACHE_MAGIC_1 or m2 != CACHE_MAGIC_2 or m3 != CACHE_MAGIC_3 'badMagic'
		return invalid
	end 'badMagic'

	let version = readDword(buf, offset: 4)
	if version != CACHE_FORMAT_VERSION 'badVersion'
		logInfo(LogCategory.compiler, message: function() gives "Stdlib cache version mismatch (found {version}, expected {CACHE_FORMAT_VERSION}); regenerating")
		return invalid
	end 'badVersion'

	let checksum = readDword(buf, offset: 8)
	if checksum != expectedChecksum 'badChecksum'
		return invalid
	end 'badChecksum'

	// Compiler fingerprint
	let cachedCompilerSize = readDword(buf, offset: 12)
	let cachedCompilerMtime = readQword(buf, offset: 16)
	let (currentCompilerSize, currentCompilerMtime) = getCompilerFingerprint()

	if cachedCompilerSize != currentCompilerSize or cachedCompilerMtime != currentCompilerMtime 'staleCompiler'
		return invalid
	end 'staleCompiler'

	// Target
	let (cachedCpu, _) = readCpuArch(buf, offset: 24)
	let (cachedOs, _) = readOs(buf, offset: 28)

	if cachedCpu.rawValue != target.cpu.rawValue or cachedOs.rawValue != target.os.rawValue 'badTarget'
		return invalid
	end 'badTarget'

	let functionCount = readDword(buf, offset: 32)
	var pos = 36

	var data = StdlibCacheData.create()

	// Read per-function objects
	for _ in 0 upto functionCount 'eachFunc'
		let (name, p1) = try readString(buf, offset: pos)
		pos = p1
		let (returnType, p1b) = readStdReturnType(buf, offset: pos)
		pos = p1b
		let paramCount = readDword(buf, offset: pos)
		pos = pos + 4

		var func = ObjectFunction.create(name, returnType: returnType, paramCount: paramCount)

		// Param types
		let paramTypeCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto paramTypeCount 'eachParamType'
			let (pt, ptPos) = readStdTypeTag(buf, offset: pos)
			pos = ptPos
			func.paramTypes.push(pt)
		end 'eachParamType'

		// Code bytes
		let codeLen = readDword(buf, offset: pos)
		pos = pos + 4

		func.code.reserve(codeLen)
		pos = copyBytesInto(func.code, buf: buf, offset: pos, len: codeLen)

		// Call fixups
		let fixupCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto fixupCount 'eachFixup'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (targetName, p2) = try readString(buf, offset: pos)
			pos = p2
			func.callFixups.push(CallFixup.create(codeOffset, targetName: targetName))
		end 'eachFixup'

		// Rdata relocations
		let rdataCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto rdataCount 'eachRdata'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (rdataLabel, p3) = try readString(buf, offset: pos)
			pos = p3
			let (kind, p4) = readRdataRelocKind(buf, offset: pos)
			pos = p4
			func.rdataRelocs.push(RdataRelocation.create(codeOffset, rdataLabel: rdataLabel, kind: kind))
		end 'eachRdata'

		// IAT/GOT relocations
		let relocCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto relocCount 'eachReloc'
			let codeOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let slotIndex = readDword(buf, offset: pos)
			pos = pos + 4
			func.relocations.push(Relocation.create(codeOffset, slotIndex: slotIndex))
		end 'eachReloc'

		// ARM64 ADR fixups
		let adrCount = readDword(buf, offset: pos)
		pos = pos + 4

		for _ in 0 upto adrCount 'eachAdr'
			let instrOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let destReg = readDword(buf, offset: pos)
			pos = pos + 4
			let (targetName, p2b) = try readString(buf, offset: pos)
			pos = p2b
			func.adrFixups.push(CachedAdrFixup.create(instrOffset, destReg: destReg, targetName: targetName))
		end 'eachAdr'

		data.functions.push(func)
	end 'eachFunc'

	// WASM per-function objects
	let wasmFuncCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto wasmFuncCount 'eachWasmFunc'
		let (wName, wp1) = try readString(buf, offset: pos)
		pos = wp1
		let (wReturnType, wp2) = readStdReturnType(buf, offset: pos)
		pos = wp2
		let wParamCount = readDword(buf, offset: pos)
		pos = pos + 4
		let wParamTypeCount = readDword(buf, offset: pos)
		pos = pos + 4

		var wFunc = WasmObjectFunction.create(wName, returnType: wReturnType, paramCount: wParamCount, paramTypes: StdTypeArray.create())

		for _ in 0 upto wParamTypeCount 'eachParamType'
			let (pt, wp3) = readStdTypeTag(buf, offset: pos)
			pos = wp3
			wFunc.paramTypes.push(pt)
		end 'eachParamType'

		let (wThrowsClause, wpThrows) = try readThrowsClauseField(buf, offset: pos)
		pos = wpThrows
		wFunc.throwsTypeName = wThrowsClause

		// Body bytes
		let wBodyLen = readDword(buf, offset: pos)
		pos = pos + 4
		wFunc.body.reserve(wBodyLen)
		pos = copyBytesInto(wFunc.body, buf: buf, offset: pos, len: wBodyLen)

		// WASM call fixups
		let wFixupCount = readDword(buf, offset: pos)
		pos = pos + 4
		for _ in 0 upto wFixupCount 'eachFixup'
			let wOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (wTarget, wp4) = try readString(buf, offset: pos)
			pos = wp4
			wFunc.callFixups.push(WasmCallFixup.create(wOffset, targetName: wTarget))
		end 'eachFixup'

		// WASM type-section fixups (one per indirect-call site in the
		// cached body). Mirrors the writer; bodyOffset is the position of
		// the 5-byte fixed ULEB128 placeholder, signatureBytes is the
		// encoded function-type the user-build resolves against its own
		// type section.
		let wTyFixCount = readDword(buf, offset: pos)
		pos = pos + 4
		for _ in 0 upto wTyFixCount 'eachTyFix'
			let tyOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let sigLen = readDword(buf, offset: pos)
			pos = pos + 4
			var sigBytes = ByteArray.create()
			sigBytes.reserve(sigLen)
			pos = copyBytesInto(sigBytes, buf: buf, offset: pos, len: sigLen)
			wFunc.typeFixups.push(WasmTypeFixup.create(tyOffset, signatureBytes: sigBytes))
		end 'eachTyFix'

		// Cache v29: funcAddr fixups (targetName → final table index, patched
		// at user-build link time). Mirrors the writer's layout.
		let wAddrFixCount = readDword(buf, offset: pos)
		pos = pos + 4
		for _ in 0 upto wAddrFixCount 'eachAddrFix'
			let addrOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (addrTarget, ap1) = try readString(buf, offset: pos)
			pos = ap1
			wFunc.funcAddrFixups.push(WasmFuncAddrFixup.create(addrOffset, targetName: addrTarget))
		end 'eachAddrFix'

		// Cache v46: globalAddr linear-memory offset fixups.
		let wGAddrFixCount = readDword(buf, offset: pos)
		pos = pos + 4
		for _ in 0 upto wGAddrFixCount 'eachGAddrFix'
			let gOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (gTarget, gp1) = try readString(buf, offset: pos)
			pos = gp1
			wFunc.globalAddrFixups.push(WasmGlobalAddrFixup.create(gOffset, targetName: gTarget))
		end 'eachGAddrFix'

		data.wasmFunctions.push(wFunc)
	end 'eachWasmFunc'

	// GlobalData
	let globalCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto globalCount 'eachGlobal'
		let (name, p5) = try readString(buf, offset: pos)
		pos = p5
		let dataLen = readDword(buf, offset: pos)
		pos = pos + 4

		var bytes = ByteArray.create()
		bytes.reserve(dataLen)
		pos = copyBytesInto(bytes, buf: buf, offset: pos, len: dataLen)

		addNamedGlobalData(data.globalData, name: name, data: bytes)
	end 'eachGlobal'

	// Typealiases
	let aliasCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto aliasCount 'eachAlias'
		let (name, p6) = try readString(buf, offset: pos)
		pos = p6
		let (stdType, p7) = readStdTypeTag(buf, offset: pos)
		pos = p7
		try data.typealiases.insert(name, value: stdType) otherwise ignore
	end 'eachAlias'

	// Cache v17: typealias visibility sidecar.
	let aliasVisCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto aliasVisCount 'eachAliasVis'
		let (name, pVisName) = try readString(buf, offset: pos)
		pos = pVisName
		let entryCount = readDword(buf, offset: pos)
		pos = pos + 4
		var infos = TypealiasVisibilityInfoArray.create()
		for _ in 0 upto entryCount 'eachVisEntry'
			let (visibility, pVis) = try readVisibility(buf, offset: pos)
			pos = pVis
			let (pathStr, pVisPath) = try readString(buf, offset: pos)
			pos = pVisPath
			let path = try FilePath.from(pathStr) otherwise try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("readStdlibCache: stdlib-bootstrap.maxon FilePath.from rejected")
			infos.push(TypealiasVisibilityInfo.create(visibility, sourceFilePath: path))
		end 'eachVisEntry'
		try data.typealiasVisibilities.insert(name, value: infos) otherwise ignore
	end 'eachAliasVis'

	// Typealias ranges
	let rangeCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto rangeCount 'eachRange'
		let (name, p8) = try readString(buf, offset: pos)
		pos = p8
		let lower = readQword(buf, offset: pos)
		pos = pos + 8
		let upper = readQword(buf, offset: pos)
		pos = pos + 8
		try data.typealiasRanges.insert(name, value: TypealiasRange.create(lower, upper: upper)) otherwise ignore
	end 'eachRange'

	// Typealias cast categories
	let categoryCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto categoryCount 'eachCategory'
		let (name, pCatName) = try readString(buf, offset: pos)
		pos = pCatName
		let categoryTag = readDword(buf, offset: pos)
		pos = pos + 4
		let category = try CastCategory.allCases.get(categoryTag) otherwise panic("readStdlibCache: unknown CastCategory tag {categoryTag}")
		try data.typealiasCastCategories.insert(name, value: category) otherwise ignore
	end 'eachCategory'

	// Function return types
	let rtCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto rtCount 'eachRt'
		let (name, p9) = try readString(buf, offset: pos)
		pos = p9
		let (rt, p10) = try readMaxonReturnType(project, buf: buf, offset: pos)
		pos = p10
		try data.funcReturnTypes.insert(name, value: rt) otherwise ignore
	end 'eachRt'

	// Function signatures
	let sigCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto sigCount 'eachSig'
		let (sigName, pSig0) = try readString(buf, offset: pos)
		pos = pSig0
		let paramCount = readDword(buf, offset: pos)
		pos = pos + 4
		var paramNames = StringArray.create()
		for _ in 0 upto paramCount 'eachParamName'
			let (paramName, pSig1) = try readString(buf, offset: pos)
			pos = pSig1
			paramNames.push(paramName)
		end 'eachParamName'
		var paramTypes = MaxonTypeArray.create()
		for _ in 0 upto paramCount 'eachParamType'
			let (pt, pSig2) = try readMaxonType(project, buf: buf, offset: pos)
			pos = pSig2
			paramTypes.push(pt)
		end 'eachParamType'
		var paramDefaults = ParamDefaultArray.create()
		for _ in 0 upto paramCount 'eachParamDefault'
			let (pd, pSig3) = try readParamDefault(buf, offset: pos)
			pos = pSig3
			paramDefaults.push(pd)
		end 'eachParamDefault'
		try data.funcSignatures.insert(sigName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	end 'eachSig'

	// Cache v70 (Concept C): argument-consume bits, then the transparent-wrapper
	// name set. Read in the exact order written above.
	let consumeCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto consumeCount 'eachConsume'
		let (consumeName, pC0) = try readString(buf, offset: pos)
		pos = pC0
		let bitCount = readDword(buf, offset: pos)
		pos = pos + 4
		var bits = BoolArray.create()
		for _ in 0 upto bitCount 'eachConsumeBit'
			let (b, pC1) = readBoolByte(buf, offset: pos)
			pos = pC1
			bits.push(b)
		end 'eachConsumeBit'
		data.funcParamConsumes.upsert(consumeName, value: bits)
	end 'eachConsume'
	let wrapperCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto wrapperCount 'eachWrapper'
		let (wrapperName, pW0) = try readString(buf, offset: pos)
		pos = pW0
		data.funcReturnsConsumedArg.insert(wrapperName)
	end 'eachWrapper'

	// Cache v72: return-borrow function-name set (read in write order).
	let borrowCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto borrowCount 'eachBorrow'
		let (borrowName, pB0) = try readString(buf, offset: pos)
		pos = pB0
		data.funcReturnsBorrow.insert(borrowName)
	end 'eachBorrow'

	// Cache v77: receiver-interior return set (read in write order).
	let interiorCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto interiorCount 'eachInterior'
		let (interiorName, pI0) = try readString(buf, offset: pos)
		pos = pI0
		data.funcReturnsReceiverInterior.insert(interiorName)
	end 'eachInterior'

	// Cache v73: element-loader chain-boundary function-name set (read in write order).
	let loaderCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto loaderCount 'eachLoader'
		let (loaderName, pL0) = try readString(buf, offset: pos)
		pos = pL0
		data.funcIsElementLoader.insert(loaderName)
	end 'eachLoader'

	// Cache v47: function throws-clause entries. Mirrors the
	// funcReturnTypes loop above — string key + ThrowsClause value.
	let throwsCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto throwsCount 'eachThrows'
		let (throwsName, pTh0) = try readString(buf, offset: pos)
		pos = pTh0
		let (clause, pTh1) = try readThrowsClauseField(buf, offset: pos)
		pos = pTh1
		try data.funcThrowsTypes.insert(throwsName, value: clause) otherwise ignore
	end 'eachThrows'

	// Stdlib decls don't carry visibility / sourceFilePath in the cache
	// codec — every entry is implicitly `global` and originates at the
	// shared stdlib bootstrap path. Stamping these defaults here lets
	// user code reach stdlib symbols regardless of where the user's
	// reading file lives. Declared before the struct loop so the
	// `StructType.create` call below can stamp it in.
	let stdlibBootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("readStdlibCache: bootstrap path rejected")

	// Struct types
	let structCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto structCount 'eachStruct'
		let (name, p11) = try readString(buf, offset: pos)
		pos = p11
		let byteSize = readDword(buf, offset: pos)
		pos = pos + 4
		let fieldCount = readDword(buf, offset: pos)
		pos = pos + 4

		var fields = StructFieldArray.create()

		for _ in 0 upto fieldCount 'eachField'
			let (fieldName, p12) = try readString(buf, offset: pos)
			pos = p12
			let (fieldType, p13) = try readMaxonType(project, buf: buf, offset: pos)
			pos = p13
			let fieldOffset = readDword(buf, offset: pos)
			pos = pos + 4
			let (isMutable, pIm) = readBoolByte(buf, offset: pos)
			pos = pIm
			// Cache v32: read back the layout-pass sentinel. Cached struct
			// fields carry real offsets, so this is always `true` once the
			// producing run has executed `layoutAllStructs`.
			let (offsetResolved, pOr) = readBoolByte(buf, offset: pos)
			pos = pOr
			// Cache v35: read back the per-field `export` flag.
			let (isExported, pEx) = readBoolByte(buf, offset: pos)
			pos = pEx
			fields.push(StructField.create(fieldName, fieldType: fieldType, offset: fieldOffset, isMutable: isMutable, offsetResolved: offsetResolved, isExported: isExported))
		end 'eachField'

		// Cache v7: read back the per-struct inner-typealias map. The
		// resolved MaxonTypes were re-interned into the destination
		// project's registries by `readMaxonType` above, so the resulting
		// map is directly usable by `applyInnerAliasIfNamed` without any
		// translation step.
		let innerAliasCount = readDword(buf, offset: pos)
		pos = pos + 4
		var innerAliases = ResolvedInnerAliasMap.create()
		for _ in 0 upto innerAliasCount 'eachInnerAlias'
			let (aliasName, pIa1) = try readString(buf, offset: pos)
			pos = pIa1
			let (aliasType, pIa2) = try readMaxonType(project, buf: buf, offset: pos)
			pos = pIa2
			try innerAliases.insert(aliasName, value: aliasType) otherwise ignore
		end 'eachInnerAlias'

		let st = StructType.create(name, fields: fields, byteSize: byteSize, visibility: Visibility.global, sourceFilePath: stdlibBootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: innerAliases)
		try data.structTypes.insert(name, value: st) otherwise ignore
	end 'eachStruct'

	// Cache v47: enum types. Mirrors the writer above; visibility +
	// sourceFilePath stamp `global` + the stdlib bootstrap path the same
	// way structTypes does, and `expectedMethods` stays empty because the
	// cache-hit pipeline doesn't re-check enum conformance.
	let enumCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto enumCount 'eachEnum'
		let (enumName, pEn0) = try readString(buf, offset: pos)
		pos = pEn0
		let (isFloatBacked, pEn1) = readBoolByte(buf, offset: pos)
		pos = pEn1
		let (isStringBacked, pEn2) = readBoolByte(buf, offset: pos)
		pos = pEn2
		let (isCharBacked, pEn3) = readBoolByte(buf, offset: pos)
		pos = pEn3
		let (isUnion, pEn4) = readBoolByte(buf, offset: pos)
		pos = pEn4
		let caseCount = readDword(buf, offset: pos)
		pos = pos + 4
		var cases = EnumCaseArray.create()
		for _ in 0 upto caseCount 'eachCase'
			let (caseName, pCa0) = try readString(buf, offset: pos)
			pos = pCa0
			let ordinal = readDword(buf, offset: pos)
			pos = pos + 4
			let rawValue = readQword(buf, offset: pos)
			pos = pos + 8
			let (rawStringValue, pCa1) = try readOptionalStringDefaultEmpty(buf, offset: pos)
			pos = pCa1
			let (backingStructName, pCa2) = try readOptionalStringDefaultEmpty(buf, offset: pos)
			pos = pCa2
			let payloadCount = readDword(buf, offset: pos)
			pos = pos + 4
			var payloadFields = EnumPayloadFieldArray.create()
			for _ in 0 upto payloadCount 'eachPayload'
				let (pfName, pPf0) = try readString(buf, offset: pos)
				pos = pPf0
				let (pfType, pPf1) = try readMaxonType(project, buf: buf, offset: pos)
				pos = pPf1
				payloadFields.push(EnumPayloadField.create(pfName, fieldType: pfType))
			end 'eachPayload'
			cases.push(EnumCase.create(caseName, ordinal: ordinal as CaseOrdinal, rawValue: rawValue, line: 0, column: 0, payloadFields: payloadFields, backingStructName: backingStructName, backingStructExprId: 0, rawStringValue: rawStringValue))
		end 'eachCase'
		let et = EnumType.create(enumName, cases: cases, isFloatBacked: isFloatBacked, visibility: Visibility.global, sourceFilePath: stdlibBootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), isUnion: isUnion, isStringBacked: isStringBacked, isCharBacked: isCharBacked)
		try data.enumTypes.insert(enumName, value: et) otherwise ignore
	end 'eachEnum'

	// Top-level constants
	let constCount = readDword(buf, offset: pos)
	pos = pos + 4

	for _ in 0 upto constCount 'eachConst'
		let (name, p14) = try readString(buf, offset: pos)
		pos = p14
		let (cv, p15) = try readConstantValue(project, buf: buf, offset: pos)
		pos = p15
		let entry = TopLevelConstant.create(cv, visibility: Visibility.global, sourceFilePath: stdlibBootstrapPath)
		try data.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'eachConst'

	// BuiltinArrayLiteral / BuiltinDictionaryLiteral discovery.
	let (builtinArrayLiteralName, pBal) = try readBuiltinArrayLiteralNameField(buf, offset: pos)
	pos = pBal
	data.builtinArrayLiteralTypeName = builtinArrayLiteralName
	let (builtinDictionaryLiteralName, pBdl) = try readBuiltinDictionaryLiteralNameField(buf, offset: pos)
	pos = pBdl
	data.builtinDictionaryLiteralTypeName = builtinDictionaryLiteralName
	let (builtinCharLiteralName, pBcl) = try readBuiltinCharLiteralNameField(buf, offset: pos)
	pos = pBcl
	data.builtinCharLiteralTypeName = builtinCharLiteralName
	let (builtinStringLiteralName, pBsl) = try readBuiltinStringLiteralNameField(buf, offset: pos)
	pos = pBsl
	data.builtinStringLiteralTypeName = builtinStringLiteralName

	// Cache v8: read Phase 11 conformance + registry state in the same order
	// the writer emitted it. The MaxonType helpers (`readMaxonType` etc.)
	// re-intern named/typeParameter/genericInstance/interface arms through
	// the destination project's registries during the walk, so by the time
	// we reach here every captured registry is in the destination project's
	// id space — no post-translation step needed for these fields.
	let (typeParamReg, pTpr) = try readTypeParamRegistry(buf, offset: pos)
	pos = pTpr
	data.typeParameters = typeParamReg
	let (ifaceReg, pIfr) = try readInterfaceTypeRegistry(buf, offset: pos)
	pos = pIfr
	data.interfaceRegistry = ifaceReg
	let (gInstReg, pGir) = try readGenericInstanceRegistry(project, buf: buf, offset: pos, writerGidMap: data.writerGidToProjectGid)
	pos = pGir
	data.genericInstances = gInstReg
	let (ifaceMap, pIm) = try readInterfaceMap(project, buf: buf, offset: pos)
	pos = pIm
	data.interfaces = ifaceMap
	let (confReg, pCr) = try readConformanceRegistry(project, buf: buf, offset: pos)
	pos = pCr
	data.conformances = confReg
	let (gtm, pGtm) = try readGenericTypealiasMap(project, buf: buf, offset: pos)
	pos = pGtm
	data.genericTypealiases = gtm
	let (ldr, pLdr) = try readLayoutDescriptorRegistry(buf, offset: pos)
	pos = pLdr
	data.layoutDescriptors = ldr
	let (wtr, pWtr) = try readWitnessTableRegistry(buf, offset: pos)
	pos = pWtr
	data.witnessTables = wtr
	let (lr, pLr) = try readStringArray(buf, offset: pos)
	pos = pLr
	data.livenessRoots = lr
	// v55: moduleInitFuncs + initToStoredVars + topLevelVars
	let (mif, pMif) = try readStringArray(buf, offset: pos)
	pos = pMif
	data.moduleInitFuncs = mif
	let (itsv, pItsv) = try readInitToStoredVarsMap(buf, offset: pos)
	pos = pItsv
	data.initToStoredVars = itsv
	let (tlv, pTlv) = try readTopLevelVarMap(project, buf: buf, offset: pos)
	pos = pTlv
	data.topLevelVars = tlv
	let (gfia, pGfia) = try readGenericFunctionImplicitArityMap(buf, offset: pos)
	pos = pGfia
	data.genericFunctionImplicitArity = gfia
	let (srv, pSrv) = try readStaticRdataValueMap(buf, offset: pos)
	pos = pSrv
	data.staticRdataValues = srv
	// Cache v50 (J.4c): read the persisted stdlib-side extension metadata
	// before the StdModule blob — mirrors the encode order above.
	let (ue, pUe) = try readUnresolvedExtensionArray(buf, offset: pos)
	pos = pUe
	data.unresolvedExtensions = ue
	let (emwc, pEmwc) = try readWhereClauseMapByName(buf, offset: pos)
	pos = pEmwc
	data.extensionMethodWhereClauses = emwc
	// Cache v68: read the precomputed Std-DFE edge table before the
	// StdModule blob — mirrors the encode order above.
	let (sfe, pSfe) = try readStdFuncEdgeMap(buf, offset: pos)
	pos = pSfe
	data.stdFuncEdges = sfe
	// Cache v10: read the stdlib's post-dce StdModule for the user
	// pipeline's inliner pass.
	let (inlinerMod, pIm2) = try readStdModule(buf, offset: pos)
	pos = pIm2
	data.inlinerStdModule = inlinerMod

	// Populate data.typeNameTable from the destination project's interner so
	// `restoreStdlibMetadata`'s translation step is a no-op identity. The
	// disk format encodes named types as strings (writeMaxonType emits
	// `(tag, name)`), and `readMaxonType` reinterns each name into the
	// destination project — so by the time we get here, every named type id
	// in `data.*` already points into `project.typeNames`. Mirroring those
	// names into `data.typeNameTable` makes restore see `table[id] == name`,
	// so the named-id translation round-trips through `intern(name)` and
	// returns the same id. Without this, `data.typeNameTable` is empty and
	// `restoreStdlibMetadata` panics on the first cached named return type
	// (e.g. `Math.exp returns Real`).
	for name in project.typeNames.names 'mirrorTable'
		data.typeNameTable.push(name)
	end 'mirrorTable'

	// Cache v19 + v44: identity-mirror trick for the generic-instance,
	// type-parameter, and interface registries. `readMaxonType` interns
	// nested generic instances directly into `project.genericInstances`
	// (not `data.genericInstances`), so any cached `genericInstance(id)`
	// payload in a MaxonType is already a project-space id. Mirror
	// project.* into data.* here so `translateCapturedGenericInstance` can
	// look up the project-id payload in `data.genericInstances` and get
	// an identity round-trip. Raw writer-side gids in
	// `layoutDescriptors`/`witnessTables` do *not* use this path — they go
	// through `translateWriterGenericInstanceId` against the
	// `writerGidToProjectGid` table built during the registry read, since
	// writer-id ordering generally diverges from reader-project-id ordering
	// once recursive arg interning reorders project assignments.
	data.genericInstances = GenericInstanceRegistry.create()
	for i in 0 upto project.genericInstances.count() 'mirrorGenericInstances'
		let (baseId, args) = project.genericInstances.get(i)
		_ = data.genericInstances.intern(baseId, args: args)
	end 'mirrorGenericInstances'

	// The mirror above re-keyed `data.genericInstances` into the reading
	// project's id space, discarding the writer's ordering. The read-time
	// writer→project map is the only record of that ordering — and since the
	// mirror is an identity copy (the project registry is intern-built, so
	// it has no structural duplicates), a project gid IS the data gid.
	// Persist it as writer→data so `restoreRegistries` can rebuild
	// writer→project maps for this and any later project in the process.
	data.writerGidToDataGid.clear()
	for projectGid in data.writerGidToProjectGid 'recordWriterToData'
		data.writerGidToDataGid.push(projectGid)
	end 'recordWriterToData'
	// Rebuild `data.typeParameters` in `project.typeParameters`'s id space
	// (so cached MaxonType.typeParameter(id) payloads round-trip identity)
	// while preserving the constraints originally read from disk. The disk
	// blob is the only source of those constraints — `project.typeParameters`
	// at this point holds bootstrap + readMaxonType-interned entries with no
	// constraints attached, so a naive mirror from `project.typeParameters`
	// would drop every `where T is Hashable` clause. Snapshotting the cached
	// registry as a flat `(declName, paramName) -> constraints` view first
	// and consulting it during the id-space rebuild preserves the payload
	// at the new ids.
	var cachedConstraints = CachedConstraintMap.create()
	let cachedTypeParams = data.typeParameters
	for ci in 0 upto cachedTypeParams.count() 'snapshotCached'
		let cDecl = cachedTypeParams.getDeclaringTypeName(ci)
		let cParam = cachedTypeParams.getName(ci)
		let cs = cachedTypeParams.getConstraints(ci)
		if cs.count() == 0 'noneToSnapshot'
			continue
		end 'noneToSnapshot'
		var copy = StringArray.create()
		for c in cs 'eachTrait'
			copy.push(c)
		end 'eachTrait'
		try cachedConstraints.insert("{cDecl}::{cParam}", value: copy) otherwise ignore
	end 'snapshotCached'
	let savedParamLists = cachedTypeParams.declaringTypeParamLists
	data.typeParameters = TypeParamRegistry.create()
	for i in 0 upto project.typeParameters.count() 'mirrorTypeParams'
		let declName = project.typeParameters.getDeclaringTypeName(i)
		let paramName = project.typeParameters.getName(i)
		let destId = data.typeParameters.intern(declName, paramName: paramName)
		if let cs = try cachedConstraints.get("{declName}::{paramName}") 'haveCached'
			for c in cs 'eachConstraint'
				data.typeParameters.addConstraint(destId, traitName: c)
			end 'eachConstraint'
		end 'haveCached'
	end 'mirrorTypeParams'
	// The cached registry may carry (declName, paramName) entries that
	// `project.typeParameters` hasn't yet seen — typically constrained
	// generic types whose declarations only become live once user code
	// references them. Intern those into `data.typeParameters` too so the
	// constraint payload survives the cache round-trip; `restoreRegistries`
	// will then thread them onto `project.typeParameters` when user code
	// triggers the lookup.
	for i in 0 upto cachedTypeParams.count() 'carryCachedExtras'
		let declName = cachedTypeParams.getDeclaringTypeName(i)
		let paramName = cachedTypeParams.getName(i)
		if data.typeParameters.contains(declName, paramName: paramName) 'alreadyMirrored'
			continue
		end 'alreadyMirrored'
		let destId = data.typeParameters.intern(declName, paramName: paramName)
		let cs = cachedTypeParams.getConstraints(i)
		for c in cs 'eachConstraint'
			data.typeParameters.addConstraint(destId, traitName: c)
		end 'eachConstraint'
	end 'carryCachedExtras'
	for (declName, paramNames) in savedParamLists 'restoreParamLists'
		var copy = StringArray.create()
		for n in paramNames 'eachName'
			copy.push(n)
		end 'eachName'
		data.typeParameters.recordParamOrder(declName, paramOrder: copy)
	end 'restoreParamLists'
	data.interfaceRegistry = InterfaceTypeRegistry.create()
	for i in 0 upto project.interfaceRegistry.count() 'mirrorInterfaces'
		_ = data.interfaceRegistry.intern(project.interfaceRegistry.getName(i))
	end 'mirrorInterfaces'

	// Cache v49: identity-mirror the function-type registry. `readMaxonType`
	// interns each cached `function(id)` payload directly into
	// `project.functionTypes`, so we mirror project.* into data.* here.
	// `translateCapturedFunctionType` then walks data.functionTypes,
	// translates the params/return through the identity-mirrored named /
	// generic / interface tables, and re-interns to recover the same
	// project-space id.
	data.functionTypes = FunctionTypeRegistry.create()
	for i in 0 upto project.functionTypes.count() 'mirrorFunctionTypes'
		let (params, returnType) = project.functionTypes.get(i)
		_ = data.functionTypes.append(params, returnType: returnType)
	end 'mirrorFunctionTypes'

	return StdlibCacheResult.create(data, valid: true)
end 'decodeStdlibCache'

// ============================================================
// Linker: reachability analysis (shared across all targets)
// ============================================================

// Compute which stdlib functions are needed given a set of seed function names.
// Performs transitive closure over call dependencies and adr fixup dependencies.
// Returns the set of needed function names.
// Resolve a (possibly bare) call/seed name to the actual stdlib-cache key.
// The cache is keyed by the function's emitted name: runtime.std functions are
// bare (`__mm_alloc` callers like `mrt_alloc`), while Internals.maxon functions
// are `stdlib.`-qualified (`stdlib.__mm_alloc`). A bare call from runtime.std
// targeting an Internals function therefore won't exact-match the qualified
// cache key, so probe the `stdlib.`-qualified form too. Returns the empty
// string when neither form is a cache function.
function resolveStdlibCacheKey(name String, funcNameToIndex StdlibFuncIndexMap) returns String
	if funcNameToIndex.contains(name) 'exact'
		return name
	end 'exact'
	let qualified = "stdlib.{name}"
	if funcNameToIndex.contains(qualified) 'qualifiedHit'
		return qualified
	end 'qualifiedHit'
	return ""
end 'resolveStdlibCacheKey'

export function computeNeededStdlibFunctions(seeds StringArray, stdlibCache StdlibCacheData) returns StdlibFuncNameSet
	var funcNameToIndex = StdlibFuncIndexMap.create()

	for (iter, func) in stdlibCache.functions.withIterator() 'buildIndex'
		funcNameToIndex.upsert(func.name, value: iter.index())
	end 'buildIndex'

	var needed = StdlibFuncNameSet.create()
	var worklist = StringArray.create()

	// Seed from caller-provided names, resolving each to its cache key so a bare
	// runtime.std call to a `stdlib.`-qualified Internals function still seeds.
	for name in seeds 'seed'
		let key = resolveStdlibCacheKey(name, funcNameToIndex: funcNameToIndex)
		if not key.isEmpty() and not needed.contains(key) 'isStdlib'
			needed.insert(key)
			worklist.push(key)
		end 'isStdlib'
	end 'seed'

	// Transitive closure
	var wi = 0

	while wi < worklist.count() 'walkDeps'
		let nameRef = try worklist.get(wi) otherwise 'skipWalk'
			wi = wi + 1
			continue
		end 'skipWalk'
		let name = "{nameRef}"
		wi = wi + 1

		let funcIdx = try funcNameToIndex.get(name) otherwise continue

		let func = try stdlibCache.functions.get(funcIdx) otherwise continue

		var newDeps = StringArray.create()

		for fixup in func.callFixups 'eachDep'
			let depKey = resolveStdlibCacheKey(fixup.targetName, funcNameToIndex: funcNameToIndex)
			if not depKey.isEmpty() and not needed.contains(depKey) 'newDep'
				needed.insert(depKey)
				newDeps.push(depKey)
			end 'newDep'
		end 'eachDep'

		for fixup in func.adrFixups 'eachAdrDep'
			let adrKey = resolveStdlibCacheKey(fixup.targetName, funcNameToIndex: funcNameToIndex)
			if not adrKey.isEmpty() and not needed.contains(adrKey) 'newAdrDep'
				needed.insert(adrKey)
				newDeps.push(adrKey)
			end 'newAdrDep'
		end 'eachAdrDep'

		for dep in newDeps 'addDeps'
			worklist.push(dep)
		end 'addDeps'
	end 'walkDeps'

	return needed
end 'computeNeededStdlibFunctions'

// Merge global data entries referenced by the linked stdlib functions.
export function mergeStdlibGlobalData(globalData GlobalDataTable, rdataRelocs RdataRelocationArray, stdlibCache StdlibCacheData)
	var neededGlobals = StdlibFuncNameSet.create()

	for fixup in rdataRelocs 'findGlobals'
		neededGlobals.insert(fixup.rdataLabel)
	end 'findGlobals'

	for i in 0 upto stdlibCache.globalData.names.count() 'mergeGlobals'
		let name = try stdlibCache.globalData.names.get(i) otherwise continue

		if not neededGlobals.contains(name) 'notNeeded'
			continue
		end 'notNeeded'

		let existing = lookupGlobalData(globalData, name: name)
		if existing.count() == 0 'notPresent'
			let data = try stdlibCache.globalData.values.get(i) otherwise continue
			addNamedGlobalData(globalData, name: name, data: data)
		end 'notPresent'
	end 'mergeGlobals'
end 'mergeStdlibGlobalData'

// ============================================================
// Restore stdlib metadata into a project for user parsing
// ============================================================

// Translate a captured MaxonType into the destination project's id space.
// Every `named(id)` is reinterned through the destination project's typeNames
// using `data.typeNameTable`. Generic-aware arms (`typeParameter`,
// `genericInstance`, `interface`) recurse through the captured registries
// (`data.typeParameters`, `data.genericInstances`, `data.interfaceRegistry`)
// to look up the source-id's logical key (declName/paramName for
// type parameters, baseName + arg list for generic instances, name for
// interfaces) and re-intern that key into the destination project. This is
// required because the in-memory `cachedStdlibCacheData` snapshot is
// populated by `captureStdlibMetadata` (which copies source-project ids
// directly), and the disk-cache read path uses the same `data.*` registries
// keyed by the warmup project's id space — neither matches the per-test
// destination project's id space.
function translateMaxonType(project Project, data StdlibCacheData, t MaxonType) returns MaxonType
	return match t 'translate'
		boolean gives MaxonType.boolean
		integer gives MaxonType.integer
		float gives MaxonType.float
		string gives MaxonType.string
		character gives MaxonType.character
		unresolved gives MaxonType.unresolved
		named(id) gives translateNamedTypeId(project, table: data.typeNameTable, id: id)
		function(id) gives translateCapturedFunctionType(project, data: data, id: id)
		typeParameter(id) gives translateCapturedTypeParameter(project, data: data, id: id)
		genericInstance(id) gives translateCapturedGenericInstance(project, data: data, id: id)
		interface(id) gives translateCapturedInterface(project, data: data, id: id)
		// `constInt` arms carry a literal payload, not a registry id —
		// no captured-data lookup needed, pass the literal through.
		constInt gives t
		// `opaquePointer` is payload-less; pass it through unchanged.
		opaquePointer to cstring gives t
	end 'translate'
end 'translateMaxonType'

// Cache v49: translate a captured `function(id)` arm into the destination
// project's id space. Walks the captured signature from `data.functionTypes`,
// translates each param + return type through `translateMaxonType` /
// `translateMaxonReturnType` (which recurse into nested generic/function
// arms), then re-interns the resulting (params, returnType) via
// `internFunctionType` in the destination project. The returned id may
// differ from the captured one but the structural signature is preserved.
function translateCapturedFunctionType(project Project, data StdlibCacheData, id FunctionTypeId) returns MaxonType
	let (sourceParams, sourceReturn) = data.functionTypes.get(id)
	let translatedParams = translateCapturedTypeArray(project, data: data, src: sourceParams)
	let translatedReturn = translateMaxonReturnType(project, data: data, rt: sourceReturn)
	let newId = internFunctionType(project, paramTypes: translatedParams, returnType: translatedReturn)
	return MaxonType.function(newId)
end 'translateCapturedFunctionType'

function translateNamedTypeId(project Project, table StringArray, id TypeNameId) returns MaxonType
	let name = try table.get(id) otherwise panic("translateNamedTypeId: captured id {id} out of range (table count={table.count()}) — captureStdlibMetadata snapshot is missing entries")
	return MaxonType.named(project.typeNames.intern(name))
end 'translateNamedTypeId'

// Translate a captured `typeParameter(id)`. The captured registry stores the
// `(declaringTypeName, paramName)` pair at `id`; re-intern that pair into the
// destination project so the result references the destination-project id
// for the same logical type parameter.
function translateCapturedTypeParameter(project Project, data StdlibCacheData, id TypeParamId) returns MaxonType
	let declName = data.typeParameters.getDeclaringTypeName(id)
	let paramName = data.typeParameters.getName(id)
	let destId = project.typeParameters.intern(declName, paramName: paramName)
	return MaxonType.typeParameter(destId)
end 'translateCapturedTypeParameter'

// Translate a captured `genericInstance(id)`. Wraps the shared
// `translateCapturedGenericInstanceId` helper in `MaxonType.genericInstance`.
function translateCapturedGenericInstance(project Project, data StdlibCacheData, id GenericInstanceId) returns MaxonType
	return MaxonType.genericInstance(translateCapturedGenericInstanceId(project, data: data, id: id))
end 'translateCapturedGenericInstance'

// Translate a captured `interface(id)`. The captured registry is just a
// name-keyed parallel array; re-intern the name into the destination
// project's `interfaceRegistry`.
function translateCapturedInterface(project Project, data StdlibCacheData, id InterfaceTypeId) returns MaxonType
	let name = data.interfaceRegistry.getName(id)
	let destId = project.interfaceRegistry.intern(name)
	return MaxonType.interface(destId)
end 'translateCapturedInterface'

// Translate a captured GenericInstanceId to a destination GenericInstanceId.
// The captured registry stores `(baseId, args)` where `baseId` indexes into
// the captured typeNameTable and each arg is itself a captured MaxonType.
// Re-intern the base name into the destination project's typeNames,
// recursively translate each arg, then intern the resulting
// `(destBaseId, destArgs)` pair into the destination project's
// `genericInstances` registry. Shared by `translateCapturedGenericInstance`
// (which wraps the result in MaxonType) and `LayoutDescriptorRegistry`
// translation (which needs the bare GenericInstanceId).
function translateCapturedGenericInstanceId(project Project, data StdlibCacheData, id GenericInstanceId) returns GenericInstanceId
	let (sourceBaseId, sourceArgs) = data.genericInstances.get(id)
	let baseName = try data.typeNameTable.get(sourceBaseId) otherwise panic("translateCapturedGenericInstanceId: typeNameTable.get OOB for baseId={sourceBaseId} (table count={data.typeNameTable.count()})")
	let destBaseId = project.typeNames.intern(baseName)
	let destArgs = translateCapturedTypeArray(project, data: data, src: sourceArgs)
	return project.genericInstances.intern(destBaseId, args: destArgs)
end 'translateCapturedGenericInstanceId'

// Translate a writer-side `GenericInstanceId` (the raw qword payload of
// `layoutDescriptors`/`witnessTables`) to the destination project's id
// space by consulting the `writerGidToProjectGid` table built during
// `readGenericInstanceRegistry`. Distinct from
// `translateCapturedGenericInstanceId` (which works in
// data.genericInstances' id space — post-mirror == project space) because
// the writer's id space generally diverges from the reader's after
// recursive arg interning reorders project assignments.
function translateWriterGenericInstanceId(data StdlibCacheData, writerGid GenericInstanceId) returns GenericInstanceId
	return try data.writerGidToProjectGid.get(writerGid) otherwise panic("translateWriterGenericInstanceId: writerGid={writerGid} OOB (table count={data.writerGidToProjectGid.count()}) — writer wrote a gid the read pass never saw")
end 'translateWriterGenericInstanceId'

// Translate every captured MaxonType in `src` through `translateMaxonType`
// into a fresh MaxonTypeArray in the destination project's id space.
function translateCapturedTypeArray(project Project, data StdlibCacheData, src MaxonTypeArray) returns MaxonTypeArray
	var dst = MaxonTypeArray.create()
	for t in src 'eachT'
		dst.push(translateMaxonType(project, data: data, t: t))
	end 'eachT'
	return dst
end 'translateCapturedTypeArray'

// Translate a captured MaxonReturnType: void passes through; value(inner)
// gets its inner MaxonType reinterned via translateMaxonType.
function translateMaxonReturnType(project Project, data StdlibCacheData, rt MaxonReturnType) returns MaxonReturnType
	return match rt 'translate'
		void gives MaxonReturnType.void
		value(inner) gives MaxonReturnType.value(translateMaxonType(project, data: data, t: inner))
	end 'translate'
end 'translateMaxonReturnType'

// Translate a captured InterfaceMethodSig: paramTypes and returnType carry
// captured MaxonTypes. Other fields (name / paramNames / throwsTypeName /
// line / column) are name- or position-keyed and pass through unchanged.
function translateInterfaceMethodSig(project Project, data StdlibCacheData, sig InterfaceMethodSig) returns InterfaceMethodSig
	let destParamTypes = translateCapturedTypeArray(project, data: data, src: sig.paramTypes)
	let destReturn = translateMaxonReturnType(project, data: data, rt: sig.returnType)
	var translated = InterfaceMethodSig.create(sig.name, paramNames: sig.paramNames, paramTypes: destParamTypes, returnType: destReturn, throwsTypeName: sig.throwsTypeName, isStatic: sig.isStatic, line: sig.line, column: sig.column)
	translated.sourceInterfaceName = sig.sourceInterfaceName
	translated.directInterfaceName = sig.directInterfaceName
	return translated
end 'translateInterfaceMethodSig'

// Translate a captured IrInterface: each method sig's paramTypes / returnType
// MaxonTypes are reinterned through the destination project. innerAliases
// values are translated for the same reason as `translateStructType` — they
// embed `named` / `genericInstance` ids that index the producing run's
// typeNames table. Other fields (name / extendsNames / usesParams /
// visibility / filePath / line / column) pass through unchanged because
// they're name- or position-keyed.
function translateIrInterface(project Project, data StdlibCacheData, iface IrInterface) returns IrInterface
	var destMethods = InterfaceMethodSigArray.create()
	for m in iface.methods 'eachM'
		destMethods.push(translateInterfaceMethodSig(project, data: data, sig: m))
	end 'eachM'
	var translatedInner = ResolvedInnerAliasMap.create()
	for (aliasName, aliasType) in iface.innerAliases 'eachInner'
		try translatedInner.insert(aliasName, value: translateMaxonType(project, data: data, t: aliasType)) otherwise ignore
	end 'eachInner'
	return IrInterface.create(iface.name, extendsNames: iface.extendsNames, usesParams: iface.usesParams, methods: destMethods, visibility: iface.visibility, line: iface.line, column: iface.column, filePath: iface.filePath, innerAliases: translatedInner)
end 'translateIrInterface'

// Translate a captured StructType: every field's MaxonType has its captured
// ids reinterned in the destination project. innerAliases values are also
// translated — without this, a struct's `Array.innerAliases["ArrayIter"]`
// would retain a captured `genericInstance` whose base id pointed into the
// source typeNames at a slot whose value differed in the destination.
function translateStructType(project Project, data StdlibCacheData, st StructType) returns StructType
	var fields = StructFieldArray.create()
	for f in st.fields 'eachField'
		fields.push(StructField.create(f.name, fieldType: translateMaxonType(project, data: data, t: f.fieldType), offset: f.offset, isMutable: f.isMutable, offsetResolved: f.offsetResolved, isExported: f.isExported))
	end 'eachField'
	var translatedInner = ResolvedInnerAliasMap.create()
	for (aliasName, aliasType) in st.innerAliases 'eachInner'
		try translatedInner.insert(aliasName, value: translateMaxonType(project, data: data, t: aliasType)) otherwise ignore
	end 'eachInner'
	var translatedExpected = InterfaceMethodSigArray.create()
	for sig in st.expectedMethods 'eachExpected'
		translatedExpected.push(translateInterfaceMethodSig(project, data: data, sig: sig))
	end 'eachExpected'
	return StructType.create(st.name, fields: fields, byteSize: st.byteSize, visibility: st.visibility, sourceFilePath: st.sourceFilePath, nameLine: st.nameLine, nameColumn: st.nameColumn, expectedMethods: translatedExpected, innerAliases: translatedInner)
end 'translateStructType'

// Translate a captured EnumType into the destination project's id space —
// the enum-side counterpart of `translateStructType`. The in-memory
// `captureStdlibMetadata` path copies each `EnumType` verbatim, so every
// MaxonType it carries (each union case's payload-field types and the enum's
// substituted `expectedMethods` signatures) still indexes the *source*
// project's registries. Re-intern each through the captured `typeNameTable`
// so a restored union references the destination project's `typeNames`. For
// the disk path this is the same identity round-trip `translateStructType`
// performs — the typeNameTable is mirrored from the destination interner, so
// `intern(name)` returns the same id. Without this, a `match` on a cached
// union (e.g. `TerminationStatus`) reads each payload field's type through a
// stale id that lands on an unrelated type — classifying a scalar `ExitInt`
// payload as a managed `Configuration` struct and emitting a bogus
// `__mm_incref` on the scalar that faults at runtime.
function translateEnumType(project Project, data StdlibCacheData, et EnumType) returns EnumType
	var cases = EnumCaseArray.create()
	for c in et.cases 'eachCase'
		var payloadFields = EnumPayloadFieldArray.create()
		for pf in c.payloadFields 'eachPayload'
			payloadFields.push(EnumPayloadField.create(pf.name, fieldType: translateMaxonType(project, data: data, t: pf.fieldType)))
		end 'eachPayload'
		cases.push(EnumCase.create(c.name, ordinal: c.ordinal, rawValue: c.rawValue, line: c.line, column: c.column, payloadFields: payloadFields, backingStructName: c.backingStructName, backingStructExprId: c.backingStructExprId, rawStringValue: c.rawStringValue, rawFunctionName: c.rawFunctionName))
	end 'eachCase'

	var expectedMethods = InterfaceMethodSigArray.create()
	for m in et.expectedMethods 'eachMethod'
		expectedMethods.push(translateInterfaceMethodSig(project, data: data, sig: m))
	end 'eachMethod'

	// Function-backed enums share one FunctionTypeId across every case. It
	// indexes the source project's `functionTypes`; re-intern the captured
	// signature so the restored enum points at the destination id. Non
	// function-backed enums keep the sentinel `0` (the disk path never sets
	// either field, so this only fires on the in-memory capture path).
	var functionBackingTypeId = et.functionBackingTypeId
	if et.isFunctionBacked and functionBackingTypeId != 0 'remapFnBacking'
		functionBackingTypeId = match translateCapturedFunctionType(project, data: data, id: et.functionBackingTypeId) 'extractId'
			function(id) gives id
			default panic("translateEnumType: translateCapturedFunctionType returned a non-function type for enum '{et.name}'")
		end 'extractId'
	end 'remapFnBacking'

	return EnumType.create(et.name, cases: cases, isFloatBacked: et.isFloatBacked, visibility: et.visibility, sourceFilePath: et.sourceFilePath, nameLine: et.nameLine, nameColumn: et.nameColumn, expectedMethods: expectedMethods, isUnion: et.isUnion, isStringBacked: et.isStringBacked, isCharBacked: et.isCharBacked, isFunctionBacked: et.isFunctionBacked, functionBackingTypeId: functionBackingTypeId)
end 'translateEnumType'

// Capture parser metadata from a project into a StdlibCacheData.
export function captureStdlibMetadata(project Project, data StdlibCacheData)
	// Snapshot the type-name interner so restoreStdlibMetadata can translate
	// captured ids back to names — every MaxonType.named id in the captured
	// metadata indexes into this table.
	for name in project.typeNames.names 'snapshotTypeNames'
		data.typeNameTable.push(name)
	end 'snapshotTypeNames'

	for (name, baseType) in project.typealiases 'copyAliases'
		try data.typealiases.insert(name, value: baseType) otherwise ignore
	end 'copyAliases'

	// Cache v17: snapshot the typealias visibility sidecar. Each name maps
	// to an array of (visibility, sourceFilePath) entries; deep-copy each
	// array so subsequent mutations to project.typealiasVisibilities don't
	// alias into data.
	for (name, infos) in project.typealiasVisibilities 'copyAliasVis'
		var copied = TypealiasVisibilityInfoArray.create()
		for info in infos 'eachInfo'
			copied.push(info)
		end 'eachInfo'
		try data.typealiasVisibilities.insert(name, value: copied) otherwise ignore
	end 'copyAliasVis'

	for (name, range) in project.typealiasRanges 'copyRanges'
		try data.typealiasRanges.insert(name, value: range) otherwise ignore
	end 'copyRanges'

	for (name, category) in project.typealiasCastCategories 'copyCategories'
		try data.typealiasCastCategories.insert(name, value: category) otherwise ignore
	end 'copyCategories'

	for (name, rt) in project.funcReturnTypes 'copyRts'
		try data.funcReturnTypes.insert(name, value: rt) otherwise ignore
	end 'copyRts'

	for (name, sig) in project.funcSignatures 'copySigs'
		try data.funcSignatures.insert(name, value: sig) otherwise ignore
	end 'copySigs'

	// Cache v70 (Concept C): snapshot the stdlib argument-consume facts so a cached
	// user build reads the structural per-parameter consume bits (the inserter's
	// name-free consume signal). Copy each BoolArray by value so the cache owns it.
	for (name, bits) in project.funcParamConsumes 'copyConsumes'
		var bitsCopy = BoolArray.create()
		for b in bits 'eachBit'
			bitsCopy.push(b)
		end 'eachBit'
		data.funcParamConsumes.upsert(name, value: bitsCopy)
	end 'copyConsumes'
	for wrapperName in project.funcReturnsConsumedArg 'copyWrappers'
		data.funcReturnsConsumedArg.insert(wrapperName)
	end 'copyWrappers'

	// Cache v72: snapshot the stdlib's structural return-borrow facts so the user
	// build restores them (notably the element-loader intrinsics, classified from
	// their bodies here) instead of a name allowlist.
	for borrowName in project.funcReturnsBorrow 'copyBorrows'
		data.funcReturnsBorrow.insert(borrowName)
	end 'copyBorrows'

	// Cache v77: snapshot the receiver-interior return facts for the same reason.
	for interiorName in project.funcReturnsReceiverInterior 'copyInteriors'
		data.funcReturnsReceiverInterior.insert(interiorName)
	end 'copyInteriors'

	// Cache v73: snapshot the element-loader chain-boundary facts (functions that call
	// the `__managed_mem_load_sized` primitive) for the same reason — the loader bodies
	// are absent on the user build.
	for loaderName in project.funcIsElementLoader 'copyLoaders'
		data.funcIsElementLoader.insert(loaderName)
	end 'copyLoaders'

	// Cache v47: snapshot per-callee throws-clause so a cached-stdlib run
	// of `try map.insert(...) otherwise (e) ... match e ...` recovers the
	// MapError-typed binding instead of falling back to `integer`.
	for (name, throwsClause) in project.funcThrowsTypes 'copyThrows'
		try data.funcThrowsTypes.insert(name, value: throwsClause) otherwise ignore
	end 'copyThrows'

	for (name, st) in project.structTypes 'copyStructs'
		try data.structTypes.insert(name, value: st) otherwise ignore
	end 'copyStructs'

	// Cache v47: enumTypes so cache-hit user code can dispatch on stdlib
	// enum cases (MapError, ArrayError, ...). Without this round-trip the
	// `match` scrutinee check in TR rejects every stdlib-throws binding.
	for (name, et) in project.enumTypes 'copyEnums'
		try data.enumTypes.insert(name, value: et) otherwise ignore
	end 'copyEnums'

	for (name, entry) in project.topLevelConstants 'copyConsts'
		try data.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'copyConsts'

	// BuiltinArrayLiteral / BuiltinDictionaryLiteral discovery — sourced from
	// the parser's statics via the loader-side accessors. Populated during the
	// cache-miss parse, then carried here so cache-hit runs in the same process
	// (and the on-disk cache write below) see the discovered names without
	// re-parsing stdlib. The loader-side helpers still return Strings (they
	// manage an in-memory cache, separate from the on-disk encoding); we adapt
	// at the boundary into the sum-typed fields.
	let raw = getCachedBuiltinArrayLiteralTypeName()
	if raw.isEmpty() 'noLit'
		data.builtinArrayLiteralTypeName = BuiltinArrayLiteralName.none
	end 'noLit' else 'haveLit'
		data.builtinArrayLiteralTypeName = BuiltinArrayLiteralName.found(raw)
	end 'haveLit'
	let rawDict = getCachedBuiltinDictionaryLiteralTypeName()
	if rawDict.isEmpty() 'noDictLit'
		data.builtinDictionaryLiteralTypeName = BuiltinDictionaryLiteralName.none
	end 'noDictLit' else 'haveDictLit'
		data.builtinDictionaryLiteralTypeName = BuiltinDictionaryLiteralName.found(rawDict)
	end 'haveDictLit'
	let rawChar = getCachedBuiltinCharLiteralTypeName()
	if rawChar.isEmpty() 'noCharLit'
		data.builtinCharLiteralTypeName = BuiltinCharLiteralName.none
	end 'noCharLit' else 'haveCharLit'
		data.builtinCharLiteralTypeName = BuiltinCharLiteralName.found(rawChar)
	end 'haveCharLit'
	let rawStr = getCachedBuiltinStringLiteralTypeName()
	if rawStr.isEmpty() 'noStrLit'
		data.builtinStringLiteralTypeName = BuiltinStringLiteralName.none
	end 'noStrLit' else 'haveStrLit'
		data.builtinStringLiteralTypeName = BuiltinStringLiteralName.found(rawStr)
	end 'haveStrLit'

	// Cache v8: snapshot Phase 11 conformance + registry state. These
	// registries are populated during the cache-build pipeline's
	// `resolveTypes` (interfaces / conformances / typeParameters /
	// genericInstances / interfaceRegistry / genericTypealiases) and
	// `buildLayoutDescriptors` / `buildWitnessTables` passes (layoutDescriptors
	// / witnessTables / livenessRoots / staticRdataValues). Without
	// persisting them here, cache-hit user builds run with empty
	// conformance state — primitive `extension int implements Comparable`
	// and friends never reach `project.conformances`.
	captureRegistries(project, data: data)
end 'captureStdlibMetadata'

// Phase 11.4 (cache v8): copy each registry from the cache-build project
// into the cache buffer. Using the project's API (intern / insert / etc.)
// rather than struct copy preserves the parallel-array invariants — every
// registry uses linear-scan dedup, so a value-copy snapshot is identical
// to a fresh registry built by replaying the same intern calls.
function captureRegistries(project Project, data StdlibCacheData)
	for i in 0 upto project.typeParameters.count() 'eachTp'
		let declName = project.typeParameters.getDeclaringTypeName(i)
		let paramName = project.typeParameters.getName(i)
		_ = data.typeParameters.intern(declName, paramName: paramName)
		// Constraints (where-clause traits) are persisted because the
		// Constraints / where-clause path consults them at user-code call
		// sites. Stdlib's parser fills these during interface processing,
		// so a cache hit must reproduce them exactly.
		let cs = project.typeParameters.getConstraints(i)
		for c in cs 'eachConstraint'
			data.typeParameters.addConstraint(i, traitName: c)
		end 'eachConstraint'
	end 'eachTp'
	// Carry the source-declaration-ordered param-name lists across the
	// cache boundary. Mirrors the structure of the typeParameters
	// registry but indexed by declaring-type name so getParamNames hits
	// it before falling back to registry-id-order scanning.
	for (declName, paramNames) in project.typeParameters.declaringTypeParamLists 'eachList'
		var copy = StringArray.create()
		for n in paramNames 'eachName'
			copy.push(n)
		end 'eachName'
		data.typeParameters.recordParamOrder(declName, paramOrder: copy)
	end 'eachList'

	for i in 0 upto project.interfaceRegistry.count() 'eachIface'
		_ = data.interfaceRegistry.intern(project.interfaceRegistry.getName(i))
	end 'eachIface'

	// Cache v49: capture each function-type signature so `translateMaxonType`
	// can resolve a captured `function(id)` arm by reading the params + return
	// type and re-interning them in the destination project. Captured params
	// keep the cache-build project's id space — they are translated lazily
	// during `translateMaxonType` recursion before re-interning.
	for i in 0 upto project.functionTypes.count() 'eachFt'
		let (params, returnType) = project.functionTypes.get(i)
		_ = data.functionTypes.append(params, returnType: returnType)
	end 'eachFt'

	// Record writer→data gid alongside the mirror. The raw gids embedded in
	// `layoutDescriptors`/`witnessTables` below are writer-project ids, so
	// each writer entry's data-space id must be captured for the restore-time
	// writer→project rebuild (`restoreRegistries`).
	data.writerGidToDataGid.clear()
	for i in 0 upto project.genericInstances.count() 'eachGi'
		let (baseId, args) = project.genericInstances.get(i)
		data.writerGidToDataGid.push(data.genericInstances.intern(baseId, args: args))
	end 'eachGi'

	for (name, iface) in project.interfaces 'eachInterface'
		try data.interfaces.insert(name, value: iface) otherwise ignore
	end 'eachInterface'

	for i in 0 upto project.conformances.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = project.conformances.get(i)
		_ = data.conformances.intern(typeName, interfaceName: ifaceName, withArgs: withArgs)
	end 'eachConf'

	for (name, t) in project.genericTypealiases 'eachGta'
		try data.genericTypealiases.insert(name, value: t) otherwise ignore
	end 'eachGta'

	for i in 0 upto project.layoutDescriptors.count() 'eachLd'
		let gid = try project.layoutDescriptors.instanceIds.get(i) otherwise panic("captureRegistries: layoutDescriptors.instanceIds.get OOB at {i}")
		let label = try project.layoutDescriptors.labels.get(i) otherwise panic("captureRegistries: layoutDescriptors.labels desync at {i}")
		data.layoutDescriptors.intern(gid, label: label)
	end 'eachLd'

	for i in 0 upto project.witnessTables.count() 'eachWt'
		let e = project.witnessTables.get(i)
		data.witnessTables.intern(e.typeName, interfaceName: e.interfaceName, label: e.label, methodImplNames: e.methodImplNames, parentWitnessLabel: e.parentWitnessLabel, isFatBoxed: e.isFatBoxed)
	end 'eachWt'
	for i in 0 upto project.witnessTables.gidCount() 'eachGidWt'
		let g = project.witnessTables.getGid(i)
		data.witnessTables.internForGid(g.gid, interfaceName: g.interfaceName, label: g.label, methodImplNames: g.methodImplNames, isFatBoxed: g.isFatBoxed)
	end 'eachGidWt'

	for r in project.livenessRoots 'eachRoot'
		data.livenessRoots.push(r)
	end 'eachRoot'

	// v55: stdlib's __module_init_<n> registry + per-init write-set +
	// top-level var map so cache-on user builds match cache-off behavior
	// for dead-init pruning AND for `.data` section layout.
	for n in project.moduleInitFuncs 'eachInit'
		data.moduleInitFuncs.push(n)
	end 'eachInit'
	for (initName, vars) in project.initToStoredVars 'eachInitVars'
		var copiedVars = StoredVarNameSet.create()
		for v in vars 'eachVar'
			copiedVars.insert(v)
		end 'eachVar'
		try data.initToStoredVars.insert(initName, value: copiedVars) otherwise ignore
	end 'eachInitVars'
	for (varName, info) in project.topLevelVars 'eachTopVar'
		try data.topLevelVars.insert(varName, value: info) otherwise ignore
	end 'eachTopVar'

	for (name, arity) in project.genericFunctionImplicitArity 'eachArity'
		try data.genericFunctionImplicitArity.insert(name, value: arity) otherwise ignore
	end 'eachArity'

	for (label, bytes) in project.staticRdataValues 'eachRdata'
		try data.staticRdataValues.insert(label, value: bytes) otherwise ignore
	end 'eachRdata'

	// Cache v50 (J.4c): snapshot stdlib-side extension metadata. The
	// `UnresolvedExtension` value-shape interns no project-local ids — its
	// fields are bare strings, the conformance/where-clause sub-arrays
	// likewise carry bare names — so a direct push preserves identity
	// across the cache boundary without a translation step.
	for ext in project.unresolvedExtensions 'eachExt'
		data.unresolvedExtensions.push(ext)
	end 'eachExt'

	for (methodKey, clauses) in project.extensionMethodWhereClauses 'eachExtWhere'
		try data.extensionMethodWhereClauses.insert(methodKey, value: clauses) otherwise ignore
	end 'eachExtWhere'
end 'captureRegistries'

export function restoreStdlibMetadata(project Project, data StdlibCacheData)
	// Restore typealiases
	for (name, baseType) in data.typealiases 'restoreAliases'
		try project.typealiases.insert(name, value: baseType) otherwise ignore
	end 'restoreAliases'

	// Cache v17: restore typealias visibility sidecar so the parser's
	// shadowing check sees correct (visibility, sourceFilePath) for every
	// stdlib alias. Each name's array carries one entry per declaring file.
	for (name, infos) in data.typealiasVisibilities 'restoreAliasVis'
		for info in infos 'eachInfo'
			appendTypealiasVisibility(project, name: name, info: info)
		end 'eachInfo'
	end 'restoreAliasVis'

	// Restore typealias ranges
	for (name, range) in data.typealiasRanges 'restoreRanges'
		try project.typealiasRanges.insert(name, value: range) otherwise ignore
	end 'restoreRanges'

	// Restore typealias cast categories so ranged-primitive aliases keep
	// their user-declared category (`int`/`byte`/`float`) across a cache
	// round-trip.
	for (name, category) in data.typealiasCastCategories 'restoreCategories'
		try project.typealiasCastCategories.insert(name, value: category) otherwise ignore
	end 'restoreCategories'

	// Restore function return types and seed the method-name index in
	// lockstep so DFE's methodCall handling sees stdlib methods alongside
	// user-defined ones without a separate post-pass. MaxonType.named ids
	// embedded in the cached return types belong to the source project's
	// interner, so translate each through the captured typeNameTable into a
	// fresh id in the destination project before storing.
	for (name, rt) in data.funcReturnTypes 'restoreRts'
		let translated = translateMaxonReturnType(project, data: data, rt: rt)
		try project.funcReturnTypes.insert(name, value: translated) otherwise ignore
		project.methodNameIndex.record(name)
	end 'restoreRts'

	// Function signatures carry MaxonTypes embedded in paramTypes — same
	// captured-id concern as funcReturnTypes, so each signature is rebuilt
	// with the destination project's id space.
	for (name, sig) in data.funcSignatures 'restoreSigs'
		let translatedTypes = translateCapturedTypeArray(project, data: data, src: sig.paramTypes)
		try project.funcSignatures.insert(name, value: FuncSignature.create(sig.paramNames, paramTypes: translatedTypes, paramDefaults: sig.paramDefaults)) otherwise ignore
	end 'restoreSigs'

	// Cache v70 (Concept C): replay the stdlib argument-consume facts. No
	// captured-id translation — names are strings and the payload is a BoolArray of
	// per-parameter consume bits. The user-pipeline `analyzeParamConsumes` forwards
	// from these for user functions; the inserter reads them for non-inlined
	// consuming stdlib callees.
	for (name, bits) in data.funcParamConsumes 'restoreConsumes'
		var bitsCopy = BoolArray.create()
		for b in bits 'eachBit'
			bitsCopy.push(b)
		end 'eachBit'
		project.funcParamConsumes.upsert(name, value: bitsCopy)
	end 'restoreConsumes'
	for wrapperName in data.funcReturnsConsumedArg 'restoreWrappers'
		project.funcReturnsConsumedArg.insert(wrapperName)
	end 'restoreWrappers'
	// Cache v72: replay the stdlib's structural return-borrow facts into the user
	// project so `analyzeReturnBorrows` / the inserter see a stdlib callee's
	// borrow-returning status without re-analyzing its (absent) body.
	for borrowName in data.funcReturnsBorrow 'restoreBorrows'
		project.funcReturnsBorrow.insert(borrowName)
	end 'restoreBorrows'

	// Cache v77: replay the receiver-interior return facts so the liveness
	// nav-borrow edge extends receivers past opaque interior-returning callees
	// (`List.walkTo`) on the user build.
	for interiorName in data.funcReturnsReceiverInterior 'restoreInteriors'
		project.funcReturnsReceiverInterior.insert(interiorName)
	end 'restoreInteriors'

	// Cache v73: replay the element-loader chain-boundary facts so the wrapper-retain
	// boundary (`calleeIsBorrowFunction`) excludes a stdlib loader without its body.
	for loaderName in data.funcIsElementLoader 'restoreLoaders'
		project.funcIsElementLoader.insert(loaderName)
	end 'restoreLoaders'

	// Cache v47: replay per-callee throws-clause so `funcThrowsTypes.get`
	// at parse time of user code returns the stdlib method's declared
	// error type. The clause is a plain `ThrowsClause.throwing(name)` /
	// `ThrowsClause.none` — no captured-id translation required since the
	// payload is a String (the throws type is looked up by name later).
	for (name, throwsClause) in data.funcThrowsTypes 'restoreThrows'
		try project.funcThrowsTypes.insert(name, value: throwsClause) otherwise ignore
	end 'restoreThrows'

	// Phase 2 closure rename: the per-closure back-pointer and capture-count
	// maps are gone. Enclosing name now derives from the closure's own
	// embedded prefix via `enclosingFuncOfClosure`; capture count lives on
	// the IrFunction itself and is restored as part of `readStdIrFunction`.
	// The project-wide `closureCounter` is also gone — per-function
	// `closureSubCounter` on `IrFunction` mints unique closure names
	// directly from source structure.

	// Rebuild `overloadedNames` from the restored signature names.
	// The overload bucket is populated by the parser when a second `function
	// foo` registers under the same qualified name — rekeyExistingFunction
	// re-mangles both entries to `foo$<suffix>` and pushes them onto
	// `project.overloadedNames[foo]`. The cache persists the post-mangle
	// signature names but not the bucket itself, so without this rebuild a
	// user-code call site looks up `Array.contains` and finds no variants
	// — overload resolution returns the bare name, the linker can't find
	// a body, and codegen produces a value-less call that trips the
	// register allocator.
	rebuildOverloadedNames(project)

	// Restore struct types. Field MaxonTypes carry the same captured-id
	// problem as funcReturnTypes — translate every named id through the
	// typeNameTable before insertion.
	//
	// Rebuild the `structInnerAliasNames` reverse index alongside each restored
	// struct: the parser maintains it on a from-source build (one entry per
	// member typealias declared in a type body), but a cached build never parses
	// the stdlib, so the index would otherwise stay empty for stdlib member
	// aliases. `structNameIsHeapManaged`'s member-alias resolution (which
	// classifies a value typed by a bare member alias like `Map.Entry` =
	// `(Key, Value)` heap-managed) gates on this index — without the rebuild a
	// cached build misclassifies such a value `notManaged`, and the lifted-closure
	// param of `m.map(function(p) gives p)` loses its return-incref, diverging from
	// the from-source build (the stdlib-map-on-map-with-function cache-only crash).
	for (name, st) in data.structTypes 'restoreStructs'
		let translated = translateStructType(project, data: data, st: st)
		for (aliasName, _) in translated.innerAliases 'eachInnerAlias'
			project.structInnerAliasNames.insert(aliasName)
		end 'eachInnerAlias'
		try project.structTypes.insert(name, value: translated) otherwise ignore
	end 'restoreStructs'

	// Cache v47: restore enum types so `match` on cached stdlib enums
	// (MapError, ArrayError, ...) dispatches by case name. Payload-field
	// and expectedMethod MaxonTypes carry the same captured-id problem as
	// struct fields — the in-memory `captureStdlibMetadata` path copies each
	// `EnumType` verbatim with the source project's ids. Translate every
	// named id through the typeNameTable before insertion (a no-op identity
	// on the disk path, where readMaxonType already reinterned the names).
	for (name, et) in data.enumTypes 'restoreEnums'
		let translatedEnum = translateEnumType(project, data: data, et: et)
		try project.enumTypes.insert(name, value: translatedEnum) otherwise ignore
	end 'restoreEnums'

	// Restore top-level constants
	for (name, entry) in data.topLevelConstants 'restoreConsts'
		try project.topLevelConstants.insert(name, value: entry) otherwise ignore
	end 'restoreConsts'

	// Republish BuiltinArrayLiteral / BuiltinDictionaryLiteral discovery so the
	// parser-side cache is live for the user-code parse that follows. The
	// `none` arm means stdlib didn't declare an implementing type; the parser
	// will emit a diagnostic on the first literal of that kind in that case.
	// The loader-side cache is still a String, so we only call the setter on
	// the `found` arm — the loader's static defaults to "" (its own absent
	// marker).
	match data.builtinArrayLiteralTypeName 'restoreArr'
		none then break 'restoreArr'
		found(n) then setCachedBuiltinArrayLiteralTypeName(n)
	end 'restoreArr'
	match data.builtinDictionaryLiteralTypeName 'restoreDict'
		none then break 'restoreDict'
		found(n) then setCachedBuiltinDictionaryLiteralTypeName(n)
	end 'restoreDict'
	match data.builtinCharLiteralTypeName 'restoreChar'
		none then break 'restoreChar'
		found(n) then setCachedBuiltinCharLiteralTypeName(n)
	end 'restoreChar'
	match data.builtinStringLiteralTypeName 'restoreStr'
		none then break 'restoreStr'
		found(n) then setCachedBuiltinStringLiteralTypeName(n)
	end 'restoreStr'

	// Cache v8: replay Phase 11 conformance + registry state. The on-disk
	// codec re-interns named/typeParameter/genericInstance/interface arms
	// through the destination project as it reads, so the captured
	// registries already carry destination-id-space MaxonTypes; copying
	// them onto `project` is a direct merge.
	restoreRegistries(project, data: data)
end 'restoreStdlibMetadata'

// Walk every signature name now in `project.funcSignatures` and rebuild
// `project.overloadedNames` by grouping mangled names under their bare
// qualified prefix. A signature named `Array.contains$Element` lands on
// `overloadedNames["Array.contains"]` alongside `Array.contains$ElementArray`.
// Names without a `$` are not overloaded and are skipped.
function rebuildOverloadedNames(project Project)
	for (name, _) in project.funcSignatures 'eachSig'
		let bare = try stripFirstDollarPrefix(name) otherwise continue
		var bucket = try project.overloadedNames.get(bare) otherwise QualifiedNameArray.create()
		var alreadyPresent = false
		for entry in bucket 'scanDup'
			if entry == name 'dup'
				alreadyPresent = true
				break
			end 'dup'
		end 'scanDup'
		if alreadyPresent 'skipDup'
			continue
		end 'skipDup'
		bucket.push(name)
		project.overloadedNames.upsert(bare, value: bucket)
	end 'eachSig'
end 'rebuildOverloadedNames'

function stripFirstDollarPrefix(s String) returns String throws NameSplitError
	let bytes = s.toByteArray()
	let dollarByte = 0x24
	var i = 0
	while i < bytes.count() 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i < bytes.count() but get failed at {i}")
		if b == dollarByte 'hit'
			let head = try bytes.slice(0, endIndex: i) otherwise panic("invariant: 0 <= i < bytes.count() but slice failed")
			return String.from(head)
		end 'hit'
		i = i + 1
	end 'scan'
	throw NameSplitError.noSeparator
end 'stripFirstDollarPrefix'

// Phase 11.4 (cache v8): merge each captured registry into the destination
// project. Order matches the writer (typeParameters → interfaceRegistry →
// genericInstances → interfaces → conformances → genericTypealiases →
// layoutDescriptors → witnessTables → livenessRoots → staticRdataValues).
// Each merge is idempotent so a second restore (e.g. multiple compilation
// units in one process) is a no-op.
function restoreRegistries(project Project, data StdlibCacheData)
	// typeParameters and interfaceRegistry are name-keyed — re-interning by
	// `(declaringTypeName, paramName)` / `name` reproduces the source ordering
	// in the destination project's id space iff the destination is empty when
	// we start. (Stdlib bootstrap pre-parsed declarations may have allocated
	// some entries; intern still returns the right id for those.)
	for i in 0 upto data.typeParameters.count() 'eachTp'
		let declName = data.typeParameters.getDeclaringTypeName(i)
		let paramName = data.typeParameters.getName(i)
		let destId = project.typeParameters.intern(declName, paramName: paramName)
		let cs = data.typeParameters.getConstraints(i)
		for c in cs 'eachConstraint'
			project.typeParameters.addConstraint(destId, traitName: c)
		end 'eachConstraint'
	end 'eachTp'
	// Copy the source-declaration-ordered param-name lists into the
	// destination registry. Without this, the destination's id space
	// could end up in a different order than the original parse, and
	// getParamNames would return the wrong pairing.
	for (declName, paramNames) in data.typeParameters.declaringTypeParamLists 'eachList'
		var copy = StringArray.create()
		for n in paramNames 'eachName'
			copy.push(n)
		end 'eachName'
		project.typeParameters.recordParamOrder(declName, paramOrder: copy)
	end 'eachList'

	for i in 0 upto data.interfaceRegistry.count() 'eachIface'
		_ = project.interfaceRegistry.intern(data.interfaceRegistry.getName(i))
	end 'eachIface'

	// genericInstances entries reference captured `(baseId, args)` where
	// `baseId` is a captured typeNameTable index and each arg is a captured
	// MaxonType. Re-intern each through the destination project's registries
	// (via the shared helper) so subsequent lookups return ids whose payload
	// is meaningful in the destination id space.
	//
	// The `writerGidToProjectGid` table is rebuilt fresh on every restore so
	// the layoutDescriptors / witnessTables loops below can translate
	// writer-side gids (a writer-project index for the in-memory cache, a
	// disk-encoded index for the on-disk cache) into the CURRENT destination
	// project's gid space. The disk-read path populates the map inline in
	// `readGenericInstanceRegistry`, but that's tied to a single project; a
	// second compile reusing the cached data needs a fresh map keyed on the
	// new project's `project.genericInstances`. Without this rebuild the
	// in-memory cache path (activateStdlibCache after warmup) would see an
	// empty map and panic in `translateWriterGenericInstanceId`.
	//
	// Route each writer gid through `writerGidToDataGid` — on the disk path
	// `data.genericInstances` is a mirror of the FIRST reading project's
	// registry, whose ordering diverges from the writer's once recursive arg
	// interning reorders id assignments, so indexing it positionally by
	// writer gid translates the WRONG entry (`__layout_Array_String` landed
	// on `Array with Element` while `Array with String` got the
	// `__layout_Array_SlotState` label, killing its element walk).
	//
	// Mutate the existing array in-place (clear then refill) so this works
	// when `data` is passed as a value parameter — `.push` mutates through
	// the array reference without requiring the enclosing struct to be a
	// `var` binding at every call site.
	data.writerGidToProjectGid.clear()
	for dataGid in data.writerGidToDataGid 'eachGi'
		let destGid = translateCapturedGenericInstanceId(project, data: data, id: dataGid)
		data.writerGidToProjectGid.push(destGid)
	end 'eachGi'

	// IrInterface entries store method signatures whose paramTypes / returnType
	// carry captured ids. Rebuild each method sig with translated MaxonTypes.
	for (name, iface) in data.interfaces 'eachInterface'
		try project.interfaces.insert(name, value: translateIrInterface(project, data: data, iface: iface)) otherwise ignore
	end 'eachInterface'

	// Conformance withArgs are MaxonTypeArrays — translate each entry's args
	// before interning so the destination registry's args reference
	// destination-project ids.
	for i in 0 upto data.conformances.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = data.conformances.get(i)
		let destWithArgs = translateCapturedTypeArray(project, data: data, src: withArgs)
		_ = project.conformances.intern(typeName, interfaceName: ifaceName, withArgs: destWithArgs)
	end 'eachConf'

	// genericTypealiases values are MaxonTypes (the resolved alias target).
	// Translate each before insertion.
	for (name, t) in data.genericTypealiases 'eachGta'
		try project.genericTypealiases.insert(name, value: translateMaxonType(project, data: data, t: t)) otherwise ignore
	end 'eachGta'

	// layoutDescriptors are keyed by GenericInstanceId. The serialized `gid`
	// is a *writer-side* project id (raw qword payload), not a translated
	// `data.genericInstances` index — so route it through
	// `translateWriterGenericInstanceId` which consults the writer→project
	// table built during `readGenericInstanceRegistry`.
	for i in 0 upto data.layoutDescriptors.count() 'eachLd'
		let sourceGid = try data.layoutDescriptors.instanceIds.get(i) otherwise panic("restoreRegistries: layoutDescriptors.instanceIds.get OOB at {i}")
		let label = try data.layoutDescriptors.labels.get(i) otherwise panic("restoreRegistries: layoutDescriptors.labels desync at {i}")
		let destGid = translateWriterGenericInstanceId(data, writerGid: sourceGid)
		project.layoutDescriptors.intern(destGid, label: label)
	end 'eachLd'

	for i in 0 upto data.witnessTables.count() 'eachWt'
		let e = data.witnessTables.get(i)
		project.witnessTables.intern(e.typeName, interfaceName: e.interfaceName, label: e.label, methodImplNames: e.methodImplNames, parentWitnessLabel: e.parentWitnessLabel, isFatBoxed: e.isFatBoxed)
	end 'eachWt'
	// Per-instance gid-keyed entries. Same writer-id translation as
	// layoutDescriptors above so the user pipeline's witness loader can
	// resolve labels for stdlib-emitted instances (e.g. `Array<Byte>`).
	for i in 0 upto data.witnessTables.gidCount() 'eachGidWt'
		let g = data.witnessTables.getGid(i)
		let destGid = translateWriterGenericInstanceId(data, writerGid: g.gid)
		project.witnessTables.internForGid(destGid, interfaceName: g.interfaceName, label: g.label, methodImplNames: g.methodImplNames, isFatBoxed: g.isFatBoxed)
	end 'eachGidWt'

	for r in data.livenessRoots 'eachRoot'
		project.livenessRoots.push(r)
	end 'eachRoot'

	// v55: restore stdlib's __module_init_<n> registry + per-init
	// write-set + top-level var map so the user pipeline's lowering and
	// dead-init prune see the same state as a cache-off build.
	for n in data.moduleInitFuncs 'eachInit'
		project.moduleInitFuncs.push(n)
	end 'eachInit'
	for (initName, vars) in data.initToStoredVars 'eachInitVars'
		var copiedVars = StoredVarNameSet.create()
		for v in vars 'eachVar'
			copiedVars.insert(v)
		end 'eachVar'
		try project.initToStoredVars.insert(initName, value: copiedVars) otherwise ignore
	end 'eachInitVars'
	for (varName, info) in data.topLevelVars 'eachTopVar'
		try project.topLevelVars.insert(varName, value: info) otherwise ignore
	end 'eachTopVar'

	// Phase 11.4: replay the generic-function implicit-arity map so the
	// per-function lowering can decide synthetic-arg-append at every call
	// site, not just for callees in the local stdModule.
	for (name, arity) in data.genericFunctionImplicitArity 'eachArity'
		try project.genericFunctionImplicitArity.insert(name, value: arity) otherwise ignore
	end 'eachArity'

	for (label, bytes) in data.staticRdataValues 'eachRdata'
		try project.staticRdataValues.insert(label, value: bytes) otherwise ignore
	end 'eachRdata'

	// Cache v50 (J.4c): replay stdlib-side extension metadata so the
	// conditional-conformance check + E4006 diagnostic see the same
	// `project.unresolvedExtensions` / `extensionMethodWhereClauses` a
	// from-source build would have populated.
	for ext in data.unresolvedExtensions 'eachExt'
		project.unresolvedExtensions.push(ext)
	end 'eachExt'

	for (methodKey, clauses) in data.extensionMethodWhereClauses 'eachExtWhere'
		try project.extensionMethodWhereClauses.insert(methodKey, value: clauses) otherwise ignore
	end 'eachExtWhere'
end 'restoreRegistries'

// ============================================================
// Cache v8 codec helpers — Phase 11 registry round-trip.
// ============================================================
//
// Each codec mirrors the parallel-array shape of the registry it serializes.
// MaxonType / MaxonReturnType use the existing `writeMaxonType` /
// `readMaxonType` helpers in MaxonDialect.maxon — those re-intern through
// the destination project's registries during read, so callers don't need
// a separate `translateMaxonType` step on these fields.

// --- Visibility ---

function writeVisibility(buf ByteArray, v Visibility)
	writeDword(buf, value: v.rawValue)
end 'writeVisibility'

function readVisibility(buf ByteArray, offset ByteOffset) returns (Visibility, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let v = try Visibility.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return (v, offset + 4)
end 'readVisibility'

// --- OwnershipClass (refcount-insertion per-value class) ---

function writeOwnershipClass(buf ByteArray, c OwnershipClass)
	writeDword(buf, value: c.rawValue)
end 'writeOwnershipClass'

function readOwnershipClass(buf ByteArray, offset ByteOffset) returns (OwnershipClass, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let c = try OwnershipClass.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return (c, offset + 4)
end 'readOwnershipClass'

// --- FilePath ---

function writeFilePath(buf ByteArray, p FilePath) throws CacheCorruption
	try writeString(buf, s: p.toString())
end 'writeFilePath'

function readFilePath(buf ByteArray, offset ByteOffset) returns (FilePath, ByteOffset) throws CacheCorruption
	let (s, p) = try readString(buf, offset: offset)
	let path = try FilePath.from(s) otherwise FilePath from ""
	return (path, p)
end 'readFilePath'

// Optional-string codec where the `absent` tag restores to "". Used for
// fields that synthesized functions leave empty (`namespace`,
// `sourceFilePath`) — the mandatory codec would throw
// `CacheCorruption.invalidEncoding` on the empty payload.
function writeOptionalStringDefaultEmpty(buf ByteArray, value String) throws CacheCorruption
	try writeOptionalString(buf, present: not value.isEmpty(), value: value)
end 'writeOptionalStringDefaultEmpty'

function readOptionalStringDefaultEmpty(buf ByteArray, offset ByteOffset) returns (String, ByteOffset) throws CacheCorruption
	let result = try readOptionalString(buf, offset: offset) otherwise (e) 'pickArm'
		match e 'kind'
			absent then return ("", offset + 1)
			invalidEncoding then throw CacheCorruption.invalidEncoding
		end 'kind'
	end 'pickArm'
	return result
end 'readOptionalStringDefaultEmpty'

// FilePath wrapper around the empty-default optional-string codec.
function writeOptionalFilePath(buf ByteArray, p FilePath) throws CacheCorruption
	try writeOptionalStringDefaultEmpty(buf, value: p.toString())
end 'writeOptionalFilePath'

function readOptionalFilePath(buf ByteArray, offset ByteOffset) returns (FilePath, ByteOffset) throws CacheCorruption
	let (s, nextPos) = try readOptionalStringDefaultEmpty(buf, offset: offset)
	let path = try FilePath.from(s) otherwise FilePath from ""
	return (path, nextPos)
end 'readOptionalFilePath'

// --- StringArray ---

function writeStringArray(buf ByteArray, arr StringArray) throws CacheCorruption
	writeDword(buf, value: arr.count())
	for s in arr 'eachString'
		try writeString(buf, s: s)
	end 'eachString'
end 'writeStringArray'

function readStringArray(buf ByteArray, offset ByteOffset) returns (StringArray, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = StringArray.create()
	for _ in 0 upto count 'eachString'
		let (s, p) = try readString(buf, offset: pos)
		pos = p
		arr.push(s)
	end 'eachString'
	return (arr, pos)
end 'readStringArray'

// --- WhereClauseArray ---
//
// Each entry is `(paramName, requiredTraitName, declaringTypeName)`. Used by
// `IrFunction.implicitWitnessConstraints` to record one implicit `__witness_*`
// trailing param per where-clause entry, in declaration order.

function writeWhereClauseArray(buf ByteArray, arr WhereClauseArray) throws CacheCorruption
	writeDword(buf, value: arr.count())
	for wc in arr 'eachClause'
		try writeString(buf, s: wc.paramName)
		try writeString(buf, s: wc.requiredTraitName)
		try writeString(buf, s: wc.declaringTypeName)
	end 'eachClause'
end 'writeWhereClauseArray'

function readWhereClauseArray(buf ByteArray, offset ByteOffset) returns (WhereClauseArray, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = WhereClauseArray.create()
	for _ in 0 upto count 'eachClause'
		let (paramName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (requiredTraitName, p2) = try readString(buf, offset: pos)
		pos = p2
		let (declaringTypeName, p3) = try readString(buf, offset: pos)
		pos = p3
		arr.push(WhereClause.createScoped(paramName, requiredTraitName: requiredTraitName, declaringTypeName: declaringTypeName))
	end 'eachClause'
	return (arr, pos)
end 'readWhereClauseArray'

function writeMaxonTypeArray(project Project, buf ByteArray, arr MaxonTypeArray) throws CacheCorruption
	writeDword(buf, value: arr.count())
	for t in arr 'eachType'
		try writeMaxonType(project, buf: buf, t: t)
	end 'eachType'
end 'writeMaxonTypeArray'

function readMaxonTypeArray(project Project, buf ByteArray, offset ByteOffset) returns (MaxonTypeArray, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = MaxonTypeArray.create()
	for _ in 0 upto count 'eachType'
		let (t, p) = try readMaxonType(project, buf: buf, offset: pos)
		pos = p
		arr.push(t)
	end 'eachType'
	return (arr, pos)
end 'readMaxonTypeArray'

// --- TypeParamRegistry ---

function writeTypeParamRegistry(buf ByteArray, registry TypeParamRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachEntry'
		try writeString(buf, s: registry.getDeclaringTypeName(i))
		try writeString(buf, s: registry.getName(i))
		let cs = registry.getConstraints(i)
		try writeStringArray(buf, arr: cs)
	end 'eachEntry'
	// Cache v28: persist the source-declaration-ordered param-name list
	// per declaring type. Required because the (declaringTypeName,
	// paramName) pairs above are recorded in intern-call order, which
	// isn't always source order once cache-restore / re-resolution paths
	// touch the registry. See `getParamNames` for the read side.
	writeDword(buf, value: registry.declaringTypeParamLists.count())
	for (declName, paramNames) in registry.declaringTypeParamLists 'eachList'
		try writeString(buf, s: declName)
		try writeStringArray(buf, arr: paramNames)
	end 'eachList'
end 'writeTypeParamRegistry'

function readTypeParamRegistry(buf ByteArray, offset ByteOffset) returns (TypeParamRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = TypeParamRegistry.create()
	for _ in 0 upto count 'eachEntry'
		let (declName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (paramName, p2) = try readString(buf, offset: pos)
		pos = p2
		let id = registry.intern(declName, paramName: paramName)
		let (constraints, p3) = try readStringArray(buf, offset: pos)
		pos = p3
		for c in constraints 'eachConstraint'
			registry.addConstraint(id, traitName: c)
		end 'eachConstraint'
	end 'eachEntry'
	// Cache v28: read the per-type ordered param-name lists.
	let listCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto listCount 'eachList'
		let (declName, p4) = try readString(buf, offset: pos)
		pos = p4
		let (paramNames, p5) = try readStringArray(buf, offset: pos)
		pos = p5
		registry.recordParamOrder(declName, paramOrder: paramNames)
	end 'eachList'
	return (registry, pos)
end 'readTypeParamRegistry'

// --- InterfaceTypeRegistry ---

function writeInterfaceTypeRegistry(buf ByteArray, registry InterfaceTypeRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachName'
		try writeString(buf, s: registry.getName(i))
	end 'eachName'
end 'writeInterfaceTypeRegistry'

function readInterfaceTypeRegistry(buf ByteArray, offset ByteOffset) returns (InterfaceTypeRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = InterfaceTypeRegistry.create()
	for _ in 0 upto count 'eachName'
		let (name, p) = try readString(buf, offset: pos)
		pos = p
		_ = registry.intern(name)
	end 'eachName'
	return (registry, pos)
end 'readInterfaceTypeRegistry'

// --- GenericInstanceRegistry ---

function writeGenericInstanceRegistry(project Project, buf ByteArray, registry GenericInstanceRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachInst'
		let (baseId, args) = registry.get(i)
		// Persist the base name (not the local id) so the reader re-interns
		// through the destination project's `typeNames` and gets a meaningful
		// id in its own id space.
		try writeString(buf, s: project.typeNames.get(baseId))
		try writeMaxonTypeArray(project, buf: buf, arr: args)
	end 'eachInst'
end 'writeGenericInstanceRegistry'

// Read the on-disk generic-instance registry. Each writer-side entry is
// interned into the fresh `data.genericInstances` (so the i-th entry
// keeps writer-id i — needed by raw qword gid translation for
// `layoutDescriptors`/`witnessTables`). The writer→project mapping is
// recorded in `writerGidMap` by interning each entry's `(baseId, args)`
// into `project.genericInstances` (idempotent — returns the existing id
// when the recursive arg read already created it via
// `readMaxonGenericInstance`). Polymorphic-slot writer entries whose args
// contain `unresolved`/`typeParameter` placeholders also surface in
// project as a side effect; downstream emission passes filter them via
// `gidIsConditional`.
function readGenericInstanceRegistry(project Project, buf ByteArray, offset ByteOffset, writerGidMap GenericInstanceIdArray) returns (GenericInstanceRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = GenericInstanceRegistry.create()
	for _ in 0 upto count 'eachInst'
		let (baseName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (args, p2) = try readMaxonTypeArray(project, buf: buf, offset: pos)
		pos = p2
		let baseId = project.typeNames.intern(baseName)
		let projectGid = project.genericInstances.intern(baseId, args: args)
		_ = registry.intern(baseId, args: args)
		writerGidMap.push(projectGid)
	end 'eachInst'
	return (registry, pos)
end 'readGenericInstanceRegistry'

// --- IrInterface map ---

function writeInterfaceMethodSig(project Project, buf ByteArray, sig InterfaceMethodSig) throws CacheCorruption
	try writeString(buf, s: sig.name)
	try writeStringArray(buf, arr: sig.paramNames)
	try writeMaxonTypeArray(project, buf: buf, arr: sig.paramTypes)
	try writeMaxonReturnType(project, buf: buf, rt: sig.returnType)
	try writeThrowsClauseField(buf, clause: sig.throwsTypeName)
	writeBoolByte(buf, b: sig.isStatic)
	writeDword(buf, value: sig.line)
	writeDword(buf, value: sig.column)
end 'writeInterfaceMethodSig'

function readInterfaceMethodSig(project Project, buf ByteArray, offset ByteOffset) returns (InterfaceMethodSig, ByteOffset) throws CacheCorruption
	let (name, p1) = try readString(buf, offset: offset)
	let (paramNames, p2) = try readStringArray(buf, offset: p1)
	let (paramTypes, p3) = try readMaxonTypeArray(project, buf: buf, offset: p2)
	let (returnType, p4) = try readMaxonReturnType(project, buf: buf, offset: p3)
	let (throwsTypeName, p5) = try readThrowsClauseField(buf, offset: p4)
	let (isStatic, p6) = readBoolByte(buf, offset: p5)
	let line = readDword(buf, offset: p6)
	let column = readDword(buf, offset: p6 + 4)
	return (InterfaceMethodSig.create(name, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType, throwsTypeName: throwsTypeName, isStatic: isStatic, line: line, column: column), p6 + 8)
end 'readInterfaceMethodSig'

function writeInterfaceMap(project Project, buf ByteArray, m IrInterfaceMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (name, iface) in m 'eachIface'
		try writeString(buf, s: name)
		try writeString(buf, s: iface.name)
		try writeStringArray(buf, arr: iface.extendsNames)
		try writeStringArray(buf, arr: iface.usesParams)
		writeDword(buf, value: iface.methods.count())
		for sig in iface.methods 'eachMethod'
			try writeInterfaceMethodSig(project, buf: buf, sig: sig)
		end 'eachMethod'
		writeVisibility(buf, v: iface.visibility)
		writeDword(buf, value: iface.line)
		writeDword(buf, value: iface.column)
		try writeFilePath(buf, p: iface.filePath)
		// Cache v48: persist the per-interface inner-typealias map so
		// cache-hit method-body lowering can resolve names declared inside
		// an `extension <ThisInterface>` block the same way a cache-miss
		// parse would. Mirrors the struct innerAliases write loop above.
		writeDword(buf, value: iface.innerAliases.count())
		for (aliasName, aliasType) in iface.innerAliases 'eachInnerAlias'
			try writeString(buf, s: aliasName)
			try writeMaxonType(project, buf: buf, t: aliasType)
		end 'eachInnerAlias'
	end 'eachIface'
end 'writeInterfaceMap'

function readInterfaceMap(project Project, buf ByteArray, offset ByteOffset) returns (IrInterfaceMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = IrInterfaceMap.create()
	for _ in 0 upto count 'eachIface'
		let (key, p1) = try readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = try readString(buf, offset: pos)
		pos = p2
		let (extendsNames, p3) = try readStringArray(buf, offset: pos)
		pos = p3
		let (usesParams, p4) = try readStringArray(buf, offset: pos)
		pos = p4
		let methodCount = readDword(buf, offset: pos)
		pos = pos + 4
		var methods = InterfaceMethodSigArray.create()
		for _ in 0 upto methodCount 'eachMethod'
			let (sig, p5) = try readInterfaceMethodSig(project, buf: buf, offset: pos)
			pos = p5
			methods.push(sig)
		end 'eachMethod'
		let (visibility, p6) = try readVisibility(buf, offset: pos)
		pos = p6
		let line = readDword(buf, offset: pos)
		pos = pos + 4
		let column = readDword(buf, offset: pos)
		pos = pos + 4
		let (filePath, p7) = try readFilePath(buf, offset: pos)
		pos = p7
		// Cache v48: read the per-interface inner-typealias map. Same
		// shape as the struct innerAliases reader.
		let innerCount = readDword(buf, offset: pos)
		pos = pos + 4
		var innerAliases = ResolvedInnerAliasMap.create()
		for _ in 0 upto innerCount 'eachInner'
			let (aliasName, p8) = try readString(buf, offset: pos)
			pos = p8
			let (aliasType, p9) = try readMaxonType(project, buf: buf, offset: pos)
			pos = p9
			try innerAliases.insert(aliasName, value: aliasType) otherwise ignore
		end 'eachInner'
		let iface = IrInterface.create(ifaceName, extendsNames: extendsNames, usesParams: usesParams, methods: methods, visibility: visibility, line: line, column: column, filePath: filePath, innerAliases: innerAliases)
		try m.insert(key, value: iface) otherwise ignore
	end 'eachIface'
	return (m, pos)
end 'readInterfaceMap'

// --- ConformanceRegistry ---

function writeConformanceRegistry(project Project, buf ByteArray, registry ConformanceRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachConf'
		let (typeName, ifaceName, withArgs) = registry.get(i)
		try writeString(buf, s: typeName)
		try writeString(buf, s: ifaceName)
		try writeMaxonTypeArray(project, buf: buf, arr: withArgs)
	end 'eachConf'
end 'writeConformanceRegistry'

function readConformanceRegistry(project Project, buf ByteArray, offset ByteOffset) returns (ConformanceRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = ConformanceRegistry.create()
	for _ in 0 upto count 'eachConf'
		let (typeName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = try readString(buf, offset: pos)
		pos = p2
		let (withArgs, p3) = try readMaxonTypeArray(project, buf: buf, offset: pos)
		pos = p3
		_ = registry.intern(typeName, interfaceName: ifaceName, withArgs: withArgs)
	end 'eachConf'
	return (registry, pos)
end 'readConformanceRegistry'

// --- ConformanceArray (per-extension) ---
//
// Used by `UnresolvedExtension.addedConformances`. Distinct from
// `ConformanceRegistry`: each entry is a parser-recorded `Conformance` with
// `(interfaceName, withArgs StringArray, parenForm bool, line, column)`. The
// withArgs are bare identifier names captured at parse time, NOT MaxonType
// values — Phase 11.0 step 5+ resolves them later through the receiver's
// `typeParameters` registry. Round-tripping as strings keeps the persisted
// shape stable across MaxonType-id remapping.
function writeConformanceArray(buf ByteArray, arr ConformanceArray) throws CacheCorruption
	writeDword(buf, value: arr.count())
	for c in arr 'eachConf'
		try writeString(buf, s: c.interfaceName)
		try writeStringArray(buf, arr: c.withArgs)
		writeBoolByte(buf, b: c.parenForm)
		writeDword(buf, value: c.line)
		writeDword(buf, value: c.column)
	end 'eachConf'
end 'writeConformanceArray'

function readConformanceArray(buf ByteArray, offset ByteOffset) returns (ConformanceArray, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = ConformanceArray.create()
	for _ in 0 upto count 'eachConf'
		let (interfaceName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (withArgs, p2) = try readStringArray(buf, offset: pos)
		pos = p2
		let (parenForm, p3) = readBoolByte(buf, offset: pos)
		pos = p3
		let line = readDword(buf, offset: pos)
		pos = pos + 4
		let column = readDword(buf, offset: pos)
		pos = pos + 4
		arr.push(Conformance.create(interfaceName, withArgs: withArgs, parenForm: parenForm, line: line, column: column))
	end 'eachConf'
	return (arr, pos)
end 'readConformanceArray'

// --- UnresolvedExtensionArray ---
//
// Cache v50 (J.4c): round-trips `project.unresolvedExtensions` so cache-hit
// user builds see the stdlib's struct- and interface-extension metadata. Each
// entry's fields are bare strings + plain enums — no MaxonType ids are
// embedded, so the codec needs no captured-id translation.
function writeUnresolvedExtensionArray(buf ByteArray, arr UnresolvedExtensionArray) throws CacheCorruption
	writeDword(buf, value: arr.count())
	for ext in arr 'eachExt'
		try writeString(buf, s: ext.targetTypeName)
		try writeStringArray(buf, arr: ext.targetTypeParams)
		try writeConformanceArray(buf, arr: ext.addedConformances)
		try writeWhereClauseArray(buf, arr: ext.whereClauses)
		writeVisibility(buf, v: ext.visibility)
		writeDword(buf, value: ext.line)
		writeDword(buf, value: ext.column)
		try writeFilePath(buf, p: ext.filePath)
	end 'eachExt'
end 'writeUnresolvedExtensionArray'

function readUnresolvedExtensionArray(buf ByteArray, offset ByteOffset) returns (UnresolvedExtensionArray, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = UnresolvedExtensionArray.create()
	for _ in 0 upto count 'eachExt'
		let (targetTypeName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (targetTypeParams, p2) = try readStringArray(buf, offset: pos)
		pos = p2
		let (addedConformances, p3) = try readConformanceArray(buf, offset: pos)
		pos = p3
		let (whereClauses, p4) = try readWhereClauseArray(buf, offset: pos)
		pos = p4
		let (visibility, p5) = try readVisibility(buf, offset: pos)
		pos = p5
		let line = readDword(buf, offset: pos)
		pos = pos + 4
		let column = readDword(buf, offset: pos)
		pos = pos + 4
		let (filePath, p6) = try readFilePath(buf, offset: pos)
		pos = p6
		arr.push(UnresolvedExtension.create(targetTypeName, targetTypeParams: targetTypeParams, addedConformances: addedConformances, whereClauses: whereClauses, visibility: visibility, line: line, column: column, filePath: filePath))
	end 'eachExt'
	return (arr, pos)
end 'readUnresolvedExtensionArray'

// --- WhereClauseMapByName ---
//
// Cache v50 (J.4c): round-trips `project.extensionMethodWhereClauses`. Each
// entry is `(methodKey String, clauses WhereClauseArray)`. The methodKey is
// the fully-qualified callee name; the clauses are the enclosing extension's
// where-clauses stamped on every method in the block at parse time.
function writeWhereClauseMapByName(buf ByteArray, m WhereClauseMapByName) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (methodKey, clauses) in m 'eachEntry'
		try writeString(buf, s: methodKey)
		try writeWhereClauseArray(buf, arr: clauses)
	end 'eachEntry'
end 'writeWhereClauseMapByName'

function readWhereClauseMapByName(buf ByteArray, offset ByteOffset) returns (WhereClauseMapByName, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = WhereClauseMapByName.create()
	for _ in 0 upto count 'eachEntry'
		let (methodKey, p1) = try readString(buf, offset: pos)
		pos = p1
		let (clauses, p2) = try readWhereClauseArray(buf, offset: pos)
		pos = p2
		try m.insert(methodKey, value: clauses) otherwise ignore
	end 'eachEntry'
	return (m, pos)
end 'readWhereClauseMapByName'

// --- GenericTypealiasMap ---

function writeGenericTypealiasMap(project Project, buf ByteArray, m GenericTypealiasMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (name, t) in m 'eachAlias'
		try writeString(buf, s: name)
		try writeMaxonType(project, buf: buf, t: t)
	end 'eachAlias'
end 'writeGenericTypealiasMap'

function readGenericTypealiasMap(project Project, buf ByteArray, offset ByteOffset) returns (GenericTypealiasMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = GenericTypealiasMap.create()
	for _ in 0 upto count 'eachAlias'
		let (name, p1) = try readString(buf, offset: pos)
		pos = p1
		let (t, p2) = try readMaxonType(project, buf: buf, offset: pos)
		pos = p2
		try m.insert(name, value: t) otherwise ignore
	end 'eachAlias'
	return (m, pos)
end 'readGenericTypealiasMap'

// --- LayoutDescriptorRegistry ---

function writeLayoutDescriptorRegistry(buf ByteArray, registry LayoutDescriptorRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachLd'
		let gid = try registry.instanceIds.get(i) otherwise panic("writeLayoutDescriptorRegistry: instanceIds.get OOB at {i}")
		let label = try registry.labels.get(i) otherwise panic("writeLayoutDescriptorRegistry: labels desync at {i}")
		writeQword(buf, value: gid)
		try writeString(buf, s: label)
	end 'eachLd'
end 'writeLayoutDescriptorRegistry'

function readLayoutDescriptorRegistry(buf ByteArray, offset ByteOffset) returns (LayoutDescriptorRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = LayoutDescriptorRegistry.create()
	for _ in 0 upto count 'eachLd'
		let gid = readQword(buf, offset: pos)
		pos = pos + 8
		let (label, p) = try readString(buf, offset: pos)
		pos = p
		registry.intern(gid, label: label)
	end 'eachLd'
	return (registry, pos)
end 'readLayoutDescriptorRegistry'

// --- WitnessTableRegistry ---

function writeWitnessTableRegistry(buf ByteArray, registry WitnessTableRegistry) throws CacheCorruption
	writeDword(buf, value: registry.count())
	for i in 0 upto registry.count() 'eachWt'
		let e = registry.get(i)
		try writeString(buf, s: e.typeName)
		try writeString(buf, s: e.interfaceName)
		try writeString(buf, s: e.label)
		try writeStringArray(buf, arr: e.methodImplNames)
		try writeParentWitnessLabelField(buf, label: e.parentWitnessLabel)
		var fatRaw = 0 as MachineWord
		if e.isFatBoxed 'isFat'
			fatRaw = 1
		end 'isFat'
		writeDword(buf, value: fatRaw)
	end 'eachWt'
	// Per-instance (gid-keyed) entries, used for generic conformers like
	// `Array: Equatable`. The user pipeline replays these on cache restore
	// so the on-demand path can find labels for stdlib-emitted instances
	// (e.g. `Array<Byte>: Equatable` produced when the stdlib parse
	// interned ByteArray).
	writeDword(buf, value: registry.gidCount())
	for i in 0 upto registry.gidCount() 'eachGidEntry'
		let g = registry.getGid(i)
		writeDword(buf, value: g.gid as MachineWord)
		try writeString(buf, s: g.interfaceName)
		try writeString(buf, s: g.label)
		try writeStringArray(buf, arr: g.methodImplNames)
		var fatRaw = 0 as MachineWord
		if g.isFatBoxed 'isFat'
			fatRaw = 1
		end 'isFat'
		writeDword(buf, value: fatRaw)
	end 'eachGidEntry'
end 'writeWitnessTableRegistry'

function readWitnessTableRegistry(buf ByteArray, offset ByteOffset) returns (WitnessTableRegistry, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var registry = WitnessTableRegistry.create()
	for _ in 0 upto count 'eachWt'
		let (typeName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (ifaceName, p2) = try readString(buf, offset: pos)
		pos = p2
		let (label, p3) = try readString(buf, offset: pos)
		pos = p3
		let (methodImplNames, p4) = try readStringArray(buf, offset: pos)
		pos = p4
		let (parentLabel, p5) = try readParentWitnessLabelField(buf, offset: pos)
		pos = p5
		let isFatRaw = readDword(buf, offset: pos)
		pos = pos + 4
		let isFatBoxed = isFatRaw != 0
		registry.intern(typeName, interfaceName: ifaceName, label: label, methodImplNames: methodImplNames, parentWitnessLabel: parentLabel, isFatBoxed: isFatBoxed)
	end 'eachWt'
	let gidCount = readDword(buf, offset: pos)
	pos = pos + 4
	for _ in 0 upto gidCount 'eachGidEntry'
		let gidRaw = readDword(buf, offset: pos)
		pos = pos + 4
		let (gIfaceName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (gLabel, p2) = try readString(buf, offset: pos)
		pos = p2
		let (gMethodImpls, p3) = try readStringArray(buf, offset: pos)
		pos = p3
		let gIsFatRaw = readDword(buf, offset: pos)
		pos = pos + 4
		let gIsFat = gIsFatRaw != 0
		registry.internForGid(gidRaw, interfaceName: gIfaceName, label: gLabel, methodImplNames: gMethodImpls, isFatBoxed: gIsFat)
	end 'eachGidEntry'
	return (registry, pos)
end 'readWitnessTableRegistry'

// --- GenericFunctionImplicitArityMap ---

function writeGenericFunctionImplicitArityMap(buf ByteArray, m GenericFunctionImplicitArityMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (name, implicits) in m 'eachEntry'
		try writeString(buf, s: name)
		writeBoolByte(buf, b: implicits.hasLayout)
		try writeWhereClauseArray(buf, arr: implicits.witnessConstraints)
	end 'eachEntry'
end 'writeGenericFunctionImplicitArityMap'

function readGenericFunctionImplicitArityMap(buf ByteArray, offset ByteOffset) returns (GenericFunctionImplicitArityMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = GenericFunctionImplicitArityMap.create()
	for _ in 0 upto count 'eachEntry'
		let (name, p1) = try readString(buf, offset: pos)
		pos = p1
		let (hasLayout, p2) = readBoolByte(buf, offset: pos)
		pos = p2
		let (witnessConstraints, p3) = try readWhereClauseArray(buf, offset: pos)
		pos = p3
		try m.insert(name, value: GenericFunctionImplicits.create(hasLayout, witnessConstraints: witnessConstraints)) otherwise ignore
	end 'eachEntry'
	return (m, pos)
end 'readGenericFunctionImplicitArityMap'

// --- TopLevelVarMap (v55) ---

function writeTopLevelVarMap(project Project, buf ByteArray, m TopLevelVarMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (name, info) in m 'eachVar'
		try writeString(buf, s: name)
		try writeMaxonType(project, buf: buf, t: info.slotType)
		writeQword(buf, value: info.initialValue)
		writeVisibility(buf, v: info.visibility)
		try writeFilePath(buf, p: info.sourceFilePath)
	end 'eachVar'
end 'writeTopLevelVarMap'

function readTopLevelVarMap(project Project, buf ByteArray, offset ByteOffset) returns (TopLevelVarMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = TopLevelVarMap.create()
	for _ in 0 upto count 'eachVar'
		let (name, p1) = try readString(buf, offset: pos)
		pos = p1
		let (slotType, p2) = try readMaxonType(project, buf: buf, offset: pos)
		pos = p2
		let initialValue = readQword(buf, offset: pos) as IntConstant
		pos = pos + 8
		let (visibility, p3) = try readVisibility(buf, offset: pos)
		pos = p3
		let (sourceFilePath, p4) = try readFilePath(buf, offset: pos)
		pos = p4
		try m.insert(name, value: TopLevelVarInfo.create(name, slotType: slotType, initialValue: initialValue, visibility: visibility, sourceFilePath: sourceFilePath)) otherwise ignore
	end 'eachVar'
	return (m, pos)
end 'readTopLevelVarMap'

// --- InitToStoredVarsMap (v55) ---

function writeInitToStoredVarsMap(buf ByteArray, m InitToStoredVarsMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (initName, vars) in m 'eachInit'
		try writeString(buf, s: initName)
		writeDword(buf, value: vars.count())
		for varName in vars 'eachVar'
			try writeString(buf, s: varName)
		end 'eachVar'
	end 'eachInit'
end 'writeInitToStoredVarsMap'

function readInitToStoredVarsMap(buf ByteArray, offset ByteOffset) returns (InitToStoredVarsMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = InitToStoredVarsMap.create()
	for _ in 0 upto count 'eachInit'
		let (initName, p1) = try readString(buf, offset: pos)
		pos = p1
		let varCount = readDword(buf, offset: pos)
		pos = pos + 4
		var vars = StoredVarNameSet.create()
		for _ in 0 upto varCount 'eachVar'
			let (varName, p2) = try readString(buf, offset: pos)
			pos = p2
			vars.insert(varName)
		end 'eachVar'
		try m.insert(initName, value: vars) otherwise ignore
	end 'eachInit'
	return (m, pos)
end 'readInitToStoredVarsMap'

// --- CachedFuncEdgeMap (v68) ---
//
// Same `name -> lists-of-strings` shape as `writeInitToStoredVarsMap`, but
// each entry carries three string lists (callees / conditionalRootLabels /
// plainLabels). Per entry: name, then each list as (count + strings).

function writeStdFuncEdgeMap(buf ByteArray, m CachedFuncEdgeMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (funcName, edges) in m 'eachFunc'
		try writeString(buf, s: funcName)
		try writeStringArray(buf, arr: edges.callees)
		try writeStringArray(buf, arr: edges.conditionalRootLabels)
		try writeStringArray(buf, arr: edges.plainLabels)
	end 'eachFunc'
end 'writeStdFuncEdgeMap'

function readStdFuncEdgeMap(buf ByteArray, offset ByteOffset) returns (CachedFuncEdgeMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = CachedFuncEdgeMap.create()
	for _ in 0 upto count 'eachFunc'
		let (funcName, p1) = try readString(buf, offset: pos)
		pos = p1
		let (callees, p2) = try readStringArray(buf, offset: pos)
		pos = p2
		let (conditionalRootLabels, p3) = try readStringArray(buf, offset: pos)
		pos = p3
		let (plainLabels, p4) = try readStringArray(buf, offset: pos)
		pos = p4
		var edges = CachedFuncEdges.create()
		edges.callees = callees
		edges.conditionalRootLabels = conditionalRootLabels
		edges.plainLabels = plainLabels
		try m.insert(funcName, value: edges) otherwise ignore
	end 'eachFunc'
	return (m, pos)
end 'readStdFuncEdgeMap'

// --- StaticRdataValueMap ---

function writeStaticRdataValueMap(buf ByteArray, m StaticRdataValueMap) throws CacheCorruption
	writeDword(buf, value: m.count())
	for (label, bytes) in m 'eachEntry'
		try writeString(buf, s: label)
		writeDword(buf, value: bytes.count())
		buf.append(bytes)
	end 'eachEntry'
end 'writeStaticRdataValueMap'

function readStaticRdataValueMap(buf ByteArray, offset ByteOffset) returns (StaticRdataValueMap, ByteOffset) throws CacheCorruption
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var m = StaticRdataValueMap.create()
	for _ in 0 upto count 'eachEntry'
		let (label, p1) = try readString(buf, offset: pos)
		pos = p1
		let len = readDword(buf, offset: pos)
		pos = pos + 4
		var bytes = ByteArray.create()
		bytes.reserve(len)
		pos = copyBytesInto(bytes, buf: buf, offset: pos, len: len)
		try m.insert(label, value: bytes) otherwise ignore
	end 'eachEntry'
	return (m, pos)
end 'readStaticRdataValueMap'

// ============================================================
// Cache v10 codec helpers — Phase 11.6 stdlib StdModule round-trip.
// ============================================================
//
// Persists the stdlib's post-dce StdModule so the user pipeline's inliner
// pass can splice stdlib accessor bodies. Symmetric pairs: each
// `write<TypeName>` matches the value's variants and emits ordinal +
// payload; each `read<TypeName>` reads the ordinal, lifts via
// `unionCases.fromRawValue`, and dispatches to a per-variant helper that
// returns the freshly-constructed union value plus the post-read offset.
// Match arms in this language are single-statement, so the read side
// factors every multi-statement arm into a `read<Variant>Inner` helper.

// --- Bool byte helper ---
//
// Single-byte encoding for bool fields. Persisting a 1-bit flag in 8
// bytes via writeQword would cost ~6KB across a typical stdlib's worth
// of system ops. One byte per flag keeps the codec compact.

function writeBoolByte(buf ByteArray, b bool)
	if b 'isTrue'
		buf.push(1)
	end 'isTrue' else 'isFalse'
		buf.push(0)
	end 'isFalse'
end 'writeBoolByte'

function readBoolByte(buf ByteArray, offset ByteOffset) returns (bool, ByteOffset)
	let b = try buf.get(offset) otherwise panic("readBoolByte: buf truncated at {offset}")
	return (b != 0, offset + 1)
end 'readBoolByte'

// --- ValueIdArray ---

function writeValueIdArrayCodec(buf ByteArray, arr ValueIdArray)
	writeDword(buf, value: arr.count())
	for v in arr 'each'
		writeQword(buf, value: v)
	end 'each'
end 'writeValueIdArrayCodec'

function readValueIdArrayCodec(buf ByteArray, offset ByteOffset) returns (ValueIdArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = ValueIdArray.create()
	for _ in 0 upto count 'each'
		let v = readQword(buf, offset: pos)
		pos = pos + 8
		arr.push(v)
	end 'each'
	return (arr, pos)
end 'readValueIdArrayCodec'

// --- StdTypeArray ---

function writeStdTypeArrayCodec(buf ByteArray, arr StdTypeArray)
	writeDword(buf, value: arr.count())
	for t in arr 'each'
		writeStdTypeTag(buf, t: t)
	end 'each'
end 'writeStdTypeArrayCodec'

function readStdTypeArrayCodec(buf ByteArray, offset ByteOffset) returns (StdTypeArray, ByteOffset)
	let count = readDword(buf, offset: offset)
	var pos = offset + 4
	var arr = StdTypeArray.create()
	for _ in 0 upto count 'each'
		let (t, p) = readStdTypeTag(buf, offset: pos)
		pos = p
		arr.push(t)
	end 'each'
	return (arr, pos)
end 'readStdTypeArrayCodec'

// --- StdArithConst / StdArithUnaryOp / StdArithBinaryOp ---

function writeStdArithConst(buf ByteArray, c StdArithConst)
	writeDword(buf, value: c.opcode.ordinal)
	writeQword(buf, value: c.resultId)
	writeQword(buf, value: c.value)
end 'writeStdArithConst'

function readStdArithConst(buf ByteArray, offset ByteOffset) returns (StdArithConst, ByteOffset) throws CacheCorruption
	let opRaw = readDword(buf, offset: offset)
	let opcode = try liftStdArithConstOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let value = readQword(buf, offset: offset + 12)
	return (StdArithConst.create(opcode, resultId: resultId, value: value), offset + 20)
end 'readStdArithConst'

function liftStdArithConstOpcode(raw MachineWord) returns StdArithConstOpcode throws CacheCorruption
	let kase = try StdArithConstOpcode.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'oc'
		constI64 gives StdArithConstOpcode.constI64
		constF64 gives StdArithConstOpcode.constF64
	end 'oc'
end 'liftStdArithConstOpcode'

function writeStdArithUnaryOp(buf ByteArray, u StdArithUnaryOp)
	writeDword(buf, value: u.opcode.ordinal)
	writeQword(buf, value: u.resultId)
	writeQword(buf, value: u.operandId)
end 'writeStdArithUnaryOp'

function readStdArithUnaryOp(buf ByteArray, offset ByteOffset) returns (StdArithUnaryOp, ByteOffset) throws CacheCorruption
	let opRaw = readDword(buf, offset: offset)
	let opcode = try liftStdArithUnaryOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let operandId = readQword(buf, offset: offset + 12)
	return (StdArithUnaryOp.create(opcode, resultId: resultId, operandId: operandId), offset + 20)
end 'readStdArithUnaryOp'

function liftStdArithUnaryOpcode(raw MachineWord) returns StdArithUnaryOpcode throws CacheCorruption
	let kase = try StdArithUnaryOpcode.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'oc'
		negI64 gives StdArithUnaryOpcode.negI64
		bitNotI64 gives StdArithUnaryOpcode.bitNotI64
		fpToSiI64 gives StdArithUnaryOpcode.fpToSiI64
		bitcastF64ToI64 gives StdArithUnaryOpcode.bitcastF64ToI64
		bitcastI64ToF64 gives StdArithUnaryOpcode.bitcastI64ToF64
		siToFpF64 gives StdArithUnaryOpcode.siToFpF64
		sqrtF64 gives StdArithUnaryOpcode.sqrtF64
		floorF64 gives StdArithUnaryOpcode.floorF64
		ceilF64 gives StdArithUnaryOpcode.ceilF64
		roundF64 gives StdArithUnaryOpcode.roundF64
		absF64 gives StdArithUnaryOpcode.absF64
	end 'oc'
end 'liftStdArithUnaryOpcode'

function writeStdArithBinaryOp(buf ByteArray, b StdArithBinaryOp)
	writeDword(buf, value: b.opcode.ordinal)
	writeQword(buf, value: b.resultId)
	writeQword(buf, value: b.leftId)
	writeQword(buf, value: b.rightId)
end 'writeStdArithBinaryOp'

function readStdArithBinaryOp(buf ByteArray, offset ByteOffset) returns (StdArithBinaryOp, ByteOffset) throws CacheCorruption
	let opRaw = readDword(buf, offset: offset)
	let opcode = try liftStdArithBinaryOpcode(opRaw)
	let resultId = readQword(buf, offset: offset + 4)
	let leftId = readQword(buf, offset: offset + 12)
	let rightId = readQword(buf, offset: offset + 20)
	return (StdArithBinaryOp.create(opcode, resultId: resultId, leftId: leftId, rightId: rightId), offset + 28)
end 'readStdArithBinaryOp'

function liftStdArithBinaryOpcode(raw MachineWord) returns StdArithBinaryOpcode throws CacheCorruption
	let kase = try StdArithBinaryOpcode.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'oc'
		addI64 gives StdArithBinaryOpcode.addI64
		subI64 gives StdArithBinaryOpcode.subI64
		mulI64 gives StdArithBinaryOpcode.mulI64
		divI64 gives StdArithBinaryOpcode.divI64
		remI64 gives StdArithBinaryOpcode.remI64
		andI64 gives StdArithBinaryOpcode.andI64
		orI64 gives StdArithBinaryOpcode.orI64
		orI1 gives StdArithBinaryOpcode.orI1
		xorI64 gives StdArithBinaryOpcode.xorI64
		shlI64 gives StdArithBinaryOpcode.shlI64
		shrI64 gives StdArithBinaryOpcode.shrI64
		addF64 gives StdArithBinaryOpcode.addF64
		subF64 gives StdArithBinaryOpcode.subF64
		mulF64 gives StdArithBinaryOpcode.mulF64
		divF64 gives StdArithBinaryOpcode.divF64
		minF64 gives StdArithBinaryOpcode.minF64
		maxF64 gives StdArithBinaryOpcode.maxF64
		cmpI64Eq gives StdArithBinaryOpcode.cmpI64Eq
		cmpI64Ne gives StdArithBinaryOpcode.cmpI64Ne
		cmpI64Lt gives StdArithBinaryOpcode.cmpI64Lt
		cmpI64Le gives StdArithBinaryOpcode.cmpI64Le
		cmpI64Gt gives StdArithBinaryOpcode.cmpI64Gt
		cmpI64Ge gives StdArithBinaryOpcode.cmpI64Ge
		cmpI64Ugt gives StdArithBinaryOpcode.cmpI64Ugt
		cmpF64Eq gives StdArithBinaryOpcode.cmpF64Eq
		cmpF64Ne gives StdArithBinaryOpcode.cmpF64Ne
		cmpF64Lt gives StdArithBinaryOpcode.cmpF64Lt
		cmpF64Le gives StdArithBinaryOpcode.cmpF64Le
		cmpF64Gt gives StdArithBinaryOpcode.cmpF64Gt
		cmpF64Ge gives StdArithBinaryOpcode.cmpF64Ge
	end 'oc'
end 'liftStdArithBinaryOpcode'

// --- StdArithOp ---

function writeStdArithOp(buf ByteArray, op StdArithOp)
	writeDword(buf, value: op.ordinal)
	match op 'arith'
		const(c) then writeStdArithConst(buf, c: c)
		unary(u) then writeStdArithUnaryOp(buf, u: u)
		binary(bin) then writeStdArithBinaryOp(buf, b: bin)
	end 'arith'
end 'writeStdArithOp'

function readStdArithOp(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdArithOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'arith'
		const gives try readStdArithOpConst(buf, offset: offset + 4)
		unary gives try readStdArithOpUnary(buf, offset: offset + 4)
		binary gives try readStdArithOpBinary(buf, offset: offset + 4)
	end 'arith'
end 'readStdArithOp'

function readStdArithOpConst(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset) throws CacheCorruption
	let (c, p) = try readStdArithConst(buf, offset: offset)
	return (StdArithOp.const(c), p)
end 'readStdArithOpConst'

function readStdArithOpUnary(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset) throws CacheCorruption
	let (u, p) = try readStdArithUnaryOp(buf, offset: offset)
	return (StdArithOp.unary(u), p)
end 'readStdArithOpUnary'

function readStdArithOpBinary(buf ByteArray, offset ByteOffset) returns (StdArithOp, ByteOffset) throws CacheCorruption
	let (binOp, p) = try readStdArithBinaryOp(buf, offset: offset)
	return (StdArithOp.binary(binOp), p)
end 'readStdArithOpBinary'

// --- StdControlOp ---

function writeStdControlOp(buf ByteArray, op StdControlOp)
	writeDword(buf, value: op.ordinal)
	match op 'cf'
		br(target, argIds) then writeStdControlBr(buf, target: target, argIds: argIds)
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) then writeStdControlCondBr(buf, condId: condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds)
	end 'cf'
end 'writeStdControlOp'

function writeStdControlBr(buf ByteArray, target BlockId, argIds ValueIdArray)
	writeQword(buf, value: target)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdControlBr'

function writeStdControlCondBr(buf ByteArray, condId ValueId, thenTarget BlockId, thenArgIds ValueIdArray, elseTarget BlockId, elseArgIds ValueIdArray)
	writeQword(buf, value: condId)
	writeQword(buf, value: thenTarget)
	writeValueIdArrayCodec(buf, arr: thenArgIds)
	writeQword(buf, value: elseTarget)
	writeValueIdArrayCodec(buf, arr: elseArgIds)
end 'writeStdControlCondBr'

function readStdControlOp(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdControlOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'cf'
		br gives readStdControlOpBr(buf, offset: offset + 4)
		condBr gives readStdControlOpCondBr(buf, offset: offset + 4)
	end 'cf'
end 'readStdControlOp'

function readStdControlOpBr(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset)
	let target = readQword(buf, offset: offset)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 8)
	return (StdControlOp.br(target, argIds: argIds), p)
end 'readStdControlOpBr'

function readStdControlOpCondBr(buf ByteArray, offset ByteOffset) returns (StdControlOp, ByteOffset)
	let condId = readQword(buf, offset: offset)
	let thenTarget = readQword(buf, offset: offset + 8)
	let (thenArgIds, p1) = readValueIdArrayCodec(buf, offset: offset + 16)
	let elseTarget = readQword(buf, offset: p1)
	let (elseArgIds, p2) = readValueIdArrayCodec(buf, offset: p1 + 8)
	return (StdControlOp.condBr(condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds), p2)
end 'readStdControlOpCondBr'

// --- StdCallOp ---

function writeStdCallOp(buf ByteArray, op StdCallOp) throws CacheCorruption
	writeDword(buf, value: op.ordinal)
	match op 'call'
		ret(retValId) then writeQword(buf, value: retValId)
		call(resultId, callee, argIds) then try writeStdCallCall(buf, resultId: resultId, callee: callee, argIds: argIds)
		tryCall(resultId, callee, argIds, errorFlagId) then try writeStdCallTryCall(buf, resultId: resultId, callee: callee, argIds: argIds, errorFlagId: errorFlagId)
		indirectCall(resultId, calleeId, argIds, isVoid, isThrowing, errorFlagId) then writeStdCallIndirect(buf, resultId: resultId, calleeId: calleeId, argIds: argIds, isVoid: isVoid, isThrowing: isThrowing, errorFlagId: errorFlagId)
		witnessCall(resultId, witnessAddrId, methodIndex, isVoid, argIds) then writeStdCallWitness(buf, resultId: resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds)
		witnessTryCall(resultId, witnessAddrId, methodIndex, isVoid, argIds, errorFlagId) then writeStdCallWitnessTry(buf, resultId: resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds, errorFlagId: errorFlagId)
		funcRef(resultId, funcName) then try writeStdCallFuncRef(buf, resultId: resultId, funcName: funcName)
		tailCall(callee, argIds) then try writeStdCallTail(buf, callee: callee, argIds: argIds)
		param(resultId, paramIndex, paramType) then writeStdCallParam(buf, resultId: resultId, paramIndex: paramIndex, paramType: paramType)
		errorReturn(retValId, errorFlagId) then writeStdCallErrorReturn(buf, retValId: retValId, errorFlagId: errorFlagId)
	end 'call'
end 'writeStdCallOp'

function writeStdCallCall(buf ByteArray, resultId ValueId, callee String, argIds ValueIdArray) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallCall'

function writeStdCallTryCall(buf ByteArray, resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
	writeQword(buf, value: errorFlagId)
end 'writeStdCallTryCall'

function writeStdCallIndirect(buf ByteArray, resultId ValueId, calleeId ValueId, argIds ValueIdArray, isVoid bool, isThrowing bool, errorFlagId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: calleeId)
	let voidFlag = 1 if isVoid else 0
	writeQword(buf, value: voidFlag)
	let throwsFlag = 1 if isThrowing else 0
	writeQword(buf, value: throwsFlag)
	writeQword(buf, value: errorFlagId)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallIndirect'

function writeStdCallWitness(buf ByteArray, resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray)
	writeQword(buf, value: resultId)
	writeQword(buf, value: witnessAddrId)
	writeQword(buf, value: methodIndex)
	let voidFlag = 1 if isVoid else 0
	writeQword(buf, value: voidFlag)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallWitness'

function writeStdCallWitnessTry(buf ByteArray, resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray, errorFlagId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: witnessAddrId)
	writeQword(buf, value: methodIndex)
	let voidFlag = 1 if isVoid else 0
	writeQword(buf, value: voidFlag)
	writeValueIdArrayCodec(buf, arr: argIds)
	writeQword(buf, value: errorFlagId)
end 'writeStdCallWitnessTry'

function writeStdCallFuncRef(buf ByteArray, resultId ValueId, funcName String) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: funcName)
end 'writeStdCallFuncRef'

function writeStdCallTail(buf ByteArray, callee String, argIds ValueIdArray) throws CacheCorruption
	try writeString(buf, s: callee)
	writeValueIdArrayCodec(buf, arr: argIds)
end 'writeStdCallTail'

function writeStdCallParam(buf ByteArray, resultId ValueId, paramIndex VarSlot, paramType StdType)
	writeQword(buf, value: resultId)
	writeQword(buf, value: paramIndex)
	writeStdTypeTag(buf, t: paramType)
end 'writeStdCallParam'

function writeStdCallErrorReturn(buf ByteArray, retValId ValueId, errorFlagId ValueId)
	writeQword(buf, value: retValId)
	writeQword(buf, value: errorFlagId)
end 'writeStdCallErrorReturn'

function readStdCallOp(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdCallOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'call'
		ret gives readStdCallRet(buf, offset: offset + 4)
		call gives try readStdCallCall(buf, offset: offset + 4)
		tryCall gives try readStdCallTryCall(buf, offset: offset + 4)
		indirectCall gives readStdCallIndirect(buf, offset: offset + 4)
		witnessCall gives readStdCallWitness(buf, offset: offset + 4)
		witnessTryCall gives readStdCallWitnessTry(buf, offset: offset + 4)
		funcRef gives try readStdCallFuncRef(buf, offset: offset + 4)
		tailCall gives try readStdCallTail(buf, offset: offset + 4)
		param gives readStdCallParam(buf, offset: offset + 4)
		errorReturn gives readStdCallErrorReturn(buf, offset: offset + 4)
	end 'call'
end 'readStdCallOp'

function readStdCallRet(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let retValId = readQword(buf, offset: offset)
	return (StdCallOp.ret(retValId), offset + 8)
end 'readStdCallRet'

function readStdCallCall(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset) throws CacheCorruption
	let resultId = readQword(buf, offset: offset)
	let (callee, p1) = try readString(buf, offset: offset + 8)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	return (StdCallOp.call(resultId, callee: callee, argIds: argIds), p2)
end 'readStdCallCall'

function readStdCallTryCall(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset) throws CacheCorruption
	let resultId = readQword(buf, offset: offset)
	let (callee, p1) = try readString(buf, offset: offset + 8)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	let errorFlagId = readQword(buf, offset: p2)
	return (StdCallOp.tryCall(resultId, callee: callee, argIds: argIds, errorFlagId: errorFlagId), p2 + 8)
end 'readStdCallTryCall'

function readStdCallIndirect(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let calleeId = readQword(buf, offset: offset + 8)
	let isVoid = readQword(buf, offset: offset + 16) != 0
	let isThrowing = readQword(buf, offset: offset + 24) != 0
	let errorFlagId = readQword(buf, offset: offset + 32)
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 40)
	return (StdCallOp.indirectCall(resultId, calleeId: calleeId, argIds: argIds, isVoid: isVoid, isThrowing: isThrowing, errorFlagId: errorFlagId), p)
end 'readStdCallIndirect'

function readStdCallWitness(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let witnessAddrId = readQword(buf, offset: offset + 8)
	let methodIndex = readQword(buf, offset: offset + 16)
	let isVoidFlag = readQword(buf, offset: offset + 24)
	let isVoid = isVoidFlag != 0
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 32)
	return (StdCallOp.witnessCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds), p)
end 'readStdCallWitness'

function readStdCallWitnessTry(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let witnessAddrId = readQword(buf, offset: offset + 8)
	let methodIndex = readQword(buf, offset: offset + 16)
	let isVoidFlag = readQword(buf, offset: offset + 24)
	let isVoid = isVoidFlag != 0
	let (argIds, p) = readValueIdArrayCodec(buf, offset: offset + 32)
	let errorFlagId = readQword(buf, offset: p)
	return (StdCallOp.witnessTryCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds, errorFlagId: errorFlagId), p + 8)
end 'readStdCallWitnessTry'

function readStdCallFuncRef(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset) throws CacheCorruption
	let resultId = readQword(buf, offset: offset)
	let (funcName, p) = try readString(buf, offset: offset + 8)
	return (StdCallOp.funcRef(resultId, funcName: funcName), p)
end 'readStdCallFuncRef'

function readStdCallTail(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset) throws CacheCorruption
	let (callee, p1) = try readString(buf, offset: offset)
	let (argIds, p2) = readValueIdArrayCodec(buf, offset: p1)
	return (StdCallOp.tailCall(callee, argIds: argIds), p2)
end 'readStdCallTail'

function readStdCallParam(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let paramIndex = readQword(buf, offset: offset + 8)
	let (paramType, p) = readStdTypeTag(buf, offset: offset + 16)
	return (StdCallOp.param(resultId, paramIndex: paramIndex, paramType: paramType), p)
end 'readStdCallParam'

function readStdCallErrorReturn(buf ByteArray, offset ByteOffset) returns (StdCallOp, ByteOffset)
	let retValId = readQword(buf, offset: offset)
	let errorFlagId = readQword(buf, offset: offset + 8)
	return (StdCallOp.errorReturn(retValId, errorFlagId: errorFlagId), offset + 16)
end 'readStdCallErrorReturn'

// --- StdMemoryOp ---

function writeStdMemoryOp(buf ByteArray, op StdMemoryOp)
	writeDword(buf, value: op.ordinal)
	match op 'mem'
		storeSlot(slotId, valueId) then writeStdMemoryStore(buf, slotId: slotId, valueId: valueId)
		loadSlot(resultId, slotId) then writeStdMemoryLoad(buf, resultId: resultId, slotId: slotId)
	end 'mem'
end 'writeStdMemoryOp'

function writeStdMemoryStore(buf ByteArray, slotId VarSlot, valueId ValueId)
	writeQword(buf, value: slotId)
	writeQword(buf, value: valueId)
end 'writeStdMemoryStore'

function writeStdMemoryLoad(buf ByteArray, resultId ValueId, slotId VarSlot)
	writeQword(buf, value: resultId)
	writeQword(buf, value: slotId)
end 'writeStdMemoryLoad'

function readStdMemoryOp(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdMemoryOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	return match kase 'mem'
		storeSlot gives readStdMemoryStore(buf, offset: offset + 4)
		loadSlot gives readStdMemoryLoad(buf, offset: offset + 4)
	end 'mem'
end 'readStdMemoryOp'

function readStdMemoryStore(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset)
	let slotId = readQword(buf, offset: offset)
	let valueId = readQword(buf, offset: offset + 8)
	return (StdMemoryOp.storeSlot(slotId, valueId: valueId), offset + 16)
end 'readStdMemoryStore'

function readStdMemoryLoad(buf ByteArray, offset ByteOffset) returns (StdMemoryOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let slotId = readQword(buf, offset: offset + 8)
	return (StdMemoryOp.loadSlot(resultId, slotId: slotId), offset + 16)
end 'readStdMemoryLoad'

// --- StdSystemOp ---
//
// The largest variant set: every system op is serialized tag + payload.
// Each variant has both a `writeStdSys<Variant>` and a
// `readStdSys<Variant>` helper because the language requires single-
// statement match arms.

function writeStdSystemOp(buf ByteArray, op StdSystemOp) throws CacheCorruption
	writeDword(buf, value: op.ordinal)
	match op 'sys'
		globalAddr(resultId, name) then try writeStdSysGlobalAddr(buf, resultId: resultId, name: name)
		memcpy(dstId, srcId, lenId) then writeStdSysMemcpy(buf, dstId: dstId, srcId: srcId, lenId: lenId)
		stackAddr(resultId, slotId) then writeStdSysStackAddr(buf, resultId: resultId, slotId: slotId)
		storeByte(baseId, offsetId, byteId) then writeStdSysStoreByte(buf, baseId: baseId, offsetId: offsetId, byteId: byteId)
		loadByte(resultId, baseId, offsetId) then writeStdSysLoadByte(buf, resultId: resultId, baseId: baseId, offsetId: offsetId)
		osExit(codeId) then writeQword(buf, value: codeId)
		osSleep(msId) then writeQword(buf, value: msId)
		osWrite(ptrId, lenId) then writeStdSysOsWrite(buf, ptrId: ptrId, lenId: lenId)
		free(ptrId) then writeQword(buf, value: ptrId)
		osWriteErr(ptrId, lenId) then writeStdSysOsWriteErr(buf, ptrId: ptrId, lenId: lenId)
		osRead(resultId, ptrId, lenId) then writeStdSysOsRead(buf, resultId: resultId, ptrId: ptrId, lenId: lenId)
		osOpenWrite(resultId, pathPtrId, pathLenId) then writeStdSysOsOpenWrite(buf, resultId: resultId, pathPtrId: pathPtrId, pathLenId: pathLenId)
		osWriteFd(fdId, ptrId, lenId) then writeStdSysOsWriteFd(buf, fdId: fdId, ptrId: ptrId, lenId: lenId)
		osClose(fdId) then writeQword(buf, value: fdId)
		osGetEnv(resultId, namePtrId, nameLenId, outBufPtrId, outBufLenId) then writeStdSysOsGetEnv(buf, resultId: resultId, namePtrId: namePtrId, nameLenId: nameLenId, outBufPtrId: outBufPtrId, outBufLenId: outBufLenId)
		osGetArgc(resultId) then writeQword(buf, value: resultId)
		osClockMs(resultId) then writeQword(buf, value: resultId)
		osGetArgv(resultId, indexId) then writeStdSysOsGetArgv(buf, resultId: resultId, indexId: indexId)
		osGetExecutablePath(resultId, bufPtrId, bufSizeId) then writeStdSysOsGetExecutablePath(buf, resultId: resultId, bufPtrId: bufPtrId, bufSizeId: bufSizeId)
		loadFramePtr(resultId) then writeQword(buf, value: resultId)
		loadIndirect(resultId, addrId, offset, width, signed, isFloat) then writeStdSysLoadIndirect(buf, resultId: resultId, addrId: addrId, offset: offset, width: width, signed: signed, isFloat: isFloat)
		funcAddr(resultId, name) then try writeStdSysFuncAddr(buf, resultId: resultId, name: name)
		storeIndirect(addrId, offset, valueId, width, isFloat) then writeStdSysStoreIndirect(buf, addrId: addrId, offset: offset, valueId: valueId, width: width, isFloat: isFloat)
		drop(valueId) then writeQword(buf, value: valueId)
		osAllocPages(resultId, sizeId) then writeStdSysOsAllocPages(buf, resultId: resultId, sizeId: sizeId)
		osAllocPagesLarge(resultId, sizeId) then writeStdSysOsAllocPagesLarge(buf, resultId: resultId, sizeId: sizeId)
		osFreePages(ptrId, sizeId) then writeStdSysOsFreePages(buf, ptrId: ptrId, sizeId: sizeId)
		osFileOpen(resultId, cStringPtrId, flagsId, fileModeId) then writeStdSysOsFileOpen(buf, resultId: resultId, cStringPtrId: cStringPtrId, flagsId: flagsId, fileModeId: fileModeId)
		osFileRead(resultId, fdId, bufPtrId, countId) then writeStdSysOsFileRead(buf, resultId: resultId, fdId: fdId, bufPtrId: bufPtrId, countId: countId)
		osFileWrite(resultId, fdId, bufPtrId, countId) then writeStdSysOsFileWrite(buf, resultId: resultId, fdId: fdId, bufPtrId: bufPtrId, countId: countId)
		osFileClose(resultId, fdId) then writeStdSysOsFileClose(buf, resultId: resultId, fdId: fdId)
		osFileLseek(resultId, fdId, offsetId, whenceId) then writeStdSysOsFileLseek(buf, resultId: resultId, fdId: fdId, offsetId: offsetId, whenceId: whenceId)
		osFileStat(resultId, cStringPtrId, statBufPtrId) then writeStdSysOsFileStat(buf, resultId: resultId, cStringPtrId: cStringPtrId, statBufPtrId: statBufPtrId)
		osFileAccess(resultId, cStringPtrId, modeId) then writeStdSysOsFileAccess(buf, resultId: resultId, cStringPtrId: cStringPtrId, modeId: modeId)
		osFileUnlink(resultId, cStringPtrId) then writeStdSysOsFileUnlink(buf, resultId: resultId, cStringPtrId: cStringPtrId)
		osDirGetdents64(resultId, fdId, bufPtrId, bufSizeId) then writeStdSysOsDirGetdents64(buf, resultId: resultId, fdId: fdId, bufPtrId: bufPtrId, bufSizeId: bufSizeId)
		osDirGetcwd(resultId, bufPtrId, bufSizeId) then writeStdSysOsDirGetcwd(buf, resultId: resultId, bufPtrId: bufPtrId, bufSizeId: bufSizeId)
		osDirMkdir(resultId, cStringPtrId, modeId) then writeStdSysOsDirMkdir(buf, resultId: resultId, cStringPtrId: cStringPtrId, modeId: modeId)
		atomicInc(addrId) then writeQword(buf, value: addrId)
		atomicDec(addrId) then writeQword(buf, value: addrId)
		atomicXadd(resultId, addrId, valId) then writeStdSysAtomicXadd(buf, resultId: resultId, addrId: addrId, valId: valId)
		atomicCas(resultId, addrId, oldId, newId) then writeStdSysAtomicCas(buf, resultId: resultId, addrId: addrId, oldId: oldId, newId: newId)
		osLockInit(addrId) then writeQword(buf, value: addrId)
		osLockAcquire(addrId) then writeQword(buf, value: addrId)
		osLockRelease(addrId) then writeQword(buf, value: addrId)
		boxValue(resultId, valueId, sizeId) then writeStdSysBoxValue(buf, resultId: resultId, valueId: valueId, sizeId: sizeId)
		unboxValue(resultId, ptrId, sizeId) then writeStdSysUnboxValue(buf, resultId: resultId, ptrId: ptrId, sizeId: sizeId)
		loadLayoutDescriptor(resultId, label) then try writeStdSysLoadLayoutDescriptor(buf, resultId: resultId, label: label)
		loadWitnessTable(resultId, label) then try writeStdSysLoadWitnessTable(buf, resultId: resultId, label: label)
		descriptorField(resultId, descAddrId, field) then writeStdSysDescriptorField(buf, resultId: resultId, descAddrId: descAddrId, field: field)
		witnessMethod(resultId, witnessAddrId, methodIndex) then writeStdSysWitnessMethod(buf, resultId: resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex)
		dropTypeParam(slotValueId, layoutValueId) then writeStdSysDropTypeParam(buf, slotValueId: slotValueId, layoutValueId: layoutValueId)
	end 'sys'
end 'writeStdSystemOp'

function writeStdSysGlobalAddr(buf ByteArray, resultId ValueId, name String) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: name)
end 'writeStdSysGlobalAddr'

function writeStdSysMemcpy(buf ByteArray, dstId ValueId, srcId ValueId, lenId ValueId)
	writeQword(buf, value: dstId)
	writeQword(buf, value: srcId)
	writeQword(buf, value: lenId)
end 'writeStdSysMemcpy'

function writeStdSysStackAddr(buf ByteArray, resultId ValueId, slotId VarSlot)
	writeQword(buf, value: resultId)
	writeQword(buf, value: slotId)
end 'writeStdSysStackAddr'

function writeStdSysStoreByte(buf ByteArray, baseId ValueId, offsetId ValueId, byteId ValueId)
	writeQword(buf, value: baseId)
	writeQword(buf, value: offsetId)
	writeQword(buf, value: byteId)
end 'writeStdSysStoreByte'

function writeStdSysLoadByte(buf ByteArray, resultId ValueId, baseId ValueId, offsetId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: baseId)
	writeQword(buf, value: offsetId)
end 'writeStdSysLoadByte'

function writeStdSysOsWrite(buf ByteArray, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWrite'

function writeStdSysOsWriteErr(buf ByteArray, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWriteErr'

function writeStdSysOsRead(buf ByteArray, resultId ValueId, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsRead'

function writeStdSysOsOpenWrite(buf ByteArray, resultId ValueId, pathPtrId ValueId, pathLenId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: pathPtrId)
	writeQword(buf, value: pathLenId)
end 'writeStdSysOsOpenWrite'

function writeStdSysOsWriteFd(buf ByteArray, fdId ValueId, ptrId ValueId, lenId ValueId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: lenId)
end 'writeStdSysOsWriteFd'

function writeStdSysOsGetEnv(buf ByteArray, resultId ValueId, namePtrId ValueId, nameLenId ValueId, outBufPtrId ValueId, outBufLenId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: namePtrId)
	writeQword(buf, value: nameLenId)
	writeQword(buf, value: outBufPtrId)
	writeQword(buf, value: outBufLenId)
end 'writeStdSysOsGetEnv'

function writeStdSysOsGetArgv(buf ByteArray, resultId ValueId, indexId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: indexId)
end 'writeStdSysOsGetArgv'

function writeStdSysOsGetExecutablePath(buf ByteArray, resultId ValueId, bufPtrId ValueId, bufSizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: bufPtrId)
	writeQword(buf, value: bufSizeId)
end 'writeStdSysOsGetExecutablePath'

function writeStdSysLoadIndirect(buf ByteArray, resultId ValueId, addrId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool)
	writeQword(buf, value: resultId)
	writeQword(buf, value: addrId)
	writeQword(buf, value: offset)
	writeStoreWidthTag(buf, w: width)
	writeBoolByte(buf, b: signed)
	writeBoolByte(buf, b: isFloat)
end 'writeStdSysLoadIndirect'

function writeStdSysFuncAddr(buf ByteArray, resultId ValueId, name String) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: name)
end 'writeStdSysFuncAddr'

function writeStdSysStoreIndirect(buf ByteArray, addrId ValueId, offset MachineWord, valueId ValueId, width StoreWidth, isFloat bool)
	writeQword(buf, value: addrId)
	writeQword(buf, value: offset)
	writeQword(buf, value: valueId)
	writeStoreWidthTag(buf, w: width)
	writeBoolByte(buf, b: isFloat)
end 'writeStdSysStoreIndirect'

function writeStdSysOsAllocPages(buf ByteArray, resultId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsAllocPages'

function writeStdSysOsAllocPagesLarge(buf ByteArray, resultId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsAllocPagesLarge'

function writeStdSysOsFreePages(buf ByteArray, ptrId ValueId, sizeId ValueId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: sizeId)
end 'writeStdSysOsFreePages'

// Phase 15c Stream 4.1 file-I/O ops.
function writeStdSysOsFileOpen(buf ByteArray, resultId ValueId, cStringPtrId ValueId, flagsId ValueId, fileModeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: cStringPtrId)
	writeQword(buf, value: flagsId)
	writeQword(buf, value: fileModeId)
end 'writeStdSysOsFileOpen'

function writeStdSysOsFileRead(buf ByteArray, resultId ValueId, fdId ValueId, bufPtrId ValueId, countId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: bufPtrId)
	writeQword(buf, value: countId)
end 'writeStdSysOsFileRead'

function writeStdSysOsFileWrite(buf ByteArray, resultId ValueId, fdId ValueId, bufPtrId ValueId, countId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: bufPtrId)
	writeQword(buf, value: countId)
end 'writeStdSysOsFileWrite'

function writeStdSysOsFileClose(buf ByteArray, resultId ValueId, fdId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: fdId)
end 'writeStdSysOsFileClose'

function writeStdSysOsFileLseek(buf ByteArray, resultId ValueId, fdId ValueId, offsetId ValueId, whenceId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: offsetId)
	writeQword(buf, value: whenceId)
end 'writeStdSysOsFileLseek'

function writeStdSysOsFileStat(buf ByteArray, resultId ValueId, cStringPtrId ValueId, statBufPtrId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: cStringPtrId)
	writeQword(buf, value: statBufPtrId)
end 'writeStdSysOsFileStat'

function writeStdSysOsFileAccess(buf ByteArray, resultId ValueId, cStringPtrId ValueId, modeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: cStringPtrId)
	writeQword(buf, value: modeId)
end 'writeStdSysOsFileAccess'

function writeStdSysOsFileUnlink(buf ByteArray, resultId ValueId, cStringPtrId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: cStringPtrId)
end 'writeStdSysOsFileUnlink'

function writeStdSysOsDirGetdents64(buf ByteArray, resultId ValueId, fdId ValueId, bufPtrId ValueId, bufSizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: fdId)
	writeQword(buf, value: bufPtrId)
	writeQword(buf, value: bufSizeId)
end 'writeStdSysOsDirGetdents64'

function writeStdSysOsDirGetcwd(buf ByteArray, resultId ValueId, bufPtrId ValueId, bufSizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: bufPtrId)
	writeQword(buf, value: bufSizeId)
end 'writeStdSysOsDirGetcwd'

function writeStdSysOsDirMkdir(buf ByteArray, resultId ValueId, cStringPtrId ValueId, modeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: cStringPtrId)
	writeQword(buf, value: modeId)
end 'writeStdSysOsDirMkdir'

function writeStdSysAtomicXadd(buf ByteArray, resultId ValueId, addrId ValueId, valId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: addrId)
	writeQword(buf, value: valId)
end 'writeStdSysAtomicXadd'

function writeStdSysAtomicCas(buf ByteArray, resultId ValueId, addrId ValueId, oldId ValueId, newId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: addrId)
	writeQword(buf, value: oldId)
	writeQword(buf, value: newId)
end 'writeStdSysAtomicCas'

function writeStdSysBoxValue(buf ByteArray, resultId ValueId, valueId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: valueId)
	writeQword(buf, value: sizeId)
end 'writeStdSysBoxValue'

function writeStdSysUnboxValue(buf ByteArray, resultId ValueId, ptrId ValueId, sizeId ValueId)
	writeQword(buf, value: resultId)
	writeQword(buf, value: ptrId)
	writeQword(buf, value: sizeId)
end 'writeStdSysUnboxValue'

function writeStdSysLoadLayoutDescriptor(buf ByteArray, resultId ValueId, label String) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: label)
end 'writeStdSysLoadLayoutDescriptor'

function writeStdSysLoadWitnessTable(buf ByteArray, resultId ValueId, label String) throws CacheCorruption
	writeQword(buf, value: resultId)
	try writeString(buf, s: label)
end 'writeStdSysLoadWitnessTable'

function writeStdSysDescriptorField(buf ByteArray, resultId ValueId, descAddrId ValueId, field DescriptorField)
	writeQword(buf, value: resultId)
	writeQword(buf, value: descAddrId)
	writeDword(buf, value: field.ordinal)
end 'writeStdSysDescriptorField'

function writeStdSysWitnessMethod(buf ByteArray, resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord)
	writeQword(buf, value: resultId)
	writeQword(buf, value: witnessAddrId)
	writeQword(buf, value: methodIndex)
end 'writeStdSysWitnessMethod'

function writeStdSysDropTypeParam(buf ByteArray, slotValueId ValueId, layoutValueId ValueId)
	writeQword(buf, value: slotValueId)
	writeQword(buf, value: layoutValueId)
end 'writeStdSysDropTypeParam'

function readStdSystemOp(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let kase = try StdSystemOp.unionCases.fromRawValue(raw) otherwise throw CacheCorruption.invalidEncoding
	let pos = offset + 4
	return match kase 'sys'
		globalAddr gives try readStdSysGlobalAddr(buf, offset: pos)
		memcpy gives readStdSysMemcpy(buf, offset: pos)
		stackAddr gives readStdSysStackAddr(buf, offset: pos)
		storeByte gives readStdSysStoreByte(buf, offset: pos)
		loadByte gives readStdSysLoadByte(buf, offset: pos)
		osExit gives readStdSysOsExit(buf, offset: pos)
		osSleep gives readStdSysOsSleep(buf, offset: pos)
		osWrite gives readStdSysOsWrite(buf, offset: pos)
		free gives readStdSysFree(buf, offset: pos)
		osWriteErr gives readStdSysOsWriteErr(buf, offset: pos)
		osRead gives readStdSysOsRead(buf, offset: pos)
		osOpenWrite gives readStdSysOsOpenWrite(buf, offset: pos)
		osWriteFd gives readStdSysOsWriteFd(buf, offset: pos)
		osClose gives readStdSysOsClose(buf, offset: pos)
		osGetEnv gives readStdSysOsGetEnv(buf, offset: pos)
		osGetArgc gives readStdSysOsGetArgc(buf, offset: pos)
		osClockMs gives readStdSysOsClockMs(buf, offset: pos)
		osGetArgv gives readStdSysOsGetArgv(buf, offset: pos)
		osGetExecutablePath gives readStdSysOsGetExecutablePath(buf, offset: pos)
		loadFramePtr gives readStdSysLoadFramePtr(buf, offset: pos)
		loadIndirect gives readStdSysLoadIndirect(buf, offset: pos)
		funcAddr gives try readStdSysFuncAddr(buf, offset: pos)
		storeIndirect gives readStdSysStoreIndirect(buf, offset: pos)
		drop gives readStdSysDrop(buf, offset: pos)
		osAllocPages gives readStdSysOsAllocPages(buf, offset: pos)
		osAllocPagesLarge gives readStdSysOsAllocPagesLarge(buf, offset: pos)
		osFreePages gives readStdSysOsFreePages(buf, offset: pos)
		osFileOpen gives readStdSysOsFileOpen(buf, offset: pos)
		osFileRead gives readStdSysOsFileRead(buf, offset: pos)
		osFileWrite gives readStdSysOsFileWrite(buf, offset: pos)
		osFileClose gives readStdSysOsFileClose(buf, offset: pos)
		osFileLseek gives readStdSysOsFileLseek(buf, offset: pos)
		osFileStat gives readStdSysOsFileStat(buf, offset: pos)
		osFileAccess gives readStdSysOsFileAccess(buf, offset: pos)
		osFileUnlink gives readStdSysOsFileUnlink(buf, offset: pos)
		osDirGetdents64 gives readStdSysOsDirGetdents64(buf, offset: pos)
		osDirGetcwd gives readStdSysOsDirGetcwd(buf, offset: pos)
		osDirMkdir gives readStdSysOsDirMkdir(buf, offset: pos)
		atomicInc gives readStdSysAtomicInc(buf, offset: pos)
		atomicDec gives readStdSysAtomicDec(buf, offset: pos)
		atomicXadd gives readStdSysAtomicXadd(buf, offset: pos)
		atomicCas gives readStdSysAtomicCas(buf, offset: pos)
		osLockInit gives readStdSysOsLockInit(buf, offset: pos)
		osLockAcquire gives readStdSysOsLockAcquire(buf, offset: pos)
		osLockRelease gives readStdSysOsLockRelease(buf, offset: pos)
		boxValue gives readStdSysBoxValue(buf, offset: pos)
		unboxValue gives readStdSysUnboxValue(buf, offset: pos)
		loadLayoutDescriptor gives try readStdSysLoadLayoutDescriptor(buf, offset: pos)
		loadWitnessTable gives try readStdSysLoadWitnessTable(buf, offset: pos)
		descriptorField gives try readStdSysDescriptorField(buf, offset: pos)
		witnessMethod gives readStdSysWitnessMethod(buf, offset: pos)
		dropTypeParam gives readStdSysDropTypeParam(buf, offset: pos)
	end 'sys'
end 'readStdSystemOp'

function readStdSysGlobalAddr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset) throws CacheCorruption
	let resultId = readQword(buf, offset: offset)
	let (name, p) = try readString(buf, offset: offset + 8)
	return (StdSystemOp.globalAddr(resultId, name: name), p)
end 'readStdSysGlobalAddr'

function readStdSysMemcpy(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let dstId = readQword(buf, offset: offset)
	let srcId = readQword(buf, offset: offset + 8)
	let lenId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.memcpy(dstId, srcId: srcId, lenId: lenId), offset + 24)
end 'readStdSysMemcpy'

function readStdSysStackAddr(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let slotId = readQword(buf, offset: offset + 8)
	return (StdSystemOp.stackAddr(resultId, slotId: slotId), offset + 16)
end 'readStdSysStackAddr'

function readStdSysStoreByte(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let baseId = readQword(buf, offset: offset)
	let offsetId = readQword(buf, offset: offset + 8)
	let byteId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.storeByte(baseId, offsetId: offsetId, byteId: byteId), offset + 24)
end 'readStdSysStoreByte'

function readStdSysLoadByte(buf ByteArray, offset ByteOffset) returns (StdSystemOp, ByteOffset)
	let resultId = readQword(buf, offset: offset)
	let baseId = readQword(buf, offset: offset + 8)
	let offsetId = readQword(buf, offset: offset + 16)
	return (StdSystemOp.loadByte(resultId, baseId: baseId, offsetId: offsetId), offset + 24)
end 'readStdSysLoadByte'


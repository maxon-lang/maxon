    ]

// actionTable: 32 entries indexed by state → action to perform
//              start           sawEq          sawBang        sawLt          sawGt          sawSlash       skipWs         skipCr
let actionTable = [Action.skip, Action.skip,   Action.skip,   Action.skip,   Action.skip,   Action.skip,   Action.skip,   Action.skipCr,
//              newline         lParen         rParen         lBrace         rBrace         plus           minus          star           colon
                Action.newline, Action.emit,   Action.emit,   Action.emit,   Action.emit,   Action.emit,   Action.emit,   Action.emit,   Action.emit,
//              eq              eqEq           bangEq         lt             ltEq           gt             gtEq
                Action.emit,    Action.emit,   Action.emit2,  Action.emit2,  Action.emit,   Action.emit2,  Action.emit,
//              skipBang        enterSquote      enterDquote      enterDigit      enterAlpha      enterComment   skipSlash      skipOther
                Action.skip,    Action.enterStrSq, Action.enterStrDq, Action.enterNumber, Action.enterIdent, Action.enterComment, Action.skip, Action.skip
    ]

function singleByte(b Byte) returns ByteArray
    var arr = ByteArray{}
    arr.push(b)
    return arr
end 'singleByte'

function twoBytes(a Byte, b Byte) returns ByteArray
    var arr = ByteArray{}
    arr.push(a)
    arr.push(b)
    return arr
end 'twoBytes'

// Single dispatch point for all fixed-text tokens (operators, punctuation).
// Token values are built as ByteArray directly — String literals assigned to
// ByteArray fields in struct literals cause memory corruption in the self-hosted binary.
function emitFixedToken(state DfaIndex, tokens TokenArray, line LineNumber, column ColumnNumber)
    match state 'dispatch'
        9 then tokens.push({kind: TokenKind.leftParen, value: singleByte(40), line: line, column: column})
        10 then tokens.push({kind: TokenKind.rightParen, value: singleByte(41), line: line, column: column})
        11 then tokens.push({kind: TokenKind.leftBrace, value: singleByte(123), line: line, column: column})
        12 then tokens.push({kind: TokenKind.rightBrace, value: singleByte(125), line: line, column: column})
        13 then tokens.push({kind: TokenKind.plus, value: singleByte(43), line: line, column: column})
        14 then tokens.push({kind: TokenKind.minus, value: singleByte(45), line: line, column: column})
        15 then tokens.push({kind: TokenKind.star, value: singleByte(42), line: line, column: column})
        16 then tokens.push({kind: TokenKind.colon, value: singleByte(58), line: line, column: column})
        17 then tokens.push({kind: TokenKind.equals, value: singleByte(61), line: line, column: column})
        18 then tokens.push({kind: TokenKind.equalsEquals, value: twoBytes(61, b: 61), line: line, column: column})
        19 then tokens.push({kind: TokenKind.bangEquals, value: twoBytes(33, b: 61), line: line, column: column})
        20 then tokens.push({kind: TokenKind.lessThan, value: singleByte(60), line: line, column: column})
        21 then tokens.push({kind: TokenKind.lessEquals, value: twoBytes(60, b: 61), line: line, column: column})
        22 then tokens.push({kind: TokenKind.greaterThan, value: singleByte(62), line: line, column: column})
        23 then tokens.push({kind: TokenKind.greaterEquals, value: twoBytes(62, b: 61), line: line, column: column})
        default then break
    end 'dispatch'
end 'emitFixedToken'

// --- Main tokenize function ---

export function tokenize(source ByteArray) returns TokenArray
    logDebug(LogCategory.lexer, message: "Starting lexer")

    var tokens = TokenArray{}
    var s = LexerState{pos: 0, line: 1, column: 1}
    let len = source.count()

    while s.pos < len 'scan'
        let ch = try source.get(s.pos) otherwise 0
        let startLine = s.line
        let startCol = s.column

        // Look up character class
        let charClass = try charClassTable.get(ch) otherwise 0

        // Consume the first character
        s.pos = s.pos + 1
        s.column = s.column + 1

        // Look up first transition from START
        var state = try transitionTable.get(DfaState.start * CharClass.COUNT + charClass) otherwise DfaState.skipOther

        // If we reached a live state (1-5), peek at the next character for a second transition
        if state >= DfaState.sawEq and state <= DfaState.sawSlash 'live'
            var nextClass = CharClass.eof
            if s.pos < len 'hasNext'
                let nextCh = try source.get(s.pos) otherwise 0
                nextClass = try charClassTable.get(nextCh) otherwise CharClass.other
            end 'hasNext'
            state = try transitionTable.get(state * CharClass.COUNT + nextClass) otherwise DfaState.skipOther
        end 'live'

        // Look up the action for the terminal state
        let action = try actionTable.get(state) otherwise Action.skip

        if action == Action.skip 'doSkip'
            continue
        end 'doSkip'

        if action == Action.skipCr 'doCr'
            // CR does not advance column
            s.column = s.column - 1
            continue
        end 'doCr'

        if action == Action.newline 'doNewline'
            tokens.push({kind: TokenKind.newline, value: ByteArray{}, line: startLine, column: startCol})
            s.line = s.line + 1
            s.column = 1
            continue
        end 'doNewline'

        if action == Action.emit 'doEmit'
            emitFixedToken(state, tokens: tokens, line: startLine, column: startCol)
            continue
        end 'doEmit'

        if action == Action.emit2 'doEmit2'
            s.pos = s.pos + 1
            s.column = s.column + 1
            emitFixedToken(state, tokens: tokens, line: startLine, column: startCol)
            continue
        end 'doEmit2'

        if action == Action.enterStrSq 'doSQ'
            scanSingleQuoteString(source, state: s, tokens: tokens, startLine: startLine, startCol: startCol)
            continue
        end 'doSQ'

        if action == Action.enterStrDq 'doDQ'
            scanDoubleQuoteString(source, state: s, tokens: tokens, startLine: startLine, startCol: startCol)
            continue
        end 'doDQ'

        if action == Action.enterNumber 'doNum'
            // Undo advance — scanNumber scans from the first digit
            s.pos = s.pos - 1
            s.column = s.column - 1
            scanNumber(source, state: s, tokens: tokens, startLine: startLine, startCol: startCol)
            continue
        end 'doNum'

        if action == Action.enterIdent 'doIdent'
            // Undo advance — scanIdentifier scans from the first alpha char
            s.pos = s.pos - 1
            s.column = s.column - 1
            scanIdentifier(source, state: s, tokens: tokens, startLine: startLine, startCol: startCol)
            continue
        end 'doIdent'

        if action == Action.enterComment 'doComment'
            // Both '/' characters have been consumed (first by main loop, second needs consuming)
            s.pos = s.pos + 1
            s.column = s.column + 1
            scanComment(source, state: s)
            continue
        end 'doComment'
    end 'scan'

    tokens.push({kind: TokenKind.eof, value: ByteArray{}, line: s.line, column: s.column})
    logDebug(LogCategory.lexer, message: "Lexer complete: {tokens.count()} tokens")
    return tokens
end 'tokenize'

// --- Sub-scanner functions ---

// Opening quote already consumed by main loop.
function scanSingleQuoteString(source ByteArray, state LexerState, tokens TokenArray, startLine LineNumber, startCol ColumnNumber)
    let len = source.count()
    let strStart = state.pos
    while state.pos < len 'strBody'
        let sc = try source.get(state.pos) otherwise 0
        if sc == Ascii.quote 'endStr'
            break
        end 'endStr'
        state.pos = state.pos + 1
        state.column = state.column + 1
    end 'strBody'
    let strVal = sliceBytes(source, startPos: strStart, endPos: state.pos)
    // Consume the closing quote
    state.pos = state.pos + 1
    state.column = state.column + 1
    tokens.push(Token{kind: TokenKind.stringLiteral, value: strVal, line: startLine, column: startCol})
end 'scanSingleQuoteString'

// Opening double-quote already consumed by main loop.
function scanDoubleQuoteString(source ByteArray, state LexerState, tokens TokenArray, startLine LineNumber, startCol ColumnNumber)
    let len = source.count()
    let dstrStart = state.pos
    while state.pos < len 'dstrBody'
        let dc = try source.get(state.pos) otherwise 0
        if dc == Ascii.dquote 'endDstr'
            break
        end 'endDstr'
        if dc == Ascii.backslash 'esc'
            state.pos = state.pos + 1
            state.column = state.column + 1
        end 'esc'
        state.pos = state.pos + 1
        state.column = state.column + 1
    end 'dstrBody'
    let dstrVal = sliceBytes(source, startPos: dstrStart, endPos: state.pos)
    // Consume the closing double-quote
    state.pos = state.pos + 1
    state.column = state.column + 1
    tokens.push({kind: TokenKind.doubleStringLiteral, value: dstrVal, line: startLine, column: startCol})
end 'scanDoubleQuoteString'

// pos points to the first digit (not yet consumed by this scanner).
function scanNumber(source ByteArray, state LexerState, tokens TokenArray, startLine LineNumber, startCol ColumnNumber)
    let len = source.count()
    let numStart = state.pos
    while state.pos < len 'digits'
        let dc = try source.get(state.pos) otherwise 0
        if not isDigit(dc) 'endNum'
            break
        end 'endNum'
        state.pos = state.pos + 1
        state.column = state.column + 1
    end 'digits'
    // Check for decimal point (float literal)
    var isFloat = false
    if state.pos < len 'checkDot'
        let dotCh = try source.get(state.pos) otherwise 0
        if dotCh == Ascii.dot 'hasDot'
            isFloat = true
            state.pos = state.pos + 1
            state.column = state.column + 1
            while state.pos < len 'fracDigits'
                let fc = try source.get(state.pos) otherwise 0
                if not isDigit(fc) 'endFrac'
                    break
                end 'endFrac'
                state.pos = state.pos + 1
                state.column = state.column + 1
            end 'fracDigits'
        end 'hasDot'
    end 'checkDot'
    let numVal = sliceBytes(source, startPos: numStart, endPos: state.pos)
    if isFloat 'emitFloat'
        tokens.push({kind: TokenKind.floatLiteral, value: numVal, line: startLine, column: startCol})
    end 'emitFloat' else 'emitInt'
        tokens.push({kind: TokenKind.intLiteral, value: numVal, line: startLine, column: startCol})
    end 'emitInt'
end 'scanNumber'

// pos points to the first alpha/underscore (not yet consumed by this scanner).
function scanIdentifier(source ByteArray, state LexerState, tokens TokenArray, startLine LineNumber, startCol ColumnNumber)
    let len = source.count()
    let startPos = state.pos
    while state.pos < len 'identBody'
        let ic = try source.get(state.pos) otherwise 0
        if not isAlphaNum(ic) 'endIdent'
            break
        end 'endIdent'
        state.pos = state.pos + 1
        state.column = state.column + 1
    end 'identBody'
    let identVal = sliceBytes(source, startPos: startPos, endPos: state.pos)
    let identBuf = ByteBuffer{managed: identVal.managed}
    let kind = classifyIdentifier(identBuf)
    tokens.push({kind: kind, value: identVal, line: startLine, column: startCol})
end 'scanIdentifier'

// Both '/' characters already consumed. Advances to (but not past) the newline.
function scanComment(source ByteArray, state LexerState)
    let len = source.count()
    while state.pos < len 'skipComment'
        let cc = try source.get(state.pos) otherwise 0
        if cc == Ascii.lf 'endComment'
            break
        end 'endComment'
        state.pos = state.pos + 1
    end 'skipComment'
end 'scanComment'

// --- Helpers ---

function isDigit(b Byte) returns bool
    return b >= 48 and b <= 57
end 'isDigit'

// Valid identifier start: letter (A-Z, a-z) or underscore
function isAlpha(b Byte) returns bool
    return (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or b == 95
end 'isAlpha'

// Valid identifier continuation: letter, digit, or underscore
function isAlphaNum(b Byte) returns bool
    return isAlpha(b) or isDigit(b)
end 'isAlphaNum'

export function sliceBytes(source ByteArray, startPos CharOffset, endPos CharOffset) returns ByteArray
    var sliced = source.slice(startPos, endIndex: endPos)
    return {managed: sliced.managed}
end 'sliceBytes'

export function bytesToByteArray(src ByteBuffer) returns ByteArray
    return {managed: src.managed}
end 'bytesToByteArray'

// Element-wise comparison for ByteArrays (== does pointer comparison in self-hosted binary).
export function bytesEqual(a ByteArray, b ByteArray) returns bool
    let aLen = a.count()
    if aLen != b.count() 'lenMismatch'
        return false
    end 'lenMismatch'
    var i = 0
    while i < aLen 'cmp'
        let ab = try a.get(i) otherwise 0
        let bb = try b.get(i) otherwise 1
        if ab != bb 'ne'
            return false
        end 'ne'
        i = i + 1
    end 'cmp'
    return true
end 'bytesEqual'

export type KeywordInfo
    export var kind TokenKind
    export var helpText String
    export var canHaveBlockLabel bool
end 'KeywordInfo'

var keywordMap = [
    b"if":          KeywordInfo{kind: TokenKind.if,          helpText: "Conditional statement. Executes code if the condition is true.",                                                    canHaveBlockLabel: true},
    b"else":        KeywordInfo{kind: TokenKind.else,        helpText: "Alternative branch in an if statement. Executed when the condition is false.",                                      canHaveBlockLabel: true},
    b"while":       KeywordInfo{kind: TokenKind.while,       helpText: "Loop that continues while the condition is true.",                                                                   canHaveBlockLabel: true},
    b"for":         KeywordInfo{kind: TokenKind.for,         helpText: "Loop that iterates over a range or collection.",                                                                     canHaveBlockLabel: true},
    b"in":          KeywordInfo{kind: TokenKind.in,          helpText: "Used in for loops to specify the range or collection to iterate over.",                                             canHaveBlockLabel: false},
    b"break":       KeywordInfo{kind: TokenKind.break,       helpText: "Exits the current loop or match statement.",                                                                         canHaveBlockLabel: false},
    b"continue":    KeywordInfo{kind: TokenKind.continue,    helpText: "Skips the rest of the current loop iteration and continues with the next iteration.",                               canHaveBlockLabel: false},
    b"return":      KeywordInfo{kind: TokenKind.return,      helpText: "Returns a value from a function and exits the function.",                                                           canHaveBlockLabel: false},
    b"end":         KeywordInfo{kind: TokenKind.end,         helpText: "Ends a block (function, type, if, for, while, etc.). Must be followed by the block's label in quotes.",            canHaveBlockLabel: true},
    b"match":       KeywordInfo{kind: TokenKind.match,       helpText: "Pattern matching statement for unions and values.",                                                                  canHaveBlockLabel: false},
    b"then":        KeywordInfo{kind: TokenKind.then,        helpText: "Used in match expressions to separate pattern from result.",                                                        canHaveBlockLabel: true},
    b"fallthrough": KeywordInfo{kind: TokenKind.fallthrough, helpText: "Falls through to the next case in a match statement.",                                                              canHaveBlockLabel: false},
    b"default":     KeywordInfo{kind: TokenKind.default,     helpText: "Default case in a match statement.",                                                                                canHaveBlockLabel: false},
    b"upto":        KeywordInfo{kind: TokenKind.upto,        helpText: "Exclusive upper bound in range patterns.",                                                                          canHaveBlockLabel: false},
    b"gives":       KeywordInfo{kind: TokenKind.gives,       helpText: "Used in iterator expressions.",                                                                                     canHaveBlockLabel: false},
    b"try":         KeywordInfo{kind: TokenKind.try,         helpText: "Attempts an operation that may throw an error.",                                                                    canHaveBlockLabel: false},
    b"otherwise":   KeywordInfo{kind: TokenKind.otherwise,   helpText: "Provides a fallback for try expressions when an error occurs.",                                                    canHaveBlockLabel: true},
    b"throw":       KeywordInfo{kind: TokenKind.throw,       helpText: "Throws an error that can be caught by a try-catch block.",                                                         canHaveBlockLabel: false},
    b"ignore":      KeywordInfo{kind: TokenKind.ignore,      helpText: "Used with otherwise to silently ignore errors.",                                                                    canHaveBlockLabel: false},
    b"function":    KeywordInfo{kind: TokenKind.function,    helpText: "Declares a function. Functions contain executable code and can return values.",                                    canHaveBlockLabel: false},
    b"returns":     KeywordInfo{kind: TokenKind.returns,     helpText: "Specifies the return type of a function.",                                                                          canHaveBlockLabel: false},
    b"let":         KeywordInfo{kind: TokenKind.let,         helpText: "Declares an immutable variable. The value cannot be changed after initialization.",                                canHaveBlockLabel: false},
    b"var":         KeywordInfo{kind: TokenKind.var,         helpText: "Declares a mutable variable. The value can be changed after initialization.",                                      canHaveBlockLabel: false},
    b"type":        KeywordInfo{kind: TokenKind.type,        helpText: "Declares a struct type with fields and methods.",                                                                   canHaveBlockLabel: false},
    b"union":       KeywordInfo{kind: TokenKind.union,       helpText: "Declares a union type with a fixed set of named cases, optional associated values, and methods.",                    canHaveBlockLabel: false},
    b"enum":        KeywordInfo{kind: TokenKind.enum,        helpText: "Declares a named group of typed constant values with no methods.",                                                      canHaveBlockLabel: false},
    b"typealias":   KeywordInfo{kind: TokenKind.typealias,   helpText: "Declares a type alias for an existing type or associated type in an interface.",                                   canHaveBlockLabel: false},
    b"export":      KeywordInfo{kind: TokenKind.export,      helpText: "Makes a function or type visible to other modules.",                                                                canHaveBlockLabel: false},
    b"static":      KeywordInfo{kind: TokenKind.static,      helpText: "Declares a static method that doesn't require an instance.",                                                       canHaveBlockLabel: false},
    b"interface":   KeywordInfo{kind: TokenKind.interface,   helpText: "Declares an interface that types can conform to.",                                                                  canHaveBlockLabel: false},
    b"extension":   KeywordInfo{kind: TokenKind.extension,   helpText: "Defines extension methods for an interface.",                                                                       canHaveBlockLabel: false},
    b"extends":     KeywordInfo{kind: TokenKind.extends,     helpText: "Indicates interface inheritance.",                                                                                  canHaveBlockLabel: false},
    b"uses":        KeywordInfo{kind: TokenKind.uses,        helpText: "Declares associated types in an interface.",                                                                        canHaveBlockLabel: false},
    b"with":        KeywordInfo{kind: TokenKind.with,        helpText: "Specifies interface conformance requirements.",                                                                     canHaveBlockLabel: false},
    b"where":       KeywordInfo{kind: TokenKind.where,       helpText: "Constrains type parameters to require interface conformance.",                                                     canHaveBlockLabel: false},
    b"self":        KeywordInfo{kind: TokenKind.self,        helpText: "Refers to the current instance in a method.",                                                                       canHaveBlockLabel: false},
    b"Self":        KeywordInfo{kind: TokenKind.selfType,    helpText: "Refers to the current type in a method signature.",                                                                 canHaveBlockLabel: false},
    b"throws":      KeywordInfo{kind: TokenKind.throws,      helpText: "Indicates that a function may throw an error.",                                                                     canHaveBlockLabel: false},
    b"from":        KeywordInfo{kind: TokenKind.from,        helpText: "Used in range expressions (from X to Y).",                                                                         canHaveBlockLabel: false},
    b"to":          KeywordInfo{kind: TokenKind.to,          helpText: "Used in range expressions (from X to Y).",                                                                         canHaveBlockLabel: false},
    b"mod":         KeywordInfo{kind: TokenKind.mod,         helpText: "Modulo operator. Returns the remainder of integer division.",                                                      canHaveBlockLabel: false},
    b"and":         KeywordInfo{kind: TokenKind.and,         helpText: "AND operator. Logical AND on bools, bitwise AND on integers.",                                                     canHaveBlockLabel: false},
    b"or":          KeywordInfo{kind: TokenKind.or,          helpText: "OR operator. Logical OR on bools, bitwise OR on integers.",                                                        canHaveBlockLabel: true},
    b"not":         KeywordInfo{kind: TokenKind.not,         helpText: "NOT operator. Logical NOT on bools, bitwise NOT on integers.",                                                     canHaveBlockLabel: false},
    b"xor":         KeywordInfo{kind: TokenKind.xor,         helpText: "XOR operator. Logical XOR on bools, bitwise XOR on integers.",                                                    canHaveBlockLabel: false},
    b"shl":         KeywordInfo{kind: TokenKind.shl,         helpText: "Shift left operator. Shifts integer bits to the left.",                                                            canHaveBlockLabel: false},
    b"shr":         KeywordInfo{kind: TokenKind.shr,         helpText: "Shift right operator. Shifts integer bits to the right.",                                                          canHaveBlockLabel: false},
    b"as":          KeywordInfo{kind: TokenKind.as,          helpText: "Type cast operator. Converts a value to a different type.",                                                        canHaveBlockLabel: false},
    b"implements":  KeywordInfo{kind: TokenKind.implements,  helpText: "Specifies that a type conforms to an interface.",                                                                   canHaveBlockLabel: false},
    b"true":        KeywordInfo{kind: TokenKind.true,        helpText: "Boolean literal representing true.",                                                                                canHaveBlockLabel: false},
    b"false":       KeywordInfo{kind: TokenKind.false,       helpText: "Boolean literal representing false.",                                                                               canHaveBlockLabel: false},
    b"int":         KeywordInfo{kind: TokenKind.int,         helpText: "Primitive integer type (64-bit signed).",                                                                           canHaveBlockLabel: false},
    b"float":       KeywordInfo{kind: TokenKind.float,       helpText: "Primitive floating-point type (64-bit double precision).",                                                         canHaveBlockLabel: false},
    b"bool":        KeywordInfo{kind: TokenKind.bool,        helpText: "Primitive boolean type (true or false).",                                                                           canHaveBlockLabel: false},
    b"byte":        KeywordInfo{kind: TokenKind.byte,        helpText: "Primitive byte type (8-bit unsigned integer).",                                                                    canHaveBlockLabel: false},
    b"array":       KeywordInfo{kind: TokenKind.array,       helpText: "Used in array type declarations (array of int).",                                                                   canHaveBlockLabel: false},
    b"of":          KeywordInfo{kind: TokenKind.of,          helpText: "Used in array type declarations (array of int).",                                                                   canHaveBlockLabel: false},
    b"print":       KeywordInfo{kind: TokenKind.print,       helpText: "Built-in function for printing to the console. Not a real keyword.",                                               canHaveBlockLabel: false}
]

function classifyIdentifier(name ByteBuffer) returns TokenKind
    let info = try keywordMap.get(key: name) otherwise 'notFound'
        return TokenKind.identifier
    end 'notFound'
    return info.kind
end 'classifyIdentifier'

// ASCII byte enum
enum Ascii
    lf        = 10
    quote     = 39
    dquote    = 34
    dot       = 46
    backslash = 92
end 'Ascii'

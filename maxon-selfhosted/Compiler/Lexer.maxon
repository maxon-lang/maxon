    // sawSlash: '/' seen, looking for '/'
    DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.enterComment, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash, DfaState.skipSlash,
    // Terminal states (rows 6-31) — never transitioned from
    DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther,
    DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther, DfaState.skipOther,

// Table-driven DFA lexer for Maxon source code.
// Accepts a String source, converts to ByteArray internally for efficient byte-level scanning,
// and produces tokens with String values sliced from the original source.

export typealias LineNumber = int(0 to u64.max)
export typealias ColumnNumber = int(0 to u64.max)
export typealias CharOffset = int(0 to u64.max)

typealias ByteCursor = ArrayIterator with Byte

export union LexerError implements Error
	unexpectedEof(line LineNumber, column ColumnNumber)
	unterminatedString(line LineNumber, column ColumnNumber)
	unterminatedBlockComment(line LineNumber, column ColumnNumber)
end 'LexerError'

// --- Character classes ---
enum CharClass
	other
	space
	tab
	cr
	lf
	lParen
	rParen
	lBrace
	rBrace
	lBracket
	rBracket
	equals
	bang
	less
	greater
	plus
	minus
	star
	colon
	slash
	squote
	dquote
	backslash
	dot
	digit
	alpha
	eof
	COUNT
end 'CharClass'

// --- DFA states ---
enum DfaState
	// Live states (need more input)
	start
	sawEq
	sawBang
	sawLt
	sawGt
	sawSlash
	// Terminal states
	skipWs
	skipCr
	newline
	lParen
	rParen
	lBrace
	rBrace
	plus
	minus
	star
	colon
	eq
	eqEq
	bangEq
	lt
	ltEq
	gt
	gtEq
	bang
	enterSquote
	enterDquote
	enterDigit
	enterAlpha
	enterComment
	enterBlockComment
	slash
	skipOther
	dot
	lBracket
	rBracket
	emitBackslash
	COUNT
end 'DfaState'

// --- Action codes ---
// Start at 1 so 0 is never a valid action (catches uninitialized table entries)
enum Action
	skip = 1
	skipCr
	newline
	emit
	emit2
	enterStrSq
	enterStrDq
	enterNumber
	enterIdent
	enterComment
	enterBlockComment
end 'Action'

// --- Token kind enum ---
// String-backed: each variant carries its diagnostic display text as
// `.rawValue`, so error messages can stringify a kind directly without
// needing a separate display lookup. Comparisons remain ordinal-based.
// Backing strings carry no surrounding quotes — callers that want the
// quoted form (e.g. `'function'` in expected-token diagnostics) wrap
// the value at the use site.
export enum TokenKind
	// Top level
	function = "function"
	let = "let"
	typealias = "typealias"
	export = "export"
	// Control flow
	if = "if"
	else = "else"
	while = "while"
	for = "for"
	in = "in"
	break = "break"
	continue = "continue"
	return = "return"
	panic = "panic"
	end = "end"
	match = "match"
	then = "then"
	fallthrough = "fallthrough"
	default = "default"
	upto = "upto"
	gives = "gives"
	try = "try"
	otherwise = "otherwise"
	throw = "throw"
	ignore = "ignore"
	// Declarations
	returns = "returns"
	var = "var"
	type = "type"
	union = "union"
	enum = "enum"
	static = "static"
	interface = "interface"
	extension = "extension"
	extends = "extends"
	implements = "implements"
	uses = "uses"
	with = "with"
	where = "where"
	self = "self"
	selfType = "Self"
	throws = "throws"
	from = "from"
	to = "to"
	mod = "mod"
	// Logical / bitwise operators
	and = "and"
	or = "or"
	not = "not"
	xor = "xor"
	shl = "shl"
	shr = "shr"
	as = "as"
	is = "is"
	// Literals
	true = "true"
	false = "false"
	// Primitive types
	int = "int"
	float = "float"
	bool = "bool"
	byte = "byte"
	// Other
	array = "array"
	of = "of"
	// Literals
	intLiteral = "integer literal"
	floatLiteral = "float literal"
	charLiteral = "character literal"
	stringLiteral = "string literal"
	// Delimiters for pre-lexed interpolation expressions. A double-quoted
	// string containing `{...}` interpolations emits as:
	//   stringLiteral("fragment0") stringInterpStart <expr tokens> stringInterpEnd
	//   stringLiteral("fragment1") stringInterpStart <expr tokens> stringInterpEnd
	//   ...
	//   stringLiteral("fragmentN")
	// Strings without interpolations emit a single stringLiteral as
	// before. This lets the parser consume interpolated expressions inline
	// from the main token stream instead of re-lexing the expression bytes
	// through a sub-parser for every `{...}` segment.
	stringInterpStart = "interpolation start"
	stringInterpEnd = "interpolation end"
	// Identifiers
	identifier = "identifier"
	// Punctuation
	leftParen = "("
	rightParen = ")"
	leftBrace = "\{"
	rightBrace = "}"
	leftBracket = "["
	rightBracket = "]"
	equals = "="
	equalsEquals = "=="
	bangEquals = "!="
	lessThan = "<"
	lessEquals = "<="
	greaterThan = ">"
	greaterEquals = ">="
	plus = "+"
	minus = "-"
	star = "*"
	slash = "/"
	dot = "."
	colon = ":"
	newline = "newline"
	eof = "end of file"
	// Temporary for bootstrapping
	print = "print"
end 'TokenKind'

export type Token
	export let kind TokenKind
	// Human-readable identifier text, kept as `String` for the many existing
	// parser sites that compare against string literals ("if", "return", ...)
	// and that route through diagnostic formatting. Future work will migrate
	// those sites to byte-slice comparisons, at which point this field can be
	// retired in favor of `valueBytes`.
	export let value String
	// Zero-copy byte slice of the original source span for this token. Future
	// Maxon-IR ops (after Commit D) reference names as `ByteArray` slices; the
	// parser plumbs `token.valueBytes` into those fields directly, avoiding
	// a String-from-bytes round trip on the hot path.
	//
	// Note: EOF and synthetic tokens carry an empty `ByteArray`.
	export let valueBytes ByteArray
	export let line LineNumber
	export let column ColumnNumber
	// Byte offsets into the source buffer bracketing this token's span, used
	// by the parser to compute op source ranges and by the LSP to map cursor
	// positions back to ops. Both fields are 0 on EOF and synthetic tokens.
	export let startByte ByteOffset
	export let endByte ByteOffset

	export static function create(kind TokenKind, value String, line LineNumber, column ColumnNumber, valueBytes ByteArray = ByteArray.create(), startByte ByteOffset = 0, endByte ByteOffset = 0) returns Token
		return Self{kind: kind, value: value, valueBytes: valueBytes, line: line, column: column, startByte: startByte, endByte: endByte}
	end 'create'

	export static function eof() returns Token
		return Self{kind: TokenKind.eof, value: "", valueBytes: ByteArray.create(), line: 0, column: 0, startByte: 0, endByte: 0}
	end 'eof'
end 'Token'

export typealias TokenArray = Array with Token

// --- Table variables ---
// Static lookup: byte value -> character class (256 entries, O(1) index)
let charClassTable = [
	// 0-15:                                                                       \t                \n                      \r
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.tab, CharClass.lf, CharClass.other, CharClass.other, CharClass.cr, CharClass.other, CharClass.other,
	// 16-31
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	// 32-47:  sp              !               "               #               $               %               &               '               (               )               *               +               ,               -               .               /
	CharClass.space, CharClass.bang, CharClass.dquote, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.squote, CharClass.lParen, CharClass.rParen, CharClass.star, CharClass.plus, CharClass.other, CharClass.minus, CharClass.dot, CharClass.slash,
	// 48-63:  0-9                                                                                                           :               ;               <               =               >               ?
	CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.digit, CharClass.colon, CharClass.other, CharClass.less, CharClass.equals, CharClass.greater, CharClass.other,
	// 64-79:  @               A-O
	CharClass.other, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha,
	// 80-95:  P-Z                                                                             [               \               ]               ^               _
	CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.lBracket, CharClass.backslash, CharClass.rBracket, CharClass.other, CharClass.alpha,
	// 96-111: `               a-o
	CharClass.other, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha,
	// 112-127: p-z                                                                             {               |               }               ~               DEL
	CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.alpha, CharClass.lBrace, CharClass.other, CharClass.rBrace, CharClass.other, CharClass.other,
	// 128-255: extended ASCII (all other)
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other,
	CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other, CharClass.other
]


// MidLevelParser: parses .mid text files into MlirFunction objects.
// The .mid format uses tokens compatible with the Maxon lexer:
//   func <name> <paramCount> <returnType> ... end
//   block <label>:
//   v0 = arith constI64 <value>
//   memref storeSlot <slotId> <valueRef>
//   cf br b0
//   cf condBr v0 b1 b2
//   func ret v0
//   sys osExit v0
//   sys osWrite v0 v1
//   etc.

typealias MidTokenIndex = int(0 to 100000)

// State for parsing a single function.
type MidFuncState
	// Local value name -> ValueId map
	export var valueNames StringArray
	export var valueIds ValueIdArray
	// Block label -> BlockId map
	export var blockLabels StringArray
	export var blockIds BlockIdArray
	// Monotonic ValueId counter
	export var nextId ValueId

	static function create(startId ValueId) returns MidFuncState
		return Self{
			valueNames: StringArray.create(),
			valueIds: ValueIdArray.create(),
			blockLabels: StringArray.create(),
			blockIds: BlockIdArray.create(),
			nextId: startId
		}
	end 'create'
end 'MidFuncState'

function createMidFuncState(startId ValueId) returns MidFuncState
	return MidFuncState.create(startId)
end 'createMidFuncState'

function allocValueId(state MidFuncState, name String) returns ValueId
	let id = state.nextId
	state.nextId = state.nextId + 1
	state.valueNames.push(name)
	state.valueIds.push(id)
	return id
end 'allocValueId'

function lookupValueId(state MidFuncState, name String) returns ValueId
	for(i, n) in state.valueNames.enumerated() 'find'
		if n == name 'match'
			return try state.valueIds.get(i) otherwise 'bug'
				panic("MidLevelParser: valueIds/valueNames arrays out of sync at index {i}")
			end 'bug'
		end 'match'
	end 'find'
	panic("MidLevelParser: unknown value name '{name}'")
end 'lookupValueId'

function allocBlockId(state MidFuncState, label String) returns BlockId
	let id = state.blockIds.count()
	state.blockLabels.push(label)
	state.blockIds.push(id)
	return id
end 'allocBlockId'

function lookupBlockId(state MidFuncState, label String) returns BlockId
	for(i, n) in state.blockLabels.enumerated() 'find'
		if n == label 'match'
			return try state.blockIds.get(i) otherwise 'bug'
				panic("MidLevelParser: blockIds/blockLabels arrays out of sync at index {i}")
			end 'bug'
		end 'match'
	end 'find'
	panic("MidLevelParser: unknown block label '{label}'")
end 'lookupBlockId'

// --- Sys op table ---

enum SysOpTag
	stackAddr
	osExit
	osWrite
	osWriteErr
	loadByte
	storeByte
	memcpy
	loadFramePtr
	loadIndirect
	funcAddr
	globalAddr
	iatCall
	storeIndirect
end 'SysOpTag'

typealias SysTokenAdvance = int(0 to 8)

function midMakeSysStackAddr(tokens TokenArray, pos MidTokenIndex, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let slotId = midParseUnsignedInt(midTokenAt(tokens, pos: pos).value)
	return(SysOp.stackAddr(resultId, slotId: slotId), 1)
end 'midMakeSysStackAddr'

function midMakeSysOsExit(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let codeId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	return(SysOp.osExit(codeId), 1)
end 'midMakeSysOsExit'

function midMakeSysOsWrite(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let ptrId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let lenId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	return(SysOp.osWrite(ptrId, lenId: lenId), 2)
end 'midMakeSysOsWrite'

function midMakeSysLoadByte(tokens TokenArray, pos MidTokenIndex, state MidFuncState, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let baseId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let offsetId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	return(SysOp.loadByte(resultId, baseId: baseId, offsetId: offsetId), 2)
end 'midMakeSysLoadByte'

function midMakeSysStoreByte(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let baseId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let offsetId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	let byteId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 2).value)
	return(SysOp.storeByte(baseId, offsetId: offsetId, byteId: byteId), 3)
end 'midMakeSysStoreByte'

function midMakeSysMemcpy(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let dstId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let srcId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	let lenId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 2).value)
	return(SysOp.memcpy(dstId, srcId: srcId, lenId: lenId), 3)
end 'midMakeSysMemcpy'

function midMakeSysOsWriteErr(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let ptrId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let lenId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	return(SysOp.osWriteErr(ptrId, lenId: lenId), 2)
end 'midMakeSysOsWriteErr'

function midMakeSysLoadFramePtr(resultId ValueId) returns(SysOp, SysTokenAdvance)
	return(SysOp.loadFramePtr(resultId), 0)
end 'midMakeSysLoadFramePtr'

function midMakeSysLoadIndirect(tokens TokenArray, pos MidTokenIndex, state MidFuncState, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let addrId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let offset = midParseUnsignedInt(midTokenAt(tokens, pos: pos + 1).value)
	return(SysOp.loadIndirect(resultId, addrId: addrId, offset: offset), 2)
end 'midMakeSysLoadIndirect'

function midMakeSysFuncAddr(tokens TokenArray, pos MidTokenIndex, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let name = midTokenAt(tokens, pos: pos).value
	return(SysOp.funcAddr(resultId, name: name), 1)
end 'midMakeSysFuncAddr'

function midMakeSysGlobalAddr(tokens TokenArray, pos MidTokenIndex, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let name = midTokenAt(tokens, pos: pos).value
	return(SysOp.globalAddr(resultId, name: name), 1)
end 'midMakeSysGlobalAddr'

// sys iatCall SLOT arg0 arg1 ... argN
// Parses: slotIndex followed by variable-length value references
function midMakeSysIatCall(tokens TokenArray, pos MidTokenIndex, state MidFuncState, resultId ValueId) returns(SysOp, SysTokenAdvance)
	let slotIndex = midParseUnsignedInt(midTokenAt(tokens, pos: pos).value)
	var argIds = ValueIdArray.create()
	var advance = 1
	// Parse remaining value references until end of line
	while true 'parseArgs'
		let argToken = midTokenAt(tokens, pos: pos + advance)
		if argToken.kind == TokenKind.newline or argToken.kind == TokenKind.eof 'endOfLine'
			break
		end 'endOfLine'
		let argId = lookupValueId(state, name: argToken.value)
		argIds.push(argId)
		advance = advance + 1
	end 'parseArgs'
	return(SysOp.iatCall(resultId, slotIndex: slotIndex, argIds: argIds), advance)
end 'midMakeSysIatCall'

// sys storeIndirect addrRef offset valueRef
function midMakeSysStoreIndirect(tokens TokenArray, pos MidTokenIndex, state MidFuncState) returns(SysOp, SysTokenAdvance)
	let addrId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let offset = midParseUnsignedInt(midTokenAt(tokens, pos: pos + 1).value)
	let valueId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 2).value)
	return(SysOp.storeIndirect(addrId, offset: offset, valueId: valueId), 3)
end 'midMakeSysStoreIndirect'

// --- Token helpers ---

function midTokenAt(tokens TokenArray, pos MidTokenIndex) returns Token
	return try tokens.get(pos) otherwise Token.eof()
end 'midTokenAt'

function midSkipNewlines(tokens TokenArray, pos MidTokenIndex) returns MidTokenIndex
	var p = pos
	while p < tokens.count() 'skip'
		let t = midTokenAt(tokens, pos: p)
		if t.kind != TokenKind.newline 'notNl'
			break
		end 'notNl'
		p = p + 1
	end 'skip'
	return p
end 'midSkipNewlines'

// Parse a signed integer value from current position.
// Handles optional leading minus: - <intLiteral>
// Also handles hex literals (0x...).
function midParseIntValue(tokens TokenArray, pos MidTokenIndex) returns ParsedInt
	let t = midTokenAt(tokens, pos: pos)
	if t.kind == TokenKind.minus 'negative'
		let numToken = midTokenAt(tokens, pos: pos + 1)
		return 0 - midParseUnsignedInt(numToken.value)
	end 'negative'
	return midParseUnsignedInt(t.value)
end 'midParseIntValue'

// How many tokens does the integer value consume?
function midIntValueTokenCount(tokens TokenArray, pos MidTokenIndex) returns MidTokenIndex
	let t = midTokenAt(tokens, pos: pos)
	if t.kind == TokenKind.minus 'negative'
		return 2
	end 'negative'
	return 1
end 'midIntValueTokenCount'

// Parse an unsigned integer from a token value (decimal or hex).
function midParseUnsignedInt(s String) returns ParsedInt
	let bytes = s.toByteArray()
	let sLen = bytes.count()
	if sLen < 1 'empty'
		return 0
	end 'empty'

	// Check for 0x prefix
	if sLen >= 2 'checkHex'
		let first = try bytes.get(0) otherwise 0
		let second = try bytes.get(1) otherwise 0
		if first == '0' and(second == 'x' or second == 'X') 'isHex'
			return midParseHex(bytes, startIndex: 2)
		end 'isHex'
	end 'checkHex'

	// Decimal
	var result = 0
	for pi in 0 upto sLen 'digits'
		let b = try bytes.get(pi) otherwise 0
		if b >= '0' and b <= '9' 'digit'
			result = result * 10 + (b - '0')
		end 'digit'
	end 'digits'
	return result
end 'midParseUnsignedInt'

function midParseStdType(s String) returns StdType
	if s == "i64" 'isI64'
		return StdType.i64
	end 'isI64'
	if s == "f64" 'isF64'
		return StdType.f64
	end 'isF64'
	panic("midParseStdType: unknown type '{s}'")
end 'midParseStdType'

function midParseHex(s ByteArray, startIndex MidTokenIndex) returns ParsedInt
	var result = 0
	for pi in startIndex upto s.count() 'hexDigits'
		let b = try s.get(pi) otherwise 0
		if b >= '0' and b <= '9' 'decDigit'
			result = result * 16 + (b - '0')
		end 'decDigit' else if b >= 'a' and b <= 'f' 'lowerHex'
			result = result * 16 + (b - 'a' + 10)
		end 'lowerHex' else if b >= 'A' and b <= 'F' 'upperHex'
			result = result * 16 + (b - 'A' + 10)
		end 'upperHex'
	end 'hexDigits'
	return result
end 'midParseHex'

// --- Main parse entry point ---

// Parse a .mid file and return an MlirModule with functions, blocks, and ops.
// startValueId: first ValueId to allocate (avoids collision with user code).
export function parseMidModule(source String, startValueId ValueId) returns MlirModule
	let tokens = tokenize(source)
	var module = createMlirModule()
	var pos = midSkipNewlines(tokens, pos: 0)
	var currentValueId = startValueId

	while pos < tokens.count() 'parseLoop'
		let t = midTokenAt(tokens, pos: pos)
		if t.kind == TokenKind.eof 'done'
			break
		end 'done'

		if t.kind == TokenKind.identifier and t.value == "func" 'isFunc'
			let startId = currentValueId
			let result = midParseFunction(module, tokens: tokens, startPos: pos, startValueId: startId)
			module.functions.push(result.func)
			currentValueId = result.nextValueId
			pos = result.nextPos
		end 'isFunc' else 'skipNonFunc'
			// Skip comments (already handled by lexer) and other tokens
			pos = pos + 1
		end 'skipNonFunc'

		pos = midSkipNewlines(tokens, pos: pos)
	end 'parseLoop'

	return module
end 'parseMidModule'

// Result of parsing a single function.
type MidFuncResult
	export var func MlirFunction
	export var nextPos MidTokenIndex
	export var nextValueId ValueId

	static function create(func MlirFunction, nextPos MidTokenIndex, nextValueId ValueId) returns MidFuncResult
		return Self{func: func, nextPos: nextPos, nextValueId: nextValueId}
	end 'create'
end 'MidFuncResult'

// Parse a single function: func <name> <paramCount> <returnType> ... end
function midParseFunction(module MlirModule, tokens TokenArray, startPos MidTokenIndex, startValueId ValueId) returns MidFuncResult
	var pos = startPos + 1  // skip 'func'

	// Function name
	let nameToken = midTokenAt(tokens, pos: pos)
	pos = pos + 1

	// Param count
	let paramCountToken = midTokenAt(tokens, pos: pos)
	let paramCount = midParseUnsignedInt(paramCountToken.value)
	pos = pos + 1

	// Return type
	let returnTypeToken = midTokenAt(tokens, pos: pos)
	pos = pos + 1

	pos = midSkipNewlines(tokens, pos: pos)

	// Create function
	var func = createMlirFunction(nameToken.value, returnType: returnTypeToken.value, paramCount: paramCount, paramTypes: StdTypeArray.create(), returnLine: 0)

	// Create state for this function
	var state = createMidFuncState(startValueId)

	// First pass: collect all block labels to pre-allocate BlockIds
	midCollectBlockLabels(tokens, startPos: pos, state: state)

	// Second pass: parse blocks and ops
	pos = midParseBlocks(module, tokens: tokens, startPos: pos, func: func, state: state)

	// Skip 'end'
	let endToken = midTokenAt(tokens, pos: pos)
	if endToken.kind == TokenKind.end 'hasEnd'
		pos = pos + 1
	end 'hasEnd'
	pos = midSkipNewlines(tokens, pos: pos)

	return MidFuncResult.create(func, nextPos: pos, nextValueId: state.nextId)
end 'midParseFunction'

// First pass: scan tokens for block labels to pre-allocate BlockIds.
// A block label pattern is: "block" <identifier> ":"
function midCollectBlockLabels(tokens TokenArray, startPos MidTokenIndex, state MidFuncState)
	var pos = startPos
	while pos < tokens.count() 'scan'
		let t = midTokenAt(tokens, pos: pos)
		if t.kind == TokenKind.end 'atEnd'
			break
		end 'atEnd'
		if t.kind == TokenKind.eof 'atEof'
			break
		end 'atEof'

		// Look for: identifier("block") identifier(<label>) colon
		if t.kind == TokenKind.identifier and t.value == "block" 'isBlock'
			let labelToken = midTokenAt(tokens, pos: pos + 1)
			if labelToken.kind == TokenKind.identifier 'hasLabel'
				let colonToken = midTokenAt(tokens, pos: pos + 2)
				if colonToken.kind == TokenKind.colon 'hasColon'
					_ = allocBlockId(state, label: labelToken.value)
				end 'hasColon'
			end 'hasLabel'
		end 'isBlock'

		pos = pos + 1
	end 'scan'
end 'midCollectBlockLabels'

// Second pass: parse blocks within the function body.
function midParseBlocks(module MlirModule, tokens TokenArray, startPos MidTokenIndex, func MlirFunction, state MidFuncState) returns MidTokenIndex
	var pos = startPos

	while pos < tokens.count() 'blockLoop'
		let t = midTokenAt(tokens, pos: pos)
		if t.kind == TokenKind.end 'atEnd'
			break
		end 'atEnd'
		if t.kind == TokenKind.eof 'atEof'
			break
		end 'atEof'

		// Expect: "block" <label> ":"
		if t.kind == TokenKind.identifier and t.value == "block" 'isBlock'
			let labelToken = midTokenAt(tokens, pos: pos + 1)
			pos = pos + 3  // skip "block" <label> ":"
			pos = midSkipNewlines(tokens, pos: pos)

			var block = addBlock(module, func: func, label: labelToken.value)

			// Parse ops within this block until next "block" or "end"
			pos = midParseBlockOps(module, tokens: tokens, startPos: pos, block: block, state: state)
		end 'isBlock' else 'skipOther'
			pos = pos + 1
			pos = midSkipNewlines(tokens, pos: pos)
		end 'skipOther'
	end 'blockLoop'

	return pos
end 'midParseBlocks'

// Parse ops within a single block.
function midParseBlockOps(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState) returns MidTokenIndex
	var pos = startPos

	while pos < tokens.count() 'opLoop'
		let t = midTokenAt(tokens, pos: pos)

		// Stop at end of function or start of next block
		if t.kind == TokenKind.end 'atEnd'
			break
		end 'atEnd'
		if t.kind == TokenKind.eof 'atEof'
			break
		end 'atEof'
		if t.kind == TokenKind.identifier and t.value == "block" 'nextBlock'
			break
		end 'nextBlock'
		if t.kind == TokenKind.newline 'skipNl'
			pos = pos + 1
			continue
		end 'skipNl'

		// Parse an op line. Two forms:
		// 1. <valueRef> = <dialect> <opName> <args...>   (op with result)
		// 2. <dialect> <opName> <args...>                (op without result)
		pos = midParseOp(module, tokens: tokens, startPos: pos, block: block, state: state)
		pos = midSkipNewlines(tokens, pos: pos)
	end 'opLoop'

	return pos
end 'midParseBlockOps'

// Parse a single op line.
function midParseOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState) returns MidTokenIndex
	var pos = startPos
	let t = midTokenAt(tokens, pos: pos)

	// Check if this is an assignment: vN = ...
	let nextT = midTokenAt(tokens, pos: pos + 1)
	if nextT.kind == TokenKind.equals 'isAssignment'
		// vN = <dialect> <opName> <args...>
		let resultName = t.value
		let resultId = allocValueId(state, name: resultName)
		pos = pos + 2  // skip vN and =
		return midParseOpBody(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: resultId)
	end 'isAssignment'

	// No assignment: <dialect> <opName> <args...>
	return midParseOpBody(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: 0)
end 'midParseOp'

// Parse the body of an op after optional "vN = ".
// Current token is the dialect name.
function midParseOpBody(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, resultId ValueId) returns MidTokenIndex
	var pos = startPos
	let dialectToken = midTokenAt(tokens, pos: pos)
	pos = pos + 1
	let opToken = midTokenAt(tokens, pos: pos)
	pos = pos + 1

	let dialect = dialectToken.value
	let opName = opToken.value

	// Dispatch on dialect
	if dialect == "arith" 'isArith'
		return midParseArithOp(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: resultId, opName: opName)
	end 'isArith' else if dialect == "memref" 'isMemref'
		return midParseMemRefOp(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: resultId, opName: opName)
	end 'isMemref' else if dialect == "cf" 'isCf'
		return midParseCfOp(module, tokens: tokens, startPos: pos, block: block, state: state, opName: opName)
	end 'isCf' else if dialect == "sys" 'isSys'
		return midParseSysOp(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: resultId, opName: opName)
	end 'isSys' else if dialect == "func" 'isFunc'
		return midParseFuncOp(module, tokens: tokens, startPos: pos, block: block, state: state, resultId: resultId, opName: opName)
	end 'isFunc' else 'unknownDialect'
		panic("MidLevelParser: unknown dialect '{dialect}'")
	end 'unknownDialect'
end 'midParseOpBody'

// Arith ops — table-driven dispatch via map + match
function midParseArithOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, resultId ValueId, opName String) returns MidTokenIndex
	var pos = startPos

	// constI64 takes an integer literal, not a value ref
	if opName == "constI64" 'isConst'
		let value = midParseIntValue(tokens, pos: pos)
		pos = pos + midIntValueTokenCount(tokens, pos: pos)
		appendArithOp(module, block: block, op: ArithOp.const(ArithConst.create(ArithConstOpcode.constI64, resultId: resultId, value: value)))
		return pos
	end 'isConst'

	// constF64 takes an integer literal (raw bits), not a value ref
	if opName == "constF64" 'isConstF64'
		let value = midParseIntValue(tokens, pos: pos)
		pos = pos + midIntValueTokenCount(tokens, pos: pos)
		appendArithOp(module, block: block, op: ArithOp.const(ArithConst.create(ArithConstOpcode.constF64, resultId: resultId, value: value)))
		return pos
	end 'isConstF64'

	// Binary ops: construct enum from string -> match -> single emit
	let binTag = try ArithBinaryOpcode.fromName(opName) otherwise 'notBinary'
		// Unary ops: construct enum from string -> match -> single emit
		let unaryTag = try ArithUnaryOpcode.fromName(opName) otherwise 'notUnary'
			panic("MidLevelParser: unknown arith op '{opName}'")
		end 'notUnary'
		let operandId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
		appendArithOp(module, block: block, op: ArithOp.unary(ArithUnaryOp.create(unaryTag, resultId: resultId, operandId: operandId)))
		return pos + 1
	end 'notBinary'

	let leftId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
	let rightId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
	appendArithOp(module, block: block, op: ArithOp.binary(ArithBinaryOp.create(binTag, resultId: resultId, leftId: leftId, rightId: rightId)))
	return pos + 2
end 'midParseArithOp'

// MemRef ops
function midParseMemRefOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, resultId ValueId, opName String) returns MidTokenIndex
	let pos = startPos

	// loadSlot: memref loadSlot <slotId>
	if opName == "loadSlot" 'isLoad'
		let slotId = midParseUnsignedInt(midTokenAt(tokens, pos: pos).value)
		appendMemrefOp(module, block: block, op: MemRefOp.loadSlot(resultId, slotId: slotId))
		return pos + 1
	end 'isLoad'

	// storeSlot: memref storeSlot <slotId> <valueRef>
	if opName == "storeSlot" 'isStore'
		let slotId = midParseUnsignedInt(midTokenAt(tokens, pos: pos).value)
		let valueRefId = lookupValueId(state, name: midTokenAt(tokens, pos: pos + 1).value)
		appendMemrefOp(module, block: block, op: MemRefOp.storeSlot(slotId, valueId: valueRefId))
		return pos + 2
	end 'isStore'

	panic("MidLevelParser: unknown memref op '{opName}'")
	return pos
end 'midParseMemRefOp'

// Cf ops (terminators)
function midParseCfOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, opName String) returns MidTokenIndex
	let pos = startPos

	// br: cf br <blockRef>
	if opName == "br" 'isBr'
		let targetId = lookupBlockId(state, label: midTokenAt(tokens, pos: pos).value)
		setCfTerminator(module, block: block, op: CfOp.br(targetId, argIds: ValueIdArray.create()))
		return pos + 1
	end 'isBr'

	// condBr: cf condBr <condRef> <thenBlock> <elseBlock>
	if opName == "condBr" 'isCondBr'
		let condId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
		let thenId = lookupBlockId(state, label: midTokenAt(tokens, pos: pos + 1).value)
		let elseId = lookupBlockId(state, label: midTokenAt(tokens, pos: pos + 2).value)
		setCfTerminator(module, block: block, op: CfOp.condBr(condId, thenTarget: thenId, thenArgIds: ValueIdArray.create(), elseTarget: elseId, elseArgIds: ValueIdArray.create()))
		return pos + 3
	end 'isCondBr'

	panic("MidLevelParser: unknown cf op '{opName}'")
	return pos
end 'midParseCfOp'

// Sys ops — table-driven dispatch via map + match + helpers
function midParseSysOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, resultId ValueId, opName String) returns MidTokenIndex
	let pos = startPos

	let tag = try SysOpTag.fromName(opName) otherwise 'unknown'
		panic("MidLevelParser: unknown sys op '{opName}'")
	end 'unknown'

	(let op, let advance) = match tag 'dispatch'
		stackAddr gives midMakeSysStackAddr(tokens, pos: pos, resultId: resultId)
		osExit gives midMakeSysOsExit(tokens, pos: pos, state: state)
		osWrite gives midMakeSysOsWrite(tokens, pos: pos, state: state)
		osWriteErr gives midMakeSysOsWriteErr(tokens, pos: pos, state: state)
		loadByte gives midMakeSysLoadByte(tokens, pos: pos, state: state, resultId: resultId)
		storeByte gives midMakeSysStoreByte(tokens, pos: pos, state: state)
		memcpy gives midMakeSysMemcpy(tokens, pos: pos, state: state)
		loadFramePtr gives midMakeSysLoadFramePtr(resultId: resultId)
		loadIndirect gives midMakeSysLoadIndirect(tokens, pos: pos, state: state, resultId: resultId)
		funcAddr gives midMakeSysFuncAddr(tokens, pos: pos, resultId: resultId)
		globalAddr gives midMakeSysGlobalAddr(tokens, pos: pos, resultId: resultId)
		iatCall gives midMakeSysIatCall(tokens, pos: pos, state: state, resultId: resultId)
		storeIndirect gives midMakeSysStoreIndirect(tokens, pos: pos, state: state)
	end 'dispatch'
	appendSysOp(module, block: block, op: op)
	return pos + advance
end 'midParseSysOp'

// --- Func dialect ops ---
// "func" is an identifier (not the "function" keyword), parsed like other dialects.
function midParseFuncOp(module MlirModule, tokens TokenArray, startPos MidTokenIndex, block MlirBlock, state MidFuncState, resultId ValueId, opName String) returns MidTokenIndex
	var pos = startPos

	// ret: func ret <valueRef>
	if opName == "ret" 'isRet'
		let retValId = lookupValueId(state, name: midTokenAt(tokens, pos: pos).value)
		setFuncTerminator(module, block: block, op: FuncOp.ret(retValId))
		return pos + 1
	end 'isRet'

	// call: func call <callee> <arg0> <arg1> ...
	if opName == "call" 'isCall'
		let calleeToken = midTokenAt(tokens, pos: pos)
		pos = pos + 1
		var argIds = ValueIdArray.create()
		// Collect args until newline/eof/end
		while pos < tokens.count() 'argLoop'
			let argToken = midTokenAt(tokens, pos: pos)
			if argToken.kind == TokenKind.newline or argToken.kind == TokenKind.eof or argToken.kind == TokenKind.end 'endArgs'
				break
			end 'endArgs'
			argIds.push(lookupValueId(state, name: argToken.value))
			pos = pos + 1
		end 'argLoop'
		appendFuncOp(module, block: block, op: FuncOp.call(resultId, callee: calleeToken.value, argIds: argIds))
		return pos
	end 'isCall'

	// param: func param <paramIndex> <paramType>
	if opName == "param" 'isParam'
		let paramIndexToken = midTokenAt(tokens, pos: pos)
		let paramIndex = midParseUnsignedInt(paramIndexToken.value)
		pos = pos + 1
		let paramTypeToken = midTokenAt(tokens, pos: pos)
		let paramType = midParseStdType(paramTypeToken.value)
		appendFuncOp(module, block: block, op: FuncOp.param(resultId, paramIndex: paramIndex, paramType: paramType))
		return pos + 1
	end 'isParam'

	panic("MidLevelParser: unknown func op '{opName}'")
	return pos
end 'midParseFuncOp'

  block already_done:
    // Awaited GT already complete on entry: emit `await #<id> [immediate]`
    // (no suspend), then extract+free+return. Mirrors the immediate arm of
    // emitX64GtAwait.
    v54 = std globalAddr __at_tag_await
    v55 = std loadSlot 0
    v56 = std loadIndirect v55 56
    v57 = std globalAddr __at_tag_await_imm
    v58 = std call __gt_trace_emit v54 v56 v57
    std br extract

  block extract:
    // The awaited GT is complete. Snapshot its result and throw flag, then free
    // its per-GT allocations (asyncify spill buffer, arg buffer, GT struct) —
    // the x64 path frees the GT stack here via VirtualFree for the same reason.
    // We are no longer suspended on this promise and the scheduler is done with
    // it (status==completed, dequeued), so nothing else references it. Read
    // BEFORE freeing the struct.
    v60 = std loadSlot 0
    v61 = std loadIndirect v60 8
    std storeSlot 2 v61
    v62 = std loadIndirect v60 16
    std storeSlot 3 v62
    // __slab_free(promise.asyncifyData)
    v63 = std loadIndirect v60 64
    v64 = std call __slab_free v63
    // __slab_free(promise.argBuf)
    v65 = std loadIndirect v60 32
    v66 = std call __slab_free v65
    // __slab_free(promise)  — the GT struct itself, freed last.
    v67 = std call __slab_free v60
    // errorReturn(result, threw)
    v68 = std loadSlot 2
    v69 = std loadSlot 3
    std errorReturn v68 v69

  block suspend:
    // self = __gt_current_p ; self.status = 3 (waiting) ; promise.waiter = self
    v6 = std globalAddr __gt_current_p
    v7 = std loadIndirect v6 0
    std storeSlot 1 v7
    v8 = std constI64 3
    std storeIndirect v7 0 v8
    v9 = std loadSlot 0
    v10 = std loadSlot 1
    std storeIndirect v9 48 v10

    // asyncify_start_unwind(self.asyncifyData) arms the unwind, then we RETURN.
    // Asyncify does not instrument calls to its own primitives, so the unwind
    // does not propagate from inside this function — it propagates from the
    // (instrumented) CALLER's post-`call __gt_await` check, which observes the
    // unwinding state and saves+returns. The chain climbs through the user GT
    // frames + __gt_invoke (all instrumented) up to the non-instrumented
    // __sched_run, which catches it. The return values here are irrelevant: the
    // caller never uses them (its frame is being unwound, not consumed), but the
    // dual-value ABI still requires two operands, so return (0, 0).
    v11 = std loadIndirect v7 64
    v12 = std call asyncify_start_unwind v11
    v13 = std constI64 0
    v14 = std constI64 0
    std errorReturn v13 v14
end

// __gt_current_trace_id() -> trace id of the running GT (0 if none). Phase 3
// wires the real trace lines; for now this gives mrt_file_exists a valid id.
func __gt_current_trace_id 0 i64
  block entry:
    v0 = std globalAddr __gt_current_p
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 none have

  block none:
    v4 = std constI64 0
    std ret v4

  block have:
    v5 = std loadIndirect v1 56
    std ret v5
end

// __gt_trace_emit(tag, value, suffix): print one async-trace line
// `<tag><value><suffix?>\n` to stderr, gated on __at_trace_enabled. `tag` and
// `suffix` are cstr addresses (the callers pass `globalAddr __at_tag_*`); the
// suffix is printed only when non-zero (spawn passes 0). Single-threaded on
// wasm, so unlike emitX64GtTraceEmit there is NO trace critical section.
// Mirrors emitX64GtTraceEmit otherwise.
func __gt_trace_emit 3 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2
    // if __at_trace_enabled == 0: return
    v3 = std globalAddr __at_trace_enabled
    v4 = std loadIndirect v3 0
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 disabled emit

  block disabled:
    v7 = std constI64 0
    std ret v7

  block emit:
    // print tag, then value.
    v8 = std loadSlot 0
    v9 = std call __diag_print_tag v8
    v10 = std loadSlot 1
    v11 = std call __diag_print_i64 v10
    // optional suffix: skip when 0.
    v12 = std loadSlot 2
    v17 = std constI64 0
    v18 = std cmpI64Eq v12 v17
    std condBr v18 no_suffix print_suffix

  block print_suffix:
    v13 = std loadSlot 2
    v19 = std call __diag_print_tag v13
    std br no_suffix

  block no_suffix:
    v14 = std globalAddr __at_tag_nl
    v15 = std call __diag_print_tag v14
    v16 = std constI64 0
    std ret v16
end

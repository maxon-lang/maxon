    v8 = std constI64 0
    std storeIndirect v7 0 v8
    // gt.result = 0
    std storeIndirect v7 8 v8
    // gt.threw = 0
    std storeIndirect v7 16 v8
    // gt.funcPtr = fn
    v9 = std loadSlot 0
    std storeIndirect v7 24 v9
    // gt.argBuf = buf
    v10 = std loadSlot 2
    std storeIndirect v7 32 v10
    // gt.next = 0
    std storeIndirect v7 40 v8
    // gt.waiter = 0
    std storeIndirect v7 48 v8
    // gt.traceId = 0
    std storeIndirect v7 56 v8
    // gt.asyncifyData = asyncifyData
    v11 = std loadSlot 4
    std storeIndirect v7 64 v11
    // gt.started = 0
    std storeIndirect v7 72 v8

    v12 = std loadSlot 3
    std ret v12

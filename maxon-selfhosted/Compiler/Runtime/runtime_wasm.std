    v6 = std loadIndirect v5 0
    v7 = std constI64 1
    v8 = std addI64 v6 v7
    std storeIndirect v5 0 v8
    v9 = std loadSlot 0
    std storeIndirect v9 56 v8
    std storeSlot 1 v8

    // __gt_trace_emit(tag=&"spawn #", value=traceId, suffix=0)
    v10 = std globalAddr __at_tag_spawn
    v11 = std loadSlot 1
    v12 = std constI64 0
    v13 = std call __gt_trace_emit v10 v11 v12

    v14 = std loadSlot 0
    v15 = std call __gt_enqueue v14
    v16 = std loadSlot 0
    std ret v16
end


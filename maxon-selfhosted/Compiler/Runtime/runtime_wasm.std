// Wasm-only green-thread coroutine runtime (Std-level IR).
//
// On wasm32-wasi there is no native stack switching, so green threads are
// implemented with Binaryen Asyncify: every instrumented function can unwind
// its live locals into a per-GT buffer at a suspend point and rewind them back
// later. This file holds the REAL bodies for the `__gt_*` runtime functions on
// wasm. On x64/arm64 the equivalent bodies are hand-emitted machine code that
// overrides the signature stubs in runtime.std; those targets must NEVER see
// these bodies (they call the `asyncify_*` primitives, which only the wasm
// backend lowers), so `augmentWithRuntime` splices this file in ONLY when
// `project.target.cpu == CpuArch.wasm32`.
//
// Single-threaded, cooperative scheduler. No locks, no per-P array, no TLS.
// A Promise IS the GT pointer; `await` reads `gt.result`.
//
// GT struct (slab-allocated, 80 bytes; wasm-private offsets):
//   +0  status      0=spawned(new) 1=running 2=completed 3=waiting
//   +8  result      the GT's return value (await reads this)
//   +16 threw       error flag (try-await; unused this phase)
//   +24 funcPtr     wasm function-table index of the coroutine entry
//   +32 argBuf      pointer to [count@+0, managed_mask@+8, arg_i@+16+i*8]
//   +40 next        intrusive FIFO link for the run queue
//   +48 waiter      GT blocked on this one (enqueued when this completes)
//   +56 traceId     async-trace id (unused this phase)
//   +64 asyncifyData per-GT asyncify spill buffer (4096 bytes)
//   +72 started     0 before first dispatch, 1 after (rewind vs first-call)
//
// Reuses the `.data` globals registered in registerSlabAndMmGlobalsForDataSection:
//   __gt_run_queue_head / __gt_run_queue_tail — the FIFO ends
//   __gt_init_done                            — idempotent-init guard
//   __gt_current_p                            — the currently-running GT
//   __gt_trace_counter                        — trace id source (Phase 3)

// ---------------------------------------------------------------------------
// Asyncify primitive signature stubs.
//
// These are dead module functions: `emitDirectCall` in MirToWasm intercepts the
// four names and emits `call <fixed import index>` (wrapping the i64 ptr arg to
// i32) instead of a module-function call, so the bodies here are never reached.
// They exist only so the Std parser resolves the call sites' (arity, return
// type). Mirrors the `__gt_spawn` stub shape in runtime.std.
func asyncify_start_unwind 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 0
    std ret v1
end

func asyncify_stop_unwind 0 void
  block entry:
    v0 = std constI64 0
    std ret v0
end

func asyncify_start_rewind 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 0
    std ret v1
end

func asyncify_stop_rewind 0 void
  block entry:
    v0 = std constI64 0
    std ret v0
end

// __gt_init(): one-time scheduler init, idempotent via __gt_init_done. Single
// threaded, so there is nothing to set up beyond flipping the guard.
func __gt_init 0 void
  block entry:
    v0 = std globalAddr __gt_init_done
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 do_init done

  block do_init:
    v4 = std globalAddr __gt_init_done
    v5 = std constI64 1
    std storeIndirect v4 0 v5
    std br done

  block done:
    v6 = std constI64 0
    std ret v6
end

// __gt_enqueue(gt): append `gt` to the tail of the FIFO run queue. Clears
// gt.next first so the queue stays NUL-terminated.
func __gt_enqueue 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    // gt.next = 0
    v1 = std constI64 0
    std storeIndirect v0 40 v1

    // tail = __gt_run_queue_tail
    v2 = std globalAddr __gt_run_queue_tail
    v3 = std loadIndirect v2 0
    v4 = std constI64 0
    v5 = std cmpI64Eq v3 v4
    std condBr v5 empty_queue nonempty_queue

  block empty_queue:
    // head = tail = gt
    v6 = std globalAddr __gt_run_queue_head
    v7 = std loadSlot 0
    std storeIndirect v6 0 v7
    v8 = std globalAddr __gt_run_queue_tail
    v9 = std loadSlot 0
    std storeIndirect v8 0 v9
    std br done

  block nonempty_queue:
    // oldTail.next = gt ; tail = gt
    v10 = std globalAddr __gt_run_queue_tail
    v11 = std loadIndirect v10 0
    v12 = std loadSlot 0
    std storeIndirect v11 40 v12
    v13 = std globalAddr __gt_run_queue_tail
    v14 = std loadSlot 0
    std storeIndirect v13 0 v14
    std br done

  block done:
    v15 = std constI64 0
    std ret v15
end

// __gt_dequeue() -> gt (0 if the queue is empty). Pops the head of the FIFO and
// fixes up the tail when the queue drains.
func __gt_dequeue 0 i64
  block entry:
    v0 = std globalAddr __gt_run_queue_head
    v1 = std loadIndirect v0 0
    std storeSlot 0 v1
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 empty pop

  block empty:
    v4 = std constI64 0
    std ret v4

  block pop:
    // head = gt.next
    v5 = std loadSlot 0
    v6 = std loadIndirect v5 40
    v7 = std globalAddr __gt_run_queue_head
    std storeIndirect v7 0 v6
    // if head == 0, tail = 0
    v8 = std constI64 0
    v9 = std cmpI64Eq v6 v8
    std condBr v9 clear_tail return_gt

  block clear_tail:
    v10 = std globalAddr __gt_run_queue_tail
    v11 = std constI64 0
    std storeIndirect v10 0 v11
    std br return_gt

  block return_gt:
    v12 = std loadSlot 0
    std ret v12
end

// ---------------------------------------------------------------------------
// Cooperative-sleep timer (wasm). Single-threaded, so instead of the native
// absolute-deadline min-heap this is a flat array of {remaining_ms, gt} entries
// in the shared `__gt_timer_heap` / `__gt_timer_count` globals. Wall-clock time
// only advances on wasm while `__sched_run` blocks in `__gt_idle_poll`, so the
// scheduler decrements every entry's remaining time by the poll duration and
// fires those that reach zero — no real clock (and so no extra WASI import) is
// needed. `maxon_sleep` adds a timer and suspends; `__sched_run` drains the
// run queue, then idles on the smallest remaining time, advancing the timers.

// __gt_timer_add(gt, ms): append {remaining=ms, gt} to the timer array.
func __gt_timer_add 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    // i = count
    v2 = std globalAddr __gt_timer_count
    v3 = std loadIndirect v2 0
    // slot = heap + i*16
    v4 = std globalAddr __gt_timer_heap
    v5 = std constI64 16
    v6 = std mulI64 v3 v5
    v7 = std addI64 v4 v6
    std storeIndirect v7 0 v1
    std storeIndirect v7 8 v0
    // count = i + 1
    v8 = std constI64 1
    v9 = std addI64 v3 v8
    std storeIndirect v2 0 v9
    v10 = std constI64 0
    std ret v10
end

// __gt_timer_min() -> smallest remaining time among pending timers. The caller
// (__sched_run) guarantees count > 0.
func __gt_timer_min 0 i64
  block entry:
    v0 = std globalAddr __gt_timer_heap
    v1 = std loadIndirect v0 0
    std storeSlot 0 v1
    v2 = std constI64 1
    std storeSlot 1 v2
    std br loop

  block loop:
    v3 = std loadSlot 1
    v4 = std globalAddr __gt_timer_count
    v5 = std loadIndirect v4 0
    v6 = std cmpI64Lt v3 v5
    v7 = std constI64 0
    v8 = std cmpI64Eq v6 v7
    std condBr v8 done body

  block body:
    v9 = std globalAddr __gt_timer_heap
    v10 = std loadSlot 1
    v11 = std constI64 16
    v12 = std mulI64 v10 v11
    v13 = std addI64 v9 v12
    v14 = std loadIndirect v13 0
    std storeSlot 2 v14
    v15 = std loadSlot 0
    v16 = std cmpI64Lt v14 v15
    std condBr v16 update next

  block update:
    v17 = std loadSlot 2
    std storeSlot 0 v17
    std br next

  block next:
    v18 = std loadSlot 1
    v19 = std constI64 1
    v20 = std addI64 v18 v19
    std storeSlot 1 v20
    std br loop

  block done:
    v21 = std loadSlot 0
    std ret v21
end

// __gt_timer_advance(elapsed): subtract `elapsed` from every timer's remaining
// time and enqueue (then swap-remove) each GT whose remaining reaches <= 0. The
// swapped-in entry is re-examined at the same index, so a single pass fires all
// due timers regardless of order.
func __gt_timer_advance 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    std storeSlot 1 v1
    std br loop

  block loop:
    v2 = std loadSlot 1
    v3 = std globalAddr __gt_timer_count
    v4 = std loadIndirect v3 0
    v5 = std cmpI64Lt v2 v4
    v6 = std constI64 0
    v7 = std cmpI64Eq v5 v6
    std condBr v7 done body

  block body:
    v8 = std globalAddr __gt_timer_heap
    v9 = std loadSlot 1
    v10 = std constI64 16
    v11 = std mulI64 v9 v10
    v12 = std addI64 v8 v11
    std storeSlot 2 v12
    v13 = std loadIndirect v12 0
    v14 = std loadSlot 0
    v15 = std subI64 v13 v14
    std storeIndirect v12 0 v15
    // remaining > 0 → keep (advance i); else fire.
    v16 = std constI64 0
    v17 = std cmpI64Lt v16 v15
    std condBr v17 advance fire

  block fire:
    v18 = std loadSlot 2
    v19 = std loadIndirect v18 8
    std storeSlot 3 v19
    // count-- ; copy last entry into this slot
    v20 = std globalAddr __gt_timer_count
    v21 = std loadIndirect v20 0
    v22 = std constI64 1
    v23 = std subI64 v21 v22
    std storeIndirect v20 0 v23
    v24 = std globalAddr __gt_timer_heap
    v25 = std constI64 16
    v26 = std mulI64 v23 v25
    v27 = std addI64 v24 v26
    v28 = std loadSlot 2
    v29 = std loadIndirect v27 0
    std storeIndirect v28 0 v29
    v30 = std loadIndirect v27 8
    std storeIndirect v28 8 v30
    // enqueue the fired GT (re-examine the swapped-in entry: no i++)
    v31 = std loadSlot 3
    v32 = std call __gt_enqueue v31
    std br loop

  block advance:
    v33 = std loadSlot 1
    v34 = std constI64 1
    v35 = std addI64 v33 v34
    std storeSlot 1 v35
    std br loop

  block done:
    v36 = std constI64 0
    std ret v36
end

// __gt_idle_poll(ms): block the single wasm thread for `ms` milliseconds via the
// `osSleep` poll_oneoff path. Called ONLY from the uninstrumented __sched_run
// when the run queue is empty but timers are pending, so it idles rather than
// busy-spinning and does not affect interleaving (nothing else is runnable).
func __gt_idle_poll 1 void
  block entry:
    v0 = std param 0 i64
    std osSleep v0
    v1 = std constI64 0
    std ret v1
end

// maxon_sleep(ms): cooperative green-thread sleep on wasm. Mirrors __gt_await's
// suspend/rewind. A fresh call registers a {ms, self} timer, marks self waiting,
// and arms the asyncify unwind; the rewind pass (driven by __sched_run after the
// timer fires and re-dispatches self) stops the rewind and returns. Void, so it
// returns via `std ret` rather than __gt_await's errorReturn. Overrides the
// runtime.std stub on wasm (registered in wasmGtOverrideNames).
func maxon_sleep 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    // Rewind pass? (__sched_run sets __gt_rewinding before asyncify_start_rewind.)
    v1 = std globalAddr __gt_rewinding
    v2 = std loadIndirect v1 0
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 fresh resume

  block resume:
    v5 = std globalAddr __gt_rewinding
    v6 = std constI64 0
    std storeIndirect v5 0 v6
    v7 = std call asyncify_stop_rewind
    v8 = std constI64 0
    std ret v8

  block fresh:
    // self = __gt_current_p ; self.status = 3 (waiting)
    v9 = std globalAddr __gt_current_p
    v10 = std loadIndirect v9 0
    std storeSlot 1 v10
    v11 = std constI64 3
    std storeIndirect v10 0 v11
    // __gt_timer_add(self, ms)
    v12 = std loadSlot 1
    v13 = std loadSlot 0
    v14 = std call __gt_timer_add v12 v13
    // asyncify_start_unwind(self.asyncifyData) ; return (caller's frame unwinds)
    v15 = std loadSlot 1
    v16 = std loadIndirect v15 64
    v17 = std call asyncify_start_unwind v16
    v18 = std constI64 0
    std ret v18
end

// __gt_invoke(gt): call the coroutine entry through the function table with the
// buffered args, store the result into gt.result and the throw flag into
// gt.threw, then mark gt completed.
//
// If the call SUSPENDS (asyncify unwinds inside __gt_await), the indirectCall
// never returns normally — the unwind propagates up to __sched_run — so the
// `gt.status = completed` line is skipped and status stays at 1 (running). That
// is how the scheduler detects suspension. On a true completion the call
// returns and status flips to 2.
//
// wasm `call_indirect` needs a static type, so the entry is dispatched on BOTH
// arity (0..7) AND return shape. The shape is required because the indirect
// target's wasm signature must match exactly: a void entry pushes no result,
// a throwing entry pushes a trailing i64 error flag. Mirroring the x64
// trampoline (which reads r8/rdx uniformly), the runtime cannot ignore a
// missing/extra wasm result, so it emits one of three `call_indirect` shapes:
//   shape 0 — `(i64×N)->i64`            (plain result)         std indirectCall
//   shape 1 — `(i64×N)->()`             (void)                 std indirectCallVoid
//   shape 2 — `(i64×N)->(i64, i64)`     (result + error flag)  std indirectCallThrows
// The arg buffer is [count@+0, managed_mask@+8, arg_i@+16+i*8, shape@+16+N*8].
//
// Slots: 0=gt, 1=funcPtr, 2=argBuf, 3=count, 4=result, 5=shape, 6=threw.
func __gt_invoke 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    // funcPtr = gt.funcPtr ; argBuf = gt.argBuf
    v1 = std loadIndirect v0 24
    std storeSlot 1 v1
    v2 = std loadIndirect v0 32
    std storeSlot 2 v2
    // count = argBuf[0]
    v3 = std loadIndirect v2 0
    std storeSlot 3 v3
    // shape = argBuf[16 + count*8] (the trailing slot after the args)
    v200 = std constI64 8
    v201 = std mulI64 v3 v200
    v202 = std constI64 16
    v203 = std addI64 v201 v202
    v204 = std addI64 v2 v203
    v205 = std loadIndirect v204 0
    std storeSlot 5 v205
    // threw = 0 (overwritten by a throwing entry)
    v206 = std constI64 0
    std storeSlot 6 v206

    v4 = std constI64 0
    v5 = std cmpI64Eq v3 v4
    std condBr v5 arity0 try1

  block try1:
    v6 = std constI64 1
    v7 = std cmpI64Eq v3 v6
    std condBr v7 arity1 try2

  block try2:
    v8 = std constI64 2
    v9 = std cmpI64Eq v3 v8
    std condBr v9 arity2 try3

  block try3:
    v10 = std constI64 3
    v11 = std cmpI64Eq v3 v10
    std condBr v11 arity3 try4

  block try4:
    v12 = std constI64 4
    v13 = std cmpI64Eq v3 v12
    std condBr v13 arity4 try5

  block try5:
    v14 = std constI64 5
    v15 = std cmpI64Eq v3 v14
    std condBr v15 arity5 try6

  block try6:
    v16 = std constI64 6
    v17 = std cmpI64Eq v3 v16
    std condBr v17 arity6 try7

  block try7:
    v18 = std constI64 7
    v19 = std cmpI64Eq v3 v18
    std condBr v19 arity7 bad_arity

  // --- arity 0 ---
  block arity0:
    v220 = std loadSlot 5
    v221 = std constI64 1
    v222 = std cmpI64Eq v220 v221
    std condBr v222 arity0_void arity0_try

  block arity0_try:
    v223 = std loadSlot 5
    v224 = std constI64 2
    v225 = std cmpI64Eq v223 v224
    std condBr v225 arity0_throws arity0_t3

  block arity0_t3:
    v600 = std loadSlot 5
    v601 = std constI64 3
    v602 = std cmpI64Eq v600 v601
    std condBr v602 arity0_throwsvoid arity0_i64

  block arity0_i64:
    v20 = std loadSlot 1
    v21 = std indirectCall v20
    std storeSlot 4 v21
    std br store_result

  block arity0_void:
    v226 = std loadSlot 1
    std indirectCallVoid v226
    std br store_result

  block arity0_throws:
    v227 = std loadSlot 1
    v228 = std indirectCallThrows v229 v227
    std storeSlot 4 v228
    std storeSlot 6 v229
    std br store_result

  block arity0_throwsvoid:
    v603 = std loadSlot 1
    std indirectCallThrowsVoid v604 v603
    std storeSlot 6 v604
    std br store_result

  // --- arity 1 ---
  block arity1:
    v230 = std loadSlot 5
    v231 = std constI64 1
    v232 = std cmpI64Eq v230 v231
    std condBr v232 arity1_void arity1_try

  block arity1_try:
    v233 = std loadSlot 5
    v234 = std constI64 2
    v235 = std cmpI64Eq v233 v234
    std condBr v235 arity1_throws arity1_t3

  block arity1_t3:
    v610 = std loadSlot 5
    v611 = std constI64 3
    v612 = std cmpI64Eq v610 v611
    std condBr v612 arity1_throwsvoid arity1_i64

  block arity1_i64:
    v22 = std loadSlot 2
    v23 = std loadIndirect v22 16
    v24 = std loadSlot 1
    v25 = std indirectCall v24 v23
    std storeSlot 4 v25
    std br store_result

  block arity1_void:
    v236 = std loadSlot 2
    v237 = std loadIndirect v236 16
    v238 = std loadSlot 1
    std indirectCallVoid v238 v237
    std br store_result

  block arity1_throws:
    v239 = std loadSlot 2
    v240 = std loadIndirect v239 16
    v241 = std loadSlot 1
    v242 = std indirectCallThrows v243 v241 v240
    std storeSlot 4 v242
    std storeSlot 6 v243
    std br store_result

  block arity1_throwsvoid:
    v613 = std loadSlot 2
    v614 = std loadIndirect v613 16
    v615 = std loadSlot 1
    std indirectCallThrowsVoid v616 v615 v614
    std storeSlot 6 v616
    std br store_result

  // --- arity 2 ---
  block arity2:
    v250 = std loadSlot 5
    v251 = std constI64 1
    v252 = std cmpI64Eq v250 v251
    std condBr v252 arity2_void arity2_try

  block arity2_try:
    v253 = std loadSlot 5
    v254 = std constI64 2
    v255 = std cmpI64Eq v253 v254
    std condBr v255 arity2_throws arity2_t3

  block arity2_t3:
    v620 = std loadSlot 5
    v621 = std constI64 3
    v622 = std cmpI64Eq v620 v621
    std condBr v622 arity2_throwsvoid arity2_i64

  block arity2_i64:
    v26 = std loadSlot 2
    v27 = std loadIndirect v26 16
    v28 = std loadIndirect v26 24
    v29 = std loadSlot 1
    v30 = std indirectCall v29 v27 v28
    std storeSlot 4 v30
    std br store_result

  block arity2_void:
    v256 = std loadSlot 2
    v257 = std loadIndirect v256 16
    v258 = std loadIndirect v256 24
    v259 = std loadSlot 1
    std indirectCallVoid v259 v257 v258
    std br store_result

  block arity2_throws:
    v260 = std loadSlot 2
    v261 = std loadIndirect v260 16
    v262 = std loadIndirect v260 24
    v263 = std loadSlot 1
    v264 = std indirectCallThrows v265 v263 v261 v262
    std storeSlot 4 v264
    std storeSlot 6 v265
    std br store_result

  block arity2_throwsvoid:
    v623 = std loadSlot 2
    v624 = std loadIndirect v623 16
    v625 = std loadIndirect v623 24
    v626 = std loadSlot 1
    std indirectCallThrowsVoid v627 v626 v624 v625
    std storeSlot 6 v627
    std br store_result

  // --- arity 3 ---
  block arity3:
    v270 = std loadSlot 5
    v271 = std constI64 1
    v272 = std cmpI64Eq v270 v271
    std condBr v272 arity3_void arity3_try

  block arity3_try:
    v273 = std loadSlot 5
    v274 = std constI64 2
    v275 = std cmpI64Eq v273 v274
    std condBr v275 arity3_throws arity3_t3

  block arity3_t3:
    v630 = std loadSlot 5
    v631 = std constI64 3
    v632 = std cmpI64Eq v630 v631
    std condBr v632 arity3_throwsvoid arity3_i64

  block arity3_i64:
    v31 = std loadSlot 2
    v32 = std loadIndirect v31 16
    v33 = std loadIndirect v31 24
    v34 = std loadIndirect v31 32
    v35 = std loadSlot 1
    v36 = std indirectCall v35 v32 v33 v34
    std storeSlot 4 v36
    std br store_result

  block arity3_void:
    v276 = std loadSlot 2
    v277 = std loadIndirect v276 16
    v278 = std loadIndirect v276 24
    v279 = std loadIndirect v276 32
    v280 = std loadSlot 1
    std indirectCallVoid v280 v277 v278 v279
    std br store_result

  block arity3_throws:
    v281 = std loadSlot 2
    v282 = std loadIndirect v281 16
    v283 = std loadIndirect v281 24
    v284 = std loadIndirect v281 32
    v285 = std loadSlot 1
    v286 = std indirectCallThrows v287 v285 v282 v283 v284
    std storeSlot 4 v286
    std storeSlot 6 v287
    std br store_result

  block arity3_throwsvoid:
    v633 = std loadSlot 2
    v634 = std loadIndirect v633 16
    v635 = std loadIndirect v633 24
    v636 = std loadIndirect v633 32
    v637 = std loadSlot 1
    std indirectCallThrowsVoid v638 v637 v634 v635 v636
    std storeSlot 6 v638
    std br store_result

  // --- arity 4 ---
  block arity4:
    v290 = std loadSlot 5
    v291 = std constI64 1
    v292 = std cmpI64Eq v290 v291
    std condBr v292 arity4_void arity4_try

  block arity4_try:
    v293 = std loadSlot 5
    v294 = std constI64 2
    v295 = std cmpI64Eq v293 v294
    std condBr v295 arity4_throws arity4_t3

  block arity4_t3:
    v640 = std loadSlot 5
    v641 = std constI64 3
    v642 = std cmpI64Eq v640 v641
    std condBr v642 arity4_throwsvoid arity4_i64

  block arity4_i64:
    v37 = std loadSlot 2
    v38 = std loadIndirect v37 16
    v39 = std loadIndirect v37 24
    v40 = std loadIndirect v37 32
    v41 = std loadIndirect v37 40
    v42 = std loadSlot 1
    v43 = std indirectCall v42 v38 v39 v40 v41
    std storeSlot 4 v43
    std br store_result

  block arity4_void:
    v296 = std loadSlot 2
    v297 = std loadIndirect v296 16
    v298 = std loadIndirect v296 24
    v299 = std loadIndirect v296 32
    v300 = std loadIndirect v296 40
    v301 = std loadSlot 1
    std indirectCallVoid v301 v297 v298 v299 v300
    std br store_result

  block arity4_throws:
    v302 = std loadSlot 2
    v303 = std loadIndirect v302 16
    v304 = std loadIndirect v302 24
    v305 = std loadIndirect v302 32
    v306 = std loadIndirect v302 40
    v307 = std loadSlot 1
    v308 = std indirectCallThrows v309 v307 v303 v304 v305 v306
    std storeSlot 4 v308
    std storeSlot 6 v309
    std br store_result

  block arity4_throwsvoid:

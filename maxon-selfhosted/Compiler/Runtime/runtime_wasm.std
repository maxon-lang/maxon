    // import, so `__sched_run` sets `__gt_rewinding` before re-running this GT's
    // call chain via `asyncify_start_rewind`. On the rewind pass asyncify replays
    // every call top-to-bottom to rebuild the stack; this `__gt_await` is the
    // deepest frame (it originally armed the unwind), so it ends the rewind here.
    v40 = std globalAddr __gt_rewinding
    v41 = std loadIndirect v40 0
    v42 = std constI64 0
    v43 = std cmpI64Eq v41 v42
    std condBr v43 not_rewinding resume_rewind

  block resume_rewind:
    // Clear the flag, leave rewind mode, emit the await line (this resume path
    // had to SUSPEND, so the suffix is " [yield]"), then extract+free+return.
    // Emitting on the RESUME path orders the await line AFTER the awaited GT's
    // io_yield/io_resume lines. Mirrors the yielded arm of emitX64GtAwait.
    v44 = std globalAddr __gt_rewinding
    v45 = std constI64 0
    std storeIndirect v44 0 v45
    v46 = std call asyncify_stop_rewind
    // __gt_trace_emit(tag=&"await #", value=promise.traceId, suffix=&" [yield]")
    v49 = std globalAddr __at_tag_await
    v50 = std loadSlot 0
    v51 = std loadIndirect v50 56
    v52 = std globalAddr __at_tag_await_yield
    v53 = std call __gt_trace_emit v49 v51 v52
    std br extract

  block not_rewinding:
    // if promise.status == 2 (completed): return promise.result immediately.
    v1 = std loadIndirect v0 0
    v2 = std constI64 2
    v3 = std cmpI64Eq v1 v2

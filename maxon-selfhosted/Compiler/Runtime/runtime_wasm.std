// __sched_run(gt0) -> exit code: the cooperative scheduler driver. Runs ready
// GTs until the queue drains, then returns gt0's result (gt0 is the root GT for
// main). MUST be on the asyncify removelist so it is NOT instrumented — a non
// instrumented function does not save+return on an unwind, so it is where the
// unwind STOPS; it then observes the suspend (status != completed) and calls
// asyncify_stop_unwind to clear the unwinding state.
//
//   loop:
//     gt = __gt_dequeue() ; if gt == 0: return gt0.result
//     __gt_current_p = gt ; gt.status = 1 (running)
//     base = gt.asyncifyData ; base[0] = base+8 ; base[4] = base+4096
//     if gt.started == 0: gt.started = 1 ; __gt_invoke(gt)
//     else:               asyncify_start_rewind(base) ; __gt_invoke(gt)
//     if gt.status == 2: if gt.waiter != 0: __gt_enqueue(gt.waiter)
//     else:              asyncify_stop_unwind()   // it suspended
func __sched_run 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    std br loop_head

  block loop_head:
    v1 = std call __gt_dequeue
    std storeSlot 1 v1
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 queue_drained run_gt

  block queue_drained:
    // Run queue empty. If sleep timers are pending, idle until the nearest one is
    // due, then advance them and loop; otherwise the program is genuinely done.
    v90 = std globalAddr __gt_timer_count
    v91 = std loadIndirect v90 0
    v92 = std constI64 0
    v93 = std cmpI64Eq v91 v92
    std condBr v93 loop_done idle_wait

  block idle_wait:
    // wait = smallest remaining time; block that long (if > 0) then advance.
    v94 = std call __gt_timer_min
    std storeSlot 4 v94
    v95 = std constI64 0
    v96 = std cmpI64Lt v95 v94
    std condBr v96 do_poll do_advance

  block do_poll:
    v97 = std loadSlot 4
    v98 = std call __gt_idle_poll v97
    std br do_advance

  block do_advance:
    v99 = std loadSlot 4
    v100 = std call __gt_timer_advance v99
    std br loop_head

  block loop_done:
    // The run queue has drained. Snapshot gt0's result, then free the root GT's
    // per-GT allocations (asyncify spill buffer, arg buffer, GT struct) — the
    // root GT is run by the scheduler and never awaited, so __gt_await never
    // frees it; without this it leaks at program exit and trips the MM check.
    // Read the result BEFORE freeing the struct.
    v4 = std loadSlot 0
    v5 = std loadIndirect v4 8
    std storeSlot 3 v5
    v50 = std loadIndirect v4 64
    v51 = std call __slab_free v50
    v52 = std loadIndirect v4 32
    v53 = std call __slab_free v52
    v54 = std call __slab_free v4
    v55 = std loadSlot 3
    std ret v55

  block run_gt:
    // __gt_current_p = gt
    v6 = std globalAddr __gt_current_p
    v7 = std loadSlot 1
    std storeIndirect v6 0 v7
    // gt.status = 1 (running)
    v8 = std constI64 1
    std storeIndirect v7 0 v8

    // base = gt.asyncifyData (the per-GT asyncify spill buffer).
    v9 = std loadIndirect v7 64
    std storeSlot 2 v9

    // started?
    v14 = std loadSlot 1
    v15 = std loadIndirect v14 72
    v16 = std constI64 0
    v17 = std cmpI64Eq v15 v16
    std condBr v17 first_call rewind_call

  block first_call:
    // Arm the asyncify data window for a FRESH run: data[+0] = spill region
    // start (base+8), data[+4] = spill region end (base+4096). Asyncify writes
    // upward from data[+0] during an unwind, leaving data[+0] at the high-water
    // mark. We must NOT reset data[+0] on the rewind path: asyncify reads the
    // saved frames top-down (it DECREMENTS the pointer per frame on restore), so
    // the pointer has to stay at that high-water mark for start_rewind. Only the
    // first call seeds it.
    v10 = std constI64 8
    v11 = std addI64 v9 v10
    std storeIndirect v9 0 v11
    v12 = std constI64 4096
    v13 = std addI64 v9 v12
    std storeIndirect v9 4 v13
    // gt.started = 1 ; __gt_invoke(gt)
    v18 = std loadSlot 1
    v19 = std constI64 1
    std storeIndirect v18 72 v19
    v20 = std loadSlot 1
    v21 = std call __gt_invoke v20
    std br after_invoke

  block rewind_call:
    // Mark the rewind pass so the resuming __gt_await calls asyncify_stop_rewind
    // (asyncify has no get_state import). Arm the rewind WITHOUT touching the
    // data window — data[+0] still holds the unwind's high-water mark, which is
    // where asyncify starts reading frames back (top-down). Then re-run the GT's
    // entry: asyncify replays the saved call chain back to the suspend point.
    v40 = std globalAddr __gt_rewinding
    v41 = std constI64 1
    std storeIndirect v40 0 v41
    v22 = std loadSlot 2
    v23 = std call asyncify_start_rewind v22
    v24 = std loadSlot 1
    v25 = std call __gt_invoke v24
    std br after_invoke

  block after_invoke:
    // Completed vs suspended, read from gt.status.
    v26 = std loadSlot 1
    v27 = std loadIndirect v26 0
    v28 = std constI64 2
    v29 = std cmpI64Eq v27 v28
    std condBr v29 completed suspended

  block completed:
    // if gt.waiter != 0: enqueue it
    v30 = std loadSlot 1
    v31 = std loadIndirect v30 48
    v32 = std constI64 0
    v33 = std cmpI64Eq v31 v32
    std condBr v33 loop_head enqueue_waiter

  block enqueue_waiter:
    v34 = std loadSlot 1
    v35 = std loadIndirect v34 48
    v36 = std call __gt_enqueue v35
    std br loop_head

  block suspended:
    // The GT unwound into its asyncify buffer; clear the unwinding state.
    v37 = std call asyncify_stop_unwind
    std br loop_head
end

// __gt_await(promise) -> (result, threw): the suspend point. Called from user
// code running as a GT (driven by __gt_invoke). If the awaited GT is already
// complete, returns its result immediately. Otherwise it registers `self` as
// the promise's waiter, starts an asyncify unwind, and returns — the unwind
// propagates up through the (instrumented) user frames + __gt_invoke to the
// (non-instrumented) __sched_run, which catches it. When the awaited GT later
// completes, __sched_run enqueues the waiter; the next dispatch takes the
// rewind path, replays this call chain, and execution resumes just after the
// start_unwind below, where stop_rewind is called and the result returned.
//
// Follows the dual-value error ABI: every non-suspending exit is an
// `errorReturn` returning (promise.result, promise.threw). A plain `await`
// discards the threw flag (the wasm backend drops the trailing i64 of a
// throwing callee reached through a plain `call`); a `try await` captures it
// via `tryCall`. This mirrors x64's __gt_await (result in r8, threw in rdx).
// `errorReturn` also makes the StdParser mark this function throwing, so its
// wasm signature carries the trailing i64 the callers expect.
//
// Slots: 0=promise, 1=self, 2=saved result, 3=saved threw.
func __gt_await 1 i64

    v33 = std loadSlot 6
    v34 = std loadByte v32 v33
    v35 = std loadSlot 3
    v36 = std subI64 v33 v35
    std storeByte v32 v36 v34
    v37 = std constI64 1
    v38 = std addI64 v33 v37
    std storeSlot 6 v38
    std br shift_loop

  block shift_end:

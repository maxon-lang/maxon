// COW-aware: if the receiver's capacity is < 0 (rdata-backed = -2 or
// slice-backed = -1), call __managed_mem_cow_check to materialize a
// private writable buffer first; that promotes capacity to length, after
// which the standard "newCap < capacity" check and mm_realloc path apply.
//
// Slot usage:
//   slot 0 = self    (arg)
//   slot 1 = newCap  (arg)
//   slot 2 = newBuf  (mm_realloc result)
func __managed_mem_grow 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // Promote any rdata/slice buffer to a private heap buffer. No-op
    // when capacity >= 0.
    v100 = std loadSlot 0
    v101 = std call __managed_mem_cow_check v100

    // if newCap < capacity -> err (now meaningful on the post-COW capacity)
    v2 = std loadIndirect v0 16
    v3 = std cmpI64Lt v1 v2
    std condBr v3 err ok

  block err:
    v4 = std constI64 5
    v5 = std constI64 0
    std errorReturn v5 v4

  block ok:
    // newSize = newCap * elemSize
    v7 = std loadSlot 0
    v8 = std loadIndirect v7 24
    v9 = std loadSlot 1
    v10 = std mulI64 v9 v8

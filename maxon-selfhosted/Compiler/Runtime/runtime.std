    v6 = std loadIndirect v5 16
    v200 = std constI64 0
    v201 = std cmpI64Lt v6 v200
    std condBr v201 cow capCheck

  block capCheck:
    v7 = std loadSlot 1
    v8 = std cmpI64Lt v7 v6
    std condBr v8 ok err

  block err:
    v9 = std constI64 1
    v10 = std constI64 0
    std errorReturn v10 v9

  block cow:
    v202 = std loadSlot 0
    v203 = std call __managed_mem_cow_check v202

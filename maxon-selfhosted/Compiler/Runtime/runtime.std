    v27 = std constI64 0xFFFFFFFF
    v28 = std andI64 v26 v27
    std storeSlot 5 v28
    v29 = std loadSlot 5
    v30 = std constI64 61440
    v31 = std andI64 v29 v30
    v32 = std constI64 16384
    v33 = std cmpI64Eq v31 v32
    std storeIndirect v22 32 v33

    // isReadOnly: (st_mode & S_IWUSR) == 0. S_IWUSR = 0o200 = 128.
    v34 = std loadSlot 5
    v35 = std constI64 128
    v36 = std andI64 v34 v35
    v37 = std constI64 0
    v38 = std cmpI64Eq v36 v37
    std storeIndirect v22 40 v38

    // Free Linux stat buf, return output buf.
    v39 = std loadSlot 2
    v40 = std call mm_decref v39

    v41 = std loadSlot 4
    v42 = std constI64 0
    std errorReturn v41 v42
end

// mrt_file_stat_field: non-throwing field read. Reads buffer[index*8].
// Identical to Windows version.

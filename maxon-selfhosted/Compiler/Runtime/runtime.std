    v21 = std loadSlot 4
    v22 = std loadSlot 5
    v23 = std loadByte v21 v22
    v24 = std loadSlot 3
    v25 = std subI64 v22 v24
    std storeByte v21 v25 v23
    v26 = std constI64 1
    v27 = std addI64 v22 v26
    std storeSlot 5 v27
    std br loop_head


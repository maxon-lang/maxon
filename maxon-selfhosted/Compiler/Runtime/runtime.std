    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    v2 = std call mrt_managed_list_unlink v0 v1
    v3 = std call mm_decref v1
    v4 = std constI64 0
    std ret v4
end

// mrt_managed_list_remove(list, node) -> value. Unlinks `node` from `list`,
// reads its value field, drops the list's reference, and returns the value.
// Caller takes ownership of the value (for managed elements the Maxon-level
// lowering must decref it at scope end).
//
// Slot usage:
//   slot 0 = list_ptr (arg)
//   slot 1 = node_ptr (arg)
//   slot 2 = value
func mrt_managed_list_remove 2 i64

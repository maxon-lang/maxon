    v3 = std constI64 493
    v4 = std osDirMkdir v2 v3
    std storeSlot 2 v4

    v5 = std loadSlot 1
    v6 = std call mm_decref v5

    v7 = std loadSlot 2
    v8 = std constI64 0
    v9 = std cmpI64Lt v7 v8
    std condBr v9 fail ok

  block fail:
    // DirectoryCreateError ordinal 5 → wire 6 (matches Windows stub).
    v10 = std loadSlot 2
    v11 = std constI64 6
    v12 = std call mrt_select_io_error_flag v10 v11
    v13 = std constI64 0
    std errorReturn v13 v12

  block ok:
    v14 = std constI64 0
    v15 = std constI64 0
    std errorReturn v14 v15
end

// mrt_directory_current_path() throws -> __ManagedMemory holding cwd.
// Linux getcwd(buf, size).
//
// Slot usage:
//   slot 0 = scratch buffer (4096 bytes)
//   slot 1 = result (buf ptr or -errno)
//   slot 2 = output mm
//   slot 3 = output buf
//   slot 4 = loop counter
func mrt_directory_current_path 0 i64
  block entry:
    // Allocate a 4096-byte scratch buffer.
    v0 = std constI64 4096
    v1 = std call mrt_alloc v0
    std storeSlot 0 v1

    // getcwd(buf, 4096).
    v2 = std loadSlot 0
    v3 = std constI64 4096
    v4 = std osDirGetcwd v2 v3
    std storeSlot 1 v4

    v5 = std loadSlot 1
    v6 = std constI64 0
    v7 = std cmpI64Lt v5 v6
    std condBr v7 fail ok

  block fail:
    // Free scratch, return error.
    v8 = std loadSlot 0
    v9 = std call mm_decref v8
    // DirectoryCurrentPathError ordinal 6 → wire 7.
    v10 = std loadSlot 1
    v11 = std constI64 7
    v12 = std call mrt_select_io_error_flag v10 v11
    v13 = std constI64 0
    std errorReturn v13 v12

  block ok:
    // Compute string length (search for NUL). Linux getcwd returns the
    // buffer pointer on success; data is NUL-terminated.
    v14 = std constI64 0
    std storeSlot 4 v14
    std br count_loop

  block count_loop:
    v15 = std loadSlot 0
    v16 = std loadSlot 4
    v17 = std addI64 v15 v16
    v18 = std loadByte v17 v6
    v19 = std cmpI64Eq v18 v6
    std condBr v19 count_done bump_idx

  block bump_idx:
    v20 = std loadSlot 4
    v21 = std constI64 1
    v22 = std addI64 v20 v21
    std storeSlot 4 v22
    std br count_loop

  block count_done:
    // Allocate output __ManagedMemory with count == byteLen, elemSize == 1.
    v23 = std loadSlot 4
    v24 = std constI64 1
    v25 = std call __managed_mem_create v23 v24
    std storeSlot 2 v25

    // Set length = byteLen.
    v26 = std loadSlot 2
    v27 = std loadSlot 4
    std storeIndirect v26 8 v27

    // Copy scratch into output buf.
    v28 = std loadIndirect v26 0
    std storeSlot 3 v28
    v29 = std loadSlot 3
    v30 = std loadSlot 0
    v31 = std loadSlot 4
    std memcpy v29 v30 v31

    // Free scratch.
    v32 = std loadSlot 0
    v33 = std call mm_decref v32

    v34 = std loadSlot 2
    v35 = std constI64 0
    std errorReturn v34 v35
end

// mrt_directory_next(self) throws -> 1 if more entries, 0 if done.
// self = block ptr (40 bytes). Block layout per open_search.
//
// Advance the cursor to the next non-"."/".." entry in the dirent buffer;
// when the buffer is exhausted, refill via getdents64. Store the filename
// pointer at block[32] for mrt_directory_filename to read.
//
// Linux dirent64 layout (per getdents64):
//   d_ino   u64  @  0
//   d_off   u64  @  8
//   d_reclen u16 @ 16
//   d_type  u8   @ 18
//   d_name  ...  @ 19 (NUL-terminated)
//
// Slot usage:
//   slot 0 = block ptr
//   slot 1 = fd
//   slot 2 = dirent buffer ptr
//   slot 3 = bufused
//   slot 4 = cursor
//   slot 5 = dirent record reclen
//   slot 6 = entry name ptr
func mrt_directory_next 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std loadIndirect v0 0
    std storeSlot 1 v1
    v2 = std loadIndirect v0 8
    std storeSlot 2 v2

    std br check_buffer

  block check_buffer:
    v3 = std loadIndirect v0 16
    std storeSlot 3 v3
    v4 = std loadIndirect v0 24
    std storeSlot 4 v4

    v5 = std loadSlot 4
    v6 = std loadSlot 3
    v7 = std cmpI64Lt v5 v6
    std condBr v7 read_entry refill

  block refill:
    // getdents64(fd, buf, 4096).
    v8 = std loadSlot 1
    v9 = std loadSlot 2
    v10 = std constI64 4096
    v11 = std osDirGetdents64 v8 v9 v10

    // Store new bufused, reset cursor.
    std storeIndirect v0 16 v11
    v12 = std constI64 0
    std storeIndirect v0 24 v12

    // If <= 0, we're done (0 = EOF; negative = error treated as EOF).
    v13 = std constI64 0
    v14 = std cmpI64Le v11 v13
    std condBr v14 done_no_more check_buffer

  block read_entry:
    // Read reclen at cursor + 16.
    v15 = std loadSlot 2
    v16 = std loadSlot 4
    v17 = std addI64 v15 v16
    v18 = std loadIndirect v17 16
    v19 = std constI64 0xFFFF
    v20 = std andI64 v18 v19
    std storeSlot 5 v20

    // Compute entry name ptr = base + cursor + 19.
    v21 = std constI64 19
    v22 = std addI64 v17 v21
    std storeSlot 6 v22

    // Bump cursor by reclen and store.
    v23 = std loadSlot 4
    v24 = std loadSlot 5
    v25 = std addI64 v23 v24
    std storeIndirect v0 24 v25

    // Skip "." and "..".
    v26 = std loadSlot 6
    v27 = std loadByte v26 v13
    v28 = std constI64 46
    v29 = std cmpI64Eq v27 v28
    std condBr v29 maybe_dot have_entry

  block maybe_dot:
    // First byte is '.'. Check second byte.
    v30 = std constI64 1
    v31 = std addI64 v26 v30
    v32 = std loadByte v31 v13
    v33 = std cmpI64Eq v32 v13
    std condBr v33 skip_entry maybe_dotdot

  block maybe_dotdot:
    v34 = std cmpI64Eq v32 v28
    std condBr v34 maybe_dotdot_term have_entry

  block maybe_dotdot_term:
    // Two leading dots; check third byte for NUL.
    v35 = std constI64 2
    v36 = std addI64 v26 v35
    v37 = std loadByte v36 v13
    v38 = std cmpI64Eq v37 v13
    std condBr v38 skip_entry have_entry

  block skip_entry:
    // Loop back to check_buffer for the next dirent.
    std br check_buffer

  block have_entry:
    // Store name ptr in block[32] for filename to read.
    std storeIndirect v0 32 v26
    v39 = std constI64 1
    v40 = std constI64 0
    std errorReturn v39 v40

  block done_no_more:
    v41 = std constI64 0
    std storeIndirect v0 32 v41
    v42 = std constI64 0
    std errorReturn v41 v42
end

// mrt_directory_filename(self) -> __ManagedMemory. Reads the NUL-
// terminated filename stored at block[32] by directory_next and returns
// a fresh __ManagedMemory containing the bytes.
//
// Slot usage:
//   slot 0 = self (block ptr)
//   slot 1 = name ptr
//   slot 2 = name length
//   slot 3 = output mm
func mrt_directory_filename 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std loadIndirect v0 32
    std storeSlot 1 v1

    // If name ptr is 0, return empty mm.
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 empty count

  block count:
    // Count bytes until NUL.
    std storeSlot 2 v2
    std br count_loop

  block count_loop:
    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std addI64 v4 v5
    v7 = std loadByte v6 v2
    v8 = std cmpI64Eq v7 v2
    std condBr v8 count_done bump

  block bump:
    v9 = std loadSlot 2
    v10 = std constI64 1
    v11 = std addI64 v9 v10
    std storeSlot 2 v11
    std br count_loop

  block count_done:
    // Allocate output mm.
    v12 = std loadSlot 2
    v13 = std constI64 1
    v14 = std call __managed_mem_create v12 v13
    std storeSlot 3 v14

    // length = name len.
    v15 = std loadSlot 3
    v16 = std loadSlot 2
    std storeIndirect v15 8 v16

    // Copy bytes.
    v17 = std loadIndirect v15 0
    v18 = std loadSlot 1
    std memcpy v17 v18 v16

    std ret v15

  block empty:
    v19 = std constI64 0
    v20 = std constI64 1
    v21 = std call __managed_mem_create v19 v20
    std ret v21
end

// mrt_directory_close: close fd, free dirent buf and block.
//
// Slot usage:
//   slot 0 = self (block ptr)
// Close the search handle's RESOURCES (fd + dirent buffer) and stamp the
// closed sentinels (fd = -1, dirent = 0) so the handle destructor
// (`__destruct___ManagedDirectory`, run when the OWNER's reference drops) is
// an idempotent no-op afterward. close() must NOT release the handle BLOCK:
// its single +1 belongs to the owner (a `Directory.dir` field / a scope
// binding), whose own decref frees the block — close() decreffing it too
// double-released every explicitly-closed handle (the `Directory.list`
// teardown trap). Mirrors `__ManagedFile.close`'s -1-sentinel contract.
func mrt_directory_close 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // If self == 0, nothing to do.
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 done close_fd

  block close_fd:
    v3 = std loadIndirect v0 0
    v4 = std cmpI64Lt v3 v1
    std condBr v4 free_bufs do_close

  block do_close:
    v5 = std osFileClose v3
    std br free_bufs

  block free_bufs:
    v6 = std loadIndirect v0 8
    v7 = std cmpI64Eq v6 v1
    std condBr v7 stamp_closed free_dirent

  block free_dirent:
    v8 = std call mm_decref v6
    std br stamp_closed

  block stamp_closed:
    v9 = std constI64 -1
    std storeIndirect v0 0 v9
    v10 = std constI64 0
    std storeIndirect v0 8 v10
    std storeIndirect v0 32 v10
    std br done

  block done:
    v11 = std constI64 0
    std ret v11
end

// Destructor for a __ManagedDirectory search handle: runs when the OWNER's
// reference drops the block to rc 0. Closes the fd and frees the dirent
// buffer iff an explicit close() didn't already (the -1/0 sentinels make it
// idempotent). The block itself is freed by mm_free after this returns.
func __destruct___ManagedDirectory 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    v2 = std loadIndirect v0 0
    v3 = std cmpI64Lt v2 v1
    std condBr v3 free_bufs do_close

  block do_close:
    v4 = std osFileClose v2
    std br free_bufs

  block free_bufs:
    v5 = std loadIndirect v0 8
    v6 = std cmpI64Eq v5 v1
    std condBr v6 done free_dirent

  block free_dirent:
    v7 = std call mm_decref v5
    std br done

  block done:
    v8 = std constI64 0
    std ret v8
end

// mrt_directory_exists(path) -> 1 if directory, else 0. Non-throwing.
// Uses stat + S_ISDIR.
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = cstr ptr
//   slot 2 = stat buf ptr (144 bytes)
//   slot 3 = stat result
func mrt_directory_exists 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call mrt_cstr_from_mm v0
    std storeSlot 1 v1

    v2 = std constI64 144
    v3 = std call mrt_alloc v2
    std storeSlot 2 v3

    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std osFileStat v4 v5
    std storeSlot 3 v6

    // Free cstr.
    v7 = std loadSlot 1
    v8 = std call mm_decref v7

    v9 = std loadSlot 3
    v10 = std constI64 0
    v11 = std cmpI64Lt v9 v10
    std condBr v11 not_exist check_mode

  block not_exist:
    v12 = std loadSlot 2
    v13 = std call mm_decref v12
    v14 = std constI64 0
    std ret v14

  block check_mode:
    // st_mode @ 24; (mode & S_IFMT) == S_IFDIR ?
    v15 = std loadSlot 2
    v16 = std loadIndirect v15 24
    v17 = std constI64 0xFFFFFFFF
    v18 = std andI64 v16 v17
    v19 = std constI64 61440
    v20 = std andI64 v18 v19
    v21 = std constI64 16384
    v22 = std cmpI64Eq v20 v21
    std condBr v22 is_dir not_dir

  block is_dir:
    v23 = std loadSlot 2
    v24 = std call mm_decref v23
    v25 = std constI64 1
    std ret v25

  block not_dir:
    v26 = std loadSlot 2
    v27 = std call mm_decref v26
    v28 = std constI64 0
    std ret v28
end

// =============================================================================
// Command-line / executable-path retrieval — platform-independent bodies.
//
// Each helper emits one of the new Std-level ops (`osGetArgc` / `osGetArgv` /
// `osGetExecutablePath`), and the per-backend MIR lowering decides what those
// mean per OS (Linux/macOS read stashed argv globals; Windows calls hand-
// rolled IAT helpers in the backend; WASI uses its argv cache). The bodies
// here are identical across targets — no per-OS stub split remains.

// mrt_command_line_count(): returns the process argument count.
func mrt_command_line_count 0 i64
  block entry:
    v0 = std osGetArgc
    std ret v0
end

// mrt_command_line_arg(index): returns a freshly-allocated __ManagedMemory
// holding the UTF-8 bytes of argv[index]. Out-of-bounds (osGetArgv returned 0)
// produces an empty MM (length=0). Slot usage:
//   slot 0 = argv[index] raw C-string pointer
//   slot 1 = NUL-scan counter (byte length, excluding NUL)
//   slot 2 = mm pointer
func mrt_command_line_arg 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std osGetArgv v0
    std storeSlot 0 v1
    // If osGetArgv returned 0 the index is out of bounds — emit an empty MM.
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 oob_path scan_init

  block scan_init:
    // Initialise the NUL-scan counter to 0; loop reads cstr[counter] until 0.
    v4 = std constI64 0
    std storeSlot 1 v4
    std br scan

  block scan:
    v5 = std loadSlot 0
    v6 = std loadSlot 1
    v7 = std loadByte v5 v6
    v8 = std constI64 0
    v9 = std cmpI64Eq v7 v8
    std condBr v9 alloc scan_next

  block scan_next:
    v10 = std loadSlot 1
    v11 = std constI64 1
    v12 = std addI64 v10 v11
    std storeSlot 1 v12
    std br scan

  block alloc:
    // __managed_mem_create(byteLen + 1, 1). The +1 reserves space for the NUL
    // terminator so the memcpy below (which copies `byteLen` bytes, no NUL)
    // can be followed by callers writing a NUL if they want C-string access.
    v13 = std loadSlot 1
    v14 = std constI64 1
    v15 = std addI64 v13 v14
    v16 = std constI64 1
    v17 = std call __managed_mem_create v15 v16
    std storeSlot 2 v17

    // dst = mm[0] (the heap-allocated buffer pointer stored at offset 0).
    v18 = std loadSlot 2
    v19 = std loadIndirect v18 0

    // memcpy(dst, src, byteLen). Does not copy the NUL — only the data bytes.
    v20 = std loadSlot 0
    v21 = std loadSlot 1
    std memcpy v19 v20 v21

    // Store length = byteLen at mm[8].
    v22 = std loadSlot 1
    v23 = std loadSlot 2
    std storeIndirect v23 8 v22

    v24 = std loadSlot 2
    std ret v24

  block oob_path:
    // Out-of-bounds: empty 1-byte MM (length stays 0). Matches the existing
    // Windows `mrt_command_line_arg` OOB return shape so callers observe an
    // empty String regardless of platform.
    v25 = std constI64 1
    v26 = std constI64 1
    v27 = std call __managed_mem_create v25 v26
    std ret v27
end

// mrt_executable_path(): returns a __ManagedMemory holding the UTF-8 bytes
// of the running executable's path. On error (osGetExecutablePath returned a
// negative errno-style value) produces an empty MM. The stack buffer holds
// up to 4096 bytes — well past PATH_MAX on every supported system.
//
// Slot usage:
//   slot 0 = osGetExecutablePath return value (bytes written or -errno)
//   slot 1 = mm pointer
//   slot 2 = mm[0] buffer pointer
//   slots 11..522 = 512-qword (4096-byte) UTF-8 path buffer
func mrt_executable_path 0 i64
  block entry:
    // Stack-allocate the path buffer at slot 522 (low-address end of a
    // 4096-byte region extending toward slot 11; the slot allocator reserves
    // the frame).
    v0 = std stackAddr 522
    v1 = std constI64 4096
    v2 = std osGetExecutablePath v0 v1
    std storeSlot 0 v2

    // Error path: result < 0 → return empty MM.
    v3 = std constI64 0
    v4 = std cmpI64Lt v2 v3
    std condBr v4 err_path ok_path

  block ok_path:
    // __managed_mem_create(bytes + 1, 1). The +1 reserves NUL space; memcpy
    // below copies only `bytes` data bytes.
    v5 = std loadSlot 0
    v6 = std constI64 1
    v7 = std addI64 v5 v6
    v8 = std constI64 1
    v9 = std call __managed_mem_create v7 v8
    std storeSlot 1 v9

    // dst = mm[0].
    v10 = std loadSlot 1
    v11 = std loadIndirect v10 0
    std storeSlot 2 v11

    // memcpy(dst, stackBuf, bytes).
    v12 = std loadSlot 2
    v13 = std stackAddr 522
    v14 = std loadSlot 0
    std memcpy v12 v13 v14

    // Store length = bytes at mm[8].
    v15 = std loadSlot 0
    v16 = std loadSlot 1
    std storeIndirect v16 8 v15

    v17 = std loadSlot 1
    std ret v17

  block err_path:
    v18 = std constI64 1
    v19 = std constI64 1
    v20 = std call __managed_mem_create v18 v19
    std ret v20
end

// mrt_cov_hit(siteId): increments __data_cov_counters[siteId].
// __data_cov_counters is a u64 array in .data sized numSites*8 bytes.
// Only invoked when coverage instrumentation was enabled at compile time;
// otherwise the runtime merge leaves the counters global unregistered and
// this function is never called from user code.
func mrt_cov_hit 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __data_cov_counters
    v2 = std constI64 3
    v3 = std shlI64 v0 v2
    v4 = std addI64 v1 v3
    v5 = std loadIndirect v4 0
    v6 = std constI64 1
    v7 = std addI64 v5 v6
    std storeIndirect v4 0 v7
    v8 = std constI64 0
    std ret v8
end

// mrt_cov_dump(): writes the coverage file when MAXON_COV_OUT is set.
// File format: 4-byte magic "MCOV" | 4-byte numSites (u32 LE) | numSites*8 bytes of counters (u64 LE).
//
// Slot usage:
//   slot 0 = bytes written by osGetEnv (path length)
//   slot 1 = fd returned by osOpenWrite
//   slot 2 = numSites (masked to u32)
//   slots 10..41 = 256-byte path buffer (32 qword slots)
//   slot 50 = 8-byte header buffer
func mrt_cov_dump 0 void
  block entry:
    v0 = std globalAddr __cov_env_name
    v1 = std constI64 13
    // Slots 10..41 reserve 256 bytes. Stack addresses go DOWN as slot index
    // goes up, so the LOWEST address of the buffer is at slot 41. Passing
    // stackAddr 41 as the ptr makes osGetEnv write FORWARD through slots
    // 41..10; using stackAddr 10 here would write OFF THE TOP of the buffer
    // into the saved frame and return address (works for ≤8-byte strings,
    // crashes on longer paths).
    v2 = std stackAddr 41
    v3 = std constI64 256
    v4 = std osGetEnv v0 v1 v2 v3
    std storeSlot 0 v4
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 done doOpen

  block doOpen:
    v7 = std stackAddr 41
    v8 = std loadSlot 0
    v9 = std osOpenWrite v7 v8
    std storeSlot 1 v9

    v10 = std globalAddr __data_cov_num_sites
    v11 = std loadIndirect v10 0
    v12 = std constI64 0xFFFFFFFF
    v13 = std andI64 v11 v12
    std storeSlot 2 v13

    v14 = std stackAddr 50

    v15 = std constI64 0
    v16 = std constI64 0x4D
    std storeByte v14 v15 v16
    v17 = std constI64 1
    v18 = std constI64 0x43
    std storeByte v14 v17 v18
    v19 = std constI64 2
    v20 = std constI64 0x4F
    std storeByte v14 v19 v20
    v21 = std constI64 3
    v22 = std constI64 0x56
    std storeByte v14 v21 v22

    v23 = std loadSlot 2
    v24 = std constI64 0xFF
    v25 = std andI64 v23 v24
    v26 = std constI64 4
    std storeByte v14 v26 v25

    v27 = std loadSlot 2
    v28 = std constI64 8
    v29 = std shrI64 v27 v28
    v30 = std constI64 0xFF
    v31 = std andI64 v29 v30
    v32 = std constI64 5
    std storeByte v14 v32 v31

    v33 = std loadSlot 2
    v34 = std constI64 16
    v35 = std shrI64 v33 v34
    v36 = std constI64 0xFF
    v37 = std andI64 v35 v36
    v38 = std constI64 6
    std storeByte v14 v38 v37

    v39 = std loadSlot 2
    v40 = std constI64 24
    v41 = std shrI64 v39 v40
    v42 = std constI64 0xFF
    v43 = std andI64 v41 v42
    v44 = std constI64 7
    std storeByte v14 v44 v43

    v45 = std loadSlot 1
    v46 = std stackAddr 50
    v47 = std constI64 8
    std osWriteFd v45 v46 v47

    v48 = std loadSlot 1
    v49 = std globalAddr __data_cov_counters
    v50 = std loadSlot 2
    v51 = std constI64 3
    v52 = std shlI64 v50 v51
    std osWriteFd v48 v49 v52

    v53 = std loadSlot 1
    std osClose v53
    std br done

  block done:
    v54 = std constI64 0
    std ret v54
end

// mrt_start_with_coverage: entry point used when coverage is enabled.
// Calls main, invokes mrt_cov_dump to flush counters, then exits with main's result.
// augmentWithRuntime selects between this and mrt_start based on project.coverageEnabled.
func mrt_start_with_coverage 0 void
  block entry:
    v4 = std call __slab_init
    v0 = std call main
    std storeSlot 0 v0
    v1 = std call mrt_cov_dump
    v2 = std loadSlot 0
    std osExit v2
    v3 = std constI64 0
    std ret v3
end

// =============================================================================
// MM tracked layer
// =============================================================================
//
// There is exactly ONE allocator: `__mm_alloc` (stdlib/Internals.maxon),
// alloc-at-0 — a fresh allocation owns NO reference; the binding/field-store
// that takes ownership supplies the first +1. runtime.std no longer defines its
// own `mm_alloc`; `mrt_alloc` and the runtime container helpers call
// `__mm_alloc` directly (see `mrt_alloc` for the raw-buffer rc=1 convention).
// `mm_incref` / `mm_decref` / `mm_free` are thin delegations to the matching
// `__mm_*` Internals bodies (single source of truth — refcount maintenance,
// mm-trace instrumentation, and the pointer-sanity guard all live there).
//
// Header layout (32 bytes preceding the user pointer; matches Internals):
//   [ptr - 32] = packed_id (alloc_id << 16 | tag; 0 when untraced)
//   [ptr - 24] = destructor function pointer (i64, 0 if no destructor)
//   [ptr - 16] = size in bytes (i64; user-requested size)
//   [ptr -  8] = refcount (i64)
//
// Globals referenced (registered by registerSlabAndMmGlobalsForDataSection
// in LowerMaxonToStd):
//   __mm_alloc_count   8 bytes — atomic count of live __mm_alloc allocations.
//
// Destructor invocation: when mm_decref drives the refcount to zero it
// calls mm_free, which reads the destructor pointer from [ptr - 24] and
// invokes it via `indirectCall` (if non-null) before slab-freeing. The
// destructor receives the user pointer and is expected to decref any
// managed fields stored in the user region.

// mm_incref(ptr): atomically bump the refcount at [ptr - 8].
// Caller must ensure ptr is non-null; we skip the null check for speed
// (matches the inner-loop expectations of array.set / etc.).
//
// TODO(safety): once we have a cheap way to panic with a static message,
// consider adding a NULL-check that calls mrt_panic with __mm_panic_incref_null.
//
// Slot usage:
//   slot 0 = ptr (arg)
// Delegates to the stdlib `__mm_incref` so refcount maintenance — and its
// mm-trace instrumentation + pointer-sanity guard — live in ONE place
// (stdlib/Internals.maxon). The runtime.std `mrt_*` wrappers and any legacy
// `mm_incref` call sites route through here; the lowering's direct
// `stdlib.__mm_incref` calls hit the same body. Keeping both names as one
// implementation prevents the traced/untraced split that previously left
// scope-exit decrefs (via `__mm_decref_maybenull_helper`→`mm_decref`) untraced.
func mm_incref 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call __mm_incref v0
    v2 = std constI64 0
    std ret v2
end

// mm_decref(ptr): atomically decrement the refcount at [ptr - 8]. If the
// prior value was 1 (i.e. the refcount has reached 0), call mm_free(ptr) to
// release the allocation. Caller must ensure ptr is non-null.
//
// We use atomicXadd with -1 (rather than atomicDec) because the dec op
// has no result Id in Std-IR — we need the prior value to detect the
// transition to zero across architectures uniformly.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = prior refcount (return of atomicXadd)
// Delegates to the stdlib `__mm_decref` (single source of truth — trace +
// guard + transition-to-zero free all live there). See `mm_incref`.
func mm_decref 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call __mm_decref v0
    v2 = std constI64 0
    std ret v2
end

// mm_retain_type_param(value, layout): incref a generic type-parameter POINTER
// value iff the layout descriptor's HAS_HEAP_REFS flag (`flags@24`, bit 0) is set.
// The SYMMETRIC counterpart of the element-walk's `element_destroy` (&__mm_decref):
// inside a generic body the concrete element managed-ness is only known at runtime
// via the layout descriptor. The refcount inserter emits a `mm_retain_type_param`
// call when a BORROWED element is moved into a container that must take its own
// ref (the source collection still owns its reference). A primitive element (bit
// clear), a null layout, or a null value is a no-op. The logic is INLINE here
// (calling the always-reachable `__mm_incref`) rather than delegating to a
// separate stdlib helper, so no extra source call edge is needed to keep it linked.
// Emitted late (post-DCE), so seeded as a runtime reachability root in BOTH link
// legs (BackendDispatch / X64Backend); its signature is registered here for the
// backend's call-lowering lookup.
//
// Slot usage:
//   slot 0 = value (arg), slot 1 = layout descriptor (arg)
func mm_retain_type_param 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 noop check_value
  block check_value:
    v4 = std constI64 0
    v5 = std cmpI64Eq v0 v4
    std condBr v5 noop do_check
  block do_check:
    v6 = std loadIndirect v1 24
    v7 = std constI64 1
    v8 = std andI64 v6 v7
    v9 = std constI64 0
    v10 = std cmpI64Eq v8 v9
    std condBr v10 noop do_incref
  block do_incref:
    v11 = std call __mm_incref v0
    v12 = std constI64 0
    std ret v12
  block noop:
    v13 = std constI64 0
    std ret v13
end

// mm_retain_type_param_at(value, layout, ordinal): incref a generic type-parameter
// POINTER value iff the layout descriptor's PER-ARG heap-ref bit for type-arg
// `ordinal` is set (`flags@24` bit `8 + ordinal` — LAYOUT_PER_ARG_HEAPREF_SHIFT).
// The multi-type-param form of `mm_retain_type_param`: inside a `Map<K,V>` body
// the aggregate bit 0 is the OR over BOTH args, so retaining a raw-int Value
// through it increfs the integer (the `m.get("a")` addr=-7 fault). The inserter
// passes the value's own param ordinal so only ITS managed-ness is consulted.
// A primitive element (bit clear), a null layout, or a null value is a no-op.
// Emitted late (post-DCE) → seeded as a runtime reachability root in BOTH link
// legs, exactly like `mm_retain_type_param`.
//
// Slot usage:
//   slot 0 = value (arg), slot 1 = layout descriptor (arg), slot 2 = ordinal (arg)
func mm_retain_type_param_at 3 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std constI64 0
    v4 = std cmpI64Eq v1 v3
    std condBr v4 noop check_value
  block check_value:
    v5 = std constI64 0
    v6 = std cmpI64Eq v0 v5
    std condBr v6 noop do_check
  block do_check:
    v7 = std loadIndirect v1 24
    v8 = std constI64 8
    v9 = std addI64 v2 v8
    v10 = std shrI64 v7 v9
    v11 = std constI64 1
    v12 = std andI64 v10 v11
    v13 = std constI64 0
    v14 = std cmpI64Eq v12 v13
    std condBr v14 noop do_incref
  block do_incref:
    v15 = std call __mm_incref v0
    v16 = std constI64 0
    std ret v16
  block noop:
    v17 = std constI64 0
    std ret v17
end

// mm_drop_type_param_at(value, layout, ordinal): release a generic type-parameter
// value through its PER-ARG heap-ref bit (`flags@24` bit `8 + ordinal`) — decref
// when the concrete type-arg is heap-managed, no-op when raw. The drop-side dual
// of `mm_retain_type_param_at`, replacing the old `sys.dropTypeParam` indirect
// call through the aggregate descriptor's `destroyFunc`: that function destroys
// the INSTANCE shape (e.g. `__layout_destroy_Map_String_Int` reads three struct
// fields), so calling it on an ELEMENT only ever worked by coincidence for
// single-managed-field-at-offset-0 layouts and faulted for everything else
// (the String-keyed map findSlot key drop reading `[str+8]`=isAscii as a
// pointer). Null layout / null value are no-ops (a zero-init'd slot's path).
// Seeded as a runtime reachability root in BOTH link legs.
//
// Slot usage:
//   slot 0 = value (arg), slot 1 = layout descriptor (arg), slot 2 = ordinal (arg)
func mm_drop_type_param_at 3 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std constI64 0
    v4 = std cmpI64Eq v1 v3
    std condBr v4 noop check_value
  block check_value:
    v5 = std constI64 0
    v6 = std cmpI64Eq v0 v5
    std condBr v6 noop do_check
  block do_check:
    v7 = std loadIndirect v1 24
    v8 = std constI64 8
    v9 = std addI64 v2 v8
    v10 = std shrI64 v7 v9
    v11 = std constI64 1
    v12 = std andI64 v10 v11
    v13 = std constI64 0
    v14 = std cmpI64Eq v12 v13
    std condBr v14 noop do_decref
  block do_decref:
    v15 = std call __mm_decref v0
    v16 = std constI64 0
    std ret v16
  block noop:
    v17 = std constI64 0
    std ret v17
end

// mm_drop(ptr): owner-drop of a never-escaped freshRc0 value — frees at rc==0,
// else decrefs. The SSA insert-refcounts pass emits `mm_drop` at the last use of
// a provably-local allocation. Wraps the stdlib `__mm_drop` (single source of
// truth). Seeded as a runtime-reachability root in BOTH the cache-off
// (`filterRuntimeByReachability`) and cache-on (`linkX64StdlibFunctionsConcat`)
// link paths — exactly like `mm_decref` — so its `call __mm_drop` edge pulls the
// stdlib body symmetrically and a no-managed-alloc program keeps cache parity.
func mm_drop 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call __mm_drop v0
    v2 = std constI64 0
    std ret v2
end

// mm_move_{return,container,phi}(ptr): trace-only marker for an ownership MOVE — a
// value whose +1 transfers to a new owner with NO refcount op. The destination is
// baked into WHICH wrapper is called (not a runtime `dest` operand): this avoids a
// regalloc hazard where a `dest`-const ValueId, queued at a branch terminator next
// to the phi-edge materialization, was scheduled AFTER the `mm_move` call and read
// stale (the phi-move traced `-> return` instead of `-> phi`). Each wrapper passes a
// CONSTANT dest to the stdlib `__mm_move_trace` (single source of truth — trace line
// + null/untraced guards). 0=return, 1=container, 2=phi. Untraced bodies DCE to a
// bare `ret`. All three are seeded as runtime-reachability roots in BOTH link legs.
func mm_move_return 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 0
    v2 = std call __mm_move_trace v0 v1
    v3 = std constI64 0
    std ret v3
end

func mm_move_container 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 1
    v2 = std call __mm_move_trace v0 v1
    v3 = std constI64 0
    std ret v3
end

func mm_move_phi 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 2
    v2 = std call __mm_move_trace v0 v1
    v3 = std constI64 0
    std ret v3
end

// mm_scope_push(name) / mm_scope_pop(): mm-trace scope STACK frame bracketing. Each
// function pushes its name cstr on entry and pops before returning; trace lines read
// the top frame, so an inlined callee's push/pop (inlined verbatim) restore the
// caller's scope after the inlined region — `[scope]` correct at any inline depth.
// Wrap the stdlib `__mm_scope_push`/`__mm_scope_pop` (single source of truth; bodies
// DCE to nothing untraced). Seeded as runtime-reachability roots in BOTH link legs
// like `mm_drop`/`mm_move`, so the `call __mm_scope_*` edges stay symmetric between
// the cache-off and cache-on builds.
func mm_scope_push 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call __mm_scope_push v0
    v2 = std constI64 0
    std ret v2
end

func mm_scope_pop 0 void
  block entry:
    v0 = std call __mm_scope_pop
    v1 = std constI64 0
    std ret v1
end

// mm_free(ptr): release a tracked allocation. Internal — usually invoked
// by mm_decref when the refcount reaches zero. Reads the destructor from
// [ptr - 24] and invokes it (if non-null) before slab-freeing. The
// destructor is responsible for decreffing managed fields stored inside
// the user region; mm_free only releases the surrounding allocation.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = slot_base (= ptr - 24)
//   slot 2 = destructor (read from [ptr - 24], 0 means "no destructor")
// Delegates to the stdlib `__mm_free` (single source of truth — runs the
// destructor, decrements __mm_alloc_count, slab-frees, and emits the
// mm-trace `mm_free`/`sl_free` nesting). See `mm_incref`.
func mm_free 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call __mm_free v0
    v2 = std constI64 0
    std ret v2
end

// mm_realloc(ptr, new_size) -> new_ptr: grow or shrink a tracked allocation.
// Allocates a fresh buffer (preserving the destructor from the old header),
// copies min(old_size, new_size) bytes of user data, then slab-frees the old
// allocation directly (bypassing mm_free / the destructor — the new buffer
// now owns whatever resources the old one held).
//
// If ptr == 0, behaves as mm_alloc(new_size, destructor=0, tag=0).
//
// Note: realloc transfers ownership. If the caller had aliased the old
// pointer (incref'd it elsewhere), they would expect both to refer to the
// same object — the C# bootstrap doesn't fix that either; we accept the
// "realloc consumes its input" semantic and document it here.
//
// Slot usage:
//   slot 0 = old_ptr   (arg)
//   slot 1 = new_size  (arg)
//   slot 2 = old_size       (read from header)
//   slot 3 = destructor     (read from header)
//   slot 4 = new_ptr        (returned)
//   slot 5 = copy_size      (= min(old_size, new_size))
//   slot 6 = old_slot_base  (= old_ptr - 24)
func mm_realloc 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    v2 = std constI64 0
    v3 = std cmpI64Eq v0 v2
    std condBr v3 null_path live_path

  block null_path:
    // ptr == 0 => behave as a fresh raw allocation the caller owns (rc=1).
    v4 = std loadSlot 1
    v7 = std call mrt_alloc v4
    std ret v7

  block live_path:
    // old_size = *(old_ptr - 16). Compute address explicitly (loadIndirect
    // takes only unsigned offsets, so we can't use a -16 offset directly).
    v8 = std loadSlot 0
    v9 = std constI64 16
    v10 = std subI64 v8 v9
    v11 = std loadIndirect v10 0
    std storeSlot 2 v11

    // destructor = *(old_ptr - 24).
    v12 = std loadSlot 0
    v13 = std constI64 24
    v14 = std subI64 v12 v13
    v15 = std loadIndirect v14 0
    std storeSlot 3 v15

    // new_ptr = __mm_alloc(new_size, destructor, 0). This refreshes the
    // destructor on the new buffer so a subsequent mm_decref still has it.
    // alloc-at-0: the new buffer INHERITS the old object's reference (realloc
    // identity), so incref to rc=1 — the old buffer is slab-freed below without
    // a matching decref, so its +1 transfers here.
    v16 = std loadSlot 1
    v17 = std loadSlot 3
    // tag = MM_TAG_RAW (1): a realloc'd raw element buffer. Non-zero so the strict
    // mm-trace null-tag panic is not tripped (the buffer carries no element type).
    v18 = std constI64 1
    v19 = std call __mm_alloc v16 v17 v18
    std storeSlot 4 v19
    v35 = std call __mm_incref v19

    // copy_size = min(old_size, new_size)
    v20 = std loadSlot 2
    v21 = std loadSlot 1
    v22 = std cmpI64Lt v20 v21
    std condBr v22 pick_old pick_new

  block pick_old:
    v23 = std loadSlot 2
    std storeSlot 5 v23
    std br do_copy

  block pick_new:
    v24 = std loadSlot 1
    std storeSlot 5 v24
    std br do_copy

  block do_copy:
    // memcpy(new_ptr, old_ptr, copy_size).
    v25 = std loadSlot 4
    v26 = std loadSlot 0
    v27 = std loadSlot 5
    std memcpy v25 v26 v27

    // Zero the GROWN tail [copy_size, new_size). The new buffer came from
    // __mm_alloc (uninitialized slab bytes); memcpy only filled [0, copy_size).
    // A container that grows its buffer and fills it SPARSELY (a Map/Set hash
    // table) leaves the tail slots holding garbage, which its element-walk would
    // decref as live pointers → fault. Zeroing the tail makes unoccupied slots
    // read null so the walk skips them (matches C# `mm_raw_realloc`, whose new
    // buffer is zero-filled by `mm_raw_alloc` before the copy).
    v40 = std loadSlot 4
    v41 = std loadSlot 5
    v42 = std addI64 v40 v41
    v43 = std loadSlot 1
    v44 = std subI64 v43 v41
    std call mrt_memzero v42 v44

    // Slab-free the old buffer directly (bypassing mm_free): the new buffer
    // has taken ownership of the contents, so the destructor must NOT run.
    // slot_base = old_ptr - 32 (32-byte header).
    v28 = std loadSlot 0
    v29 = std constI64 32
    v30 = std subI64 v28 v29
    std storeSlot 6 v30
    v31 = std loadSlot 6
    v32 = std call __slab_free v31

    // Manually decrement __mm_alloc_count to balance the mm_alloc above.
    // (We bumped it once in mm_alloc, but the old allocation also still
    // counts — so net we need one decrement here.)
    v33 = std globalAddr __mm_alloc_count
    std atomicDec v33

    v34 = std loadSlot 4
    std ret v34
end

// __destruct___ManagedFile(self): destructor for a refcounted __ManagedFile
// handle. The handle is an 8-byte mm_alloc'd block holding the OS file
// descriptor at offset 0. When mm_decref drives the handle's refcount to
// zero, mm_free reads this destructor from the mm header and invokes it
// (via indirectCall) before slab-freeing — so a __ManagedFile local closes
// its fd automatically when it goes out of scope. The fd is loaded out of
// the handle and closed via mrt_file_close, which no-ops on the -1 sentinel
// an explicit `.close()` stored back, so an explicitly closed handle is not
// double-closed here. `mrt_file_close` is the per-target raw-fd close (the
// wasm backend hand-emits a WASI `fd_close` body), keeping this destructor
// target-neutral — it only loads a field and makes a call.
//
// Returns i64 (always 0) to match the indirect-call destructor ABI — see
// the __destruct___ManagedMemory header for why destructors return a value.
//
// Slot usage:
//   slot 0 = self (handle ptr)
func __destruct___ManagedFile 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std loadIndirect v0 0
    v2 = std call mrt_file_close v1
    v3 = std constI64 0
    std ret v3
end

// __managed_file_wrap(fd) -> handle: box a raw file descriptor into a
// refcounted __ManagedFile handle. Allocates an 8-byte mm block whose
// destructor is __destruct___ManagedFile (closes the fd on final decref)
// and stores the fd at offset 0. Refcount starts at 1; the caller owns
// that reference. Mirrors how a struct allocation carries its destructor.
//
// The lowering calls this unconditionally on every open, including the
// error path where the open returned the -1 sentinel. An invalid fd
// (negative) returns NULL (0) without allocating, so a failed open does
// not leak a handle — and the caller-side error-edge release the
// `callReturnRc1` classification plans is a null-guarded no-op (a
// negative-fd passthrough would feed the decref a non-pointer scalar).
//
// Slot usage:
//   slot 0 = fd
//   slot 1 = handle (returned)
func __managed_file_wrap 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    // Invalid (negative) fd → return null, no allocation.
    v8 = std constI64 0
    v9 = std cmpI64Lt v0 v8
    std condBr v9 invalid do_wrap

  block invalid:
    v10 = std constI64 0
    std ret v10

  block do_wrap:
    v1 = std constI64 8
    v2 = std funcAddr __destruct___ManagedFile
    // tag = MM_TAG_RAW (1): a fixed-size handle wrapper, no element type to name.
    v3 = std constI64 1
    v4 = std call __mm_alloc v1 v2 v3
    std storeSlot 1 v4
    // alloc-at-0: the returned __ManagedFile is an owned ref — incref to rc=1.
    v8 = std call __mm_incref v4
    v5 = std loadSlot 1
    v6 = std loadSlot 0
    std storeIndirect v5 0 v6
    v7 = std loadSlot 1
    std ret v7
end

// __mm_decref_maybenull_helper(ptr): the ONLY null-tolerant decref entry. Tolerates
// EXACTLY null (ptr == 0) — a value that is statically maybe-null at its release
// site (an `incomingOwner`/`selfReturnBorrow` value on a path that may not have
// stored, or a field-reassign old-occupant that may be unset) — and routes every
// non-null pointer through STRICT `mm_decref`. It does NOT tolerate arbitrary
// low/misrouted scalars: only exact 0 short-circuits, so a misrouted index/length
// still faults inside `__mm_decref` (the bug surfaces loudly instead of hiding).
// Emitted by the inserter only at the statically-maybe-null release classes and
// by the synthesized struct/field destructors; provably-live releases call
// strict `mm_decref` directly.
//
// Slot usage:
//   slot 0 = ptr
func __mm_decref_maybenull_helper 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 done do_decref

  block do_decref:
    v3 = std loadSlot 0
    v4 = std call mm_decref v3
    std br done

  block done:
    v5 = std constI64 0
    std ret v5
end

// =============================================================================
// __ManagedMemory builtin runtime helpers (step 6b.4).
//
// Each helper backs one of the 18 `__ManagedMemory.*` methods registered by
// `registerManagedMemoryMethods`. Lowering (`lowerManagedMemBuiltin` in
// LowerMaxonToStd) routes the throwing methods through these helpers so the
// per-method bounds-check + control-flow logic lives in one place rather than
// being duplicated at every call site. Each helper that wants to signal an
// error returns a non-zero variant ordinal (1..8) in the secondary return
// register (RDX/X1 — the multi-value-return error ABI) alongside a sentinel
// zero primary value; the parser-emitted `try ... otherwise` machinery picks
// up the error flag from the secondary register at the call site. The +1
// shift keeps 0 reserved for "no error in flight" — matching the `throw`
// lowering convention in `LowerMaxonToStd.lowerThrow`.
//
// __ManagedMemoryError ordinal map (mirrors stdlib/Builtins.maxon and the
// enum cases registered in registerManagedMemoryErrorEnum). The "wire"
// column shows the value placed in the error register (= ordinal + 1):
//   ordinal | name              | wire
//   0       | indexOutOfBounds  | 1
//   1       | emptySlot         | 2
//   2       | sliceOutOfBounds  | 3
//   3       | invalidLength     | 4
//   4       | invalidCapacity   | 5
//   5       | shiftOutOfBounds  | 6
//   6       | invalidByteRange  | 7
//   7       | invalidAllocation | 8
//
// Layout (5-field, 40-byte __ManagedMemory struct):
//   offset 0  buffer       i64 (heap pointer to mm_alloc'd buffer or 0)
//   offset 8  length       i64 (live element count)
//   offset 16 capacity     i64 (allocated element slots)
//   offset 24 element_size i64 (sizeof(Element); 1 for Byte, 8 otherwise)
//   offset 32 parent_ptr   i64 (-1 root; -2 rdata-backed; otherwise parent ptr)
// =============================================================================

// __layout_word_load(ptr) -> i64
// Reads 8 bytes from ptr. Used by Phase 11.2 layout copy/destroy thunks
// synthesized in BuildLayoutDescriptors when the Maxon dialect — which
// has no raw-pointer load/store ops — needs to manipulate layout-routed
// values. 8 bytes is enough because every Phase 11 generic instance arg
// in flight today (Array-shaped containers, struct fields, heap pointers)
// occupies a full pointer-sized slot.
//
// Slot usage:
//   slot 0 = ptr (arg)
func __layout_word_load 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std loadIndirect v0 0
    std ret v1
end

// __layout_word_store(ptr, v): stores 8 bytes (v) at ptr. Sibling of
// __layout_word_load — see that helper's comment for the rationale and
// the width discussion.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = v   (arg)
func __layout_word_store 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std storeIndirect v0 0 v1
    v2 = std constI64 0
    std ret v2
end

// =============================================================================
// Phase 3.4 — Subprocess + Clock runtime stubs.
//
// Each function below declares the ABI signature the self-hosted X64 backend's
// `emitDirectCall` looks up via `lookupFuncParamTypes`. Bodies are intentionally
// stubs that signal "operation unsupported" to the caller — the real Win32 /
// POSIX subprocess work is the heavy mechanical step 3.4 in the parent plan.
// Once a target's real implementation lands, replace the stub body in place.
//
// Return-shape conventions (matching the runtime contract in the parent plan):
//   int family       → -1 on failure, a valid handle / value otherwise.
//   managed family   → fresh empty __ManagedMemory; callers test via
//                       `__Builtins.managedIsNull`, which sees a real-but-empty
//                       MM as non-null. The Subprocess.maxon stub treats the
//                       managed-not-null result as "resolver hit" — a bare-name
//                       caller falls through to OS lookup, so the empty hit is
//                       fine for the smoke test path even though it'd misfire
//                       semantically for a name that should be reported as
//                       missing. Real PATH lookup lands later.
//   void family      → standard `ret 0` convention.

// maxon_current_time_ms() — monotonic clock helper for stdlib/Clock.maxon.
// Lowers to the target-neutral `osClockMs` op: x64-Windows reads
// kernel32!GetTickCount64 (ms since boot) via IAT; wasm32-wasi reads
// wasi:clocks/monotonic-clock.now (nanoseconds, divided to ms at MirToWasm).
// Linux/macOS lowerings are not yet implemented (the op panics there).
func maxon_current_time_ms 0 i64
  block entry:
    v0 = std osClockMs
    std ret v0
end

// maxon_sleep(ms) — suspends the current thread for `ms` milliseconds. The
// `std osSleep` op is target-neutral: each backend lowers it to the OS's
// blocking-sleep primitive (kernel32!Sleep on Windows, poll_oneoff with a
// CLOCK_MONOTONIC subscription on WASI, nanosleep syscall/libcall on
// Linux/macOS). The body returns 0 because the Maxon-level signature is
// void; the constI64 is bound to the return slot so the codegen path through
// `lookupFuncReturnStdType` resolves cleanly.
func maxon_sleep 1 void
  block entry:
    v0 = std param 0 i64
    std osSleep v0
    v1 = std constI64 0
    std ret v1
end


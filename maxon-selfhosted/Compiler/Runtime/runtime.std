// __managed_mem_cow_check(self) -> 0 (no error path)
// Buffer-level Copy-On-Write. If the receiver's capacity is >= 0 the
// buffer is already mm_alloc-owned and writable — no-op. If capacity < 0
// (rdata = -2 or slice = -1) the buffer is shared / read-only; allocate a
// fresh mm_alloc buffer of length*elemSize bytes, memcpy the old bytes
// in, store the fresh buffer back into self, and update capacity to
// length so subsequent capacity bounds checks work normally.
//
// Slot usage:
//   slot 0 = self      (arg)
//   slot 1 = capacity  (cached)
//   slot 2 = length
//   slot 3 = elemSize
//   slot 4 = byteLen   (length * elemSize)
//   slot 5 = newBuf
//   slot 6 = oldBuf
func __managed_mem_cow_check 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // If capacity >= 0, buffer is owned — return.
    v1 = std loadIndirect v0 16
    std storeSlot 1 v1
    v2 = std constI64 0
    v3 = std cmpI64Lt v1 v2
    std condBr v3 doCopy noCopy

  block noCopy:
    v100 = std constI64 0
    std ret v100

  block doCopy:
    // length, elemSize, byteLen
    v4 = std loadIndirect v0 8
    std storeSlot 2 v4
    v5 = std loadIndirect v0 24
    std storeSlot 3 v5
    v6 = std mulI64 v4 v5
    std storeSlot 4 v6

    // mm_alloc(byteLen, destructor=0, tag=0) — destructor isn't needed
    // because the buffer is a raw byte allocation (no nested heap refs).
    // For empty buffers (byteLen == 0) mm_alloc clamps to size 1.
    v7 = std loadSlot 4
    v8 = std constI64 0
    v9 = std constI64 0
    v10 = std call mm_alloc v7 v8 v9
    std storeSlot 5 v10

    // Save oldBuf BEFORE we mutate self.buffer.
    v11 = std loadIndirect v0 0
    std storeSlot 6 v11

    // memcpy(newBuf, oldBuf, byteLen) — std memcpy handles byteLen==0
    // safely (ABI requires it to be a no-op on zero count).
    v12 = std loadSlot 5
    v13 = std loadSlot 6
    v14 = std loadSlot 4
    std memcpy v12 v13 v14

    // self.buffer = newBuf
    v15 = std loadSlot 5
    std storeIndirect v0 0 v15
    // self.capacity = length (we allocated exactly length slots; subsequent
    // grow() calls will realloc as needed)
    v16 = std loadSlot 2
    std storeIndirect v0 16 v16
    // Old rdata/slice buffer is intentionally NOT freed: rdata lives in
    // the binary's read-only section; slice buffers are owned by their
    // parent struct (whose refcount tracks lifetime).

    v17 = std constI64 0
    std ret v17
end

// __managed_mem_grow(self, newCap) -> 0 (sets error invalidCapacity=4,
// wire 5, on newCap < capacity)

    v2 = std constI64 0
    v3 = std constI64 2
    v4 = std osFileLseek v1 v2 v3
    std storeSlot 1 v4

    v5 = std loadSlot 1
    v6 = std constI64 0
    v7 = std cmpI64Lt v5 v6

// Runtime functions expressed as Std-level IR.
// Parsed by StdParser into IrFunction objects.
// Uses std osExit / std osWrite for OS-independent runtime.

// mrt_start: process entry point. Calls main() and exits with its return code.
// Step 6a.17: bootstrap the slab/MM allocator before main() runs. `__slab_init`
// is idempotent so it's safe to call once unconditionally; the allocator's
// mutable globals (`__slab_init_done`, `__slab_arena_list_head`, ...) are
// registered in the .data prelude by `registerSlabAndMmGlobalsForDataSection`.
func mrt_start 0 void
  block entry:
    v2 = std call __slab_init
    v0 = std call main
    std osExit v0
    v1 = std constI64 0
    std ret v1
end

// mrt_write_stdout(ptr len): writes len bytes at ptr to stdout.
func mrt_write_stdout 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std osWrite v0 v1
    v2 = std constI64 0
    std ret v2
end

// mrt_write_stderr(ptr len): writes len bytes at ptr to stderr.
func mrt_write_stderr 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std osWriteErr v0 v1
    v2 = std constI64 0
    std ret v2
end

// mrt_i64_to_string(value buffer_ptr): converts integer to decimal string in buffer.
// Returns number of bytes written.
func mrt_i64_to_string 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v46 = std param 1 i64
    std storeSlot 1 v46
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 zero_case check_neg

  block zero_case:
    v3 = std loadSlot 1
    v4 = std constI64 0
    v5 = std constI64 0x30
    std storeByte v3 v4 v5
    v6 = std constI64 1
    std ret v6

  block check_neg:
    v7 = std constI64 0
    std storeSlot 5 v7
    v8 = std loadSlot 0
    std storeSlot 6 v8
    v9 = std constI64 0
    v10 = std cmpI64Lt v8 v9
    std condBr v10 negate setup

  block negate:
    v11 = std loadSlot 6
    v12 = std negI64 v11
    std storeSlot 6 v12
    v13 = std constI64 1
    std storeSlot 5 v13
    std br setup

  block setup:
    v14 = std stackAddr 2
    v15 = std constI64 20
    v16 = std addI64 v14 v15
    std storeSlot 7 v16
    v17 = std constI64 0
    v18 = std constI64 0
    std storeByte v16 v18 v17
    std br digit_loop

  block digit_loop:
    v19 = std loadSlot 7
    v20 = std constI64 1
    v21 = std subI64 v19 v20
    std storeSlot 7 v21
    v22 = std loadSlot 6
    v23 = std constI64 10
    v24 = std remI64 v22 v23
    v25 = std divI64 v22 v23
    std storeSlot 6 v25
    v26 = std constI64 0x30
    v27 = std addI64 v24 v26
    v28 = std constI64 0
    std storeByte v21 v28 v27
    v29 = std constI64 0
    v30 = std loadSlot 6
    v31 = std cmpI64Gt v30 v29
    std condBr v31 digit_loop check_sign

  block check_sign:
    v32 = std loadSlot 5
    v33 = std constI64 0
    v34 = std cmpI64Gt v32 v33
    std condBr v34 prepend_minus copy_phase

  block prepend_minus:
    v35 = std loadSlot 7
    v36 = std constI64 1
    v37 = std subI64 v35 v36
    std storeSlot 7 v37
    v38 = std constI64 0x2D
    v39 = std constI64 0
    std storeByte v37 v39 v38
    std br copy_phase

  block copy_phase:
    v40 = std stackAddr 2
    v41 = std constI64 20
    v42 = std addI64 v40 v41
    v43 = std loadSlot 7
    v44 = std subI64 v42 v43
    v45 = std loadSlot 1
    std memcpy v45 v43 v44
    std ret v44

end

// mrt_write_cstr_stderr(ptr): scans for null terminator, then writes to stderr.
func mrt_write_cstr_stderr 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    std storeSlot 1 v1
    std br scan

  block scan:
    v2 = std loadSlot 0
    v3 = std loadSlot 1
    v4 = std loadByte v2 v3
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 write scan_next

  block scan_next:
    v7 = std loadSlot 1
    v8 = std constI64 1
    v9 = std addI64 v7 v8
    std storeSlot 1 v9
    std br scan

  block write:
    v10 = std loadSlot 0
    v11 = std loadSlot 1
    v12 = std call mrt_write_stderr v10 v11
    v13 = std constI64 0
    std ret v13

end

// mrt_panic(msg_ptr): prints panic message + stack trace to stderr, then exits.
// Walks the RBP/X29 chain to print up to 32 stack frames.
//
// Slot usage:
//   slot 0 = msg_ptr (arg)
//   slot 1 = text_base (mrt_start address)
//   slot 2 = symtable_ptr
//   slot 3 = frame_ptr (current frame being walked)
//   slot 4 = frame_counter
func mrt_panic 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // Print panic message to stderr
    v1 = std call mrt_write_cstr_stderr v0

    // Print "Stack trace:\n"
    v2 = std globalAddr __panic_stacktrace
    v3 = std call mrt_write_cstr_stderr v2

    // Get text_base and symtable for frame lookup
    v4 = std funcAddr mrt_start
    std storeSlot 1 v4
    v5 = std funcAddr __symtable
    std storeSlot 2 v5

    // Walk the frame chain starting from our caller
    v6 = std loadFramePtr
    std storeSlot 3 v6

    // frame_counter = 32
    v13 = std constI64 32
    std storeSlot 4 v13
    std br walk_loop

  block walk_loop:
    // Check frame counter
    v14 = std loadSlot 4
    v15 = std constI64 0
    v16 = std cmpI64Eq v14 v15
    std condBr v16 walk_done check_frame_ptr

  block check_frame_ptr:
    // Decrement counter
    v17 = std loadSlot 4
    v18 = std constI64 1
    v19 = std subI64 v17 v18
    std storeSlot 4 v19

    // Load current frame_ptr
    v20 = std loadSlot 3
    v21 = std constI64 0
    v22 = std cmpI64Eq v20 v21
    std condBr v22 walk_done get_return_addr

  block get_return_addr:
    // Get return address: [frame_ptr + 8]
    v23 = std loadSlot 3
    v24 = std loadIndirect v23 8
    std storeSlot 6 v24
    v25 = std constI64 0
    v26 = std cmpI64Eq v24 v25
    std condBr v26 walk_done compute_offset

  block compute_offset:
    // Compute text_offset = return_addr - text_base
    v52 = std loadSlot 6
    v27 = std loadSlot 1
    v28 = std subI64 v52 v27
    std storeSlot 5 v28

    // Check if outside .text (negative or beyond code end)
    v29 = std constI64 0
    v30 = std cmpI64Lt v28 v29
    std condBr v30 walk_done check_upper_bound

  block check_upper_bound:
    v53 = std loadSlot 5
    v54 = std loadSlot 2
    v55 = std loadSlot 1
    v56 = std subI64 v54 v55
    v57 = std cmpI64Lt v53 v56
    std condBr v57 print_frame walk_done

  block print_frame:
    // Print this frame
    v51 = std loadSlot 5
    v31 = std loadSlot 2
    v32 = std call mrt_panic_print_frame v51 v31

    // Advance frame_ptr to next frame: [frame_ptr] = prev frame pointer
    v33 = std loadSlot 3
    v34 = std loadIndirect v33 0
    std storeSlot 3 v34
    std br walk_loop

  block walk_done:
    v35 = std constI64 1
    std osExit v35
    v36 = std constI64 0
    std ret v36

end

// mrt_panic_print_frame(text_offset, symtable_ptr):
// Looks up text_offset in the symbol table and prints "  in <funcName>\n".
//
// Symbol table format: count(i32) | entries[count] of {codeOffset(i32), nameOffset(i32)} | name strings
// Finds the largest codeOffset <= text_offset (best match).
//
// Slot usage:
//   slot 0 = text_offset (arg)
//   slot 1 = symtable_ptr (arg)
//   slot 2 = count (from symtable header)
//   slot 3 = loop index
//   slot 4 = best_name_offset (-1 = not found)
//   slot 5 = entry_ptr (current entry address)
func mrt_panic_print_frame 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // Print "  in "
    v2 = std globalAddr __panic_in
    v3 = std call mrt_write_cstr_stderr v2

    // Load count from symtable header (first 4 bytes as i32)
    // Load 8 bytes and mask to lower 32 bits
    v4 = std loadIndirect v1 0
    v5 = std constI64 0xFFFFFFFF
    v6 = std andI64 v4 v5
    std storeSlot 2 v6

    // Initialize loop: index = 0, best_name_offset = -1
    v7 = std constI64 0
    std storeSlot 3 v7
    v8 = std constI64 -1
    std storeSlot 4 v8
    std br lookup_loop

  block lookup_loop:
    // Check index < count
    v9 = std loadSlot 3
    v10 = std loadSlot 2
    v11 = std cmpI64Lt v9 v10
    std condBr v11 lookup_body lookup_done

  block lookup_body:
    // entry_ptr = symtable_ptr + 4 + index * 8
    v12 = std loadSlot 1
    v13 = std constI64 4
    v14 = std addI64 v12 v13
    v15 = std loadSlot 3
    v16 = std constI64 8
    v17 = std mulI64 v15 v16
    v18 = std addI64 v14 v17
    std storeSlot 5 v18

    // Load entry codeOffset (i32 at [entry_ptr + 0])
    v19 = std loadIndirect v18 0
    v20 = std constI64 0xFFFFFFFF
    v21 = std andI64 v19 v20

    // Check if text_offset >= codeOffset
    v22 = std loadSlot 0
    v23 = std cmpI64Lt v22 v21
    std condBr v23 lookup_next lookup_update

  block lookup_update:
    // Update best: load nameOffset (i32 at [entry_ptr + 4])
    v24 = std loadSlot 5
    v25 = std constI64 4
    v26 = std addI64 v24 v25
    v27 = std loadIndirect v26 0
    v28 = std constI64 0xFFFFFFFF
    v29 = std andI64 v27 v28
    std storeSlot 4 v29
    std br lookup_next

  block lookup_next:
    // index++
    v30 = std loadSlot 3
    v31 = std constI64 1
    v32 = std addI64 v30 v31
    std storeSlot 3 v32
    std br lookup_loop

  block lookup_done:
    // Check if found
    v33 = std loadSlot 4
    v34 = std constI64 -1
    v35 = std cmpI64Eq v33 v34
    std condBr v35 print_unknown print_name

  block print_name:
    // name_ptr = symtable_ptr + best_name_offset
    v36 = std loadSlot 1
    v37 = std loadSlot 4
    v38 = std addI64 v36 v37
    v39 = std call mrt_write_cstr_stderr v38
    std br print_newline

  block print_unknown:
    v40 = std globalAddr __panic_unknown
    v41 = std call mrt_write_cstr_stderr v40
    std br print_newline

  block print_newline:
    v42 = std globalAddr __panic_newline
    v43 = std call mrt_write_cstr_stderr v42
    v44 = std constI64 0
    std ret v44

end

// mrt_alloc(size): thin wrapper around mm_raw_alloc. All allocations go
// through the slab + MM raw path.
func mrt_alloc 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std call mm_raw_alloc v0
    std ret v1
end

// mrt_printInt(value): converts to string and prints to stdout.
func mrt_printInt 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std stackAddr 1
    v2 = std call mrt_i64_to_string v0 v1
    v3 = std stackAddr 1
    v4 = std call mrt_write_stdout v3 v2
    v5 = std constI64 0
    std ret v5
end

// mrt_cov_hit(siteId): increments __data_cov_counters[siteId].
// __data_cov_counters is a u64 array in .data sized numSites*8 bytes.
// Only invoked when coverage instrumentation was enabled at compile time;
// otherwise the runtime merge leaves the counters global unregistered and
// this function is never called from user code.
func mrt_cov_hit 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __data_cov_counters
    v2 = std constI64 3
    v3 = std shlI64 v0 v2
    v4 = std addI64 v1 v3
    v5 = std loadIndirect v4 0
    v6 = std constI64 1
    v7 = std addI64 v5 v6
    std storeIndirect v4 0 v7
    v8 = std constI64 0
    std ret v8
end

// mrt_cov_dump(): writes the coverage file when MAXON_COV_OUT is set.
// File format: 4-byte magic "MCOV" | 4-byte numSites (u32 LE) | numSites*8 bytes of counters (u64 LE).
//
// Slot usage:
//   slot 0 = bytes written by osGetEnv (path length)
//   slot 1 = fd returned by osOpenWrite
//   slot 2 = numSites (masked to u32)
//   slots 10..41 = 256-byte path buffer (32 qword slots)
//   slot 50 = 8-byte header buffer
func mrt_cov_dump 0 void
  block entry:
    v0 = std globalAddr __cov_env_name
    v1 = std constI64 13
    // Slots 10..41 reserve 256 bytes. Stack addresses go DOWN as slot index
    // goes up, so the LOWEST address of the buffer is at slot 41. Passing
    // stackAddr 41 as the ptr makes osGetEnv write FORWARD through slots
    // 41..10; using stackAddr 10 here would write OFF THE TOP of the buffer
    // into the saved frame and return address (works for ≤8-byte strings,
    // crashes on longer paths).
    v2 = std stackAddr 41
    v3 = std constI64 256
    v4 = std osGetEnv v0 v1 v2 v3
    std storeSlot 0 v4
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 done doOpen

  block doOpen:
    v7 = std stackAddr 41
    v8 = std loadSlot 0
    v9 = std osOpenWrite v7 v8
    std storeSlot 1 v9

    v10 = std globalAddr __data_cov_num_sites
    v11 = std loadIndirect v10 0
    v12 = std constI64 0xFFFFFFFF
    v13 = std andI64 v11 v12
    std storeSlot 2 v13

    v14 = std stackAddr 50

    v15 = std constI64 0
    v16 = std constI64 0x4D
    std storeByte v14 v15 v16
    v17 = std constI64 1
    v18 = std constI64 0x43
    std storeByte v14 v17 v18
    v19 = std constI64 2
    v20 = std constI64 0x4F
    std storeByte v14 v19 v20
    v21 = std constI64 3
    v22 = std constI64 0x56
    std storeByte v14 v21 v22

    v23 = std loadSlot 2
    v24 = std constI64 0xFF
    v25 = std andI64 v23 v24
    v26 = std constI64 4
    std storeByte v14 v26 v25

    v27 = std loadSlot 2
    v28 = std constI64 8
    v29 = std shrI64 v27 v28
    v30 = std constI64 0xFF
    v31 = std andI64 v29 v30
    v32 = std constI64 5
    std storeByte v14 v32 v31

    v33 = std loadSlot 2
    v34 = std constI64 16
    v35 = std shrI64 v33 v34
    v36 = std constI64 0xFF
    v37 = std andI64 v35 v36
    v38 = std constI64 6
    std storeByte v14 v38 v37

    v39 = std loadSlot 2
    v40 = std constI64 24
    v41 = std shrI64 v39 v40
    v42 = std constI64 0xFF
    v43 = std andI64 v41 v42
    v44 = std constI64 7
    std storeByte v14 v44 v43

    v45 = std loadSlot 1
    v46 = std stackAddr 50
    v47 = std constI64 8
    std osWriteFd v45 v46 v47

    v48 = std loadSlot 1
    v49 = std globalAddr __data_cov_counters
    v50 = std loadSlot 2
    v51 = std constI64 3
    v52 = std shlI64 v50 v51
    std osWriteFd v48 v49 v52

    v53 = std loadSlot 1
    std osClose v53
    std br done

  block done:
    v54 = std constI64 0
    std ret v54
end

// mrt_start_with_coverage: entry point used when coverage is enabled.
// Calls main, invokes mrt_cov_dump to flush counters, then exits with main's result.
// augmentWithRuntime selects between this and mrt_start based on project.coverageEnabled.
func mrt_start_with_coverage 0 void
  block entry:
    v4 = std call __slab_init
    v0 = std call main
    std storeSlot 0 v0
    v1 = std call mrt_cov_dump
    v2 = std loadSlot 0
    std osExit v2
    v3 = std constI64 0
    std ret v3
end

// mrt_set_error(code): writes `code` into the thread-local error slot
// (__data_maxon_error). Used by the throw lowering path: a throwing function
// that wants to signal failure stores the variant ordinal here, then returns a
// default primary value. The caller's `try EXPR` reads (and clears) the slot
// via mrt_get_error_and_clear immediately after the call returns. Returns 0.
//
// Slot usage:
//   slot 0 = code (arg)
func mrt_set_error 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __data_maxon_error
    std storeIndirect v1 0 v0
    v2 = std constI64 0
    std ret v2
end

// mrt_get_error_and_clear(): reads the thread-local error slot and zeroes it.
// Returns the prior error code (0 = no error in flight). Used by the tryCall
// lowering path: the caller emits `let flag = mrt_get_error_and_clear()`
// immediately after a throwing call returns. The clear-on-read semantics mean
// a successful call leaves the slot at 0 for the next caller, and a propagated
// error is observed exactly once at the catch site.
func mrt_get_error_and_clear 0 i64
  block entry:
    v0 = std globalAddr __data_maxon_error
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    std storeIndirect v0 0 v2
    std ret v1
end

// =============================================================================
// Slab allocator — bottom layer (step 6a.12 of the allocator port).
//
// Provides:
//   - __slab_memzero            byte-zero helper used by upper layers.
//   - __slab_arena_init         allocates the first 64MB arena from the OS,
//                               sets up its bitmap, links it into the head.
//   - __slab_arena_alloc_chunks bitmap scan for N contiguous 8KB chunks.
//   - __slab_arena_free_chunks  marks chunks free in the bitmap.
//   - __slab_init               public init entry; idempotent.
//
// The upper layers (mspan, mcentral, mcache, arena map, mm_*) live in later
// steps. None of these functions are reachable from user code yet — step 6a.17
// will wire __slab_init into mrt_start and step 6a.18 will route mrt_alloc /
// __mm_alloc through the slab. Until then this file simply has to PARSE,
// LOWER, and EMIT cleanly so the build keeps producing a working binary.
//
// Constants (mirrored from RuntimeEmitter.Allocator.cs):
//   ARENA_SIZE           = 0x4000000   // 64 MiB
//   CHUNK_SIZE           = 0x2000      // 8 KiB
//   CHUNKS_PER_ARENA     = 0x2000      // 8192 chunks
//   ARENA_META_OFF_NEXT  = 0x00
//   ARENA_META_OFF_BITMAP= 0x10        // 1024-byte bitmap, 128 qwords
//
// Mutable globals expected by these functions:
//   __slab_arena_list_head   8 bytes — head of the singly-linked arena list
//   __slab_arena_last_base   8 bytes — arena base of the most recent
//                                       successful arena_alloc_chunks call
//   __slab_init_done         8 bytes — 0 = uninitialised, 1 = ready
//
// TODO(step 6a.17): the X64/Arm64 backends do not yet register these `__slab_*`
// labels in either the rdata or .data prelude. globalAddr emits a relocation
// referencing the unregistered label, and `lookupRdataOffset` silently returns
// offset 0 — harmless because the functions in this block are unreached, but
// the bootstrap step that calls __slab_init from mrt_start MUST first arrange
// for these globals to be backed by writable storage (likely via a new
// addDataSectionEntry call, mirroring registerErrorStateForDataSection).
//
// TODO(step 6a.13+): size-class lookup tables (__slab_class_sizes,
// __slab_objs_per_span) are not emitted here — the chunk allocator does not
// need them. They will arrive with the mspan/mcentral layer.
// =============================================================================

// __slab_memzero(ptr, size): zeros `size` bytes starting at `ptr`. Loops one
// byte at a time so callers don't have to ensure 8-byte alignment of `size`.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = size (arg)
//   slot 2 = i (loop counter)
func __slab_memzero 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std constI64 0
    std storeSlot 2 v2
    std br loop

  block loop:
    v3 = std loadSlot 2
    v4 = std loadSlot 1
    v5 = std cmpI64Lt v3 v4
    std condBr v5 body done

  block body:
    v6 = std loadSlot 0
    v7 = std loadSlot 2
    v8 = std constI64 0
    std storeByte v6 v7 v8
    v9 = std loadSlot 2
    v10 = std constI64 1
    v11 = std addI64 v9 v10
    std storeSlot 2 v11
    std br loop

  block done:
    v12 = std constI64 0
    std ret v12
end

// __slab_arena_init(): allocates the very first 64 MiB arena from the OS,
// initialises its metadata + bitmap, prepends it to the arena list, and
// flips __slab_init_done to 1. Idempotent — only runs when the head is null.
//
// Bitmap layout: chunk 0 holds the metadata, so its bit must stay 0 (used).
// All other 8191 chunks start as 1 (free). 128 qwords of bitmap. We write
// 0xFFFFFFFFFFFFFFFE into qword 0 and 0xFFFFFFFFFFFFFFFF into qwords 1..127.
//
// Slot usage:
//   slot 0 = arena_base
//   slot 1 = qword index (loop counter)
func __slab_arena_init 0 void
  block entry:
    v0 = std constI64 0x4000000
    v1 = std osAllocPages v0
    std storeSlot 0 v1

    // metadata: next = NULL  (offset 0x00)
    v2 = std constI64 0
    std storeIndirect v1 0 v2

    // bitmap qword 0 = 0xFFFFFFFFFFFFFFFE  (chunk 0 used, rest free)
    // arena_base + 0x10
    v3 = std constI64 0x10
    v4 = std addI64 v1 v3
    v5 = std constI64 -2
    std storeIndirect v4 0 v5

    // qwords 1..127 = 0xFFFFFFFFFFFFFFFF
    v6 = std constI64 1
    std storeSlot 1 v6
    std br fill_loop

  block fill_loop:
    v7 = std loadSlot 1
    v8 = std constI64 128
    v9 = std cmpI64Lt v7 v8
    std condBr v9 fill_body fill_done

  block fill_body:
    v10 = std loadSlot 0
    v11 = std loadSlot 1
    v12 = std constI64 3
    v13 = std shlI64 v11 v12
    v14 = std constI64 0x10
    v15 = std addI64 v13 v14
    v16 = std addI64 v10 v15
    v17 = std constI64 -1
    std storeIndirect v16 0 v17
    v18 = std loadSlot 1
    v19 = std constI64 1
    v20 = std addI64 v18 v19
    std storeSlot 1 v20
    std br fill_loop

  block fill_done:
    // Prepend to the arena list head: new->next = old_head; head = new.
    v21 = std globalAddr __slab_arena_list_head
    v22 = std loadIndirect v21 0
    v23 = std loadSlot 0
    std storeIndirect v23 0 v22
    std storeIndirect v21 0 v23

    // __slab_init_done = 1
    v24 = std globalAddr __slab_init_done
    v25 = std constI64 1
    std storeIndirect v24 0 v25

    v26 = std constI64 0
    std ret v26
end

// __slab_arena_alloc_chunks(num_chunks) -> ptr
//
// Walks the arena list scanning each arena's bitmap bit-by-bit for a run of
// `num_chunks` consecutive free chunks. On success: clears those bits, stores
// the arena base in __slab_arena_last_base, and returns
// (arena_base + run_start * CHUNK_SIZE).
//
// On failure (no arena has room): allocates a fresh 64 MiB arena via the OS,
// links it in, and retries. The C# implementation uses a qword-level fast
// path with BSF; this port uses a simple bit-by-bit scan. The bottom layer
// is not on a hot path yet (chunks are allocated rarely — once per mspan
// refill or arena-map L2), so the simpler scan is fine for now.
//
// TODO(perf, step 6a.18): port the qword/BSF fast path from
// EmitArenaAllocChunks once the upper layer is calling this in production.
//
// Slot usage:
//   slot 0  = num_chunks (arg)
//   slot 1  = arena_ptr (current arena being scanned)
//   slot 2  = i (chunk index 0..ChunksPerArena)
//   slot 3  = run_len
//   slot 4  = run_start
//   slot 5  = result ptr
//   slot 6  = j (clear loop counter)
func __slab_arena_alloc_chunks 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std globalAddr __slab_arena_list_head
    v2 = std loadIndirect v1 0
    std storeSlot 1 v2
    std br arena_loop

  block arena_loop:
    v3 = std loadSlot 1
    v4 = std constI64 0
    v5 = std cmpI64Eq v3 v4
    std condBr v5 grow_arena scan_init

  block scan_init:
    // i = 1 (skip chunk 0, always used by metadata)
    v6 = std constI64 1
    std storeSlot 2 v6
    v7 = std constI64 0
    std storeSlot 3 v7
    v8 = std constI64 0
    std storeSlot 4 v8
    std br bit_loop

  block bit_loop:
    // i < CHUNKS_PER_ARENA (8192)?
    v9 = std loadSlot 2
    v10 = std constI64 0x2000
    v11 = std cmpI64Lt v9 v10
    std condBr v11 bit_body next_arena

  block bit_body:
    // qword_idx = i >> 6
    v12 = std loadSlot 2
    v13 = std constI64 6
    v14 = std shrI64 v12 v13
    // qword_addr = arena + 0x10 + qword_idx * 8
    v15 = std loadSlot 1
    v16 = std constI64 3
    v17 = std shlI64 v14 v16
    v18 = std constI64 0x10
    v19 = std addI64 v17 v18
    v20 = std addI64 v15 v19
    v21 = std loadIndirect v20 0
    // bit = (qword >> (i & 63)) & 1
    v22 = std constI64 63
    v23 = std andI64 v12 v22
    v24 = std shrI64 v21 v23
    v25 = std constI64 1
    v26 = std andI64 v24 v25
    v27 = std constI64 0
    v28 = std cmpI64Eq v26 v27
    std condBr v28 bit_used bit_free

  block bit_used:
    // run broken
    v29 = std constI64 0
    std storeSlot 3 v29
    std br bit_advance

  block bit_free:
    // run_len was 0? then run_start = i.
    v30 = std loadSlot 3
    v31 = std constI64 0
    v32 = std cmpI64Eq v30 v31
    std condBr v32 set_start incr_run

  block set_start:
    v33 = std loadSlot 2
    std storeSlot 4 v33
    std br incr_run

  block incr_run:
    v34 = std loadSlot 3
    v35 = std constI64 1
    v36 = std addI64 v34 v35
    std storeSlot 3 v36
    // run_len >= num_chunks?
    v37 = std loadSlot 0
    v38 = std cmpI64Lt v36 v37
    std condBr v38 bit_advance found

  block bit_advance:
    v39 = std loadSlot 2
    v40 = std constI64 1
    v41 = std addI64 v39 v40
    std storeSlot 2 v41
    std br bit_loop

  block next_arena:
    // arena = arena->next  (offset 0x00)
    v42 = std loadSlot 1
    v43 = std loadIndirect v42 0
    std storeSlot 1 v43
    std br arena_loop

  block found:
    // Clear bits run_start..run_start+num_chunks-1 in the bitmap.
    // j = run_start
    v44 = std loadSlot 4
    std storeSlot 6 v44
    std br clear_loop

  block clear_loop:
    // j < run_start + num_chunks?
    v45 = std loadSlot 6
    v46 = std loadSlot 4
    v47 = std loadSlot 0
    v48 = std addI64 v46 v47
    v49 = std cmpI64Lt v45 v48
    std condBr v49 clear_body clear_done

  block clear_body:
    // qword_addr = arena + 0x10 + (j >> 6) * 8
    v50 = std constI64 6
    v51 = std shrI64 v45 v50
    v52 = std constI64 3
    v53 = std shlI64 v51 v52
    v54 = std constI64 0x10
    v55 = std addI64 v53 v54
    v56 = std loadSlot 1
    v57 = std addI64 v56 v55
    // mask = ~(1 << (j & 63))
    v58 = std constI64 63
    v59 = std andI64 v45 v58
    v60 = std constI64 1
    v61 = std shlI64 v60 v59
    v62 = std bitNotI64 v61
    // bitmap[qword] &= mask
    v63 = std loadIndirect v57 0
    v64 = std andI64 v63 v62
    std storeIndirect v57 0 v64
    // j++
    v65 = std constI64 1
    v66 = std addI64 v45 v65
    std storeSlot 6 v66
    std br clear_loop

  block clear_done:
    // __slab_arena_last_base = arena_ptr
    v67 = std globalAddr __slab_arena_last_base
    v68 = std loadSlot 1
    std storeIndirect v67 0 v68
    // result = arena + run_start * CHUNK_SIZE
    v69 = std loadSlot 4
    v70 = std constI64 13
    v71 = std shlI64 v69 v70
    v72 = std loadSlot 1
    v73 = std addI64 v72 v71
    std ret v73

  block grow_arena:
    // No arena had room — allocate a fresh 64 MiB arena from the OS, link
    // it in, then jump back to the top to retry the scan.
    v74 = std constI64 0x4000000
    v75 = std osAllocPages v74
    std storeSlot 1 v75

    // metadata: next = old_head
    v76 = std globalAddr __slab_arena_list_head
    v77 = std loadIndirect v76 0
    std storeIndirect v75 0 v77

    // bitmap qword 0 = 0xFFFFFFFFFFFFFFFE
    v78 = std constI64 0x10
    v79 = std addI64 v75 v78
    v80 = std constI64 -2
    std storeIndirect v79 0 v80

    // qwords 1..127 = -1 (all free)
    v81 = std constI64 1
    std storeSlot 6 v81
    std br grow_fill_loop

  block grow_fill_loop:
    v82 = std loadSlot 6
    v83 = std constI64 128
    v84 = std cmpI64Lt v82 v83
    std condBr v84 grow_fill_body grow_fill_done

  block grow_fill_body:
    v85 = std loadSlot 1
    v86 = std loadSlot 6
    v87 = std constI64 3
    v88 = std shlI64 v86 v87
    v89 = std constI64 0x10
    v90 = std addI64 v88 v89
    v91 = std addI64 v85 v90
    v92 = std constI64 -1
    std storeIndirect v91 0 v92
    v93 = std loadSlot 6
    v94 = std constI64 1
    v95 = std addI64 v93 v94
    std storeSlot 6 v95
    std br grow_fill_loop

  block grow_fill_done:
    // head = new_arena (slot 1 still holds it)
    v96 = std loadSlot 1
    std storeIndirect v76 0 v96
    // Restart the scan against the fresh arena.
    std br arena_loop
end

// __slab_arena_free_chunks(arena_base, chunk_index, num_chunks)
//
// Marks chunks [chunk_index .. chunk_index + num_chunks - 1] as free in the
// bitmap of the given arena. Bit-by-bit OR; the C# version uses qword masks.
//
// Slot usage:
//   slot 0 = arena_base (arg)
//   slot 1 = chunk_index (arg)
//   slot 2 = num_chunks (arg)
//   slot 3 = j (loop counter, absolute chunk index)
func __slab_arena_free_chunks 3 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2

    // j = chunk_index
    std storeSlot 3 v1
    std br loop

  block loop:
    // j < chunk_index + num_chunks?
    v3 = std loadSlot 3
    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std addI64 v4 v5
    v7 = std cmpI64Lt v3 v6
    std condBr v7 body done

  block body:
    // qword_addr = arena_base + 0x10 + (j >> 6) * 8
    v8 = std constI64 6
    v9 = std shrI64 v3 v8
    v10 = std constI64 3
    v11 = std shlI64 v9 v10
    v12 = std constI64 0x10
    v13 = std addI64 v11 v12
    v14 = std loadSlot 0
    v15 = std addI64 v14 v13
    // bitmap[qword] |= 1 << (j & 63)
    v16 = std constI64 63
    v17 = std andI64 v3 v16
    v18 = std constI64 1
    v19 = std shlI64 v18 v17
    v20 = std loadIndirect v15 0
    v21 = std orI64 v20 v19
    std storeIndirect v15 0 v21
    // j++
    v22 = std constI64 1
    v23 = std addI64 v3 v22
    std storeSlot 3 v23
    std br loop

  block done:
    v24 = std constI64 0
    std ret v24
end

// __slab_init(): public init entry. Idempotent — runs __slab_arena_init
// only if __slab_init_done is still 0. The size-class tables and the
// upper-layer state (mcache, mcentral, arena map, OS-direct array) are NOT
// set up here yet — they belong to step 6a.13+.
func __slab_init 0 void
  block entry:
    v0 = std globalAddr __slab_init_done
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 do_init done

  block do_init:
    v4 = std call __slab_arena_init
    std br done

  block done:
    v5 = std constI64 0
    std ret v5
end

// =============================================================================
// Slab allocator — middle layer (step 6a.13 of the allocator port).
//
// Adds the mspan / mcentral / mcache layer on top of the chunk allocator.
//
// Provides:
//   - __slab_class_size(idx)        size-class lookup table (cascade compares).
//   - __slab_objs_per_span(idx)     objects-per-span lookup table.
//   - __slab_meta_alloc()           hands out 64-byte mspan-header slots,
//                                   backed by a free list + bump pointer that
//                                   refills from a dedicated 8 KiB chunk.
//   - __slab_meta_free(ptr)         pushes a 64-byte slot back onto the free
//                                   list.
//   - __slab_refill_mcache(class)   drains a span from mcentral.partial or
//                                   builds a fresh one, stores it in
//                                   mcache[class].
//   - __slab_alloc_class(class)     fast-path: pop a slot from the cached
//                                   span, refilling mcache on miss.
//   - __slab_free_class_with_mspan(slot, mspan)
//                                   pushes a slot back onto its span's free
//                                   list. The arena-map–driven public free
//                                   path (`__slab_free`) belongs to step
//                                   6a.14 — until then callers must already
//                                   know the owning mspan.
//
// Globals consumed (declared by step 6a.17 alongside the chunk-allocator
// globals — see the TODO atop the bottom-layer block):
//   __slab_mcache_base     8 bytes  pointer-array of 18 mspan*; single-thread.
//   __slab_meta_free_head  8 bytes  head of intrusive free-list of 64 B slots.
//   __slab_meta_bump_ptr   8 bytes  current bump pointer in metadata chunk.
//   __slab_meta_bump_end   8 bytes  end of the metadata chunk.
//   __slab_mcentral_array  288 B    18 × {partial_head(8), full_head(8)}.
//
// mspan struct (64 bytes, mirrors RuntimeEmitter.Allocator.cs):
//   +0x00 base_addr    +0x08 slot_size   +0x10 free_list   +0x18 free_count
//   +0x20 next_span    +0x28 class_idx   +0x30 total_slots +0x38 arena_base
//
// TODO(step 6a.14): introduce `__slab_free` (public) that recovers the mspan
// from the slot pointer via the two-level arena map, then forwards to
// __slab_free_class_with_mspan. Until then the slab allocator leaks freed
// slots — acceptable per the plan because user code is not yet routed
// through it.
//
// TODO(step 6a.17): the per-class mcentral locks (__slab_mcentral_lock_<i>,
// 40 bytes on Windows / 24 on Linux) are intentionally NOT acquired here.
// The self-hosted compiler currently runs single-threaded so contention is
// impossible; once threading lands the lock acquire/release must be inserted
// at the marked sites in __slab_refill_mcache.
// =============================================================================

// __slab_class_size(idx) -> i64
// Returns SlabClassSizes[idx]. Implemented as a cascade of equality compares
// rather than a data-table load so we don't have to register a new symdata
// global in this step (that would also pull in step-6a.17 work). The 18-way
// cascade is fine — it sits behind both __slab_alloc_class (size class is
// already known statically by the caller in many cases) and the upcoming
// __slab_alloc which dispatches once per allocation.

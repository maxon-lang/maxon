// __slab_meta_alloc() -> ptr
// Hands out 64-byte slots used as mspan-header storage. Three-tier:
//   1. Pop from intrusive free-list at __slab_meta_free_head if non-null:
//      result = head; head = [head]. (The first 8 bytes of a freed slot
//      hold the next-pointer.)
//   2. Otherwise bump within the current metadata chunk: if
//      bump_ptr + 64 ≤ bump_end, return bump_ptr and advance.
//   3. Otherwise grab a new 8 KiB chunk from the chunk allocator (one chunk
//      = 128 mspans), reserve its first 64 B as the return value, and seed
//      bump_ptr = chunk + 64, bump_end = chunk + 8192.
//
// Slot usage:
//   slot 0 = candidate ptr / chunk_base
//   slot 1 = next free-list head / advanced bump_ptr
//   slot 2 = bump_end (only on bump path)
func __slab_meta_alloc 0 i64
  block entry:
    // --- Free list path ---
    v0 = std globalAddr __slab_meta_free_head
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 try_bump pop_free

  block pop_free:
    // result = v1; head = [v1]
    v4 = std loadIndirect v1 0
    std storeIndirect v0 0 v4
    std ret v1

  block try_bump:
    // bump_ptr + 64 ≤ bump_end ?
    v5 = std globalAddr __slab_meta_bump_ptr
    v6 = std loadIndirect v5 0
    std storeSlot 0 v6
    v7 = std constI64 0x40
    v8 = std addI64 v6 v7
    std storeSlot 1 v8
    v9 = std globalAddr __slab_meta_bump_end
    v10 = std loadIndirect v9 0
    std storeSlot 2 v10
    // Use signed Lt — both values are valid pointers in user space, well below
    // 0x8000_0000_0000_0000, so signed and unsigned compares agree here.
    v11 = std cmpI64Lt v10 v8
    std condBr v11 grow do_bump

  block do_bump:
    // bump_ptr = bump_ptr + 64; return old bump_ptr
    v12 = std loadSlot 1
    std storeIndirect v5 0 v12
    v13 = std loadSlot 0
    std ret v13

  block grow:
    // Need a fresh metadata chunk.
    v14 = std constI64 1
    v15 = std call __slab_arena_alloc_chunks v14
    std storeSlot 0 v15
    // bump_ptr = chunk_base + 64
    v16 = std constI64 0x40
    v17 = std addI64 v15 v16
    v18 = std globalAddr __slab_meta_bump_ptr
    std storeIndirect v18 0 v17
    // bump_end = chunk_base + 8192
    v19 = std constI64 0x2000
    v20 = std addI64 v15 v19
    v21 = std globalAddr __slab_meta_bump_end
    std storeIndirect v21 0 v20
    // Return chunk_base — the first 64-byte slot of the fresh chunk.
    std ret v15
end

// __slab_meta_free(ptr): pushes `ptr` onto the metadata free list.
// [ptr] = old_head; head = ptr. The slot's first 8 bytes are clobbered with
// the next-pointer, which is fine — the caller is done with the contents.
//
// Slot usage:
//   slot 0 = ptr (arg)
func __slab_meta_free 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __slab_meta_free_head
    v2 = std loadIndirect v1 0
    std storeIndirect v0 0 v2
    std storeIndirect v1 0 v0
    v3 = std constI64 0
    std ret v3
end

// __slab_refill_mcache(class_idx): repopulates mcache[class_idx] with a span
// that has at least one free slot. Two-tier:
//   1. Pop the head of mcentral[class_idx].partial — clearing its next_span
//      pointer — and store it as mcache[class_idx]. The mcentral.partial list
//      is the source of recycled spans.
//   2. If partial is empty: build a brand-new span by allocating chunks for
//      the slot data, an mspan header from the metadata slab, initialising
//      the mspan fields, then walking the slot region wiring up the
//      intrusive free list ([slot[i]] = slot[i+1], last slot's next = 0).
//
// Lock acquire/release intentionally elided — see the file-level TODO for
// step 6a.17.
//
// Slot usage:
//   slot 0  = class_idx (arg)
//   slot 1  = mcentral entry addr
//   slot 2  = mcache slot addr  (mcache_base + class_idx * 8)
//   slot 3  = span_ptr (winning mspan)
//   slot 4  = slot_size
//   slot 5  = total_slots (objs_per_span)
//   slot 6  = data_size = slot_size * total_slots
//   slot 7  = num_chunks
//   slot 8  = page_base (slot region base)
//   slot 9  = arena_base (most recent arena from chunk allocator)
//   slot 10 = i (free-list build counter)
//   slot 11 = current slot addr
//   slot 12 = next slot addr
func __slab_refill_mcache 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // mcentral_entry_addr = __slab_mcentral_array + class_idx * 16
    v1 = std globalAddr __slab_mcentral_array
    v2 = std constI64 4
    v3 = std shlI64 v0 v2
    v4 = std addI64 v1 v3
    std storeSlot 1 v4

    // mcache_slot_addr = __slab_mcache_base + class_idx * 8
    v5 = std globalAddr __slab_mcache_base
    v6 = std constI64 3
    v7 = std shlI64 v0 v6
    v8 = std addI64 v5 v7
    std storeSlot 2 v8

    // TODO(step 6a.17): acquire __slab_mcentral_lock_<class_idx>.

    // partial = mcentral_entry.partial_head
    v9 = std loadIndirect v4 0
    v10 = std constI64 0
    v11 = std cmpI64Eq v9 v10
    std condBr v11 grow_new take_partial

  block take_partial:
    // span = partial; partial_head = span.next_span; span.next_span = 0
    std storeSlot 3 v9
    v12 = std loadIndirect v9 0x20
    v13 = std loadSlot 1
    std storeIndirect v13 0 v12
    v14 = std constI64 0
    std storeIndirect v9 0x20 v14
    std br install

  block grow_new:
    // Fetch class parameters.
    v15 = std loadSlot 0
    v16 = std call __slab_class_size v15
    std storeSlot 4 v16
    v17 = std loadSlot 0
    v18 = std call __slab_objs_per_span v17
    std storeSlot 5 v18

    // data_size = slot_size * total_slots
    v19 = std mulI64 v16 v18
    std storeSlot 6 v19

    // num_chunks = (data_size + 8191) >> 13
    v20 = std constI64 8191
    v21 = std addI64 v19 v20
    v22 = std constI64 13
    v23 = std shrI64 v21 v22
    std storeSlot 7 v23

    // page_base = __slab_arena_alloc_chunks(num_chunks)
    v24 = std call __slab_arena_alloc_chunks v23
    std storeSlot 8 v24

    // arena_base = __slab_arena_last_base
    v25 = std globalAddr __slab_arena_last_base
    v26 = std loadIndirect v25 0
    std storeSlot 9 v26

    // span = __slab_meta_alloc()
    v27 = std call __slab_meta_alloc
    std storeSlot 3 v27

    // Initialise mspan fields.
    //   +0x00 base_addr   = page_base
    //   +0x08 slot_size   = slot_size
    //   +0x10 free_list   = page_base
    //   +0x18 free_count  = total_slots
    //   +0x20 next_span   = 0
    //   +0x28 class_idx   = class_idx
    //   +0x30 total_slots = total_slots
    //   +0x38 arena_base  = arena_base
    std storeIndirect v27 0x00 v24
    std storeIndirect v27 0x08 v16
    std storeIndirect v27 0x10 v24
    std storeIndirect v27 0x18 v18
    v28 = std constI64 0
    std storeIndirect v27 0x20 v28
    v29 = std loadSlot 0
    std storeIndirect v27 0x28 v29
    std storeIndirect v27 0x30 v18
    std storeIndirect v27 0x38 v26

    // Register the new mspan in the arena map so __slab_arena_map_get
    // (and therefore __slab_free) can recover it from any slot pointer.
    // num_pages == num_chunks because chunks and pages are both 8KB.
    v53 = std loadSlot 8
    v54 = std loadSlot 7
    v55 = std loadSlot 3
    v56 = std call __slab_arena_map_set v53 v54 v55

    // Build the intrusive free list. i = 0.
    v30 = std constI64 0
    std storeSlot 10 v30
    std br link_loop

  block link_loop:
    v31 = std loadSlot 10
    v32 = std loadSlot 5
    v33 = std cmpI64Lt v31 v32
    std condBr v33 link_body install

  block link_body:
    // current = page_base + i * slot_size
    v34 = std loadSlot 10
    v35 = std loadSlot 4
    v36 = std mulI64 v34 v35
    v37 = std loadSlot 8
    v38 = std addI64 v37 v36
    std storeSlot 11 v38

    // i + 1 == total_slots ?
    v39 = std constI64 1
    v40 = std addI64 v34 v39
    v41 = std loadSlot 5
    v42 = std cmpI64Eq v40 v41
    std condBr v42 last_slot mid_slot

  block mid_slot:
    // [current] = page_base + (i+1) * slot_size
    v43 = std mulI64 v40 v35
    v44 = std loadSlot 8
    v45 = std addI64 v44 v43
    std storeIndirect v38 0 v45
    std br link_advance

  block last_slot:
    // [current] = 0
    v46 = std constI64 0
    std storeIndirect v38 0 v46
    std br link_advance

  block link_advance:
    v47 = std loadSlot 10
    v48 = std constI64 1
    v49 = std addI64 v47 v48
    std storeSlot 10 v49
    std br link_loop

  block install:
    // mcache[class_idx] = span
    v50 = std loadSlot 2
    v51 = std loadSlot 3
    std storeIndirect v50 0 v51

    // TODO(step 6a.17): release __slab_mcentral_lock_<class_idx>.

    v52 = std constI64 0
    std ret v52
end

// __slab_alloc_class(class_idx) -> ptr
// Fast path slab allocator. Pops a slot from the cached mspan in
// mcache[class_idx]. Refills via __slab_refill_mcache when the slot is empty,
// retries once, then proceeds with the pop. A successful pop also clears the
// mcache entry when the span runs out of free slots so the next allocation
// triggers a refill rather than walking a depleted span on every call.
//
// Structure: rather than a back-edge `do_refill -> load_span` retry loop
// (which keeps mcache_slot_addr live across the refill call and trips the
// register allocator's caller-saved spill heuristics), the body is laid out
// linearly. The first attempt either succeeds and falls through to the pop,
// or jumps to a refill block that calls `__slab_refill_mcache` then
// recomputes mcache_slot_addr from scratch and proceeds with the pop —
// `__slab_refill_mcache` guarantees the mcache slot now references a span
// with at least one free slot.
//
// Slot usage:
//   slot 0 = class_idx (arg)
//   slot 1 = mcache_slot_addr
//   slot 2 = span_ptr
//   slot 3 = result slot
func __slab_alloc_class 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // mcache_slot_addr = __slab_mcache_base + class_idx * 8
    v1 = std globalAddr __slab_mcache_base
    v2 = std constI64 3
    v3 = std shlI64 v0 v2
    v4 = std addI64 v1 v3
    std storeSlot 1 v4

    // span = [mcache_slot]
    v5 = std loadIndirect v4 0
    v6 = std constI64 0
    v7 = std cmpI64Eq v5 v6
    std condBr v7 do_refill check_count

  block check_count:
    // Defensive: a cached span could in principle have free_count == 0 (e.g.
    // after a future thread hand-off). Treat it as a miss and refill.
    std storeSlot 2 v5
    v8 = std loadIndirect v5 0x18
    v9 = std constI64 0
    v10 = std cmpI64Eq v8 v9
    std condBr v10 do_refill pop_slot

  block do_refill:
    v11 = std loadSlot 0
    v12 = std call __slab_refill_mcache v11

    // Recompute mcache_slot_addr — the value we computed in entry was kept in
    // a caller-saved register that the call clobbers, so reload from slot 0
    // (class_idx) and rebuild instead of relying on slot 1 being live in a
    // register.
    v13 = std loadSlot 0
    v14 = std globalAddr __slab_mcache_base
    v15 = std constI64 3
    v16 = std shlI64 v13 v15
    v17 = std addI64 v14 v16
    std storeSlot 1 v17

    // After the refill the mcache slot is guaranteed to point at a span with
    // free_count > 0 (otherwise __slab_refill_mcache would have grown a fresh
    // one), so we can fall straight through to the pop.
    v18 = std loadIndirect v17 0
    std storeSlot 2 v18
    std br pop_slot

  block pop_slot:
    // result = span.free_list
    v19 = std loadSlot 2
    v20 = std loadIndirect v19 0x10
    std storeSlot 3 v20

    // span.free_list = [result] (next pointer at slot offset 0)
    v21 = std loadIndirect v20 0
    std storeIndirect v19 0x10 v21

    // span.free_count -= 1
    v22 = std loadIndirect v19 0x18
    v23 = std constI64 1
    v24 = std subI64 v22 v23
    std storeIndirect v19 0x18 v24

    // If free_count is now 0, drop the span from the mcache so the next call
    // refills cleanly. The span lives on through free callers because the
    // arena map (step 6a.14) — and __slab_free_class_with_mspan today — own
    // the link back.
    v25 = std constI64 0
    v26 = std cmpI64Eq v24 v25
    std condBr v26 evict ret_slot

  block evict:
    v27 = std loadSlot 1
    v28 = std constI64 0
    std storeIndirect v27 0 v28
    std br ret_slot

  block ret_slot:
    v29 = std loadSlot 3
    std ret v29
end

// __slab_free_class_with_mspan(slot, mspan)
// Returns `slot` to its owning mspan's free list:
//   [slot] = mspan.free_list
//   mspan.free_list = slot
//   mspan.free_count += 1
//
// This is the building block that step 6a.14's `__slab_free` will use once it
// can resolve the mspan from an arbitrary slot pointer via the two-level
// arena map. Until then callers must already know `mspan` — none do today,
// which is why this is a leak in practice. That is OK: user code is not yet
// routed through the slab.
//
// Slot usage:
//   slot 0 = slot (arg)
//   slot 1 = mspan (arg)
func __slab_free_class_with_mspan 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64

    // [slot] = mspan.free_list
    v2 = std loadIndirect v1 0x10
    std storeIndirect v0 0 v2

    // mspan.free_list = slot
    std storeIndirect v1 0x10 v0

    // mspan.free_count += 1
    v3 = std loadIndirect v1 0x18
    v4 = std constI64 1
    v5 = std addI64 v3 v4
    std storeIndirect v1 0x18 v5

    v6 = std constI64 0
    std ret v6
end

// =============================================================================
// Slab allocator — top layer (step 6a.14 of the allocator port).
//
// Adds the two-level radix tree mapping any pointer back to its owning mspan,
// the OS-direct path for >32KB allocations, and the public __slab_alloc /
// __slab_free entry points.
//
// Architecture:
//   __slab_arena_map_l1 -> 256 entries, each pointing to an L2 table
//   each L2 table       -> 8192 entries, each pointing to a `spans[]` array
//   each `spans[]` array -> 8192 entries, each holding an mspan* for one 8KB
//                          page within an arena (or NULL if unmapped).
//
// Address decoding (mirrors the C# bootstrap exactly):
//   l1_idx     = ptr >> 39                          // bits 39+ pick L1 slot
//   l2_idx     = (ptr >> 26) & 0x1FFF               // bits 26-38 pick L2 slot
//   page_idx   = (ptr >> 13) & 0x1FFF               // bits 13-25 pick page slot
//
// Mutable globals expected by these functions (registered by step 6a.17):
//   __slab_arena_map_l1        8 bytes — pointer to lazily-allocated L1 array
//   __slab_os_direct_array     8 bytes — pointer to (ptr,size) entries
//   __slab_os_direct_count     8 bytes — number of OS-direct entries in use
//   __slab_os_direct_capacity  8 bytes — number of (ptr,size) slots available
//
// TODO(step 6a.17): the X64/Arm64 backends do not yet register these labels
// in the .data section; until then `globalAddr` references resolve to offset 0
// and these functions only need to PARSE/LOWER/EMIT cleanly. They become
// reachable from user code once mrt_alloc is rerouted in step 6a.18.
// =============================================================================

// __slab_arena_map_ensure(addr): ensures the L1, L2, and spans[] arrays exist
// for the arena map entry corresponding to `addr`. Lazy-allocates each layer
// on first need. Three-level mirror of EmitArenaMapEnsure in
// RuntimeEmitter.Allocator.cs (the plan's "two-level" wording collapses the
// L2 and spans[] layers descriptively, but the actual structure must be
// three-level — bits 39+ -> bits 26-38 -> bits 13-25 — because each L2 slot
// covers a 64MB region and each spans[] entry covers one 8KB page within it).
//
// TODO(step 6a.17): this function is presently single-threaded. The C# version
// holds __slab_mspan_pool_lock around L1 allocation to keep two threads from
// racing on the global pointer. When threads land, wrap the alloc_l1 /
// alloc_l2 / alloc_spans paths with osLockAcquire / osLockRelease.
//
// Slot usage:
//   slot 0 = addr (arg)
//   slot 1 = scratch (l1_alloc / l2_alloc / spans_alloc result holders)
//   slot 2 = l1_idx
//   slot 3 = l1_base
//   slot 4 = l1_slot_addr
//   slot 5 = l2_ptr
//   slot 6 = l2_idx
//   slot 7 = l2_slot_addr
//   slot 8 = spans_ptr
func __slab_arena_map_ensure 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // Lazy-allocate L1 if missing.
    v1 = std globalAddr __slab_arena_map_l1
    v2 = std loadIndirect v1 0
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 alloc_l1 l1_ready

  block alloc_l1:
    // L1 = 256 entries * 8 bytes = 2048 bytes -> 1 chunk.
    v5 = std constI64 1
    v6 = std call __slab_arena_alloc_chunks v5
    std storeSlot 1 v6
    v7 = std constI64 2048
    v8 = std call __slab_memzero v6 v7
    v9 = std globalAddr __slab_arena_map_l1
    v10 = std loadSlot 1
    std storeIndirect v9 0 v10
    std br l1_ready

  block l1_ready:
    // l1_idx = addr >> 39
    v11 = std loadSlot 0
    v12 = std constI64 39
    v13 = std shrI64 v11 v12
    std storeSlot 2 v13

    // l1_base = [__slab_arena_map_l1]
    v14 = std globalAddr __slab_arena_map_l1
    v15 = std loadIndirect v14 0
    std storeSlot 3 v15

    // l1_slot_addr = l1_base + l1_idx * 8
    v16 = std constI64 3
    v17 = std shlI64 v13 v16
    v18 = std addI64 v15 v17
    std storeSlot 4 v18

    // l2_ptr = [l1_slot]
    v19 = std loadIndirect v18 0
    v20 = std constI64 0
    v21 = std cmpI64Eq v19 v20
    std condBr v21 alloc_l2 l2_have_ptr

  block alloc_l2:
    // L2 = 8192 entries * 8 bytes = 65536 bytes -> 8 chunks.
    v22 = std constI64 8
    v23 = std call __slab_arena_alloc_chunks v22
    std storeSlot 5 v23
    v24 = std constI64 65536
    v25 = std call __slab_memzero v23 v24
    // [l1_slot] = l2_ptr
    v26 = std loadSlot 4
    v27 = std loadSlot 5
    std storeIndirect v26 0 v27
    std br compute_l2_idx

  block l2_have_ptr:
    std storeSlot 5 v19
    std br compute_l2_idx

  block compute_l2_idx:
    // l2_idx = (addr >> 26) & 0x1FFF
    v28 = std loadSlot 0
    v29 = std constI64 26
    v30 = std shrI64 v28 v29
    v31 = std constI64 8191
    v32 = std andI64 v30 v31
    std storeSlot 6 v32

    // l2_slot_addr = l2_ptr + l2_idx * 8
    v33 = std loadSlot 5
    v34 = std constI64 3
    v35 = std shlI64 v32 v34
    v36 = std addI64 v33 v35
    std storeSlot 7 v36

    // spans_ptr = [l2_slot]
    v37 = std loadIndirect v36 0
    v38 = std constI64 0
    v39 = std cmpI64Eq v37 v38
    std condBr v39 alloc_spans done

  block alloc_spans:
    // spans[] = 8192 entries * 8 bytes = 65536 bytes -> 8 chunks.
    v40 = std constI64 8
    v41 = std call __slab_arena_alloc_chunks v40
    std storeSlot 8 v41
    v42 = std constI64 65536
    v43 = std call __slab_memzero v41 v42
    // [l2_slot] = spans_ptr
    v44 = std loadSlot 7
    v45 = std loadSlot 8
    std storeIndirect v44 0 v45
    std br done

  block done:
    v46 = std constI64 0
    std ret v46
end

// __slab_arena_map_set(base, num_pages, mspan): registers `mspan` in the arena
// map for every 8KB page in [base, base + num_pages*8192). Multi-page mspans
// share the same mspan pointer across all of their page slots so that
// __slab_arena_map_get on any pointer inside the span returns the same mspan.
//
// Mirrors EmitSpanMapUpdate(writeSpanPtr=true) in the C# bootstrap.
//
// Slot usage:
//   slot 0 = base (arg)
//   slot 1 = num_pages (arg)
//   slot 2 = mspan (arg)
//   slot 3 = i (loop counter)
//   slot 4 = page_addr
func __slab_arena_map_set 3 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2
    v3 = std constI64 0
    std storeSlot 3 v3
    std br loop

  block loop:
    v4 = std loadSlot 3
    v5 = std loadSlot 1
    v6 = std cmpI64Lt v4 v5
    std condBr v6 body done

  block body:
    // page_addr = base + i * 8192
    v7 = std loadSlot 0
    v8 = std loadSlot 3
    v9 = std constI64 13
    v10 = std shlI64 v8 v9
    v11 = std addI64 v7 v10
    std storeSlot 4 v11

    // Ensure map entries exist.
    v12 = std call __slab_arena_map_ensure v11

    // l1_idx = page_addr >> 39
    v13 = std loadSlot 4
    v14 = std constI64 39
    v15 = std shrI64 v13 v14

    // l2_ptr = [l1_base + l1_idx*8]
    v16 = std globalAddr __slab_arena_map_l1
    v17 = std loadIndirect v16 0
    v18 = std constI64 3
    v19 = std shlI64 v15 v18
    v20 = std addI64 v17 v19
    v21 = std loadIndirect v20 0

    // l2_idx = (page_addr >> 26) & 0x1FFF
    v22 = std loadSlot 4
    v23 = std constI64 26
    v24 = std shrI64 v22 v23
    v25 = std constI64 8191
    v26 = std andI64 v24 v25

    // spans_ptr = [l2_ptr + l2_idx*8]
    v27 = std constI64 3
    v28 = std shlI64 v26 v27
    v29 = std addI64 v21 v28
    v30 = std loadIndirect v29 0

    // page_idx = (page_addr >> 13) & 0x1FFF
    v31 = std loadSlot 4
    v32 = std constI64 13
    v33 = std shrI64 v31 v32
    v34 = std constI64 8191
    v35 = std andI64 v33 v34

    // [spans_ptr + page_idx*8] = mspan
    v36 = std constI64 3
    v37 = std shlI64 v35 v36
    v38 = std addI64 v30 v37
    v39 = std loadSlot 2
    std storeIndirect v38 0 v39

    // i++
    v40 = std loadSlot 3
    v41 = std constI64 1
    v42 = std addI64 v40 v41
    std storeSlot 3 v42
    std br loop

  block done:
    v43 = std constI64 0
    std ret v43
end

// __slab_arena_map_get(ptr) -> mspan_ptr
// Returns the mspan registered for the 8KB page containing `ptr`, or NULL if
// none. Performs the three-level lookup with no locks (reads are racy-safe in
// single-threaded mode; thread-safety arrives with step 6a.17).
//
// Slot usage:
//   slot 0 = ptr (arg)
func __slab_arena_map_get 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std globalAddr __slab_arena_map_l1
    v2 = std loadIndirect v1 0
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 ret_null check_l2

  block check_l2:
    v5 = std loadSlot 0
    v6 = std constI64 39
    v7 = std shrI64 v5 v6

    v8 = std constI64 3
    v9 = std shlI64 v7 v8
    v10 = std addI64 v2 v9
    v11 = std loadIndirect v10 0

    v12 = std constI64 0
    v13 = std cmpI64Eq v11 v12
    std condBr v13 ret_null check_spans

  block check_spans:
    v14 = std loadSlot 0
    v15 = std constI64 26
    v16 = std shrI64 v14 v15
    v17 = std constI64 8191
    v18 = std andI64 v16 v17

    v19 = std constI64 3
    v20 = std shlI64 v18 v19
    v21 = std addI64 v11 v20
    v22 = std loadIndirect v21 0

    v23 = std constI64 0
    v24 = std cmpI64Eq v22 v23
    std condBr v24 ret_null lookup_span

  block lookup_span:
    v25 = std loadSlot 0
    v26 = std constI64 13
    v27 = std shrI64 v25 v26
    v28 = std constI64 8191
    v29 = std andI64 v27 v28

    v30 = std constI64 3
    v31 = std shlI64 v29 v30
    v32 = std addI64 v22 v31
    v33 = std loadIndirect v32 0
    std ret v33

  block ret_null:
    v34 = std constI64 0
    std ret v34
end

func __slab_os_direct_free 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std globalAddr __slab_os_direct_count
    v2 = std loadIndirect v1 0
    std storeSlot 1 v2

    v3 = std globalAddr __slab_os_direct_array
    v4 = std loadIndirect v3 0
    std storeSlot 2 v4

    v5 = std constI64 0
    std storeSlot 3 v5
    std br loop

  block loop:
    v6 = std loadSlot 3
    v7 = std loadSlot 1
    v8 = std cmpI64Lt v6 v7
    std condBr v8 check_entry not_found

  block check_entry:
    v9 = std loadSlot 2
    v10 = std loadSlot 3
    v11 = std constI64 4
    v12 = std shlI64 v10 v11
    v13 = std addI64 v9 v12
    v14 = std loadIndirect v13 0
    v15 = std loadSlot 0
    v16 = std cmpI64Eq v14 v15
    std condBr v16 found advance

  block advance:
    v17 = std loadSlot 3
    v18 = std constI64 1
    v19 = std addI64 v17 v18
    std storeSlot 3 v19
    std br loop

  block found:
    v20 = std loadIndirect v13 8
    std storeSlot 4 v20

    v21 = std loadSlot 1
    v22 = std constI64 1
    v23 = std subI64 v21 v22

    v24 = std loadSlot 3
    v25 = std cmpI64Eq v24 v23
    std condBr v25 update_count do_swap

  block do_swap:
    v26 = std loadSlot 2
    v27 = std constI64 4
    v28 = std shlI64 v23 v27
    v29 = std addI64 v26 v28
    v30 = std loadIndirect v29 0
    v31 = std loadIndirect v29 8
    std storeIndirect v13 0 v30
    std storeIndirect v13 8 v31
    std br update_count

  block update_count:
    v32 = std globalAddr __slab_os_direct_count
    std storeIndirect v32 0 v23

    v33 = std loadSlot 0
    v34 = std loadSlot 4
    std osFreePages v33 v34

    v35 = std constI64 0
    std ret v35

  block not_found:
    // Exit with a distinct sentinel for debuggers: 135 = OS-direct miss.
    v36 = std constI64 135
    std osExit v36
    v37 = std constI64 0
    std ret v37
end

// __slab_os_direct_alloc(size) -> ptr
// Allocates `size` bytes (rounded up to 8KB) directly from the OS via
// osAllocPages, and records (ptr, aligned_size) in the OS-direct tracking
// array so __slab_os_direct_free can later return it to the OS.
//
// Capacity model: the array is a single 8KB chunk holding 512 (ptr, size)
// entries, lazy-allocated on first call. Each entry covers a >32KB allocation,
// so 512 outstanding OS-direct allocations is plenty for early bring-up.
//
// TODO(step 6a.??): grow the OS-direct array dynamically once heavy users
// exist. The C# bootstrap sorts entries and binary-searches; we punt on that
// until we have a workload that justifies the complexity.
//
// Slot usage:
//   slot 0 = size (arg)
//   slot 1 = aligned size
//   slot 2 = ptr
//   slot 3 = scratch (chunk pointer during lazy-init)
//   slot 4 = count
func __slab_os_direct_alloc 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // aligned = (size + 8191) & ~8191
    v1 = std constI64 8191
    v2 = std addI64 v0 v1
    v3 = std constI64 -8192
    v4 = std andI64 v2 v3
    std storeSlot 1 v4

    // ptr = osAllocPages(aligned)
    v5 = std osAllocPages v4
    std storeSlot 2 v5

    // Lazy-allocate the OS-direct array if capacity == 0.
    v6 = std globalAddr __slab_os_direct_capacity
    v7 = std loadIndirect v6 0
    v8 = std constI64 0
    v9 = std cmpI64Eq v7 v8
    std condBr v9 alloc_arr arr_ready

  block alloc_arr:
    // 1 chunk = 8192 bytes / 16 bytes per entry = 512 entries.
    v10 = std constI64 1
    v11 = std call __slab_arena_alloc_chunks v10
    std storeSlot 3 v11
    v12 = std constI64 8192
    v13 = std call __slab_memzero v11 v12
    v14 = std globalAddr __slab_os_direct_array
    v15 = std loadSlot 3
    std storeIndirect v14 0 v15
    v16 = std globalAddr __slab_os_direct_capacity
    v17 = std constI64 512
    std storeIndirect v16 0 v17
    std br arr_ready

  block arr_ready:
    // Reload count and capacity (capacity may have just been written).
    v18 = std globalAddr __slab_os_direct_count
    v19 = std loadIndirect v18 0
    std storeSlot 4 v19
    v20 = std globalAddr __slab_os_direct_capacity
    v21 = std loadIndirect v20 0

    // If count >= capacity, exhausted — exit with sentinel code.
    v22 = std cmpI64Lt v19 v21
    std condBr v22 do_insert capacity_exceeded

  block capacity_exceeded:
    // TODO(step 6a.??): grow the array. For now exit with a distinct code so
    // the failure is unambiguous from a debugger.
    v23 = std constI64 134
    std osExit v23
    v24 = std constI64 0
    std ret v24

  block do_insert:
    // entry_addr = array_base + count * 16
    v25 = std globalAddr __slab_os_direct_array
    v26 = std loadIndirect v25 0
    v27 = std loadSlot 4
    v28 = std constI64 4
    v29 = std shlI64 v27 v28
    v30 = std addI64 v26 v29
    // entry.ptr = ptr (offset 0)
    v31 = std loadSlot 2
    std storeIndirect v30 0 v31
    // entry.size = aligned (offset 8)
    v32 = std loadSlot 1
    std storeIndirect v30 8 v32
    // count++
    v33 = std loadSlot 4
    v34 = std constI64 1
    v35 = std addI64 v33 v34
    v36 = std globalAddr __slab_os_direct_count
    std storeIndirect v36 0 v35

    v37 = std loadSlot 2
    std ret v37
end

// __slab_alloc(size) -> ptr
// Public allocator entry point. Routes to:
//   - __slab_os_direct_alloc for size > 32768 (SLAB_MAX_SMALL_SIZE)
//   - __slab_alloc_class otherwise, after a linear scan of the size-class
//     table to find the smallest class >= size.
//
// The 18-class linear scan is what the C# bootstrap also uses; the bounded
// loop count makes it competitive with a binary search and far simpler to
// emit. Future micro-optimisation: a precomputed small-bucket table.
//
// Slot usage:
//   slot 0 = size (arg)
//   slot 1 = class_idx
func __slab_alloc 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std constI64 32768
    v2 = std cmpI64Gt v0 v1
    std condBr v2 os_path small_path

  block os_path:
    v3 = std loadSlot 0
    v4 = std call __slab_os_direct_alloc v3
    std ret v4

  block small_path:
    v5 = std constI64 0
    std storeSlot 1 v5
    std br class_loop

  block class_loop:
    v6 = std loadSlot 1
    v7 = std constI64 18
    v8 = std cmpI64Lt v6 v7
    std condBr v8 class_test no_class

  block class_test:
    v9 = std loadSlot 1
    v10 = std call __slab_class_size v9
    v11 = std loadSlot 0
    v12 = std cmpI64Ge v10 v11
    std condBr v12 class_found class_advance

  block class_advance:
    v13 = std loadSlot 1
    v14 = std constI64 1
    v15 = std addI64 v13 v14
    std storeSlot 1 v15
    std br class_loop

  block class_found:
    v16 = std loadSlot 1
    v17 = std call __slab_alloc_class v16
    std ret v17

  block no_class:
    // Should be unreachable (size <= 32768 fits in class 17).
    v18 = std constI64 136
    std osExit v18
    v19 = std constI64 0
    std ret v19
end

// __slab_free(ptr): public free entry point. Recovers the owning mspan via
// __slab_arena_map_get; if the lookup misses, the pointer must have come
// from the OS-direct path, so __slab_os_direct_free handles it.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = mspan
func __slab_free 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call __slab_arena_map_get v0
    std storeSlot 1 v1

    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 os_direct slab_path

  block os_direct:
    v4 = std loadSlot 0
    v5 = std call __slab_os_direct_free v4
    v6 = std constI64 0
    std ret v6

  block slab_path:
    v7 = std loadSlot 0
    v8 = std loadSlot 1
    v9 = std call __slab_free_class_with_mspan v7 v8
    v10 = std constI64 0
    std ret v10
end

// =============================================================================
// MM tracked layer
// =============================================================================
//
// mm_alloc / mm_free / mm_incref / mm_decref / mm_realloc — refcounted user
// pointers carrying a destructor function pointer and tag, all stored in a
// header preceding the user-facing pointer. This is the layer that
// __ManagedMemory.create (Phase 6b) will call directly.
//
// Header layout (24 bytes preceding the user pointer):
//   [ptr - 24] = destructor function pointer (i64, 0 if no destructor)
//   [ptr - 16] = size in bytes (i64; user-requested size)
//   [ptr -  8] = refcount (i64)
//
// TODO(perf): pack into a 16-byte header like the C# bootstrap. The bootstrap
// encodes (tag, destructor offset, size class index) into one i64 plus an
// i64 refcount. We use 24 bytes here for clarity; the simplification costs
// us 8 bytes per allocation but avoids the packing/unpacking arithmetic and
// the destructor-offset relocation logic.
//
// TODO(diag): per-tag leak breakdown. The `tag` argument to mm_alloc is
// currently accepted and ignored — a future diag pass will use it to give a
// per-type leak summary on shutdown.
//
// Globals referenced (registered by registerSlabAndMmGlobalsForDataSection
// in LowerMaxonToStd):
//   __mm_alloc_count   8 bytes — atomic count of live mm_alloc allocations.
//
// Destructor invocation: when mm_decref drives the refcount to zero it
// calls mm_free, which reads the destructor pointer from [ptr - 24] and
// invokes it via `indirectCall` (if non-null) before slab-freeing. The
// destructor receives the user pointer and is expected to decref any
// managed fields stored in the user region.

// mm_alloc(size, destructor, tag) -> ptr: allocate a tracked refcounted
// buffer with a 24-byte header. Refcount starts at 1. The `tag` arg is
// accepted for API parity with the C# bootstrap but currently ignored.
//
// Slot usage:
//   slot 0 = size       (arg)
//   slot 1 = destructor (arg)
//   slot 2 = tag        (arg, currently unused)
//   slot 3 = slot_base  (raw slab pointer)
//   slot 4 = user_ptr   (returned)
//   slot 5 = clamped_size (size, clamped to >= 1)
func mm_alloc 3 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2

    // Clamp size: if size < 1, clamp to 1 (no panic).
    v3 = std loadSlot 0
    v4 = std constI64 1
    v5 = std cmpI64Lt v3 v4
    std condBr v5 clamp_size keep_size

  block clamp_size:
    v6 = std constI64 1
    std storeSlot 5 v6
    std br do_alloc

  block keep_size:
    v7 = std loadSlot 0
    std storeSlot 5 v7
    std br do_alloc

  block do_alloc:
    // Atomic increment __mm_alloc_count.
    v8 = std globalAddr __mm_alloc_count
    std atomicInc v8

    // raw_size = clamped_size + 24
    v9 = std loadSlot 5
    v10 = std constI64 24
    v11 = std addI64 v9 v10
    v12 = std call __slab_alloc v11
    std storeSlot 3 v12

    // user_ptr = slot_base + 24
    v13 = std loadSlot 3
    v14 = std constI64 24
    v15 = std addI64 v13 v14
    std storeSlot 4 v15

    // Store destructor at [user_ptr - 24] == [slot_base + 0].
    v16 = std loadSlot 3
    v17 = std loadSlot 1
    std storeIndirect v16 0 v17

    // Store size at [user_ptr - 16] == [slot_base + 8].
    v18 = std loadSlot 3
    v19 = std loadSlot 5
    std storeIndirect v18 8 v19

    // Store refcount = 1 at [user_ptr - 8] == [slot_base + 16].
    v20 = std loadSlot 3
    v21 = std constI64 1
    std storeIndirect v20 16 v21

    // Return user_ptr.
    v22 = std loadSlot 4
    std ret v22
end

// mm_incref(ptr): atomically bump the refcount at [ptr - 8].
// Caller must ensure ptr is non-null; we skip the null check for speed
// (matches the inner-loop expectations of array.set / etc.).
//
// TODO(safety): once we have a cheap way to panic with a static message,
// consider adding a NULL-check that calls mrt_panic with __mm_panic_incref_null.
//
// Slot usage:
//   slot 0 = ptr (arg)
func mm_incref 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // refcount_addr = ptr - 8
    v1 = std loadSlot 0
    v2 = std constI64 8
    v3 = std subI64 v1 v2
    std atomicInc v3

    v4 = std constI64 0
    std ret v4
end

// mm_decref(ptr): atomically decrement the refcount at [ptr - 8]. If the
// prior value was 1 (i.e. the refcount has reached 0), call mm_free(ptr) to
// release the allocation. Caller must ensure ptr is non-null.
//
// We use atomicXadd with -1 (rather than atomicDec) because the dec op
// has no result Id in Std-IR — we need the prior value to detect the
// transition to zero across architectures uniformly.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = prior refcount (return of atomicXadd)
func mm_decref 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // refcount_addr = ptr - 8
    v1 = std loadSlot 0
    v2 = std constI64 8
    v3 = std subI64 v1 v2

    // prior = atomicXadd(refcount_addr, -1)
    v4 = std constI64 -1
    v5 = std atomicXadd v3 v4
    std storeSlot 1 v5

    // If prior == 1, the new refcount is 0 — free.
    v6 = std loadSlot 1
    v7 = std constI64 1
    v8 = std cmpI64Eq v6 v7
    std condBr v8 do_free done

  block do_free:
    v9 = std loadSlot 0
    v10 = std call mm_free v9
    std br done

  block done:
    v11 = std constI64 0
    std ret v11
end

// mm_free(ptr): release a tracked allocation. Internal — usually invoked
// by mm_decref when the refcount reaches zero. Reads the destructor from
// [ptr - 24] and invokes it (if non-null) before slab-freeing. The
// destructor is responsible for decreffing managed fields stored inside
// the user region; mm_free only releases the surrounding allocation.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = slot_base (= ptr - 24)
//   slot 2 = destructor (read from [ptr - 24], 0 means "no destructor")
func mm_free 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 null_path live_path

  block null_path:
    v3 = std constI64 0
    std ret v3

  block live_path:
    // Load destructor from [ptr - 24]. Compute address explicitly because
    // loadIndirect takes only unsigned offsets.
    v11 = std loadSlot 0
    v12 = std constI64 24
    v13 = std subI64 v11 v12
    v14 = std loadIndirect v13 0
    std storeSlot 2 v14

    // If destructor != 0, run it.
    v15 = std loadSlot 2
    v16 = std constI64 0
    v17 = std cmpI64Eq v15 v16
    std condBr v17 free_only do_destruct

  block do_destruct:
    // destructor(ptr) — reads managed fields out of the user region and
    // decrefs them. Must run BEFORE slab_free so the user data is still
    // intact when the destructor reads it.
    v18 = std loadSlot 2
    v19 = std loadSlot 0
    v20 = std indirectCall v18 v19
    std br free_only

  block free_only:
    // Atomic decrement __mm_alloc_count.
    v4 = std globalAddr __mm_alloc_count
    std atomicDec v4

    // slot_base = ptr - 24
    v5 = std loadSlot 0
    v6 = std constI64 24
    v7 = std subI64 v5 v6
    std storeSlot 1 v7

    v8 = std loadSlot 1
    v9 = std call __slab_free v8
    v10 = std constI64 0
    std ret v10
end

// mm_realloc(ptr, new_size) -> new_ptr: grow or shrink a tracked allocation.
// Allocates a fresh buffer (preserving the destructor from the old header),
// copies min(old_size, new_size) bytes of user data, then slab-frees the old
// allocation directly (bypassing mm_free / the destructor — the new buffer
// now owns whatever resources the old one held).
//
// If ptr == 0, behaves as mm_alloc(new_size, destructor=0, tag=0).
//
// Note: realloc transfers ownership. If the caller had aliased the old
// pointer (incref'd it elsewhere), they would expect both to refer to the
// same object — the C# bootstrap doesn't fix that either; we accept the
// "realloc consumes its input" semantic and document it here.
//
// Slot usage:
//   slot 0 = old_ptr   (arg)
//   slot 1 = new_size  (arg)
//   slot 2 = old_size       (read from header)
//   slot 3 = destructor     (read from header)
//   slot 4 = new_ptr        (returned)
//   slot 5 = copy_size      (= min(old_size, new_size))
//   slot 6 = old_slot_base  (= old_ptr - 24)
func mm_realloc 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    v2 = std constI64 0
    v3 = std cmpI64Eq v0 v2
    std condBr v3 null_path live_path

  block null_path:
    // ptr == 0 => behave as mm_alloc(new_size, 0, 0).
    v4 = std loadSlot 1
    v5 = std constI64 0
    v6 = std constI64 0
    v7 = std call mm_alloc v4 v5 v6
    std ret v7

  block live_path:
    // old_size = *(old_ptr - 16). Compute address explicitly (loadIndirect
    // takes only unsigned offsets, so we can't use a -16 offset directly).
    v8 = std loadSlot 0
    v9 = std constI64 16
    v10 = std subI64 v8 v9
    v11 = std loadIndirect v10 0
    std storeSlot 2 v11

    // destructor = *(old_ptr - 24).
    v12 = std loadSlot 0
    v13 = std constI64 24
    v14 = std subI64 v12 v13
    v15 = std loadIndirect v14 0
    std storeSlot 3 v15

    // new_ptr = mm_alloc(new_size, destructor, 0). This refreshes the
    // destructor on the new buffer so a subsequent mm_decref still has it.
    v16 = std loadSlot 1
    v17 = std loadSlot 3
    v18 = std constI64 0
    v19 = std call mm_alloc v16 v17 v18
    std storeSlot 4 v19

    // copy_size = min(old_size, new_size)
    v20 = std loadSlot 2
    v21 = std loadSlot 1
    v22 = std cmpI64Lt v20 v21
    std condBr v22 pick_old pick_new

  block pick_old:
    v23 = std loadSlot 2
    std storeSlot 5 v23
    std br do_copy

  block pick_new:
    v24 = std loadSlot 1
    std storeSlot 5 v24
    std br do_copy

  block do_copy:
    // memcpy(new_ptr, old_ptr, copy_size).
    v25 = std loadSlot 4
    v26 = std loadSlot 0
    v27 = std loadSlot 5
    std memcpy v25 v26 v27

    // Slab-free the old buffer directly (bypassing mm_free): the new buffer
    // has taken ownership of the contents, so the destructor must NOT run.
    v28 = std loadSlot 0
    v29 = std constI64 24
    v30 = std subI64 v28 v29
    std storeSlot 6 v30
    v31 = std loadSlot 6
    v32 = std call __slab_free v31

    // Manually decrement __mm_alloc_count to balance the mm_alloc above.
    // (We bumped it once in mm_alloc, but the old allocation also still
    // counts — so net we need one decrement here.)
    v33 = std globalAddr __mm_alloc_count
    std atomicDec v33

    v34 = std loadSlot 4
    std ret v34
end

// Step 6b.3: __destruct___ManagedMemory(self) — destructor for a
// `__ManagedMemory` instance. Runs (will run, once indirect-call lands on
// the StdParser side and `mm_decref` is wired to dispatch on the destructor
// slot stored in the MM header) when `mm_decref` drops a __ManagedMemory's
// refcount to zero. Until indirect-call is exposed (TODO 6a.18+), the
// lowering pass for `__ManagedMemory` (step 6b.4) will need to either call
// this function directly at the appropriate point or substitute equivalent
// inlined teardown — both paths are valid because the destructor only ever
// runs against `__ManagedMemory` instances.
//
// Inspects `parent_ptr` (offset 32 in the 5-field 40-byte struct) to decide
// what to free:
//   parent_ptr == -1:  this is a root __ManagedMemory; drop its buffer via
//                      mm_decref.
//   parent_ptr == -2:  this is rdata-backed; the buffer is in the static
//                      .rdata section and must NOT be freed.
//   parent_ptr == 0:   uninitialized (e.g. a freshly slab-allocated header
//                      that was never populated); nothing to free.
//   otherwise:         this is a slice view; mm_decref the parent so the
//                      parent's refcount drops by one.
//
// The function takes `self` as a tracked pointer (i.e. ptr == user_ptr,
// already past the 24-byte mm_alloc header). All field offsets are relative
// to that pointer — `loadIndirect self 0` returns the buffer pointer,
// `loadIndirect self 32` returns parent_ptr, etc.
//
// Returns i64 (always 0) rather than void: the call site uses `indirectCall`
// (mm_free reads the destructor pointer out of the allocation header), and
// the wasm backend's `call_indirect` requires the static call-site type to
// match the target function's signature exactly. Matching the IR
// `indirectCall` op's "always defines a result value" shape on the
// destructor side keeps the wasm signature uniform across every callable
// destructor and avoids a per-target void-indirect-call codepath. The
// returned 0 is silently discarded by the X64/Arm64 backends and stored
// into a never-read SSA value by the wasm backend.
//
// Slot usage:
//   slot 0 = self     (arg)
//   slot 1 = parent   (loaded from self+32)
func __destruct___ManagedMemory 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // parent = self.parent_ptr (offset 32)
    v1 = std loadSlot 0
    v2 = std loadIndirect v1 32
    std storeSlot 1 v2

    // if parent == -1 -> free_buffer
    v3 = std loadSlot 1
    v4 = std constI64 -1
    v5 = std cmpI64Eq v3 v4
    std condBr v5 free_buffer check_rdata

  block check_rdata:
    // if parent == -2 -> done (rdata-backed; do nothing)
    v6 = std loadSlot 1
    v7 = std constI64 -2
    v8 = std cmpI64Eq v6 v7
    std condBr v8 done check_uninit

  block check_uninit:
    // if parent == 0 -> done (uninitialized; nothing to free)
    v9 = std loadSlot 1
    v10 = std constI64 0
    v11 = std cmpI64Eq v9 v10
    std condBr v11 done decref_parent

  block free_buffer:
    // Buffer pointer at offset 0. Drop our ref via mm_decref if non-null;
    // mm_decref dereferences [ptr-8] without a null check, so guard.
    v12 = std loadSlot 0
    v13 = std loadIndirect v12 0
    v14 = std constI64 0
    v15 = std cmpI64Eq v13 v14
    std condBr v15 done do_free_buffer

  block do_free_buffer:
    v16 = std loadSlot 0
    v17 = std loadIndirect v16 0
    v18 = std call mm_decref v17
    std br done

  block decref_parent:
    // Slice view: drop one ref on the parent __ManagedMemory.
    v19 = std loadSlot 1
    v20 = std call mm_decref v19
    std br done

  block done:
    v21 = std constI64 0
    std ret v21
end

// =============================================================================
// __ManagedMemory builtin runtime helpers (step 6b.4).
//
// Each helper backs one of the 18 `__ManagedMemory.*` methods registered by
// `registerManagedMemoryMethods`. Lowering (`lowerManagedMemBuiltin` in
// LowerMaxonToStd) routes the throwing methods through these helpers so the
// per-method bounds-check + control-flow logic lives in one place rather than
// being duplicated at every call site. Each helper that wants to signal an
// error returns a non-zero variant ordinal (1..8) in the secondary return
// register (RDX/X1 — the multi-value-return error ABI) alongside a sentinel
// zero primary value; the parser-emitted `try ... otherwise` machinery picks
// up the error flag from the secondary register at the call site. The +1
// shift keeps 0 reserved for "no error in flight" — matching the `throw`
// lowering convention in `LowerMaxonToStd.lowerThrow`.
//
// __ManagedMemoryError ordinal map (mirrors stdlib/Builtins.maxon and the
// enum cases registered in registerManagedMemoryErrorEnum). The "wire"
// column shows the value placed in the error register (= ordinal + 1):
//   ordinal | name              | wire
//   0       | indexOutOfBounds  | 1
//   1       | emptySlot         | 2
//   2       | sliceOutOfBounds  | 3
//   3       | invalidLength     | 4
//   4       | invalidCapacity   | 5
//   5       | shiftOutOfBounds  | 6
//   6       | invalidByteRange  | 7
//   7       | invalidAllocation | 8
//
// Layout (5-field, 40-byte __ManagedMemory struct):
//   offset 0  buffer       i64 (heap pointer to mm_alloc'd buffer or 0)
//   offset 8  length       i64 (live element count)
//   offset 16 capacity     i64 (allocated element slots)
//   offset 24 element_size i64 (sizeof(Element); 1 for Byte, 8 otherwise)
//   offset 32 parent_ptr   i64 (-1 root; -2 rdata-backed; otherwise parent ptr)

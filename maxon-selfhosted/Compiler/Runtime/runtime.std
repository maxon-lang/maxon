    v23 = std loadSlot 4
    v24 = std constI64 1
    v25 = std call __managed_mem_create v23 v24
    std storeSlot 2 v25

    // Set length = byteLen.
    v26 = std loadSlot 2
    v27 = std loadSlot 4
    std storeIndirect v26 8 v27

    // Copy scratch into output buf.
    v28 = std loadIndirect v26 0
    std storeSlot 3 v28
    v29 = std loadSlot 3
    v30 = std loadSlot 0
    v31 = std loadSlot 4
    std memcpy v29 v30 v31

    // Free scratch.
    v32 = std loadSlot 0
    v33 = std call mm_decref v32

    v34 = std loadSlot 2
    v35 = std constI64 0
    std errorReturn v34 v35
end

// mrt_directory_next(self) throws -> 1 if more entries, 0 if done.
// self = block ptr (40 bytes). Block layout per open_search.
//
// Advance the cursor to the next non-"."/".." entry in the dirent buffer;
// when the buffer is exhausted, refill via getdents64. Store the filename
// pointer at block[32] for mrt_directory_filename to read.
//
// Linux dirent64 layout (per getdents64):
//   d_ino   u64  @  0
//   d_off   u64  @  8
//   d_reclen u16 @ 16
//   d_type  u8   @ 18
//   d_name  ...  @ 19 (NUL-terminated)
//
// Slot usage:
//   slot 0 = block ptr
//   slot 1 = fd
//   slot 2 = dirent buffer ptr
//   slot 3 = bufused
//   slot 4 = cursor
//   slot 5 = dirent record reclen
//   slot 6 = entry name ptr
func mrt_directory_next 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std loadIndirect v0 0
    std storeSlot 1 v1
    v2 = std loadIndirect v0 8
    std storeSlot 2 v2

    std br check_buffer

  block check_buffer:
    v3 = std loadIndirect v0 16
    std storeSlot 3 v3
    v4 = std loadIndirect v0 24
    std storeSlot 4 v4

    v5 = std loadSlot 4
    v6 = std loadSlot 3
    v7 = std cmpI64Lt v5 v6
    std condBr v7 read_entry refill

  block refill:
    // getdents64(fd, buf, 4096).
    v8 = std loadSlot 1
    v9 = std loadSlot 2
    v10 = std constI64 4096
    v11 = std osDirGetdents64 v8 v9 v10

    // Store new bufused, reset cursor.
    std storeIndirect v0 16 v11
    v12 = std constI64 0
    std storeIndirect v0 24 v12

    // If <= 0, we're done (0 = EOF; negative = error treated as EOF).
    v13 = std constI64 0
    v14 = std cmpI64Le v11 v13
    std condBr v14 done_no_more check_buffer

  block read_entry:
    // Read reclen at cursor + 16.
    v15 = std loadSlot 2
    v16 = std loadSlot 4
    v17 = std addI64 v15 v16
    v18 = std loadIndirect v17 16
    v19 = std constI64 0xFFFF
    v20 = std andI64 v18 v19
    std storeSlot 5 v20

    // Compute entry name ptr = base + cursor + 19.
    v21 = std constI64 19
    v22 = std addI64 v17 v21
    std storeSlot 6 v22

    // Bump cursor by reclen and store.
    v23 = std loadSlot 4
    v24 = std loadSlot 5
    v25 = std addI64 v23 v24
    std storeIndirect v0 24 v25

    // Skip "." and "..".
    v26 = std loadSlot 6
    v27 = std loadByte v26 v13
    v28 = std constI64 46
    v29 = std cmpI64Eq v27 v28
    std condBr v29 maybe_dot have_entry

  block maybe_dot:
    // First byte is '.'. Check second byte.
    v30 = std constI64 1
    v31 = std addI64 v26 v30
    v32 = std loadByte v31 v13
    v33 = std cmpI64Eq v32 v13
    std condBr v33 skip_entry maybe_dotdot

  block maybe_dotdot:
    v34 = std cmpI64Eq v32 v28
    std condBr v34 maybe_dotdot_term have_entry

  block maybe_dotdot_term:
    // Two leading dots; check third byte for NUL.
    v35 = std constI64 2
    v36 = std addI64 v26 v35
    v37 = std loadByte v36 v13
    v38 = std cmpI64Eq v37 v13
    std condBr v38 skip_entry have_entry

  block skip_entry:
    // Loop back to check_buffer for the next dirent.
    std br check_buffer

  block have_entry:
    // Store name ptr in block[32] for filename to read.
    std storeIndirect v0 32 v26
    v39 = std constI64 1
    v40 = std constI64 0
    std errorReturn v39 v40

  block done_no_more:
    v41 = std constI64 0
    std storeIndirect v0 32 v41
    v42 = std constI64 0
    std errorReturn v41 v42
end

// mrt_directory_filename(self) -> __ManagedMemory. Reads the NUL-
// terminated filename stored at block[32] by directory_next and returns
// a fresh __ManagedMemory containing the bytes.
//
// Slot usage:
//   slot 0 = self (block ptr)
//   slot 1 = name ptr
//   slot 2 = name length
//   slot 3 = output mm
func mrt_directory_filename 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std loadIndirect v0 32
    std storeSlot 1 v1

    // If name ptr is 0, return empty mm.
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 empty count

  block count:
    // Count bytes until NUL.
    std storeSlot 2 v2
    std br count_loop

  block count_loop:
    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std addI64 v4 v5
    v7 = std loadByte v6 v2
    v8 = std cmpI64Eq v7 v2
    std condBr v8 count_done bump

  block bump:
    v9 = std loadSlot 2
    v10 = std constI64 1
    v11 = std addI64 v9 v10
    std storeSlot 2 v11
    std br count_loop

  block count_done:
    // Allocate output mm.
    v12 = std loadSlot 2
    v13 = std constI64 1
    v14 = std call __managed_mem_create v12 v13
    std storeSlot 3 v14

    // length = name len.
    v15 = std loadSlot 3
    v16 = std loadSlot 2
    std storeIndirect v15 8 v16

    // Copy bytes.
    v17 = std loadIndirect v15 0
    v18 = std loadSlot 1
    std memcpy v17 v18 v16

    std ret v15

  block empty:
    v19 = std constI64 0
    v20 = std constI64 1
    v21 = std call __managed_mem_create v19 v20
    std ret v21
end

// mrt_directory_close: close fd, free dirent buf and block.
//
// Slot usage:
//   slot 0 = self (block ptr)
func mrt_directory_close 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // If self == 0, nothing to do.
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 done close_fd

  block close_fd:
    v3 = std loadIndirect v0 0
    v4 = std cmpI64Lt v3 v1
    std condBr v4 free_bufs do_close

  block do_close:
    v5 = std osFileClose v3
    std br free_bufs

  block free_bufs:
    v6 = std loadIndirect v0 8
    v7 = std cmpI64Eq v6 v1
    std condBr v7 free_block free_dirent

  block free_dirent:
    v8 = std call mm_decref v6
    std br free_block

  block free_block:
    v9 = std call mm_decref v0
    std br done

  block done:
    v10 = std constI64 0
    std ret v10
end

// mrt_directory_exists(path) -> 1 if directory, else 0. Non-throwing.
// Uses stat + S_ISDIR.
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = cstr ptr
//   slot 2 = stat buf ptr (144 bytes)
//   slot 3 = stat result
func mrt_directory_exists 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call mrt_cstr_from_mm v0
    std storeSlot 1 v1

    v2 = std constI64 144
    v3 = std call mrt_alloc v2
    std storeSlot 2 v3

    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std osFileStat v4 v5
    std storeSlot 3 v6

    // Free cstr.
    v7 = std loadSlot 1
    v8 = std call mm_decref v7

    v9 = std loadSlot 3
    v10 = std constI64 0
    v11 = std cmpI64Lt v9 v10
    std condBr v11 not_exist check_mode

  block not_exist:
    v12 = std loadSlot 2
    v13 = std call mm_decref v12
    v14 = std constI64 0
    std ret v14

  block check_mode:
    // st_mode @ 24; (mode & S_IFMT) == S_IFDIR ?
    v15 = std loadSlot 2
    v16 = std loadIndirect v15 24
    v17 = std constI64 0xFFFFFFFF
    v18 = std andI64 v16 v17
    v19 = std constI64 61440
    v20 = std andI64 v18 v19
    v21 = std constI64 16384
    v22 = std cmpI64Eq v20 v21
    std condBr v22 is_dir not_dir

  block is_dir:
    v23 = std loadSlot 2
    v24 = std call mm_decref v23
    v25 = std constI64 1
    std ret v25

  block not_dir:
    v26 = std loadSlot 2
    v27 = std call mm_decref v26
    v28 = std constI64 0
    std ret v28
end

// =============================================================================
// Command-line / executable-path retrieval — platform-independent bodies.
//
// Each helper emits one of the new Std-level ops (`osGetArgc` / `osGetArgv` /
// `osGetExecutablePath`), and the per-backend MIR lowering decides what those
// mean per OS (Linux/macOS read stashed argv globals; Windows calls hand-
// rolled IAT helpers in the backend; WASI uses its argv cache). The bodies
// here are identical across targets — no per-OS stub split remains.

// mrt_command_line_count(): returns the process argument count.
func mrt_command_line_count 0 i64
  block entry:
    v0 = std osGetArgc
    std ret v0
end

// mrt_command_line_arg(index): returns a freshly-allocated __ManagedMemory
// holding the UTF-8 bytes of argv[index]. Out-of-bounds (osGetArgv returned 0)
// produces an empty MM (length=0). Slot usage:
//   slot 0 = argv[index] raw C-string pointer
//   slot 1 = NUL-scan counter (byte length, excluding NUL)
//   slot 2 = mm pointer
func mrt_command_line_arg 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std osGetArgv v0
    std storeSlot 0 v1
    // If osGetArgv returned 0 the index is out of bounds — emit an empty MM.
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 oob_path scan_init

  block scan_init:
    // Initialise the NUL-scan counter to 0; loop reads cstr[counter] until 0.
    v4 = std constI64 0
    std storeSlot 1 v4
    std br scan

  block scan:
    v5 = std loadSlot 0
    v6 = std loadSlot 1
    v7 = std loadByte v5 v6
    v8 = std constI64 0
    v9 = std cmpI64Eq v7 v8
    std condBr v9 alloc scan_next

  block scan_next:
    v10 = std loadSlot 1
    v11 = std constI64 1
    v12 = std addI64 v10 v11
    std storeSlot 1 v12
    std br scan

  block alloc:
    // __managed_mem_create(byteLen + 1, 1). The +1 reserves space for the NUL
    // terminator so the memcpy below (which copies `byteLen` bytes, no NUL)
    // can be followed by callers writing a NUL if they want C-string access.
    v13 = std loadSlot 1
    v14 = std constI64 1
    v15 = std addI64 v13 v14
    v16 = std constI64 1
    v17 = std call __managed_mem_create v15 v16
    std storeSlot 2 v17

    // dst = mm[0] (the heap-allocated buffer pointer stored at offset 0).
    v18 = std loadSlot 2
    v19 = std loadIndirect v18 0

    // memcpy(dst, src, byteLen). Does not copy the NUL — only the data bytes.
    v20 = std loadSlot 0
    v21 = std loadSlot 1
    std memcpy v19 v20 v21

    // Store length = byteLen at mm[8].
    v22 = std loadSlot 1
    v23 = std loadSlot 2
    std storeIndirect v23 8 v22

    v24 = std loadSlot 2
    std ret v24

  block oob_path:
    // Out-of-bounds: empty 1-byte MM (length stays 0). Matches the existing
    // Windows `mrt_command_line_arg` OOB return shape so callers observe an
    // empty String regardless of platform.
    v25 = std constI64 1
    v26 = std constI64 1
    v27 = std call __managed_mem_create v25 v26
    std ret v27
end

// mrt_executable_path(): returns a __ManagedMemory holding the UTF-8 bytes
// of the running executable's path. On error (osGetExecutablePath returned a
// negative errno-style value) produces an empty MM. The stack buffer holds
// up to 4096 bytes — well past PATH_MAX on every supported system.
//
// Slot usage:
//   slot 0 = osGetExecutablePath return value (bytes written or -errno)
//   slot 1 = mm pointer
//   slot 2 = mm[0] buffer pointer
//   slots 11..522 = 512-qword (4096-byte) UTF-8 path buffer
func mrt_executable_path 0 i64
  block entry:
    // Stack-allocate the path buffer at slot 522 (low-address end of a
    // 4096-byte region extending toward slot 11; the slot allocator reserves
    // the frame).
    v0 = std stackAddr 522
    v1 = std constI64 4096
    v2 = std osGetExecutablePath v0 v1
    std storeSlot 0 v2

    // Error path: result < 0 → return empty MM.
    v3 = std constI64 0
    v4 = std cmpI64Lt v2 v3
    std condBr v4 err_path ok_path

  block ok_path:
    // __managed_mem_create(bytes + 1, 1). The +1 reserves NUL space; memcpy
    // below copies only `bytes` data bytes.
    v5 = std loadSlot 0
    v6 = std constI64 1
    v7 = std addI64 v5 v6
    v8 = std constI64 1
    v9 = std call __managed_mem_create v7 v8
    std storeSlot 1 v9

    // dst = mm[0].
    v10 = std loadSlot 1
    v11 = std loadIndirect v10 0
    std storeSlot 2 v11

    // memcpy(dst, stackBuf, bytes).
    v12 = std loadSlot 2
    v13 = std stackAddr 522
    v14 = std loadSlot 0
    std memcpy v12 v13 v14

    // Store length = bytes at mm[8].
    v15 = std loadSlot 0
    v16 = std loadSlot 1
    std storeIndirect v16 8 v15

    v17 = std loadSlot 1
    std ret v17

  block err_path:
    v18 = std constI64 1
    v19 = std constI64 1
    v20 = std call __managed_mem_create v18 v19
    std ret v20
end

// mrt_cov_hit(siteId): increments __data_cov_counters[siteId].
// __data_cov_counters is a u64 array in .data sized numSites*8 bytes.
// Only invoked when coverage instrumentation was enabled at compile time;
// otherwise the runtime merge leaves the counters global unregistered and
// this function is never called from user code.
func mrt_cov_hit 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __data_cov_counters
    v2 = std constI64 3
    v3 = std shlI64 v0 v2
    v4 = std addI64 v1 v3
    v5 = std loadIndirect v4 0
    v6 = std constI64 1
    v7 = std addI64 v5 v6
    std storeIndirect v4 0 v7
    v8 = std constI64 0
    std ret v8
end

// mrt_cov_dump(): writes the coverage file when MAXON_COV_OUT is set.
// File format: 4-byte magic "MCOV" | 4-byte numSites (u32 LE) | numSites*8 bytes of counters (u64 LE).
//
// Slot usage:
//   slot 0 = bytes written by osGetEnv (path length)
//   slot 1 = fd returned by osOpenWrite
//   slot 2 = numSites (masked to u32)
//   slots 10..41 = 256-byte path buffer (32 qword slots)
//   slot 50 = 8-byte header buffer
func mrt_cov_dump 0 void
  block entry:
    v0 = std globalAddr __cov_env_name
    v1 = std constI64 13
    // Slots 10..41 reserve 256 bytes. Stack addresses go DOWN as slot index
    // goes up, so the LOWEST address of the buffer is at slot 41. Passing
    // stackAddr 41 as the ptr makes osGetEnv write FORWARD through slots
    // 41..10; using stackAddr 10 here would write OFF THE TOP of the buffer
    // into the saved frame and return address (works for ≤8-byte strings,
    // crashes on longer paths).
    v2 = std stackAddr 41
    v3 = std constI64 256
    v4 = std osGetEnv v0 v1 v2 v3
    std storeSlot 0 v4
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 done doOpen

  block doOpen:
    v7 = std stackAddr 41
    v8 = std loadSlot 0
    v9 = std osOpenWrite v7 v8
    std storeSlot 1 v9

    v10 = std globalAddr __data_cov_num_sites
    v11 = std loadIndirect v10 0
    v12 = std constI64 0xFFFFFFFF
    v13 = std andI64 v11 v12
    std storeSlot 2 v13

    v14 = std stackAddr 50

    v15 = std constI64 0
    v16 = std constI64 0x4D
    std storeByte v14 v15 v16
    v17 = std constI64 1
    v18 = std constI64 0x43
    std storeByte v14 v17 v18
    v19 = std constI64 2
    v20 = std constI64 0x4F
    std storeByte v14 v19 v20
    v21 = std constI64 3
    v22 = std constI64 0x56
    std storeByte v14 v21 v22

    v23 = std loadSlot 2
    v24 = std constI64 0xFF
    v25 = std andI64 v23 v24
    v26 = std constI64 4
    std storeByte v14 v26 v25

    v27 = std loadSlot 2
    v28 = std constI64 8
    v29 = std shrI64 v27 v28
    v30 = std constI64 0xFF
    v31 = std andI64 v29 v30
    v32 = std constI64 5
    std storeByte v14 v32 v31

    v33 = std loadSlot 2
    v34 = std constI64 16
    v35 = std shrI64 v33 v34
    v36 = std constI64 0xFF
    v37 = std andI64 v35 v36
    v38 = std constI64 6
    std storeByte v14 v38 v37

    v39 = std loadSlot 2
    v40 = std constI64 24
    v41 = std shrI64 v39 v40
    v42 = std constI64 0xFF
    v43 = std andI64 v41 v42
    v44 = std constI64 7
    std storeByte v14 v44 v43

    v45 = std loadSlot 1
    v46 = std stackAddr 50
    v47 = std constI64 8
    std osWriteFd v45 v46 v47

    v48 = std loadSlot 1
    v49 = std globalAddr __data_cov_counters
    v50 = std loadSlot 2
    v51 = std constI64 3
    v52 = std shlI64 v50 v51
    std osWriteFd v48 v49 v52

    v53 = std loadSlot 1
    std osClose v53
    std br done

  block done:
    v54 = std constI64 0
    std ret v54
end

// mrt_start_with_coverage: entry point used when coverage is enabled.
// Calls main, invokes mrt_cov_dump to flush counters, then exits with main's result.
// augmentWithRuntime selects between this and mrt_start based on project.coverageEnabled.
func mrt_start_with_coverage 0 void
  block entry:
    v4 = std call __slab_init
    v0 = std call main
    std storeSlot 0 v0
    v1 = std call mrt_cov_dump
    v2 = std loadSlot 0
    std osExit v2
    v3 = std constI64 0
    std ret v3
end

// =============================================================================
// Slab allocator — bottom layer (step 6a.12 of the allocator port).
//
// Provides:
//   - __slab_memzero            byte-zero helper used by upper layers.
//   - __slab_arena_init         allocates the first 64MB arena from the OS,
//                               sets up its bitmap, links it into the head.
//   - __slab_arena_alloc_chunks bitmap scan for N contiguous 8KB chunks.
//   - __slab_arena_free_chunks  marks chunks free in the bitmap.
//   - __slab_init               public init entry; idempotent.
//
// The upper layers (mspan, mcentral, mcache, arena map, mm_*) live in later
// steps. None of these functions are reachable from user code yet — step 6a.17
// will wire __slab_init into mrt_start and step 6a.18 will route mrt_alloc /
// __mm_alloc through the slab. Until then this file simply has to PARSE,
// LOWER, and EMIT cleanly so the build keeps producing a working binary.
//
// Constants (mirrored from RuntimeEmitter.Allocator.cs):
//   ARENA_SIZE           = 0x4000000   // 64 MiB
//   CHUNK_SIZE           = 0x2000      // 8 KiB
//   CHUNKS_PER_ARENA     = 0x2000      // 8192 chunks
//   ARENA_META_OFF_NEXT  = 0x00
//   ARENA_META_OFF_BITMAP= 0x10        // 1024-byte bitmap, 128 qwords
//
// Mutable globals expected by these functions:
//   __slab_arena_list_head   8 bytes — head of the singly-linked arena list
//   __slab_arena_last_base   8 bytes — arena base of the most recent
//                                       successful arena_alloc_chunks call
//   __slab_init_done         8 bytes — 0 = uninitialised, 1 = ready
//
// TODO(step 6a.17): the X64/Arm64 backends do not yet register these `__slab_*`
// labels in either the rdata or .data prelude. globalAddr emits a relocation
// referencing the unregistered label, and `lookupRdataOffset` silently returns
// offset 0 — harmless because the functions in this block are unreached, but
// the bootstrap step that calls __slab_init from mrt_start MUST first arrange
// for these globals to be backed by writable storage (likely via a new
// addDataSectionEntry call).
//
// TODO(step 6a.13+): size-class lookup tables (__slab_class_sizes,
// __slab_objs_per_span) are not emitted here — the chunk allocator does not
// need them. They will arrive with the mspan/mcentral layer.
// =============================================================================

// __slab_memzero(ptr, size): zeros `size` bytes starting at `ptr`. Loops one
// byte at a time so callers don't have to ensure 8-byte alignment of `size`.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = size (arg)
//   slot 2 = i (loop counter)
func __slab_memzero 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std constI64 0
    std storeSlot 2 v2
    std br loop

  block loop:
    v3 = std loadSlot 2
    v4 = std loadSlot 1
    v5 = std cmpI64Lt v3 v4
    std condBr v5 body done

  block body:
    v6 = std loadSlot 0
    v7 = std loadSlot 2
    v8 = std constI64 0
    std storeByte v6 v7 v8
    v9 = std loadSlot 2
    v10 = std constI64 1
    v11 = std addI64 v9 v10
    std storeSlot 2 v11
    std br loop

  block done:
    v12 = std constI64 0
    std ret v12
end

// __slab_arena_init(): allocates the very first 64 MiB arena from the OS,
// initialises its metadata + bitmap, prepends it to the arena list, and
// flips __slab_init_done to 1. Idempotent — only runs when the head is null.
//
// Bitmap layout: chunk 0 holds the metadata, so its bit must stay 0 (used).
// All other 8191 chunks start as 1 (free). 128 qwords of bitmap. We write
// 0xFFFFFFFFFFFFFFFE into qword 0 and 0xFFFFFFFFFFFFFFFF into qwords 1..127.
//
// Slot usage:
//   slot 0 = arena_base
//   slot 1 = qword index (loop counter)
func __slab_arena_init 0 void
  block entry:
    v0 = std constI64 0x4000000
    v1 = std osAllocPages v0
    std storeSlot 0 v1

    // metadata: next = NULL  (offset 0x00)
    v2 = std constI64 0
    std storeIndirect v1 0 v2

    // bitmap qword 0 = 0xFFFFFFFFFFFFFFFE  (chunk 0 used, rest free)
    // arena_base + 0x10
    v3 = std constI64 0x10
    v4 = std addI64 v1 v3
    v5 = std constI64 -2
    std storeIndirect v4 0 v5

    // qwords 1..127 = 0xFFFFFFFFFFFFFFFF
    v6 = std constI64 1
    std storeSlot 1 v6
    std br fill_loop

  block fill_loop:
    v7 = std loadSlot 1
    v8 = std constI64 128
    v9 = std cmpI64Lt v7 v8
    std condBr v9 fill_body fill_done

  block fill_body:
    v10 = std loadSlot 0
    v11 = std loadSlot 1
    v12 = std constI64 3
    v13 = std shlI64 v11 v12
    v14 = std constI64 0x10
    v15 = std addI64 v13 v14
    v16 = std addI64 v10 v15
    v17 = std constI64 -1
    std storeIndirect v16 0 v17
    v18 = std loadSlot 1
    v19 = std constI64 1
    v20 = std addI64 v18 v19
    std storeSlot 1 v20
    std br fill_loop

  block fill_done:
    // Prepend to the arena list head: new->next = old_head; head = new.
    v21 = std globalAddr __slab_arena_list_head
    v22 = std loadIndirect v21 0
    v23 = std loadSlot 0
    std storeIndirect v23 0 v22
    std storeIndirect v21 0 v23

    // __slab_init_done = 1
    v24 = std globalAddr __slab_init_done
    v25 = std constI64 1
    std storeIndirect v24 0 v25

    v26 = std constI64 0
    std ret v26
end

// __slab_arena_alloc_chunks(num_chunks) -> ptr
//
// Walks the arena list scanning each arena's bitmap bit-by-bit for a run of
// `num_chunks` consecutive free chunks. On success: clears those bits, stores
// the arena base in __slab_arena_last_base, and returns
// (arena_base + run_start * CHUNK_SIZE).
//
// On failure (no arena has room): allocates a fresh 64 MiB arena via the OS,
// links it in, and retries. The C# implementation uses a qword-level fast
// path with BSF; this port uses a simple bit-by-bit scan. The bottom layer
// is not on a hot path yet (chunks are allocated rarely — once per mspan
// refill or arena-map L2), so the simpler scan is fine for now.
//
// TODO(perf, step 6a.18): port the qword/BSF fast path from
// EmitArenaAllocChunks once the upper layer is calling this in production.
//
// Slot usage:
//   slot 0  = num_chunks (arg)
//   slot 1  = arena_ptr (current arena being scanned)
//   slot 2  = i (chunk index 0..ChunksPerArena)
//   slot 3  = run_len
//   slot 4  = run_start
//   slot 5  = result ptr
//   slot 6  = j (clear loop counter)
func __slab_arena_alloc_chunks 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std globalAddr __slab_arena_list_head
    v2 = std loadIndirect v1 0
    std storeSlot 1 v2
    std br arena_loop

  block arena_loop:
    v3 = std loadSlot 1
    v4 = std constI64 0
    v5 = std cmpI64Eq v3 v4
    std condBr v5 grow_arena scan_init

  block scan_init:
    // i = 1 (skip chunk 0, always used by metadata)
    v6 = std constI64 1
    std storeSlot 2 v6
    v7 = std constI64 0
    std storeSlot 3 v7
    v8 = std constI64 0
    std storeSlot 4 v8
    std br bit_loop

  block bit_loop:
    // i < CHUNKS_PER_ARENA (8192)?
    v9 = std loadSlot 2
    v10 = std constI64 0x2000
    v11 = std cmpI64Lt v9 v10
    std condBr v11 bit_body next_arena

  block bit_body:
    // qword_idx = i >> 6
    v12 = std loadSlot 2
    v13 = std constI64 6
    v14 = std shrI64 v12 v13
    // qword_addr = arena + 0x10 + qword_idx * 8
    v15 = std loadSlot 1
    v16 = std constI64 3
    v17 = std shlI64 v14 v16
    v18 = std constI64 0x10
    v19 = std addI64 v17 v18
    v20 = std addI64 v15 v19
    v21 = std loadIndirect v20 0
    // bit = (qword >> (i & 63)) & 1
    v22 = std constI64 63
    v23 = std andI64 v12 v22
    v24 = std shrI64 v21 v23
    v25 = std constI64 1
    v26 = std andI64 v24 v25
    v27 = std constI64 0
    v28 = std cmpI64Eq v26 v27
    std condBr v28 bit_used bit_free

  block bit_used:
    // run broken
    v29 = std constI64 0
    std storeSlot 3 v29
    std br bit_advance

  block bit_free:
    // run_len was 0? then run_start = i.
    v30 = std loadSlot 3
    v31 = std constI64 0
    v32 = std cmpI64Eq v30 v31
    std condBr v32 set_start incr_run

  block set_start:
    v33 = std loadSlot 2
    std storeSlot 4 v33
    std br incr_run

  block incr_run:
    v34 = std loadSlot 3
    v35 = std constI64 1
    v36 = std addI64 v34 v35
    std storeSlot 3 v36
    // run_len >= num_chunks?
    v37 = std loadSlot 0
    v38 = std cmpI64Lt v36 v37
    std condBr v38 bit_advance found

  block bit_advance:
    v39 = std loadSlot 2
    v40 = std constI64 1
    v41 = std addI64 v39 v40
    std storeSlot 2 v41
    std br bit_loop

  block next_arena:
    // arena = arena->next  (offset 0x00)
    v42 = std loadSlot 1
    v43 = std loadIndirect v42 0
    std storeSlot 1 v43
    std br arena_loop

  block found:
    // Clear bits run_start..run_start+num_chunks-1 in the bitmap.
    // j = run_start
    v44 = std loadSlot 4
    std storeSlot 6 v44
    std br clear_loop

  block clear_loop:
    // j < run_start + num_chunks?
    v45 = std loadSlot 6
    v46 = std loadSlot 4
    v47 = std loadSlot 0
    v48 = std addI64 v46 v47
    v49 = std cmpI64Lt v45 v48
    std condBr v49 clear_body clear_done

  block clear_body:
    // qword_addr = arena + 0x10 + (j >> 6) * 8
    v50 = std constI64 6
    v51 = std shrI64 v45 v50
    v52 = std constI64 3
    v53 = std shlI64 v51 v52
    v54 = std constI64 0x10
    v55 = std addI64 v53 v54
    v56 = std loadSlot 1
    v57 = std addI64 v56 v55
    // mask = ~(1 << (j & 63))
    v58 = std constI64 63
    v59 = std andI64 v45 v58
    v60 = std constI64 1
    v61 = std shlI64 v60 v59
    v62 = std bitNotI64 v61
    // bitmap[qword] &= mask
    v63 = std loadIndirect v57 0
    v64 = std andI64 v63 v62
    std storeIndirect v57 0 v64
    // j++
    v65 = std constI64 1
    v66 = std addI64 v45 v65
    std storeSlot 6 v66
    std br clear_loop

  block clear_done:
    // __slab_arena_last_base = arena_ptr
    v67 = std globalAddr __slab_arena_last_base
    v68 = std loadSlot 1
    std storeIndirect v67 0 v68
    // result = arena + run_start * CHUNK_SIZE
    v69 = std loadSlot 4
    v70 = std constI64 13
    v71 = std shlI64 v69 v70
    v72 = std loadSlot 1
    v73 = std addI64 v72 v71
    std ret v73

  block grow_arena:
    // No arena had room — allocate a fresh 64 MiB arena from the OS, link
    // it in, then jump back to the top to retry the scan.
    v74 = std constI64 0x4000000
    v75 = std osAllocPages v74
    std storeSlot 1 v75

    // metadata: next = old_head
    v76 = std globalAddr __slab_arena_list_head
    v77 = std loadIndirect v76 0
    std storeIndirect v75 0 v77

    // bitmap qword 0 = 0xFFFFFFFFFFFFFFFE
    v78 = std constI64 0x10
    v79 = std addI64 v75 v78
    v80 = std constI64 -2
    std storeIndirect v79 0 v80

    // qwords 1..127 = -1 (all free)
    v81 = std constI64 1
    std storeSlot 6 v81
    std br grow_fill_loop

  block grow_fill_loop:
    v82 = std loadSlot 6
    v83 = std constI64 128
    v84 = std cmpI64Lt v82 v83
    std condBr v84 grow_fill_body grow_fill_done

  block grow_fill_body:
    v85 = std loadSlot 1
    v86 = std loadSlot 6
    v87 = std constI64 3
    v88 = std shlI64 v86 v87
    v89 = std constI64 0x10
    v90 = std addI64 v88 v89
    v91 = std addI64 v85 v90
    v92 = std constI64 -1
    std storeIndirect v91 0 v92
    v93 = std loadSlot 6
    v94 = std constI64 1
    v95 = std addI64 v93 v94
    std storeSlot 6 v95
    std br grow_fill_loop

  block grow_fill_done:
    // head = new_arena (slot 1 still holds it)
    v96 = std loadSlot 1
    std storeIndirect v76 0 v96
    // Restart the scan against the fresh arena.
    std br arena_loop
end

// __slab_arena_free_chunks(arena_base, chunk_index, num_chunks)
//
// Marks chunks [chunk_index .. chunk_index + num_chunks - 1] as free in the
// bitmap of the given arena. Bit-by-bit OR; the C# version uses qword masks.
//
// Slot usage:
//   slot 0 = arena_base (arg)
//   slot 1 = chunk_index (arg)
//   slot 2 = num_chunks (arg)
//   slot 3 = j (loop counter, absolute chunk index)
func __slab_arena_free_chunks 3 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2

    // j = chunk_index
    std storeSlot 3 v1
    std br loop

  block loop:
    // j < chunk_index + num_chunks?
    v3 = std loadSlot 3
    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std addI64 v4 v5
    v7 = std cmpI64Lt v3 v6
    std condBr v7 body done

  block body:
    // qword_addr = arena_base + 0x10 + (j >> 6) * 8
    v8 = std constI64 6
    v9 = std shrI64 v3 v8
    v10 = std constI64 3
    v11 = std shlI64 v9 v10
    v12 = std constI64 0x10
    v13 = std addI64 v11 v12
    v14 = std loadSlot 0
    v15 = std addI64 v14 v13
    // bitmap[qword] |= 1 << (j & 63)
    v16 = std constI64 63
    v17 = std andI64 v3 v16
    v18 = std constI64 1
    v19 = std shlI64 v18 v17
    v20 = std loadIndirect v15 0
    v21 = std orI64 v20 v19
    std storeIndirect v15 0 v21
    // j++
    v22 = std constI64 1
    v23 = std addI64 v3 v22
    std storeSlot 3 v23
    std br loop

  block done:
    v24 = std constI64 0
    std ret v24
end

// __slab_init(): public init entry. Idempotent — runs __slab_arena_init
// only if __slab_init_done is still 0. The size-class tables and the
// upper-layer state (mcache, mcentral, arena map, OS-direct array) are NOT
// set up here yet — they belong to step 6a.13+.
func __slab_init 0 void
  block entry:
    v0 = std globalAddr __slab_init_done
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 do_init done

  block do_init:
    v4 = std call __slab_arena_init
    std br done

  block done:
    v5 = std constI64 0
    std ret v5
end

// =============================================================================
// Slab allocator — middle layer (step 6a.13 of the allocator port).
//
// Adds the mspan / mcentral / mcache layer on top of the chunk allocator.
//
// Provides:
//   - __slab_class_size(idx)        size-class lookup table (cascade compares).
//   - __slab_objs_per_span(idx)     objects-per-span lookup table.
//   - __slab_meta_alloc()           hands out 64-byte mspan-header slots,
//                                   backed by a free list + bump pointer that
//                                   refills from a dedicated 8 KiB chunk.
//   - __slab_meta_free(ptr)         pushes a 64-byte slot back onto the free
//                                   list.
//   - __slab_refill_mcache(class)   drains a span from mcentral.partial or
//                                   builds a fresh one, stores it in
//                                   mcache[class].
//   - __slab_alloc_class(class)     fast-path: pop a slot from the cached
//                                   span, refilling mcache on miss.
//   - __slab_free_class_with_mspan(slot, mspan)
//                                   pushes a slot back onto its span's free
//                                   list. The arena-map–driven public free
//                                   path (`__slab_free`) belongs to step
//                                   6a.14 — until then callers must already
//                                   know the owning mspan.
//
// Globals consumed (declared by step 6a.17 alongside the chunk-allocator
// globals — see the TODO atop the bottom-layer block):
//   __slab_mcache_base     8 bytes  pointer-array of 18 mspan*; single-thread.
//   __slab_meta_free_head  8 bytes  head of intrusive free-list of 64 B slots.
//   __slab_meta_bump_ptr   8 bytes  current bump pointer in metadata chunk.
//   __slab_meta_bump_end   8 bytes  end of the metadata chunk.
//   __slab_mcentral_array  288 B    18 × {partial_head(8), full_head(8)}.
//
// mspan struct (64 bytes, mirrors RuntimeEmitter.Allocator.cs):
//   +0x00 base_addr    +0x08 slot_size   +0x10 free_list   +0x18 free_count
//   +0x20 next_span    +0x28 class_idx   +0x30 total_slots +0x38 arena_base
//
// TODO(step 6a.14): introduce `__slab_free` (public) that recovers the mspan
// from the slot pointer via the two-level arena map, then forwards to
// __slab_free_class_with_mspan. Until then the slab allocator leaks freed
// slots — acceptable per the plan because user code is not yet routed
// through it.
//
// TODO(step 6a.17): the per-class mcentral locks (__slab_mcentral_lock_<i>,
// 40 bytes on Windows / 24 on Linux) are intentionally NOT acquired here.
// The self-hosted compiler currently runs single-threaded so contention is
// impossible; once threading lands the lock acquire/release must be inserted
// at the marked sites in __slab_refill_mcache.
// =============================================================================

// __slab_class_size(idx) -> i64
// Returns SlabClassSizes[idx]. Implemented as a cascade of equality compares
// rather than a data-table load so we don't have to register a new symdata
// global in this step (that would also pull in step-6a.17 work). The 18-way
// cascade is fine — it sits behind both __slab_alloc_class (size class is
// already known statically by the caller in many cases) and the upcoming
// __slab_alloc which dispatches once per allocation.

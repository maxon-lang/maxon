    std storeSlot 5 v15
    v16 = std addI64 v1 v2
    v17 = std mulI64 v16 v13
    std storeSlot 6 v17
    std br loop_head

  block loop_head:
    v18 = std loadSlot 5
    v19 = std loadSlot 6
    v20 = std cmpI64Lt v18 v19
    std condBr v20 loop_body loop_end


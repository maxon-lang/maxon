    // idx < length; rdata-backed buffers don't have spare capacity for
    // out-of-length writes.
    v204 = std loadSlot 0
    v205 = std loadIndirect v204 16
    v206 = std loadSlot 1
    v207 = std cmpI64Lt v206 v205
    std condBr v207 ok err

  block ok:
    // elemSize = self[24]; buffer = self[0]; addr = buffer + idx * elemSize
    v12 = std loadSlot 0
    v13 = std loadIndirect v12 24
    v14 = std loadSlot 1
    v15 = std mulI64 v14 v13
    v16 = std loadSlot 0
    v17 = std loadIndirect v16 0
    v18 = std addI64 v17 v15
    // if elemSize == 1 -> byte path
    v19 = std constI64 1
    v20 = std cmpI64Eq v13 v19
    std condBr v20 byte_path word_path

  block byte_path:
    v21 = std constI64 0
    v22 = std loadSlot 2
    std storeByte v18 v21 v22
    v23 = std constI64 0
    v100 = std constI64 0
    std errorReturn v23 v100

  block word_path:
    v24 = std loadSlot 2
    std storeIndirect v18 0 v24
    v25 = std constI64 0
    v101 = std constI64 0
    std errorReturn v25 v101

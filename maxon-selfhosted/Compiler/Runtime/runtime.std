// Runtime functions expressed as Std-level IR.
// Parsed by StdParser into IrFunction objects.
// Uses std osExit / std osWrite for OS-independent runtime.

// mrt_start: process entry point. Calls main() and exits with its return code.
// Step 6a.17: bootstrap the slab/MM allocator before main() runs. `__slab_init`
// is idempotent so it's safe to call once unconditionally; the allocator's
// mutable globals (`__slab_init_done`, `__slab_arena_list_head`, ...) are
// registered in the .data prelude by `registerSlabAndMmGlobalsForDataSection`.
func mrt_start 0 void
  block entry:
    v2 = std call __slab_init
    v0 = std call main
    std osExit v0
    v1 = std constI64 0
    std ret v1
end

// mrt_leak_check(code): process-exit leak gate. Reads the live tracked-allocation
// counter `__mm_alloc_count` (incremented by __mm_alloc, decremented by __mm_free);
// returns `code` (main's exit code) when the count is zero, or 101 when any
// allocation is still live at program exit. `patchMrtStartLeakCheck` rewrites
// mrt_start's `osExit(main())` to `osExit(mrt_leak_check(main()))` when the
// project's leak-check is enabled (spec-test success/ladder runs), so a leaking
// standalone program exits 101 and its test fails — the per-fragment equivalent
// of the batch dispatcher's per-test alloc-count diff.
func mrt_leak_check 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std globalAddr __mm_alloc_count
    v2 = std loadIndirect v1 0
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 clean leaked
  block clean:
    std ret v0
  block leaked:
    v5 = std constI64 101
    std ret v5
end

// mrt_write_stdout(ptr len): writes len bytes at ptr to stdout.
func mrt_write_stdout 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std osWrite v0 v1
    v2 = std constI64 0
    std ret v2
end

// mrt_write_stderr(ptr len): writes len bytes at ptr to stderr.
func mrt_write_stderr 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std osWriteErr v0 v1
    v2 = std constI64 0
    std ret v2
end

// mrt_read_stdin(ptr len): reads up to len bytes from stdin into [ptr].
// Returns the number of bytes read in v2 (0 on EOF).
func mrt_read_stdin 2 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std osRead v0 v1
    std ret v2
end

// mrt_read_stdin_managed(maxBytes): allocates a __ManagedMemory of capacity
// maxBytes (byte-sized elements), reads up to maxBytes bytes from stdin into
// its buffer, sets the MM's length to the count actually read, and returns
// the MM pointer. The lowering for `__Builtins.readStdin` calls this helper.
//
// Slot usage:
//   slot 0 = mm pointer
//   slot 1 = bytes read
func mrt_read_stdin_managed 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 1
    v2 = std call __managed_mem_create v0 v1
    std storeSlot 0 v2

    // Load mm buffer = mm[0].
    v3 = std loadSlot 0
    v4 = std loadIndirect v3 0
    v5 = std osRead v4 v0
    std storeSlot 1 v5

    // Store mm.length = bytes read at mm[8].
    v6 = std loadSlot 0
    v7 = std loadSlot 1
    std storeIndirect v6 8 v7

    v8 = std loadSlot 0
    std ret v8
end

// mrt_i64_to_string(value buffer_ptr): converts integer to decimal string in buffer.
// Returns number of bytes written.
func mrt_i64_to_string 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v46 = std param 1 i64
    std storeSlot 1 v46
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 zero_case check_neg

  block zero_case:
    v3 = std loadSlot 1
    v4 = std constI64 0
    v5 = std constI64 0x30
    std storeByte v3 v4 v5
    v6 = std constI64 1
    std ret v6

  block check_neg:
    v7 = std constI64 0
    std storeSlot 5 v7
    v8 = std loadSlot 0
    std storeSlot 6 v8
    v9 = std constI64 0
    v10 = std cmpI64Lt v8 v9
    std condBr v10 negate setup

  block negate:
    v11 = std loadSlot 6
    v12 = std negI64 v11
    std storeSlot 6 v12
    v13 = std constI64 1
    std storeSlot 5 v13
    std br setup

  block setup:
    v14 = std stackAddr 2
    v15 = std constI64 20
    v16 = std addI64 v14 v15
    std storeSlot 7 v16
    v17 = std constI64 0
    v18 = std constI64 0
    std storeByte v16 v18 v17
    std br digit_loop

  block digit_loop:
    v19 = std loadSlot 7
    v20 = std constI64 1
    v21 = std subI64 v19 v20
    std storeSlot 7 v21
    v22 = std loadSlot 6
    v23 = std constI64 10
    v24 = std remI64 v22 v23
    v25 = std divI64 v22 v23
    std storeSlot 6 v25
    v26 = std constI64 0x30
    v27 = std addI64 v24 v26
    v28 = std constI64 0
    std storeByte v21 v28 v27
    v29 = std constI64 0
    v30 = std loadSlot 6
    v31 = std cmpI64Gt v30 v29
    std condBr v31 digit_loop check_sign

  block check_sign:
    v32 = std loadSlot 5
    v33 = std constI64 0
    v34 = std cmpI64Gt v32 v33
    std condBr v34 prepend_minus copy_phase

  block prepend_minus:
    v35 = std loadSlot 7
    v36 = std constI64 1
    v37 = std subI64 v35 v36
    std storeSlot 7 v37
    v38 = std constI64 0x2D
    v39 = std constI64 0
    std storeByte v37 v39 v38
    std br copy_phase

  block copy_phase:
    v40 = std stackAddr 2
    v41 = std constI64 20
    v42 = std addI64 v40 v41
    v43 = std loadSlot 7
    v44 = std subI64 v42 v43
    v45 = std loadSlot 1
    std memcpy v45 v43 v44
    std ret v44

end

// mrt_bool_to_string(value buffer_ptr): writes "true"/"false" to buffer.
// Returns 4 (true) or 5 (false). Buffer must be >= 5 bytes.
func mrt_bool_to_string 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std constI64 0
    v3 = std cmpI64Eq v0 v2
    std condBr v3 false_case true_case

  block true_case:
    v4 = std loadSlot 1
    v5 = std constI64 0
    v6 = std constI64 1
    v7 = std constI64 2
    v8 = std constI64 3
    v9 = std constI64 0x74
    v10 = std constI64 0x72
    v11 = std constI64 0x75
    v12 = std constI64 0x65
    std storeByte v4 v5 v9
    std storeByte v4 v6 v10
    std storeByte v4 v7 v11
    std storeByte v4 v8 v12
    v13 = std constI64 4
    std ret v13

  block false_case:
    v14 = std loadSlot 1
    v15 = std constI64 0
    v16 = std constI64 1
    v17 = std constI64 2
    v18 = std constI64 3
    v19 = std constI64 4
    v20 = std constI64 0x66
    v21 = std constI64 0x61
    v22 = std constI64 0x6C
    v23 = std constI64 0x73
    v24 = std constI64 0x65
    std storeByte v14 v15 v20
    std storeByte v14 v16 v21
    std storeByte v14 v17 v22
    std storeByte v14 v18 v23
    std storeByte v14 v19 v24
    v25 = std constI64 5
    std ret v25

end

// mrt_f64_to_string(value buffer_ptr): converts float to decimal string with 6 fractional digits.
// Returns byte count. Buffer must be >= 32 bytes. No trailing-zero stripping
// (output always has exactly 6 fractional digits) — sufficient for spec tests.
//
// Slot layout:
//   slot 0 = |value| (f64, abs value updated after sign extraction)
//   slot 1 = buffer_ptr (i64)
//   slot 2 = is_negative flag (i64, 0 or 1)
//   slot 3 = total length so far (sign + integer-part length, before '.')
//   slot 4 = integer part (i64)
//   slot 5 = fractional digits (i64, 0..999999)
//   slot 6 = digit-write offset (loop counter, 5 down to 0)
func mrt_f64_to_string 2 i64
  block entry:
    v0 = std param 0 f64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std constF64 0
    v3 = std cmpF64Eq v0 v2
    std condBr v3 zero_case check_neg

  block zero_case:
    v4 = std loadSlot 1
    v5 = std constI64 0
    v6 = std constI64 1
    v7 = std constI64 2
    v8 = std constI64 0x30
    v9 = std constI64 0x2E
    std storeByte v4 v5 v8
    std storeByte v4 v6 v9
    std storeByte v4 v7 v8
    v10 = std constI64 3
    std ret v10

  block check_neg:
    v11 = std constI64 0
    std storeSlot 2 v11
    v12 = std loadSlot 0
    v13 = std constF64 0
    v14 = std cmpF64Lt v12 v13
    std condBr v14 do_neg setup_int

  block do_neg:
    v15 = std loadSlot 0
    v16 = std constF64 0
    v17 = std subF64 v16 v15
    std storeSlot 0 v17
    v18 = std constI64 1
    std storeSlot 2 v18
    std br setup_int

  block setup_int:
    v19 = std loadSlot 0
    v20 = std fpToSiI64 v19
    std storeSlot 4 v20
    v21 = std loadSlot 2
    v22 = std constI64 0
    v23 = std cmpI64Gt v21 v22
    std condBr v23 write_minus call_int

  block write_minus:
    v24 = std loadSlot 1
    v25 = std constI64 0
    v26 = std constI64 0x2D
    std storeByte v24 v25 v26
    std br call_int

  block call_int:
    v27 = std loadSlot 1
    v28 = std loadSlot 2
    v29 = std addI64 v27 v28
    v30 = std loadSlot 4
    v31 = std call mrt_i64_to_string v30 v29
    v32 = std addI64 v28 v31
    std storeSlot 3 v32
    v33 = std loadSlot 1
    v34 = std addI64 v33 v32
    v35 = std constI64 0
    v36 = std constI64 0x2E
    std storeByte v34 v35 v36
    v37 = std loadSlot 0
    v38 = std loadSlot 4
    v39 = std siToFpF64 v38
    v40 = std subF64 v37 v39
    v41 = std constF64 0x412e848000000000
    v42 = std mulF64 v40 v41
    v43 = std constF64 0x3fe0000000000000
    v44 = std addF64 v42 v43
    v45 = std fpToSiI64 v44
    v46 = std constI64 1000000
    v47 = std cmpI64Ge v45 v46
    std condBr v47 clamp_frac use_frac

  block clamp_frac:
    v48 = std constI64 999999
    std storeSlot 5 v48
    std br digit_setup

  block use_frac:
    std storeSlot 5 v45
    std br digit_setup

  block digit_setup:
    v49 = std constI64 5
    std storeSlot 6 v49
    std br digit_loop

  block digit_loop:
    v50 = std loadSlot 6
    v51 = std constI64 0
    v52 = std cmpI64Lt v50 v51
    std condBr v52 after_digits write_digit

  block write_digit:
    v53 = std loadSlot 5
    v54 = std constI64 10
    v55 = std remI64 v53 v54
    v56 = std divI64 v53 v54
    std storeSlot 5 v56
    v57 = std constI64 0x30
    v58 = std addI64 v55 v57
    v59 = std loadSlot 1
    v60 = std loadSlot 3
    v61 = std addI64 v59 v60
    v62 = std constI64 1
    v63 = std addI64 v61 v62
    v64 = std loadSlot 6
    std storeByte v63 v64 v58
    v65 = std loadSlot 6
    v66 = std constI64 1
    v67 = std subI64 v65 v66
    std storeSlot 6 v67
    std br digit_loop

  block after_digits:
    // Strip trailing zeros, keeping at least 1 fractional digit so output
    // always shows the decimal point (e.g. "3.0" not "3."). Slot 3 holds
    // sign+intLen (the position of '.'); the 6 fractional digits start at
    // slot3+1 and run through slot3+6. Slot 7 holds the inclusive index of
    // the last digit, dropping while it points to a '0' and the index is
    // still strictly greater than slot3+1.
    v68 = std loadSlot 3
    v69 = std constI64 6
    v70 = std addI64 v68 v69
    std storeSlot 7 v70
    std br strip_loop

  block strip_loop:
    v71 = std loadSlot 7
    v72 = std loadSlot 3
    v73 = std constI64 1
    v74 = std addI64 v72 v73
    v75 = std cmpI64Le v71 v74
    std condBr v75 strip_done check_zero

  block check_zero:
    v76 = std loadSlot 1
    v77 = std loadSlot 7
    v78 = std loadByte v76 v77
    v79 = std constI64 0x30
    v80 = std cmpI64Eq v78 v79
    std condBr v80 do_strip strip_done

  block do_strip:
    v81 = std loadSlot 7
    v82 = std constI64 1
    v83 = std subI64 v81 v82
    std storeSlot 7 v83
    std br strip_loop

  block strip_done:
    // Final length is (last kept index) + 1. slot7 is inclusive; +1 yields
    // a count.
    v84 = std loadSlot 7
    v85 = std constI64 1
    v86 = std addI64 v84 v85
    std ret v86

end

// mrt_i64_to_string_fmt(value, buffer, fmt_ptr, fmt_len) -> length.
// Converts a signed i64 to a formatted decimal/hex/octal/binary string in
// `buffer`. Format-spec mini-grammar matches the C# bootstrap:
//   [0][width][type]
// where leading `0` toggles zero-pad, `width` is a decimal integer, and
// `type` is one of x/X/b/o (defaults to decimal). Returns the byte count
// written (excluding the null terminator). `buffer` must be >= 72 bytes —
// the implementation writes digits backwards into the upper half (offsets
// 16..64) then assembles the final padded output starting at offset 0.
//
// Slot layout:
//   slot 0  = value (arg, i64)
//   slot 1  = buffer (arg, i64)
//   slot 2  = fmt_ptr (arg, i64)
//   slot 3  = fmt_len (arg, i64)
//   slot 4  = fill_char (' ' or '0')
//   slot 5  = width
//   slot 6  = type_char (0/'d'/'x'/'X'/'b'/'o')
//   slot 7  = base (10/16/8/2)
//   slot 8  = upper_hex (0 or 1)
//   slot 9  = is_negative (0 or 1)
//   slot 10 = abs_val
//   slot 11 = digits_end_offset (offset into buffer; one past last digit)
//   slot 12 = digits_start_offset (offset into buffer; first digit)
//   slot 13 = parse_idx
//   slot 14 = scratch / loop counter
func mrt_i64_to_string_fmt 4 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2
    v3 = std param 3 i64
    std storeSlot 3 v3
    // Defaults: fill=' ', width=0, type=0 (decimal), base=10, upper=0
    v4 = std constI64 0x20
    std storeSlot 4 v4
    v5 = std constI64 0
    std storeSlot 5 v5
    v6 = std constI64 0
    std storeSlot 6 v6
    v7 = std constI64 10
    std storeSlot 7 v7
    v8 = std constI64 0
    std storeSlot 8 v8
    // Skip parse if fmt_len == 0
    v9 = std constI64 0
    v10 = std cmpI64Eq v3 v9
    std condBr v10 do_convert parse_fill

  block parse_fill:
    // If fmt_ptr[0] == '0' set fill='0' and advance parse_idx by 1.
    v11 = std loadSlot 2
    v12 = std constI64 0
    v13 = std loadByte v11 v12
    v14 = std constI64 0x30
    v15 = std cmpI64Eq v13 v14
    std condBr v15 set_zero_fill init_width

  block set_zero_fill:
    v16 = std constI64 0x30
    std storeSlot 4 v16
    v17 = std constI64 1
    std storeSlot 13 v17
    std br width_loop

  block init_width:
    v18 = std constI64 0
    std storeSlot 13 v18
    std br width_loop

  block width_loop:
    // While parse_idx < fmt_len and fmt_ptr[parse_idx] is a digit:
    //   width = width * 10 + (digit - '0')
    v19 = std loadSlot 13
    v20 = std loadSlot 3
    v21 = std cmpI64Ge v19 v20
    std condBr v21 parse_done width_loop_body

  block width_loop_body:
    v22 = std loadSlot 2
    v23 = std loadSlot 13
    v24 = std loadByte v22 v23
    v25 = std constI64 0x30
    v26 = std cmpI64Lt v24 v25
    std condBr v26 check_type_char width_check_high

  block width_check_high:
    v27 = std constI64 0x39
    v28 = std cmpI64Gt v24 v27
    std condBr v28 check_type_char width_accum

  block width_accum:
    v29 = std loadSlot 5
    v30 = std constI64 10
    v31 = std mulI64 v29 v30
    v32 = std constI64 0x30
    v33 = std subI64 v24 v32
    v34 = std addI64 v31 v33
    std storeSlot 5 v34
    v35 = std loadSlot 13
    v36 = std constI64 1
    v37 = std addI64 v35 v36
    std storeSlot 13 v37
    std br width_loop

  block check_type_char:
    // parse_idx points at a non-digit. If parse_idx < fmt_len, capture
    // type_char and pick the appropriate base.
    v38 = std loadSlot 13
    v39 = std loadSlot 3
    v40 = std cmpI64Lt v38 v39
    std condBr v40 read_type_char parse_done

  block read_type_char:
    v41 = std loadSlot 2
    v42 = std loadSlot 13
    v43 = std loadByte v41 v42
    std storeSlot 6 v43
    // Pick base/upper based on type_char: 'x'(0x78) hex-lower, 'X'(0x58)
    // hex-upper, 'b'(0x62) binary, 'o'(0x6F) octal; anything else = decimal.
    v44 = std constI64 0x78
    v45 = std cmpI64Eq v43 v44
    std condBr v45 set_hex_lower check_upper_hex

  block set_hex_lower:
    v46 = std constI64 16
    std storeSlot 7 v46
    v47 = std constI64 0
    std storeSlot 8 v47
    std br parse_done

  block check_upper_hex:
    v48 = std constI64 0x58
    v49 = std cmpI64Eq v43 v48
    std condBr v49 set_hex_upper check_binary

  block set_hex_upper:
    v50 = std constI64 16
    std storeSlot 7 v50
    v51 = std constI64 1
    std storeSlot 8 v51
    std br parse_done

  block check_binary:
    v52 = std constI64 0x62
    v53 = std cmpI64Eq v43 v52
    std condBr v53 set_binary check_octal

  block set_binary:
    v54 = std constI64 2
    std storeSlot 7 v54
    std br parse_done

  block check_octal:
    v55 = std constI64 0x6F
    v56 = std cmpI64Eq v43 v55
    std condBr v56 set_octal parse_done

  block set_octal:
    v57 = std constI64 8
    std storeSlot 7 v57
    std br parse_done

  block parse_done:
    std br do_convert

  block do_convert:
    // Sign-handling: only for base 10. For other bases, value is treated
    // as unsigned bits — matches the C# bootstrap.
    v58 = std constI64 0
    std storeSlot 9 v58
    v59 = std loadSlot 7
    v60 = std constI64 10
    v61 = std cmpI64Eq v59 v60
    std condBr v61 dec_sign_check unsigned_path

  block dec_sign_check:
    v62 = std loadSlot 0
    v63 = std constI64 0
    v64 = std cmpI64Lt v62 v63
    std condBr v64 negate_value abs_done

  block negate_value:
    v65 = std loadSlot 0
    v66 = std negI64 v65
    std storeSlot 10 v66
    v67 = std constI64 1
    std storeSlot 9 v67
    std br abs_done

  block unsigned_path:
    v68 = std loadSlot 0
    std storeSlot 10 v68
    std br abs_done

  block abs_done:
    // For the decimal sign-check path, slot 10 wasn't set on the positive
    // branch (where slot 9 stayed 0). Fix that here.
    v69 = std loadSlot 9
    v70 = std constI64 0
    v71 = std cmpI64Eq v69 v70
    std condBr v71 copy_abs_value digits_init

  block copy_abs_value:
    v72 = std loadSlot 0
    std storeSlot 10 v72
    std br digits_init

  block digits_init:
    // Initialize digits_end_offset = 64 (write backwards from buffer[64]).
    v73 = std constI64 64
    std storeSlot 11 v73
    std storeSlot 12 v73
    // Special case zero
    v74 = std loadSlot 10
    v75 = std constI64 0
    v76 = std cmpI64Eq v74 v75
    std condBr v76 write_zero digit_loop

  block write_zero:
    v77 = std loadSlot 12
    v78 = std constI64 1
    v79 = std subI64 v77 v78
    std storeSlot 12 v79
    v80 = std loadSlot 1
    v81 = std constI64 0x30
    std storeByte v80 v79 v81
    std br pad_setup

  block digit_loop:
    v82 = std loadSlot 10
    v83 = std constI64 0
    v84 = std cmpI64Le v82 v83
    std condBr v84 pad_setup write_digit

  block write_digit:
    // digit = abs_val % base; abs_val = abs_val / base
    v85 = std loadSlot 10
    v86 = std loadSlot 7
    v87 = std remI64 v85 v86
    v88 = std divI64 v85 v86
    std storeSlot 10 v88
    // ch = digit < 10 ? digit + '0' : digit - 10 + ('a' or 'A')
    v89 = std constI64 10
    v90 = std cmpI64Lt v87 v89
    std condBr v90 digit_low digit_high

  block digit_low:
    v91 = std constI64 0x30
    v92 = std addI64 v87 v91
    std storeSlot 14 v92
    std br emit_digit

  block digit_high:
    v93 = std loadSlot 8
    v94 = std constI64 0
    v95 = std cmpI64Eq v93 v94
    std condBr v95 hex_lower hex_upper

  block hex_lower:
    v96 = std constI64 87
    v97 = std addI64 v87 v96
    std storeSlot 14 v97
    std br emit_digit

  block hex_upper:
    v98 = std constI64 55
    v99 = std addI64 v87 v98
    std storeSlot 14 v99
    std br emit_digit

  block emit_digit:
    v100 = std loadSlot 12
    v101 = std constI64 1
    v102 = std subI64 v100 v101
    std storeSlot 12 v102
    v103 = std loadSlot 1
    v104 = std loadSlot 14
    std storeByte v103 v102 v104
    std br digit_loop

  block pad_setup:
    // digit_count = digits_end - digits_start
    // content_len = sign_len + digit_count
    // pad_count = max(0, width - content_len)
    v105 = std loadSlot 11
    v106 = std loadSlot 12
    v107 = std subI64 v105 v106
    // digit_count -> slot 14 (reuse scratch)
    std storeSlot 14 v107
    v108 = std loadSlot 9
    v109 = std addI64 v108 v107
    // content_len -> slot 15 (new)
    std storeSlot 15 v109
    v110 = std loadSlot 5
    v111 = std subI64 v110 v109
    v112 = std constI64 0
    v113 = std cmpI64Lt v111 v112
    std condBr v113 zero_pad pad_positive

  block zero_pad:
    v114 = std constI64 0
    std storeSlot 16 v114
    std br choose_fill

  block pad_positive:
    std storeSlot 16 v111
    std br choose_fill

  block choose_fill:
    // If fill is '0' AND base == 10 AND negative, write '-' first; otherwise
    // standard branches.
    v115 = std loadSlot 4
    v116 = std constI64 0x30
    v117 = std cmpI64Eq v115 v116
    std condBr v117 zero_fill_path space_fill_path

  block space_fill_path:
    // out_pos = 0; write pad_count spaces, then sign (if any), then digits.
    v118 = std constI64 0
    std storeSlot 13 v118
    std br space_pad_loop

  block space_pad_loop:
    v119 = std loadSlot 13
    v120 = std loadSlot 16
    v121 = std cmpI64Ge v119 v120
    std condBr v121 space_write_sign space_pad_body

  block space_pad_body:
    v122 = std loadSlot 1
    v123 = std constI64 0x20
    std storeByte v122 v119 v123
    v124 = std constI64 1
    v125 = std addI64 v119 v124
    std storeSlot 13 v125
    std br space_pad_loop

  block space_write_sign:
    v126 = std loadSlot 9
    v127 = std constI64 0
    v128 = std cmpI64Eq v126 v127
    std condBr v128 copy_digits_setup space_write_minus

  block space_write_minus:
    v129 = std loadSlot 1
    v130 = std loadSlot 13
    v131 = std constI64 0x2D
    std storeByte v129 v130 v131
    v132 = std loadSlot 13
    v133 = std constI64 1
    v134 = std addI64 v132 v133
    std storeSlot 13 v134
    std br copy_digits_setup

  block zero_fill_path:
    // out_pos = 0; if negative, write '-' first; then write pad_count zeros;
    // then copy digits.
    v135 = std constI64 0
    std storeSlot 13 v135
    v136 = std loadSlot 9
    v137 = std constI64 0
    v138 = std cmpI64Eq v136 v137
    std condBr v138 zero_pad_init zero_write_minus

  block zero_write_minus:
    v139 = std loadSlot 1
    v140 = std constI64 0
    v141 = std constI64 0x2D
    std storeByte v139 v140 v141
    v142 = std constI64 1
    std storeSlot 13 v142
    std br zero_pad_init

  block zero_pad_init:
    // Slot 14 doubles as a private pad counter for this loop; the digit
    // count gets re-derived in `copy_digits_setup` after we've finished
    // emitting the zero-pad run.
    v143 = std constI64 0
    std storeSlot 14 v143
    std br zero_pad_body

  block zero_pad_body:
    v144 = std loadSlot 14
    v145 = std loadSlot 16
    v146 = std cmpI64Ge v144 v145
    std condBr v146 copy_digits_setup zero_pad_write

  block zero_pad_write:
    v147 = std loadSlot 1
    v148 = std loadSlot 13
    v149 = std constI64 0x30
    std storeByte v147 v148 v149
    v150 = std loadSlot 13
    v151 = std constI64 1
    v152 = std addI64 v150 v151
    std storeSlot 13 v152
    v153 = std loadSlot 14
    v154 = std addI64 v153 v151
    std storeSlot 14 v154
    std br zero_pad_body

  block copy_digits_setup:
    // Re-derive digit_count from digits_end - digits_start.
    v155 = std loadSlot 11
    v156 = std loadSlot 12
    v157 = std subI64 v155 v156
    std storeSlot 14 v157
    v158 = std constI64 0
    std storeSlot 11 v158
    std br copy_digits_loop

  block copy_digits_loop:
    // Iterate from 0..digit_count, copying buffer[digits_start + i] to
    // buffer[out_pos + i]. Slot 11 has been repurposed as the copy index.
    v159 = std loadSlot 11
    v160 = std loadSlot 14
    v161 = std cmpI64Ge v159 v160
    std condBr v161 finalize_len copy_one_byte

  block copy_one_byte:
    v162 = std loadSlot 12
    v163 = std loadSlot 11
    v164 = std addI64 v162 v163
    v165 = std loadSlot 1
    v166 = std loadByte v165 v164
    v167 = std loadSlot 13
    v168 = std addI64 v167 v163
    std storeByte v165 v168 v166
    v169 = std constI64 1
    v170 = std addI64 v163 v169
    std storeSlot 11 v170
    std br copy_digits_loop

  block finalize_len:
    // Total length = out_pos + digit_count
    v171 = std loadSlot 13
    v172 = std loadSlot 14
    v173 = std addI64 v171 v172
    std ret v173

end

// mrt_u64_to_string_fmt(value, buffer, fmt_ptr, fmt_len) -> length.
// Unsigned variant — tail-calls into the signed implementation. Safe
// because our unsigned types (byte, u16, u32) are zero-extended to 64
// bits before reaching here, so the sign-bit check in the signed code
// path is a no-op.
func mrt_u64_to_string_fmt 4 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std param 3 i64
    v4 = std call mrt_i64_to_string_fmt v0 v1 v2 v3
    std ret v4
end

// mrt_f64_to_string_fmt(value, buffer, fmt_ptr, fmt_len) -> length.
// Format-spec grammar: [width][.precision]. Width pads the result with
// spaces to the left. Precision sets the number of decimal places (no
// trailing-zero stripping — `:.3` on 2.0 prints `2.000`). Without either
// component, falls through to `mrt_f64_to_string`. Buffer must be >= 72
// bytes.
//
// Slot layout:
//   slot 0  = value (f64)
//   slot 1  = buffer (i64)
//   slot 2  = fmt_ptr
//   slot 3  = fmt_len
//   slot 4  = width
//   slot 5  = precision (-1 = unset)
//   slot 6  = parse_idx
//   slot 7  = is_negative
//   slot 8  = abs_val (f64)
//   slot 9  = int_part (i64)
//   slot 10 = content_len
//   slot 11 = pad_count
//   slot 12 = frac_digits (i64)
//   slot 13 = frac_loop_i
//   slot 14 = scratch / loop counter
func mrt_f64_to_string_fmt 4 i64
  block entry:
    v0 = std param 0 f64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2
    v3 = std param 3 i64
    std storeSlot 3 v3
    // Defaults
    v4 = std constI64 0
    std storeSlot 4 v4
    v5 = std constI64 -1
    std storeSlot 5 v5
    v6 = std constI64 0
    std storeSlot 6 v6
    // If fmt_len == 0, delegate to plain mrt_f64_to_string.
    v7 = std constI64 0
    v8 = std cmpI64Eq v3 v7
    std condBr v8 delegate_default parse_width

  block delegate_default:
    v9 = std loadSlot 0
    v10 = std loadSlot 1
    v11 = std call mrt_f64_to_string v9 v10
    std ret v11

  block parse_width:
    v12 = std loadSlot 6
    v13 = std loadSlot 3
    v14 = std cmpI64Ge v12 v13
    std condBr v14 width_done parse_width_body

  block parse_width_body:
    v15 = std loadSlot 2
    v16 = std loadSlot 6
    v17 = std loadByte v15 v16
    v18 = std constI64 0x2E
    v19 = std cmpI64Eq v17 v18
    std condBr v19 parse_prec_advance check_width_digit

  block check_width_digit:
    v20 = std constI64 0x30
    v21 = std cmpI64Lt v17 v20
    std condBr v21 width_done width_check_high

  block width_check_high:
    v22 = std constI64 0x39
    v23 = std cmpI64Gt v17 v22
    std condBr v23 width_done width_accum

  block width_accum:
    v24 = std loadSlot 4
    v25 = std constI64 10
    v26 = std mulI64 v24 v25
    v27 = std constI64 0x30
    v28 = std subI64 v17 v27
    v29 = std addI64 v26 v28
    std storeSlot 4 v29
    v30 = std loadSlot 6
    v31 = std constI64 1
    v32 = std addI64 v30 v31
    std storeSlot 6 v32
    std br parse_width

  block parse_prec_advance:
    // Skip the '.'
    v33 = std loadSlot 6
    v34 = std constI64 1
    v35 = std addI64 v33 v34
    std storeSlot 6 v35
    v36 = std constI64 0
    std storeSlot 5 v36
    std br parse_prec

  block parse_prec:
    v37 = std loadSlot 6
    v38 = std loadSlot 3
    v39 = std cmpI64Ge v37 v38
    std condBr v39 width_done parse_prec_body

  block parse_prec_body:
    v40 = std loadSlot 2
    v41 = std loadSlot 6
    v42 = std loadByte v40 v41
    v43 = std constI64 0x30
    v44 = std cmpI64Lt v42 v43
    std condBr v44 width_done prec_check_high

  block prec_check_high:
    v45 = std constI64 0x39
    v46 = std cmpI64Gt v42 v45
    std condBr v46 width_done prec_accum

  block prec_accum:
    v47 = std loadSlot 5
    v48 = std constI64 10
    v49 = std mulI64 v47 v48
    v50 = std constI64 0x30
    v51 = std subI64 v42 v50
    v52 = std addI64 v49 v51
    std storeSlot 5 v52
    v53 = std loadSlot 6
    v54 = std constI64 1
    v55 = std addI64 v53 v54
    std storeSlot 6 v55
    std br parse_prec

  block width_done:
    // If precision == -1 and width == 0, delegate.
    v56 = std loadSlot 5
    v57 = std constI64 -1
    v58 = std cmpI64Eq v56 v57
    std condBr v58 width_has_no_prec convert_with_prec

  block width_has_no_prec:
    v59 = std loadSlot 4
    v60 = std constI64 0
    v61 = std cmpI64Eq v59 v60
    std condBr v61 delegate_default default_then_pad

  block default_then_pad:
    // No precision, but width set — call default f64 conversion at offset 0,
    // then shift right and left-pad with spaces.
    v62 = std loadSlot 0
    v63 = std loadSlot 1
    v64 = std call mrt_f64_to_string v62 v63
    std storeSlot 10 v64
    std br apply_width

  block convert_with_prec:
    // Clamp precision to 20 max to avoid runaway loops.
    v65 = std loadSlot 5
    v66 = std constI64 20
    v67 = std cmpI64Gt v65 v66
    std condBr v67 clamp_prec sign_check

  block clamp_prec:
    v68 = std constI64 20
    std storeSlot 5 v68
    std br sign_check

  block sign_check:
    v69 = std constI64 0
    std storeSlot 7 v69
    v70 = std loadSlot 0
    v71 = std constF64 0
    v72 = std cmpF64Lt v70 v71
    std condBr v72 negate_float store_abs

  block negate_float:
    v73 = std loadSlot 0
    v74 = std constF64 0
    v75 = std subF64 v74 v73
    std storeSlot 8 v75
    v76 = std constI64 1
    std storeSlot 7 v76
    std br write_int_part

  block store_abs:
    v77 = std loadSlot 0
    std storeSlot 8 v77
    std br write_int_part

  block write_int_part:
    // int_part = trunc(abs_val); write to buffer at offset (1 if negative else 0).
    v78 = std loadSlot 8
    v79 = std fpToSiI64 v78
    std storeSlot 9 v79
    v80 = std loadSlot 1
    v81 = std loadSlot 7
    v82 = std addI64 v80 v81
    v83 = std loadSlot 9
    v84 = std call mrt_i64_to_string v83 v82
    // int_part_len_with_sign = is_negative + int_part_len
    v85 = std loadSlot 7
    v86 = std addI64 v84 v85
    std storeSlot 10 v86
    // Write '-' at buffer[0] if negative.
    v87 = std loadSlot 7
    v88 = std constI64 0
    v89 = std cmpI64Eq v87 v88
    std condBr v89 check_prec_zero write_minus

  block write_minus:
    v90 = std loadSlot 1
    v91 = std constI64 0
    v92 = std constI64 0x2D
    std storeByte v90 v91 v92
    std br check_prec_zero

  block check_prec_zero:
    // If precision == 0, skip writing '.' and fractional digits.
    v93 = std loadSlot 5
    v94 = std constI64 0
    v95 = std cmpI64Eq v93 v94
    std condBr v95 apply_width write_dot

  block write_dot:
    // Write '.' at buffer[content_len], then compute frac digits.
    v96 = std loadSlot 1
    v97 = std loadSlot 10
    v98 = std constI64 0x2E
    std storeByte v96 v97 v98
    // content_len += 1
    v99 = std loadSlot 10
    v100 = std constI64 1
    v101 = std addI64 v99 v100
    std storeSlot 10 v101
    // frac_accum = abs_val - int_part; multiply by 10 precision times,
    // then add 0.5 and truncate.
    v102 = std loadSlot 8
    v103 = std loadSlot 9
    v104 = std siToFpF64 v103
    v105 = std subF64 v102 v104
    std storeSlot 14 v105
    v106 = std constI64 0
    std storeSlot 13 v106
    std br mul_loop_real

  block mul_loop_real:
    v120 = std loadSlot 13
    v121 = std loadSlot 5
    v122 = std cmpI64Ge v120 v121
    std condBr v122 mul_done mul_step_real

  block mul_step_real:
    v123 = std loadSlot 14
    v124 = std constF64 0x4024000000000000
    v125 = std mulF64 v123 v124
    std storeSlot 14 v125
    v126 = std loadSlot 13
    v127 = std constI64 1
    v128 = std addI64 v126 v127
    std storeSlot 13 v128
    std br mul_loop_real

  block mul_done:
    v129 = std loadSlot 14
    v130 = std constF64 0x3fe0000000000000
    v131 = std addF64 v129 v130
    v132 = std fpToSiI64 v131
    std storeSlot 12 v132
    // Write the frac digits starting at buffer[content_len], padded to
    // precision digits.
    v133 = std loadSlot 5
    v134 = std constI64 1
    v135 = std subI64 v133 v134
    std storeSlot 13 v135
    std br frac_write_loop

  block frac_write_loop:
    v136 = std loadSlot 13
    v137 = std constI64 0
    v138 = std cmpI64Lt v136 v137
    std condBr v138 frac_done frac_write_one

  block frac_write_one:
    v139 = std loadSlot 12
    v140 = std constI64 10
    v141 = std remI64 v139 v140
    v142 = std divI64 v139 v140
    std storeSlot 12 v142
    v143 = std constI64 0x30
    v144 = std addI64 v141 v143
    v145 = std loadSlot 1
    v146 = std loadSlot 10
    v147 = std loadSlot 13
    v148 = std addI64 v146 v147
    std storeByte v145 v148 v144
    v149 = std loadSlot 13
    v150 = std constI64 1
    v151 = std subI64 v149 v150
    std storeSlot 13 v151
    std br frac_write_loop

  block frac_done:
    v152 = std loadSlot 10
    v153 = std loadSlot 5
    v154 = std addI64 v152 v153
    std storeSlot 10 v154
    std br apply_width

  block apply_width:
    // pad_count = width - content_len; if <= 0, return content_len.
    v155 = std loadSlot 4
    v156 = std loadSlot 10
    v157 = std subI64 v155 v156
    v158 = std constI64 0
    v159 = std cmpI64Le v157 v158
    std condBr v159 no_pad do_pad

  block no_pad:
    v160 = std loadSlot 10
    std ret v160

  block do_pad:
    std storeSlot 11 v157
    // Shift bytes right by pad_count (work backwards from end).
    // dst_end = buffer + width - 1; src_end = buffer + content_len - 1;
    // copy content_len bytes downward.
    // Use slot 13 as the loop counter from 0..content_len.
    v161 = std constI64 0
    std storeSlot 13 v161
    std br shift_loop

  block shift_loop:
    v162 = std loadSlot 13
    v163 = std loadSlot 10
    v164 = std cmpI64Ge v162 v163
    std condBr v164 fill_pad shift_one

  block shift_one:
    // src_pos = content_len - 1 - i
    // dst_pos = width - 1 - i
    v165 = std loadSlot 10
    v166 = std constI64 1
    v167 = std subI64 v165 v166
    v168 = std subI64 v167 v162
    v169 = std loadSlot 1
    v170 = std loadByte v169 v168
    v171 = std loadSlot 4
    v172 = std subI64 v171 v166
    v173 = std subI64 v172 v162
    std storeByte v169 v173 v170
    v174 = std addI64 v162 v166
    std storeSlot 13 v174
    std br shift_loop

  block fill_pad:
    // Fill buffer[0..pad_count] with ' '.
    v175 = std constI64 0
    std storeSlot 13 v175
    std br fill_pad_loop

  block fill_pad_loop:
    v176 = std loadSlot 13
    v177 = std loadSlot 11
    v178 = std cmpI64Ge v176 v177
    std condBr v178 padded_done fill_pad_one

  block fill_pad_one:
    v179 = std loadSlot 1
    v180 = std constI64 0x20
    std storeByte v179 v176 v180
    v181 = std loadSlot 13
    v182 = std constI64 1
    v183 = std addI64 v181 v182
    std storeSlot 13 v183
    std br fill_pad_loop

  block padded_done:
    v184 = std loadSlot 4
    std ret v184

end

// mrt_write_cstr_stderr(ptr): scans for null terminator, then writes to stderr.
func mrt_write_cstr_stderr 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    std storeSlot 1 v1
    std br scan

  block scan:
    v2 = std loadSlot 0
    v3 = std loadSlot 1
    v4 = std loadByte v2 v3
    v5 = std constI64 0
    v6 = std cmpI64Eq v4 v5
    std condBr v6 write scan_next

  block scan_next:
    v7 = std loadSlot 1
    v8 = std constI64 1
    v9 = std addI64 v7 v8
    std storeSlot 1 v9
    std br scan

  block write:
    v10 = std loadSlot 0
    v11 = std loadSlot 1
    v12 = std call mrt_write_stderr v10 v11
    v13 = std constI64 0
    std ret v13

end

// mm_trace_print_tag(cstr_ptr): write a NUL-terminated async-trace tag string
// (e.g. "spawn #") to stderr. Thin delegator used by the green-thread
// scheduler's AsyncTrace emission; mirrors the C# bootstrap's mm_trace_print_tag.
func mm_trace_print_tag 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std call mrt_write_cstr_stderr v0
    v2 = std constI64 0
    std ret v2

end

// mm_trace_print_i64(value): write `value` in decimal to stderr. Uses a stack
// scratch buffer addressed at slot 4 — mrt_i64_to_string writes its digits
// FORWARD (increasing address), so slots 4..2 (24 bytes) hold the up-to-21-byte
// rendering without reaching the saved RBP — then writes exactly the returned
// length. Mirrors the C# bootstrap's mm_trace_print_i64.
func mm_trace_print_i64 1 void
  block entry:
    v0 = std param 0 i64
    v1 = std stackAddr 4
    v2 = std call mrt_i64_to_string v0 v1
    v3 = std stackAddr 4
    v4 = std call mrt_write_stderr v3 v2
    v5 = std constI64 0
    std ret v5

end

// mm_trace_print_hex(value): write `value` as "0x" + 16 zero-padded lowercase
// hex digits to stderr. Used by the CPU-fault diagnostic (emitX64GtFaultDiagnostic)
// to render the faulting RIP / bad VA in a form an operator can resolve against
// `llvm-objdump -d`. Fixed 18-byte rendering into a stack scratch buffer.
//
// Nibbles are extracted from the LOW end (mask the low 4 bits, then `shrsi 4`)
// and written right-to-left into buf[17] down to buf[2], so the arithmetic
// (sign-smearing) right shift is harmless — each masked nibble is consumed before
// the smeared high bits can reach it across the exactly-16 iterations.
//
// Slot usage: slot 0 = value, slot 1 = loop index i (0..15), slot 2 = buf base.
func mm_trace_print_hex 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    // buf = &scratch (stackAddr 10 keeps the 18-byte buffer clear of slots 0..2).
    v1 = std stackAddr 10
    std storeSlot 2 v1
    // buf[0] = '0', buf[1] = 'x'
    v2 = std constI64 0
    v3 = std constI64 0x30
    std storeByte v1 v2 v3
    v4 = std constI64 1
    v5 = std constI64 0x78
    std storeByte v1 v4 v5
    // i = 0
    v6 = std constI64 0
    std storeSlot 1 v6
    std br digit_loop

  block digit_loop:
    v7 = std loadSlot 1
    v8 = std constI64 16
    v9 = std cmpI64Lt v7 v8
    std condBr v9 digit_body write_phase

  block digit_body:
    // nibble = value & 0xF
    v10 = std loadSlot 0
    v11 = std constI64 0xF
    v12 = std andI64 v10 v11
    // value = value shrsi 4
    v13 = std constI64 4
    v14 = std shrI64 v10 v13
    std storeSlot 0 v14
    // char = nibble < 10 ? '0'+nibble : 'a'+(nibble-10) = 0x57+nibble
    v15 = std constI64 10
    v16 = std cmpI64Lt v12 v15
    std condBr v16 digit_dec digit_alpha

  block digit_dec:
    v17 = std constI64 0x30
    v18 = std addI64 v12 v17
    std storeSlot 3 v18
    std br digit_store

  block digit_alpha:
    v19 = std constI64 0x57
    v20 = std addI64 v12 v19
    std storeSlot 3 v20
    std br digit_store

  block digit_store:
    // pos = 17 - i
    v21 = std loadSlot 1
    v22 = std constI64 17
    v23 = std subI64 v22 v21
    v24 = std loadSlot 2
    v25 = std loadSlot 3
    std storeByte v24 v23 v25
    // i++
    v26 = std constI64 1
    v27 = std addI64 v21 v26
    std storeSlot 1 v27
    std br digit_loop

  block write_phase:
    v28 = std loadSlot 2
    v29 = std constI64 18
    v30 = std call mrt_write_stderr v28 v29
    v31 = std constI64 0
    std ret v31

end

// maxon_force_segfault(): deliberately read through address 0 to trigger a CPU
// access-violation fault (STATUS_ACCESS_VIOLATION on Windows / SIGSEGV on POSIX /
// an out-of-bounds linear-memory trap on wasm). Exercises the VEH fault-recovery
// path on x64-Windows (clean `panic: nil pointer or invalid memory access` + exit 1)
// and backs `__Builtins.forceSegfault()` / the `safety` spec. The load always
// faults, so the `ret` is unreachable. Mirrors the C# bootstrap's hand-rolled
// EmitMaxonForceSegfault; expressed here as portable Std IR so every target gets it.
func maxon_force_segfault 0 void
  block entry:
    v0 = std constI64 0
    v1 = std loadIndirect v0 0
    v2 = std constI64 0
    std ret v2

end

// mrt_panic(msg_ptr): prints panic message + stack trace to stderr, then exits.
// Walks the RBP/X29 chain to print up to 32 stack frames.
//
// Slot usage:
//   slot 0 = msg_ptr (arg)
//   slot 1 = text_base (mrt_start address)
//   slot 2 = symtable_ptr
//   slot 3 = frame_ptr (current frame being walked)
//   slot 4 = frame_counter
func mrt_panic 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // Print panic message to stderr
    v1 = std call mrt_write_cstr_stderr v0

    // Print "Stack trace:\n"
    v2 = std globalAddr __panic_stacktrace
    v3 = std call mrt_write_cstr_stderr v2

    // Get text_base and symtable for frame lookup
    v4 = std funcAddr mrt_start
    std storeSlot 1 v4
    v5 = std funcAddr __symtable
    std storeSlot 2 v5

    // Walk the frame chain starting from our caller
    v6 = std loadFramePtr
    std storeSlot 3 v6

    // frame_counter = 32
    v13 = std constI64 32
    std storeSlot 4 v13
    std br walk_loop

  block walk_loop:
    // Check frame counter
    v14 = std loadSlot 4
    v15 = std constI64 0
    v16 = std cmpI64Eq v14 v15
    std condBr v16 walk_done check_frame_ptr

  block check_frame_ptr:
    // Decrement counter
    v17 = std loadSlot 4
    v18 = std constI64 1
    v19 = std subI64 v17 v18
    std storeSlot 4 v19

    // Load current frame_ptr
    v20 = std loadSlot 3
    v21 = std constI64 0
    v22 = std cmpI64Eq v20 v21
    std condBr v22 walk_done get_return_addr

  block get_return_addr:
    // Get return address: [frame_ptr + 8]
    v23 = std loadSlot 3
    v24 = std loadIndirect v23 8
    std storeSlot 6 v24
    v25 = std constI64 0
    v26 = std cmpI64Eq v24 v25
    std condBr v26 walk_done compute_offset

  block compute_offset:
    // Compute text_offset = return_addr - text_base
    v52 = std loadSlot 6
    v27 = std loadSlot 1
    v28 = std subI64 v52 v27
    std storeSlot 5 v28

    // Check if outside .text (negative or beyond code end)
    v29 = std constI64 0
    v30 = std cmpI64Lt v28 v29
    std condBr v30 walk_done check_upper_bound

  block check_upper_bound:
    v53 = std loadSlot 5
    v54 = std loadSlot 2
    v55 = std loadSlot 1
    v56 = std subI64 v54 v55
    v57 = std cmpI64Lt v53 v56
    std condBr v57 print_frame walk_done

  block print_frame:
    // Print this frame
    v51 = std loadSlot 5
    v31 = std loadSlot 2
    v32 = std call mrt_panic_print_frame v51 v31

    // Advance frame_ptr to next frame: [frame_ptr] = prev frame pointer
    v33 = std loadSlot 3
    v34 = std loadIndirect v33 0
    std storeSlot 3 v34
    std br walk_loop

  block walk_done:
    v35 = std constI64 1
    std osExit v35
    v36 = std constI64 0
    std ret v36

end

// mrt_panic_print_frame(text_offset, symtable_ptr):
// Looks up text_offset in the symbol table and prints "  in <funcName>\n".
//
// Symbol table format: count(i32) | entries[count] of {codeOffset(i32), nameOffset(i32)} | name strings
// Finds the largest codeOffset <= text_offset (best match).
//
// Slot usage:
//   slot 0 = text_offset (arg)
//   slot 1 = symtable_ptr (arg)
//   slot 2 = count (from symtable header)
//   slot 3 = loop index
//   slot 4 = best_name_offset (-1 = not found)
//   slot 5 = entry_ptr (current entry address)
func mrt_panic_print_frame 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // Print "  in "
    v2 = std globalAddr __panic_in
    v3 = std call mrt_write_cstr_stderr v2

    // Load count from symtable header (first 4 bytes as i32)
    // Load 8 bytes and mask to lower 32 bits
    v4 = std loadIndirect v1 0
    v5 = std constI64 0xFFFFFFFF
    v6 = std andI64 v4 v5
    std storeSlot 2 v6

    // Initialize loop: index = 0, best_name_offset = -1
    v7 = std constI64 0
    std storeSlot 3 v7
    v8 = std constI64 -1
    std storeSlot 4 v8
    std br lookup_loop

  block lookup_loop:
    // Check index < count
    v9 = std loadSlot 3
    v10 = std loadSlot 2
    v11 = std cmpI64Lt v9 v10
    std condBr v11 lookup_body lookup_done

  block lookup_body:
    // entry_ptr = symtable_ptr + 4 + index * 8
    v12 = std loadSlot 1
    v13 = std constI64 4
    v14 = std addI64 v12 v13
    v15 = std loadSlot 3
    v16 = std constI64 8
    v17 = std mulI64 v15 v16
    v18 = std addI64 v14 v17
    std storeSlot 5 v18

    // Load entry codeOffset (i32 at [entry_ptr + 0])
    v19 = std loadIndirect v18 0
    v20 = std constI64 0xFFFFFFFF
    v21 = std andI64 v19 v20

    // Check if text_offset >= codeOffset
    v22 = std loadSlot 0
    v23 = std cmpI64Lt v22 v21
    std condBr v23 lookup_next lookup_update

  block lookup_update:
    // Update best: load nameOffset (i32 at [entry_ptr + 4])
    v24 = std loadSlot 5
    v25 = std constI64 4
    v26 = std addI64 v24 v25
    v27 = std loadIndirect v26 0
    v28 = std constI64 0xFFFFFFFF
    v29 = std andI64 v27 v28
    std storeSlot 4 v29
    std br lookup_next

  block lookup_next:
    // index++
    v30 = std loadSlot 3
    v31 = std constI64 1
    v32 = std addI64 v30 v31
    std storeSlot 3 v32
    std br lookup_loop

  block lookup_done:
    // Check if found
    v33 = std loadSlot 4
    v34 = std constI64 -1
    v35 = std cmpI64Eq v33 v34
    std condBr v35 print_unknown print_name

  block print_name:
    // name_ptr = symtable_ptr + best_name_offset
    v36 = std loadSlot 1
    v37 = std loadSlot 4
    v38 = std addI64 v36 v37
    v39 = std call mrt_write_cstr_stderr v38
    std br print_newline

  block print_unknown:
    v40 = std globalAddr __panic_unknown
    v41 = std call mrt_write_cstr_stderr v40
    std br print_newline

  block print_newline:
    v42 = std globalAddr __panic_newline
    v43 = std call mrt_write_cstr_stderr v42
    v44 = std constI64 0
    std ret v44

end

// mrt_alloc(size): thin wrapper around mm_alloc with no destructor and no
// tag. Every allocation goes through the unified tracked path: the
// returned pointer carries a 24-byte mm header and refcount=1. Callers
// that drop their reference must call mm_decref; callers that don't are
// effectively leaking under __mm_alloc_count.
func mrt_memzero 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std constI64 0
    std storeSlot 2 v2
    std br loop

  block loop:
    v3 = std loadSlot 2
    v4 = std loadSlot 1
    v5 = std cmpI64Lt v3 v4
    std condBr v5 body done

  block body:
    v6 = std loadSlot 0
    v7 = std loadSlot 2
    v8 = std addI64 v6 v7
    v9 = std constI64 0
    v13 = std constI64 0
    std storeByte v8 v9 v13
    v10 = std loadSlot 2
    v11 = std constI64 1
    v12 = std addI64 v10 v11
    std storeSlot 2 v12
    std br loop

  block done:
    v14 = std constI64 0
    std ret v14
end

func mrt_alloc 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    // tag = MM_TAG_RAW (1): a raw, deliberately-typeless block. Non-zero so the
    // strict mm-trace null-tag panic distinguishes this from a forgotten type tag.
    v2 = std constI64 1
    v3 = std call __mm_alloc v0 v1 v2
    std storeSlot 1 v3
    // alloc-at-0 → restore the rc=1 contract this raw-buffer wrapper promises.
    v4 = std call __mm_incref v3
    // Zero the buffer (matches the C# `mm_raw_alloc`, which zero-fills every raw
    // allocation). A reused slab slot holds the previous occupant's bytes; a
    // sparsely-filled container buffer (a Map/Set hash table) leaves unwritten
    // slots holding that garbage, and the container's element-walk would then
    // decref the junk as a live pointer → fault. Zero-init makes unoccupied slots
    // read null so the walk's `if slot != 0` guard skips them.
    v5 = std loadSlot 1
    v6 = std loadSlot 0
    std call mrt_memzero v5 v6
    std ret v3
end

// mrt_alloc_with_dtor(size, destructor) -> rc=1 tracked block carrying
// `destructor`. The alloc-at-0 equivalent of the retired `mm_alloc(size, dtor,
// 0)`: `__mm_alloc` returns rc=0, so incref to the rc=1 contract the caller
// (e.g. the hand-emitted `__ManagedSocket` / `__ManagedFile` wrappers in the
// backends) expects. No zero-fill — the caller fully initializes the fixed-size
// wrapper struct it allocates.
func mrt_alloc_with_dtor 2 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    // tag = MM_TAG_RAW (1): the wrapper is type-agnostic (used by various fixed-size
    // managed wrappers — __ManagedMemory records, cursors, socket/file handles). A
    // non-zero sentinel keeps it out of the null-tag panic; callers that want a
    // precise type name in the trace tag at their own `__mm_alloc` site instead.
    v2 = std constI64 1
    v3 = std call __mm_alloc v0 v1 v2
    v4 = std call __mm_incref v3
    std ret v3
end

// mrt_cstr_from_mm(path __ManagedMemory*) -> __ManagedMemory ptr
// holding the UTF-8 bytes of `path[0..pathLen]` followed by a NUL byte.
// Caller must mm_decref the returned pointer.
//
// Layout reminder: a __ManagedMemory header is 40 bytes (see
// __managed_mem_create); the user-visible payload is at header offset 0
// (`buffer` field). mrt_alloc returns the user pointer directly (no
// header dereferencing needed by the syscall).
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = src buf ptr (path[0])
//   slot 2 = src len     (path[8])
//   slot 3 = dst buf (mrt_alloc result, returned)
//   slot 4 = loop index
func mrt_cstr_from_mm 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std loadIndirect v0 0
    std storeSlot 1 v1
    v2 = std loadIndirect v0 8
    std storeSlot 2 v2

    // allocSize = pathLen + 1 (for the NUL byte).
    v3 = std loadSlot 2
    v4 = std constI64 1
    v5 = std addI64 v3 v4
    v6 = std call mrt_alloc v5
    std storeSlot 3 v6

    // memcpy(dst, src, pathLen).
    v7 = std loadSlot 3
    v8 = std loadSlot 1
    v9 = std loadSlot 2
    std memcpy v7 v8 v9

    // dst[pathLen] = 0  (NUL terminator).
    v10 = std loadSlot 3
    v11 = std loadSlot 2
    v12 = std addI64 v10 v11
    v13 = std constI64 0
    std storeByte v12 v13 v13

    v14 = std loadSlot 3
    std ret v14
end

// mrt_select_io_error_flag(syscallResult, catchAll) -> 1-indexed
// error flag value. Mirrors mrt_win32_select_io_error_flag's contract:
// returns ordinal+1 (not the raw ordinal). Linux negative results encode
// -errno; map ENOENT (2) → notFound (ordinal 0 → flag 1), EACCES (13) →
// accessDenied (ordinal 1 → flag 2). Anything else → caller-supplied
// catchAll (already shifted +1).
//
// Slot usage:
//   slot 0 = syscallResult (negative on failure)
//   slot 1 = catchAll
//   slot 2 = errno (= -syscallResult)
func mrt_select_io_error_flag 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // errno = -syscallResult.
    v2 = std loadSlot 0
    v3 = std constI64 0
    v4 = std subI64 v3 v2
    std storeSlot 2 v4

    // Check ENOENT = 2.
    v5 = std loadSlot 2
    v6 = std constI64 2
    v7 = std cmpI64Eq v5 v6
    std condBr v7 not_found check_eacces

  block not_found:
    v8 = std constI64 1
    std ret v8

  block check_eacces:
    v9 = std loadSlot 2
    v10 = std constI64 13
    v11 = std cmpI64Eq v9 v10
    std condBr v11 access_denied catch_all

  block access_denied:
    v12 = std constI64 2
    std ret v12

  block catch_all:
    v13 = std loadSlot 1
    std ret v13
end


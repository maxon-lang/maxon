//   st_mtim.tv_sec @ 88, st_ctim.tv_sec @ 104.
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = cstr ptr
//   slot 2 = linux stat buf ptr (144 bytes)
//   slot 3 = stat result
//   slot 4 = output mm buf (48 bytes)
//   slot 5 = mode

    v25 = std loadIndirect v24 24
    v26 = std constI64 0xFFFFFFFF
    v27 = std andI64 v25 v26
    v28 = std constI64 61440
    v29 = std andI64 v27 v28
    v30 = std constI64 16384
    v31 = std cmpI64Eq v29 v30
    std condBr v31 is_dir is_file

  block is_dir:
    v32 = std loadSlot 3
    v33 = std call mm_decref v32
    v34 = std constI64 0
    std ret v34

  block is_file:
    v35 = std loadSlot 3
    v36 = std call mm_decref v35
    v37 = std constI64 1
    std ret v37

  block ok:
    v6 = std constI64 0
    std errorReturn v2 v6
end

// mrt_managed_list_cursor_advance(list): cursor = cursor.next; error-flag
// when the new cursor is null (end of list).
func mrt_managed_list_cursor_advance 1 i64
  block entry:

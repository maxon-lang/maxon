    v19 = std call mrt_alloc v18
    std storeSlot 4 v19

    // size (st_size @ 48).
    v20 = std loadSlot 2
    v21 = std loadIndirect v20 48
    v22 = std loadSlot 4
    std storeIndirect v22 0 v21

    // mtime (st_mtim.tv_sec @ 88).
    v23 = std loadIndirect v20 88
    std storeIndirect v22 8 v23

    // ctime (st_ctim.tv_sec @ 104).
    v24 = std loadIndirect v20 104
    std storeIndirect v22 16 v24

    // atime (st_atim.tv_sec @ 72).
    v25 = std loadIndirect v20 72
    std storeIndirect v22 24 v25

    // isDirectory: (st_mode & S_IFMT) == S_IFDIR (0o040000 = 16384).

    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // errno = -syscallResult.
    v2 = std loadSlot 0
    v3 = std constI64 0
    v4 = std subI64 v3 v2
    std storeSlot 2 v4

    // Check ENOENT = 2.
    v5 = std loadSlot 2
    v6 = std constI64 2
    v7 = std cmpI64Eq v5 v6
    std condBr v7 not_found check_eacces

  block not_found:
    v8 = std constI64 1
    std ret v8

  block check_eacces:
    v9 = std loadSlot 2
    v10 = std constI64 13
    v11 = std cmpI64Eq v9 v10
    std condBr v11 access_denied catch_all

  block access_denied:
    v12 = std constI64 2
    std ret v12

  block catch_all:
    v13 = std loadSlot 1
    std ret v13
end


    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // old_head = list.head
    v2 = std loadIndirect v0 0
    std storeSlot 2 v2

    // node.next = old_head; node.prev = 0; node.list = list_ptr

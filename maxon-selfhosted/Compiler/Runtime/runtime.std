//                        stderrKind, stderrData, stderrLimit,
//                        flags) — 14 args, returns handle or -1.
// Stub returns -1; caller throws SubprocessError.spawnFailed.
func maxon_subprocess_spawn 14 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std param 3 i64
    v4 = std param 4 i64
    v5 = std param 5 i64
    v6 = std param 6 i64
    v7 = std param 7 i64
    v8 = std param 8 i64
    v9 = std param 9 i64
    v10 = std param 10 i64
    v11 = std param 11 i64
    v12 = std param 12 i64
    v13 = std param 13 i64
    v14 = std constI64 -1
    std ret v14
end

// maxon_subprocess_detach — same 14-arg shape as spawn, returns pid (or -1).
func maxon_subprocess_detach 14 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std param 3 i64
    v4 = std param 4 i64
    v5 = std param 5 i64

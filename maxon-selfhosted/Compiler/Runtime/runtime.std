    v13 = std call mm_decref v12
    v14 = std loadSlot 3
    v15 = std constI64 1
    v16 = std call mrt_select_io_error_flag v14 v15
    v17 = std constI64 0
    std errorReturn v17 v16

  block ok:
    // Allocate 48-byte output buffer.

    v23 = std constI64 1
    v24 = std addI64 v22 v23
    v25 = std loadSlot 3
    v26 = std mulI64 v24 v25
    std storeSlot 6 v26
    v27 = std loadSlot 5
    v28 = std mulI64 v27 v25
    std storeSlot 7 v28
    std br shift_loop


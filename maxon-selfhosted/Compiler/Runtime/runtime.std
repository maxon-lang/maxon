// mrt_file_stat(path) throws -> __ManagedMemory ptr (48-byte buffer).
// Layout: [size@0, mtime@8, ctime@16, atime@24, isDirectory@32, isReadOnly@40].
// Linux x86_64 struct stat (144 bytes) fields used:
//   st_mode @ 24, st_size @ 48, st_atim.tv_sec @ 72,
//   st_mtim.tv_sec @ 88, st_ctim.tv_sec @ 104.
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = cstr ptr
//   slot 2 = linux stat buf ptr (144 bytes)
//   slot 3 = stat result
//   slot 4 = output mm buf (48 bytes)
//   slot 5 = mode
func mrt_file_stat 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call mrt_cstr_from_mm v0
    std storeSlot 1 v1

    // Allocate Linux stat buffer.
    v2 = std constI64 144
    v3 = std call mrt_alloc v2
    std storeSlot 2 v3

    // stat(cstr, statbuf).

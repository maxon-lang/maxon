    v11 = std loadSlot 0
    v12 = std loadIndirect v11 0
    v13 = std call mm_realloc v12 v10
    std storeSlot 2 v13
    // self.buffer = newBuf; self.capacity = newCap
    v14 = std loadSlot 0
    v15 = std loadSlot 2
    std storeIndirect v14 0 v15
    v16 = std loadSlot 0
    v17 = std loadSlot 1
    std storeIndirect v16 16 v17
    v18 = std constI64 0
    v19 = std constI64 0
    std errorReturn v18 v19
end


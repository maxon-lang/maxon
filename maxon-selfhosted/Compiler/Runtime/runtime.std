// Slot usage:
//   slot 0 = idx (arg)
func __slab_class_size 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 c0 t1

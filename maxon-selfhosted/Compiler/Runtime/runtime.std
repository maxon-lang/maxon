    v9 = std constI64 1
    v10 = std call mrt_select_io_error_flag v8 v9
    v11 = std constI64 0
    std errorReturn v11 v10

  block ok:
    // Restore cursor: lseek(fd, 0, SEEK_SET=0). Ignore result.
    v12 = std loadSlot 0
    v13 = std constI64 0
    v14 = std constI64 0
    v15 = std osFileLseek v12 v13 v14

    v16 = std loadSlot 1
    v17 = std constI64 0
    std errorReturn v16 v17
end

// mrt_directory_open_search(pattern) throws -> __ManagedDirectory ptr.
// On Linux directory enumeration uses opendir/readdir-equivalent (open +
// getdents64). We allocate a 40-byte handle block:
//   [0..8]   = fd (-1 on failure)
//   [8..16]  = dirent buffer ptr (mrt_alloc'd, freed in close)
//   [16..24] = total bytes filled by last getdents64 call
//   [24..32] = current cursor into dirent buffer
//   [32..40] = filename ptr from the dirent at current cursor
//
// The pattern is treated as a directory path (Linux has no glob in the
// kernel; the C# bootstrap also only ever passes a directory path).
//
// Slot usage:
//   slot 0 = pattern *
//   slot 1 = cstr ptr (NUL-terminated dir path)
//   slot 2 = fd from open
//   slot 3 = dirent buffer ptr (4096 bytes)
//   slot 4 = block ptr (40 bytes)
func mrt_directory_open_search 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call mrt_cstr_from_mm v0
    std storeSlot 1 v1

    // open(path, O_RDONLY|O_DIRECTORY = 0|65536 = 65536).
    v2 = std loadSlot 1
    v3 = std constI64 65536
    v4 = std constI64 0
    v5 = std osFileOpen v2 v3 v4
    std storeSlot 2 v5

    // Free cstr.
    v6 = std loadSlot 1
    v7 = std call mm_decref v6

    v8 = std loadSlot 2
    v9 = std constI64 0
    v10 = std cmpI64Lt v8 v9
    std condBr v10 fail success

  block fail:
    // DirectoryOpenSearchError ordinal 2 → wire 3 (matches Windows stub).
    v11 = std loadSlot 2
    v12 = std constI64 3
    v13 = std call mrt_select_io_error_flag v11 v12
    v14 = std constI64 0
    std errorReturn v14 v13

  block success:
    // Allocate 4096-byte dirent buffer.
    v15 = std constI64 4096
    v16 = std call mrt_alloc v15
    std storeSlot 3 v16

    // Allocate the 40-byte handle block WITH the search-handle destructor so
    // an owner-drop closes the fd / frees the dirent even when the user never
    // called close() (close() stamps the -1/0 sentinels making it idempotent).
    v17 = std constI64 40
    v26 = std funcAddr __destruct___ManagedDirectory
    v18 = std call mrt_alloc_with_dtor v17 v26
    std storeSlot 4 v18

    // Init block fields.
    v19 = std loadSlot 4
    v20 = std loadSlot 2
    std storeIndirect v19 0 v20
    v21 = std loadSlot 3
    std storeIndirect v19 8 v21
    v22 = std constI64 0
    std storeIndirect v19 16 v22
    std storeIndirect v19 24 v22
    std storeIndirect v19 32 v22

    v23 = std loadSlot 4
    // Pre-load the first real directory entry into block[32] so `filename()`
    // returns it before the first `next()` call. This makes the builtin obey
    // the filename-first iteration contract that stdlib `Directory.list`, the
    // `managed-directory` spec, and the C# bootstrap all assume (without it the
    // initial `filename()` is empty and gets miscounted as a real entry).
    // `mrt_directory_next` only mutates the handle block and always reports a
    // zero error flag, so this call is purely for its side effect. An empty
    // directory leaves block[32] = 0 (an empty name), identical to reaching
    // end-of-iteration.
    v25 = std call mrt_directory_next v23
    v24 = std constI64 0
    std errorReturn v23 v24
end

// mrt_directory_create(path) throws -> 0. Linux mkdir(path, 0755).
func mrt_directory_create 1 i64
  block entry:
    v0 = std param 0 i64

// =====================================================================
// Phase D: __ManagedSocket runtime helpers (mrt_managed_socket_*)
// =====================================================================
//
// These helpers wrap the OS-level socket APIs used by stdlib/TcpClient.maxon:
//   • Windows: Winsock (WSAStartup + ConnectEx/WSASend/WSARecv via IOCP)
//   • Linux / macOS: BSD sockets (socket/connect/send/recv/close)
//   • WASI: not supported (TcpClient.maxon is `#if os(Wasi)`-gated out)
//
// The self-hosted compiler does NOT yet have an `osNetSocket` /
// `osNetConnect` / etc. StdSystemOp family, nor the IOCP/green-thread
// integration the C# bootstrap uses on Windows. Implementing those is a
// significant cross-target effort (every new StdSystemOp needs lowering in
// X64, ARM64, and Wasm backends, plus runtime threading machinery on
// Windows). For now these helpers ship as well-defined sentinel-erroring
// stubs: any actual call returns an error code mapping to the closest
// `__ManagedSocketError` variant, with the success path never taken. This
// matches the "Stream 2.3 sentinel-erroring stubs" pattern used for the
// file/directory helpers when they were first wired before the real
// per-target syscall lowerings landed (see mrt_file_open_read header).
//
// Whitelisting stdlib/TcpClient.maxon needs these symbols to exist so the
// stdlib cache builds and links; tcp-client spec tests are NOT on the
// self-hosted whitelist yet (see Testing/SpecTestRunner.maxon), so the
// stubs' runtime behavior doesn't affect the 1615/1615 baseline. Stream X
// (future) replaces each stub body with the real per-target implementation.
//
// __ManagedSocketError ordinals (must match registerManagedSocketErrorEnum
// in LowerMaxonToStd.maxon and stdlib/Builtins.maxon):
//   0 bufferOutOfBounds  -> flag 1
//   1 resolveFailed      -> flag 2
//   2 connectFailed      -> flag 3
//   3 sendFailed         -> flag 4
//   4 recvFailed         -> flag 5
//   5 connectionClosed   -> flag 6
//   6 closed             -> flag 7
//
// =====================================================================

// mrt_managed_socket_tcp_connect(host_mm, port) throws -> ptr to fresh
// __ManagedSocket. Currently returns resolveFailed (flag 2) sentinel —
// the real per-target implementations will replace this body.
func mrt_managed_socket_tcp_connect 2 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    // Sentinel: report __ManagedSocketError.resolveFailed (ordinal 1 → flag 2)
    // until a real DNS+socket+connect path lands. The result slot returns 0
    // (caller never reads it on the error path).
    v2 = std constI64 0
    v3 = std constI64 2
    std errorReturn v2 v3
end

// mrt_managed_socket_send(self, managed, offset, length) throws -> bytes
// sent. Currently returns sendFailed (flag 4) sentinel. Real impl will
// pre-check offset+length against managed.capacity() (bufferOutOfBounds
// → flag 1), then call send(2) / WSASend.
func mrt_managed_socket_send 4 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    v2 = std param 2 i64
    v3 = std param 3 i64
    // Sentinel: report __ManagedSocketError.sendFailed (ordinal 3 → flag 4).
    v4 = std constI64 0
    v5 = std constI64 4
    std errorReturn v4 v5
end

// mrt_managed_socket_recv(self, managed) throws -> bytes received.
// Currently returns recvFailed (flag 5) sentinel. Real impl will call
// recv(2) / WSARecv on the socket handle into managed.buffer up to
// managed.capacity bytes.
func mrt_managed_socket_recv 2 i64
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    // Sentinel: report __ManagedSocketError.recvFailed (ordinal 4 → flag 5).
    v2 = std constI64 0
    v3 = std constI64 5
    std errorReturn v2 v3
end

// mrt_managed_socket_close(self) -> void. Idempotent: zeroes the _handle
// field so the destructor's call doesn't double-close. The stub body
// performs the field-zero (which is the user-visible state change); the
// real implementation will additionally call closesocket / close(2) on
// the OS handle before zeroing it.
func mrt_managed_socket_close 1 void
  block entry:
    v0 = std param 0 i64
    // self._handle = 0
    v1 = std constI64 0
    std storeIndirect v0 0 v1
    v2 = std constI64 0
    std ret v2
end

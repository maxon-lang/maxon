    std storeSlot 5 v4
    // if idx < length -> ok else -> err
    v5 = std loadSlot 1
    v6 = std loadSlot 5
    v7 = std cmpI64Lt v5 v6
    std condBr v7 ok err

  block err:
    v8 = std constI64 1
    v9 = std constI64 0
    std errorReturn v9 v8

  block ok:

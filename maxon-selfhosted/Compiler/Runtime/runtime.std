// mrt_managed_list_clear(list): unlinks and frees every node, dropping each
// node's value first when the list's `elem_managed` flag is set (the node owns
// the +1 the insert helper moved in).
//
// Slot usage:
//   slot 0 = list_ptr (arg)
//   slot 1 = current  (walk pointer)
//   slot 2 = next     (preserved before current is freed)
func mrt_managed_list_clear 1 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std loadIndirect v0 0
    std storeSlot 1 v1
    std br loop

  block loop:
    v2 = std loadSlot 1
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 done body

  block body:
    // Save next.
    v5 = std loadSlot 1
    v6 = std loadIndirect v5 0
    std storeSlot 2 v6
    // Drop the node's value when the element type is heap-managed.
    v20 = std loadSlot 0
    v21 = std loadIndirect v20 32
    v22 = std constI64 0
    v23 = std cmpI64Eq v21 v22
    std condBr v23 clear_links drop_value

  block drop_value:
    v24 = std loadSlot 1
    v25 = std loadIndirect v24 24
    v26 = std constI64 0
    v27 = std cmpI64Eq v25 v26
    std condBr v27 clear_links do_value_decref

  block do_value_decref:
    v28 = std loadSlot 1
    v29 = std loadIndirect v28 24
    v30 = std call __mm_decref v29
    std br clear_links

  block clear_links:
    // Clear node links so a stray pointer sees a detached node.
    v7 = std loadSlot 1
    v31 = std constI64 0
    std storeIndirect v7 0 v31
    std storeIndirect v7 8 v31
    std storeIndirect v7 16 v31

    // Drop the list's owned reference.
    v8 = std call mm_decref v7

    // current = next
    v9 = std loadSlot 2
    std storeSlot 1 v9
    std br loop

  block done:
    // Zero head/tail/count/cursor.
    v10 = std loadSlot 0
    v11 = std constI64 0
    std storeIndirect v10 0 v11
    std storeIndirect v10 8 v11
    std storeIndirect v10 16 v11
    std storeIndirect v10 24 v11
    v12 = std constI64 0
    std ret v12
end


    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // Read the value BEFORE unlinking — the slab may not zero a freed node's
    // value slot, but defensive callers might. Reading first is the safe
    // ordering and matches the C# bootstrap's LowerManagedListRemove.
    v2 = std loadIndirect v1 24
    std storeSlot 2 v2

    v3 = std call mrt_managed_list_unlink v0 v1
    v4 = std call mm_decref v1

    v5 = std loadSlot 2
    std ret v5
end


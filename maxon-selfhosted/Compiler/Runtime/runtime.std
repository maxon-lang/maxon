// maxon_subprocess_last_error_message() — returns MM with last error text.
// Stub returns an empty MM; Subprocess.maxon renders it as an empty string,
// which is fine for the unreachable path (spawn always fails so this is
// what fills SubprocessError.spawnFailed's reason field).
func maxon_subprocess_last_error_message 0 i64
  block entry:
    v0 = std constI64 1
    v1 = std constI64 1
    v2 = std call __managed_mem_create v0 v1
    std ret v2
end

// maxon_subprocess_get_pid(handle) — returns the OS pid for a live handle.

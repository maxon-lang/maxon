    std storeSlot 0 v0
    v1 = std call __gt_current_trace_id
    std storeSlot 1 v1
    v2 = std constI64 0
    v3 = std cmpI64Eq v1 v2
    std condBr v3 do_call yield_trace

  block yield_trace:
    v4 = std globalAddr __at_tag_io_yield
    v5 = std loadSlot 1
    v6 = std globalAddr __at_io_op_file_exists
    v7 = std call __gt_trace_emit v4 v5 v6
    std br do_call

  block do_call:
    v8 = std loadSlot 0
    v9 = std call mrt_file_exists_impl v8
    std storeSlot 2 v9
    v10 = std loadSlot 1
    v11 = std constI64 0
    v12 = std cmpI64Eq v10 v11
    std condBr v12 done resume_trace

  block resume_trace:
    v13 = std globalAddr __at_tag_io_resume
    v14 = std loadSlot 1
    v15 = std globalAddr __at_io_op_file_exists
    v16 = std call __gt_trace_emit v13 v14 v15
    std br done

  block done:
    v17 = std loadSlot 2
    std ret v17
end

// Implementation of mrt_file_exists (see the tracing wrapper above). Non-throwing.
// Uses access(path, F_OK) then stat to differentiate dir/file.
//
// Slot usage:
//   slot 0 = path *
//   slot 1 = cstr ptr
//   slot 2 = access result
//   slot 3 = stat buffer ptr (144 bytes)
//   slot 4 = stat result
func mrt_file_exists_impl 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std call mrt_cstr_from_mm v0
    std storeSlot 1 v1

    // access(cstr, F_OK = 0).
    v2 = std loadSlot 1
    v3 = std constI64 0
    v4 = std osFileAccess v2 v3
    std storeSlot 2 v4

    v5 = std loadSlot 2
    v6 = std constI64 0
    v7 = std cmpI64Lt v5 v6
    std condBr v7 not_exist check_dir

  block not_exist:
    // Free cstr and return 0.
    v8 = std loadSlot 1
    v9 = std call mm_decref v8
    v10 = std constI64 0
    std ret v10

  block check_dir:
    // Allocate 144-byte stat buffer.
    v11 = std constI64 144
    v12 = std call mrt_alloc v11
    std storeSlot 3 v12

    // stat(cstr, statbuf).
    v13 = std loadSlot 1
    v14 = std loadSlot 3
    v15 = std osFileStat v13 v14
    std storeSlot 4 v15

    // Free cstr now — done with it.
    v16 = std loadSlot 1
    v17 = std call mm_decref v16

    v18 = std loadSlot 4
    v19 = std constI64 0
    v20 = std cmpI64Lt v18 v19
    std condBr v20 stat_failed read_mode

  block stat_failed:
    // stat failed even though access succeeded — treat as not-found.
    v21 = std loadSlot 3
    v22 = std call mm_decref v21
    v23 = std constI64 0
    std ret v23

  block read_mode:
    // st_mode @ offset 24. Linux S_IFMT = 0o170000 = 61440;
    // S_IFDIR = 0o040000 = 16384.
    v24 = std loadSlot 3
    v25 = std loadIndirect v24 24
    v26 = std constI64 0xFFFFFFFF
    v27 = std andI64 v25 v26
    v28 = std constI64 61440
    v29 = std andI64 v27 v28
    v30 = std constI64 16384
    v31 = std cmpI64Eq v29 v30
    std condBr v31 is_dir is_file

  block is_dir:
    v32 = std loadSlot 3
    v33 = std call mm_decref v32
    v34 = std constI64 0
    std ret v34

  block is_file:
    v35 = std loadSlot 3
    v36 = std call mm_decref v35
    v37 = std constI64 1
    std ret v37
end


  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std constI64 0
    v2 = std cmpI64Eq v0 v1
    std condBr v2 c0 t1
  block t1:
    v3 = std constI64 1
    v4 = std cmpI64Eq v0 v3
    std condBr v4 c1 t2
  block t2:
    v5 = std constI64 2
    v6 = std cmpI64Eq v0 v5
    std condBr v6 c2 t3
  block t3:
    v7 = std constI64 3
    v8 = std cmpI64Eq v0 v7
    std condBr v8 c3 t4
  block t4:
    v9 = std constI64 4
    v10 = std cmpI64Eq v0 v9
    std condBr v10 c4 t5
  block t5:
    v11 = std constI64 5
    v12 = std cmpI64Eq v0 v11
    std condBr v12 c5 t6
  block t6:
    v13 = std constI64 6
    v14 = std cmpI64Eq v0 v13
    std condBr v14 c6 t7
  block t7:
    v15 = std constI64 7
    v16 = std cmpI64Eq v0 v15
    std condBr v16 c7 t8
  block t8:
    v17 = std constI64 8
    v18 = std cmpI64Eq v0 v17
    std condBr v18 c8 t9
  block t9:
    v19 = std constI64 9
    v20 = std cmpI64Eq v0 v19
    std condBr v20 c9 t10
  block t10:
    v21 = std constI64 10
    v22 = std cmpI64Eq v0 v21
    std condBr v22 c10 t11
  block t11:
    v23 = std constI64 11
    v24 = std cmpI64Eq v0 v23
    std condBr v24 c11 t12
  block t12:
    v25 = std constI64 12
    v26 = std cmpI64Eq v0 v25
    std condBr v26 c12 t13
  block t13:
    v27 = std constI64 13
    v28 = std cmpI64Eq v0 v27
    std condBr v28 c13 t14
  block t14:
    v29 = std constI64 14
    v30 = std cmpI64Eq v0 v29
    std condBr v30 c14 t15
  block t15:
    v31 = std constI64 15
    v32 = std cmpI64Eq v0 v31
    std condBr v32 c15 t16
  block t16:
    v33 = std constI64 16
    v34 = std cmpI64Eq v0 v33
    std condBr v34 c16 c17
  block c0:
    v100 = std constI64 8
    std ret v100
  block c1:
    v101 = std constI64 16
    std ret v101
  block c2:
    v102 = std constI64 24
    std ret v102
  block c3:
    v103 = std constI64 32
    std ret v103
  block c4:
    v104 = std constI64 48
    std ret v104
  block c5:
    v105 = std constI64 64
    std ret v105
  block c6:
    v106 = std constI64 96
    std ret v106
  block c7:
    v107 = std constI64 128
    std ret v107
  block c8:
    v108 = std constI64 192
    std ret v108
  block c9:
    v109 = std constI64 256
    std ret v109
  block c10:
    v110 = std constI64 384
    std ret v110
  block c11:
    v111 = std constI64 512
    std ret v111
  block c12:
    v112 = std constI64 1024

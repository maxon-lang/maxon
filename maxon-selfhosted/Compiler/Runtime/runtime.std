    v2 = std constI64 144
    v3 = std call mrt_alloc v2
    std storeSlot 2 v3

    // stat(cstr, statbuf).
    v4 = std loadSlot 1
    v5 = std loadSlot 2
    v6 = std osFileStat v4 v5
    std storeSlot 3 v6

    // Free cstr.
    v7 = std loadSlot 1
    v8 = std call mm_decref v7

    v9 = std loadSlot 3
    v10 = std constI64 0
    v11 = std cmpI64Lt v9 v10

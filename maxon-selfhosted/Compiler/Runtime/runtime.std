    // self.length = newLength
    v20 = std loadSlot 0
    v21 = std loadSlot 2
    std storeIndirect v20 8 v21
    v22 = std constI64 0
    std ret v22
end

// __managed_mem_slice(self, start, end) -> newPtr (sets error
// sliceOutOfBounds=2, wire 3, on OOB).
// Allocates a fresh root __ManagedMemory header (mm_alloc'd, with the same
// destructor as the source) plus a fresh buffer (mm_alloc'd, untagged) sized for
// (end - start) elements. Copies the slice's bytes from the source buffer
// into the new buffer. The new struct's parent_ptr is -1 (root) — i.e. the
// slice owns its buffer; we don't hold a reference to the source.
//
// Bounds checks: 0 <= start <= end <= length.
//
// Slot usage:
//   slot 0 = self     (arg)
//   slot 1 = start    (arg)
//   slot 2 = end      (arg)
//   slot 3 = elemSize
//   slot 4 = sliceLen (end - start)
//   slot 5 = byteLen  (sliceLen * elemSize)
//   slot 6 = newStruct
//   slot 7 = newBuf
func __managed_mem_slice 3 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2

    v3 = std constI64 0
    // if start < 0 -> err
    v4 = std cmpI64Lt v1 v3
    std condBr v4 err start_ok

  block start_ok:
    // if end < start -> err
    v5 = std cmpI64Lt v2 v1
    std condBr v5 err end_ok

  block end_ok:
    // if end > length -> err
    v6 = std loadIndirect v0 8
    v7 = std cmpI64Gt v2 v6
    std condBr v7 err alloc

  block err:
    v8 = std constI64 3
    v9 = std constI64 0
    std errorReturn v9 v8

  block alloc:
    // sliceLen = end - start
    // byteLen = sliceLen * elemSize
    v11 = std loadIndirect v0 24
    std storeSlot 3 v11
    v12 = std subI64 v2 v1
    std storeSlot 4 v12
    v13 = std mulI64 v12 v11
    std storeSlot 5 v13

    // newStruct = mm_alloc(40, &__destruct___ManagedMemory, 0)
    v14 = std constI64 40
    v15 = std funcAddr __destruct___ManagedMemory
    v16 = std constI64 0
    v17 = std call mm_alloc v14 v15 v16
    std storeSlot 6 v17

    // If sliceLen == 0, no buffer; store 0 for buffer and skip the copy.
    v18 = std loadSlot 4
    v19 = std constI64 0
    v20 = std cmpI64Eq v18 v19
    std condBr v20 init_empty alloc_buf

  block alloc_buf:
    v21 = std loadSlot 5
    v37 = std constI64 0
    v38 = std constI64 0
    v22 = std call mm_alloc v21 v37 v38
    std storeSlot 7 v22
    // memcpy(newBuf, self.buffer + start * elemSize, byteLen)
    v23 = std loadSlot 0
    v24 = std loadIndirect v23 0
    v25 = std loadSlot 1
    v26 = std loadSlot 3
    v27 = std mulI64 v25 v26
    v28 = std addI64 v24 v27
    v29 = std loadSlot 5
    std memcpy v22 v28 v29
    std br init_struct

  block init_empty:
    v30 = std constI64 0
    std storeSlot 7 v30
    std br init_struct

  block init_struct:
    // newStruct fields: buffer=newBuf, length=sliceLen, capacity=sliceLen,
    //                   element_size=elemSize, parent_ptr=-1 (root)
    v31 = std loadSlot 6
    v32 = std loadSlot 7
    std storeIndirect v31 0 v32
    v33 = std loadSlot 4
    std storeIndirect v31 8 v33
    std storeIndirect v31 16 v33
    v34 = std loadSlot 3
    std storeIndirect v31 24 v34
    v35 = std constI64 -1
    std storeIndirect v31 32 v35
    v36 = std constI64 0
    std errorReturn v31 v36
end

// __managed_mem_create(count, elemSize) -> newPtr.
// Static __ManagedMemory.create. Allocates a fresh root __ManagedMemory
// struct (mm_alloc) plus, when count > 0, a fresh buffer (mm_alloc, untagged)
// sized for `count` elements. Initializes:
//   buffer       = newBuf or 0
//   length       = 0
//   capacity     = count
//   element_size = elemSize
//   parent_ptr   = -1 (root)
// Does not currently signal allocation failure (the slab+mm layer
// panics on exhaustion); error 7 (invalidAllocation) is reserved for a
// future hook.
//
// Slot usage:
//   slot 0 = count    (arg)
//   slot 1 = elemSize (arg)
//   slot 2 = newStruct
//   slot 3 = newBuf
func __managed_mem_create 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // newStruct = mm_alloc(40, &__destruct___ManagedMemory, 0)
    v2 = std constI64 40
    v3 = std funcAddr __destruct___ManagedMemory
    v4 = std constI64 0
    v5 = std call mm_alloc v2 v3 v4
    std storeSlot 2 v5

    // If count > 0 alloc buffer; else store 0.
    v6 = std constI64 0
    v7 = std cmpI64Le v0 v6
    std condBr v7 init_empty alloc_buf

  block alloc_buf:
    // size = count * elemSize; allocate as untagged buffer (no destructor).
    v8 = std mulI64 v0 v1
    v15 = std constI64 0
    v16 = std constI64 0
    v9 = std call mm_alloc v8 v15 v16
    std storeSlot 3 v9
    std br init_struct

  block init_empty:
    v10 = std constI64 0
    std storeSlot 3 v10
    std br init_struct

  block init_struct:
    v11 = std loadSlot 2
    v12 = std loadSlot 3
    std storeIndirect v11 0 v12
    v13 = std constI64 0
    std storeIndirect v11 8 v13     // length = 0
    std storeIndirect v11 16 v0     // capacity = count
    std storeIndirect v11 24 v1     // element_size = elemSize
    v14 = std constI64 -1
    std storeIndirect v11 32 v14    // parent_ptr = -1 (root)
    std ret v11
end

// __layout_word_load(ptr) -> i64
// Reads 8 bytes from ptr. Used by Phase 11.2 layout copy/destroy thunks
// synthesized in BuildLayoutDescriptors when the Maxon dialect — which
// has no raw-pointer load/store ops — needs to manipulate layout-routed
// values. 8 bytes is enough because every Phase 11 generic instance arg
// in flight today (Array-shaped containers, struct fields, heap pointers)
// occupies a full pointer-sized slot.
//
// Slot usage:
//   slot 0 = ptr (arg)
func __layout_word_load 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std loadIndirect v0 0
    std ret v1
end

// __layout_word_store(ptr, v): stores 8 bytes (v) at ptr. Sibling of
// __layout_word_load — see that helper's comment for the rationale and
// the width discussion.
//
// Slot usage:
//   slot 0 = ptr (arg)
//   slot 1 = v   (arg)
func __layout_word_store 2 void
  block entry:
    v0 = std param 0 i64
    v1 = std param 1 i64
    std storeIndirect v0 0 v1
    v2 = std constI64 0
    std ret v2
end

// =============================================================================
// Phase 3.4 — Subprocess + Clock runtime stubs.
//
// Each function below declares the ABI signature the self-hosted X64 backend's
// `emitDirectCall` looks up via `lookupFuncParamTypes`. Bodies are intentionally
// stubs that signal "operation unsupported" to the caller — the real Win32 /
// POSIX subprocess work is the heavy mechanical step 3.4 in the parent plan.
// Once a target's real implementation lands, replace the stub body in place.
//
// Return-shape conventions (matching the runtime contract in the parent plan):
//   int family       → -1 on failure, a valid handle / value otherwise.
//   managed family   → fresh empty __ManagedMemory; callers test via
//                       `__Builtins.managedIsNull`, which sees a real-but-empty
//                       MM as non-null. The Subprocess.maxon stub treats the
//                       managed-not-null result as "resolver hit" — a bare-name
//                       caller falls through to OS lookup, so the empty hit is
//                       fine for the smoke test path even though it'd misfire
//                       semantically for a name that should be reported as
//                       missing. Real PATH lookup lands later.
//   void family      → standard `ret 0` convention.

// maxon_current_time_ms() — monotonic clock helper for stdlib/Clock.maxon.
// Real bodies query QueryPerformanceCounter / clock_gettime; the stub returns
// 0 so `Clock.elapsedMs(since: start)` reports 0 elapsed.
func maxon_current_time_ms 0 i64
  block entry:
    v0 = std constI64 0
    std ret v0
end

// maxon_sleep(ms) — suspends the current thread for `ms` milliseconds. The
// `std osSleep` op is target-neutral: each backend lowers it to the OS's
// blocking-sleep primitive (kernel32!Sleep on Windows, poll_oneoff with a
// CLOCK_MONOTONIC subscription on WASI, nanosleep syscall/libcall on
// Linux/macOS). The body returns 0 because the Maxon-level signature is
// void; the constI64 is bound to the return slot so the codegen path through
// `lookupFuncReturnStdType` resolves cleanly.
func maxon_sleep 1 void
  block entry:
    v0 = std param 0 i64
    std osSleep v0
    v1 = std constI64 0
    std ret v1
end

// maxon_subprocess_resolve_on_path(name_mm) — PATH lookup. Stub returns a
// fresh empty MM so the Subprocess.maxon caller's `managedIsNull` check sees
// "resolver returned something" and uses the bare name with the OS spawn
// primitive. The subsequent spawn-stub will fail with -1, surfacing as
// `SubprocessError.spawnFailed`.
func maxon_subprocess_resolve_on_path 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 1
    v2 = std constI64 1
    v3 = std call __managed_mem_create v1 v2
    std ret v3
end


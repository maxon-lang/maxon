    v25 = std loadSlot 5
    v26 = std loadByte v24 v25
    v27 = std loadSlot 3
    v28 = std addI64 v25 v27
    std storeByte v24 v28 v26
    v29 = std constI64 1
    v30 = std subI64 v25 v29
    std storeSlot 5 v30
    std br loop_head

  block loop_end:
    v31 = std constI64 0

// Slot usage:
//   slot 0 = self  (arg)
//   slot 1 = idx   (arg)
//   slot 2 = value (arg)
func __managed_mem_set 3 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1
    v2 = std param 2 i64
    std storeSlot 2 v2

    // if idx < 0 -> err
    v3 = std constI64 0
    v4 = std cmpI64Lt v1 v3
    std condBr v4 err lo_ok

  block lo_ok:
    // if idx < capacity -> ok else -> err. set() bounds-checks against
    // capacity, NOT length, so push()'s "set then setLength" sequence is
    // valid: push reserves capacity for len+1, writes the new element at
    // slot `len` (which is < capacity but == length), then bumps length.
    // Matches C# bootstrap semantics in `LowerManagedMemSet`.
    //
    // For rdata-backed buffers capacity == -2, so any non-negative idx
    // fails this check. Treat capacity < 0 as "needs COW first" and
    // re-bounds-check against the post-COW capacity (= length).

// Slot usage:
//   slot 0 = self (arg)
//   slot 1 = n    (arg)
func __managed_mem_set_length 2 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // capacity = self[16]
    v2 = std loadIndirect v0 16
    // if n <= capacity -> ok, else -> err
    v3 = std cmpI64Le v1 v2
    std condBr v3 ok err

  block err:
    v4 = std constI64 4
    v5 = std constI64 0
    std errorReturn v5 v4

  block ok:
    v7 = std loadSlot 0
    v8 = std loadSlot 1
    std storeIndirect v7 8 v8
    v9 = std constI64 0
    v10 = std constI64 0
    std errorReturn v9 v10
end

// __managed_mem_get(self, idx) -> value (sets error indexOutOfBounds=0,
// wire 1, on out-of-bounds)

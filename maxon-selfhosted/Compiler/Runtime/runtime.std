    std condBr v6 c2 t3
  block t3:
    v7 = std constI64 3
    v8 = std cmpI64Eq v0 v7
    std condBr v8 c3 t4
  block t4:
    v9 = std constI64 4
    v10 = std cmpI64Eq v0 v9
    std condBr v10 c4 t5
  block t5:
    v11 = std constI64 5
    v12 = std cmpI64Eq v0 v11
    std condBr v12 c5 t6
  block t6:
    v13 = std constI64 6
    v14 = std cmpI64Eq v0 v13
    std condBr v14 c6 t7
  block t7:
    v15 = std constI64 7
    v16 = std cmpI64Eq v0 v15
    std condBr v16 c7 t8
  block t8:
    v17 = std constI64 8
    v18 = std cmpI64Eq v0 v17
    std condBr v18 c8 t9
  block t9:
    v19 = std constI64 9
    v20 = std cmpI64Eq v0 v19

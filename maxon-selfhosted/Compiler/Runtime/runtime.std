// =============================================================================
// Phase C — __ManagedList / __ManagedListNode runtime helpers.
//
// Backs every `__ManagedList.*` and `__ManagedListNode.*` method registered in
// `registerManagedListMethods` / `registerManagedListNodeMethods`.
//
// Layouts mirror the C# bootstrap (plus the trailing elem_managed flag):
//   __ManagedList (40 bytes via mm_alloc):
//     offset  0  head         i64 (first __ManagedListNode pointer, or 0)
//     offset  8  tail         i64 (last __ManagedListNode pointer, or 0)
//     offset 16  count        i64 (number of nodes)
//     offset 24  cursor       i64 (current iteration cursor node pointer, or 0)
//     offset 32  elem_managed i64 (1 when Element is heap-managed — stamped at
//                                  create from the layout descriptor's heap-ref
//                                  bit; destructor/clear decref each node's
//                                  value when set)
//
//   __ManagedListNode (32 bytes via mm_alloc):
//     offset  0  next    i64 (next __ManagedListNode pointer, or 0)
//     offset  8  prev    i64 (previous __ManagedListNode pointer, or 0)
//     offset 16  list    i64 (back-pointer to owning __ManagedList, or 0 when detached)
//     offset 24  value   i64 (element slot, ABI matches __ManagedMemory.set/get)
//
// __ManagedListError ordinal map (mirrors stdlib/Builtins.maxon):
//   ordinal | name              | wire
//   0       | empty             | 1
//   1       | endOfList         | 2
//   2       | nodeNotInList     | 3
//   3       | nodeAlreadyInList | 4
//
// Element-managed lifecycle: the insert helpers receive values whose +1 the
// caller transferred in (the intrinsic-consumer seed); each node owns its
// value's reference. The list-level `elem_managed` flag (offset 32, stamped at
// create from the layout descriptor's heap-ref bit) tells the destructor and
// `clear` walks whether to decref each node's value before freeing the node;
// `remove` hands the unlinked value's +1 to the caller instead.
// =============================================================================

// __destruct___ManagedList(self): destructor for a __ManagedList instance.
// Walks every node, drops its value when `elem_managed` is set, clears its
// links, and mm_decref's it.
//
// Slot usage:
//   slot 0 = self    (arg, list_ptr)
//   slot 1 = current (current node pointer during walk)
//   slot 2 = next    (next node pointer, saved before current is freed)
func __destruct___ManagedList 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    // current = self.head
    v1 = std loadIndirect v0 0
    std storeSlot 1 v1
    std br loop

  block loop:
    v2 = std loadSlot 1
    v3 = std constI64 0
    v4 = std cmpI64Eq v2 v3
    std condBr v4 done body

  block body:
    // next = current.next
    v5 = std loadSlot 1
    v6 = std loadIndirect v5 0
    std storeSlot 2 v6
    // Drop the node's value when the element type is heap-managed (the
    // node owns the +1 the insert helper moved in). Null value = no-op
    // (a cleared slot).
    v20 = std loadSlot 0
    v21 = std loadIndirect v20 32
    v22 = std constI64 0
    v23 = std cmpI64Eq v21 v22
    std condBr v23 clear_links drop_value

  block drop_value:
    v24 = std loadSlot 1
    v25 = std loadIndirect v24 24
    v26 = std constI64 0
    v27 = std cmpI64Eq v25 v26
    std condBr v27 clear_links do_value_decref

  block do_value_decref:
    v28 = std loadSlot 1
    v29 = std loadIndirect v28 24
    v30 = std call __mm_decref v29
    std br clear_links

  block clear_links:
    // Zero the node's link fields so the freed node looks detached if
    // anything still has a stray pointer to it.
    v7 = std loadSlot 1
    v8 = std constI64 0
    std storeIndirect v7 0 v8
    std storeIndirect v7 8 v8
    std storeIndirect v7 16 v8
    // Drop the list's owned reference to this node.
    v9 = std loadSlot 1
    v10 = std call mm_decref v9
    // current = next
    v11 = std loadSlot 2
    std storeSlot 1 v11
    std br loop

  block done:
    v12 = std constI64 0
    std ret v12
end

// __destruct___ManagedListNode(self): destructor for a __ManagedListNode.
// No-op for primitive-value nodes. Managed-value decref is performed at the
// Maxon-level lowering site (mirrors __ManagedMemory's pattern), so the
// destructor body has nothing to do today. The destructor must still exist
// because `mm_decref` reads the slot from `[ptr - 24]` and invokes it via
// `indirectCall`; a zero slot bypasses the call, so wiring an explicit no-op
// keeps the type's lifecycle path symmetric with __ManagedList / __ManagedMemory.
func __destruct___ManagedListNode 1 i64
  block entry:
    v0 = std param 0 i64
    v1 = std constI64 0
    std ret v1
end

// mrt_managed_list_create(elem_managed) -> ptr to fresh empty __ManagedList.
// head/tail/count/cursor zero-initialized; `elem_managed` (the layout
// descriptor's heap-ref bit, projected at the lowering's synthesized-create
// site) is stamped at offset 32 so the destructor/clear walks know whether to
// decref each node's value.
func mrt_managed_list_create 1 i64
  block entry:
    v8 = std param 0 i64
    v0 = std constI64 40
    v1 = std funcAddr __destruct___ManagedList
    // tag = MM_TAG_MANAGED_LIST (4) — see resetMmTraceTags' reserved indices.
    v2 = std constI64 4
    v3 = std call __mm_alloc v0 v1 v2
    std storeSlot 0 v3
    // alloc-at-0: the returned list is an owned ref — incref to rc=1 so the
    // caller's matching decref balances (see dual-mm-alloc unification).
    v7 = std call __mm_incref v3
    // Zero head/tail/count/cursor; stamp elem_managed.
    v4 = std loadSlot 0
    v5 = std constI64 0
    std storeIndirect v4 0 v5
    std storeIndirect v4 8 v5
    std storeIndirect v4 16 v5
    std storeIndirect v4 24 v5
    std storeIndirect v4 32 v8
    v6 = std loadSlot 0
    std ret v6
end

// mrt_managed_list_alloc_node(value) -> ptr to fresh __ManagedListNode.
// Internal helper: allocates a node with refcount 1, stores `value` at
// offset 24, zero-initializes next/prev/list. The node is owned by the
// caller's stack until reinsertFirst/Last/etc. links it into a list (the
// list takes an mm_incref reference, see the insert helpers below).
func mrt_managed_list_alloc_node 1 i64
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0

    v1 = std constI64 32
    v2 = std funcAddr __destruct___ManagedListNode
    // tag = MM_TAG_MANAGED_LIST_NODE (5) — see resetMmTraceTags' reserved indices.
    v3 = std constI64 5
    v4 = std call __mm_alloc v1 v2 v3
    std storeSlot 1 v4
    // alloc-at-0: the returned node is an owned ref — incref to rc=1.
    v9 = std call __mm_incref v4

    // Zero next/prev/list.
    v5 = std loadSlot 1
    v6 = std constI64 0
    std storeIndirect v5 0 v6
    std storeIndirect v5 8 v6
    std storeIndirect v5 16 v6
    // Store value at offset 24.
    v7 = std loadSlot 0
    std storeIndirect v5 24 v7

    v8 = std loadSlot 1
    std ret v8
end

// mrt_managed_list_unlink(list, node): internal helper. Removes the node from
// the list's doubly-linked chain, clears the node's next/prev/list fields,
// and decrements the list's count. Does NOT decref the node — the caller is
// responsible for that (the node's reference count tracks whether ANY pointer
// holds it; the list's "owned" reference is dropped by the caller).
//
// Slot usage:
//   slot 0 = list_ptr (arg)
//   slot 1 = node_ptr (arg)
//   slot 2 = prev
//   slot 3 = next
func mrt_managed_list_unlink 2 void
  block entry:
    v0 = std param 0 i64
    std storeSlot 0 v0
    v1 = std param 1 i64
    std storeSlot 1 v1

    // Check node.list — 0 means already detached; nothing to do.
    v2 = std loadSlot 1
    v3 = std loadIndirect v2 16
    v4 = std constI64 0
    v5 = std cmpI64Eq v3 v4
    std condBr v5 done relink

  block relink:
    // prev = node.prev; next = node.next
    v6 = std loadSlot 1
    v7 = std loadIndirect v6 8
    std storeSlot 2 v7
    v8 = std loadIndirect v6 0
    std storeSlot 3 v8

    // If prev != 0: prev.next = next; else: list.head = next.
    v9 = std loadSlot 2
    v10 = std constI64 0
    v11 = std cmpI64Eq v9 v10
    std condBr v11 list_head_path prev_link

  block prev_link:
    v12 = std loadSlot 2
    v13 = std loadSlot 3
    std storeIndirect v12 0 v13
    std br after_prev

  block list_head_path:
    v14 = std loadSlot 0
    v15 = std loadSlot 3
    std storeIndirect v14 0 v15
    std br after_prev

  block after_prev:
    // If next != 0: next.prev = prev; else: list.tail = prev.
    v16 = std loadSlot 3
    v17 = std constI64 0
    v18 = std cmpI64Eq v16 v17
    std condBr v18 list_tail_path next_link

  block next_link:
    v19 = std loadSlot 3
    v20 = std loadSlot 2
    std storeIndirect v19 8 v20
    std br after_next

  block list_tail_path:
    v21 = std loadSlot 0
    v22 = std loadSlot 2
    std storeIndirect v21 8 v22
    std br after_next

  block after_next:
    // If list.cursor == node, advance cursor to next so a subsequent
    // cursorValue/cursorAdvance doesn't dereference the freed slot.
    v23 = std loadSlot 0
    v24 = std loadIndirect v23 24
    v25 = std loadSlot 1
    v26 = std cmpI64Eq v24 v25
    std condBr v26 cursor_advance after_cursor

  block cursor_advance:
    v27 = std loadSlot 0
    v28 = std loadSlot 3
    std storeIndirect v27 24 v28
    std br after_cursor

  block after_cursor:
    // Clear node links.
    v29 = std loadSlot 1
    v30 = std constI64 0
    std storeIndirect v29 0 v30
    std storeIndirect v29 8 v30
    std storeIndirect v29 16 v30

    // list.count -= 1
    v31 = std loadSlot 0
    v32 = std loadIndirect v31 16
    v33 = std constI64 1
    v34 = std subI64 v32 v33
    std storeIndirect v31 16 v34
    std br done

  block done:
    v35 = std constI64 0
    std ret v35
end


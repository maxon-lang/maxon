// Global data table: maps names to byte arrays for .rdata/.rodata sections.
// Used by Maxon->Mid lowering to register string literals for the PE/ELF data section.

// A .covdata section entry. Used for coverage-counter globals (`__data_cov_*`)
// that must live in a writable segment with a dedicated RVA — separate from the
// .data heap arena so the two can grow independently. `sizeBytes` reserves room
// inside .covdata; `initialBytes` (if non-empty) seed the beginning of that
// region and the writer zero-fills the rest.
export type CovDataEntry
	export var name as String
	export var sizeBytes as ByteCount
	export var initialBytes as ByteArray

	export static function create(name String, sizeBytes ByteCount, initialBytes ByteArray) returns CovDataEntry
		return Self{name: name, sizeBytes: sizeBytes, initialBytes: initialBytes}
	end 'create'
end 'CovDataEntry'

export typealias CovDataEntryArray = Array with CovDataEntry

// A .data section entry. Used for top-level `var` and `static var/let`
// globals: writable storage with an initial value emitted into the section's
// raw on-disk bytes. Resolved through the `__data_*` relocation kind;
// offsets are assigned by buildDataPreludeSection at backend time.
export type DataSectionEntry
	export var name as String
	export var initialBytes as ByteArray

	export static function create(name String, initialBytes ByteArray) returns DataSectionEntry
		return Self{name: name, initialBytes: initialBytes}
	end 'create'
end 'DataSectionEntry'

export typealias DataSectionEntryArray = Array with DataSectionEntry
export typealias GlobalNameIndexMap = Map with (String, MachineWord)
export typealias GlobalDedupMap = Map with (ByteArray, String)

export type GlobalDataTable
	export var names as StringArray
	export var values as ByteArrayArray
	export var nextStringId as MachineWord
	// Coverage-counter entries in the .covdata section. Kept separate from
	// `names`/`values` (which serve .rdata) because .covdata is writable and
	// uses its own relocation kinds with an independent base address.
	export var covDataEntries as CovDataEntryArray
	// Top-level / static-field globals in the .data section, ordered by
	// declaration. Each entry consumes 8 bytes; `buildDataPreludeSection`
	// concatenates their `initialBytes` and registers each name's offset in
	// the rdata offset map so dataSection relocations resolve correctly.
	export var dataSectionEntries as DataSectionEntryArray
	// O(1) lookup tables maintained in lockstep with `names`/`values`.
	// `nameIndex` maps a registered global's name to its index in
	// `names`/`values`; `valueDedup` maps a previously-registered byte
	// payload to its synthetic name so addGlobalData can dedupe in O(1)
	// instead of scanning every prior value. Without these, both lookup
	// helpers were O(N) per call and drove a quadratic build cost.
	export var nameIndex as GlobalNameIndexMap
	export var valueDedup as GlobalDedupMap
	// Phase 11.2: relocations whose patch site lives inside an rdata blob
	// (rather than inside code), e.g. layout-descriptor copy/destroy slots.
	// Emitted by Maxon-level passes (BuildLayoutDescriptors) directly into
	// the project-level globalData so they survive the per-function backend
	// emit and get concatenated into the final rdataRelocs array.
	export var pendingRdataRelocs as RdataRelocationArray

	export static function create() returns GlobalDataTable
		return Self{names: StringArray.create(), values: ByteArrayArray.create(), nextStringId: 0, covDataEntries: CovDataEntryArray.create(), dataSectionEntries: DataSectionEntryArray.create(), nameIndex: GlobalNameIndexMap.create(), valueDedup: GlobalDedupMap.create(), pendingRdataRelocs: RdataRelocationArray.create()}
	end 'create'
end 'GlobalDataTable'

export function createGlobalDataTable() returns GlobalDataTable
	return GlobalDataTable.create()
end 'createGlobalDataTable'

// Look up a named entry in the global data table. O(1) via nameIndex.
// Returns empty ByteArray if the name is not found.
export function lookupGlobalData(table GlobalDataTable, name String) returns ByteArray
	let idx = try table.nameIndex.get(name) otherwise return ByteArray.create()
	return try table.values.get(idx) otherwise ByteArray.create()
end 'lookupGlobalData'

export function addGlobalData(table GlobalDataTable, data ByteArray) returns String
	// Deduplicate via the byte-payload → name map so identical strings
	// share a single .rdata entry across the whole module. Hash lookup,
	// not a per-entry scan.
	//
	// Callers that already hold a StringId (everything that flows through
	// `project.strings`) should prefer `addInternedString`, which uses the
	// id itself as the dedup key and skips the byte-payload hash entirely.
	// This entry point remains for ad-hoc payloads that don't have an
	// interner-backed identity.
	let existingName = try table.valueDedup.get(data) otherwise 'fresh'
		let id = table.nextStringId
		table.nextStringId = table.nextStringId + 1
		// Build name like "__str_0", "__str_1", etc.
		let name = "__str_{id}"
		let newIdx = table.names.count()
		table.names.push(name)
		table.values.push(data)
		table.nameIndex.upsert(name, value: newIdx)
		table.valueDedup.upsert(data, value: name)
		return name
	end 'fresh'
	return existingName
end 'addGlobalData'

// Register a string already interned in `project.strings` for emission
// into the .rdata section. The interner's StringId is the dedup key —
// identical content has one id, so checking `nameIndex` for the
// canonical `__istr_<stringId>` symbol is enough; the byte-payload hash
// in `valueDedup` is bypassed entirely. Idempotent: a second call with
// the same id is an O(1) name-index hit and returns the existing symbol.
export function addInternedString(table GlobalDataTable, stringId StringId, data ByteArray) returns String
	let name = "__istr_{stringId}"
	if table.nameIndex.contains(name) 'alreadyRegistered'
		return name
	end 'alreadyRegistered'
	let newIdx = table.names.count()
	table.names.push(name)
	table.values.push(data)
	table.nameIndex.upsert(name, value: newIdx)
	return name
end 'addInternedString'

// Register global data with an explicit name (no auto-generated __str_N prefix).
// Idempotent on `name`: a second call with the same name is a no-op, so
// stdlib-cache hydration (which re-emits previously-interned __istr_N and
// other named globals) can run before user-side lowering without causing
// duplicate-name entries that would crash the wasm/PE/ELF layout pass.
// The check mirrors `addInternedString`.
export function addNamedGlobalData(table GlobalDataTable, name String, data ByteArray)
	if table.nameIndex.contains(name) 'alreadyRegistered'
		return
	end 'alreadyRegistered'
	let newIdx = table.names.count()
	table.names.push(name)
	table.values.push(data)
	table.nameIndex.upsert(name, value: newIdx)
	// Don't seed valueDedup here: addGlobalData callers expect identical
	// payloads to dedupe through the synthetic-name path; named entries
	// (cov counters, registered globals) own their name and aren't
	// candidates for dedup-merging with auto-named strings.
end 'addNamedGlobalData'

// Build a binary symbol table as a standalone ByteArray for the .symtab section.
// Referenced by mrt_panic via funcAddr __symtable (resolved through rdata relocations).
// Format: count(i32) | entries[count]{codeOffset(i32), nameOffset(i32)} | null-terminated name strings
// Entries sorted by codeOffset ascending.
export function buildSymbolTable(labelNames StringArray, funcLabelOffsets CodeOffsetArray) returns ByteArray
	var symdata = ByteArray.create()
	let count = labelNames.count()

	// Build sorted indices by offset (insertion sort)
	var sortedIndices = CodeOffsetArray.create()
	for i in 0 upto count 'init'
		sortedIndices.push(i)
	end 'init'
	for i in 1 upto count 'sort'
		let key = try sortedIndices.get(i) otherwise panic("buildSymbolTable.sort: sortedIndices grown to count but get({i}) failed (count={count})")
		let keyOffset = try funcLabelOffsets.get(key) otherwise panic("buildSymbolTable.sort: key < count = funcLabelOffsets.count() but get({key}) failed (count={funcLabelOffsets.count()})")
		var j = i
		while j > 0 'shift'
			let prev = try sortedIndices.get(j - 1) otherwise panic("buildSymbolTable.shift: j > 0 just checked, sortedIndices sized count but get({j - 1}) failed")
			let prevOffset = try funcLabelOffsets.get(prev) otherwise panic("buildSymbolTable.shift: prev is a valid sortedIndex but funcLabelOffsets.get({prev}) failed")
			if prevOffset <= keyOffset 'done'
				break
			end 'done'
			try sortedIndices.set(j, value: prev) otherwise panic("invariant: sortedIndices.set OOB")
			j = j - 1
		end 'shift'
		try sortedIndices.set(j, value: key) otherwise panic("invariant: sortedIndices.set OOB")
	end 'sort'

	// Build name strings block and record offsets
	var nameStrings = ByteArray.create()
	var nameOffsets = CodeOffsetArray.create()
	for i in 0 upto count 'buildNames'
		let idx = try sortedIndices.get(i) otherwise panic("buildSymbolTable.buildNames: i < count = sortedIndices.count() but get({i}) failed")
		nameOffsets.push(nameStrings.count())
		let name = try labelNames.get(idx) otherwise panic("buildSymbolTable.buildNames: idx < labelNames.count() but get({idx}) failed (count={labelNames.count()})")
		nameStrings.append(name.toByteArray())
		nameStrings.push(0)
	end 'buildNames'

	// Header size: 4 (count) + 8 * count (entries)
	let headerSize = 4 + 8 * count

	writeDword(symdata, value: count)
	for i in 0 upto count 'writeEntries'
		let idx = try sortedIndices.get(i) otherwise panic("buildSymbolTable.writeEntries: i < count = sortedIndices.count() but get({i}) failed")
		let codeOffset = try funcLabelOffsets.get(idx) otherwise panic("buildSymbolTable.writeEntries: idx < funcLabelOffsets.count() but get({idx}) failed")
		writeDword(symdata, value: codeOffset)
		let nameOffset = headerSize + (try nameOffsets.get(i) otherwise panic("buildSymbolTable.writeEntries: nameOffsets sized count but get({i}) failed"))
		writeDword(symdata, value: nameOffset)
	end 'writeEntries'
	symdata.append(nameStrings)
	return symdata
end 'buildSymbolTable'

export typealias RdataOffsetIndexMap = Map with (String, CodeOffset)

// Rdata label → byte-offset directory. The parallel name/offset arrays
// preserve insertion order for callers that walk every entry; the
// `index` map answers single-name lookups in O(1) for the relocation
// resolver, which fires once per relocation in the function and used to
// scan every entry per call.
export type RdataOffsetMap
	export var names as StringArray
	export var offsets as CodeOffsetArray
	export var index as RdataOffsetIndexMap

	export static function create() returns RdataOffsetMap
		return Self{names: StringArray.create(), offsets: CodeOffsetArray.create(), index: RdataOffsetIndexMap.create()}
	end 'create'

	// Append `name` at `offset` and record the lookup index. Callers must
	// route every insertion through this helper (or carefully push to all
	// three fields in lockstep) so the views stay in sync.
	export function record(name String, offset CodeOffset)
		self.names.push(name)
		self.offsets.push(offset)
		self.index.upsert(name, value: offset)
	end 'record'
end 'RdataOffsetMap'

// Look up an rdata offset by label name. Returns 0 if not found.
// O(1) via the offset map's `index`.
export function lookupRdataOffset(map RdataOffsetMap, name String) returns CodeOffset
	return try map.index.get(name) otherwise 0
end 'lookupRdataOffset'

// Classify a globalData entry by name. User-emitted constants (string
// literals, float literals, user panic messages, UCD blobs) come first in
// `.rdata`; infrastructure entries (layout descriptors, witness tables,
// runtime panic strings) come after. This matches the C# bootstrap, where
// runtime data lives in `.symdata` and `.rdata` opens with user values —
// `RequiredRdata` blocks in spec files rely on that prefix.
function isUserRdataEntry(name String) returns bool
	if name.startsWith("__str_") 'isStr'
		return true
	end 'isStr'
	if name.startsWith("__istr_") 'isIStr'
		return true
	end 'isIStr'
	if name.startsWith("__float_") 'isFloat'
		return true
	end 'isFloat'
	if name.startsWith("__panic_msg_") 'isPanicMsg'
		return true
	end 'isPanicMsg'
	if name.startsWith("__ucd_") 'isUcd'
		return true
	end 'isUcd'
	if name.startsWith("__rdata_arr_") 'isArrayLit'
		return true
	end 'isArrayLit'
	return false
end 'isUserRdataEntry'

// Serialize the global data table into a flat ByteArray for the .rdata section.
// Each entry is 8-byte aligned. Populates the offset map for label-to-offset resolution.
// Two-pass emission: user entries (classified by `isUserRdataEntry`) first,
// infrastructure entries last. Within each pass, original insertion order is
// preserved. Matching the C# bootstrap's prefix-first layout lets the spec
// runner verify user `RequiredRdata` byte blocks against the start of the
// section.
export function buildRdataSection(table GlobalDataTable, map RdataOffsetMap) returns ByteArray
	var rdata = ByteArray.create()
	let count = table.names.count()
	emitRdataPass(rdata, table: table, map: map, count: count, wantUser: true)
	emitRdataPass(rdata, table: table, map: map, count: count, wantUser: false)
	return rdata
end 'buildRdataSection'

function emitRdataPass(rdata ByteArray, table GlobalDataTable, map RdataOffsetMap, count ByteCount, wantUser bool)
	for i in 0 upto count 'build'
		let name = try table.names.get(i) otherwise panic("emitRdataPass: i < count = table.names.count() but get({i}) failed")
		let isUser = isUserRdataEntry(name)
		if isUser != wantUser 'skipPass'
			continue
		end 'skipPass'
		var data = try table.values.get(i) otherwise panic("emitRdataPass: names and values kept parallel but values.get({i}) failed (values.count={table.values.count()})")
		// `__xmmmask_*` entries hold 128-bit constants that SSE packed
		// instructions (ANDPD / PCMPEQD with m128 operand) require to be
		// 16-byte aligned. The PE rdata section starts on a SECTION_ALIGNMENT
		// (4KB) boundary, so a 16-byte aligned offset within rdata is
		// 16-byte aligned at runtime.
		if name.startsWith("__xmmmask_") 'mask16'
			while rdata.count() mod 16 != 0 'align16'
				rdata.push(0)
			end 'align16'
		end 'mask16'
		map.record(name, offset: rdata.count())
		rdata.append(data)
		// Pad to 8-byte alignment
		while rdata.count() mod 8 != 0 'align'
			rdata.push(0)
		end 'align'
	end 'build'
end 'emitRdataPass'

// Resolve rdata relocations: fill in rdataOffset from the offset map.
// Returns a new array with resolved offsets.
//
// `funcAbs64InRdata` relocs carry the rdata label inside the kind payload
// (the patch site is rdata-relative, not code-relative); for those we look
// up the descriptor's start offset and stash it in `rdataOffset` so the
// per-target writers can compute `rdataOffset + offsetInLabel` to find the
// 8-byte slot to overwrite with the function's absolute VA.
export function resolveRdataRelocations(relocs RdataRelocationArray, map RdataOffsetMap) returns RdataRelocationArray
	var resolved = RdataRelocationArray.create()
	for reloc in relocs 'resolve'
		let labelForLookup = match reloc.kind 'pickLabel'
			funcAbs64InRdata(_, rdataLabel, _) gives rdataLabel
			ripRelDisp32 to covdataArm64Adr gives reloc.rdataLabel
		end 'pickLabel'
		let offset = lookupRdataOffset(map, name: labelForLookup)
		var copy = RdataRelocation.create(reloc.codeOffset, rdataLabel: reloc.rdataLabel, kind: reloc.kind)
		copy.rdataOffset = offset
		resolved.push(copy)
	end 'resolve'
	return resolved
end 'resolveRdataRelocations'

// Register panic message string constants in globalData.
export function registerPanicStrings(globalData GlobalDataTable)
	addNamedGlobalData(globalData, name: "__panic_stacktrace", data: b"Stack trace:\n\0")
	addNamedGlobalData(globalData, name: "__panic_in", data: b"  in \0")
	addNamedGlobalData(globalData, name: "__panic_newline", data: b"\n\0")
	addNamedGlobalData(globalData, name: "__panic_unknown", data: b"<unknown>\0")
	addNamedGlobalData(globalData, name: "__mm_panic_list_empty_msg", data: b"managed list cursor null: cursorStart() must be called before cursorValue()\n\0")
end 'registerPanicStrings'

// Register a .covdata entry with the given fixed byte size. The entry lives in
// its own writable section (separate RVA from the .data heap arena) so it can
// grow independently. The final offset is resolved by buildCovDataSection when
// the backend emits code.
export function addCovDataEntry(table GlobalDataTable, name String, sizeBytes ByteCount, initialBytes ByteArray)
	table.covDataEntries.push(CovDataEntry.create(name, sizeBytes: sizeBytes, initialBytes: initialBytes))
end 'addCovDataEntry'

// Serialize .covdata entries into a contiguous ByteArray, laid out starting at
// offset 0 inside its own section. Populates `map` with (name -> offset) entries
// so code emissions resolve to the correct address after the writer assigns the
// section's base RVA. Short `initialBytes` values are zero-padded to their
// declared `sizeBytes`.
export function buildCovDataSection(table GlobalDataTable, map RdataOffsetMap) returns ByteArray
	var data = ByteArray.create()
	for entry in table.covDataEntries 'build'
		if entry.initialBytes.count() > entry.sizeBytes 'tooLarge'
			panic("CovDataEntry {entry.name} has {entry.initialBytes.count()} initial bytes but sizeBytes is only {entry.sizeBytes}")
		end 'tooLarge'

		map.record(entry.name, offset: data.count())

		data.append(entry.initialBytes)
		for _ in entry.initialBytes.count() upto entry.sizeBytes 'pad'
			data.push(0)
		end 'pad'
	end 'build'
	return data
end 'buildCovDataSection'

// Register a .data section entry for a top-level `var` or `static var/let`
// global. `initialBytes` is the 8-byte little-endian image of the initial
// value; `buildDataPreludeSection` lays them out before the heap arena and
// records each name's offset.
export function addDataSectionEntry(table GlobalDataTable, name String, initialBytes ByteArray)
	table.dataSectionEntries.push(DataSectionEntry.create(name, initialBytes: initialBytes))
end 'addDataSectionEntry'

// Serialize all .data section entries into a contiguous prelude block laid
// out at the very start of the writable .data section. Populates `map` with
// (name -> offset) entries so `__data_<global>` relocations resolve to the
// right offset.
export function buildDataPreludeSection(table GlobalDataTable, map RdataOffsetMap) returns ByteArray
	var prelude = ByteArray.create()
	for entry in table.dataSectionEntries 'build'
		map.record(entry.name, offset: prelude.count())
		prelude.append(entry.initialBytes)
		// Pad to 8-byte alignment so the next entry starts aligned.
		while prelude.count() mod 8 != 0 'align'
			prelude.push(0)
		end 'align'
	end 'build'
	return prelude
end 'buildDataPreludeSection'

// Register the writable-data globals used by coverage instrumentation.
// __data_cov_num_sites holds the site count (u32 LE) so mrt_cov_dump can
// write the correct header and counter payload without relying on a constant
// baked into code. __data_cov_counters is zero-initialized and incremented
// by mrt_cov_hit at runtime. Called by augmentWithRuntime in Chunk D when
// project.coverageEnabled is true; left uncalled here so non-coverage builds
// see no .covdata section in the output.
export function registerCoverageGlobals(globalData GlobalDataTable, numSites CovNumSites)
	var numSitesBytes = ByteArray.create()
	writeDword(numSitesBytes, value: numSites)
	addCovDataEntry(globalData, name: "__data_cov_num_sites", sizeBytes: 4, initialBytes: numSitesBytes)

	let countersSize = numSites * 8
	addCovDataEntry(globalData, name: "__data_cov_counters", sizeBytes: countersSize, initialBytes: ByteArray.create())

	addNamedGlobalData(globalData, name: "__cov_env_name", data: b"MAXON_COV_OUT\0")
end 'registerCoverageGlobals'

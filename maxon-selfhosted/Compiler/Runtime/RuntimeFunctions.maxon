// Runtime function builder -- constructs MlirFunction objects for runtime stubs.
// These functions are expressed as mid-level MLIR IR (arith/cf/func/memref/sys ops)
// and are lowered by the target-specific backends just like user functions.

// Global data table: maps names to byte arrays for .rdata/.rodata sections.
export type GlobalDataTable
    export var names ByteArrayArray
    export var values ByteArrayArray
    export var nextStringId MachineWord
end 'GlobalDataTable'

export function createGlobalDataTable() returns GlobalDataTable
    return GlobalDataTable{names: ByteArrayArray{}, values: ByteArrayArray{}, nextStringId: 0}
end 'createGlobalDataTable'

// Look up a named entry in the global data table.
// Returns empty ByteArray if the name is not found.
export function lookupGlobalData(table GlobalDataTable, name ByteArray) returns ByteArray
    for (i, tableName) in table.names.enumerated() 'findData'
        if bytesEqual(tableName, b: name) 'found'
            return try table.values.get(i) otherwise ByteArray{}
        end 'found'
    end 'findData'
    return ByteArray{}
end 'lookupGlobalData'

export function addGlobalData(table GlobalDataTable, data ByteArray) returns ByteArray
    let id = table.nextStringId
    table.nextStringId = table.nextStringId + 1
    // Build name like "__str_0", "__str_1", etc.
    var name = b"__str_"
    let idStr = intToBytes(id)
    name.append(idStr)
    table.names.push(name)
    table.values.push(data)
    return name
end 'addGlobalData'

// Convert an integer to its decimal byte representation.
function intToBytes(value MachineWord) returns ByteArray
    if value == 0 'zero'
        return b"0"
    end 'zero'
    var result = ByteArray{}
    var remaining = value
    while remaining > 0 'digits'
        let digit = remaining mod 10
        result.push(digit + 0x30)
        remaining = remaining / 10
    end 'digits'
    // Reverse in place
    var lo = 0
    var hi = result.count() - 1
    while lo < hi 'reverse'
        let tmp = try result.get(lo) otherwise 0
        let hiVal = try result.get(hi) otherwise 0
        result.set(lo, value: hiVal)
        result.set(hi, value: tmp)
        lo = lo + 1
        hi = hi - 1
    end 'reverse'
    return result
end 'intToBytes'

// Value ID counter for runtime-generated functions.
// Starts at a high value to avoid collisions with user code IDs.
type RuntimeIdCounter
    export var nextId ValueId
end 'RuntimeIdCounter'

function nextId(counter RuntimeIdCounter) returns ValueId
    let id = counter.nextId
    counter.nextId = counter.nextId + 1
    return id
end 'nextId'

function nextSlot(counter RuntimeIdCounter) returns VarSlot
    let id = counter.nextId
    counter.nextId = counter.nextId + 1
    return id
end 'nextSlot'

// --- Build write_stdout ---
// write_stdout(ptr: i64, len: i64) -- paramCount=2
// Linux: syscall(writeNum, fd, ptr, len)
// Windows: GetStdHandle(STD_OUTPUT_HANDLE) -> handle; WriteFile(handle, ptr, len, &written, 0)

export function buildWriteStdout(osDesc OsDescriptor) returns MlirFunction
    var func = createMlirFunction(b"write_stdout", returnType: b"void")
    func.paramCount = 2
    var counter = RuntimeIdCounter{nextId: 0}

    // Param slots: 0 = ptr, 1 = len
    let ptrSlot = 0
    let lenSlot = 1

    var entry = addBlock(func.region, label: b"entry")

    match osDesc.write 'strategy'
        syscall(writeNum, fd) then buildWriteStdoutSyscall(entry, counter: counter, ptrSlot: ptrSlot, lenSlot: lenSlot, writeNum: writeNum, fd: fd)
        winApi(getHandleSlot, handleConstant, writeFileSlot) then buildWriteStdoutWinApi(entry, counter: counter, func: func, ptrSlot: ptrSlot, lenSlot: lenSlot, getHandleSlot: getHandleSlot, handleConstant: handleConstant, writeFileSlot: writeFileSlot)
    end 'strategy'

    // Return
    let zeroId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(zeroId, 0)))
    entry.terminator = MlirOp.func(FuncOp.ret(zeroId))
    entry.hasTerminator = true

    return func
end 'buildWriteStdout'

function buildWriteStdoutSyscall(entry MlirBlock, counter RuntimeIdCounter, ptrSlot VarSlot, lenSlot VarSlot, writeNum MachineWord, fd MachineWord)
    // Load ptr and len from param slots
    let ptrId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(ptrId, ptrSlot)))
    let lenId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(lenId, lenSlot)))

    // fd constant
    let fdId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(fdId, fd)))

    // syscall(writeNum, fd, ptr, len)
    let resultId = nextId(counter)
    var argIds = ValueIdArray{}
    argIds.push(fdId)
    argIds.push(ptrId)
    argIds.push(lenId)
    entry.ops.push(MlirOp.sys(SysOp.syscall(resultId, writeNum, argIds)))
end 'buildWriteStdoutSyscall'

function buildWriteStdoutWinApi(entry MlirBlock, counter RuntimeIdCounter, func MlirFunction, ptrSlot VarSlot, lenSlot VarSlot, getHandleSlot MachineWord, handleConstant MachineWord, writeFileSlot MachineWord)
    // Load ptr and len from param slots
    let ptrId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(ptrId, ptrSlot)))
    let lenId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(lenId, lenSlot)))

    // GetStdHandle(handleConstant)
    let handleConstId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(handleConstId, handleConstant)))
    let handleResultId = nextId(counter)
    var getHandleArgs = ValueIdArray{}
    getHandleArgs.push(handleConstId)
    entry.ops.push(MlirOp.sys(SysOp.iatCall(handleResultId, getHandleSlot, getHandleArgs)))

    // Store handle to a slot for WriteFile
    let handleSlot = 2
    entry.ops.push(MlirOp.memref(MemRefOp.storeSlot(handleSlot, handleResultId)))

    // bytesWritten = 0, stored to a slot for its address
    let zeroId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(zeroId, 0)))
    let writtenSlot = 3
    entry.ops.push(MlirOp.memref(MemRefOp.storeSlot(writtenSlot, zeroId)))

    // Get address of bytesWritten slot
    let writtenAddrId = nextId(counter)
    entry.ops.push(MlirOp.sys(SysOp.stackAddr(writtenAddrId, writtenSlot)))

    // NULL for lpOverlapped
    let nullId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(nullId, 0)))

    // Reload handle from slot
    let handleReloadId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(handleReloadId, handleSlot)))

    // WriteFile(handle, ptr, len, &bytesWritten, NULL)
    let writeResultId = nextId(counter)
    var writeArgs = ValueIdArray{}
    writeArgs.push(handleReloadId)
    writeArgs.push(ptrId)
    writeArgs.push(lenId)
    writeArgs.push(writtenAddrId)
    writeArgs.push(nullId)
    entry.ops.push(MlirOp.sys(SysOp.iatCall(writeResultId, writeFileSlot, writeArgs)))
end 'buildWriteStdoutWinApi'

// --- Build _start ---
// _start is the process entry point. It calls main() and then exits.
// It does NOT use standard function prologue/epilogue.
// On Windows, it needs shadow space before calling main.
// On Linux, it's minimal: call main, syscall exit.

export function buildStart(osDesc OsDescriptor) returns MlirFunction
    var func = createMlirFunction(b"_start", returnType: b"void")
    func.paramCount = 0

    var counter = RuntimeIdCounter{nextId: 0}
    var entry = addBlock(func.region, label: b"entry")

    // Call main() -- result in mainResultId
    let mainResultId = nextId(counter)
    var mainArgs = ValueIdArray{}
    entry.ops.push(MlirOp.func(FuncOp.call(mainResultId, b"main", mainArgs)))

    // Exit using the OS exit strategy
    match osDesc.exit 'exit'
        syscall(num) then buildExitSyscall(entry, counter: counter, exitCode: mainResultId, syscallNum: num)
        iatCall(slotIdx) then buildExitIatCall(entry, counter: counter, exitCode: mainResultId, slotIndex: slotIdx)
    end 'exit'

    // Unreachable terminator
    let deadId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(deadId, 0)))
    entry.terminator = MlirOp.func(FuncOp.ret(deadId))
    entry.hasTerminator = true

    return func
end 'buildStart'

function buildExitSyscall(block MlirBlock, counter RuntimeIdCounter, exitCode ValueId, syscallNum MachineWord)
    let resultId = nextId(counter)
    var argIds = ValueIdArray{}
    argIds.push(exitCode)
    block.ops.push(MlirOp.sys(SysOp.syscall(resultId, syscallNum, argIds)))
end 'buildExitSyscall'

function buildExitIatCall(block MlirBlock, counter RuntimeIdCounter, exitCode ValueId, slotIndex MachineWord)
    let resultId = nextId(counter)
    var argIds = ValueIdArray{}
    argIds.push(exitCode)
    block.ops.push(MlirOp.sys(SysOp.iatCall(resultId, slotIndex, argIds)))
end 'buildExitIatCall'

// --- Build i64_to_string ---
// i64_to_string(value: i64, buffer: i64) -> length: i64
// Converts an integer to its decimal string representation.
// Writes the result into buffer and returns the number of bytes written.
// Handles negative numbers and zero.

export function buildI64ToString() returns MlirFunction
    var func = createMlirFunction(b"i64_to_string", returnType: b"i64")
    func.paramCount = 2

    var counter = RuntimeIdCounter{nextId: 0}

    // Param slots: 0 = value, 1 = buffer_ptr
    let valueSlot = 0
    let bufferSlot = 1

    // We need a 21-byte work area on the stack for building digits in reverse.
    // Use slots 2..4 (24 bytes) as the work area.
    let workSlot = 2
    // is_negative flag
    let negFlagSlot = 5
    // current value being divided
    let curValueSlot = 6
    // work pointer (into work area, starts at end, moves backward)
    let workPtrSlot = 7

    // --- Entry block ---
    var entry = addBlock(func.region, label: b"entry")

    // Load value from param slot
    let valueId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(valueId, valueSlot)))

    // Check if value == 0
    let zeroConstId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(zeroConstId, 0)))
    let isZeroId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.cmpI64Eq(isZeroId, valueId, zeroConstId)))

    // Branch: if zero, go to zero_case; else go to check_negative
    let zeroBlockId = 1
    let checkNegBlockId = 2
    entry.terminator = MlirOp.cf(CfOp.condBr(isZeroId, zeroBlockId, checkNegBlockId))
    entry.hasTerminator = true

    // --- Zero case block ---
    var zeroBlock = addBlock(func.region, label: b"zero_case")

    // Load buffer ptr
    let bufPtrZeroId = nextId(counter)
    zeroBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(bufPtrZeroId, bufferSlot)))
    // Store '0' at buffer[0]
    let zeroOffId = nextId(counter)
    zeroBlock.ops.push(MlirOp.arith(ArithOp.constI64(zeroOffId, 0)))
    let charZeroId = nextId(counter)
    zeroBlock.ops.push(MlirOp.arith(ArithOp.constI64(charZeroId, 0x30)))
    zeroBlock.ops.push(MlirOp.sys(SysOp.storeByte(bufPtrZeroId, zeroOffId, charZeroId)))
    // Return 1
    let oneId = nextId(counter)
    zeroBlock.ops.push(MlirOp.arith(ArithOp.constI64(oneId, 1)))
    zeroBlock.terminator = MlirOp.func(FuncOp.ret(oneId))
    zeroBlock.hasTerminator = true

    // --- Check negative block ---
    var checkNegBlock = addBlock(func.region, label: b"check_neg")

    // is_negative = 0
    let negFalseId = nextId(counter)
    checkNegBlock.ops.push(MlirOp.arith(ArithOp.constI64(negFalseId, 0)))
    checkNegBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(negFlagSlot, negFalseId)))

    // Store current value
    let valueReloadId = nextId(counter)
    checkNegBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(valueReloadId, valueSlot)))
    checkNegBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(curValueSlot, valueReloadId)))

    // Check if value < 0
    let zeroId2 = nextId(counter)
    checkNegBlock.ops.push(MlirOp.arith(ArithOp.constI64(zeroId2, 0)))
    let isNegId = nextId(counter)
    checkNegBlock.ops.push(MlirOp.arith(ArithOp.cmpI64Lt(isNegId, valueReloadId, zeroId2)))

    let negateBlockId = 3
    let setupBlockId = 4
    checkNegBlock.terminator = MlirOp.cf(CfOp.condBr(isNegId, negateBlockId, setupBlockId))
    checkNegBlock.hasTerminator = true

    // --- Negate block ---
    var negateBlock = addBlock(func.region, label: b"negate")

    // Negate value
    let curValLoadId = nextId(counter)
    negateBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(curValLoadId, curValueSlot)))
    let negatedId = nextId(counter)
    negateBlock.ops.push(MlirOp.arith(ArithOp.negI64(negatedId, curValLoadId)))
    negateBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(curValueSlot, negatedId)))

    // Set is_negative = 1
    let negTrueId = nextId(counter)
    negateBlock.ops.push(MlirOp.arith(ArithOp.constI64(negTrueId, 1)))
    negateBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(negFlagSlot, negTrueId)))

    // Fall through to setup
    negateBlock.terminator = MlirOp.cf(CfOp.br(setupBlockId))
    negateBlock.hasTerminator = true

    // --- Setup block ---
    // Initialize work pointer to end of work area (slot 2 + 20 bytes = slot 2 base + 20)
    var setupBlock = addBlock(func.region, label: b"setup")

    let workBaseId = nextId(counter)
    setupBlock.ops.push(MlirOp.sys(SysOp.stackAddr(workBaseId, workSlot)))
    let twentyId = nextId(counter)
    setupBlock.ops.push(MlirOp.arith(ArithOp.constI64(twentyId, 20)))
    let workEndId = nextId(counter)
    setupBlock.ops.push(MlirOp.arith(ArithOp.addI64(workEndId, workBaseId, twentyId)))
    setupBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(workPtrSlot, workEndId)))

    // Store null terminator at work[20]
    let nullByteId = nextId(counter)
    setupBlock.ops.push(MlirOp.arith(ArithOp.constI64(nullByteId, 0)))
    let zeroOff2Id = nextId(counter)
    setupBlock.ops.push(MlirOp.arith(ArithOp.constI64(zeroOff2Id, 0)))
    setupBlock.ops.push(MlirOp.sys(SysOp.storeByte(workEndId, zeroOff2Id, nullByteId)))

    let digitLoopBlockId = 5
    setupBlock.terminator = MlirOp.cf(CfOp.br(digitLoopBlockId))
    setupBlock.hasTerminator = true

    // --- Digit loop block ---
    var digitBlock = addBlock(func.region, label: b"digit_loop")

    // workPtr = workPtr - 1
    let wpLoadId = nextId(counter)
    digitBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(wpLoadId, workPtrSlot)))
    let oneId2 = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.constI64(oneId2, 1)))
    let wpDecId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.subI64(wpDecId, wpLoadId, oneId2)))
    digitBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(workPtrSlot, wpDecId)))

    // Load current value
    let curId = nextId(counter)
    digitBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(curId, curValueSlot)))

    // remainder = curValue % 10
    let tenId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.constI64(tenId, 10)))
    let remId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.remI64(remId, curId, tenId)))

    // quotient = curValue / 10
    let quotId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.divI64(quotId, curId, tenId)))
    digitBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(curValueSlot, quotId)))

    // digit = remainder + '0'
    let charOffId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.constI64(charOffId, 0x30)))
    let digitCharId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.addI64(digitCharId, remId, charOffId)))

    // Store digit byte at workPtr
    let storeOffId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.constI64(storeOffId, 0)))
    digitBlock.ops.push(MlirOp.sys(SysOp.storeByte(wpDecId, storeOffId, digitCharId)))

    // Check if quotient > 0 -> continue loop
    let zeroId3 = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.constI64(zeroId3, 0)))
    let quotReloadId = nextId(counter)
    digitBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(quotReloadId, curValueSlot)))
    let notDoneId = nextId(counter)
    digitBlock.ops.push(MlirOp.arith(ArithOp.cmpI64Gt(notDoneId, quotReloadId, zeroId3)))

    let checkSignBlockId = 6
    digitBlock.terminator = MlirOp.cf(CfOp.condBr(notDoneId, digitLoopBlockId, checkSignBlockId))
    digitBlock.hasTerminator = true

    // --- Check sign block ---
    var checkSignBlock = addBlock(func.region, label: b"check_sign")

    // If is_negative, prepend '-'
    let negFlagLoadId = nextId(counter)
    checkSignBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(negFlagLoadId, negFlagSlot)))
    let zeroId4 = nextId(counter)
    checkSignBlock.ops.push(MlirOp.arith(ArithOp.constI64(zeroId4, 0)))
    let isNegFlagId = nextId(counter)
    checkSignBlock.ops.push(MlirOp.arith(ArithOp.cmpI64Gt(isNegFlagId, negFlagLoadId, zeroId4)))

    let prependMinusBlockId = 7
    let copyBlockId = 8
    checkSignBlock.terminator = MlirOp.cf(CfOp.condBr(isNegFlagId, prependMinusBlockId, copyBlockId))
    checkSignBlock.hasTerminator = true

    // --- Prepend minus block ---
    var minusBlock = addBlock(func.region, label: b"prepend_minus")

    // workPtr = workPtr - 1
    let wpLoad2Id = nextId(counter)
    minusBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(wpLoad2Id, workPtrSlot)))
    let oneId3 = nextId(counter)
    minusBlock.ops.push(MlirOp.arith(ArithOp.constI64(oneId3, 1)))
    let wpDec2Id = nextId(counter)
    minusBlock.ops.push(MlirOp.arith(ArithOp.subI64(wpDec2Id, wpLoad2Id, oneId3)))
    minusBlock.ops.push(MlirOp.memref(MemRefOp.storeSlot(workPtrSlot, wpDec2Id)))

    // Store '-' at workPtr
    let minusCharId = nextId(counter)
    minusBlock.ops.push(MlirOp.arith(ArithOp.constI64(minusCharId, 0x2D)))
    let storeOff2Id = nextId(counter)
    minusBlock.ops.push(MlirOp.arith(ArithOp.constI64(storeOff2Id, 0)))
    minusBlock.ops.push(MlirOp.sys(SysOp.storeByte(wpDec2Id, storeOff2Id, minusCharId)))

    minusBlock.terminator = MlirOp.cf(CfOp.br(copyBlockId))
    minusBlock.hasTerminator = true

    // --- Copy block ---
    // Compute length = (workBase + 20) - workPtr
    // memcpy(buffer, workPtr, length)
    // Return length
    var copyBlock = addBlock(func.region, label: b"copy")

    let workBase2Id = nextId(counter)
    copyBlock.ops.push(MlirOp.sys(SysOp.stackAddr(workBase2Id, workSlot)))
    let twenty2Id = nextId(counter)
    copyBlock.ops.push(MlirOp.arith(ArithOp.constI64(twenty2Id, 20)))
    let workEnd2Id = nextId(counter)
    copyBlock.ops.push(MlirOp.arith(ArithOp.addI64(workEnd2Id, workBase2Id, twenty2Id)))

    let wpLoad3Id = nextId(counter)
    copyBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(wpLoad3Id, workPtrSlot)))
    let lengthId = nextId(counter)
    copyBlock.ops.push(MlirOp.arith(ArithOp.subI64(lengthId, workEnd2Id, wpLoad3Id)))

    // Load buffer ptr
    let bufPtrId = nextId(counter)
    copyBlock.ops.push(MlirOp.memref(MemRefOp.loadSlot(bufPtrId, bufferSlot)))

    // memcpy(buffer, workPtr, length)
    copyBlock.ops.push(MlirOp.sys(SysOp.memcpy(bufPtrId, wpLoad3Id, lengthId)))

    // Return length
    copyBlock.terminator = MlirOp.func(FuncOp.ret(lengthId))
    copyBlock.hasTerminator = true

    return func
end 'buildI64ToString'

// --- Build __rt_printInt ---
// __rt_printInt(value: i64)
// Converts value to string using i64_to_string, then prints via write_stdout.
// Uses a stack slot as the string buffer.

export function buildPrintInt() returns MlirFunction
    var func = createMlirFunction(b"__rt_printInt", returnType: b"void")
    func.paramCount = 1

    var counter = RuntimeIdCounter{nextId: 0}

    // Param slot: 0 = value
    let valueSlot = 0
    // Buffer slot: use slots 1..3 (24 bytes) as string buffer
    let bufferSlot = 1

    var entry = addBlock(func.region, label: b"entry")

    // Load value
    let valueId = nextId(counter)
    entry.ops.push(MlirOp.memref(MemRefOp.loadSlot(valueId, valueSlot)))

    // Get buffer address
    let bufAddrId = nextId(counter)
    entry.ops.push(MlirOp.sys(SysOp.stackAddr(bufAddrId, bufferSlot)))

    // Call i64_to_string(value, bufAddr) -> length
    let lenResultId = nextId(counter)
    var toStrArgs = ValueIdArray{}
    toStrArgs.push(valueId)
    toStrArgs.push(bufAddrId)
    entry.ops.push(MlirOp.func(FuncOp.call(lenResultId, b"i64_to_string", toStrArgs)))

    // Call write_stdout(bufAddr, length)
    // Reload bufAddr since it may have been clobbered
    let bufAddr2Id = nextId(counter)
    entry.ops.push(MlirOp.sys(SysOp.stackAddr(bufAddr2Id, bufferSlot)))

    let writeResultId = nextId(counter)
    var writeArgs = ValueIdArray{}
    writeArgs.push(bufAddr2Id)
    writeArgs.push(lenResultId)
    entry.ops.push(MlirOp.func(FuncOp.call(writeResultId, b"write_stdout", writeArgs)))

    // Return
    let zeroId = nextId(counter)
    entry.ops.push(MlirOp.arith(ArithOp.constI64(zeroId, 0)))
    entry.terminator = MlirOp.func(FuncOp.ret(zeroId))
    entry.hasTerminator = true

    return func
end 'buildPrintInt'

// --- Build all runtime functions ---
// Returns an array of MlirFunctions to prepend to the module.

export function buildRuntimeFunctions(osDesc OsDescriptor) returns MlirFunctionArray
    var funcs = MlirFunctionArray{}
    // _start must come first since the entry point is at the beginning of the code.
    funcs.push(buildStart(osDesc))
    funcs.push(buildWriteStdout(osDesc))
    funcs.push(buildI64ToString())
    funcs.push(buildPrintInt())
    return funcs
end 'buildRuntimeFunctions'

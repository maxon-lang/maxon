// Project type: encapsulates all per-project compilation state.
// Each project has its own query database, value ID counter, and parser state.
// This enables multiple projects to be compiled independently (e.g., in an LSP server).

// Bounded counter for `--dump-stages` filenames. Comfortable upper bound —
// the full native pipeline runs ~20 passes today.
export typealias DumpPassCounter = int(0 to 1024)

// Stage B (closures): unbounded counter for the `_$closure_<N>` name
// suffix. There is no concrete upper bound on the number of closures a
// project may declare, so the wide `0 to u64.max` range is appropriate.
export typealias ClosureCounter = int(0 to u64.max)

// Configuration for `--emit-ir` / `--dump-stages`. Disables query-cache fast
// paths when active so every compile observes the full pipeline, and carries
// the per-pass filename counter. Grouped into a struct so the rest of the
// compiler passes a single value around instead of three loose fields.
export type IrDumpOptions
	// True when `--emit-ir` is active.
	export var emitFinal bool
	// Base path for `--dump-stages`. Empty when disabled. When non-empty, the
	// pipeline writes `{base}.NN-passName.phase.ir` after every pass.
	export var stagesBasePath String
	// Monotonic counter for `--dump-stages` filenames. Starts at 1 and
	// increments once per pass dump so filenames are ordered across
	// queryAllMid, the backend pipeline, and the final target-lowering dump.
	export var passCounter DumpPassCounter

	export static function disabled() returns IrDumpOptions
		return Self{emitFinal: false, stagesBasePath: "", passCounter: 1}
	end 'disabled'

	// True when any form of IR dumping is active. Callers use this to bypass
	// the query cache so every pass (and the final IR render) runs against a
	// freshly-computed module instead of a cached memo.
	export function enabled() returns bool
		return emitFinal or not stagesBasePath.isEmpty()
	end 'enabled'

	// True when per-pass stage dumps are requested.
	export function stagesEnabled() returns bool
		return not stagesBasePath.isEmpty()
	end 'stagesEnabled'
end 'IrDumpOptions'

// Visibility tier for a top-level declaration. Three tiers match the
// language reference:
//   - `file`: visible only inside the declaring file. The default
//     when a decl carries no visibility modifier.
//   - `module`: visible from any file in the directory subtree
//     rooted at the declaring file's directory. Source: the contextual
//     `module` keyword that precedes the decl token.
//   - `exported`: visible everywhere. Source: the `export` keyword.
//
// Stored on every resolved/unresolved decl entry so visibility-aware
// lookup can filter candidates against the reading file's path. Until
// this enum landed, the self-hosted compiler treated every decl as
// `exported` regardless of modifier.
export enum Visibility
	file
	module
	global
end 'Visibility'

// True when a decl declared in `declFilePath` (with the given visibility
// tier) is visible from the file at `readerFilePath`. The two paths are
// absolute / virtual paths as the parser stamped them at decl time.
//
// Tier rules:
//   - file: declFilePath must equal readerFilePath
//   - module: readerFilePath must live under declFilePath's parent
//     directory (or in that directory itself)
//   - global: always visible
export function isVisibleFrom(visibility Visibility, declFilePath FilePath, readerFilePath FilePath) returns bool
	match visibility 'tier'
		global then return true
		file then return declFilePath.toString() == readerFilePath.toString()
		module then return readerFileIsInModuleSubtree(declFilePath, readerFilePath: readerFilePath)
	end 'tier'
end 'isVisibleFrom'

// True when `readerFilePath` lives in the same directory as `declFilePath`
// or any descendant directory. The check compares stringified parent
// paths: the reader's parent must start with the declarer's parent
// (followed by either end-of-string or a path separator) so a sibling
// directory whose name happens to share a prefix doesn't match.
function readerFileIsInModuleSubtree(declFilePath FilePath, readerFilePath FilePath) returns bool
	let declDir = try declFilePath.parent() otherwise return declFilePath.toString() == readerFilePath.toString()
	let readerDir = try readerFilePath.parent() otherwise return false
	let declDirStr = declDir.toString()
	let readerDirStr = readerDir.toString()
	if readerDirStr == declDirStr 'sameDir'
		return true
	end 'sameDir'
	// Subtree match: readerDir must start with declDir + native separator
	// so a directory name that shares a prefix (`foo/` vs `foobar/`)
	// doesn't false-positive. FilePath normalizes paths to the platform
	// separator on construction, so we use the same separator here.
	let prefix = "{declDirStr}{FilePath.separator()}"
	return readerDirStr.startsWith(prefix)
end 'readerFileIsInModuleSubtree'

export type Project
	// Query database (incremental compilation cache)
	export var db QueryDatabase

	// Type-name interner. MaxonType.named carries a TypeNameId into this table
	// instead of a raw String, so identical type references (`Count`, `String`,
	// `Integer`, …) share a single backing allocation.
	export var typeNames TypeNameInterner

	// Callee-name interner. Every emitted maxon.call op carries the callee name
	// as a ByteArray; this table caches one ByteArray per name so the parser
	// stops re-allocating the same bytes for hot stdlib callees on every call.
	export var calleeNames CalleeNameInterner

	// String-literal interner. Every string literal the parser sees is
	// interned at parse time and the IR carries the resulting StringId
	// instead of raw bytes. Identical literals across files dedupe to a
	// single id; cross-file string-constant references resolve by id at
	// TypeResolution time. Lowering reads the bytes back via
	// `strings.get(id)` when emitting the runtime payload.
	export var strings StringInterner

	// Typealias registry: maps alias names to their IR base type ("i64", "f64", etc.)
	// Populated by the TypeResolution pass as it drains unresolvedTypealiases.
	// Read by lowering and the range-check pass; never written to directly by
	// the parser.
	export var typealiases TypealiasMap

	// Typealias visibility sidecar: maps alias names to their declared
	// visibility tier and source file path. Populated alongside
	// `typealiases` by the TypeResolution drain. Lookups treat a missing
	// key as `(global, stdlibBootstrapPath)` so stdlib aliases (which
	// aren't serialized through the cache visibility-side) stay reachable.
	export var typealiasVisibilities TypealiasVisibilityMap

	// Typealias range bounds: maps alias names to their (lower, upper) bounds.
	// Used by the parser to emit runtime range checks on return values.
	// Populated by the TypeResolution pass alongside `typealiases`.
	export var typealiasRanges TypealiasRangeMap

	// Typealias cast category: maps alias names to the user-declared cast
	// family (int / byte / float). Populated by the TypeResolution pass for
	// ranged-primitive aliases so storage narrowing (e.g. `int(0 to 255)` →
	// u8) doesn't flip the alias into a different cast category. Aliases
	// without an entry derive their category from their resolved StdType.
	export var typealiasCastCategories TypealiasCastCategoryMap

	// Unresolved typealias registry: every `typealias Name = ...` the parser
	// sees lands here first. The TypeResolution pass runs a fixed-point loop
	// over this map, moving each entry into `typealiases` (and
	// `typealiasRanges` when applicable) once its right-hand side resolves.
	// Entries that remain after the loop terminates are reported as either
	// unknown-name or cycle errors and dropped.
	export var unresolvedTypealiases UnresolvedTypealiasMap

	// Function return type registry: maps qualified function names to their return type names
	export var funcReturnTypes FuncReturnTypeMap

	// Maps qualified function names to their throws-clause error type name.
	// Empty string means non-throwing. Populated by the parser at decl time;
	// read by checkErrorHandlingRules to validate try/otherwise usage.
	export var funcThrowsTypes FuncThrowsTypeMap

	// Function visibility sidecar: maps qualified function names to their
	// declared visibility tier and source file path. Populated alongside
	// `funcReturnTypes` inserts in the parser. Lookups treat a missing
	// key as `(global, stdlib bootstrap path)` so stdlib-cached functions
	// (which the cache codec doesn't serialize visibility for) stay
	// reachable from any user file.
	export var funcVisibilities FuncVisibilityMap

	// Method-name index: maps a bare method name (the trailing segment after
	// the last '.') to the list of qualified function names that end in
	// `.{methodName}`. Maintained alongside funcReturnTypes inserts so DFE's
	// methodCall handling can mark every candidate in O(matches) instead of
	// scanning the full funcReturnTypes map (O(N) per methodCall, O(K*N)
	// across the function).
	export var methodNameIndex MethodNameIndex

	// Function signature registry: parameter names and optional integer default
	// values. Keyed by the same qualified function name as funcReturnTypes.
	// Default values are currently limited to integer literals; omitted
	// parameters without a default are a compile error at the call site.
	export var funcSignatures FuncSignatureMap

	// Per-call-site substituted paramTypes — the FuncSignature's declared
	// paramTypes resolved against each call's enclosing-struct innerAliases
	// + receiver's genericInstance arg bindings. Populated by TypeResolution
	// after the regular fillCall/fillMethodCall pass and asserted to contain
	// no `typeParameter` / unresolved arms before lowering runs. Keyed by
	// the OpIndex of the call/methodCall op. Lowering reads this directly;
	// no substitution work happens after TypeResolution finishes.
	export var callParamTypes CallParamTypesMap

	// Per-call-site resolved callee name (post typealias chase + overload
	// disambiguation). Populated by the same TypeResolution pass that fills
	// `callParamTypes`; consumed by LowerMaxonToStd to skip the resolver
	// chain. Missing entries mean the resolver bailed (interface stub path).
	export var resolvedCallees ResolvedCalleesMap

	// Per-call-site resolved receiver type. Populated by `resolveAllCalls`
	// alongside `resolvedCallees`; carries the genericInstance shape the
	// receiver typealias chased to (e.g. `ByteArray.init(...)` records
	// `genericInstance(Array, [Byte])` here so lowering's
	// `materializeLayoutArg` can pick the right concrete or conditional
	// layout descriptor). Free non-generic calls don't insert.
	export var resolvedReceiverTypes ResolvedReceiverTypesMap

	// Minimal first-param overload registry. When the parser detects a
	// duplicate qualified function name and the two functions differ in their
	// first non-`self` parameter type, both functions are re-keyed under
	// mangled names (`Array.contains` -> `Array.contains$Element`,
	// `Array.contains$Array_Element`) and this map records the bare ->
	// variants mapping. Call-site resolution (lowerCall, lowerMethodCall,
	// callResultType, methodCallResultType) consults this map before falling
	// back to the bare lookup so an overloaded callee dispatches to the
	// matching mangled name. Non-overloaded callees never appear here and
	// pay nothing on the lookup path. Real duplicates (same first-param-type
	// suffix) still report E2001.
	export var overloadedNames OverloadedNameMap

	// Top-level constants (compile-time evaluated string and integer values)
	export var topLevelConstants ConstantMap

	// Pending top-level bindings — both immutable `let` constants (which
	// drain into `topLevelConstants`) and mutable `var` / `static var/let`
	// globals (which drain into `topLevelVars`). Each entry's `mutable` flag
	// picks the destination at drain time. The TypeResolution pass walks
	// the map with DFS + a visiting stack so let-references between entries
	// resolve in dependency order; cycles are reported as E2012.
	// Readers that ask "is this name a known let?" need to consult this
	// map alongside `topLevelConstants` since the resolved value moves out
	// once it lands in the destination.
	export var unresolvedTopLevelDecls UnresolvedTopLevelDeclMap

	// Flat arena of expression nodes referenced by UnresolvedTopLevelDecl
	// entries via UnresolvedConstExprId. Shared project-wide because
	// cross-file `export let` references resolve through the same id space.
	export var unresolvedConstExprs UnresolvedConstExprArray

	// Mutable top-level vars (`var` at module scope) and `static var/let`
	// fields. The map key is the qualified name used at the source level
	// (`counter` for a top-level var, `Counter.count` for a static field).
	// Writable storage in the .data section is sized one 8-byte slot per
	// entry. Export visibility is a separate axis tracked elsewhere — this
	// registry holds entries from every visibility tier.
	export var topLevelVars TopLevelVarMap

	// Per-file synthetic module-init function names, in file-discovery order.
	// Empty when no file has a deferred (array-literal) top-level initializer.
	// `mrt_start` calls these sequentially before `main`. Each parser instance
	// allocates one `__module_init_<n>` function lazily on the first top-level
	// array-literal initializer it sees.
	export var moduleInitFuncs StringArray

	// Qualified names of top-level `let xs = [...]` bindings whose array-literal
	// init lands in `topLevelVars` (writable .data slot) rather than in
	// `topLevelConstants`. The reassignment-rewrite path keys off this set to
	// keep firing E2013 for source-level `xs = ...` writes — without it, the
	// `topLevelVars` arm would silently rewrite the unresolvedAssign as a
	// globalStore.
	export var immutableArrayLitNames StringArray

	// Struct type registry: maps type names to field layouts.
	// Populated by the TypeResolution pass as it drains unresolvedStructTypes.
	// Read by lowering and downstream validation; never written to directly by
	// the parser.
	export var structTypes StructTypeMap

	// Unresolved struct registry: every `type Name ... end` the parser sees
	// lands here first. The TypeResolution pass moves each entry into
	// `structTypes` before any pass that consumes struct layouts runs.
	export var unresolvedStructTypes UnresolvedStructTypeMap

	// Phase 11.0 step 4: parser-recorded `extension TargetType ... end`
	// blocks. Method bodies inside each extension are registered as
	// qualified `TargetType.methodName` callees at parse time; this
	// registry only stores per-extension metadata (added conformances,
	// where-clauses, type-parameter rebindings) for later resolution.
	// Multiple extensions may target the same type, so this is an array
	// rather than a map.
	export var unresolvedExtensions UnresolvedExtensionArray

	// Enum type registry: maps enum names to their case lists. Populated by
	// the TypeResolution pass as it drains `unresolvedEnums`. Each enum's
	// cases are also registered as top-level integer constants
	// (`{EnumName}.{caseName}`), which is how `EnumName.case` references
	// resolve through the existing `unresolvedRead → literal` rewrite.
	export var enumTypes EnumTypeMap

	// Unresolved enum registry: every `enum Name ... end` the parser sees lands
	// here first. The TypeResolution pass drains it into `enumTypes` before
	// passes that consume enum layouts run.
	export var unresolvedEnums UnresolvedEnumTypeMap

	// Unresolved interface registry: every `interface Name ... end` the parser
	// sees lands here first. Phase 3 of the interfaces plan drains it into
	// `interfaces` once every referenced name is known.
	export var unresolvedInterfaces UnresolvedInterfaceMap

	// Resolved interface registry. Populated by TypeResolution's
	// `resolveAllInterfaces` drain. Keyed by the source-level interface name.
	// Conforming-type substitution reads off this map; the C# bootstrap
	// stores method signatures with `Element`-style type-parameter names
	// unsubstituted and substitutes at the conformance site, and we mirror
	// that pattern.
	export var interfaces IrInterfaceMap

	// Function-type interner. Every `(P1, P2) returns R` signature the parser
	// sees in a parameter position lands here as a parallel-array entry; the
	// `MaxonType.function(id)` arm is just a stable index into this registry.
	// Interning by structural identity means two parameters declared with the
	// same shape share an id, so downstream equality checks on
	// `MaxonType.function` reduce to integer compare.
	export var functionTypes FunctionTypeRegistry

	// Phase 11.0: type-parameter registry. Keyed by the
	// (declaringTypeName, paramName) pair the parser collected while walking
	// a generic `type Foo uses Element` (or `extension`/`function`) header.
	// Stores the constraint set as a list of interface names — initially
	// empty; populated when a `where` clause names the constraint set. The
	// `MaxonType.typeParameter(id)` arm is a stable index into this table.
	export var typeParameters TypeParamRegistry

	// Phase 11.0: generic-instance interner. Every distinct `Base with (Args)`
	// MaxonType the parser produces lands here as a parallel-array entry; the
	// `MaxonType.genericInstance(baseId, args)` arm carries the args inline,
	// but downstream consumers that want a stable id (Phase 11.2 layout
	// descriptors, Phase 11.3 witness tables) intern through this registry.
	// For Phase 11.0 the registry primarily exists so the parser-AST surface
	// has a place to record observed instances.
	export var genericInstances GenericInstanceRegistry

	// Phase 11.0: conformance registry. Keyed by (typeName, interfaceName).
	// Stores the source-level `with` arguments captured by the parser at the
	// `implements` clause; later phases will fill in resolved methodImpls and
	// the witness-table label. Phase 11.0 only seeds the keys.
	export var conformances ConformanceRegistry

	// Parser → TypeResolution sidecar describing each array literal's
	// structural pieces. The parser collects only IR-shape information
	// (the array type's name, the value names of `__mm` and `__arr`, the
	// per-element value names); TypeResolution unifies the elements'
	// already-recorded producer types, interns the matching
	// `genericInstance(...)` arms, and writes them as the producer types
	// for `__mm` and `__arr`. Each literal's entry is registered under
	// both `(funcName, mmResultName)` and `(funcName, initResultName)`
	// so the create- and init-resolution paths each get an O(1) lookup.
	export var arrayLiteralProducers ArrayLiteralProducerMap

	// Parallel sidecar for map literals (`[k: v, ...]`). The parser emits two
	// __ManagedMemory.create + setLength sequences (one per axis) and then a
	// `<mapType>.init(keyMm, valueMm)` call. The per-axis __mm names also live
	// in arrayLiteralProducers so the key/value-axis types resolve through the
	// same single-arg `genericInstance(__ManagedMemory, [...])` path used by
	// array literals; this map only carries the final init-result entry so
	// the user-visible map value gets the matching `genericInstance(<mapType>,
	// [Key, Value])` type binding.
	export var mapLiteralProducers MapLiteralProducerMap

	// Phase 11.0 step 2: project-wide table of resolved generic typealiases.
	// Generic aliases (`typealias E = Base with(...)`) cannot live in
	// `typealiases TypealiasMap` (StdType-typed) because their resolved form
	// is a `MaxonType.genericInstance(...)`. The drain in TypeResolution
	// promotes `UnresolvedTypeExpr.genericAlias(...)` into entries here.
	export var genericTypealiases GenericTypealiasMap

	// Phase 11.0: parallel registry of interface-typed value identifiers.
	// `MaxonType.interface(id)` carries an InterfaceTypeId into this table;
	// the table maps id back to the source-level interface name. Distinct
	// from `interfaces IrInterfaceMap` (which is keyed by name and stores the
	// resolved declaration). Interning by name means two `interface Iterable`
	// arms share an id so structural equality reduces to integer compare.
	export var interfaceRegistry InterfaceTypeRegistry

	// Stage B (closures): monotonic counter used to mint unique
	// `_$closure_<N>` names for lifted closure bodies. Per-project rather
	// than per-module so cross-file uniqueness holds even when closures
	// from multiple files land in the same merged module. Bumped once per
	// `parseClosure` invocation; the parser never decrements.
	export var closureCounter ClosureCounter

	// Per-project counter for cast-site range-check label minting
	// (`__cast_panic_N`, `__cast_ok_N`, `__cast_check_lo_N`). Bumped once
	// per expanded `castCheck` op in `expandCastRangeChecks`. Reset is
	// not needed across compiles — the counter just produces unique
	// labels per run.
	export var castCheckCounter ParsedInt

	// Phase 15e: map each `__TupleN` structAlloc's result name to the
	// fully-specialised `genericInstance(__TupleN, [T0..TN])` interned by
	// the parser. lowerStructAlloc consults this so the receiver's lowering
	// value-type is the gi instead of the bare `named(__TupleN)`, which lets
	// downstream fieldLoad/fieldStore substitute `_TN` typeParameter fields
	// through to their concrete arg types (essential for mixed int/float
	// tuples where the field's width / SSE-register-ness depends on the
	// resolved arg type).
	export var tupleAllocGids TupleAllocGidMap

	// Project metadata
	export var rootPath FilePath
	// Compilation target
	export var target Target

	// Collected diagnostics (errors reported during compilation)
	export var diagnostics DiagnosticArray

	// Global data table for string literals and other read-only data.
	// Populated during Maxon->Mid lowering when string-producing ops are lowered.
	export var globalData GlobalDataTable

	// True when coverage instrumentation should run. Gates the
	// InstrumentCoverage pass, the coverage-aware runtime augmentation, and
	// registration of the __data_cov_* globals. Defaults to false so a plain
	// build of any project is unchanged by the coverage machinery.
	export var coverageEnabled bool

	// Populated by the InstrumentCoverage pass: one CovSite per instrumented
	// block. Chunk E serializes this to a .covmap file next to the executable;
	// Chunk D only builds the in-memory table.
	export var covSites CovSiteTable

	// IR dump configuration (`--emit-ir` and `--dump-stages`). The pipeline and
	// the query layer consult `irDump.enabled()` to bypass cache fast paths so
	// every pass runs against a freshly-computed module.
	export var irDump IrDumpOptions

	// Phase 11.2: per-`GenericInstanceId` mangled label of the emitted
	// 56-byte rdata layout descriptor. Filled by BuildLayoutDescriptors;
	// read by Phase 11.4 lowering when materializing a descriptor at a
	// generic call site.
	export var layoutDescriptors LayoutDescriptorRegistry

	// Phase 11.3: per-`(typeName, interfaceName)` resolved witness table
	// (label, ordered method-impl names, fat-pointer flag, optional
	// `extends` parent label). Filled by BuildWitnessTables; read by
	// Phase 11.4 lowering when constructing an interface-typed value or
	// dispatching through a witness.
	export var witnessTables WitnessTableRegistry

	// Definite roots — function names the DFE must keep alive even when no
	// statically-named `call` op reaches them. After Stage K.4, this is
	// restricted to runtime-called entry points like `__module_init_<namespace>`
	// that the runtime invokes before `main` and that no Std-level op names.
	// Witness-table method impls and layout-descriptor copy/destroy thunks
	// moved to `witnessConditionalRoots` (their liveness is now contingent
	// on the owning rdata blob's label being demanded by a `loadWitnessTable`
	// / `loadLayoutDescriptor` op).
	export var livenessRoots StringArray

	// Stage K.4: witness-conditional roots — keyed by the rdata label of a
	// witness table (`__witness_<type>_<iface>` / `__witness_<gid>_<iface>`)
	// or a layout descriptor (`__layout_<gid>`); value is the list of
	// function names whose liveness is contingent on that label being
	// demanded by a `loadWitnessTable` / `loadLayoutDescriptor` op in a
	// live function. Std-DFE promotes entries here onto its worklist the
	// moment it sees a demand op for the corresponding label, so
	// witness-impl bodies and layout copy/destroy thunks stay alive
	// exactly when the rdata blob they back is actually loaded by user
	// code.
	export var witnessConditionalRoots WitnessConditionalRootsMap

	// Phase 11.4: per-function shape of synthetic trailing params that the
	// Maxon→Std lowering injects when the body is a generic — a layout slot
	// plus one witness slot per where-clause `(typeParam, interface)` pair.
	// Populated during `transferFuncs` alongside
	// `IrFunction.hasImplicitLayoutParam`/`implicitWitnessConstraints`, persisted
	// through the stdlib cache so cache-hit user builds see the same shape a
	// fresh-from-source build would. Read by `emitCallWithArgs` to decide
	// whether to append synthetic args at a call site — using a project-wide
	// map instead of a local `stdModule.functions` scan so the per-function
	// pipeline (where stdlib functions aren't in the local module) still gets
	// the right arity.
	//
	// On x64 the prior local-scan implementation was a silent ABI bug for
	// stdlib generics: callees like `Array.init` whose bodies don't read the
	// implicit layout slot worked by accident; any generic body that did read
	// it would have consumed garbage. On wasm the validator surfaced the bug
	// as `expected i64 but nothing on stack`. The map-based lookup here is
	// the proper architectural fix.
	export var genericFunctionImplicitArity GenericFunctionImplicitArityMap

	// Phase 11.2: emitted rdata blob bytes keyed by mangled label. The
	// canonicalize pass (11.6) folds `descriptorField` reads of a known
	// label into a constant when this map carries the bytes — that's the
	// primary mechanism by which inlined generic bodies recover
	// monomorphization-quality codegen.
	export var staticRdataValues StaticRdataValueMap

	// Constant-array-to-rdata fast path. Populated by the
	// `runConstantArrayLiteralRdata` pass; consumed by the lowering hook
	// at `__ManagedMemory.create`. See ConstantArrayRdataInfo for details.
	export var constantArrayRdata ConstantArrayRdataMap

	// Phase 11.4 follow-up: per-instance witness-method thunks that
	// `BuildWitnessTables` recorded for this pipeline run.
	// `lowerMaxonToStd.synthesizeWitnessThunks` reads this list to know
	// which `(gid, interfaceName)` pairs the run owns vs. which ones came
	// out of the stdlib cache (already compiled into stdlib's object code).
	// Not cache-persisted: the next pipeline run rebuilds it from its own
	// gid/conformance walk.
	export var pendingWitnessThunkGids GenericInstanceIdArray
	export var pendingWitnessThunkInterfaces StringArray

	// Phase 11.7: deferred where-clause checks for generic typealias
	// instantiations. Populated during typealias drain (when conformances
	// haven't been recorded yet) and drained after `validateConformances`
	// finishes. Each entry pins a (typealiasName, expr, source location)
	// triple — an E3017 is emitted per failing constraint.
	export var pendingConstraintChecks PendingConstraintCheckArray

	// Deferred unused-variable checks (E3012). The parser pushes one entry
	// per function — capturing parameter and local declarations seen in the
	// body — but doesn't run the actual check at parse time, since later
	// passes (TypeResolution's E3009 cast-error path, primarily) may emit
	// errors for the same body that would otherwise be obscured by a
	// premature E3012. SemanticCheck drains this list and emits one E3012
	// per function, skipping any function whose source file already carries
	// a diagnostic.
	export var pendingUnusedChecks PendingUnusedCheckArray

	// Provenance for char-byte literals — see `CharByteLiteralSet` for the why.
	// Populated by the parser at every single-byte char-literal site and
	// expanded by TypeResolution's producer-types walk through varDecl/varLoad
	// chains so consumers can recover char-ness at use sites.
	export var charByteLiterals CharByteLiteralSet

	// J.4b: per-receiver monomorphization cache for user-declared
	// interface-extension methods. Keyed by `{receiverType}::{ifaceCallee}`
	// so a repeated `intList.has(...)` site picks up the already-cloned
	// `IntList.has` function instead of synthesizing a duplicate.
	export var monomorphCache MonomorphCache

	// J.4b: per-method where-clause sidecar. Keyed by `<iface>.<method>`
	// (the qualified callee name used everywhere else); value is the
	// extension block's `whereClauses` snapshot recorded at parse time.
	// An empty array means the method was declared by an unconditional
	// extension (or an interface body that doesn't carry constraints).
	// Used by `resolveMethodCallSite` to surface E4006 when a conditional
	// extension's constraints aren't satisfied by the call site's
	// receiver bindings.
	export var extensionMethodWhereClauses WhereClauseMapByName

	// Stage B (closures): hand out the next unique `_$closure_<N>` suffix
	// and bump the counter. Called by the parser at every closure
	// expression to keep lifted-function names disjoint.
	export function nextClosureId() returns ClosureCounter
		let id = closureCounter
		closureCounter = closureCounter + 1
		return id
	end 'nextClosureId'

	export static function create(db QueryDatabase, rootPath FilePath, target Target) returns Project
		return Self{
			db: db,
			typeNames: TypeNameInterner.create(),
			calleeNames: CalleeNameInterner.create(),
			strings: StringInterner.create(),
			typealiases: TypealiasMap.create(),
			typealiasVisibilities: TypealiasVisibilityMap.create(),
			typealiasRanges: TypealiasRangeMap.create(),
			typealiasCastCategories: TypealiasCastCategoryMap.create(),
			unresolvedTypealiases: UnresolvedTypealiasMap.create(),
			funcReturnTypes: FuncReturnTypeMap.create(),
			funcThrowsTypes: FuncThrowsTypeMap.create(),
			funcVisibilities: FuncVisibilityMap.create(),
			methodNameIndex: MethodNameIndex.create(),
			funcSignatures: FuncSignatureMap.create(),
			callParamTypes: CallParamTypesMap.create(),
			resolvedCallees: ResolvedCalleesMap.create(),
			resolvedReceiverTypes: ResolvedReceiverTypesMap.create(),
			overloadedNames: OverloadedNameMap.create(),
			topLevelConstants: ConstantMap.create(),
			unresolvedTopLevelDecls: UnresolvedTopLevelDeclMap.create(),
			unresolvedConstExprs: UnresolvedConstExprArray.create(),
			topLevelVars: TopLevelVarMap.create(),
			moduleInitFuncs: StringArray.create(),
			immutableArrayLitNames: StringArray.create(),
			structTypes: StructTypeMap.create(),
			unresolvedStructTypes: UnresolvedStructTypeMap.create(),
			unresolvedExtensions: UnresolvedExtensionArray.create(),
			enumTypes: EnumTypeMap.create(),
			unresolvedEnums: UnresolvedEnumTypeMap.create(),
			unresolvedInterfaces: UnresolvedInterfaceMap.create(),
			interfaces: IrInterfaceMap.create(),
			functionTypes: FunctionTypeRegistry.create(),
			typeParameters: TypeParamRegistry.create(),
			genericInstances: GenericInstanceRegistry.create(),
			conformances: ConformanceRegistry.create(),
			arrayLiteralProducers: ArrayLiteralProducerMap.create(),
			mapLiteralProducers: MapLiteralProducerMap.create(),
			genericTypealiases: GenericTypealiasMap.create(),
			interfaceRegistry: InterfaceTypeRegistry.create(),
			closureCounter: 0,
			castCheckCounter: 0,
			tupleAllocGids: TupleAllocGidMap.create(),
			rootPath: rootPath,
			target: target,
			diagnostics: DiagnosticArray.create(),
			globalData: createGlobalDataTable(),
			coverageEnabled: false,
			covSites: CovSiteTable.create(),
			irDump: IrDumpOptions.disabled(),
			layoutDescriptors: LayoutDescriptorRegistry.create(),
			witnessTables: WitnessTableRegistry.create(),
			livenessRoots: StringArray.create(),
			witnessConditionalRoots: WitnessConditionalRootsMap.create(),
			genericFunctionImplicitArity: GenericFunctionImplicitArityMap.create(),
			staticRdataValues: StaticRdataValueMap.create(),
			constantArrayRdata: ConstantArrayRdataMap.create(),
			pendingWitnessThunkGids: GenericInstanceIdArray.create(),
			pendingWitnessThunkInterfaces: StringArray.create(),
			pendingConstraintChecks: PendingConstraintCheckArray.create(),
			pendingUnusedChecks: PendingUnusedCheckArray.create(),
			charByteLiterals: CharByteLiteralSet.create(),
			monomorphCache: MonomorphCache.create(),
			extensionMethodWhereClauses: WhereClauseMapByName.create()
		}
	end 'create'
end 'Project'

// Phase 11.4: per-generic-function shape of synthetic trailing params.
// `hasLayout` is true iff the function takes an implicit layout-descriptor
// slot. `witnessConstraints` lists the where-clause entries that contribute
// trailing `__witness_*` slots, in declaration order. Total trailing params
// = (1 if hasLayout else 0) + witnessConstraints.count().
//
// Read by `emitCallWithArgs` so the caller knows how many synthetic args to
// append at a call site, and which `(typeParam, interface)` pair each one
// witnesses. Persists through the stdlib cache so per-function lowering of
// user code (where stdlib funcs aren't in the local module) reaches the
// right shape — without it, the call op is under-arity (silent ABI
// corruption on x64, validator rejection on wasm).
export type GenericFunctionImplicits
	export var hasLayout bool
	export var witnessConstraints WhereClauseArray

	export static function create(hasLayout bool, witnessConstraints WhereClauseArray) returns GenericFunctionImplicits
		return Self{hasLayout: hasLayout, witnessConstraints: witnessConstraints}
	end 'create'

	export static function none() returns GenericFunctionImplicits
		return Self{hasLayout: false, witnessConstraints: WhereClauseArray.create()}
	end 'none'
end 'GenericFunctionImplicits'

export typealias GenericFunctionImplicitArityMap = Map with(String, GenericFunctionImplicits)

// One name + declaration site to test for unread-ness. Captured by the
// parser at every parameter and local declaration site; consumed by
// SemanticCheck's deferred unused-var pass.
export type UnusedCandidate
	export let name String
	export let line LineNumber
	export let column ColumnNumber

	export static function create(name String, line LineNumber, column ColumnNumber) returns UnusedCandidate
		return Self{name: name, line: line, column: column}
	end 'create'
end 'UnusedCandidate'

export typealias UnusedCandidateArray = Array with UnusedCandidate

// One deferred unused-variable check: the parser captures every parameter
// and local declaration in a function body along with the names referenced
// from it, then defers the actual cross-check to SemanticCheck. Deferring
// avoids false-positive E3012 emissions when a later pass (TypeResolution,
// most often via a cast error) reports a primary diagnostic that the C#
// bootstrap would have thrown on before reaching its unused-var pass.
//
// `skipParamCheck` is true when the function is an interface-required
// method — the parameter names are dictated by the interface and silently
// unused params are valid for stub implementations. Local-var detection
// still runs in that case.
//
// `startLine`/`endLine` describe the source range covered by this function
// body so the consumer can decide on a per-function basis whether a primary
// diagnostic landed inside the same body — files that hold both clean and
// erroneous functions (e.g. spec `unused-parameters/void-function-unused`)
// must still emit E3012 for the clean function while suppressing the noisy
// secondary diagnostic for the dirty one.
export type PendingUnusedCheck
	export let filePath FilePath
	export let candidates UnusedCandidateArray
	export let referenced ReferencedNameSet
	export let skipParamCheck bool
	export let paramCount ParsedInt
	export let startLine LineNumber
	export let endLine LineNumber

	export static function create(filePath FilePath, candidates UnusedCandidateArray, referenced ReferencedNameSet, skipParamCheck bool, paramCount ParsedInt, startLine LineNumber, endLine LineNumber) returns PendingUnusedCheck
		return Self{filePath: filePath, candidates: candidates, referenced: referenced, skipParamCheck: skipParamCheck, paramCount: paramCount, startLine: startLine, endLine: endLine}
	end 'create'
end 'PendingUnusedCheck'

export typealias PendingUnusedCheckArray = Array with PendingUnusedCheck
export typealias ReferencedNameSet = Set with String

// Parser-recorded provenance for char literals. The single-byte fast path in
// `parseCharLiteralExpr` emits a `MaxonType.integer` literal so existing
// `b == 'a'`-style byte comparisons keep type-checking without coercions, but
// that loses the value's char-ness for two consumers that need it:
//   - overload resolution: `s.contains('e')` against `contains(needle String)`
//     / `contains(character Character)` is ambiguous on the raw int.
//   - string interpolation: `print("{c}\n")` on `let c = 'A'` prints `65`
//     instead of `A` because the lowering picks the i64 arm.
// The set is keyed by `"<funcName>|<valueName>"` (the same key scheme
// `ArrayLiteralProducerMap` uses) and is populated by the parser at the
// char-literal site. TypeResolution then propagates membership through
// varDecl/varLoad so a value loaded out of a `let c = 'A'` slot stays
// recognisable as a char byte at the consumer site.
export typealias CharByteLiteralSet = Set with String

// Build the composite key under which `charByteLiterals` records a char-byte
// value's provenance. Mirrors `arrayLiteralProducerKey`'s scheme so the
// per-function `freshSynthName` reset doesn't cause cross-function
// collisions.
export function charByteLiteralKey(funcName String, valueName ByteArray) returns String
	return "{funcName}|{String.from(valueName)}"
end 'charByteLiteralKey'

// Structural description of an array literal, recorded by the parser and
// consumed by TypeResolution. Carries only IR-shape information — no
// MaxonTypes — so the parser stays out of the type system.
//
//   arrayTypeName  : the stdlib type that opted in via BuiltinArrayLiteral
//                    (typically "Array")
//   mmResultName   : the IR value name bound by the `__ManagedMemory.create`
//                    call
//   initResultName : the IR value name bound by the `T.init(__mm)` call
//   elemNames      : the IR value names of the literal's elements, in
//                    source order
//   elemRanges     : the source range of each element expression, parallel
//                    to `elemNames` — preserved so a TypeResolution-time
//                    type-mismatch error can point at the offending element
//   sourceFilePath : the file the literal was parsed from, recorded so
//                    error reports survive the parser→TypeResolution hop
//   errorReported  : sticky flag — set the first time element-type
//                    unification reports E3005 for this literal, so the
//                    second resolution pass (the `__arr.init` callsite,
//                    which sees the same shared entry the `__mm.create`
//                    callsite already errored on) doesn't double-report
export type ArrayLiteralProducer
	export var arrayTypeName String
	export var mmResultName ByteArray
	export var initResultName ByteArray
	export var elemNames ByteArrayArray
	export var elemRanges SourceRangeArray
	export var sourceFilePath FilePath
	export var errorReported bool

	export static function create(arrayTypeName String, mmResultName ByteArray, initResultName ByteArray, elemNames ByteArrayArray, elemRanges SourceRangeArray, sourceFilePath FilePath) returns ArrayLiteralProducer
		return Self{arrayTypeName: arrayTypeName, mmResultName: mmResultName, initResultName: initResultName, elemNames: elemNames, elemRanges: elemRanges, sourceFilePath: sourceFilePath, errorReported: false}
	end 'create'
end 'ArrayLiteralProducer'

// Keyed by `"<funcName>|<valueName>"` where `valueName` is *either* the
// literal's `__mm` (create-call result) or its `__arr` (init-call result).
// The parser inserts the same entry under both keys so the create- and
// init-resolution paths in TypeResolution both get O(1) lookups; the
// extra entry is cheap (the value is shared by reference). The composite
// key prevents `freshSynthName`-induced collisions across functions
// (synth-name counters reset per function, so a bare-name keying would
// have e.g. `__module_init_0`'s `$t5` shadow `main`'s `$t5`).
export typealias ArrayLiteralProducerMap = Map with(String, ArrayLiteralProducer)

// Sidecar entry recorded by the parser for each map literal (`[k: v, ...]`).
// Carries the chosen Map type name and the init-call's result name; the
// key-axis and value-axis `__mm` allocations have their own ArrayLiteralProducer
// entries so single-axis resolution stays uniform. TypeResolution uses this to
// pin the user-visible result's type to `genericInstance(<mapType>, [Key,
// Value])` after the keys/values axes finish unifying.
export type MapLiteralProducer
	export var mapTypeName String
	export var initResultName ByteArray
	// Per-axis __mm result names so TypeResolution can recover the unified
	// key/value element types from the existing array-literal pipeline.
	export var keyMmResultName ByteArray
	export var valueMmResultName ByteArray
	export var sourceRange SourceRange
	export var sourceFilePath FilePath

	export static function create(mapTypeName String, initResultName ByteArray, keyMmResultName ByteArray, valueMmResultName ByteArray, sourceRange SourceRange, sourceFilePath FilePath) returns MapLiteralProducer
		return Self{mapTypeName: mapTypeName, initResultName: initResultName, keyMmResultName: keyMmResultName, valueMmResultName: valueMmResultName, sourceRange: sourceRange, sourceFilePath: sourceFilePath}
	end 'create'
end 'MapLiteralProducer'

// Keyed by `"<funcName>|<initResultName>"`. The init-result name is the only
// user-visible value (the two `__mm` allocations are resolved through their
// own arrayLiteralProducers entries), so a single-key registry suffices.
export typealias MapLiteralProducerMap = Map with(String, MapLiteralProducer)

// Phase 11.7: a single deferred where-clause check, captured during
// typealias drain.
export type PendingConstraintCheck
	export var name String
	export var expr UnresolvedTypeExpr
	export var declLine LineNumber
	export var declColumn ColumnNumber
	export var declFilePath FilePath

	export static function create(name String, expr UnresolvedTypeExpr, declLine LineNumber, declColumn ColumnNumber, declFilePath FilePath) returns PendingConstraintCheck
		return Self{name: name, expr: expr, declLine: declLine, declColumn: declColumn, declFilePath: declFilePath}
	end 'create'
end 'PendingConstraintCheck'

export typealias PendingConstraintCheckArray = Array with PendingConstraintCheck

// Phase 11.2: lookup table for emitted layout-descriptor bytes. Used by
// the canonicalize pass to fold `descriptorField` reads into constants
// when the descriptor's content is known at compile time.
export typealias StaticRdataValueMap = Map with(String, ByteArray)

// Stage K.4 witness-conditional roots: rdata label → list of function
// names whose liveness is contingent on that label being demanded by a
// code-level `loadWitnessTable` / `loadLayoutDescriptor` op in a function
// the DFE has already kept alive. Std-DFE walks this map at promotion time.
export typealias WitnessConditionalRootsMap = Map with(String, StringArray)

// Phase: constant-array-to-rdata fast path. Populated by the
// `runConstantArrayLiteralRdata` pass for `__ManagedMemory.create` call
// ops whose subsequent per-element `set` ops use only compile-time
// integer literals. The lowering hook in `lowerManagedMemBuiltin` reads
// the table on each call op: when an entry is present, the create lowers
// to an mm_alloc(40) + buffer/length/elemSize/parent stores pointing at
// the registered `__rdata_arr_*` label instead of allocating a fresh
// buffer + running per-element set runtime calls. Keyed by the call op's
// stable `OpIndex` (which is unique per MaxonModule).
export type ConstantArrayRdataInfo
	export var rdataLabel String
	export var count ParsedInt
	export var elementSize ParsedInt

	export static function create(rdataLabel String, count ParsedInt, elementSize ParsedInt) returns ConstantArrayRdataInfo
		return Self{rdataLabel: rdataLabel, count: count, elementSize: elementSize}
	end 'create'
end 'ConstantArrayRdataInfo'

export typealias ConstantArrayRdataMap = Map with(OpIndex, ConstantArrayRdataInfo)

// --- Function-type registry ---
//
// Stores every distinct `(P1, P2) returns R` signature encountered by the
// parser as a parallel-array tuple. `MaxonType.function(id)` carries an
// index into this registry. Two parameters declared with the same shape
// share an id (interned by `internFunctionType` in MaxonDialect), so a
// downstream equality check on the union arm collapses to an integer
// compare.
//
// The registry is unbounded — there is no concrete upper bound on the
// number of distinct function-type shapes a project may declare — so
// `FunctionTypeId` uses the wide `0 to u64.max` typealias from
// MaxonDialect.

export typealias MaxonTypeArrayArray = Array with MaxonTypeArray
export typealias MaxonReturnTypeArray = Array with MaxonReturnType

export type FunctionTypeRegistry
	export var paramTypes MaxonTypeArrayArray
	export var returnTypes MaxonReturnTypeArray

	export static function create() returns FunctionTypeRegistry
		return Self{paramTypes: MaxonTypeArrayArray.create(), returnTypes: MaxonReturnTypeArray.create()}
	end 'create'

	// Number of distinct signatures interned so far. Doubles as the next id
	// that `append` will hand out.
	export function count() returns FunctionTypeId
		return paramTypes.count()
	end 'count'

	// Append a fresh signature to the registry and return its newly assigned
	// id. Callers must ensure structural identity has been ruled out (via
	// `internFunctionType`) before invoking — this routine never dedupes.
	export function append(params MaxonTypeArray, returnType MaxonReturnType) returns FunctionTypeId
		let id = paramTypes.count()
		paramTypes.push(params)
		returnTypes.push(returnType)
		return id
	end 'append'

	// Resolve an id back to the captured signature. Panics on an out-of-range
	// id because the registry never hands out ids it can't satisfy.
	export function get(id FunctionTypeId) returns (MaxonTypeArray, MaxonReturnType)
		let params = try paramTypes.get(id) otherwise panic("FunctionTypeRegistry.get: invalid id {id}")
		let ret = try returnTypes.get(id) otherwise panic("FunctionTypeRegistry.get: returnTypes desync at id {id}")
		return (params, ret)
	end 'get'

	// Replace the captured return type at `id`. Used by TypeResolution's
	// post-`resolveUnresolvedFunctionReturnTypes` patch pass: the parser
	// interns a lifted closure's function type with `value(unresolved)`
	// when the body's expression type couldn't be derived at parse time,
	// and the registry entry must be updated once TR has resolved it.
	export function setReturnType(id FunctionTypeId, returnType MaxonReturnType)
		try returnTypes.set(id, value: returnType) otherwise panic("FunctionTypeRegistry.setReturnType: invalid id {id}")
	end 'setReturnType'
end 'FunctionTypeRegistry'

// --- Phase 11.0 generic-aware registries ---
//
// All four registries follow the FunctionTypeRegistry pattern: parallel
// arrays for the captured payload, a `count()`/`get()`/`intern()`/`getName()`
// API, and a wide-range integer id type that mirrors the union arm. Keep
// them minimal in Phase 11.0 — substitution / lookup machinery lands in
// Phase 11 step 5; today these are just storage so the parser can record
// what it sees.

export typealias TypeParamConstraintArray = Array with StringArray

export typealias DeclaringTypeParamListMap = Map with(String, StringArray)

// Phase 11.0: captured (declaringTypeName, paramName) entries for every
// `T` / `Element` the parser sees in a `uses` clause. `constraints[i]` is
// the list of required interface names for entry `i` (initially empty;
// Phase 11.0 step 1g writes into it from `where` clauses). The display
// name returned by `getName` is just the bare param name — the
// declaringTypeName context isn't part of the printed form.
//
// `declaringTypeParamLists` carries each declaringTypeName's parameter
// names in **source-declaration order**. Required because the registry's
// id space is filled in whatever order callers first encounter each
// (declaringTypeName, paramName) pair — which is NOT always source order
// once the stdlib cache restore path is involved. Substitution callers
// (resolveCalleeParamToConcreteType) MUST pair declaring-type param
// names against a `genericInstance`'s `gidArgs` in source order so
// `Map.Key` maps to gidArgs[0] (the Key arg) and not gidArgs[1] (Value);
// otherwise the witness lookup demands the wrong type's interface.
// Mirrors what `IrInterface.usesParams` does for interfaces.
export type TypeParamRegistry
	export var declaringTypeNames StringArray
	export var paramNames StringArray
	export var constraints TypeParamConstraintArray
	export var declaringTypeParamLists DeclaringTypeParamListMap

	export static function create() returns TypeParamRegistry
		return Self{declaringTypeNames: StringArray.create(), paramNames: StringArray.create(), constraints: TypeParamConstraintArray.create(), declaringTypeParamLists: DeclaringTypeParamListMap.create()}
	end 'create'

	// Number of distinct (declaringTypeName, paramName) pairs interned. Doubles
	// as the next id `intern` will hand out for a fresh entry.
	export function count() returns TypeParamId
		return paramNames.count()
	end 'count'

	// Record the source-declaration order of param names for a declaring
	// type. Called by the parser (and by stdlib-cache restore for cached
	// struct types) at the point the `uses Key, Value` clause is parsed —
	// `paramOrder` MUST be in source order. Once recorded, `getParamNames`
	// returns this list verbatim instead of falling back to registry-id
	// order, which isn't reliable when entries are added through routes
	// other than the parser (e.g. cache restore reaches a typeParameter
	// reference before walking the type's declaration).
	export function recordParamOrder(declaringTypeName String, paramOrder StringArray)
		declaringTypeParamLists.upsert(declaringTypeName, value: paramOrder)
	end 'recordParamOrder'

	// Intern a type-parameter binding. Returns an existing id when the same
	// (declaringTypeName, paramName) pair has already been recorded. Linear
	// scan suffices for Phase 11.0 — generic decls are rare.
	export function intern(declaringTypeName String, paramName String) returns TypeParamId
		for i in 0 upto paramNames.count() 'scan'
			let p = try paramNames.get(i) otherwise panic("TypeParamRegistry.intern: paramNames.get OOB at {i}")
			let d = try declaringTypeNames.get(i) otherwise panic("TypeParamRegistry.intern: declaringTypeNames desync at {i}")
			if p == paramName and d == declaringTypeName 'hit'
				return i
			end 'hit'
		end 'scan'
		let id = paramNames.count()
		declaringTypeNames.push(declaringTypeName)
		paramNames.push(paramName)
		constraints.push(StringArray.create())
		return id
	end 'intern'

	// Return the bare param name for an interned id (e.g. "Element"). Used by
	// `MaxonType.toString` / `nameOrEmpty`. Returns the empty string for ids
	// outside the interned range so cascading-error diagnostics paths don't
	// turn an already-reported E3011/E3015 into a hard compiler crash —
	// matches the same defensive contract as `TypeNameInterner.get`.
	export function getName(id TypeParamId) returns String
		return try paramNames.get(id) otherwise ""
	end 'getName'

	// Return the enclosing declaration name this param id was interned
	// against (e.g. "Set" for `Set`'s `Element`). Used by call-site type
	// inference to filter out type-parameters that belong to outer scopes
	// (interface usesParams / where-clause forwards) when walking a struct's
	// own signature. Same defensive empty-string return as `getName`.
	export function getOwner(id TypeParamId) returns String
		return try declaringTypeNames.get(id) otherwise ""
	end 'getOwner'

	// True when the registry already has a binding for the given pair.
	// Helper for callers that want to skip interning.
	export function contains(declaringTypeName String, paramName String) returns bool
		for i in 0 upto paramNames.count() 'scan'
			let p = try paramNames.get(i) otherwise panic("TypeParamRegistry.contains: paramNames.get OOB at {i}")
			let d = try declaringTypeNames.get(i) otherwise panic("TypeParamRegistry.contains: declaringTypeNames desync at {i}")
			if p == paramName and d == declaringTypeName 'hit'
				return true
			end 'hit'
		end 'scan'
		return false
	end 'contains'

	// Append an interface-name constraint to an existing entry. Used by the
	// parser's `where` clause walker; later phases consume the list during
	// conformance validation. Idempotent — duplicate constraint names are
	// silently dropped.
	export function addConstraint(id TypeParamId, traitName String)
		var bucket = try constraints.get(id) otherwise panic("TypeParamRegistry.addConstraint: invalid id {id}")
		for i in 0 upto bucket.count() 'dedup'
			let existing = try bucket.get(i) otherwise panic("TypeParamRegistry.addConstraint: bucket.get OOB at {i}")
			if existing == traitName 'hit'
				return
			end 'hit'
		end 'dedup'
		bucket.push(traitName)
	end 'addConstraint'

	// Phase 11.1 (step 5): return the declared interface-name constraint list
	// for a type-parameter id. Empty array on missing id (caller treats as
	// "no constraints"); the empty StringArray makes the constraint walk
	// in `Constraints.typeParamConformsTo` self-terminating.
	export function getConstraints(id TypeParamId) returns StringArray
		return try constraints.get(id) otherwise StringArray.create()
	end 'getConstraints'

	// Phase 11.1 (step 5): return every param name declared against
	// `declaringTypeName`, in declaration order. Used by
	// `Substitution.buildSubstitution` to pair a generic type's
	// `usesParams` with a concrete `args` list. Empty array on miss
	// (the caller `buildSubstitution` then returns an empty substitution).
	//
	// Prefers the parser-recorded list (via `recordParamOrder`) when
	// available — that's the only source of truth for source-declaration
	// order. Falls back to a registry-id-order scan only when no list
	// was recorded (older code paths, runtime synthetic types like
	// `__ManagedMemory` which intern their params directly through
	// LowerMaxonToStd without going through the parser). The registry
	// order matches source order in single-parse builds but can scramble
	// once cache restoration / re-resolution introduces interns out of
	// the original source sequence — see Map.findSlot.
	export function getParamNames(declaringTypeName String) returns StringArray
		if let recorded = try declaringTypeParamLists.get(declaringTypeName) 'hasRecorded'
			return recorded
		end 'hasRecorded'
		var result = StringArray.create()
		for i in 0 upto paramNames.count() 'scan'
			let d = try declaringTypeNames.get(i) otherwise panic("TypeParamRegistry.getParamNames: declaringTypeNames.get OOB at {i}")
			if d == declaringTypeName 'hit'
				let p = try paramNames.get(i) otherwise panic("TypeParamRegistry.getParamNames: paramNames.get OOB at {i}")
				result.push(p)
			end 'hit'
		end 'scan'
		return result
	end 'getParamNames'

	// Phase 11.1 (step 5): return the declaring-type name for an interned id
	// (e.g. "Array" for the `Element` param declared on Array). Used by
	// `whereClauseSatisfied` to pair a where-clause's bare param name with
	// the substitution's id space.
	export function getDeclaringTypeName(id TypeParamId) returns String
		return try declaringTypeNames.get(id) otherwise panic("TypeParamRegistry.getDeclaringTypeName: invalid id {id}")
	end 'getDeclaringTypeName'
end 'TypeParamRegistry'

// Phase 11.0: interner for `MaxonType.genericInstance(baseId, args)`. Two
// genericInstance arms with the same baseId and structurally equal args
// share an id, so downstream equality checks reduce to integer compare.
export type GenericInstanceRegistry
	export var baseIds TypeNameIdArray
	export var argLists MaxonTypeArrayArray

	export static function create() returns GenericInstanceRegistry
		return Self{baseIds: TypeNameIdArray.create(), argLists: MaxonTypeArrayArray.create()}
	end 'create'

	export function count() returns GenericInstanceId
		return baseIds.count()
	end 'count'

	// Intern a (baseId, args) pair by structural identity. Linear scan over
	// the existing entries — generic instances are rare enough that a hash
	// lookup is overkill in Phase 11.0.
	export function intern(baseId TypeNameId, args MaxonTypeArray) returns GenericInstanceId
		for i in 0 upto baseIds.count() 'scan'
			let existingBase = try baseIds.get(i) otherwise panic("GenericInstanceRegistry.intern: baseIds.get OOB at {i}")
			let existingArgs = try argLists.get(i) otherwise panic("GenericInstanceRegistry.intern: argLists desync at {i}")
			if existingBase == baseId and maxonTypeArraysStructurallyEqual(existingArgs, b: args) 'hit'
				return i
			end 'hit'
		end 'scan'
		let id = baseIds.count()
		baseIds.push(baseId)
		argLists.push(args)
		return id
	end 'intern'

	// Resolve an id back to its (baseId, args) payload.
	export function get(id GenericInstanceId) returns (TypeNameId, MaxonTypeArray)
		let baseId = try baseIds.get(id) otherwise panic("GenericInstanceRegistry.get: invalid id {id}")
		let args = try argLists.get(id) otherwise panic("GenericInstanceRegistry.get: argLists desync at id {id}")
		return (baseId, args)
	end 'get'
end 'GenericInstanceRegistry'

export typealias GenericInstanceId = int(0 to u64.max)
export typealias TypeNameIdArray = Array with TypeNameId

// Phase 11.0: registry of distinct interface-typed values. Keyed by
// (typeName, interfaceName) the parser saw on `implements` clauses, but
// also seeded by `MaxonType.interface(id)` arms parsed from type positions.
// For Phase 11.0 we only need the bare interface name lookup; the
// (typeName, interfaceName) matrix and method-impl table land in step 5+.
export type ConformanceRegistry
	export var typeNames StringArray
	export var interfaceNames StringArray
	export var withArgsList ConformanceWithArgsArray

	export static function create() returns ConformanceRegistry
		return Self{typeNames: StringArray.create(), interfaceNames: StringArray.create(), withArgsList: ConformanceWithArgsArray.create()}
	end 'create'

	export function count() returns ConformanceId
		return typeNames.count()
	end 'count'

	// Intern a (typeName, interfaceName) pair with its captured `with` args.
	// Returns an existing id on a duplicate insert (parser may revisit the
	// same conformance during recovery).
	export function intern(typeName String, interfaceName String, withArgs MaxonTypeArray) returns ConformanceId
		for i in 0 upto typeNames.count() 'scan'
			let t = try typeNames.get(i) otherwise panic("ConformanceRegistry.intern: typeNames.get OOB at {i}")
			let n = try interfaceNames.get(i) otherwise panic("ConformanceRegistry.intern: interfaceNames desync at {i}")
			if t == typeName and n == interfaceName 'hit'
				return i
			end 'hit'
		end 'scan'
		let id = typeNames.count()
		typeNames.push(typeName)
		interfaceNames.push(interfaceName)
		withArgsList.push(withArgs)
		return id
	end 'intern'

	// Resolve an id back to its (typeName, interfaceName, withArgs) payload.
	export function get(id ConformanceId) returns (String, String, MaxonTypeArray)
		let t = try typeNames.get(id) otherwise panic("ConformanceRegistry.get: invalid id {id}")
		let n = try interfaceNames.get(id) otherwise panic("ConformanceRegistry.get: interfaceNames desync at id {id}")
		let a = try withArgsList.get(id) otherwise panic("ConformanceRegistry.get: withArgsList desync at id {id}")
		return (t, n, a)
	end 'get'

	// True when the registry has an entry for the given pair.
	export function contains(typeName String, interfaceName String) returns bool
		for i in 0 upto typeNames.count() 'scan'
			let t = try typeNames.get(i) otherwise panic("ConformanceRegistry.contains: typeNames.get OOB at {i}")
			let n = try interfaceNames.get(i) otherwise panic("ConformanceRegistry.contains: interfaceNames desync at {i}")
			if t == typeName and n == interfaceName 'hit'
				return true
			end 'hit'
		end 'scan'
		return false
	end 'contains'
end 'ConformanceRegistry'

export typealias ConformanceId = int(0 to u64.max)
export typealias ConformanceWithArgsArray = Array with MaxonTypeArray

// J.4b: extension-method → where-clauses map. Populated by the parser
// at the end of every `extension Iface where ... function M ... end`
// body so the call-site resolver can recover the gating constraints in
// O(1) when emitting E4006 for an unsatisfied conditional extension.
export typealias WhereClauseMapByName = Map with(String, WhereClauseArray)

// Phase 11.0: registry of interface-typed values for the
// `MaxonType.interface(id)` arm. Maintains a String name table indexed by
// id; interns by name so the existential value-type representation collapses
// to integer compare under structural equality.
export type InterfaceTypeRegistry
	export var names StringArray

	export static function create() returns InterfaceTypeRegistry
		return Self{names: StringArray.create()}
	end 'create'

	export function count() returns InterfaceTypeId
		return names.count()
	end 'count'

	// Intern an interface-typed value by name; returns an existing id on a
	// duplicate intern.
	export function intern(name String) returns InterfaceTypeId
		for i in 0 upto names.count() 'scan'
			let existing = try names.get(i) otherwise panic("InterfaceTypeRegistry.intern: names.get OOB at {i}")
			if existing == name 'hit'
				return i
			end 'hit'
		end 'scan'
		let id = names.count()
		names.push(name)
		return id
	end 'intern'

	// Return the bare interface name for an interned id.
	export function getName(id InterfaceTypeId) returns String
		return try names.get(id) otherwise panic("InterfaceTypeRegistry.getName: invalid id {id}")
	end 'getName'
end 'InterfaceTypeRegistry'

// --- Method-name index ---
// Maps a bare method name (e.g. "isOn") to the list of qualified callee
// names that share that trailing segment (e.g. "Toggle.isOn",
// "Signal.isOn"). Built incrementally as funcReturnTypes is populated so
// the methodCall handling in DFE can resolve every candidate by name in
// O(matches) rather than scanning the full funcReturnTypes map.
//
// `record` is the only mutator; callers that insert into funcReturnTypes
// also call this to keep the two consistent.

export typealias QualifiedNameArray = Array with String
export typealias MethodNameIndexMap = Map with(String, QualifiedNameArray)

export type MethodNameIndex
	export var byBareName MethodNameIndexMap

	export static function create() returns MethodNameIndex
		return Self{byBareName: MethodNameIndexMap.create()}
	end 'create'

	// Record a qualified name under its trailing-segment bucket. Free
	// functions (no '.') are skipped: methodCall resolution only walks the
	// method-name buckets, never the bare-name space. The bucket is an
	// Array (reference type), so an existing bucket is mutated in place —
	// only the first record for a given bare name needs an upsert.
	//
	// Overload-mangled names like `Array.contains$Element` get indexed under
	// both their full trailing segment (`contains$Element`) and the source-
	// level method name (`contains`) so DFE's methodCall walk — which only
	// has the source-level name in hand — can find every monomorph variant
	// without re-running the overload mangler. Without this dual indexing,
	// `methodCall .contains(...)` against an overloaded `Array.contains`
	// finds zero candidates and DFE drops the bodies, leaving lowering with
	// a call to the bare unregistered name.
	export function record(qualifiedName String)
		let bareName = try bareMethodName(qualifiedName) otherwise return
		recordUnderKey(qualifiedName, key: bareName)
		if let unsuffixed = try stripFirstDollar(bareName) 'alsoBare'
			if unsuffixed != bareName 'distinct'
				recordUnderKey(qualifiedName, key: unsuffixed)
			end 'distinct'
		end 'alsoBare'
	end 'record'

	function recordUnderKey(qualifiedName String, key String)
		if var bucket = try byBareName.get(key) 'append'
			bucket.push(qualifiedName)
			return
		end 'append'
		var freshBucket = QualifiedNameArray.create()
		freshBucket.push(qualifiedName)
		byBareName.upsert(key, value: freshBucket)
	end 'recordUnderKey'

	// Look up the list of qualified names ending in `.{bareName}`. Returns
	// an empty array on miss so DFE callers can iterate unconditionally.
	export function get(bareName String) returns QualifiedNameArray
		return try byBareName.get(bareName) otherwise QualifiedNameArray.create()
	end 'get'
end 'MethodNameIndex'

// Shared error type for the small string-splitting helpers below
// (`stripFirstDollar`, `bareMethodName`, and `StdlibCache`'s
// `stripFirstDollarPrefix`). Each helper throws this when the requested
// separator (`$` or `.`) isn't found, so callers use `try ... otherwise`
// to skip names that lack the split point rather than checking for an
// empty-string sentinel.
export enum NameSplitError implements Error
	noSeparator
end 'NameSplitError'

// Strip the first `$<suffix>` from a name, returning the prefix. Throws
// `NameSplitError.noSeparator` when the name has no `$`. Used to dual-index
// overload-mangled method names so `Array.contains$Element` is reachable both
// via the full trailing segment and via the source-level `contains`.

function stripFirstDollar(s String) returns String throws NameSplitError
	let bytes = s.toByteArray()
	let dollarByte = 0x24
	var i = 0
	while i < bytes.count() 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i < bytes.count() but get failed at {i}")
		if b == dollarByte 'hit'
			let head = try bytes.slice(0, endIndex: i) otherwise panic("invariant: 0 <= i < bytes.count() but slice failed")
			return String.from(head)
		end 'hit'
		i = i + 1
	end 'scan'
	throw NameSplitError.noSeparator
end 'stripFirstDollar'

// Return the trailing segment of `s` (the bytes after the last '.') as a
// fresh String. Throws `NameSplitError.noSeparator` when there is no dot.
// Used by MethodNameIndex.record to split a qualified name like
// "Toggle.isOn" into the bare method name "isOn" so it can be inserted into
// the index by trailing segment.
function bareMethodName(s String) returns String throws NameSplitError
	let bytes = s.toByteArray()
	let dotByte = 0x2E
	var lastDot = -1
	var i = bytes.count() - 1
	while i >= 0 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i in [0, bytes.count()) but get failed at {i}")
		if b == dotByte 'hit'
			lastDot = i
			break
		end 'hit'
		i = i - 1
	end 'scan'
	if lastDot < 0 'noDot'
		throw NameSplitError.noSeparator
	end 'noDot'
	let tailBytes = try bytes.slice(lastDot + 1, endIndex: bytes.count()) otherwise panic("invariant: lastDot < bytes.count() but slice failed")
	return String.from(tailBytes)
end 'bareMethodName'

// --- Type name interning ---
// MaxonType.named carries a TypeNameId that indexes the project's interner so
// identical named types share a single String allocation. The interner is
// populated by the parser and consulted everywhere a named type is printed,
// resolved, or compared.

export typealias TypeNameId = int(0 to u64.max)

export typealias TypeNameIdMap = Map with(String, TypeNameId)

export type TypeNameInterner
	export var names StringArray
	export var lookup TypeNameIdMap

	export static function create() returns TypeNameInterner
		return Self{names: StringArray.create(), lookup: TypeNameIdMap.create()}
	end 'create'

	// Intern a type name, returning its stable TypeNameId.
	export function intern(name String) returns TypeNameId
		let existing = try lookup.get(name) otherwise 'fresh'
			let id = names.count()
			names.push(name)
			lookup.upsert(name, value: id)
			return id
		end 'fresh'
		return existing
	end 'intern'

	// Resolve a TypeNameId back to its String name. Returns the empty string
	// for ids outside the interned range — under cascading type-resolution
	// failures, a `MaxonType.named(badId)` may surface in diagnostic-formatting
	// paths (`maxonTypeStructName` → `nameOrEmpty` → here) before the resolver
	// has a chance to clean it up. Panicking here would turn an already-reported
	// E3011/E3015 cascade into a hard compiler crash; returning empty makes the
	// downstream consumers ("no struct match" / "<unresolved>") treat the bad
	// id as "unknown type" and continue, so the user sees a clean error count
	// and exit. The interner never hands out ids outside the range during
	// normal operation, so the empty-string path is exclusively a
	// diagnostics-cascade fallback.
	export function get(id TypeNameId) returns String
		return try names.get(id) otherwise ""
	end 'get'
end 'TypeNameInterner'

// --- Callee name interning ---
// Every emitted maxon.call op carries the callee name as a ByteArray. Hot
// stdlib callees (Print.print, equals, arithmetic helpers) are referenced
// thousands of times across a compilation, so converting the same String to
// a fresh ByteArray on every emission is pure waste. The interner caches the
// ByteArray per name and hands the same instance out on every subsequent
// call. The op consumes it read-only (lowering reads it via String.from), so
// sharing one instance across many ops is safe.

export typealias CalleeNameByteArrayMap = Map with(String, ByteArray)

export type CalleeNameInterner
	export var lookup CalleeNameByteArrayMap

	export static function create() returns CalleeNameInterner
		return Self{lookup: CalleeNameByteArrayMap.create()}
	end 'create'

	export function intern(name String) returns ByteArray
		let existing = try lookup.get(name) otherwise 'fresh'
			let bytes = name.toByteArray()
			lookup.upsert(name, value: bytes)
			return bytes
		end 'fresh'
		return existing
	end 'intern'
end 'CalleeNameInterner'

// --- String literal interning ---
// Every string literal the parser encounters is interned into a project-wide
// table. The IR carries a `StringId` (a stable index into the table) instead
// of raw String bytes — identical literals across files share a single id
// and a single backing allocation. Top-level string constants
// (`let MSG = "hello"`) record their content as a StringId so cross-file
// references resolve through the interner, not the parser. Lowering recovers
// the raw bytes via `project.strings.get(id)` when emitting the runtime
// `globalAddr + length` tuple.

export typealias StringId = int(0 to u64.max)

export typealias StringIdMap = Map with(String, StringId)

export type StringInterner
	export var values StringArray
	export var lookup StringIdMap

	export static function create() returns StringInterner
		return Self{values: StringArray.create(), lookup: StringIdMap.create()}
	end 'create'

	// Intern a string literal, returning its stable StringId. Identical
	// content always returns the same id so equality checks reduce to id
	// comparison and downstream consumers (panic, top-level constants,
	// string-interp parts) carry a single fixed-width id instead of
	// variable-length String bytes.
	export function intern(value String) returns StringId
		let existing = try lookup.get(value) otherwise 'fresh'
			let id = values.count()
			values.push(value)
			lookup.upsert(value, value: id)
			return id
		end 'fresh'
		return existing
	end 'intern'

	// Resolve a StringId back to its raw bytes. Panics on an invalid id —
	// the interner never hands out ids it can't resolve.
	export function get(id StringId) returns String
		return try values.get(id) otherwise panic("StringInterner: invalid id {id}")
	end 'get'
end 'StringInterner'

export typealias VarSlotArray = Array with VarSlot

// --- Variable info ---
// The parser tracks every local variable by its source-level MaxonType. That
// type is carried all the way to lowerMaxonToStd, which picks the concrete
// StdType (int vs float, width) through the typealias registry after all
// types have been resolved. The parser never branches on int-vs-float; mixed
// arithmetic promotions are inserted by lowering, not by the parser.

export type VarInfo
	export var name String
	export var varType MaxonType
	export var mutable bool
	export var slot VarSlot
	// True when this name is a self-field alias inside an instance method.
	// Reads emit maxon.fieldLoad via __self + fieldOffset; writes emit
	// maxon.fieldStore. The local slot is unused in that case — heap is the
	// single source of truth, so nested method calls that mutate self.field
	// are observed on return.
	export var isSelfField bool
	export var fieldOffset FieldOffset
	// Phase 9 Stage 4: true when this name was introduced as a match-arm
	// binding on a union payload (e.g. `match u 'a' full(value) then …`).
	// Reads still go through the local slot — `emitUnionArmBindings`
	// declares a slot and seeds it from `enumPayloadRead`. Writes (`value =
	// expr`) are rewritten by `parseVarAssignment` to `enumPayloadStore`
	// against `payloadScrutineeName + payloadFieldIndex` so the union's
	// heap-resident payload slot updates in place. The `mutable` flag on the
	// VarInfo follows the scrutinee's mutability so `let u = …` produces an
	// E2013 on the assignment path.
	export var isPayloadBinding bool
	export var payloadScrutineeName String
	export var payloadFieldIndex CaseOrdinal
	// Phase 9 Stage 4 follow-up: the union case this binding belongs to.
	// Carries through to `enumPayloadStore` so TR can resolve the payload's
	// field type from the union's case table — different cases of the
	// same union have independent payload field types, so the case name
	// is required, not just the union name.
	export var payloadCaseName String

	export static function create(name String, varType MaxonType, mutable bool, slot VarSlot) returns VarInfo
		return Self{name: name, varType: varType, mutable: mutable, slot: slot, isSelfField: false, fieldOffset: 0, isPayloadBinding: false, payloadScrutineeName: "", payloadFieldIndex: 0 as CaseOrdinal, payloadCaseName: ""}
	end 'create'

	export static function createSelfField(name String, varType MaxonType, slot VarSlot, offset FieldOffset) returns VarInfo
		return Self{name: name, varType: varType, mutable: true, slot: slot, isSelfField: true, fieldOffset: offset, isPayloadBinding: false, payloadScrutineeName: "", payloadFieldIndex: 0 as CaseOrdinal, payloadCaseName: ""}
	end 'createSelfField'

	// Phase 9 Stage 4: factory for a payload-binding alias. Mutability
	// inherits from the scrutinee's `let`/`var` declaration (see
	// `mutable-enums.md` test `error.assign-to-let-enum-binding`).
	export static function createPayloadBinding(name String, varType MaxonType, mutable bool, slot VarSlot, scrutineeName String, fieldIndex CaseOrdinal, caseName String) returns VarInfo
		return Self{name: name, varType: varType, mutable: mutable, slot: slot, isSelfField: false, fieldOffset: 0, isPayloadBinding: true, payloadScrutineeName: scrutineeName, payloadFieldIndex: fieldIndex, payloadCaseName: caseName}
	end 'createPayloadBinding'
end 'VarInfo'

export typealias VarInfoMap = Map with(String, VarInfo)

export typealias StringArray = Array with String

// The typealias registry maps source-level alias names (e.g. "ExitCode", "AsciiValue")
// to their concrete ABI-level StdType. Populated by the resolver from range bounds via
// computeOptimalIntType (narrowest unsigned width for `int(0..N)` aliases). The cast
// *category* (int / byte / float) is tracked separately in `TypealiasCastCategoryMap`
// so a narrow u8 storage choice doesn't flip a user-declared `int(...)` alias into
// the `byte` cast family. Range information lives alongside in `TypealiasRangeMap`
// for runtime range-check emission.
export typealias TypealiasMap = Map with(String, StdType)

// Sidecar map: alias name → user-declared cast category. Distinct from the storage
// type because `int(0 to 255)` narrows to u8 storage but must still report as `int`
// at cast/compare validation (otherwise `someInt as MyAlias` would be rejected as
// int → byte for a non-literal). Populated by the resolver: `int(...)` → int,
// `byte(...)` → byte, `float(...)` → float. Aliases that just rename another named
// type don't appear here — the lookup walks the alias chain and lands on a base
// type whose category is already encoded in StdType.
export typealias TypealiasCastCategoryMap = Map with(String, CastCategory)

// Sidecar visibility info for a resolved typealias. Stored separately from
// `TypealiasMap` because that map's value is a primitive `StdType`, so we
// can't extend it without a wider refactor. Lookups treat a missing key as
// `(global, stdlib bootstrap path)` — every stdlib alias is implicitly
// reachable from anywhere, and we don't serialize visibility through the
// stdlib cache.
export type TypealiasVisibilityInfo
	export var visibility Visibility
	export var sourceFilePath FilePath

	export static function create(visibility Visibility, sourceFilePath FilePath) returns TypealiasVisibilityInfo
		return Self{visibility: visibility, sourceFilePath: sourceFilePath}
	end 'create'
end 'TypealiasVisibilityInfo'

export typealias TypealiasVisibilityInfoArray = Array with TypealiasVisibilityInfo

// One alias name → array of (visibility, sourceFilePath) entries. The
// same name may legally be declared file-private in multiple files, so
// the map holds an entry per declaring file. Lookups iterate the array.
export typealias TypealiasVisibilityMap = Map with(String, TypealiasVisibilityInfoArray)

// Append a new (visibility, sourceFilePath) entry for `name`. Idempotent:
// exact duplicate `(visibility, sourceFilePath)` pairs are coalesced so
// repeated drains and cache-restore-then-parse sequences stay stable.
export function appendTypealiasVisibility(project Project, name String, info TypealiasVisibilityInfo)
	var fresh = TypealiasVisibilityInfoArray.create()
	if let existing = try project.typealiasVisibilities.get(name) 'haveExisting'
		for entry in existing 'eachEntry'
			let sameVis = entry.visibility.ordinal == info.visibility.ordinal
			let samePath = entry.sourceFilePath.toString() == info.sourceFilePath.toString()
			if sameVis and samePath 'dup'
				return
			end 'dup'
			fresh.push(entry)
		end 'eachEntry'
	end 'haveExisting'
	fresh.push(info)
	project.typealiasVisibilities.upsert(name, value: fresh)
end 'appendTypealiasVisibility'

// Sidecar visibility info for a function. Mirrors the data on
// `IrFunction.visibility` / `IrFunction.sourceFilePath` but is keyed by
// the function's qualified name so cross-file callee resolution can hit
// O(1) lookup without scanning `module.functions`. Lookups treat a
// missing key as `(global, stdlib bootstrap path)` — stdlib functions
// are restored without a sidecar entry and stay reachable from
// everywhere.
export type FuncVisibilityInfo
	export var visibility Visibility
	export var sourceFilePath FilePath

	export static function create(visibility Visibility, sourceFilePath FilePath) returns FuncVisibilityInfo
		return Self{visibility: visibility, sourceFilePath: sourceFilePath}
	end 'create'
end 'FuncVisibilityInfo'

export typealias FuncVisibilityMap = Map with(String, FuncVisibilityInfo)

// Function return type registry — the name returned to the source-level MaxonType.
// Keeps source-level fidelity (named aliases stay as named MaxonType) so callers
// can look up bounds in typealiasRanges.
export typealias FuncReturnTypeMap = Map with(String, MaxonReturnType)

export typealias FuncThrowsTypeMap = Map with(String, ThrowsClause)

// Per-parameter default value. None = no default (argument is mandatory);
// intLiteral(v) = literal integer default used when the call site omits the
// parameter. Only integer literal defaults are supported today.
export union ParamDefault
	none
	intLiteral(value IntConstant)
end 'ParamDefault'

export typealias ParamDefaultArray = Array with ParamDefault

// Result of unwrapping a ParamDefault into a concrete integer value. Used by
// the parser's call-site default-fill loop so the control-flow between
// "has a default" and "no default" can stay in an ordinary `if`.
export type ParamDefaultValue
	export var hasValue bool
	export var value IntConstant

	export static function some(value IntConstant) returns ParamDefaultValue
		return Self{hasValue: true, value: value}
	end 'some'

	export static function empty() returns ParamDefaultValue
		return Self{hasValue: false, value: 0}
	end 'empty'
end 'ParamDefaultValue'

export function paramDefaultAsIntLiteral(paramDefault ParamDefault) returns ParamDefaultValue
	return match paramDefault 'unwrap'
		intLiteral(value) gives ParamDefaultValue.some(value)
		none gives ParamDefaultValue.empty()
	end 'unwrap'
end 'paramDefaultAsIntLiteral'

// Stdlib-cache codec for ParamDefault. Writes the union tag (none vs
// intLiteral) followed by the int payload when present, mirroring the
// rawValue/unionCases pattern used by the other cache codecs.
export function writeParamDefault(buf ByteArray, pd ParamDefault)
	writeDword(buf, value: pd.ordinal)
	match pd 'payload'
		none then break 'payload'
		intLiteral(value) then writeQword(buf, value: value)
	end 'payload'
end 'writeParamDefault'

function readParamDefaultIntLiteral(buf ByteArray, offset ByteOffset) returns (ParamDefault, ByteOffset)
	let value = readQword(buf, offset: offset)
	return (ParamDefault.intLiteral(value), offset + 8)
end 'readParamDefaultIntLiteral'

export function readParamDefault(buf ByteArray, offset ByteOffset) returns (ParamDefault, ByteOffset)
	let raw = readDword(buf, offset: offset)
	let pos = offset + 4
	let kase = try ParamDefault.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown ParamDefault tag {raw}")
	match kase 'tag'
		none then return (ParamDefault.none, pos)
		intLiteral then return readParamDefaultIntLiteral(buf, offset: pos)
	end 'tag'
end 'readParamDefault'

export typealias ParamNameIndexMap = Map with(String, ParsedInt)

// Function signature: parallel arrays of parameter names, types, and their
// optional default values. paramNames[i] is the source-level name of parameter
// i; paramTypes[i] is its declared MaxonType; paramDefaults[i] is its default
// (or ParamDefault.none). nameToIndex mirrors paramNames as a
// String→absolute-index map so named-arg resolution at call lowering is O(1)
// instead of O(N) per arg.
//
// paramTypes carries the source-level type — the call-site type-check pass
// uses it to validate each argument's MaxonType against the declared parameter
// MaxonType, and to drive implicit conversions (int↔float, int→byte, etc.).
export type FuncSignature
	export var paramNames StringArray
	export var paramTypes MaxonTypeArray
	export var paramDefaults ParamDefaultArray
	export var nameToIndex ParamNameIndexMap

	export static function create(paramNames StringArray, paramTypes MaxonTypeArray, paramDefaults ParamDefaultArray) returns FuncSignature
		if paramTypes.count() != paramNames.count() 'arityMismatch'
			panic("FuncSignature.create: paramTypes.count={paramTypes.count()} != paramNames.count={paramNames.count()} (parser bug)")
		end 'arityMismatch'
		var nameToIndex = ParamNameIndexMap.create()
		for i in 0 upto paramNames.count() 'buildIndex'
			let name = try paramNames.get(i) otherwise panic("invariant: paramNames.get OOB at {i}")
			try nameToIndex.insert(name, value: i) otherwise panic("FuncSignature.create: duplicate paramName '{name}' (parser should reject earlier)")
		end 'buildIndex'
		return Self{paramNames: paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults, nameToIndex: nameToIndex}
	end 'create'
end 'FuncSignature'

export typealias FuncSignatureMap = Map with(String, FuncSignature)

// Per-call-site cache of paramTypes substituted into the call's context.
// Keyed by the OpIndex of the `call` / `methodCall` op. Populated by
// `resolveAllCalls` (TypeResolution's final pass) after `funcSignatures`
// is stable; consumed by LowerMaxonToStd to coerce each argument without
// re-running the substitution. The vector matches the callee
// signature's `paramTypes` slot-for-slot (including any leading __self),
// with every `typeParameter` / inner-alias / generic-instance arm
// rewritten to the concrete type the call site observes. No entry is
// inserted for ops whose callee has no registered signature (lowering
// takes the no-coerce fallback path) or whose dispatch resolves to an
// interface stub before reaching slot fill.
export typealias CallParamTypesMap = Map with(OpIndex, MaxonTypeArray)

// Per-call-site cache of the resolved qualified callee name. For `call`
// ops this is the parser-emitted bare name passed through
// `qualifyCalleeForContext` → `chaseTypealiasInQualifiedCallee` →
// `resolveOverloadedCallee`. For `methodCall` ops it is
// `{receiverStructName}.{methodName}` after `resolveOverloadedCallee`.
// LowerMaxonToStd reads this directly instead of redoing the resolver
// chain, keeping the lowering pass free of any name-resolution work.
// No entry is inserted when the resolver bails (e.g. methodCall on a
// receiver whose type didn't reduce to a concrete struct — the
// interface-dispatch stub path).
export typealias ResolvedCalleesMap = Map with(OpIndex, String)

// Per-call-site receiver-type sidecar. Keyed by the same OpIndex as
// `resolvedCallees`; the value is the receiver MaxonType the typealias
// chase landed on (genericInstance for `ByteArray.init` →
// `Array with Byte`, plain named for non-generic statics). Lowering's
// `materializeLayoutArg` reads this to thread the right descriptor at
// `Type.staticMethod()` call sites where the parser stamped only the
// resolved bare callee name.
export typealias ResolvedReceiverTypesMap = Map with(OpIndex, MaxonType)

// Minimal first-param overload registry. Maps a bare qualified function name
// (the source-level name before mangling, e.g. `Array.contains`) to the list
// of mangled variant names registered under it. Used by call-site resolution
// to disambiguate overloaded callees by argument type. Empty for any name
// with a single registration; only collisions populate this map.
export typealias OverloadedNameMap = Map with(String, QualifiedNameArray)

// Result of the parser's collision-handling helper. `isOverload` distinguishes
// the "the two functions differ in their first non-self param type — registered
// as overloads under mangled names" case from the "real duplicate — caller
// should emit E2001" case. The `mangledName` field is meaningful only when
// `isOverload` is true.
export type OverloadResolution
	export var isOverload bool
	export var mangledName String

	export static function overload(mangledName String) returns OverloadResolution
		return Self{isOverload: true, mangledName: mangledName}
	end 'overload'

	export static function duplicate() returns OverloadResolution
		return Self{isOverload: false, mangledName: ""}
	end 'duplicate'
end 'OverloadResolution'
export typealias ProjectArray = Array with Project
export typealias RangeBound = int(i64.min to i64.max)
export typealias IntConstant = int(i64.min to i64.max)
export typealias TypealiasRangeMap = Map with(String, TypealiasRange)

// --- Unresolved typealias representation ---
// The parser captures every `typealias Name = ...` declaration into an
// UnresolvedTypealias entry first. The TypeResolution pass then runs a
// fixed-point loop that moves entries into the resolved registries
// (typealiases / typealiasRanges) as their right-hand side becomes
// resolvable. This decoupling lets typealiases reference other typealiases
// regardless of source-text order, and gives us a single place to enforce
// cycle detection and unknown-name diagnostics.
//
// The expression is a small union covering the RHS forms the parser
// recognizes today. New variants (genericApp, funcType, tupleType, …) plug
// in without touching the parse-time scaffolding.

export union UnresolvedTypeExpr
	// `int(LOWER to UPPER)` — bounds are already normalized to inclusive form
	// at parse time (an `upto N` upper becomes `N - 1`). Cast category is
	// always `int` regardless of the optimal narrow storage type.
	rangedInt(lower RangeBound, upper RangeBound)
	// `float(LOWER to UPPER)` — bounds are stored as i64 bit patterns of the
	// IEEE-754 double bounds. Always normalized to inclusive form at parse time.
	rangedFloat(lower RangeBound, upper RangeBound)
	// `bool` RHS — resolvable immediately.
	boolPrim
	// Bare named reference, e.g. `typealias A = B`. Resolves once `B` is in
	// the resolved typealiases map; the fixed-point resolver picks the
	// chain up regardless of the source-text order between A and B.
	aliasName(name String)
	// Phase 11.0 step 2: generic typealias `typealias E = Base with(A, B)`.
	// `baseName` is the bare LHS name, `args` are the source-level arg names
	// captured at parse time. The resolver pass turns this into a
	// `MaxonType.genericInstance(...)` and stores it in `project.genericTypealiases`,
	// not `project.typealiases` (which is StdType-typed).
	genericAlias(baseName String, args StringArray)
	// Phase 13 (sized typealiases): `typealias Vec1 = Vector with 1 Int`.
	// Same as `genericAlias` but a positive-int const prefixes the args
	// (encoded as a leading `constInt(size)` MaxonType arg in the resulting
	// gid). Distinct N produce distinct gids so Vec1 and Vec4 don't share
	// monomorphization.
	sizedGenericAlias(baseName String, size IntConstant, args StringArray)
	// Sentinel for a syntactically valid but semantically rejected typealias
	// (range validation failure). Carried through resolution so the unused-
	// typealias check (E3062) suppresses its cascade — the E3005 raised at
	// parse time is the single user-visible diagnostic.
	invalid
end 'UnresolvedTypeExpr'

export type UnresolvedTypealias
	export var name String
	export var expr UnresolvedTypeExpr
	// Visibility tier from the `export` / `module` modifier on the
	// `typealias` declaration (or `file` if neither was present).
	// Forwarded into `typealiasVisibilities` at resolution time so
	// cross-file uses of the alias as a parameter / return type can
	// be filtered.
	export var visibility Visibility
	// Parse-time source location; carried so resolver-emitted diagnostics
	// (cycle, unknown-name) can point back at the original declaration.
	export var line LineNumber
	export var column ColumnNumber
	export var filePath FilePath

	export static function create(name String, expr UnresolvedTypeExpr, visibility Visibility, line LineNumber, column ColumnNumber, filePath FilePath) returns UnresolvedTypealias
		return Self{name: name, expr: expr, visibility: visibility, line: line, column: column, filePath: filePath}
	end 'create'
end 'UnresolvedTypealias'

export typealias UnresolvedTypealiasMap = Map with(String, UnresolvedTypealias)

// Phase 11.0 step 2: per-type table of inner `typealias Foo = ...` declarations
// that appear inside a `type Body ... end` block. Stored as raw
// `UnresolvedTypeExpr` so the resolver can promote them to concrete MaxonTypes
// after type-name interning is complete. Keyed by the inner alias name.
export typealias InnerAliasMap = Map with(String, UnresolvedTypeExpr)

// Phase 11.0 step 2: project-wide table of resolved generic-typealias names
// (e.g. `ElementMemory` at top level → `MaxonType.genericInstance(...)`). The
// existing `typealiases TypealiasMap` is StdType-typed and cannot represent a
// generic instance, so generic aliases live in this sidecar map. Lookup sites
// that resolve typealiases by name should consult both maps.
export typealias GenericTypealiasMap = Map with(String, MaxonType)

// Parser-record for a `type Name` declaration awaiting registration. The
// parser emits one of these instead of writing `project.structTypes` directly
// — the type-resolution pass drains them into `structTypes` after every
// module has been parsed. Field MaxonTypes are kept as the parser saw them;
// their named-id validation happens during the same resolver pass.
export type UnresolvedStructType
	export var name String
	export var fields StructFieldArray
	export var byteSize FieldOffset
	// Visibility tier from the `export` / `module` modifier on the
	// `type` declaration (or `file` if neither was present). Forwarded
	// to `StructType` at resolution time and consulted by
	// TypeResolution's named-type visibility walk.
	export var visibility Visibility
	// Source location of the `type Name` token, for duplicate-type diagnostics.
	export var line LineNumber
	export var column ColumnNumber
	export var filePath FilePath
	// Phase 1b: the parsed `implements I1, I2 with X, ...` clause, captured
	// as bare interface and type-parameter names. Empty when no clause was
	// present. Phase 3 of the interfaces plan validates conformance and
	// substitutes associated types — for now this is metadata only.
	export var implementedInterfaces ConformanceArray
	// Phase 11.0: the parsed `uses T1, T2` clause's bare param names. Empty
	// when no clause was present. Step 5+ resolves these against
	// `project.typeParameters` and uses them to substitute generic field /
	// method types.
	export var typeParams StringArray
	// Phase 11.0: the parsed `where T is Trait1 and Trait2, ...` clause as
	// a flat array of (paramName, requiredTraitName) pairs (conjunctions
	// expanded at parse time). Empty when no clause was present.
	export var whereClauses WhereClauseArray
	// Phase 11.0 step 2: inner `typealias Name = ...` declarations parsed
	// inside the type body (e.g. `typealias ElementMemory = __ManagedMemory
	// with Element` in `Array.maxon`). Stored as raw `UnresolvedTypeExpr` —
	// the resolver promotes these into concrete MaxonTypes alongside the
	// surrounding struct's resolution. Step 5+ consumes them during
	// substitution; for now they are recorded only.
	export var innerAliases InnerAliasMap

	export static function create(name String, fields StructFieldArray, byteSize FieldOffset, visibility Visibility, line LineNumber, column ColumnNumber, filePath FilePath, implementedInterfaces ConformanceArray, typeParams StringArray, whereClauses WhereClauseArray, innerAliases InnerAliasMap) returns UnresolvedStructType
		return Self{name: name, fields: fields, byteSize: byteSize, visibility: visibility, line: line, column: column, filePath: filePath, implementedInterfaces: implementedInterfaces, typeParams: typeParams, whereClauses: whereClauses, innerAliases: innerAliases}
	end 'create'
end 'UnresolvedStructType'

export typealias UnresolvedStructTypeMap = Map with(String, UnresolvedStructType)

// Phase 11.0 step 4: parser record for an `extension TargetType ... end`
// block. Method bodies inside the extension are registered into
// `project` directly as qualified methods on `targetTypeName` at parse
// time — this record only captures the per-extension metadata that
// later resolution / witness-table passes need (added conformances,
// where-clauses, declared type-parameter rebinding). Step 5 consumes
// this registry to enforce conditional conformance and to validate
// where-clauses at call-sites; step 7 walks it to emit conditional
// witness tables.
export type UnresolvedExtension
	// Bare name of the type being extended (e.g. "Array").
	export var targetTypeName String
	// Type-parameter rebinding when the extension uses `extension Array
	// uses E` syntax to give the target's parameters local names. Empty
	// when the extension inherits the target's parameter names verbatim
	// (the common case for `extension Array where Element is ...`).
	export var targetTypeParams StringArray
	// Conformances introduced by this extension's `implements I1, I2`
	// clause. Empty when the extension only adds methods.
	export var addedConformances ConformanceArray
	// Constraints from the `where T is Trait1 and Trait2 ...` clause that
	// gate when this extension's methods / conformances apply. Empty for
	// unconditional extensions.
	export var whereClauses WhereClauseArray
	// Visibility tier inherited by every method declared inside the body.
	// `export extension Array ...` makes added methods cross-file visible;
	// a bare `extension Array ...` keeps them file-scoped.
	export var visibility Visibility
	// Source location of the target-type token, for any future
	// per-extension diagnostic.
	export var line LineNumber
	export var column ColumnNumber
	export var filePath FilePath

	export static function create(targetTypeName String, targetTypeParams StringArray, addedConformances ConformanceArray, whereClauses WhereClauseArray, visibility Visibility, line LineNumber, column ColumnNumber, filePath FilePath) returns UnresolvedExtension
		return Self{targetTypeName: targetTypeName, targetTypeParams: targetTypeParams, addedConformances: addedConformances, whereClauses: whereClauses, visibility: visibility, line: line, column: column, filePath: filePath}
	end 'create'
end 'UnresolvedExtension'

export typealias UnresolvedExtensionArray = Array with UnresolvedExtension

export union ConstantValue
	// String-typed constants store an interned StringId (not raw bytes) so
	// cross-file references resolve by identity through `project.strings`.
	stringValue(stringId StringId)
	intValue(value IntConstant)
	// Float-typed constants store IEEE 754 f64 raw bits in the same i64
	// payload shape used by MaxonOp.literal for float values.
	floatValue(bits IntConstant)
end 'ConstantValue'

// One resolved top-level constant. The `value` carries the folded
// payload; `visibility` and `sourceFilePath` let cross-file lookup
// filter via `isVisibleFrom`. Stdlib-cached constants synthesize an
// `exported` entry with the stdlib bootstrap path so user code reading
// a stdlib constant always sees it.
export type TopLevelConstant
	export var value ConstantValue
	export var visibility Visibility
	export var sourceFilePath FilePath

	export static function create(value ConstantValue, visibility Visibility, sourceFilePath FilePath) returns TopLevelConstant
		return Self{value: value, visibility: visibility, sourceFilePath: sourceFilePath}
	end 'create'
end 'TopLevelConstant'

export typealias ConstantMap = Map with(String, TopLevelConstant)

// --- Cache codec ---
// Reader resolves stringValue payloads through the destination project's
// string interner; writer dereferences through the source project's
// strings table. The id space is per-Project and not portable across
// caches, so we round-trip the resolved bytes. Cached entries don't carry
// visibility / sourceFilePath — every stdlib constant is implicitly
// `exported` and originates at the stdlib bootstrap path; readStdlibCache
// stamps those values in.

export function writeConstantValue(project Project, buf ByteArray, cv ConstantValue) throws CacheCorruption
	writeDword(buf, value: cv.ordinal)
	match cv 'payload'
		stringValue(stringId) then try writeString(buf, s: project.strings.get(stringId))
		intValue(value) then writeQword(buf, value: value)
		floatValue(bits) then writeQword(buf, value: bits)
	end 'payload'
end 'writeConstantValue'

function readConstantValueString(project Project, buf ByteArray, offset ByteOffset) returns (ConstantValue, ByteOffset) throws CacheCorruption
	let (strVal, nextPos) = try readString(buf, offset: offset)
	return (ConstantValue.stringValue(project.strings.intern(strVal)), nextPos)
end 'readConstantValueString'

export function readConstantValue(project Project, buf ByteArray, offset ByteOffset) returns (ConstantValue, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let pos = offset + 4
	let kase = try ConstantValue.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown ConstantValue tag {raw}")
	match kase 'tag'
		stringValue then return try readConstantValueString(project, buf: buf, offset: pos)
		intValue then return (ConstantValue.intValue(readQword(buf, offset: pos)), pos + 8)
		floatValue then return (ConstantValue.floatValue(readQword(buf, offset: pos)), pos + 8)
	end 'tag'
end 'readConstantValue'

// --- Unresolved top-level decl representation ---
// Mirrors the UnresolvedTypealias pattern: the parser captures every
// `let NAME = <init>` and `var NAME = <init>` at module scope (plus their
// `static` field analogues) into an UnresolvedTopLevelDecl entry without
// resolving identifier references. The TypeResolution pass walks the map
// with DFS + a visiting stack, evaluates each initializer, and routes the
// result either into `topLevelConstants` (immutable lets) or `topLevelVars`
// (mutable vars) based on the entry's `mutable` flag. Cycles among let
// initializers surface as E2012 (parserCircularDependency) from the
// resolver, not the parser.
//
// The expression tree is stored as a flat arena of UnresolvedConstExpr
// nodes on Project; UnresolvedConstExprId is an integer index into that
// arena. The arena is shared across all files in the project so cross-file
// `export let` references resolve through the same id space.

export typealias UnresolvedConstExprId = int(0 to u64.max)
export typealias UnresolvedConstExprIdArray = Array with UnresolvedConstExprId

// Phase 9 Stage 5 (struct-backing): result of folding a per-case struct
// backing access chain at parse / type-resolution time. `found = true`
// means the chain folded successfully and `intValue` / `floatBits` carry
// the leaf constant; `kind` distinguishes int (or bool) from float so the
// parser emits the right `MaxonOp.literal` valueType. `found = false`
// signals "could not fold" — caller surfaces a clear diagnostic.
export type StructBackingFoldResult
	export var found bool
	export var isFloat bool
	export var intValue IntConstant
	export var floatBits IntConstant

	export static function notFound() returns StructBackingFoldResult
		return Self{found: false, isFloat: false, intValue: 0, floatBits: 0}
	end 'notFound'

	export static function intHit(value IntConstant) returns StructBackingFoldResult
		return Self{found: true, isFloat: false, intValue: value, floatBits: 0}
	end 'intHit'

	export static function floatHit(bits IntConstant) returns StructBackingFoldResult
		return Self{found: true, isFloat: true, intValue: 0, floatBits: bits}
	end 'floatHit'
end 'StructBackingFoldResult'

// Phase 9 Stage 5: single descend step in a struct-backing field chain.
// `found = true` means the named field exists in the current `structLit`
// arena entry and `exprId` is its sub-expression's id. `found = false`
// means the current entry isn't a struct, or the field wasn't declared.
// We need an explicit `found` flag because arena id 0 IS a valid entry —
// using 0 as a sentinel would collide with the first int literal pushed
// into the arena.
export type StructBackingDescendResult
	export var found bool
	export var exprId UnresolvedConstExprId

	export static function none() returns StructBackingDescendResult
		return Self{found: false, exprId: 0}
	end 'none'

	export static function hit(exprId UnresolvedConstExprId) returns StructBackingDescendResult
		return Self{found: true, exprId: exprId}
	end 'hit'
end 'StructBackingDescendResult'

// Cases are grouped so the four "structurally type-pinning" arms
// (`boolLit`, `floatLit`, `enumCase`, `asCast`) sit at the front as a
// contiguous block. Every other arm folds to the runtime
// ConstantValue tag, so they form one contiguous fallback range
// (`intLit to logicalOr`) that downstream `match` over this union can
// catch with a single range pattern.
export union UnresolvedConstExpr
	// --- Type-pinning forms (decide MaxonType structurally). ---

	// Boolean literal. Slot type is always `MaxonType.boolean` regardless
	// of fold result.
	boolLit(value bool)

	// Float literal raw bits. Slot type is always `MaxonType.float`.
	floatLit(bits IntConstant)

	// Enum case reference (`EnumName.caseName`). Captured structurally
	// because the enum may not be drained from `unresolvedEnums` into
	// `enumTypes` at parse time. Resolver folds this to the enum's
	// integer / float raw value once the enum's drain has run; slot type
	// is interned from the enum name.
	enumCase(enumName String, caseName String)

	// `<expr> as TypeName` — a postfix cast against a ranged-primitive
	// typealias. Resolver validates the operand is in range and threads
	// the named MaxonType through to the TopLevelVarInfo's slotType so
	// downstream loads/stores know the alias.
	asCast(operand UnresolvedConstExprId, typeName String)

	// --- Fallback forms (slot type comes from the folded value). ---
	// Order is fixed: callers depend on `intLit to logicalOr` being one
	// contiguous range that excludes the type-pinning arms above.

	// Compile-time integer / string literal.
	intLit(value IntConstant)
	stringLit(stringId StringId)

	// Forward-deferred reference to another top-level constant. The
	// resolver looks `name` up in `topLevelConstants` (already-evaluated)
	// or `unresolvedTopLevelDecls` (recurse with cycle check).
	nameRef(name String)

	// Unary ops over an arena id.
	negate(operand UnresolvedConstExprId)
	notOp(operand UnresolvedConstExprId)

	// Binary `+` / `-` / `*` over arena ids.
	add(left UnresolvedConstExprId, right UnresolvedConstExprId)
	sub(left UnresolvedConstExprId, right UnresolvedConstExprId)
	mul(left UnresolvedConstExprId, right UnresolvedConstExprId)

	// Comparison operators. Fold to `intValue(0)` / `intValue(1)` like
	// `boolLit`, so a top-level `let IS_LARGE = 100 > 50` substitutes as
	// `intValue(1)` at every read site — matching the existing boolean
	// representation used by `if` / `and` / `or` lowering.
	compareEq(left UnresolvedConstExprId, right UnresolvedConstExprId)
	compareNeq(left UnresolvedConstExprId, right UnresolvedConstExprId)
	compareLt(left UnresolvedConstExprId, right UnresolvedConstExprId)
	compareLte(left UnresolvedConstExprId, right UnresolvedConstExprId)
	compareGt(left UnresolvedConstExprId, right UnresolvedConstExprId)
	compareGte(left UnresolvedConstExprId, right UnresolvedConstExprId)

	// Logical / bitwise `and` / `xor` / `or`. Booleans are stored as
	// `intValue(0|1)`, so the integer bitwise operation produces the
	// expected result for both bool and int operands. Precedence runs
	// `and` > `xor` > `or`, matching the runtime expression grammar.
	logicalAnd(left UnresolvedConstExprId, right UnresolvedConstExprId)
	logicalXor(left UnresolvedConstExprId, right UnresolvedConstExprId)
	logicalOr(left UnresolvedConstExprId, right UnresolvedConstExprId)

	// Phase 9 Stage 5 (struct-backing): an enum-case `= StructType{...}` or
	// `= StructType.create(...)` literal. `fieldNames` and `fieldExprs` are
	// parallel arrays — `fieldExprs.get(i)` is the arena id of the i-th
	// field's value subexpression. Nested struct literals reference more
	// `structLit` arena entries through their field-expr ids, so the tree
	// is heap-bounded but supports arbitrary nesting.
	structLit(structTypeName String, fieldNames StringArray, fieldExprs UnresolvedConstExprIdArray)
end 'UnresolvedConstExpr'

export typealias UnresolvedConstExprArray = Array with UnresolvedConstExpr

// One pending top-level binding awaiting evaluation. Covers both immutable
// `let NAME = ...` constants (drained into `topLevelConstants`) and mutable
// `var NAME = ...` / `static var NAME = ...` globals (drained into
// `topLevelVars` as a `.data` slot). The two destinations are dispatched on
// `mutable` at drain time, so the parser uses one registration path and
// the resolver does one walk.
export type UnresolvedTopLevelDecl
	export var name String
	// Index into project.unresolvedConstExprs for the root of the
	// initializer expression tree.
	export var rootExprId UnresolvedConstExprId
	// True for `var` / `static var`; false for `let` / `static let`.
	// Determines whether the resolved value lands in the writable `.data`
	// section or as an inlined constant the rewriter substitutes at use sites.
	export var mutable bool
	// Visibility tier. The parser stamps in `exported` when the decl
	// carries `export`, `module` when preceded by the contextual
	// `module` keyword, otherwise `file`.
	export var visibility Visibility
	// Parse-time source location for resolver-emitted diagnostics (cycle,
	// unknown-name). `filePath` doubles as the visibility anchor —
	// visibility lookups compare against this.
	export var line LineNumber
	export var column ColumnNumber
	export var filePath FilePath

	export static function create(name String, rootExprId UnresolvedConstExprId, mutable bool, visibility Visibility, line LineNumber, column ColumnNumber, filePath FilePath) returns UnresolvedTopLevelDecl
		return Self{name: name, rootExprId: rootExprId, mutable: mutable, visibility: visibility, line: line, column: column, filePath: filePath}
	end 'create'
end 'UnresolvedTopLevelDecl'

export typealias UnresolvedTopLevelDeclMap = Map with(String, UnresolvedTopLevelDecl)

// One top-level / static-field mutable var. The qualified name (used as
// the map key) is the source-level identifier; the slot lives in the
// writable .data section as an 8-byte entry per var, with the initial
// value materialized into the section bytes at link time. Load/store at
// runtime go through RIP-relative addressing of the symbol name. The IR
// op family (`globalLoad`/`globalStore`/`globalAddr`) keeps the "global"
// label because that is the lowering technique — RIP-relative reads
// against a linker symbol — regardless of whether the source-level decl
// was exported.
//
// `visibility` and `sourceFilePath` carry the source-level visibility
// tier and declaring file path so cross-file reads can filter by
// `isVisibleFrom`.
export type TopLevelVarInfo
	export var name String
	export var slotType MaxonType
	export var initialValue IntConstant
	export var visibility Visibility
	export var sourceFilePath FilePath

	export static function create(name String, slotType MaxonType, initialValue IntConstant, visibility Visibility, sourceFilePath FilePath) returns TopLevelVarInfo
		return Self{name: name, slotType: slotType, initialValue: initialValue, visibility: visibility, sourceFilePath: sourceFilePath}
	end 'create'
end 'TopLevelVarInfo'

export typealias TopLevelVarMap = Map with(String, TopLevelVarInfo)

// Phase 15e: parser-pinned tuple-allocation result name -> generic-instance id.
// Used by lowerStructAlloc to recover the specialised receiver type that the
// parser computed at parse time but cannot stash on the structAlloc op itself
// (the op's only payload is the bare struct name).
export typealias TupleAllocGidMap = Map with(ByteArray, GenericInstanceId)

export type TypealiasRange
	export var lower RangeBound
	export var upper RangeBound

	export static function create(lower RangeBound, upper RangeBound) returns TypealiasRange
		return Self{lower: lower, upper: upper}
	end 'create'
end 'TypealiasRange'

export function createProject(rootPath FilePath, target Target) returns Project
	let emptyMaxonMemo = MaxonModuleMemo.create(MaxonModule.create(), computedAt: 0, verifiedAt: 0)
	let emptyStdMemo = StdModuleMemo.create(StdModule.create(), computedAt: 0, verifiedAt: 0)
	let emptyCodeMemo = CodeMemo.create(CodeResult.create(ByteArray.create(), mainCallFixupOffset: 0, relocations: RelocationArray.create(), globalData: createGlobalDataTable(), targetModule: TargetModule.create(target.cpu), mirModule: MirModule.create(), rdata: ByteArray.create(), rdataRelocations: RdataRelocationArray.create(), symdata: ByteArray.create(), covDataSectionBytes: ByteArray.create()), computedAt: 0, verifiedAt: 0)
	let db = QueryDatabase.create(emptyMaxonMemo, emptyStdMemo: emptyStdMemo, emptyCodeMemo: emptyCodeMemo)
	return Project.create(db, rootPath: rootPath, target: target)
end 'createProject'

export function hasErrors(project Project) returns bool
	return project.diagnostics.count() > 0
end 'hasErrors'

// True when at least one diagnostic represents a structural failure that
// makes downstream IR passes unsafe to run — lexer (1xxx), parser (2xxx),
// or IR-stage (4xxx) errors. Pure semantic-stage diagnostics (3xxx) leave
// the IR intact and are safe to flow through type-resolution / visibility
// passes so additional follow-up errors (e.g. cross-file `as Hidden` →
// E2003) can still be reported alongside them.
export function hasStructuralErrors(project Project) returns bool
	for d in project.diagnostics 'eachDiag'
		let raw = d.code.rawValue
		if raw < 3000 or (raw >= 4000 and raw < 5000) 'isStructural'
			return true
		end 'isStructural'
	end 'eachDiag'
	return false
end 'hasStructuralErrors'

// Resolve a source-level type name to its MaxonType, interning the name when
// it is not a primitive. All source-level names (typealiases, struct types,
// etc.) flow through the same path: the parser records MaxonType.named(id)
// and the later TypeResolution pass validates that the id maps to a known
// type.
export function resolveType(project Project, name String) returns MaxonType
	return internMaxonType(project, name: name)
end 'resolveType'

// Resolve a MaxonType through the typealias map to its concrete StdType.
// For named types, looks up the alias; for boolean/integer/float, picks a
// default. MaxonType is value-only so void never reaches this function —
// function return types go through maxonReturnTypeToStdReturnType instead.
export function resolveMaxonTypeToStd(project Project, ref MaxonType) returns StdType
	// MaxonType.string has no Std representation yet. Type-checking at call
	// sites must reject string flows before lowering reaches this path. If
	// we ever do see one here, panic loudly — it means a pass upstream of
	// lowering let a string-typed value escape. The match below covers the
	// numeric and named cases; the string case is handled separately so the
	// panic message can carry context.
	match ref 'stringGuard'
		string then panic("resolveMaxonTypeToStd: MaxonType.string has no Std representation; callers should have type-checked the value out before lowering")
		boolean then return StdType.i1
		integer then return StdType.i64
		float then return StdType.f64
		named(id) then return resolveNamedIdToStdType(project, id: id)
		// Function-typed values lower to a (function-pointer, env-pointer)
		// pair at the ABI level. The fn-pointer slot itself is i64; the
		// matching env-pointer slot is plumbed alongside via the
		// `fnEnvVarNames` map in LowerMaxonToStd and emitted as a separate
		// ABI param. Returning i64 here covers both the fn-pointer slot
		// type and the producer-result type for `functionRef` /
		// `closureCreate`.
		function then return StdType.i64
		unresolved then panic("resolveMaxonTypeToStd: MaxonType.unresolved survived past TypeResolution. This means a value's producer op was not handled by TypeResolution's first pass (buildProducerTypes in TypeResolution.maxon — see callResultType, fieldLoadResultType, etc.). Recently added op kinds or callee names may need an entry there. Stack trace above shows the consumer that tripped the guard.")
		// Phase 11.0 step 8b: generic-aware arms reach lowering once the
		// hybrid-generic code paths are wired. Each variant currently
		// lowers to a single i64 ABI slot — typeParameters carry whatever
		// concrete value flows at the call site, genericInstance values are
		// represented by their (struct-pointer-or-payload) i64 word, and
		// interfaces are eventually fat pointers (16 bytes) but for the
		// minimum-Array slice we treat them as i64 since interface-typed
		// values inside generic bodies don't yet differentiate the witness
		// pointer from the value at this layer.
		typeParameter then return StdType.i64
		genericInstance then return StdType.i64
		interface then return StdType.i64
		constInt then return StdType.i64
	end 'stringGuard'
end 'resolveMaxonTypeToStd'

// Look up a named type in the project registries and return its ABI-level
// StdType. Registered typealiases resolve to their declared base type;
// struct types resolve to i64 because they are passed by pointer. Anything
// else is a compiler bug — the TypeResolution pass is responsible for
// catching unregistered names before we get here, so an unresolved name at
// this point means that pass was skipped or failed to diagnose something it
// should have.
export function resolveNamedToStdType(project Project, name String) returns StdType
	let aliased = try project.typealiases.get(name) otherwise 'notAlias'
		if project.structTypes.contains(name) 'isStruct'
			return StdType.i64
		end 'isStruct'
		if let enumType = try project.enumTypes.get(name) 'isEnum'
			if enumType.isFloatBacked 'floatEnum'
				return StdType.f64
			end 'floatEnum'
			return StdType.i64
		end 'isEnum'
		// Phase 11.0 step 8b: a named-type that survived TypeResolution
		// without resolving to a primitive/struct/enum is most often a
		// generic-typealias placeholder (`ElementMemory = __ManagedMemory
		// with Element`) or an inner-alias defined on a struct body
		// (`ElementMemory` inside `type Array uses Element`). Both
		// ultimately lower to a single i64 ABI slot — generic instances of
		// these aliases always shape themselves around a managed-memory or
		// struct pointer, and inner-alias placeholders carry the same
		// representation. Returning i64 here lets generic body lowering
		// proceed without needing a separate substitution-walking pass.
		if project.genericTypealiases.contains(name) 'isGenericAlias'
			return StdType.i64
		end 'isGenericAlias'
		if anyStructHasInnerAlias(project, aliasName: name) 'isInnerAlias'
			return StdType.i64
		end 'isInnerAlias'
		if project.interfaces.contains(name) or project.unresolvedInterfaces.contains(name) 'isInterface'
			panic("resolveNamedToStdType: interface name '{name}' reached value-position lowering as MaxonType.named — C1.c interface fat-pointer construction was supposed to handle this; investigate the call path")
		end 'isInterface'
		// Phase 7 / Phase 11.4 partial: stdlib types that depend on
		// not-yet-whitelisted helper files (e.g. `ByteView` from
		// `stdlib/helpers/string/views.maxon`) reach lowering as
		// unresolved named types. Treat as i64 like genericTypealiases
		// and inner-aliases — the stdlib's own callers will surface a
		// real error if the value is misused; the compiler shouldn't
		// panic on stdlib half-loaded state.
		return StdType.i64
	end 'notAlias'
	return aliased
end 'resolveNamedToStdType'

export function resolveNamedIdToStdType(project Project, id TypeNameId) returns StdType
	return resolveNamedToStdType(project, name: project.typeNames.get(id))
end 'resolveNamedIdToStdType'

// Phase 11.0 step 8b: scan struct bodies for an inner-alias entry matching
// `aliasName`. Used by `resolveNamedToStdType` to recognize names that
// originated from per-struct inner typealiases (e.g. `ElementMemory`
// declared inside `type Array uses Element`) so they can lower to the
// shared i64 ABI representation rather than triggering the
// "unknown named type" panic.
export function anyStructHasInnerAlias(project Project, aliasName String) returns bool
	for (_, st) in project.structTypes 'eachStruct'
		if st.innerAliases.contains(aliasName) 'hit'
			return true
		end 'hit'
	end 'eachStruct'
	return false
end 'anyStructHasInnerAlias'

// Struct field descriptor: name, type, byte offset, and `var`/`let`
// mutability. `isMutable` mirrors the source-level keyword so post-construction
// writes (`receiver.field = value`) can be rejected with E2013 against
// `let`-declared fields without re-parsing.
export type StructField
	export var name String
	export var fieldType MaxonType
	export var offset FieldOffset
	export var isMutable bool
	// True when the field declaration carried a `= <expr>` default value.
	// At parse time, a synthetic helper `<TypeName>.__field_init_<fieldName>`
	// is generated that evaluates the default expression; this flag tells
	// the struct-literal lowerer to call that helper for any literal that
	// omits this field.
	export var hasDefault bool
	// Sentinel that distinguishes "the layout pass has run and stamped a real
	// offset" from "this field still holds the parser-time zero placeholder".
	// `FieldOffset` is `int(0 to 65520)`, so the value 0 alone cannot tell a
	// pre-layout placeholder from a legitimate first-field offset. The
	// `layoutAllStructs` pass in TypeResolution sets this `true` on every
	// field it processes; downstream consumers (fieldLoad/fieldStore lowering)
	// panic on `not offsetResolved` to catch any code path that bypasses the
	// pass — silent layout corruption would otherwise be possible.
	export var offsetResolved bool
	// True when the field declaration carried the `export` modifier. Fields
	// without it are accessible only from inside the type's own methods —
	// external read/write sites (`v.field` outside `type Value`) emit E3014
	// `semanticUnexportedFieldAccess`. Struct-literal initialization
	// (`Value{field: ...}`) is always permitted regardless: the type's own
	// shape determines what fields exist, and visibility only governs access
	// after construction.
	export var isExported bool

	export static function create(name String, fieldType MaxonType, offset FieldOffset, isMutable bool, hasDefault bool = false, offsetResolved bool = false, isExported bool = false) returns StructField
		return Self{name: name, fieldType: fieldType, offset: offset, isMutable: isMutable, hasDefault: hasDefault, offsetResolved: offsetResolved, isExported: isExported}
	end 'create'
end 'StructField'

export typealias FieldOffset = int(0 to 65520)
export typealias FieldCount = int(0 to 64)
export typealias StructFieldArray = Array with StructField
export typealias FieldIndex = int(0 to 64)
export typealias FieldNameIndexMap = Map with(String, FieldIndex)

// Struct type descriptor: name, fields (in declaration order), total byte
// size, and a name → field-index map. The index is built once at struct
// registration so call-site fieldLoad / fieldStore / selfFieldLoad /
// selfFieldStore lowering hits an O(1) hash lookup instead of an O(fields)
// linear scan per field access.
export type StructType
	export var name String
	export var fields StructFieldArray
	export var byteSize FieldOffset
	export var fieldByName FieldNameIndexMap
	// Visibility tier and declaring file path. Cross-file references
	// (named-type operands, struct-alloc op, dot-prefixed static/method
	// dispatch) consult these via `isVisibleFrom` against the reader's
	// path. Stdlib-cached struct types synthesize `(global, stdlib
	// bootstrap path)` so user code reaching a stdlib struct is always
	// permitted.
	export var visibility Visibility
	export var sourceFilePath FilePath
	// Source location of the `type Name` token. Used by Phase 3b's
	// conformance check (E3016) to anchor the diagnostic at the type
	// declaration rather than the file root. Stdlib-cached struct types
	// land at (0, 0) — they never carry an `implements` clause, so the
	// conformance check never reads these fields for them.
	export var nameLine LineNumber
	export var nameColumn ColumnNumber
	// Phase 3a: the method signatures the type is required to provide,
	// derived from `implementedInterfaces` with each interface's
	// type-parameter names (`Element`, `Iter`, ...) substituted by the
	// concrete types from the conformance's `with` clause. Phase 3b walks
	// this list against the type's actual methods to enforce conformance
	// (E3016). Empty when the type declares no `implements` clause or its
	// clause was rejected with E3015.
	export var expectedMethods InterfaceMethodSigArray
	// Phase 11.0 step 2: resolved inner-typealias table for this type.
	// Promoted from `UnresolvedStructType.innerAliases` during the struct
	// drain pass. Empty when the type body declared no inner typealiases.
	// Step 5+ consults this map during substitution so a method body that
	// names `ElementMemory` can resolve it back to the concrete generic
	// instance the parser captured.
	export var innerAliases ResolvedInnerAliasMap

	export static function create(name String, fields StructFieldArray, byteSize FieldOffset, visibility Visibility, sourceFilePath FilePath, nameLine LineNumber, nameColumn ColumnNumber, expectedMethods InterfaceMethodSigArray, innerAliases ResolvedInnerAliasMap) returns StructType
		var fieldByName = FieldNameIndexMap.create()
		for i in 0 upto fields.count() 'buildIndex'
			let field = try fields.get(i) otherwise panic("StructType.create: fields.get OOB at {i} (count={fields.count()})")
			try fieldByName.insert(field.name, value: i) otherwise panic("StructType.create: duplicate field '{field.name}' on type '{name}' (parser should reject earlier)")
		end 'buildIndex'
		return Self{name: name, fields: fields, byteSize: byteSize, fieldByName: fieldByName, visibility: visibility, sourceFilePath: sourceFilePath, nameLine: nameLine, nameColumn: nameColumn, expectedMethods: expectedMethods, innerAliases: innerAliases}
	end 'create'
end 'StructType'

export typealias StructTypeMap = Map with(String, StructType)
export typealias StructTypeArray = Array with StructType

// Phase 11.0 step 2: resolved-form of inner typealiases. Mirrors
// `GenericTypealiasMap`'s shape; lives on `StructType` so per-type
// substitution can resolve names declared inside the type body.
export typealias ResolvedInnerAliasMap = Map with(String, MaxonType)

// --- Enum types ---
//
// Each enum case carries its declaration ordinal (the position in the source
// case list) and its raw value. Int-backed enums store the raw value as an
// IntConstant; float-backed enums store the IEEE-754 bits in the same field
// (the `EnumType.isFloatBacked` flag tells consumers how to interpret it).
// Source location is captured to anchor parser-time diagnostics (E3030 / E3031
// / E3032) at the case rather than the enum declaration.
//
// Phase 9 Stage 2 (associated-value unions): each case may carry zero or more
// payload fields. Plain enums (and bare-case unions) always have an empty
// `payloadFields`. The enclosing `EnumType.isUnion` flag captures whether the
// declaration was a `union ...` (heap-pointer identity) or a plain `enum ...`
// (value-typed alias). The two registries share storage because resolution
// machinery is identical for both — only lowering diverges.
export type EnumPayloadField
	export var name String
	export var fieldType MaxonType

	export static function create(name String, fieldType MaxonType) returns EnumPayloadField
		return Self{name: name, fieldType: fieldType}
	end 'create'
end 'EnumPayloadField'

export typealias EnumPayloadFieldArray = Array with EnumPayloadField

export type EnumCase
	export var name String
	export var ordinal CaseOrdinal
	export var rawValue IntConstant
	export var line LineNumber
	export var column ColumnNumber
	// Phase 9 Stage 2: associated-value payload fields for union cases.
	// Empty for plain enum cases and for bare union cases. Each entry is a
	// (name, MaxonType) pair captured at parse time; lowering (Stage 3)
	// resolves the type and emits the appropriate alloc + store sequence.
	export var payloadFields EnumPayloadFieldArray
	// Phase 9 Stage 5 (struct-backing): when non-empty, the case carries a
	// struct literal as its compile-time backing (e.g.
	// `Instruction.add = OpMeta{latency: 1}`). `backingStructName` is the
	// declared struct type name; `backingStructExprId` indexes
	// `project.unresolvedConstExprs` at the root of a `structLit` arena
	// entry whose fields hold the per-case constants. Empty string +
	// sentinel `0` when the case has no struct backing.
	export var backingStructName String
	export var backingStructExprId UnresolvedConstExprId
	// Phase 9 (string/char-backed enums): decoded text of the raw value
	// when the case was declared as `caseName = "literal"` or
	// `caseName = 'literal'`. Empty string when the case has no
	// string/char backing. The runtime representation of the enum value
	// remains the ordinal (`rawValue == ordinal`); this field is the
	// compile-time literal used by interpolation and `.rawValue` /
	// `.fromName` lookups. The enclosing `EnumType.isStringBacked` /
	// `isCharBacked` flag tells consumers how to interpret the bytes.
	export var rawStringValue String

	export static function create(name String, ordinal CaseOrdinal, rawValue IntConstant, line LineNumber, column ColumnNumber, payloadFields EnumPayloadFieldArray = EnumPayloadFieldArray.create(), backingStructName String = "", backingStructExprId UnresolvedConstExprId = 0, rawStringValue String = "") returns EnumCase
		return Self{name: name, ordinal: ordinal, rawValue: rawValue, line: line, column: column, payloadFields: payloadFields, backingStructName: backingStructName, backingStructExprId: backingStructExprId, rawStringValue: rawStringValue}
	end 'create'
end 'EnumCase'

export typealias CaseOrdinal = int(0 to 65535)
export typealias EnumCaseArray = Array with EnumCase
export typealias CaseIndexMap = Map with(String, CaseOrdinal)

// Phase 9 Stage 2: derive `isUnion` from the case list. The invariant the
// parser maintains is "any case with non-empty payloadFields => isUnion",
// but bare-case unions (no payloads at all) must still flow through the
// union codegen path, so the parser passes the flag explicitly rather than
// re-deriving it here.
export function enumCasesAnyPayload(cases EnumCaseArray) returns bool
	for c in cases 'scan'
		if c.payloadFields.count() > 0 'hasPayload'
			return true
		end 'hasPayload'
	end 'scan'
	return false
end 'enumCasesAnyPayload'

// True when at least one case carries a `rawValue` that differs from its
// declaration ordinal — i.e. the user wrote `= N` on some case so the enum
// has an explicit int (or float) backing rather than the default
// auto-incremented sequence. String-interpolation lowering uses this to
// decide between case-name lookup (implicit ordinals) and raw-value
// stringification (explicit backing), matching the bootstrap behavior
// where `enum Color { red = 1; green = 2 }` prints "1" / "2" but
// `enum Direction { north; south; east; west }` prints "north" etc.
export function enumHasExplicitBacking(enumDef EnumType) returns bool
	if enumDef.isFloatBacked or enumDef.isStringBacked or enumDef.isCharBacked 'asNonInt'
		return true
	end 'asNonInt'
	for c in enumDef.cases 'scan'
		if c.rawValue != c.ordinal as IntConstant 'differs'
			return true
		end 'differs'
	end 'scan'
	return false
end 'enumHasExplicitBacking'

export type EnumType
	export var name String
	export var cases EnumCaseArray
	export var isFloatBacked bool
	// Phase 9 (string/char-backed enums): true when raw values were
	// declared as string/char literals. Mutually exclusive with
	// `isFloatBacked` (and with each other); the parser enforces the
	// invariant. Runtime representation is still the per-case ordinal —
	// these flags only tell interpolation / lookup helpers to read the
	// declared literal from `EnumCase.rawStringValue` instead of treating
	// `rawValue` as an int / float bit pattern.
	export var isStringBacked bool
	export var isCharBacked bool
	export var caseByName CaseIndexMap
	// Visibility tier and declaring file path. Cross-file references
	// (named-type operands, dot-prefixed case reads when no top-level
	// constant matches) consult these via `isVisibleFrom` against the
	// reader's path. Stdlib enums get `(global, stdlib bootstrap path)`.
	export var visibility Visibility
	export var sourceFilePath FilePath
	// Source location of the `enum Name` token. Mirrors `StructType.nameLine`
	// / `nameColumn` — Phase 3b's E3016 anchors at the enum decl when an
	// enum's conformance check fails. Stdlib-cached enums land at (0, 0)
	// because they never carry an `implements` clause.
	export var nameLine LineNumber
	export var nameColumn ColumnNumber
	// Phase 3a: substituted method signatures from the enum's
	// `implements` clause. Mirrors `StructType.expectedMethods`. Enums
	// can declare regular `function` members in their body, so the
	// conformance check in Phase 3b is identical to structs.
	export var expectedMethods InterfaceMethodSigArray
	// Phase 9 Stage 2: true when the declaration was `union ...` rather
	// than `enum ...`. Union values are heap pointers with distinct type
	// identity (typealias injection emits `MaxonType.named`, not a ranged
	// int alias). Plain enums always have `isUnion: false`; the invariant
	// `enumCasesAnyPayload(cases) implies isUnion` is enforced in `create`.
	export var isUnion bool

	export static function create(name String, cases EnumCaseArray, isFloatBacked bool, visibility Visibility, sourceFilePath FilePath, nameLine LineNumber, nameColumn ColumnNumber, expectedMethods InterfaceMethodSigArray, isUnion bool = false, isStringBacked bool = false, isCharBacked bool = false) returns EnumType
		var caseByName = CaseIndexMap.create()
		for i in 0 upto cases.count() 'buildIndex'
			let c = try cases.get(i) otherwise panic("EnumType.create: cases.get OOB at {i}")
			try caseByName.insert(c.name, value: i as CaseOrdinal) otherwise panic("EnumType.create: duplicate case '{c.name}' on enum '{name}' (parser should reject earlier)")
		end 'buildIndex'
		if enumCasesAnyPayload(cases) and not isUnion 'invariant'
			panic("EnumType.create: enum '{name}' has payload cases but isUnion is false")
		end 'invariant'
		// String/char/float backings are mutually exclusive — the parser
		// emits an E3032 the moment it sees a second-kind raw value, so by
		// the time we reach `create` at most one flag is true.
		if isFloatBacked and (isStringBacked or isCharBacked) 'badMix1'
			panic("EnumType.create: enum '{name}' has multiple scalar backings (float+string/char)")
		end 'badMix1'
		if isStringBacked and isCharBacked 'badMix2'
			panic("EnumType.create: enum '{name}' has both string and char backings")
		end 'badMix2'
		return Self{name: name, cases: cases, isFloatBacked: isFloatBacked, isStringBacked: isStringBacked, isCharBacked: isCharBacked, caseByName: caseByName, visibility: visibility, sourceFilePath: sourceFilePath, nameLine: nameLine, nameColumn: nameColumn, expectedMethods: expectedMethods, isUnion: isUnion}
	end 'create'
end 'EnumType'

export typealias EnumTypeMap = Map with(String, EnumType)

export type UnresolvedEnumType
	export var name String
	export var cases EnumCaseArray
	export var isFloatBacked bool
	// Phase 9 (string/char-backed enums): mirror of `EnumType`'s flags.
	// Promoted unchanged when TypeResolution constructs the resolved
	// `EnumType`. Mutually exclusive with each other and with
	// `isFloatBacked`; the parser enforces the invariant.
	export var isStringBacked bool
	export var isCharBacked bool
	// Visibility tier from the enum declaration's modifier. Used to
	// stamp the per-case `TopLevelConstant`s and the implicit typealias
	// the parser registers for the enum's name. The pre-register entry
	// (created before the body is walked) reuses this when patched.
	export var visibility Visibility
	export var line LineNumber
	export var column ColumnNumber
	export var filePath FilePath
	// Phase 1b: the parsed `implements I1, I2, ...` clause, captured as
	// bare interface and type-parameter names. Empty when no clause was
	// present. Phase 3 will validate conformance — currently metadata only.
	export var implementedInterfaces ConformanceArray
	// Phase 9 Stage 2: mirror of `EnumType.isUnion`. The pre-register
	// stage and post-body promotion (TypeResolution) carry the flag through
	// so consumers branching on union-vs-plain semantics see the right
	// answer at both stages.
	export var isUnion bool

	export static function create(name String, cases EnumCaseArray, isFloatBacked bool, visibility Visibility, line LineNumber, column ColumnNumber, filePath FilePath, implementedInterfaces ConformanceArray, isUnion bool = false, isStringBacked bool = false, isCharBacked bool = false) returns UnresolvedEnumType
		if enumCasesAnyPayload(cases) and not isUnion 'invariant'
			panic("UnresolvedEnumType.create: enum '{name}' has payload cases but isUnion is false")
		end 'invariant'
		return Self{name: name, cases: cases, isFloatBacked: isFloatBacked, isStringBacked: isStringBacked, isCharBacked: isCharBacked, visibility: visibility, line: line, column: column, filePath: filePath, implementedInterfaces: implementedInterfaces, isUnion: isUnion}
	end 'create'
end 'UnresolvedEnumType'

export typealias UnresolvedEnumTypeMap = Map with(String, UnresolvedEnumType)

// TargetModule: the top-level container for the target (x64/arm64) phase.
// Holds target-specific machine ops, blocks, and functions for a single
// compilation unit. Produced by lowerMirToTarget; consumed by the register
// allocator, prologue/epilogue pass, instruction scheduler, and code
// emitter.
//
// A single TargetModule holds ONE of x64Ops or arm64Ops — never both. The
// `cpu` field discriminates which array is active. Backend passes that
// care about the specific ISA dispatch on cpu. This shape is simpler than
// four fully separate X64Module/Arm64Module types because all the shared
// regalloc machinery would otherwise need two copies.
//
// An IrBlock's opRefs are plain indices into whichever op array is
// active per module.cpu; the type system still guarantees that no non-
// target op can land here, because the module only has x64Ops and
// arm64Ops arrays.
//
// At the Target phase, IrFunction's spillSize and calleeSavedGprs/calleeSavedFps
// fields are populated by the register allocator and prologue/epilogue pass.

// TargetModule: top-level container for a compilation unit at the target
// phase. Holds either x64Ops or arm64Ops (not both) depending on cpu.
export type TargetModule
	export var functions IrFunctionArray
	export var blocks IrBlockArray
	export var x64Ops X64OpArray
	export var arm64Ops Arm64OpArray
	export var cpu CpuArch

	export static function create(cpu CpuArch) returns TargetModule
		return Self{
			functions: IrFunctionArray.create(),
			blocks: IrBlockArray.create(),
			x64Ops: X64OpArray.create(),
			arm64Ops: Arm64OpArray.create(),
			cpu: cpu
		}
	end 'create'

	// Count ops still reachable from any block. Shared with IrModule via
	// `countLiveOps`; both modules report block-reachable counts so post-
	// rewrite passes don't double-count dropped, unreferenced entries in
	// the underlying op array. Cold path — only called when ir-trace
	// logging or `--dump-stages` is on.
	export function liveOpCount() returns OpCount
		return countLiveOps(self.functions, blocks: self.blocks)
	end 'liveOpCount'
end 'TargetModule'

// ============================================================
// Op append / terminator helpers
// ============================================================

export function appendX64Op(module TargetModule, block IrBlock, op X64Op)
	let idx = module.x64Ops.count()
	module.x64Ops.push(op)
	block.opRefs.append(idx)
end 'appendX64Op'

export function appendArm64Op(module TargetModule, block IrBlock, op Arm64Op)
	let idx = module.arm64Ops.count()
	module.arm64Ops.push(op)
	block.opRefs.append(idx)
end 'appendArm64Op'

export function setX64Terminator(module TargetModule, block IrBlock, op X64Op)
	let idx = module.x64Ops.count()
	module.x64Ops.push(op)
	block.terminator = Terminator.opIndex(idx)
end 'setX64Terminator'

export function setArm64Terminator(module TargetModule, block IrBlock, op Arm64Op)
	let idx = module.arm64Ops.count()
	module.arm64Ops.push(op)
	block.terminator = Terminator.opIndex(idx)
end 'setArm64Terminator'

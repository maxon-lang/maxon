// Dead Code Elimination (DCE) Pass.
// Walks module -> functions -> blocks -> ops in two phases.
// Phase 1: Count uses of each ValueId across all ops.
// Phase 2: Remove ops whose resultId has zero uses and no side effects.
//
// Side-effect ops that must NOT be removed (even with zero uses):
//   func.call, func.tryCall, func.indirectCall, func.tailCall, func.ret,
//   sys.*, runtime.*, memref.storeSlot, cf.* (terminators),
//   any op without a resultId.
//
// Safe to remove with zero uses:
//   arith.const, arith.binary, arith.unary, memref.loadSlot, func.param, func.funcRef.

// Use-count table: maps ValueId -> number of times it appears as an operand.

function incrementUse(table ValueIdArray, valueId ValueId)
	while table.count() <= valueId 'grow'
		table.push(0)
	end 'grow'
	let current = try table.get(valueId) otherwise panic("incrementUse: table grown to include valueId={valueId} but get failed (count={table.count()})")
	try table.set(valueId, value: current + 1) otherwise panic("invariant: table.set OOB")
end 'incrementUse'

function getUseCount(table ValueIdArray, valueId ValueId) returns ValueId
	if valueId >= table.count() 'outOfBounds'
		return 0
	end 'outOfBounds'
	return try table.get(valueId) otherwise panic("getUseCount: valueId < table.count() just checked but get({valueId}) failed")
end 'getUseCount'

export function eliminateDeadCode(module StdModule) returns StdModule
	for funcIdx in 0 upto module.functions.count() 'eachFunc'
		var func = try module.functions.get(funcIdx) otherwise panic("Function not found in module")

		// Phase 1: Count uses of every ValueId across the entire function.
		// Void-returning functions have an implicit `return 0` injected by the
		// parser; treating that ret as a use would pin the unused zero through
		// the entire pipeline (and downstream into a dead `xor r8d, r8d` in
		// codegen). Skip the use-count for void rets so the producer becomes
		// dead and gets removed below.
		var useCount = ValueIdArray.create()
		let isVoid = stdReturnTypeIsVoid(func.returnType)

		for blockRef in func.blockRefs 'countBlocks'
			let block = try module.blocks.get(blockRef) otherwise panic("Block not found in module")
			for packed in block.opRefs 'countOps'
				countPackedOpUses(module, opIdx: packed, useCount: useCount, isVoidFunc: isVoid)
			end 'countOps'
			if block.hasTerminatorOp() 'countTerm'
				countPackedOpUses(module, opIdx: block.terminatorIndex(), useCount: useCount, isVoidFunc: isVoid)
			end 'countTerm'
		end 'countBlocks'

		// Phase 2: Filter dead ops in-place
		for blockRef in func.blockRefs 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise panic("Block not found in module")

			let oldOps = block.opRefs
			block.opRefs = OpIndexList.create()
			for packed in oldOps 'filterOps'
				if isDeadPackedOp(module, opIdx: packed, useCount: useCount) 'dead'
					logTrace(LogCategory.ir, message: () gives "dce: removing dead op with resultId {getPackedOpResultId(module, opIdx: packed)}")
					continue
				end 'dead'
				block.opRefs.append(packed)
			end 'filterOps'
			// Terminators are never removed — they control block flow
		end 'eachBlock'

		// Phase 3: Bypass blocks whose only contents are an unconditional
		// `cf.br successor` (no live ops, no block parameters). Predecessors
		// get retargeted to the successor; the now-orphan block is pruned in
		// Phase 4. Runs after the dead-op sweep above so blocks that became
		// empty by virtue of canonicalize folding everything to dead consts
		// are recognized as bypassable.
		skipThroughEmptyBranches(module, func: func)

		// Phase 4: Remove blocks unreachable from the entry block.
		// Canonicalize may fold condBr to br, leaving successor blocks with
		// no predecessors. Pruning them here keeps the output clean.
		pruneUnreachableBlocks(func, module: module)

		try module.functions.set(funcIdx, value: func) otherwise panic("eliminateDeadCode: functions.set OOB")
	end 'eachFunc'

	return module
end 'eliminateDeadCode'

// One pass over every block, retargeting predecessors of any "skippable"
// block to the skippable block's sole successor. Non-iterative: a chain
// of two skippable blocks only collapses by one level per DCE run, but
// the canonicalize/DCE pipeline doesn't currently iterate, and chain
// compaction past one level isn't a pattern produced by current passes.
function skipThroughEmptyBranches(module StdModule, func IrFunction)
	for blockRef in func.blockRefs 'scan'
		let block = try module.blocks.get(blockRef) otherwise panic("Block not found in module")
		let bypass = tryGetBypassTarget(module, block: block)
		match bypass 'apply'
			none then break 'apply'
			some(target, fwdArgIds) then retargetPredecessors(module, func: func, fromBlockId: block.id, toBlockId: target, fwdArgIds: fwdArgIds)
		end 'apply'
	end 'scan'

	// Entry-block special case: a bypassable entry has no predecessors, so
	// `retargetPredecessors` is a no-op above. Promote its successor to the
	// new entry by removing the bypassable entry from blockRefs. The
	// downstream `pruneUnreachableBlocks` does not handle this on its own
	// because the entry block is always considered reachable from itself.
	dropBypassableEntry(module, func: func)
end 'skipThroughEmptyBranches'

// Entry-block special case: when the entry block's only contents are
// `cf.br S`, retargeting predecessors does nothing (entry has none).
// Inline S's contents into the entry block in place — replacing the
// bridge terminator with S's full op sequence + S's terminator — and
// drop S from blockRefs. The entry block keeps its conventional
// `entry` label and identity; the merged successor disappears.
//
// Only safe to merge when S has exactly one predecessor (the entry).
// Otherwise inlining would lose the join semantics other predecessors
// depend on. In that case we leave the empty-entry shape alone — the
// IR still encodes the program correctly, just with one extra hop.
function dropBypassableEntry(module StdModule, func IrFunction)
	if func.blockRefs.count() < 2 'tooSmall'
		return
	end 'tooSmall'
	let entryRef = try func.blockRefs.get(0) otherwise panic("dropBypassableEntry: blockRefs[0] missing despite count check")
	var entryBlock = try module.blocks.get(entryRef) otherwise panic("dropBypassableEntry: entry block not found in module")
	let bypass = tryGetBypassTarget(module, block: entryBlock)
	let targetBlockId = match bypass 'extract'
		none gives BLOCK_ID_NONE
		some(target, _) gives target
	end 'extract'
	if targetBlockId == BLOCK_ID_NONE 'notBypassable'
		return
	end 'notBypassable'

	let targetRefIndex = findBlockRefByBlockId(func, module: module, blockId: targetBlockId)
	if targetRefIndex == BLOCK_ID_NONE 'noTargetRef'
		panic("dropBypassableEntry: bypass target block_{targetBlockId} not in func.blockRefs")
	end 'noTargetRef'
	let targetRef = try func.blockRefs.get(targetRefIndex) otherwise panic("dropBypassableEntry: blockRefs.get({targetRefIndex}) failed")
	let targetBlock = try module.blocks.get(targetRef) otherwise panic("dropBypassableEntry: target block missing from module")

	if not isSolePredecessor(module, func: func, ofBlockId: targetBlockId, predecessorBlockId: entryBlock.id) 'notSole'
		return
	end 'notSole'
	if targetBlock.blockArgs.count() != 0 'targetHasArgs'
		// Entry's `br target argIds=[]` and target's blockArgs would
		// disagree — the merge would silently drop incoming bindings.
		return
	end 'targetHasArgs'

	entryBlock.opRefs = targetBlock.opRefs
	entryBlock.terminator = targetBlock.terminator
	try module.blocks.set(entryRef, value: entryBlock) otherwise panic("dropBypassableEntry: blocks.set OOB updating entry")

	var newRefs = BlockRefList.create()
	var index = 0
	for ref in func.blockRefs 'each'
		if index != targetRefIndex 'keep'
			newRefs.append(ref)
		end 'keep'
		index = index + 1
	end 'each'
	func.blockRefs = newRefs

	logTrace(LogCategory.ir, message: () gives "dce: merged bypassable entry into block_{targetBlockId}")
end 'dropBypassableEntry'

// True when `predecessorBlockId` is the only block whose terminator
// branches to `ofBlockId`. Walks every block's terminator in the
// function and counts incoming edges — the merge step relies on this
// being exactly one before inlining the target into the predecessor.
function isSolePredecessor(module StdModule, func IrFunction, ofBlockId BlockId, predecessorBlockId BlockId) returns bool
	var found = false
	for blockRef in func.blockRefs 'scan'
		let block = try module.blocks.get(blockRef) otherwise panic("isSolePredecessor: blockRef not in module")
		if not block.hasTerminatorOp() 'noTerm'
			continue
		end 'noTerm'
		let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("isSolePredecessor: terminator opIdx not in module.ops")
		if not terminatorBranchesTo(termOp, blockId: ofBlockId) 'noEdge'
			continue
		end 'noEdge'
		if block.id != predecessorBlockId 'otherPred'
			return false
		end 'otherPred'
		if found 'duplicateEdge'
			// Same predecessor branches via both arms of a condBr — not
			// the simple sole-predecessor case.
			return false
		end 'duplicateEdge'
		found = true
	end 'scan'
	return found
end 'isSolePredecessor'

function terminatorBranchesTo(op StdOp, blockId BlockId) returns bool
	return match op 'outer'
		control(c) gives controlBranchesTo(c, blockId: blockId)
		arith gives false
		call gives false
		memory gives false
		system gives false
	end 'outer'
end 'terminatorBranchesTo'

function controlBranchesTo(op StdControlOp, blockId BlockId) returns bool
	return match op 'inner'
		br(target, _) gives target == blockId
		condBr(_, thenTarget, _, elseTarget, _) gives thenTarget == blockId or elseTarget == blockId
	end 'inner'
end 'controlBranchesTo'

// Sentinel used to signal "no result" from helpers that return a BlockId
// or BlockRef-list index. Picked from the high end of the typealias range
// so it can't collide with any real id (the parser allocates from 0 up).
let BLOCK_ID_NONE = u64.max

function findBlockRefByBlockId(func IrFunction, module StdModule, blockId BlockId) returns BlockId
	var index = 0
	for ref in func.blockRefs 'scan'
		let block = try module.blocks.get(ref) otherwise panic("findBlockRefByBlockId: blockRef {ref} not in module")
		if block.id == blockId 'match'
			return index
		end 'match'
		index = index + 1
	end 'scan'
	return BLOCK_ID_NONE
end 'findBlockRefByBlockId'

// A block is bypassable when it has no live ops, no block parameters, and
// its terminator is an unconditional `cf.br targetBlock` carrying the args
// that should flow through to `targetBlock`. Returns `none` for any block
// that fails one of these checks. Called only after Phase 2 has stripped
// dead ops, so opRefs.count() reflects live content.
function tryGetBypassTarget(module StdModule, block IrBlock) returns BypassTarget
	if block.opRefs.count() != 0 'hasOps'
		return BypassTarget.none
	end 'hasOps'
	if block.blockArgs.count() != 0 'hasArgs'
		return BypassTarget.none
	end 'hasArgs'
	if not block.hasTerminatorOp() 'noTerm'
		return BypassTarget.none
	end 'noTerm'
	let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("invariant: terminator opIdx not in module.ops")
	return match termOp 'extract'
		control(c) gives bypassFromControl(c)
		arith gives BypassTarget.none
		call gives BypassTarget.none
		memory gives BypassTarget.none
		system gives BypassTarget.none
	end 'extract'
end 'tryGetBypassTarget'

function bypassFromControl(op StdControlOp) returns BypassTarget
	return match op 'check'
		br(target, argIds) gives BypassTarget.some(target: target, argIds: argIds)
		condBr gives BypassTarget.none
	end 'check'
end 'bypassFromControl'

// Walk every block in the function, rewriting each terminator's target so
// any branch to `fromBlockId` jumps directly to `toBlockId` instead. The
// predecessor's argIds (destined for fromBlockId, which has no blockArgs)
// are dropped; the new br carries `fwdArgIds` — the args fromBlockId's
// own br was forwarding to toBlockId — so toBlockId's blockArgs see the
// same values they would have via the bypassed hop.
function retargetPredecessors(module StdModule, func IrFunction, fromBlockId BlockId, toBlockId BlockId, fwdArgIds ValueIdArray)
	if fromBlockId == toBlockId 'selfLoop'
		return
	end 'selfLoop'
	for blockRef in func.blockRefs 'eachPred'
		let predBlock = try module.blocks.get(blockRef) otherwise panic("Block not found in module")
		if predBlock.id == fromBlockId 'skipSelf'
			continue
		end 'skipSelf'
		if not predBlock.hasTerminatorOp() 'noTerm'
			continue
		end 'noTerm'
		let termOp = try module.ops.get(predBlock.terminatorIndex()) otherwise panic("invariant: terminator opIdx not in module.ops")
		let rewritten = rewriteTerminator(termOp, fromBlockId: fromBlockId, toBlockId: toBlockId, fwdArgIds: fwdArgIds)
		match rewritten 'apply'
			none then break 'apply'
			some(newOp) then module.setTerminator(predBlock, op: newOp)
		end 'apply'
	end 'eachPred'
end 'retargetPredecessors'

// Build the rewritten terminator op when any of its targets equal
// `fromBlockId`. Returns `none` when the terminator does not branch to
// the bypassed block (no rewrite needed).
function rewriteTerminator(op StdOp, fromBlockId BlockId, toBlockId BlockId, fwdArgIds ValueIdArray) returns RewrittenTerminator
	return match op 'outer'
		control(c) gives rewriteControl(c, fromBlockId: fromBlockId, toBlockId: toBlockId, fwdArgIds: fwdArgIds)
		arith gives RewrittenTerminator.none
		call gives RewrittenTerminator.none
		memory gives RewrittenTerminator.none
		system gives RewrittenTerminator.none
	end 'outer'
end 'rewriteTerminator'

function rewriteControl(op StdControlOp, fromBlockId BlockId, toBlockId BlockId, fwdArgIds ValueIdArray) returns RewrittenTerminator
	return match op 'inner'
		br(target, _) gives rewriteBr(target, fromBlockId: fromBlockId, toBlockId: toBlockId, fwdArgIds: fwdArgIds)
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) gives rewriteCondBr(condId: condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds, fromBlockId: fromBlockId, toBlockId: toBlockId, fwdArgIds: fwdArgIds)
	end 'inner'
end 'rewriteControl'

function rewriteBr(target BlockId, fromBlockId BlockId, toBlockId BlockId, fwdArgIds ValueIdArray) returns RewrittenTerminator
	if target != fromBlockId 'noMatch'
		return RewrittenTerminator.none
	end 'noMatch'
	logTrace(LogCategory.ir, message: () gives "dce: skip-through br block_{fromBlockId} -> block_{toBlockId}")
	return RewrittenTerminator.some(op: StdOp.control(StdControlOp.br(toBlockId, argIds: fwdArgIds)))
end 'rewriteBr'

function rewriteCondBr(condId ValueId, thenTarget BlockId, thenArgIds ValueIdArray, elseTarget BlockId, elseArgIds ValueIdArray, fromBlockId BlockId, toBlockId BlockId, fwdArgIds ValueIdArray) returns RewrittenTerminator
	let newThen = toBlockId if thenTarget == fromBlockId else thenTarget
	let newThenArgs = fwdArgIds if thenTarget == fromBlockId else thenArgIds
	let newElse = toBlockId if elseTarget == fromBlockId else elseTarget
	let newElseArgs = fwdArgIds if elseTarget == fromBlockId else elseArgIds
	if newThen == thenTarget and newElse == elseTarget 'noChange'
		return RewrittenTerminator.none
	end 'noChange'
	logTrace(LogCategory.ir, message: () gives "dce: skip-through condBr -> block_{newThen}/block_{newElse}")
	return RewrittenTerminator.some(op: StdOp.control(StdControlOp.condBr(condId, thenTarget: newThen, thenArgIds: newThenArgs, elseTarget: newElse, elseArgIds: newElseArgs)))
end 'rewriteCondBr'

// Result of inspecting a block for skip-through eligibility: either it's
// not bypassable, or it is — in which case we know its sole successor and
// the args it forwards there.
union BypassTarget
	none
	some(target BlockId, argIds ValueIdArray)
end 'BypassTarget'

// Result of attempting to retarget a single terminator op: either it
// didn't reference the bypassed block, or we built a new op shape with
// the substitution applied.
union RewrittenTerminator
	none
	some(op StdOp)
end 'RewrittenTerminator'

// Remove blocks that are not reachable from the entry block via CFG edges.
// Builds the CFG, DFS-marks reachable blocks, then filters func.blockRefs.
function pruneUnreachableBlocks(func IrFunction, module StdModule)
	if func.blockRefs.count() <= 1 'trivial'
		return
	end 'trivial'

	let entryBlockRef = try func.blockRefs.get(0) otherwise panic("Entry block not found in function")
	let entryBlock = try module.blocks.get(entryBlockRef) otherwise panic("Entry block not found in module")
	let numBlocks = func.nextBlockId
	let cfg = buildCfg(func, module: module)

	var visited = BoolArray.create()
	cfgGrowBoolArray(visited, size: numBlocks)
	var postorder = BlockIdArray.create()
	dfsPostorder(entryBlock.id, cfg: cfg, visited: visited, postorder: postorder)

	var liveRefs = BlockRefList.create()
	for blockRef in func.blockRefs 'filter'
		let block = try module.blocks.get(blockRef) otherwise panic("Block not found in module")
		let isReachable = try visited.get(block.id) otherwise false
		if isReachable 'live'
			liveRefs.append(blockRef)
		end 'live' else 'pruned'
			logTrace(LogCategory.ir, message: () gives "dce: pruned unreachable block '{block.label}'")
		end 'pruned'
	end 'filter'
	func.blockRefs = liveRefs
end 'pruneUnreachableBlocks'

// ============================================================
// Phase 1: Use counting — extract operand ValueIds from each op
// ============================================================

function countPackedOpUses(module StdModule, opIdx OpIndex, useCount ValueIdArray, isVoidFunc bool)
	let stdOp = try module.ops.get(opIdx) otherwise panic("Op not found in module")
	match stdOp 'outer'
		arith(op) then countArithUses(op, useCount: useCount)
		control(op) then countCfUses(op, useCount: useCount)
		call(op) then countFuncUses(op, useCount: useCount, isVoidFunc: isVoidFunc)
		memory(op) then countMemoryUses(op, useCount: useCount)
		system(op) then countSysUses(op, useCount: useCount)
	end 'outer'
end 'countPackedOpUses'

function countArithUses(op StdArithOp, useCount ValueIdArray)
	match op 'count'
		const then break 'count'
		unary(u) then incrementUse(useCount, valueId: u.operandId)
		binary(b) then countBinaryUses(b, useCount: useCount)
	end 'count'
end 'countArithUses'

function countBinaryUses(b StdArithBinaryOp, useCount ValueIdArray)
	incrementUse(useCount, valueId: b.leftId)
	incrementUse(useCount, valueId: b.rightId)
end 'countBinaryUses'

function countCfUses(op StdControlOp, useCount ValueIdArray)
	match op 'count'
		br(_, argIds) then countBrArgUses(argIds, useCount: useCount)
		condBr(condId, _, thenArgIds, _, elseArgIds) then countCondBrUses(condId, thenArgIds: thenArgIds, elseArgIds: elseArgIds, useCount: useCount)
	end 'count'
end 'countCfUses'

function countBrArgUses(argIds ValueIdArray, useCount ValueIdArray)
	for argId in argIds 'each'
		incrementUse(useCount, valueId: argId)
	end 'each'
end 'countBrArgUses'

function countCondBrUses(condId ValueId, thenArgIds ValueIdArray, elseArgIds ValueIdArray, useCount ValueIdArray)
	incrementUse(useCount, valueId: condId)
	for argId in thenArgIds 'thenArgs'
		incrementUse(useCount, valueId: argId)
	end 'thenArgs'
	for argId in elseArgIds 'elseArgs'
		incrementUse(useCount, valueId: argId)
	end 'elseArgs'
end 'countCondBrUses'

function countFuncUses(op StdCallOp, useCount ValueIdArray, isVoidFunc bool)
	match op 'count'
		ret(retValId) then countRetUse(retValId, useCount: useCount, isVoidFunc: isVoidFunc)
		call(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		tryCall(_, _, argIds, _) then countArrayUses(argIds, useCount: useCount)
		indirectCall(_, calleeId, argIds) then countIndirectCallUses(calleeId, argIds: argIds, useCount: useCount)
		funcRef then break 'count'
		tailCall(_, argIds) then countArrayUses(argIds, useCount: useCount)
		param then break 'count'
	end 'count'
end 'countFuncUses'

// Void functions carry an implicit `return 0` whose retValId nothing else
// reads. Treating that as a use would keep the literal zero alive all the way
// through to codegen as a dead `xor r8d, r8d`. Skipping the count lets DCE
// remove both the constant and (separately) the codegen pass skip the move.
function countRetUse(retValId ValueId, useCount ValueIdArray, isVoidFunc bool)
	if isVoidFunc 'voidRet'
		return
	end 'voidRet'
	incrementUse(useCount, valueId: retValId)
end 'countRetUse'

function countIndirectCallUses(calleeId ValueId, argIds ValueIdArray, useCount ValueIdArray)
	incrementUse(useCount, valueId: calleeId)
	countArrayUses(argIds, useCount: useCount)
end 'countIndirectCallUses'

function countMemoryUses(op StdMemoryOp, useCount ValueIdArray)
	match op 'count'
		storeSlot(_, valueId) then incrementUse(useCount, valueId: valueId)
		loadSlot then break 'count'
	end 'count'
end 'countMemoryUses'

function countSysUses(op StdSystemOp, useCount ValueIdArray)
	match op 'count'
		syscall(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		iatCall(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		globalAddr then break 'count'
		memcpy(dstId, srcId, lenId) then countThreeUses(dstId, b: srcId, c: lenId, useCount: useCount)
		stackAddr then break 'count'
		storeByte(baseId, offsetId, byteId) then countThreeUses(baseId, b: offsetId, c: byteId, useCount: useCount)
		loadByte(_, baseId, offsetId) then countTwoUses(baseId, b: offsetId, useCount: useCount)
		osExit(codeId) then incrementUse(useCount, valueId: codeId)
		osWrite(ptrId, lenId) then countTwoUses(ptrId, b: lenId, useCount: useCount)
		free(ptrId) then incrementUse(useCount, valueId: ptrId)
		osWriteErr(ptrId, lenId) then countTwoUses(ptrId, b: lenId, useCount: useCount)
		osOpenWrite(_, pathPtrId, pathLenId) then countTwoUses(pathPtrId, b: pathLenId, useCount: useCount)
		osWriteFd(fdId, ptrId, lenId) then countThreeUses(fdId, b: ptrId, c: lenId, useCount: useCount)
		osClose(fdId) then incrementUse(useCount, valueId: fdId)
		osGetEnv(_, namePtrId, nameLenId, outBufPtrId, outBufLenId) then countOsGetEnvUses(namePtrId, nameLenId: nameLenId, outBufPtrId: outBufPtrId, outBufLenId: outBufLenId, useCount: useCount)
		loadFramePtr then break 'count'
		loadIndirect(_, addrId, _) then incrementUse(useCount, valueId: addrId)
		funcAddr then break 'count'
		storeIndirect(addrId, _, valueId) then countTwoUses(addrId, b: valueId, useCount: useCount)
		printLiteral then break 'count'
		printInt(valueId) then incrementUse(useCount, valueId: valueId)
		// `sys.drop` is a cleanup hook, not a real consumer of its operand. If
		// the operand has no other users, the value itself is dead — counting
		// drop as a use would pin every let-bound primitive to live through to
		// function exit just because inject-drops emitted a no-op cleanup.
		// `sys.free` IS counted (in the heap-allocated case) because freeing
		// requires the pointer to actually exist at runtime.
		drop then break 'count'
	end 'count'
end 'countSysUses'

function countArrayUses(argIds ValueIdArray, useCount ValueIdArray)
	for argId in argIds 'each'
		incrementUse(useCount, valueId: argId)
	end 'each'
end 'countArrayUses'

function countTwoUses(a ValueId, b ValueId, useCount ValueIdArray)
	incrementUse(useCount, valueId: a)
	incrementUse(useCount, valueId: b)
end 'countTwoUses'

function countThreeUses(a ValueId, b ValueId, c ValueId, useCount ValueIdArray)
	incrementUse(useCount, valueId: a)
	incrementUse(useCount, valueId: b)
	incrementUse(useCount, valueId: c)
end 'countThreeUses'

// osGetEnv takes four input operands; no existing helper fits so count them directly.
function countOsGetEnvUses(namePtrId ValueId, nameLenId ValueId, outBufPtrId ValueId, outBufLenId ValueId, useCount ValueIdArray)
	incrementUse(useCount, valueId: namePtrId)
	incrementUse(useCount, valueId: nameLenId)
	incrementUse(useCount, valueId: outBufPtrId)
	incrementUse(useCount, valueId: outBufLenId)
end 'countOsGetEnvUses'

// ============================================================
// Phase 2: Dead op detection
// ============================================================

// An op is dead if:
// 1. It has a resultId (is a value-producing op)
// 2. That resultId has zero uses
// 3. The op has no side effects
function isDeadPackedOp(module StdModule, opIdx OpIndex, useCount ValueIdArray) returns bool
	let stdOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
	return match stdOp 'outer'
		arith(op) gives isDeadArithOp(op, useCount: useCount)
		call(op) gives isDeadFuncOp(op, useCount: useCount)
		memory(op) gives isDeadMemRefOp(op, useCount: useCount)
		control gives false
		system(op) gives isDeadSysOp(op)
	end 'outer'
end 'isDeadPackedOp'

// `sys.drop` lowers to a no-op at MIR level — the runtime never runs a
// destructor. With drops carrying no real semantics, every drop is dead IR
// and can be removed; that in turn lets the producer it was pinning become
// dead too. Every other system op (syscall, iatCall, free, prints, stores)
// has observable side effects.
function isDeadSysOp(op StdSystemOp) returns bool
	return match op 'check'
		drop gives true
		syscall to printInt gives false
	end 'check'
end 'isDeadSysOp'

function isDeadArithOp(op StdArithOp, useCount ValueIdArray) returns bool
	// All arith ops are pure (no side effects) — dead if unused
	return match op 'check'
		const(c) gives getUseCount(useCount, valueId: c.resultId) == 0
		unary(u) gives getUseCount(useCount, valueId: u.resultId) == 0
		binary(b) gives getUseCount(useCount, valueId: b.resultId) == 0
	end 'check'
end 'isDeadArithOp'

function isDeadMemRefOp(op StdMemoryOp, useCount ValueIdArray) returns bool
	return match op 'check'
		// storeSlot has side effects (writes to memory) — never dead
		storeSlot gives false
		// loadSlot is pure — dead if unused
		loadSlot(resultId, _) gives getUseCount(useCount, valueId: resultId) == 0
	end 'check'
end 'isDeadMemRefOp'

function isDeadFuncOp(op StdCallOp, useCount ValueIdArray) returns bool
	return match op 'check'
		// call, tryCall, indirectCall, tailCall, ret all have side effects
		ret gives false
		call gives false
		tryCall gives false
		indirectCall gives false
		tailCall gives false
		// funcRef and param are pure value-producing ops
		funcRef(resultId, _) gives getUseCount(useCount, valueId: resultId) == 0
		param(resultId, _, _) gives getUseCount(useCount, valueId: resultId) == 0
	end 'check'
end 'isDeadFuncOp'

// ============================================================
// Utility: extract resultId from a packed op (for logging)
// ============================================================

function getPackedOpResultId(module StdModule, opIdx OpIndex) returns ValueId
	let stdOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
	return match stdOp 'outer'
		arith(op) gives getArithResultId(op)
		call(op) gives getFuncResultId(op)
		memory(op) gives getMemRefResultId(op)
		control gives 0
		system gives 0
	end 'outer'
end 'getPackedOpResultId'

function getArithResultId(op StdArithOp) returns ValueId
	return match op 'get'
		const(c) gives c.resultId
		unary(u) gives u.resultId
		binary(b) gives b.resultId
	end 'get'
end 'getArithResultId'

function getMemRefResultId(op StdMemoryOp) returns ValueId
	return match op 'get'
		storeSlot gives 0
		loadSlot(resultId, _) gives resultId
	end 'get'
end 'getMemRefResultId'

function getFuncResultId(op StdCallOp) returns ValueId
	return match op 'get'
		ret gives 0
		call(resultId, _, _) gives resultId
		tryCall(resultId, _, _, _) gives resultId
		indirectCall(resultId, _, _) gives resultId
		funcRef(resultId, _) gives resultId
		tailCall gives 0
		param(resultId, _, _) gives resultId
	end 'get'
end 'getFuncResultId'

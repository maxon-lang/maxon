// Dead Code Elimination (DCE) Pass.
// Walks module -> functions -> blocks -> ops in two phases.
// Phase 1: Count uses of each ValueId across all ops.
// Phase 2: Remove ops whose resultId has zero uses and no side effects.
//
// Side-effect ops that must NOT be removed (even with zero uses):
//   func.call, func.tryCall, func.indirectCall, func.tailCall, func.ret,
//   sys.*, runtime.*, memref.storeSlot, cf.* (terminators),
//   any op without a resultId.
//
// Safe to remove with zero uses:
//   arith.const, arith.binary, arith.unary, memref.loadSlot, func.param, func.funcRef.

// Use-count table: maps ValueId -> number of times it appears as an operand.

function incrementUse(table ValueIdArray, valueId ValueId)
	while table.count() <= valueId 'grow'
		table.push(0)
	end 'grow'
	let current = try table.get(valueId) otherwise 0
	table.set(valueId, value: current + 1)
end 'incrementUse'

function getUseCount(table ValueIdArray, valueId ValueId) returns ValueId
	if valueId >= table.count() 'outOfBounds'
		return 0
	end 'outOfBounds'
	return try table.get(valueId) otherwise 0
end 'getUseCount'

export function eliminateDeadCode(module StdModule) returns StdModule
	for func in module.functions 'eachFunc'
		// Phase 1: Count uses of every ValueId across the entire function
		var useCount = ValueIdArray.create()

		for blockRef in func.blockRefs 'countBlocks'
			let block = try module.blocks.get(blockRef) otherwise 'skip'
				continue
			end 'skip'
			for packed in block.opRefs 'countOps'
				countPackedOpUses(module, opIdx: packed, useCount: useCount)
			end 'countOps'
			if block.hasTerminator 'countTerm'
				countPackedOpUses(module, opIdx: block.terminator, useCount: useCount)
			end 'countTerm'
		end 'countBlocks'

		// Phase 2: Filter dead ops in-place
		for blockRef in func.blockRefs 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise 'skipOp'
				panic("Block not found in module")
			end 'skipOp'

			let oldOps = block.opRefs
			block.opRefs = StdOpIndexList.create()
			for packed in oldOps 'filterOps'
				if isDeadPackedOp(module, opIdx: packed, useCount: useCount) 'dead'
					logTrace(LogCategory.ir, message: () gives "dce: removing dead op with resultId {getPackedOpResultId(module, opIdx: packed)}")
					continue
				end 'dead'
				block.opRefs.append(packed)
			end 'filterOps'
			// Terminators are never removed — they control block flow
		end 'eachBlock'
	end 'eachFunc'

	return module
end 'eliminateDeadCode'

// ============================================================
// Phase 1: Use counting — extract operand ValueIds from each op
// ============================================================

function countPackedOpUses(module StdModule, opIdx StdOpIndex, useCount ValueIdArray)
	let stdOp = try module.ops.get(opIdx) otherwise 'noOp'
		return
	end 'noOp'
	match stdOp 'outer'
		arith(op) then countArithUses(op, useCount: useCount)
		control(op) then countCfUses(op, useCount: useCount)
		call(op) then countFuncUses(op, useCount: useCount)
		memory(op) then countMemoryUses(op, useCount: useCount)
		system(op) then countSysUses(op, useCount: useCount)
	end 'outer'
end 'countPackedOpUses'

function countArithUses(op StdArithOp, useCount ValueIdArray)
	match op 'count'
		const then break 'count'
		unary(u) then incrementUse(useCount, valueId: u.operandId)
		binary(b) then countBinaryUses(b, useCount: useCount)
	end 'count'
end 'countArithUses'

function countBinaryUses(b StdArithBinaryOp, useCount ValueIdArray)
	incrementUse(useCount, valueId: b.leftId)
	incrementUse(useCount, valueId: b.rightId)
end 'countBinaryUses'

function countCfUses(op StdControlOp, useCount ValueIdArray)
	match op 'count'
		br(_, argIds) then countBrArgUses(argIds, useCount: useCount)
		condBr(condId, _, thenArgIds, _, elseArgIds) then countCondBrUses(condId, thenArgIds: thenArgIds, elseArgIds: elseArgIds, useCount: useCount)
	end 'count'
end 'countCfUses'

function countBrArgUses(argIds ValueIdArray, useCount ValueIdArray)
	for argId in argIds 'each'
		incrementUse(useCount, valueId: argId)
	end 'each'
end 'countBrArgUses'

function countCondBrUses(condId ValueId, thenArgIds ValueIdArray, elseArgIds ValueIdArray, useCount ValueIdArray)
	incrementUse(useCount, valueId: condId)
	for argId in thenArgIds 'thenArgs'
		incrementUse(useCount, valueId: argId)
	end 'thenArgs'
	for argId in elseArgIds 'elseArgs'
		incrementUse(useCount, valueId: argId)
	end 'elseArgs'
end 'countCondBrUses'

function countFuncUses(op StdCallOp, useCount ValueIdArray)
	match op 'count'
		ret(retValId) then incrementUse(useCount, valueId: retValId)
		call(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		tryCall(_, _, argIds, _) then countArrayUses(argIds, useCount: useCount)
		indirectCall(_, calleeId, argIds) then countIndirectCallUses(calleeId, argIds: argIds, useCount: useCount)
		funcRef then break 'count'
		tailCall(_, argIds) then countArrayUses(argIds, useCount: useCount)
		param then break 'count'
	end 'count'
end 'countFuncUses'

function countIndirectCallUses(calleeId ValueId, argIds ValueIdArray, useCount ValueIdArray)
	incrementUse(useCount, valueId: calleeId)
	countArrayUses(argIds, useCount: useCount)
end 'countIndirectCallUses'

function countMemoryUses(op StdMemoryOp, useCount ValueIdArray)
	match op 'count'
		storeSlot(_, valueId) then incrementUse(useCount, valueId: valueId)
		loadSlot then break 'count'
	end 'count'
end 'countMemoryUses'

function countSysUses(op StdSystemOp, useCount ValueIdArray)
	match op 'count'
		syscall(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		iatCall(_, _, argIds) then countArrayUses(argIds, useCount: useCount)
		globalAddr then break 'count'
		memcpy(dstId, srcId, lenId) then countThreeUses(dstId, b: srcId, c: lenId, useCount: useCount)
		stackAddr then break 'count'
		storeByte(baseId, offsetId, byteId) then countThreeUses(baseId, b: offsetId, c: byteId, useCount: useCount)
		loadByte(_, baseId, offsetId) then countTwoUses(baseId, b: offsetId, useCount: useCount)
		osExit(codeId) then incrementUse(useCount, valueId: codeId)
		osWrite(ptrId, lenId) then countTwoUses(ptrId, b: lenId, useCount: useCount)
		free(ptrId) then incrementUse(useCount, valueId: ptrId)
		osWriteErr(ptrId, lenId) then countTwoUses(ptrId, b: lenId, useCount: useCount)
		loadFramePtr then break 'count'
		loadIndirect(_, addrId, _) then incrementUse(useCount, valueId: addrId)
		funcAddr then break 'count'
		storeIndirect(addrId, _, valueId) then countTwoUses(addrId, b: valueId, useCount: useCount)
		printLiteral then break 'count'
		printInt(valueId) then incrementUse(useCount, valueId: valueId)
		drop(valueId) then incrementUse(useCount, valueId: valueId)
	end 'count'
end 'countSysUses'

function countArrayUses(argIds ValueIdArray, useCount ValueIdArray)
	for argId in argIds 'each'
		incrementUse(useCount, valueId: argId)
	end 'each'
end 'countArrayUses'

function countTwoUses(a ValueId, b ValueId, useCount ValueIdArray)
	incrementUse(useCount, valueId: a)
	incrementUse(useCount, valueId: b)
end 'countTwoUses'

function countThreeUses(a ValueId, b ValueId, c ValueId, useCount ValueIdArray)
	incrementUse(useCount, valueId: a)
	incrementUse(useCount, valueId: b)
	incrementUse(useCount, valueId: c)
end 'countThreeUses'

// ============================================================
// Phase 2: Dead op detection
// ============================================================

// An op is dead if:
// 1. It has a resultId (is a value-producing op)
// 2. That resultId has zero uses
// 3. The op has no side effects
function isDeadPackedOp(module StdModule, opIdx StdOpIndex, useCount ValueIdArray) returns bool
	let stdOp = try module.ops.get(opIdx) otherwise 'noVal'
		return false
	end 'noVal'
	return match stdOp 'outer'
		arith(op) gives isDeadArithOp(op, useCount: useCount)
		call(op) gives isDeadFuncOp(op, useCount: useCount)
		memory(op) gives isDeadMemRefOp(op, useCount: useCount)
		control gives false
		system gives false
	end 'outer'
end 'isDeadPackedOp'

function isDeadArithOp(op StdArithOp, useCount ValueIdArray) returns bool
	// All arith ops are pure (no side effects) — dead if unused
	return match op 'check'
		const(c) gives getUseCount(useCount, valueId: c.resultId) == 0
		unary(u) gives getUseCount(useCount, valueId: u.resultId) == 0
		binary(b) gives getUseCount(useCount, valueId: b.resultId) == 0
	end 'check'
end 'isDeadArithOp'

function isDeadMemRefOp(op StdMemoryOp, useCount ValueIdArray) returns bool
	return match op 'check'
		// storeSlot has side effects (writes to memory) — never dead
		storeSlot gives false
		// loadSlot is pure — dead if unused
		loadSlot(resultId, _) gives getUseCount(useCount, valueId: resultId) == 0
	end 'check'
end 'isDeadMemRefOp'

function isDeadFuncOp(op StdCallOp, useCount ValueIdArray) returns bool
	return match op 'check'
		// call, tryCall, indirectCall, tailCall, ret all have side effects
		ret gives false
		call gives false
		tryCall gives false
		indirectCall gives false
		tailCall gives false
		// funcRef and param are pure value-producing ops
		funcRef(resultId, _) gives getUseCount(useCount, valueId: resultId) == 0
		param(resultId, _, _) gives getUseCount(useCount, valueId: resultId) == 0
	end 'check'
end 'isDeadFuncOp'

// ============================================================
// Utility: extract resultId from a packed op (for logging)
// ============================================================

function getPackedOpResultId(module StdModule, opIdx StdOpIndex) returns ValueId
	let stdOp = try module.ops.get(opIdx) otherwise 'noData'
		return 0
	end 'noData'
	return match stdOp 'outer'
		arith(op) gives getArithResultId(op)
		call(op) gives getFuncResultId(op)
		memory(op) gives getMemRefResultId(op)
		control gives 0
		system gives 0
	end 'outer'
end 'getPackedOpResultId'

function getArithResultId(op StdArithOp) returns ValueId
	return match op 'get'
		const(c) gives c.resultId
		unary(u) gives u.resultId
		binary(b) gives b.resultId
	end 'get'
end 'getArithResultId'

function getMemRefResultId(op StdMemoryOp) returns ValueId
	return match op 'get'
		storeSlot gives 0
		loadSlot(resultId, _) gives resultId
	end 'get'
end 'getMemRefResultId'

function getFuncResultId(op StdCallOp) returns ValueId
	return match op 'get'
		ret gives 0
		call(resultId, _, _) gives resultId
		tryCall(resultId, _, _, _) gives resultId
		indirectCall(resultId, _, _) gives resultId
		funcRef(resultId, _) gives resultId
		tailCall gives 0
		param(resultId, _, _) gives resultId
	end 'get'
end 'getFuncResultId'

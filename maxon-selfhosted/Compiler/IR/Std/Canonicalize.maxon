// Canonicalize Pass — Constant folding for arithmetic ops and branch simplification.
// Walks module -> functions -> blocks -> ops.
// For each std.arith.binary where both operands are std.arith.const in the
// same block, folds the computation into a new std.arith.const.
// Folds every integer arith op that doesn't trap (add/sub/mul/and/or/xor/shl/shr
// and the signed cmpI64* family); div/rem and the float arith / unsigned-cmp
// opcodes are left as-is.
// Also folds condBr terminators whose condition is a known integer constant
// into unconditional branches. Dead block removal is left to the DCE pass.

// Sentinel meaning "no known constant for this ValueId"
let CONST_UNKNOWN = i64.max

// Per-block constant map: maps ValueId -> known constant value.
// CONST_UNKNOWN means the ValueId is not a known constant.

function constMapSet(map ValueIdArray, valueId ValueId, value ParsedInt)
	while map.count() <= valueId 'grow'
		map.push(CONST_UNKNOWN)
	end 'grow'
	try map.set(valueId, value: value) otherwise panic("invariant: map.set OOB")
end 'constMapSet'

function constMapGet(map ValueIdArray, valueId ValueId) returns ParsedInt
	if valueId >= map.count() 'outOfBounds'
		return CONST_UNKNOWN
	end 'outOfBounds'
	return try map.get(valueId) otherwise CONST_UNKNOWN
end 'constMapGet'

// Phase 11.6 descriptor-fold helper map. ValueId → rdata label of the
// `loadLayoutDescriptor` op that produced it. Stored as a parallel array;
// slots for ValueIds we haven't seen carry the empty string as a "no entry"
// marker, and `descLabelGet` throws to communicate that to callers.
typealias DescriptorLabelMap = Array with String

enum DescLabelError implements Error
	notRecorded
end 'DescLabelError'

function descLabelGet(map DescriptorLabelMap, valueId ValueId) returns String throws DescLabelError
	if valueId >= map.count() 'outOfBounds'
		throw DescLabelError.notRecorded
	end 'outOfBounds'
	let label = try map.get(valueId) otherwise throw DescLabelError.notRecorded
	if label.isEmpty() 'noEntry'
		throw DescLabelError.notRecorded
	end 'noEntry'
	return label
end 'descLabelGet'

function descLabelSet(map DescriptorLabelMap, valueId ValueId, label String)
	while map.count() <= valueId 'grow'
		map.push("")
	end 'grow'
	try map.set(valueId, value: label) otherwise panic("invariant: descLabel map.set OOB")
end 'descLabelSet'

export function canonicalize(module StdModule, project Project) returns StdModule
	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise panic("Block not found in module")

			// Per-block tracking: integer constants for arith folding, plus
			// rdata-label provenance for `descriptorField` folding (11.6).
			var constMap = ValueIdArray.create()
			var descMap = DescriptorLabelMap.create()

			let oldOps = block.opRefs
			block.opRefs = OpIndexList.create()
			for packed in oldOps 'eachOp'
				tryFoldPackedOp(module, project: project, opIdx: packed, constMap: constMap, descMap: descMap, dstBlock: block)
			end 'eachOp'

			// Fold a condBr terminator when its condition is a known constant.
			// Replaces it with an unconditional branch to the taken target.
			// Dead block removal is left to the DCE pass.
			if block.hasTerminatorOp() 'hasTerm'
				tryFoldCondBr(module, block: block, constMap: constMap)
			end 'hasTerm'
		end 'eachBlock'
	end 'eachFunc'

	return module
end 'canonicalize'

// If the block's terminator is a condBr whose condition is a known constant,
// replace it with an unconditional branch to the taken target.
// The untaken target block may become dead; DCE will remove it later.
function tryFoldCondBr(module StdModule, block IrBlock, constMap ValueIdArray)
	let termOp = try module.ops.get(block.terminatorIndex()) otherwise panic("invariant: terminator opIdx not in module.ops")
	match termOp 'checkTerm'
		control(op) then tryFoldControlTerminator(module, block: block, constMap: constMap, op: op)
		arith then return
		call then return
		memory then return
		system then return
	end 'checkTerm'
end 'tryFoldCondBr'

// If op is a condBr whose condition is a known constant, fold it to a br.
function tryFoldControlTerminator(module StdModule, block IrBlock, constMap ValueIdArray, op StdControlOp)
	match op 'checkCondBr'
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) then applyCondBrFold(module, block: block, constMap: constMap, condId: condId, thenTarget: thenTarget, thenArgIds: thenArgIds, elseTarget: elseTarget, elseArgIds: elseArgIds)
		br then return
	end 'checkCondBr'
end 'tryFoldControlTerminator'

// Apply the fold when we have a condBr whose fields are already extracted.
// Two fold opportunities are checked:
//   1. Both targets point at the same successor — the condition is dead even
//      if it isn't statically known. Rewrite as an unconditional br to the
//      shared target. This case arises when DCE skip-through collapses both
//      arms of a condBr into the same surviving block (see
//      DeadCodeElimination.rewriteCondBr); without this normalization the
//      target-phase destroySSA pass can't tell which edge is the "then"
//      because pickThenTarget looks for an edge whose target differs from
//      `elseTarget` and finds none.
//   2. The condition is a known integer constant — pick the taken arm.
function applyCondBrFold(module StdModule, block IrBlock, constMap ValueIdArray, condId ValueId, thenTarget BlockId, thenArgIds ValueIdArray, elseTarget BlockId, elseArgIds ValueIdArray)
	if thenTarget == elseTarget 'sameTarget'
		// Edge args may differ structurally (the parser/DCE both emit
		// independent arg vectors for each arm), but for this fold the
		// arms are equivalent because the predicate is dead — keep the
		// then-arm args.
		module.setTerminator(block, op: StdOp.control(StdControlOp.br(thenTarget, argIds: thenArgIds)))
		logTrace(LogCategory.ir, message: function() gives "canonicalize: folded condBr (both arms -> block_{thenTarget})")
		return
	end 'sameTarget'
	let condVal = constMapGet(constMap, valueId: condId)
	if condVal == CONST_UNKNOWN 'notConst'
		return
	end 'notConst'

	let takenTarget = thenTarget if condVal != 0 else elseTarget
	let takenArgIds = thenArgIds if condVal != 0 else elseArgIds

	module.setTerminator(block, op: StdOp.control(StdControlOp.br(takenTarget, argIds: takenArgIds)))
	logTrace(LogCategory.ir, message: function() gives "canonicalize: folded condBr %{condId}={condVal} -> br block_{takenTarget}")
end 'applyCondBrFold'

// Try to fold a std op. If it is a foldable std.arith.binary with both
// operands known constant, replace with std.arith.const. Otherwise pass
// through unchanged. Also populates constMap for std.arith.const ops.
function tryFoldPackedOp(module StdModule, project Project, opIdx OpIndex, constMap ValueIdArray, descMap DescriptorLabelMap, dstBlock IrBlock)
	let stdOp = try module.ops.get(opIdx) otherwise 'noOp'
		dstBlock.opRefs.append(opIdx)
		return
	end 'noOp'
	match stdOp 'outer'
		arith(a) then tryFoldArithOp(module, op: a, constMap: constMap, dstBlock: dstBlock)
		control then dstBlock.opRefs.append(opIdx)
		call then dstBlock.opRefs.append(opIdx)
		memory then dstBlock.opRefs.append(opIdx)
		system(s) then tryFoldSysOp(module, project: project, opIdx: opIdx, op: s, constMap: constMap, descMap: descMap, dstBlock: dstBlock)
	end 'outer'
end 'tryFoldPackedOp'

// Phase 11.6: only two system ops are interesting for canonicalize today.
//   loadLayoutDescriptor — record the rdata label provenance of its
//     resultId so a downstream `descriptorField` reading from this same
//     value can fold against the rdata bytes.
//   descriptorField — when the descriptor source has a known label and
//     the bytes are present in `project.staticRdataValues`, replace the
//     load with an `arith.const(constI64)` of the field value.
// Every other system op passes through unchanged.
function tryFoldSysOp(module StdModule, project Project, opIdx OpIndex, op StdSystemOp, constMap ValueIdArray, descMap DescriptorLabelMap, dstBlock IrBlock)
	match op 'shape'
		loadLayoutDescriptor(resultId, label) then recordDescriptorLoad(opIdx, resultId: resultId, label: label, descMap: descMap, dstBlock: dstBlock)
		descriptorField(resultId, descAddrId, field) then tryFoldDescriptorField(module, project: project, opIdx: opIdx, resultId: resultId, descAddrId: descAddrId, field: field, constMap: constMap, descMap: descMap, dstBlock: dstBlock)
		globalAddr to storeIndirect then dstBlock.opRefs.append(opIdx)
		drop then dstBlock.opRefs.append(opIdx)
		osAllocPages to osLockRelease then dstBlock.opRefs.append(opIdx)
		boxValue then dstBlock.opRefs.append(opIdx)
		unboxValue then dstBlock.opRefs.append(opIdx)
		loadWitnessTable then dstBlock.opRefs.append(opIdx)
		witnessMethod then dstBlock.opRefs.append(opIdx)
		dropTypeParam then dstBlock.opRefs.append(opIdx)
	end 'shape'
end 'tryFoldSysOp'

function recordDescriptorLoad(opIdx OpIndex, resultId ValueId, label String, descMap DescriptorLabelMap, dstBlock IrBlock)
	descLabelSet(descMap, valueId: resultId, label: label)
	dstBlock.opRefs.append(opIdx)
end 'recordDescriptorLoad'

function tryFoldDescriptorField(module StdModule, project Project, opIdx OpIndex, resultId ValueId, descAddrId ValueId, field DescriptorField, constMap ValueIdArray, descMap DescriptorLabelMap, dstBlock IrBlock)
	let label = try descLabelGet(descMap, valueId: descAddrId) otherwise 'unknownSource'
		dstBlock.opRefs.append(opIdx)
		return
	end 'unknownSource'
	let foldedVal = tryReadDescriptorField(project, label: label, field: field)
	if foldedVal == CONST_UNKNOWN 'cannotFold'
		dstBlock.opRefs.append(opIdx)
		return
	end 'cannotFold'
	constMapSet(constMap, valueId: resultId, value: foldedVal)
	logTrace(LogCategory.ir, message: function() gives "canonicalize: folded descriptorField %{resultId} = @{label}.{descriptorFieldName(field)} -> const {foldedVal}")
	module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: foldedVal))))
end 'tryFoldDescriptorField'

// Read a descriptor field from `project.staticRdataValues[label]`. Returns
// the field value when:
//   - `label` is non-empty (the source value really is a loadLayoutDescriptor),
//   - the registry actually carries those bytes (the BuildLayoutDescriptors
//     pass ran for this label and stashed the encoded blob),
//   - and the field's on-disk slot is meaningful (size / alignment /
//     elementSize / hasHeapRefs / fieldOffsetsPtr — copyFunc and
//     destroyFunc are zero on disk and patched at link time, so reading
//     them returns 0 from the bytes which would fold call sites onto a
//     null pointer; we report CONST_UNKNOWN there instead).
// Otherwise returns CONST_UNKNOWN so the caller leaves the op in place.
function tryReadDescriptorField(project Project, label String, field DescriptorField) returns ParsedInt
	if label.isEmpty() 'unknownSource'
		return CONST_UNKNOWN
	end 'unknownSource'
	if not project.staticRdataValues.contains(label) 'unknownLabel'
		return CONST_UNKNOWN
	end 'unknownLabel'
	let bytes = try project.staticRdataValues.get(label) otherwise panic("tryReadDescriptorField: contains passed but get failed for {label}")
	let offset = descriptorFieldOffset(field)
	if (offset + 8) > bytes.count() 'outOfBounds'
		return CONST_UNKNOWN
	end 'outOfBounds'
	if isFunctionSlot(field) 'patchedAtLink'
		return CONST_UNKNOWN
	end 'patchedAtLink'
	return readQword(bytes, offset: offset)
end 'tryReadDescriptorField'

function isFunctionSlot(field DescriptorField) returns bool
	return match field 'check'
		size gives false
		alignment gives false
		elementSize gives false
		hasHeapRefs gives false
		copyFunc gives true
		destroyFunc gives true
		fieldOffsetsPtr gives false
	end 'check'
end 'isFunctionSlot'

function tryFoldArithOp(module StdModule, op StdArithOp, constMap ValueIdArray, dstBlock IrBlock)
	match op 'dispatch'
		const(c) then registerAndPassConst(module, c: c, constMap: constMap, dstBlock: dstBlock)
		binary(b) then tryFoldBinaryOp(module, b: b, constMap: constMap, dstBlock: dstBlock)
		unary(u) then module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(u)))
	end 'dispatch'
end 'tryFoldArithOp'

// Register a std.arith.const value in the constant map and emit it unchanged.
function registerAndPassConst(module StdModule, c StdArithConst, constMap ValueIdArray, dstBlock IrBlock)
	// Only track integer constants for folding (float folding is future work)
	match c.opcode 'checkOpcode'
		constI64 then constMapSet(constMap, valueId: c.resultId, value: c.value)
		constF64 then break 'checkOpcode'
	end 'checkOpcode'
	module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(c)))
end 'registerAndPassConst'

// Try to fold a binary op. If both operands are known integer constants
// and the opcode is one we can fold, produce a new std.arith.const.
function tryFoldBinaryOp(module StdModule, b StdArithBinaryOp, constMap ValueIdArray, dstBlock IrBlock)
	let leftVal = constMapGet(constMap, valueId: b.leftId)
	let rightVal = constMapGet(constMap, valueId: b.rightId)

	// If either operand is not a known constant, emit the op unchanged
	if leftVal == CONST_UNKNOWN or rightVal == CONST_UNKNOWN 'notFoldable'
		module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(b)))
		return
	end 'notFoldable'

	// Try to compute the folded value
	let foldResult = tryComputeFold(b.opcode, leftVal: leftVal, rightVal: rightVal)
	if foldResult == CONST_UNKNOWN 'cannotFold'
		module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(b)))
		return
	end 'cannotFold'

	// Successfully folded: emit a new std.arith.const with the binary op's resultId
	// Register the folded value so downstream ops can also fold
	constMapSet(constMap, valueId: b.resultId, value: foldResult)
	logTrace(LogCategory.ir, message: function() gives "canonicalize: folded %{b.resultId} = {b.opcode.rawValue} %{b.leftId}, %{b.rightId} -> const {foldResult}")
	module.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: b.resultId, value: foldResult))))
end 'tryFoldBinaryOp'

// Compute the folded value for an integer binary op.
// Returns CONST_UNKNOWN if the opcode is not supported for folding.
function tryComputeFold(opcode StdArithBinaryOpcode, leftVal ParsedInt, rightVal ParsedInt) returns ParsedInt
	return match opcode 'fold'
		addI64 gives leftVal + rightVal
		subI64 gives leftVal - rightVal
		mulI64 gives leftVal * rightVal
		divI64 gives CONST_UNKNOWN
		remI64 gives CONST_UNKNOWN
		andI64 gives leftVal and rightVal
		orI64 gives leftVal or rightVal
		orI1 gives leftVal or rightVal
		xorI64 gives leftVal xor rightVal
		shlI64 gives leftVal shl rightVal
		shrI64 gives leftVal shr rightVal
		addF64 to maxF64 gives CONST_UNKNOWN
		cmpI64Eq gives 1 if leftVal == rightVal else 0
		cmpI64Ne gives 1 if leftVal != rightVal else 0
		cmpI64Lt gives 1 if leftVal < rightVal else 0
		cmpI64Le gives 1 if leftVal <= rightVal else 0
		cmpI64Gt gives 1 if leftVal > rightVal else 0
		cmpI64Ge gives 1 if leftVal >= rightVal else 0
		cmpI64Ugt gives CONST_UNKNOWN
		cmpF64Eq to cmpF64Ge gives CONST_UNKNOWN
	end 'fold'
end 'tryComputeFold'

// Phase 11.6: Std-level Dead Function Elimination.
//
// Mirrors the Maxon-level DFE in Compiler/IR/Maxon/DeadFunctionElimination.maxon
// but operates over Std ops. Runs after the inliner pass at the Std level —
// any function whose static call sites have all been inlined becomes
// unreachable and can be dropped from the module.
//
// Differences from the Maxon-level pass:
//   - Walks `StdCallOp.call` / `tryCall` / `tailCall` / `funcRef` /
//     `indirectCall` (latter conservatively keeps indirectly-targeted
//     functions alive because we can't see through the function pointer at
//     this phase). At Std level call resolution is already complete; the
//     callee names are direct strings, no CallContext qualification.
//   - Stage K.4: witness-table method impls and layout-descriptor copy/destroy
//     thunks are NOT statically rooted. They live in
//     `project.witnessConditionalRoots` keyed by the rdata label of the
//     table / descriptor they back. When the worklist walk pops a function
//     and finds a `loadWitnessTable(label)` or `loadLayoutDescriptor(label)`
//     op in its body, the conditional roots for that label are promoted
//     onto the worklist. This shares the same `liveLabels` set with
//     `pruneDeadGlobalData` below: a label is in `liveLabels` iff some live
//     function demands it via a system op, and impls / blobs /
//     `pendingRdataRelocs` entries keyed under that label are kept iff the
//     label is live.
//   - `livenessRoots` is reserved for definite roots that the runtime calls
//     before `main` (e.g. `__module_init_<namespace>`) and that no Std-level
//     op names.
//   - Per-file `__module_init_<n>` functions are treated as CONDITIONAL
//     roots: each is keyed by the set of globalData labels its body
//     touches via `globalAddr` (the slots / rdata blobs the init writes
//     and reads). The init is promoted to a live root iff some *other*
//     reachable function demands one of those labels. Inits whose data
//     no live function references are dropped — the init's writes go
//     into rdata blobs that nothing reads, so the work is dead.
//
//     Why deferred: stdlib's `__module_init_0` exists to populate the
//     `let sha256KTable = [...]` slot. If the user program never calls
//     `sha256`, sha256 itself is unreachable (and dropped by the
//     standard worklist walk), so the K-table slot has no consumer and
//     the init shouldn't run either. Cache-on already gets this for
//     free (the cache linker only pulls inits the user code references
//     via `mrt_start` call fixups, and `moduleInitFuncs` doesn't carry
//     stdlib inits across the cache boundary). The conditional-root
//     mechanism mirrors that behavior on the cache-off path so both
//     legs of a cache-parity test produce identical `.text` / `.rdata`.

typealias StdDfeStringSet = Set with String
typealias StdFuncByName = Map with (String, IrFunction)
typealias ModuleInitLabelMap = Map with (String, StringArray)

export function eliminateDeadStdFunctions(module StdModule, project Project) returns StdModule
	var funcMap = StdFuncByName.create()
	for func in module.functions 'buildMap'
		funcMap.upsert(func.name, value: func)
	end 'buildMap'

	// Build the set of `__module_init_<n>` names that exist in this
	// module. We defer them out of the initial seed: each one becomes a
	// conditional root keyed by the labels its body touches via
	// `globalAddr`, and only gets promoted to live if some *other* live
	// function demands one of those labels (see promoteEligibleModule-
	// Inits below).
	let deferredInits = collectDeferredInits(project, funcMap: funcMap)
	let initLabels = collectInitLabels(module, deferredInits: deferredInits, funcMap: funcMap)

	var seen = StdDfeStringSet from ["main"]
	var worklist = ["main"]
	for root in project.livenessRoots 'seedRoots'
		if deferredInits.contains(root) 'isInit'
			continue
		end 'isInit'
		if not seen.contains(root) 'fresh'
			seen.insert(root)
			worklist.push(root)
		end 'fresh'
	end 'seedRoots'

	// Stage K.4: shared with `pruneDeadGlobalData` below — every rdata
	// label that any live function demands via `loadWitnessTable` /
	// `loadLayoutDescriptor` / `globalAddr`. Function-DFE writes into it
	// during the walk to drive witness-conditional-root promotion;
	// globalData prune reads from it to decide which blobs and relocs
	// survive.
	var liveLabels = StdDfeStringSet.create()

	walkWorklistToFixedPoint(module, project: project, funcMap: funcMap, worklist: worklist, seen: seen, liveLabels: liveLabels)

	// Conditional `__module_init_<n>` promotion: each deferred init is
	// keyed by the labels its body touches. If any live function (other
	// than a still-deferred init) has demanded one of those labels, the
	// init's writes have a consumer and the init must run — promote it
	// and re-drain the worklist. Iterate to fixed point so a newly-
	// promoted init that touches further labels can cascade.
	while promoteEligibleModuleInits(deferredInits, initLabels: initLabels, seen: seen, liveLabels: liveLabels, worklist: worklist) 'condIter'
		walkWorklistToFixedPoint(module, project: project, funcMap: funcMap, worklist: worklist, seen: seen, liveLabels: liveLabels)
	end 'condIter'

	var newFunctions = IrFunctionArray.create()
	for func in module.functions 'filter'
		if seen.contains(func.name) 'keep'
			newFunctions.push(func)
		end 'keep' else 'drop'
			logTrace(LogCategory.ir, message: function() gives "stddfe: dropping dead function '{func.name}'")
		end 'drop'
	end 'filter'
	module.functions = newFunctions

	// Drop any `__module_init_<n>` that DFE just eliminated from the
	// project-side init list and livenessRoots so downstream consumers
	// (`patchMrtStartWithModuleInits`, the cache writer, the link
	// walker) don't synthesize calls to a function that no longer
	// exists. Mirrors the .text/.rdata prune so the two artifacts stay
	// consistent: dropping the init's body without dropping its
	// `mrt_start` call site would leave a dangling `call` fixup that
	// `lookupFuncReturnStdType` panics on at lowering time.
	pruneDroppedModuleInits(project, deferredInits: deferredInits, seen: seen)

	// Stage K.X.D + K.4: prune unreferenced globalData entries and
	// pendingRdataRelocs whose target labels are dead. Sharing
	// `liveLabels` with the walker means we use the same reachability
	// fixed point that drove function-level liveness.
	pruneDeadGlobalData(project.globalData, liveLabels: liveLabels)
	return module
end 'eliminateDeadStdFunctions'

// Remove dropped `__module_init_<n>` names from `project.moduleInitFuncs`
// and `project.livenessRoots`. Called after DFE finalizes the kept-
// function set so any init the conditional-promotion step rejected is
// also stripped from the runtime patch list (`patchMrtStartWithModule-
// Inits` reads `moduleInitFuncs` to splice `call` ops into `mrt_start`)
// and from the cache-side liveness seeds.
function pruneDroppedModuleInits(project Project, deferredInits StdDfeStringSet, seen StdDfeStringSet)
	var keptInits = StringArray.create()
	for name in project.moduleInitFuncs 'eachInit'
		if not deferredInits.contains(name) or seen.contains(name) 'kept'
			keptInits.push(name)
		end 'kept'
	end 'eachInit'
	project.moduleInitFuncs = keptInits

	var keptRoots = StringArray.create()
	for root in project.livenessRoots 'eachRoot'
		if not deferredInits.contains(root) or seen.contains(root) 'rootKept'
			keptRoots.push(root)
		end 'rootKept'
	end 'eachRoot'
	project.livenessRoots = keptRoots
end 'pruneDroppedModuleInits'

// Drain the worklist by walking each newly-seeded function's body and
// transitively marking callees / labels. Used by both the initial pass
// and each conditional-init promotion cycle.
function walkWorklistToFixedPoint(module StdModule, project Project, funcMap StdFuncByName, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	var i = 0
	while i < worklist.count() 'walk'
		let name = try worklist.get(i) otherwise panic("walkWorklistToFixedPoint: worklist.get OOB at {i}")
		if let func = try funcMap.get(name) 'found'
			walkLiveFunction(module, project: project, func: func, worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'found'
		i = i + 1
	end 'walk'
end 'walkWorklistToFixedPoint'

// Collect the set of `__module_init_<n>` function names that exist in
// this module. The conditional-root path treats these as deferred so
// they don't unconditionally pin the data they initialize — that's the
// behavior the cache-on link path already gets via callFixup-driven
// reachability, and the cache-parity tests demand both legs agree.
//
// Only entries that are also IrFunctions in `funcMap` count; the user
// pipeline's `moduleInitFuncs` may carry stdlib init names that aren't
// in the local stdModule (cache-on path), and those don't need
// conditional handling because they live in the stdlib cache.
function collectDeferredInits(project Project, funcMap StdFuncByName) returns StdDfeStringSet
	var inits = StdDfeStringSet.create()
	for name in project.moduleInitFuncs 'eachInit'
		if funcMap.contains(name) 'present'
			inits.insert(name)
		end 'present'
	end 'eachInit'
	return inits
end 'collectDeferredInits'

// For each deferred `__module_init_<n>`, scan every op in its body and
// collect the labels it touches via `globalAddr`. These labels are the
// "outputs" the init writes (and any rdata blobs it reads at the same
// time — at Std level we can't tell load from store, both go through
// `globalAddr` + indirect access). A non-empty intersection with
// `liveLabels` later signals that some consumer needs the init's
// effects.
function collectInitLabels(module StdModule, deferredInits StdDfeStringSet, funcMap StdFuncByName) returns ModuleInitLabelMap
	var initLabels = ModuleInitLabelMap.create()
	for name in deferredInits 'eachInit'
		var labels = StringArray.create()
		if let func = try funcMap.get(name) 'haveFunc'
			collectGlobalAddrLabels(module, func: func, labels: labels)
		end 'haveFunc'
		initLabels.upsert(name, value: labels)
	end 'eachInit'
	return initLabels
end 'collectInitLabels'

// Walk every op in `func`'s body and push the name of every
// `globalAddr` op into `labels`. Mirrors `walkLiveFunction` but skips
// the worklist-marking side effect — we just need the label list for
// the conditional-promotion check.
function collectGlobalAddrLabels(module StdModule, func IrFunction, labels StringArray)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("collectGlobalAddrLabels: blockRef {blockRef} not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			recordGlobalAddrAtOp(module, opIdx: opIdx, labels: labels)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			recordGlobalAddrAtOp(module, opIdx: block.terminatorIndex(), labels: labels)
		end 'hasTerm'
	end 'eachBlock'
end 'collectGlobalAddrLabels'

function recordGlobalAddrAtOp(module StdModule, opIdx OpIndex, labels StringArray)
	let op = try module.ops.get(opIdx) otherwise panic("recordGlobalAddrAtOp: opIdx {opIdx} not in module.ops")
	match op 'shape'
		system(inner) then recordGlobalAddrFromSystemOp(inner, labels: labels)
		call then return
		arith then return
		control then return
		memory then return
	end 'shape'
end 'recordGlobalAddrAtOp'

function recordGlobalAddrFromSystemOp(op StdSystemOp, labels StringArray)
	match op 'kind'
		globalAddr(_, name) then labels.push(name)
		// Other system ops don't pin a named global data blob.
		// loadLayoutDescriptor / loadWitnessTable touch witness/layout
		// labels, but those are managed via `witnessConditionalRoots` and
		// belong to a different conditional-root mechanism — an init
		// touching them wouldn't be the right promotion trigger.
		memcpy to loadIndirect then return
		funcAddr then return
		storeIndirect to unboxValue then return
		descriptorField to dropTypeParam then return
		loadLayoutDescriptor then return
		loadWitnessTable then return
	end 'kind'
end 'recordGlobalAddrFromSystemOp'

// Promote any deferred `__module_init_<n>` whose label set intersects
// the current `liveLabels` (meaning some other live function demands a
// slot or rdata blob the init touches). Returns true iff at least one
// init was promoted in this call — the caller re-drains the worklist
// and re-invokes to chain promotions through cascading data deps.
//
// On promotion: insert the init's name into `seen`, push it onto the
// worklist, AND eagerly union its labels into `liveLabels`. The label
// union ensures the next promotion check sees the labels the init also
// reads from (e.g. an init that loads from rdata A and stores into
// slot B; if some other live function reads B, we promote — and then
// A becomes live too, which may unblock yet another init's promotion).
function promoteEligibleModuleInits(deferredInits StdDfeStringSet, initLabels ModuleInitLabelMap, seen StdDfeStringSet, liveLabels StdDfeStringSet, worklist StringArray) returns bool
	var promotedAny = false
	for name in deferredInits 'eachInit'
		if seen.contains(name) 'alreadyLive'
			continue
		end 'alreadyLive'
		let labels = try initLabels.get(name) otherwise panic("invariant: deferred init `{name}` missing from initLabels map — collectInitLabels should have populated every entry in deferredInits")
		var shouldPromote = false
		for label in labels 'eachLabel'
			if liveLabels.contains(label) 'hit'
				shouldPromote = true
				break
			end 'hit'
		end 'eachLabel'
		if not shouldPromote 'skip'
			continue
		end 'skip'
		seen.insert(name)
		worklist.push(name)
		for label in labels 'pinLabels'
			liveLabels.insert(label)
		end 'pinLabels'
		promotedAny = true
	end 'eachInit'
	return promotedAny
end 'promoteEligibleModuleInits'

// Prune unreferenced globalData entries.
//
// Reachability set:
//   - every label demanded by a live function via `globalAddr`,
//     `loadLayoutDescriptor`, or `loadWitnessTable` (collected during the
//     function-DFE walk into the shared `liveLabels` set).
//   - everything reserved up-front: __panic_stacktrace, __panic_in,
//     __panic_newline, __panic_unknown, the __xmmmask_* float-bit masks,
//     and any DataSection / CovData entry whose offset the linker resolves
//     statically (handled by `shouldKeepGlobal`).
//
// `globalData.pendingRdataRelocs` is filtered the same way: a reloc whose
// `rdataLabel` isn't live points at a witness/layout blob that's about to
// be pruned, so the reloc would dangle at link time. Both the writers
// hard-panic on missing functions, so the filter must run atomically with
// the function/blob prune.
function pruneDeadGlobalData(globalData GlobalDataTable, liveLabels StdDfeStringSet)
	// `liveLabels` is already populated by `walkLiveFunction` for every
	// label any kept function demanded via `globalAddr` /
	// `loadLayoutDescriptor` / `loadWitnessTable`.

	// `__data_<symbol>` slots back user/stdlib top-level `let`/`var`
	// initializers (see `registerGlobalVarsForDataSection`). Drop the
	// entry from `dataSectionEntries` when no live function references
	// the slot — the per-file `__module_init_<n>` that would have
	// written into it is itself dead at this point (the conditional-
	// root step above skipped its promotion), so emitting the slot would
	// reserve eight bytes of `.data` that no code path ever touches.
	// Dropping it keeps the cache-off `.data` layout in lockstep with
	// the cache-on path, where `topLevelVars` aren't restored from the
	// stdlib cache for these dead slots in the first place.
	//
	// Runtime/MM/slab/win32-init slots (`__slab_*`, `__mm_*`, `__mrt_*`,
	// etc.) don't carry the `__data_` prefix; they're referenced by
	// runtime helpers that haven't been merged yet (`augmentWithRuntime`
	// runs after DFE), so no `globalAddr` op for them is visible to the
	// walker. Keep them by name pattern.
	var keptDataEntries = DataSectionEntryArray.create()
	for entry in globalData.dataSectionEntries 'eachData'
		if isUserDataSlot(entry.name) and not liveLabels.contains(entry.name) 'drop'
			logTrace(LogCategory.ir, message: function() gives "pruneDeadGlobalData: dropping unused .data slot '{entry.name}'")
			continue
		end 'drop'
		keptDataEntries.push(entry)
		liveLabels.insert(entry.name)
	end 'eachData'
	globalData.dataSectionEntries = keptDataEntries
	for entry in globalData.covDataEntries 'eachCov'
		liveLabels.insert(entry.name)
	end 'eachCov'

	// Filter pendingRdataRelocs: every funcAbs64InRdata reloc names a
	// witness/layout method slot whose impl was already conditionally
	// rooted under the same `rdataLabel`. If the label isn't live, the
	// impl isn't live either (function-DFE didn't promote it), so
	// dropping the reloc keeps the patcher's symbol table consistent.
	var newRelocs = RdataRelocationArray.create()
	for reloc in globalData.pendingRdataRelocs 'eachReloc'
		if liveLabels.contains(reloc.rdataLabel) 'keepReloc'
			newRelocs.push(reloc)
		end 'keepReloc' else 'dropReloc'
			logTrace(LogCategory.ir, message: function() gives "pruneDeadGlobalData: dropping reloc for dead rdata label '{reloc.rdataLabel}'")
		end 'dropReloc'
	end 'eachReloc'
	globalData.pendingRdataRelocs = newRelocs

	let total = globalData.names.count()
	var newNames = StringArray.create()
	var newValues = ByteArrayArray.create()
	var newNameIndex = GlobalNameIndexMap.create()
	var newValueDedup = GlobalDedupMap.create()
	for i in 0 upto total 'partition'
		let name = try globalData.names.get(i) otherwise panic("pruneDeadGlobalData: i < total but names.get({i}) failed")
		let value = try globalData.values.get(i) otherwise panic("pruneDeadGlobalData: i < total but values.get({i}) failed")
		if not shouldKeepGlobal(name, liveLabels: liveLabels) 'drop'
			logTrace(LogCategory.ir, message: function() gives "pruneDeadGlobalData: dropping '{name}'")
			continue
		end 'drop'
		let newIdx = newNames.count()
		newNames.push(name)
		newValues.push(value)
		newNameIndex.upsert(name, value: newIdx)
		// Keep the byte-payload dedup index in sync. Earlier entries with
		// identical bytes still point at the canonical name; recording every
		// surviving entry preserves that invariant.
		newValueDedup.upsert(value, value: name)
	end 'partition'
	globalData.names = newNames
	globalData.values = newValues
	globalData.nameIndex = newNameIndex
	globalData.valueDedup = newValueDedup
end 'pruneDeadGlobalData'

// True for `dataSectionEntries` whose lifetime is owned by user/stdlib
// source-level `let`/`var` declarations rather than the runtime. Runtime
// helpers (`__slab_*`, `__mm_*`, `__mrt_*`, etc.) get their slots
// reserved by `lowerMaxonToStd` directly under fixed names, and the
// helper bodies that reference them haven't been merged into the
// user module yet at DFE time — so the walker can't see their
// `globalAddr` ops. Use the `__data_` prefix (mint site:
// `dataSymbolName` in `LowerMaxonToStd.maxon`) as the discriminator.
function isUserDataSlot(name String) returns bool
	return name.startsWith("__data_")
end 'isUserDataSlot'

// True when a globalData entry must survive pruning regardless of liveness:
//   - reserved runtime helpers (`__panic_*`, `__symtable`, `__xmmmask_*`) are
//     addressed via funcAddr / direct linker symbol, not globalAddr;
//   - data-section / cov-data entries are kept via the dataSectionEntries /
//     covDataEntries scan above (their names also enter `names`/`values`);
//   - `__data_*` globals back user `var`/`static` slots and the backend reads
//     their offsets through `lookupRdataOffset` without an SSA `globalAddr`.
// Everything else (user strings, panic messages, interned literals, float
// constants, layout descriptors, witness tables) gets dropped unless it
// appears in `liveLabels`.
function shouldKeepGlobal(name String, liveLabels StdDfeStringSet) returns bool
	if liveLabels.contains(name) 'isLive'
		return true
	end 'isLive'
	if name.startsWith("__panic_stacktrace") or name.startsWith("__panic_in") or name.startsWith("__panic_newline") or name.startsWith("__panic_unknown") 'isPanicHelper'
		return true
	end 'isPanicHelper'
	if name.startsWith("__xmmmask_") 'isXmmMask'
		return true
	end 'isXmmMask'
	if name == "__symtable" 'isSymtable'
		return true
	end 'isSymtable'
	if name.startsWith("__data_") 'isDataGlobal'
		return true
	end 'isDataGlobal'
	return false
end 'shouldKeepGlobal'

// Stage K.4: single-pass walk over every op in `func`'s body. Two
// reachability edges run at each op:
//   1. Static call edges (`call` / `tryCall` / `tailCall` / `funcRef`)
//      push named callees onto the worklist.
//   2. Witness-table / layout-descriptor demand ops
//      (`loadWitnessTable` / `loadLayoutDescriptor`) record the label in
//      `liveLabels` and promote every `witnessConditionalRoots[label]`
//      entry onto the worklist. `globalAddr` pins the named blob via
//      `liveLabels` only (no conditional roots — that map only keys off
//      witness/layout labels).
// Together these form the reachability fixed point: a function is live
// iff (a) it was seeded, (b) a live function calls it directly, or (c) a
// live function loads a witness/layout label under which the function
// was registered.
function walkLiveFunction(module StdModule, project Project, func IrFunction, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("walkLiveFunction: blockRef {blockRef} not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			visitStdOp(module, project: project, opIdx: opIdx, worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			visitStdOp(module, project: project, opIdx: block.terminatorIndex(), worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'hasTerm'
	end 'eachBlock'
end 'walkLiveFunction'

function visitStdOp(module StdModule, project Project, opIdx OpIndex, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	let op = try module.ops.get(opIdx) otherwise panic("visitStdOp: opIdx {opIdx} not in module.ops")
	match op 'shape'
		call(inner) then markFromStdCallOp(inner, worklist: worklist, seen: seen)
		system(inner) then promoteLabelsFromSystemOp(project, op: inner, worklist: worklist, seen: seen, liveLabels: liveLabels)
		arith then return
		control then return
		memory then return
	end 'shape'
end 'visitStdOp'

function promoteLabelsFromSystemOp(project Project, op StdSystemOp, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	match op 'kind'
		// `globalAddr` pins a generic globalData entry (string / float
		// constants). It doesn't carry witness-conditional roots — those
		// only key off witness/layout labels — but recording the name
		// into `liveLabels` lets `pruneDeadGlobalData` keep the blob
		// alive via `shouldKeepGlobal`.
		globalAddr(_, name) then liveLabels.insert(name)
		// `loadLayoutDescriptor` / `loadWitnessTable` pin both the blob
		// AND its conditional-root impls. First-touch on a label
		// promotes every `witnessConditionalRoots[label]` entry onto
		// the worklist.
		loadLayoutDescriptor(_, label) then promoteConditionalRoots(project, label: label, worklist: worklist, seen: seen, liveLabels: liveLabels)
		loadWitnessTable(_, label) then promoteConditionalRoots(project, label: label, worklist: worklist, seen: seen, liveLabels: liveLabels)
		// `funcAddr` resolves through the link-time symbol table, not
		// globalData, and any function it names is already rooted by
		// the `funcRef` op that produced its value. Other variants
		// either patch register state or perform OS-level work — none can
		// pin a witness/layout label.
		memcpy to loadIndirect then return
		funcAddr then return
		storeIndirect to unboxValue then return
		descriptorField to dropTypeParam then return
	end 'kind'
end 'promoteLabelsFromSystemOp'

function promoteConditionalRoots(project Project, label String, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	if liveLabels.contains(label) 'already'
		return
	end 'already'
	liveLabels.insert(label)
	if let bucket = try project.witnessConditionalRoots.get(label) 'haveBucket'
		for i in 0 upto bucket.count() 'eachImpl'
			let implName = try bucket.get(i) otherwise panic("promoteConditionalRoots: bucket.get OOB at {i}")
			markStdCallee(implName, worklist: worklist, seen: seen)
		end 'eachImpl'
	end 'haveBucket'
end 'promoteConditionalRoots'

function markFromStdCallOp(op StdCallOp, worklist StringArray, seen StdDfeStringSet)
	match op 'kind'
		ret then return
		call(_, callee, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		tryCall(_, callee, _, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		tailCall(callee, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		funcRef(_, funcName) then markStdCallee(funcName, worklist: worklist, seen: seen)
		// indirectCall flows through a runtime pointer; the callee was
		// already rooted by whatever produced the funcRef / closureCreate
		// upstream, so this op alone needs no fresh marking.
		indirectCall then return
		// witnessCall flows through a witness table; the callee was rooted
		// when the table was built (BuildWitnessTables emits funcRef for
		// every method address), so no fresh marking is needed here either.
		witnessCall then return
		param then return
		// errorReturn names no callee — both operands are local virtuals.
		errorReturn then return
	end 'kind'
end 'markFromStdCallOp'

function markStdCallee(name String, worklist StringArray, seen StdDfeStringSet)
	if name.isEmpty() 'noName'
		return
	end 'noName'
	if seen.contains(name) 'already'
		return
	end 'already'
	seen.insert(name)
	worklist.push(name)
end 'markStdCallee'

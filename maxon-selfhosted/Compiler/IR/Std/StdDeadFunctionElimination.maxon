// Phase 11.6: Std-level Dead Function Elimination.
//
// Mirrors the Maxon-level DFE in Compiler/IR/Maxon/DeadFunctionElimination.maxon
// but operates over Std ops. Runs after the inliner pass at the Std level —
// any function whose static call sites have all been inlined becomes
// unreachable and can be dropped from the module.
//
// Differences from the Maxon-level pass:
//   - Walks `StdCallOp.call` / `tryCall` / `tailCall` / `funcRef` /
//     `indirectCall` (latter conservatively keeps indirectly-targeted
//     functions alive because we can't see through the function pointer at
//     this phase). At Std level call resolution is already complete; the
//     callee names are direct strings, no CallContext qualification.
//   - Stage K.4: witness-table method impls and layout-descriptor copy/destroy
//     thunks are NOT statically rooted. They live in
//     `project.witnessConditionalRoots` keyed by the rdata label of the
//     table / descriptor they back. When the worklist walk pops a function
//     and finds a `loadWitnessTable(label)` or `loadLayoutDescriptor(label)`
//     op in its body, the conditional roots for that label are promoted
//     onto the worklist. This shares the same `liveLabels` set with
//     `pruneDeadGlobalData` below: a label is in `liveLabels` iff some live
//     function demands it via a system op, and impls / blobs /
//     `pendingRdataRelocs` entries keyed under that label are kept iff the
//     label is live.
//   - `livenessRoots` is reserved for definite roots that the runtime calls
//     before `main` (e.g. `__module_init_<namespace>`) and that no Std-level
//     op names.

typealias StdDfeStringSet = Set with String
typealias StdFuncByName = Map with (String, IrFunction)

export function eliminateDeadStdFunctions(module StdModule, project Project) returns StdModule
	var funcMap = StdFuncByName.create()
	for func in module.functions 'buildMap'
		funcMap.upsert(func.name, value: func)
	end 'buildMap'

	// Pre-DFE: detect `__module_init_<n>` entries whose write-set has no
	// live readers, and strip them from `livenessRoots` BEFORE the function
	// walk. Without this pre-pass, DFE would seed the dead inits as roots
	// and walk their bodies — pulling layout/witness/string dependencies
	// into `liveLabels` that survive pruning, so cache-off binaries grow
	// extra rdata for inits that never run. Uses a quick var-only
	// reachability walk over `main` + `livenessRoots` (excluding the inits
	// themselves) so the "live var" set doesn't depend on whether the dead
	// inits get walked.
	let preWalkLiveVars = computeLiveVarsExcludingInits(module, project: project, funcMap: funcMap)
	let inertInits = findInertModuleInits(project, liveVars: preWalkLiveVars)
	if inertInits.count() > 0 'haveInerts'
		project.livenessRoots = filterStringArrayBySet(project.livenessRoots, drop: inertInits)
	end 'haveInerts'

	var seen = StdDfeStringSet from ["main"]
	var worklist = ["main"]
	for root in project.livenessRoots 'seedRoots'
		if not seen.contains(root) 'fresh'
			seen.insert(root)
			worklist.push(root)
		end 'fresh'
	end 'seedRoots'

	// Stage K.4: shared with `pruneDeadGlobalData` below — every rdata
	// label that any live function demands via `loadWitnessTable` /
	// `loadLayoutDescriptor` / `globalAddr`. Function-DFE writes into it
	// during the walk to drive witness-conditional-root promotion;
	// globalData prune reads from it to decide which blobs and relocs
	// survive.
	var liveLabels = StdDfeStringSet.create()

	var i = 0
	while i < worklist.count() 'walk'
		let name = try worklist.get(i) otherwise panic("eliminateDeadStdFunctions: worklist.get OOB at {i}")
		if let func = try funcMap.get(name) 'found'
			walkLiveFunction(module, project: project, func: func, worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'found'
		i = i + 1
	end 'walk'

	var newFunctions = IrFunctionArray.create()
	for func in module.functions 'filter'
		if seen.contains(func.name) 'keep'
			newFunctions.push(func)
		end 'keep' else 'drop'
			logTrace(LogCategory.ir, message: function() gives "stddfe: dropping dead function '{func.name}'")
		end 'drop'
	end 'filter'
	module.functions = newFunctions

	// Drop `__module_init_<n>` entries whose entire write-set targets
	// dead vars. After this step, `patchMrtStartWithModuleInits` won't
	// emit a `call` for the dropped init, and the linker reachability
	// walk won't pull the init function (in user module OR stdlib cache)
	// into the final binary. Also drops the dead var entries from
	// `project.topLevelVars` so `registerGlobalVarsForDataSection` is
	// consistent on a subsequent re-lowering.
	module = pruneDeadModuleInits(module, project: project, liveLabels: liveLabels)

	// Stage K.X.D + K.4: prune unreferenced globalData entries and
	// pendingRdataRelocs whose target labels are dead. Sharing
	// `liveLabels` with the walker means we use the same reachability
	// fixed point that drove function-level liveness.
	pruneDeadGlobalData(project.globalData, liveLabels: liveLabels)
	return module
end 'eliminateDeadStdFunctions'

// Walk `project.moduleInitFuncs` and drop any init whose entire write-set
// (recorded in `project.initToStoredVars` at parse time) targets vars
// that no live function references. Removes the init from
// `moduleInitFuncs` so `patchMrtStartWithModuleInits` skips the call,
// from `livenessRoots` so the function-DFE re-run (if any) can drop the
// body, and the corresponding entries from `project.topLevelVars` and
// `globalData.dataSectionEntries` so the `.data` slot isn't reserved.
// Mini-DFE that walks the same call graph the main DFE will walk, BUT
// skips `__module_init_<n>` bodies. The returned set contains every
// `globalAddr` label demanded by a function reachable from `main` /
// `livenessRoots` without crediting any init for the labels it
// references. Used by `findInertModuleInits` to detect inits whose vars
// are never read by anyone outside themselves — those inits can be
// stripped from `livenessRoots` before the main DFE walks them.
function computeLiveVarsExcludingInits(module StdModule, project Project, funcMap StdFuncByName) returns StdDfeStringSet
	var initNames = StdDfeStringSet.create()
	for n in project.moduleInitFuncs 'collectInits'
		if not n.isEmpty() 'realName'
			initNames.insert(n)
		end 'realName'
	end 'collectInits'

	var seen = StdDfeStringSet from ["main"]
	var worklist = ["main"]
	for root in project.livenessRoots 'seedRoots'
		if initNames.contains(root) 'skipInit'
			continue
		end 'skipInit'
		if not seen.contains(root) 'fresh'
			seen.insert(root)
			worklist.push(root)
		end 'fresh'
	end 'seedRoots'

	var liveVars = StdDfeStringSet.create()
	var i = 0
	while i < worklist.count() 'walk'
		let name = try worklist.get(i) otherwise panic("computeLiveVarsExcludingInits: worklist.get OOB at {i}")
		i = i + 1
		if initNames.contains(name) 'isInit'
			continue
		end 'isInit'
		if let func = try funcMap.get(name) 'found'
			walkFunctionForVarLiveness(module, func: func, initNames: initNames, worklist: worklist, seen: seen, liveVars: liveVars)
		end 'found'
	end 'walk'
	return liveVars
end 'computeLiveVarsExcludingInits'

function walkFunctionForVarLiveness(module StdModule, func IrFunction, initNames StdDfeStringSet, worklist StringArray, seen StdDfeStringSet, liveVars StdDfeStringSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("walkFunctionForVarLiveness: blockRef {blockRef} not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			visitOpForVarLiveness(module, opIdx: opIdx, initNames: initNames, worklist: worklist, seen: seen, liveVars: liveVars)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			visitOpForVarLiveness(module, opIdx: block.terminatorIndex(), initNames: initNames, worklist: worklist, seen: seen, liveVars: liveVars)
		end 'hasTerm'
	end 'eachBlock'
end 'walkFunctionForVarLiveness'

function visitOpForVarLiveness(module StdModule, opIdx OpIndex, initNames StdDfeStringSet, worklist StringArray, seen StdDfeStringSet, liveVars StdDfeStringSet)
	let op = try module.ops.get(opIdx) otherwise panic("visitOpForVarLiveness: opIdx {opIdx} not in module.ops")
	match op 'shape'
		call(inner) then markCalleeForVarWalk(inner, initNames: initNames, worklist: worklist, seen: seen)
		system(inner) then recordSystemOpVarRef(inner, liveVars: liveVars)
		arith then return
		control then return
		memory then return
	end 'shape'
end 'visitOpForVarLiveness'

function recordSystemOpVarRef(op StdSystemOp, liveVars StdDfeStringSet)
	match op 'kind'
		globalAddr(_, name) then liveVars.insert(name)
		memcpy to loadIndirect then return
		funcAddr then return
		storeIndirect to unboxValue then return
		descriptorField to dropTypeParam then return
		loadLayoutDescriptor then return
		loadWitnessTable then return
	end 'kind'
end 'recordSystemOpVarRef'

function markCalleeForVarWalk(op StdCallOp, initNames StdDfeStringSet, worklist StringArray, seen StdDfeStringSet)
	match op 'kind'
		ret then return
		call(_, callee, _) then markCalleeNameForVarWalk(callee, initNames: initNames, worklist: worklist, seen: seen)
		tryCall(_, callee, _, _) then markCalleeNameForVarWalk(callee, initNames: initNames, worklist: worklist, seen: seen)
		tailCall(callee, _) then markCalleeNameForVarWalk(callee, initNames: initNames, worklist: worklist, seen: seen)
		funcRef(_, funcName) then markCalleeNameForVarWalk(funcName, initNames: initNames, worklist: worklist, seen: seen)
		indirectCall then return
		witnessCall then return
		witnessTryCall then return
		param then return
		errorReturn then return
	end 'kind'
end 'markCalleeForVarWalk'

function markCalleeNameForVarWalk(name String, initNames StdDfeStringSet, worklist StringArray, seen StdDfeStringSet)
	if name.isEmpty() 'noName'
		return
	end 'noName'
	if initNames.contains(name) 'skipInit'
		return
	end 'skipInit'
	if seen.contains(name) 'already'
		return
	end 'already'
	seen.insert(name)
	worklist.push(name)
end 'markCalleeNameForVarWalk'

// Walk `project.moduleInitFuncs` and return the set of init names whose
// entire write-set (recorded in `initToStoredVars`) targets vars NOT
// present in `liveVars`. These inits will never be observed by any live
// function, so dropping them from `livenessRoots` before the main DFE
// walk keeps their layout/witness/string dependencies out of `liveLabels`
// — matching what a cache-on build (which never parses the init in the
// first place) would emit.
function findInertModuleInits(project Project, liveVars StdDfeStringSet) returns StdDfeStringSet
	var inert = StdDfeStringSet.create()
	for initName in project.moduleInitFuncs 'eachInit'
		if initName.isEmpty() 'placeholder'
			continue
		end 'placeholder'
		if initWriteSetIsAllDead(project, initName: initName, liveLabels: liveVars) 'allDead'
			inert.insert(initName)
		end 'allDead'
	end 'eachInit'
	return inert
end 'findInertModuleInits'

// True when `initName` has a recorded write-set in `project.initToStoredVars`
// AND none of the `__data_<var>` labels for that write-set appear in
// `liveLabels`. Returns false if the init has no recorded write-set
// (unknown — conservative) OR if any var in the write-set is sourced from
// the stdlib — stdlib bodies live in the pre-compiled cache (not in
// `module.functions`), so the function-DFE walker can't observe their
// `globalAddr` reads. Conservatively keeping stdlib-sourced inits matches
// what a no-DFE build would emit and avoids dropping a `.data` slot the
// cached stdlib body still references via a baked-in `globalAddr` fixup.
// Shared by `findInertModuleInits` (pre-DFE roots prune) and
// `pruneDeadModuleInits` (post-DFE final prune) so they agree on the
// deadness test.
function initWriteSetIsAllDead(project Project, initName String, liveLabels StdDfeStringSet) returns bool
	if let storedSet = try project.initToStoredVars.get(initName) 'haveSet'
		for varName in storedSet 'eachVar'
			let dataLabel = "__data_{varName}"
			if liveLabels.contains(dataLabel) 'isLive'
				return false
			end 'isLive'
		end 'eachVar'
		return true
	end 'haveSet'
	return false
end 'initWriteSetIsAllDead'

function filterStringArrayBySet(input StringArray, drop StdDfeStringSet) returns StringArray
	var result = StringArray.create()
	for name in input 'eachName'
		if drop.contains(name) 'skip'
			continue
		end 'skip'
		result.push(name)
	end 'eachName'
	return result
end 'filterStringArrayBySet'

function pruneDeadModuleInits(module StdModule, project Project, liveLabels StdDfeStringSet) returns StdModule
	if project.moduleInitFuncs.count() == 0 'noInits'
		return module
	end 'noInits'

	var deadInits = StdDfeStringSet.create()
	var deadVars = StdDfeStringSet.create()
	for initName in project.moduleInitFuncs 'eachInit'
		// Empty entries are placeholder slots reserved by
		// `seedModuleInitFuncsFromLivenessRoots` to keep user-side init
		// numbering past the stdlib's. They carry no callable function and
		// no associated vars — nothing to prune.
		if initName.isEmpty() 'placeholder'
			continue
		end 'placeholder'
		if not initWriteSetIsAllDead(project, initName: initName, liveLabels: liveLabels) 'someLive'
			continue
		end 'someLive'
		deadInits.insert(initName)
		let storedSet = try project.initToStoredVars.get(initName) otherwise panic("pruneDeadModuleInits: initWriteSetIsAllDead returned true but initToStoredVars.get failed for '{initName}'")
		// Stdlib var slots stay in `dataSectionEntries` even when their init
		// is dropped: cached stdlib bodies (e.g. `Log.trace` in
		// `stdlib/Log.maxon`) bake in `globalAddr __data_<var>` fixups that
		// must resolve when those bodies get linked into the user binary.
		// User code can't see the stdlib references during the function-DFE
		// walk (cached bodies aren't in `module.functions`), so deleting a
		// stdlib slot risks leaving a fixup unresolved. The slot stays
		// zero-initialized — equivalent to what a primitive `false`/`0`
		// initial-value init would write; heap-initialized stdlib vars
		// (`var x = T.create()`) start as nullptr and are only dereferenced
		// along paths the cached body guards with explicit non-null checks
		// (e.g. `if capturing` in `Log.trace`).
		for varName in storedSet 'eachDeadVar'
			if let info = try project.topLevelVars.get(varName) 'haveInfo'
				if isStdlibDecl(info.sourceFilePath) 'stdlibVar'
					continue
				end 'stdlibVar'
			end 'haveInfo'
			deadVars.insert(varName)
		end 'eachDeadVar'
	end 'eachInit'

	if deadInits.count() == 0 'nothingToDrop'
		return module
	end 'nothingToDrop'

	// Emit a trace log for each dropped init, then rebuild
	// `moduleInitFuncs` / `livenessRoots` with a shared filter helper.
	for initName in project.moduleInitFuncs 'logDrops'
		if deadInits.contains(initName) 'drop'
			logTrace(LogCategory.ir, message: function() gives "stddfe: dropping dead module-init '{initName}'")
		end 'drop'
	end 'logDrops'
	project.moduleInitFuncs = filterStringArrayBySet(project.moduleInitFuncs, drop: deadInits)
	project.livenessRoots = filterStringArrayBySet(project.livenessRoots, drop: deadInits)

	// Drop the dead vars from project.topLevelVars and globalData.dataSectionEntries
	// so a subsequent re-lowering or backend pass sees consistent state.
	for varName in deadVars 'eachDeadVar'
		_ = project.topLevelVars.remove(varName)
	end 'eachDeadVar'
	for initName in deadInits 'eachDeadInit'
		_ = project.initToStoredVars.remove(initName)
	end 'eachDeadInit'

	// Filter dataSectionEntries to drop the dead slots. Build the
	// `__data_<var>` label set up front so the per-entry membership check
	// is O(1) instead of O(deadVars). Their `__data_*` names also need to
	// stay out of liveLabels so `pruneDeadGlobalData` (running next)
	// doesn't re-pin them via the dataSectionEntries scan.
	var deadDataLabels = StdDfeStringSet.create()
	for varName in deadVars 'eachDeadVarLabel'
		deadDataLabels.insert("__data_{varName}")
	end 'eachDeadVarLabel'
	var newDataEntries = DataSectionEntryArray.create()
	for entry in project.globalData.dataSectionEntries 'eachData'
		if deadDataLabels.contains(entry.name) 'dropEntry'
			logTrace(LogCategory.ir, message: function() gives "stddfe: dropping data-section entry '{entry.name}' (init eliminated)")
			continue
		end 'dropEntry'
		newDataEntries.push(entry)
	end 'eachData'
	project.globalData.dataSectionEntries = newDataEntries

	// Drop user-side init function bodies that were kept alive only by
	// their `livenessRoots` entry. (Stdlib inits live in the cache and
	// aren't in `module.functions`, so the filter is a no-op for them.)
	var keptFunctions = IrFunctionArray.create()
	for func in module.functions 'filterFuncs'
		if deadInits.contains(func.name) 'dropFunc'
			logTrace(LogCategory.ir, message: function() gives "stddfe: dropping dead module-init function body '{func.name}'")
			continue
		end 'dropFunc'
		keptFunctions.push(func)
	end 'filterFuncs'
	module.functions = keptFunctions
	return module
end 'pruneDeadModuleInits'

// Prune unreferenced globalData entries.
//
// Reachability set:
//   - every label demanded by a live function via `globalAddr`,
//     `loadLayoutDescriptor`, or `loadWitnessTable` (collected during the
//     function-DFE walk into the shared `liveLabels` set).
//   - everything reserved up-front: __panic_stacktrace, __panic_in,
//     __panic_newline, __panic_unknown, the __xmmmask_* float-bit masks,
//     and any DataSection / CovData entry whose offset the linker resolves
//     statically (handled by `shouldKeepGlobal`).
//
// `globalData.pendingRdataRelocs` is filtered the same way: a reloc whose
// `rdataLabel` isn't live points at a witness/layout blob that's about to
// be pruned, so the reloc would dangle at link time. Both the writers
// hard-panic on missing functions, so the filter must run atomically with
// the function/blob prune.
function pruneDeadGlobalData(globalData GlobalDataTable, liveLabels StdDfeStringSet)
	// `liveLabels` is already populated by `walkLiveFunction` for every
	// label any kept function demanded via `globalAddr` /
	// `loadLayoutDescriptor` / `loadWitnessTable`.

	// Explicitly-named globals registered through addNamedGlobalData stay
	// live — they're addressed by the runtime (panic-stack helpers) or
	// the loader (.data / .covdata) and have no code-side globalAddr op
	// until the user actually references them. User top-level vars whose
	// underlying `project.topLevelVars` entry was already dropped by the
	// upstream `pruneDeadModuleInits` (running earlier in this same
	// `eliminateDeadStdFunctions` invocation) have their `__data_*` slots
	// removed from `dataSectionEntries` there — pinning what does appear
	// is safe and matches the historical behavior runtime helpers expect.
	for entry in globalData.dataSectionEntries 'eachData'
		liveLabels.insert(entry.name)
	end 'eachData'
	for entry in globalData.covDataEntries 'eachCov'
		liveLabels.insert(entry.name)
	end 'eachCov'

	// Filter pendingRdataRelocs: every funcAbs64InRdata reloc names a
	// witness/layout method slot whose impl was already conditionally
	// rooted under the same `rdataLabel`. If the label isn't live, the
	// impl isn't live either (function-DFE didn't promote it), so
	// dropping the reloc keeps the patcher's symbol table consistent.
	var newRelocs = RdataRelocationArray.create()
	for reloc in globalData.pendingRdataRelocs 'eachReloc'
		if liveLabels.contains(reloc.rdataLabel) 'keepReloc'
			newRelocs.push(reloc)
		end 'keepReloc' else 'dropReloc'
			logTrace(LogCategory.ir, message: function() gives "pruneDeadGlobalData: dropping reloc for dead rdata label '{reloc.rdataLabel}'")
		end 'dropReloc'
	end 'eachReloc'
	globalData.pendingRdataRelocs = newRelocs

	let total = globalData.names.count()
	var newNames = StringArray.create()
	var newValues = ByteArrayArray.create()
	var newNameIndex = GlobalNameIndexMap.create()
	var newValueDedup = GlobalDedupMap.create()
	for i in 0 upto total 'partition'
		let name = try globalData.names.get(i) otherwise panic("pruneDeadGlobalData: i < total but names.get({i}) failed")
		let value = try globalData.values.get(i) otherwise panic("pruneDeadGlobalData: i < total but values.get({i}) failed")
		if not shouldKeepGlobal(name, liveLabels: liveLabels) 'drop'
			logTrace(LogCategory.ir, message: function() gives "pruneDeadGlobalData: dropping '{name}'")
			continue
		end 'drop'
		let newIdx = newNames.count()
		newNames.push(name)
		newValues.push(value)
		newNameIndex.upsert(name, value: newIdx)
		// Keep the byte-payload dedup index in sync. Earlier entries with
		// identical bytes still point at the canonical name; recording every
		// surviving entry preserves that invariant.
		newValueDedup.upsert(value, value: name)
	end 'partition'
	globalData.names = newNames
	globalData.values = newValues
	globalData.nameIndex = newNameIndex
	globalData.valueDedup = newValueDedup
end 'pruneDeadGlobalData'

// True when a globalData entry must survive pruning regardless of liveness:
//   - reserved runtime helpers (`__panic_*`, `__symtable`, `__xmmmask_*`) are
//     addressed via funcAddr / direct linker symbol, not globalAddr;
//   - data-section / cov-data entries are kept via the dataSectionEntries /
//     covDataEntries scan above (their names also enter `names`/`values`);
//   - `__data_*` globals back user `var`/`static` slots and the backend reads
//     their offsets through `lookupRdataOffset` without an SSA `globalAddr`.
// Everything else (user strings, panic messages, interned literals, float
// constants, layout descriptors, witness tables) gets dropped unless it
// appears in `liveLabels`.
function shouldKeepGlobal(name String, liveLabels StdDfeStringSet) returns bool
	if liveLabels.contains(name) 'isLive'
		return true
	end 'isLive'
	if name.startsWith("__panic_stacktrace") or name.startsWith("__panic_in") or name.startsWith("__panic_newline") or name.startsWith("__panic_unknown") 'isPanicHelper'
		return true
	end 'isPanicHelper'
	if name.startsWith("__xmmmask_") 'isXmmMask'
		return true
	end 'isXmmMask'
	if name == "__symtable" 'isSymtable'
		return true
	end 'isSymtable'
	if name.startsWith("__data_") 'isDataGlobal'
		return true
	end 'isDataGlobal'
	return false
end 'shouldKeepGlobal'

// Stage K.4: single-pass walk over every op in `func`'s body. Two
// reachability edges run at each op:
//   1. Static call edges (`call` / `tryCall` / `tailCall` / `funcRef`)
//      push named callees onto the worklist.
//   2. Witness-table / layout-descriptor demand ops
//      (`loadWitnessTable` / `loadLayoutDescriptor`) record the label in
//      `liveLabels` and promote every `witnessConditionalRoots[label]`
//      entry onto the worklist. `globalAddr` pins the named blob via
//      `liveLabels` only (no conditional roots — that map only keys off
//      witness/layout labels).
// Together these form the reachability fixed point: a function is live
// iff (a) it was seeded, (b) a live function calls it directly, or (c) a
// live function loads a witness/layout label under which the function
// was registered.
function walkLiveFunction(module StdModule, project Project, func IrFunction, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("walkLiveFunction: blockRef {blockRef} not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			visitStdOp(module, project: project, opIdx: opIdx, worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			visitStdOp(module, project: project, opIdx: block.terminatorIndex(), worklist: worklist, seen: seen, liveLabels: liveLabels)
		end 'hasTerm'
	end 'eachBlock'
end 'walkLiveFunction'

function visitStdOp(module StdModule, project Project, opIdx OpIndex, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	let op = try module.ops.get(opIdx) otherwise panic("visitStdOp: opIdx {opIdx} not in module.ops")
	match op 'shape'
		call(inner) then markFromStdCallOp(inner, worklist: worklist, seen: seen)
		system(inner) then promoteLabelsFromSystemOp(project, op: inner, worklist: worklist, seen: seen, liveLabels: liveLabels)
		arith then return
		control then return
		memory then return
	end 'shape'
end 'visitStdOp'

function promoteLabelsFromSystemOp(project Project, op StdSystemOp, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	match op 'kind'
		// `globalAddr` pins a generic globalData entry (string / float
		// constants). It doesn't carry witness-conditional roots — those
		// only key off witness/layout labels — but recording the name
		// into `liveLabels` lets `pruneDeadGlobalData` keep the blob
		// alive via `shouldKeepGlobal`.
		globalAddr(_, name) then liveLabels.insert(name)
		// `loadLayoutDescriptor` / `loadWitnessTable` pin both the blob
		// AND its conditional-root impls. First-touch on a label
		// promotes every `witnessConditionalRoots[label]` entry onto
		// the worklist.
		loadLayoutDescriptor(_, label) then promoteConditionalRoots(project, label: label, worklist: worklist, seen: seen, liveLabels: liveLabels)
		loadWitnessTable(_, label) then promoteConditionalRoots(project, label: label, worklist: worklist, seen: seen, liveLabels: liveLabels)
		// `funcAddr` resolves through the link-time symbol table, not
		// globalData, and any function it names is already rooted by
		// the `funcRef` op that produced its value. Other variants
		// either patch register state or perform OS-level work — none can
		// pin a witness/layout label.
		memcpy to loadIndirect then return
		funcAddr then return
		storeIndirect to unboxValue then return
		descriptorField to dropTypeParam then return
	end 'kind'
end 'promoteLabelsFromSystemOp'

function promoteConditionalRoots(project Project, label String, worklist StringArray, seen StdDfeStringSet, liveLabels StdDfeStringSet)
	if liveLabels.contains(label) 'already'
		return
	end 'already'
	liveLabels.insert(label)
	if let bucket = try project.witnessConditionalRoots.get(label) 'haveBucket'
		for i in 0 upto bucket.count() 'eachImpl'
			let implName = try bucket.get(i) otherwise panic("promoteConditionalRoots: bucket.get OOB at {i}")
			markStdCallee(implName, worklist: worklist, seen: seen)
		end 'eachImpl'
	end 'haveBucket'
end 'promoteConditionalRoots'

function markFromStdCallOp(op StdCallOp, worklist StringArray, seen StdDfeStringSet)
	match op 'kind'
		ret then return
		call(_, callee, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		tryCall(_, callee, _, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		tailCall(callee, _) then markStdCallee(callee, worklist: worklist, seen: seen)
		funcRef(_, funcName) then markStdCallee(funcName, worklist: worklist, seen: seen)
		// indirectCall flows through a runtime pointer; the callee was
		// already rooted by whatever produced the funcRef / closureCreate
		// upstream, so this op alone needs no fresh marking.
		indirectCall then return
		// witnessCall flows through a witness table; the callee was rooted
		// when the table was built (BuildWitnessTables emits funcRef for
		// every method address), so no fresh marking is needed here either.
		witnessCall then return
		// witnessTryCall: same witness-table dispatch as witnessCall.
		witnessTryCall then return
		param then return
		// errorReturn names no callee — both operands are local virtuals.
		errorReturn then return
	end 'kind'
end 'markFromStdCallOp'

function markStdCallee(name String, worklist StringArray, seen StdDfeStringSet)
	if name.isEmpty() 'noName'
		return
	end 'noName'
	if seen.contains(name) 'already'
		return
	end 'already'
	seen.insert(name)
	worklist.push(name)
end 'markStdCallee'

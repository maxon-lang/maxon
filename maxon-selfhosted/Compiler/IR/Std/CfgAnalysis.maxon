// Shared CFG, dominator tree, dominance frontier, and loop analysis.
// Extracted from Mem2Reg.maxon so register allocation and other passes can reuse.

export let BLOCK_NONE = i64.max

export typealias BlockIdArrayArray = Array with BlockIdArray

// ============================================================
// CFG construction
// ============================================================

// CfgInfo holds predecessor and successor lists indexed by BlockId.
// Each entry is a BlockIdArray of connected block IDs.
export type CfgInfo
	export var predecessors BlockIdArrayArray
	export var successors BlockIdArrayArray
	export var numBlocks BlockId

	export static function create(predecessors BlockIdArrayArray, successors BlockIdArrayArray, numBlocks BlockId) returns CfgInfo
		return Self{predecessors: predecessors, successors: successors, numBlocks: numBlocks}
	end 'create'
end 'CfgInfo'

export function createCfgInfo(numBlocks BlockId) returns CfgInfo
	var preds = BlockIdArrayArray.create()
	var succs = BlockIdArrayArray.create()
	var i = 0
	while i < numBlocks 'initCfg'
		preds.push(BlockIdArray.create())
		succs.push(BlockIdArray.create())
		i = i + 1
	end 'initCfg'
	return CfgInfo.create(preds, successors: succs, numBlocks: numBlocks)
end 'createCfgInfo'

export function addCfgEdge(cfg CfgInfo, fromBlock BlockId, toBlock BlockId)
	if fromBlock >= cfg.numBlocks or toBlock >= cfg.numBlocks 'outOfRange'
		panic("addCfgEdge: block id out of range (from={fromBlock}, to={toBlock}, numBlocks={cfg.numBlocks})")
	end 'outOfRange'

	var succs = try cfg.successors.get(fromBlock) otherwise panic("addCfgEdge: successors missing for block {fromBlock}")

	if not blockIdArrayContains(succs, blockId: toBlock) 'notDup'
		succs.push(toBlock)
	end 'notDup'

	var preds = try cfg.predecessors.get(toBlock) otherwise panic("addCfgEdge: predecessors missing for block {toBlock}")

	if not blockIdArrayContains(preds, blockId: fromBlock) 'notDupPred'
		preds.push(fromBlock)
	end 'notDupPred'
end 'addCfgEdge'

export function blockIdArrayContains(arr BlockIdArray, blockId BlockId) returns bool
	for id in arr 'each'
		if id == blockId 'found'
			return true
		end 'found'
	end 'each'
	return false
end 'blockIdArrayContains'

// Build CFG from cf-dialect terminators (for use by Mem2Reg and other mid-level passes).
export function buildCfg(func IrFunction, module StdModule) returns CfgInfo
	let numBlocks = func.nextBlockId
	let cfg = createCfgInfo(numBlocks)

	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		if block.hasTerminatorOp() 'hasTerm'
			extractCfgEdges(block.id, terminator: block.terminatorIndex(), module: module, cfg: cfg)
		end 'hasTerm'
	end 'eachBlock'

	return cfg
end 'buildCfg'

function extractCfgEdges(blockId BlockId, terminator OpIndex, module StdModule, cfg CfgInfo)
	let stdOp = try module.ops.get(terminator) otherwise panic("invariant: terminator opIdx not in module.ops")
	match stdOp 'outer'
		control(cfOp) then extractCfEdges(blockId, cfOp: cfOp, cfg: cfg)
		arith then break 'outer'
		call then break 'outer'
		memory then break 'outer'
		system then break 'outer'
	end 'outer'
end 'extractCfgEdges'

function extractCfEdges(blockId BlockId, cfOp StdControlOp, cfg CfgInfo)
	match cfOp 'extract'
		br(target, _) then addCfgEdge(cfg, fromBlock: blockId, toBlock: target)
		condBr(_, thenTarget, _, elseTarget, _) then extractCondBrEdges(blockId, thenTarget: thenTarget, elseTarget: elseTarget, cfg: cfg)
	end 'extract'
end 'extractCfEdges'

function extractCondBrEdges(blockId BlockId, thenTarget BlockId, elseTarget BlockId, cfg CfgInfo)
	addCfgEdge(cfg, fromBlock: blockId, toBlock: thenTarget)
	addCfgEdge(cfg, fromBlock: blockId, toBlock: elseTarget)
end 'extractCondBrEdges'

// ============================================================
// Reverse postorder
// ============================================================

// Reverse postorder numbering: rpoOrder[i] = blockId at position i,
// rpoIndex[blockId] = position of blockId in reverse postorder.
export type RpoInfo
	export var order BlockIdArray
	export var index ValueIdArray

	export static function create(order BlockIdArray, index ValueIdArray) returns RpoInfo
		return Self{order: order, index: index}
	end 'create'
end 'RpoInfo'

export function computeReversePostorder(entryBlockId BlockId, numBlocks BlockId, cfg CfgInfo) returns RpoInfo
	// DFS from entry to produce postorder, then reverse
	var visited = BoolArray.create()
	cfgGrowBoolArray(visited, size: numBlocks)
	var postorder = BlockIdArray.create()

	dfsPostorder(entryBlockId, cfg: cfg, visited: visited, postorder: postorder)

	// Reverse the postorder to get reverse postorder
	var rpoOrder = BlockIdArray.create()
	var rpoIndex = ValueIdArray.create()
	cfgGrowValueIdArray(rpoIndex, size: numBlocks)

	// Initialize all indices to a sentinel
	var initIdx = 0
	while initIdx < numBlocks 'initRpoIdx'
		try rpoIndex.set(initIdx, value: BLOCK_NONE) otherwise panic("invariant: rpoIndex.set OOB")
		initIdx = initIdx + 1
	end 'initRpoIdx'

	let postCount = postorder.count()
	var ri = 0
	while ri < postCount 'reversePost'
		let blockId = try postorder.get(postCount - 1 - ri) otherwise 'skip'
			ri = ri + 1
			continue
		end 'skip'
		rpoOrder.push(blockId)
		try rpoIndex.set(blockId, value: ri) otherwise panic("invariant: rpoIndex.set OOB")
		ri = ri + 1
	end 'reversePost'

	return RpoInfo.create(rpoOrder, index: rpoIndex)
end 'computeReversePostorder'

export function dfsPostorder(blockId BlockId, cfg CfgInfo, visited BoolArray, postorder BlockIdArray)
	if blockId >= visited.count() 'outOfRange'
		return
	end 'outOfRange'

	let alreadyVisited = try visited.get(blockId) otherwise panic("dfsPostorder: blockId < visited.count() just verified but get({blockId}) failed (visited.count={visited.count()})")
	if alreadyVisited 'skip'
		return
	end 'skip'
	try visited.set(blockId, value: true) otherwise panic("invariant: visited.set OOB")

	let succs = try cfg.successors.get(blockId) otherwise 'noSuccs'
		postorder.push(blockId)
		return
	end 'noSuccs'

	for succ in succs 'eachSucc'
		dfsPostorder(succ, cfg: cfg, visited: visited, postorder: postorder)
	end 'eachSucc'
	postorder.push(blockId)
end 'dfsPostorder'

// ============================================================
// Dominator tree (Cooper-Harvey-Kennedy algorithm)
// ============================================================

export type DomInfo
	export var idom ValueIdArray

	export static function create(idom ValueIdArray) returns DomInfo
		return Self{idom: idom}
	end 'create'
end 'DomInfo'

export function computeDominators(entryBlockId BlockId, numBlocks BlockId, cfg CfgInfo, rpo RpoInfo) returns DomInfo
	// Initialize idom array with BLOCK_NONE (undefined)
	var idom = ValueIdArray.create()
	var i = 0
	while i < numBlocks 'initIdom'
		idom.push(BLOCK_NONE)
		i = i + 1
	end 'initIdom'

	// Empty CFG (function with no blocks) — nothing to dominate.
	if numBlocks == 0 'noBlocks'
		return DomInfo.create(idom)
	end 'noBlocks'

	// Entry block dominates itself
	try idom.set(entryBlockId, value: entryBlockId) otherwise panic("invariant: idom.set OOB")

	// Iterate until convergence
	var changed = true
	while changed 'converge'
		changed = false

		// Walk blocks in reverse postorder, skipping entry
		var rpoIdx = 0
		while rpoIdx < rpo.order.count() 'eachRpo'
			let b = try rpo.order.get(rpoIdx) otherwise 'skipRpo'
				rpoIdx = rpoIdx + 1
				continue
			end 'skipRpo'

			if b == entryBlockId 'isEntry'
				rpoIdx = rpoIdx + 1
				continue
			end 'isEntry'

			// Find first processed predecessor
			let preds = try cfg.predecessors.get(b) otherwise 'noPreds'
				rpoIdx = rpoIdx + 1
				continue
			end 'noPreds'

			var newIdom = BLOCK_NONE
			var foundFirst = false
			for p in preds 'findFirst'
				let pIdom = try idom.get(p) otherwise BLOCK_NONE
				if pIdom != BLOCK_NONE 'processed'
					if not foundFirst 'setFirst'
						newIdom = p
						foundFirst = true
					end 'setFirst' else 'intersectOther'
						newIdom = intersectDom(newIdom, b2: p, idom: idom, rpo: rpo)
					end 'intersectOther'
				end 'processed'
			end 'findFirst'

			if foundFirst 'hasIdom'
				let oldIdom = try idom.get(b) otherwise BLOCK_NONE
				if newIdom != oldIdom 'changed'
					try idom.set(b, value: newIdom) otherwise panic("invariant: idom.set OOB")
					changed = true
				end 'changed'
			end 'hasIdom'

			rpoIdx = rpoIdx + 1
		end 'eachRpo'
	end 'converge'

	return DomInfo.create(idom)
end 'computeDominators'

export function intersectDom(b1 BlockId, b2 BlockId, idom ValueIdArray, rpo RpoInfo) returns BlockId
	var finger1 = b1
	var finger2 = b2

	while finger1 != finger2 'intersect'
		let rpo1 = try rpo.index.get(finger1) otherwise BLOCK_NONE
		let rpo2 = try rpo.index.get(finger2) otherwise BLOCK_NONE

		// Move the finger with the higher RPO number (further from root) up
		if rpo1 == BLOCK_NONE or rpo2 == BLOCK_NONE 'unreachable'
			// One of the blocks is unreachable; bail
			return finger1
		end 'unreachable'

		if rpo1 > rpo2 'f1Higher'
			finger1 = try idom.get(finger1) otherwise panic("invariant: finger1 is a valid block id but idom.get failed")
		end 'f1Higher' else 'f2HigherOrEqual'
			// rpo2 > rpo1 (they can't be equal since finger1 != finger2)
			finger2 = try idom.get(finger2) otherwise panic("invariant: finger2 is a valid block id but idom.get failed")
		end 'f2HigherOrEqual'
	end 'intersect'

	return finger1
end 'intersectDom'

// Check if block a dominates block b.
export function dominates(a BlockId, b BlockId, domInfo DomInfo) returns bool
	if a == b 'same'
		return true
	end 'same'

	var runner = b
	while runner != BLOCK_NONE 'walkUp'
		let parent = try domInfo.idom.get(runner) otherwise BLOCK_NONE
		if parent == a 'found'
			return true
		end 'found'
		if parent == runner 'atRoot'
			// Reached the entry block without finding a
			return false
		end 'atRoot'
		runner = parent
	end 'walkUp'

	return false
end 'dominates'

// ============================================================
// Dominance frontiers
// ============================================================

// DfInfo: df[blockId] = BlockIdArray of blocks in the dominance frontier.
export type DfInfo
	export var frontiers BlockIdArrayArray

	export static function create(frontiers BlockIdArrayArray) returns DfInfo
		return Self{frontiers: frontiers}
	end 'create'
end 'DfInfo'

export function computeDominanceFrontiers(numBlocks BlockId, cfg CfgInfo, domInfo DomInfo) returns DfInfo
	var frontiers = BlockIdArrayArray.create()
	var i = 0
	while i < numBlocks 'initDf'
		frontiers.push(BlockIdArray.create())
		i = i + 1
	end 'initDf'

	// For each block b with >= 2 predecessors, walk each predecessor up
	// to idom(b), adding b to each runner's dominance frontier.
	var b = 0
	while b < numBlocks 'eachBlock'
		let preds = try cfg.predecessors.get(b) otherwise 'noPreds'
			b = b + 1
			continue
		end 'noPreds'

		if preds.count() >= 2 'hasMultiplePreds'
			let bIdom = try domInfo.idom.get(b) otherwise BLOCK_NONE
			for p in preds 'eachPred'
				var runner = p
				while runner != bIdom and runner != BLOCK_NONE 'walkUp'
					var dfSet = try frontiers.get(runner) otherwise break
					if not blockIdArrayContains(dfSet, blockId: b) 'addToDf'
						dfSet.push(b)
					end 'addToDf'
					runner = try domInfo.idom.get(runner) otherwise BLOCK_NONE
				end 'walkUp'
			end 'eachPred'
		end 'hasMultiplePreds'

		b = b + 1
	end 'eachBlock'

	return DfInfo.create(frontiers)
end 'computeDominanceFrontiers'

// ============================================================
// Dominator tree preorder traversal
// ============================================================

// Returns blocks in dominance-tree preorder. This ordering is a perfect
// elimination ordering for SSA chordal interference graphs.
export function computeDomTreePreorder(entryBlockId BlockId, domInfo DomInfo, numBlocks BlockId) returns BlockIdArray
	// Empty CFG (e.g. an extern function with no blocks): nothing to traverse.
	if numBlocks == 0 'noBlocks'
		return BlockIdArray.create()
	end 'noBlocks'

	// Build children lists from idom
	var children = BlockIdArrayArray.create()
	var i = 0
	while i < numBlocks 'initChildren'
		children.push(BlockIdArray.create())
		i = i + 1
	end 'initChildren'

	var b = 0
	while b < numBlocks 'buildChildren'
		let parent = try domInfo.idom.get(b) otherwise BLOCK_NONE
		if parent != BLOCK_NONE and parent != b 'hasParent'
			var childList = try children.get(parent) otherwise 'noList'
				b = b + 1
				continue
			end 'noList'
			childList.push(b)
		end 'hasParent'
		b = b + 1
	end 'buildChildren'

	// DFS preorder from entry
	var result = BlockIdArray.create()
	var stack = BlockIdArray.create()
	stack.push(entryBlockId)

	while stack.count() > 0 'dfs'
		let current = try stack.pop() otherwise break
		result.push(current)

		// Push children in reverse order so leftmost child is processed first.
		let kids = try children.get(current) otherwise panic("invariant: children sized to numBlocks but get({current}) failed")

		var ci = kids.count() - 1
		while ci >= 0 'pushKids'
			let kid = try kids.get(ci) otherwise panic("invariant: ci < kids.count() but get failed")
			stack.push(kid)
			ci = ci - 1
		end 'pushKids'
	end 'dfs'

	return result
end 'computeDomTreePreorder'

// ============================================================
// Loop nesting depth
// ============================================================

// Computes loop nesting depth per block. A back edge exists from block S to
// block H when S jumps to H and H dominates S. All blocks reachable from H
// that can reach S (without going through H) are in the natural loop body.
// Each nested loop adds +1 to the depth of its body blocks.
export function computeLoopNesting(cfg CfgInfo, domInfo DomInfo, rpo RpoInfo) returns RegIntArray
	let numBlocks = cfg.numBlocks
	var depth = RegIntArray.create()
	var i = 0
	while i < numBlocks 'initDepth'
		depth.push(0)
		i = i + 1
	end 'initDepth'

	// Find all back edges: edge S -> H where H dominates S
	for blockId in rpo.order 'findBackEdges'
		let succs = try cfg.successors.get(blockId) otherwise panic("invariant: cfg.successors sized to numBlocks but get({blockId}) failed")

		for succ in succs 'eachSucc'
			if dominates(succ, b: blockId, domInfo: domInfo) 'isBackEdge'
				// succ is the loop header, blockId is the latch
				// Find all blocks in the natural loop body and increment depth
				markNaturalLoop(header: succ, latch: blockId, cfg: cfg, depth: depth)
			end 'isBackEdge'
		end 'eachSucc'
	end 'findBackEdges'

	return depth
end 'computeLoopNesting'

// Mark all blocks in the natural loop defined by back edge latch -> header.
// The loop body is: header + all blocks that can reach latch without going through header.
// We find these by reverse-walking predecessors from latch until we reach header.
function markNaturalLoop(header BlockId, latch BlockId, cfg CfgInfo, depth RegIntArray)
	// Increment depth for the header
	let headerDepth = try depth.get(header) otherwise panic("markNaturalLoop: depth sized to numBlocks but get(header={header}) failed (depth.count={depth.count()})")
	try depth.set(header, value: headerDepth + 1) otherwise panic("invariant: depth.set OOB")

	// If header == latch, it's a single-block loop
	if header == latch 'singleBlock'
		return
	end 'singleBlock'

	// Reverse walk from latch to header using a worklist
	var worklist = BlockIdArray.create()
	var visited = BoolArray.create()
	cfgGrowBoolArray(visited, size: cfg.numBlocks)

	// Mark header as visited so we don't walk past it
	try visited.set(header, value: true) otherwise panic("invariant: visited.set OOB")

	// Start from latch
	try visited.set(latch, value: true) otherwise panic("invariant: visited.set OOB")
	let latchDepth = try depth.get(latch) otherwise panic("markNaturalLoop: depth sized to numBlocks but get(latch={latch}) failed (depth.count={depth.count()})")
	try depth.set(latch, value: latchDepth + 1) otherwise panic("invariant: depth.set OOB")
	worklist.push(latch)

	while worklist.count() > 0 'walkBack'
		let current = try worklist.pop() otherwise break

		let preds = try cfg.predecessors.get(current) otherwise panic("invariant: cfg.predecessors sized to numBlocks but get({current}) failed")

		for pred in preds 'eachPred'
			let alreadyVisited = try visited.get(pred) otherwise panic("markNaturalLoop: visited sized to cfg.numBlocks but get(pred={pred}) failed (visited.count={visited.count()})")
			if not alreadyVisited 'notVisited'
				try visited.set(pred, value: true) otherwise panic("invariant: visited.set OOB")
				let predDepth = try depth.get(pred) otherwise panic("markNaturalLoop: depth sized to numBlocks but get(pred={pred}) failed (depth.count={depth.count()})")
				try depth.set(pred, value: predDepth + 1) otherwise panic("invariant: depth.set OOB")
				worklist.push(pred)
			end 'notVisited'
		end 'eachPred'
	end 'walkBack'
end 'markNaturalLoop'

// Convenience wrapper: compute per-block loop nesting depth for a function.
// Returns a RegIntArray indexed by BlockId. Used by passes that only need
// the depth map (e.g. the inliner's budget multiplier) and don't otherwise
// touch the dominator tree.
export function computeLoopDepth(func IrFunction, module StdModule) returns RegIntArray
	if func.blockRefs.count() == 0 'noBlocks'
		return RegIntArray.create()
	end 'noBlocks'
	let firstBlockRef = try func.blockRefs.get(0) otherwise panic("computeLoopDepth: blockRefs.count() > 0 but get(0) failed")
	let entry = try module.blocks.get(firstBlockRef) otherwise panic("computeLoopDepth: entry blockRef {firstBlockRef} not in module")
	let entryBlockId = entry.id
	let numBlocks = func.nextBlockId
	let cfg = buildCfg(func, module: module)
	let rpo = computeReversePostorder(entryBlockId, numBlocks: numBlocks, cfg: cfg)
	let domInfo = computeDominators(entryBlockId, numBlocks: numBlocks, cfg: cfg, rpo: rpo)
	return computeLoopNesting(cfg, domInfo: domInfo, rpo: rpo)
end 'computeLoopDepth'

// ============================================================
// Helper functions
// ============================================================

export function cfgGrowBoolArray(arr BoolArray, size BlockId)
	while arr.count() < size 'grow'
		arr.push(false)
	end 'grow'
end 'cfgGrowBoolArray'

export function cfgGrowValueIdArray(arr ValueIdArray, size BlockId)
	while arr.count() < size 'grow'
		arr.push(0)
	end 'grow'
end 'cfgGrowValueIdArray'

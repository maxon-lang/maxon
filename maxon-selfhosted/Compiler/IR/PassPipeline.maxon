// Pass pipeline registry for the Maxon self-hosted compiler.
// Defines the full compilation pipeline as an explicit, typed, extensible
// sequence of passes. Each pass is a named variant of PassKind, dispatched
// through runPipeline which calls the corresponding pass function.
//
// Pipeline phases (4-level IR: Maxon, Std, MIR, Target):
//   Phase 2: Memory Safety  — semantic checks, DFE (operate on MaxonModule)
//   Phase 3: Maxon → Std    — lowerMaxonToStd (MaxonModule → StdModule)
//   Phase 4: Std passes     — borrowCheck, injectDrops, mem2reg, canonicalize,
//                             CSE, LICM, DCE, insertRangeChecks, lowerABI
//                             (all operate on StdModule)
//   Phase 5: Std → MIR      — augmentWithRuntime (StdModule → StdModule),
//                             lowerStdToMir (StdModule → MirModule)
//   Phase 6: MIR passes     — commuteForCoalescing, scheduleInstructions
//                             (MirModule → MirModule)
//   Phase 7: MIR → target   — handled directly by the backend (not pipeline passes):
//                             backend.lowerMirToTarget(), allocateRegisters,
//                             insertPrologueEpilogueWith (operate on TargetModule)

export union PassKind
	// Phase 2: Memory Safety (operates on MaxonModule)
	semanticCheck
	deadFunctionElimination
	// Phase 3: Maxon → Std
	lowerMaxonToStd
	// Phase 4: Std passes
	borrowCheck
	injectDrops
	mem2reg
	canonicalize
	cse
	licm
	dce
	insertRangeChecks
	lowerABI
	instrumentCoverage
	// Phase 5: Std → MIR
	augmentWithRuntime
	lowerStdToMir
	// Phase 6: MIR passes
	commuteForCoalescing
	scheduleInstructions
end 'PassKind'

export typealias PassKindArray = Array with PassKind

// Mutable context threaded through the pipeline.
//
// Each phase holds its own module type. The pipeline starts with
// `maxonModule` populated by the parser; subsequent lowering passes
// read one field and populate the next. Fields that haven't been
// populated yet hold freshly-created empty modules so field access
// never traps.
export type PipelineContext
	export var maxonModule MaxonModule
	export var stdModule StdModule
	export var mirModule MirModule
	export var targetModule TargetModule
	export var project Project
	export var globalData GlobalDataTable
	export var nextValueIdRef ValueIdRef
	export var target Target
	export var sourceFileName String

	export static function create(maxonModule MaxonModule, project Project, globalData GlobalDataTable, nextValueIdRef ValueIdRef, target Target, sourceFileName String) returns PipelineContext
		return Self{
			maxonModule: maxonModule,
			stdModule: StdModule.create(),
			mirModule: MirModule.create(),
			targetModule: TargetModule.create(target.cpu),
			project: project,
			globalData: globalData,
			nextValueIdRef: nextValueIdRef,
			target: target,
			sourceFileName: sourceFileName
		}
	end 'create'
end 'PipelineContext'

// Returns the mid-level pipeline (phases 2-4).
// Runs the Maxon-phase passes, the Maxon→Std lowering, and the Std-phase
// passes, ending with a fully-optimized StdModule in ctx.stdModule.
//
// Takes the project so it can consult `project.coverageEnabled` and append
// the coverage instrumentation pass conditionally. Instrumentation runs
// after lowerABI (the last transform that rewrites block op lists in bulk)
// so its prepended hit-counter ops survive untouched into the backend.
export function buildMidPipeline(project Project) returns PassKindArray
	var passes = PassKindArray.create()
	// Phase 2: Memory Safety (Maxon-level)
	passes.push(PassKind.semanticCheck)
	passes.push(PassKind.deadFunctionElimination)
	// Phase 3: Maxon → Std
	passes.push(PassKind.lowerMaxonToStd)
	// Phase 4a: Memory safety (Std-level)
	passes.push(PassKind.borrowCheck)
	passes.push(PassKind.injectDrops)
	// Phase 4b: Std passes
	passes.push(PassKind.mem2reg)
	passes.push(PassKind.canonicalize)
	passes.push(PassKind.cse)
	passes.push(PassKind.licm)
	passes.push(PassKind.dce)
	passes.push(PassKind.insertRangeChecks)
	passes.push(PassKind.lowerABI)
	if project.coverageEnabled 'cov'
		passes.push(PassKind.instrumentCoverage)
	end 'cov'
	return passes
end 'buildMidPipeline'

// Returns the backend pipeline (phases 5-6).
// Phase 7 (target lowering, regalloc, prologue/epilogue) is handled
// directly by the backend in emitBackendWith / buildStdlibNativeWith.
export function buildBackendPipeline() returns PassKindArray
	var passes = PassKindArray.create()
	// Phase 5: Std → MIR
	passes.push(PassKind.augmentWithRuntime)
	passes.push(PassKind.lowerStdToMir)
	// Phase 6: MIR passes
	passes.push(PassKind.commuteForCoalescing)
	passes.push(PassKind.scheduleInstructions)
	return passes
end 'buildBackendPipeline'

// Returns the WASM backend pipeline (phase 5 only).
// WASM branches from MIR directly — no target lowering, regalloc, or prologue.
export function buildWasmBackendPipeline() returns PassKindArray
	var passes = PassKindArray.create()
	passes.push(PassKind.augmentWithRuntime)
	passes.push(PassKind.lowerStdToMir)
	return passes
end 'buildWasmBackendPipeline'

// Returns the full pipeline (phases 2-7): mid + backend.
export function buildDefaultPipeline(project Project) returns PassKindArray
	var passes = buildMidPipeline(project)
	passes.append(buildBackendPipeline())
	return passes
end 'buildDefaultPipeline'

// Runs each pass in the given array sequentially.
// After each pass, checks for errors and throws if any exist.
export function runPipeline(ctx PipelineContext, passes PassKindArray) throws CompileError
	for pass in passes 'eachPass'
		let name = passKindToString(pass)
		logDebug(LogCategory.ir, message: () gives "=== Running pass: {name} ===")

		dispatchPass(ctx, pass: pass)

		logTrace(LogCategory.ir, message: () gives summarizeForPass(ctx, pass: pass, name: name))

		// Gate: stop pipeline if errors were reported
		if hasErrors(ctx.project) 'checkErrors'
			throw CompileError.compileError
		end 'checkErrors'
	end 'eachPass'
end 'runPipeline'

// Returns a module summary appropriate for the pass just run.
function summarizeForPass(ctx PipelineContext, pass PassKind, name String) returns String
	let phase = classifyPhase(pass)
	return match phase 'dump'
		maxon gives dumpModuleSummary(ctx.maxonModule.functions.count(), blockCount: ctx.maxonModule.blocks.count(), opCount: ctx.maxonModule.ops.count(), dialect: "maxon", passName: name)
		std gives dumpModuleSummary(ctx.stdModule.functions.count(), blockCount: ctx.stdModule.blocks.count(), opCount: ctx.stdModule.ops.count(), dialect: "std", passName: name)
		mir gives dumpModuleSummary(ctx.mirModule.functions.count(), blockCount: ctx.mirModule.blocks.count(), opCount: ctx.mirModule.ops.count(), dialect: "mir", passName: name)
		target gives dumpModuleSummary(ctx.targetModule.functions.count(), blockCount: ctx.targetModule.blocks.count(), opCount: ctx.targetModule.x64Ops.count() + ctx.targetModule.arm64Ops.count(), dialect: ctx.targetModule.cpu.name, passName: name)
	end 'dump'
end 'summarizeForPass'

enum PipelinePhase
	maxon
	std
	mir
	target
end 'PipelinePhase'

function classifyPhase(pass PassKind) returns PipelinePhase
	// lowerMaxonToStd is the boundary — it reads a MaxonModule and writes a
	// StdModule. The summary after it runs should reflect the StdModule.
	// Similarly for lowerStdToMir.
	return match pass 'phase'
		semanticCheck gives PipelinePhase.maxon
		deadFunctionElimination gives PipelinePhase.maxon
		lowerMaxonToStd gives PipelinePhase.std
		borrowCheck gives PipelinePhase.std
		injectDrops gives PipelinePhase.std
		mem2reg gives PipelinePhase.std
		canonicalize gives PipelinePhase.std
		cse gives PipelinePhase.std
		licm gives PipelinePhase.std
		dce gives PipelinePhase.std
		insertRangeChecks gives PipelinePhase.std
		lowerABI gives PipelinePhase.std
		instrumentCoverage gives PipelinePhase.std
		augmentWithRuntime gives PipelinePhase.std
		lowerStdToMir gives PipelinePhase.mir
		commuteForCoalescing gives PipelinePhase.mir
		scheduleInstructions gives PipelinePhase.mir
	end 'phase'
end 'classifyPhase'

// Dispatches a single pass to the corresponding function. Each pass reads
// and writes the appropriate module field on the context; lowering passes
// read one module type and write a different one.
function dispatchPass(ctx PipelineContext, pass PassKind)
	var project = ctx.project
	var globalData = ctx.globalData
	var nextValueIdRef = ctx.nextValueIdRef
	match pass 'dispatch'
		// Phase 2: Maxon-level passes
		semanticCheck then runSemanticChecks(project, module: ctx.maxonModule)

		deadFunctionElimination then ctx.maxonModule = eliminateDeadFunctions(ctx.maxonModule)

		// Phase 3: Maxon → Std
		lowerMaxonToStd then ctx.stdModule = lowerMaxonToStd(ctx.maxonModule, project: project, globalData: globalData, nextValueIdRef: nextValueIdRef)

		// Phase 4: Std passes
		borrowCheck then ctx.stdModule = runBorrowCheck(project, module: ctx.stdModule)

		injectDrops then ctx.stdModule = injectDrops(ctx.stdModule)

		mem2reg then ctx.stdModule = promoteMem2Reg(ctx.stdModule, nextValueIdRef: nextValueIdRef)

		canonicalize then ctx.stdModule = canonicalize(ctx.stdModule)

		cse then ctx.stdModule = eliminateCommonSubexpressions(ctx.stdModule)

		licm then ctx.stdModule = hoistLoopInvariants(ctx.stdModule)

		dce then ctx.stdModule = eliminateDeadCode(ctx.stdModule)

		insertRangeChecks then ctx.stdModule = insertRangeChecks(ctx.stdModule, project: project, funcReturnTypes: project.funcReturnTypes, typealiasRanges: project.typealiasRanges, nextValueIdRef: nextValueIdRef, sourceFileName: ctx.sourceFileName, globalData: globalData)

		lowerABI then ctx.stdModule = lowerABI(ctx.stdModule, target: ctx.target)

		instrumentCoverage then ctx.stdModule = instrumentCoverage(ctx.stdModule, project: project, nextValueIdRef: nextValueIdRef)

		// Phase 5: Std → MIR
		augmentWithRuntime then ctx.stdModule = augmentWithRuntime(ctx.stdModule, project: project)

		lowerStdToMir then ctx.mirModule = lowerStdToMir(ctx.stdModule)

		// Phase 6: MIR passes
		commuteForCoalescing then ctx.mirModule = commuteForCoalescing(ctx.mirModule)

		scheduleInstructions then ctx.mirModule = scheduleInstructions(ctx.mirModule, target: ctx.target)
	end 'dispatch'
end 'dispatchPass'

// Returns a human-readable name for a pass, used for logging.
export function passKindToString(pass PassKind) returns String
	return match pass 'name'
		semanticCheck gives "semantic-check"
		deadFunctionElimination gives "dead-function-elimination"
		borrowCheck gives "borrow-check"
		injectDrops gives "inject-drops"
		insertRangeChecks gives "insert-range-checks"
		lowerMaxonToStd gives "lower-maxon-to-std"
		mem2reg gives "mem2reg"
		canonicalize gives "canonicalize"
		cse gives "cse"
		licm gives "licm"
		dce gives "dce"
		lowerABI gives "lower-abi"
		instrumentCoverage gives "instrument-coverage"
		augmentWithRuntime gives "augment-with-runtime"
		lowerStdToMir gives "lower-std-to-mir"
		commuteForCoalescing gives "commute-for-coalescing"
		scheduleInstructions gives "schedule-instructions"
	end 'name'
end 'passKindToString'

// ModuleSummary: formatting for module summary stats after each pass.

typealias EntityCount = int(0 to u64.max)

export function dumpModuleSummary(funcCount EntityCount, blockCount EntityCount, opCount EntityCount, dialect String, passName String) returns String
	return "=== After {passName} ({dialect}) ===\nFunctions: {funcCount}, Blocks: {blockCount}, Ops: {opCount}"
end 'dumpModuleSummary'

// ModuleSummary: formatting for module summary stats after each pass.

export function dumpModuleSummary(funcCount Count, blockCount Count, opCount Count, dialect String, passName String) returns String
	return "=== After {passName} ({dialect}) ===\nFunctions: {funcCount}, Blocks: {blockCount}, Ops: {opCount}"
end 'dumpModuleSummary'

// IrFunction: a named function shared across all IR phases (Maxon, Std, MIR, Target).
//
// Carries both Maxon-phase types (populated by the parser) and Std-phase types
// (populated by LowerMaxonToStd). Phase-specific fields like varSlotCount,
// spillSize, and callee-saved registers are zero/empty-initialized and filled
// in by the appropriate pass.

export type IrFunction
	// --- Common fields (all phases) ---
	export var name String
	// Source-file namespace this function was parsed in (e.g. "stdlib",
	// "Compiler.Parser", "main"-test fragment basename). Set by the parser
	// at the point of qualification and consumed by LowerMaxonToStd to
	// resolve `CallContext.free` callees back to their qualified names —
	// `name` itself can be bare for entrypoints like `main`, so deriving
	// the namespace from `name` alone is not reliable.
	export var namespace String
	// Visibility tier from the declaring source. Stamped by the parser at
	// dispatch time. Stdlib functions restored from the cache get
	// `Visibility.global`. Read by TypeResolution's call-visibility walk
	// when filtering candidates against the reading function's file.
	export var visibility Visibility
	// Absolute / virtual path of the file this function was parsed in.
	// Used as the visibility anchor when cross-file callers look this
	// function up. Stdlib functions restored from the cache get the
	// shared stdlib bootstrap path so user code is always allowed to
	// reach them. Empty when the function was synthesized outside the
	// parser; visibility filtering treats empty paths as the project
	// root for fall-through reachability.
	export var sourceFilePath FilePath
	export var paramCount ParamCount
	export var blockRefs BlockRefList
	export var nextBlockId BlockId
	export var returnLine LineNumber
	// Line and column of the function-name token in the declaring source file.
	// Set by the parser after IrFunction.create(); zero for synthesized/restored
	// functions. Used by SemanticCheck to locate function-level diagnostics.
	export var nameLine LineNumber
	export var nameColumn ColumnNumber

	// --- Maxon-phase types (populated by parser, consumed by LowerMaxonToStd) ---
	export var maxonReturnType MaxonReturnType
	export var maxonParamTypes MaxonTypeArray
	// Bare error-enum name from the function's `throws E` clause, or empty
	// string for non-throwing functions. Recorded by the parser at decl time;
	// Phase 4 of the interfaces plan will read this to drive error-flag ABI
	// lowering. Stdlib-restored and synthesized helpers default to empty.
	export var throwsTypeName String
	// Persistent symbol table for this function. The parser hands this off
	// when parsing completes. Today it carries the flat declare/lookup state
	// at end-of-parse; future iterations will grow a nested tree keyed on
	// source byte ranges so the name-resolution query (used by the Maxon→Std
	// lowerer and the future LSP) can resolve shadowing at any cursor
	// position. Std-phase functions leave this empty.
	export var scope Scope

	// --- Std/MIR/Target-phase types (populated by LowerMaxonToStd) ---
	export var returnType StdReturnType
	export var paramTypes StdTypeArray

	// --- Phase-specific fields (zero/empty when not applicable) ---
	// Total number of slot-addressed variables used by the ISel.
	// The register allocator uses this to place spill slots below the variable area.
	export var varSlotCount VarSlot
	// Spill area size in bytes, computed by the register allocator.
	export var spillSize StackSize
	// Running tally of bytes the function needs on the stack for its frame
	// (locals + spills + callee-save area). Bumped by each pass that allocates
	// space — ISel when it hands out a temp slot, the spill manager when it
	// places a spill slot, callee-save detection when a non-volatile register
	// gets clobbered. The prologue/epilogue pass aligns this to 16 and emits
	// a single `sub rsp, N` (plus the saves). If a later pass proves a slot
	// or save is unneeded, it should decrement the counter so the prologue
	// stays accurate without a re-scan.
	export var stackSize StackSize
	// Callee-saved registers used by this function (set by PrologueEpiloguePass).
	export var calleeSavedGprs RegIntArray
	export var calleeSavedFps RegIntArray

	// Create an IrFunction at the Maxon phase. Maxon-phase type fields are
	// populated; Std-phase fields are left at defaults. Visibility defaults
	// to `file` so the parser must positively widen it to `module` /
	// `global` — synthesized functions that never go through the parser
	// stay file-private to their (empty) source path, which keeps stray
	// helpers from being callable cross-file by accident.
	export static function create(name String, maxonReturnType MaxonReturnType, paramCount ParamCount, maxonParamTypes MaxonTypeArray, returnLine LineNumber, throwsTypeName String = "") returns IrFunction
		return Self{
			name: name,
			namespace: "",
			visibility: Visibility.file,
			sourceFilePath: FilePath from "",
			paramCount: paramCount,
			blockRefs: BlockRefList.create(),
			nextBlockId: 0,
			returnLine: returnLine,
			nameLine: 0,
			nameColumn: 0,
			maxonReturnType: maxonReturnType,
			maxonParamTypes: maxonParamTypes,
			throwsTypeName: throwsTypeName,
			scope: Scope.create(),
			returnType: StdReturnType.void,
			paramTypes: StdTypeArray.create(),
			varSlotCount: 0,
			spillSize: 0,
			stackSize: 0,
			calleeSavedGprs: RegIntArray.create(),
			calleeSavedFps: RegIntArray.create()
		}
	end 'create'

	// Create an IrFunction at the Std phase or later. Std-phase type fields
	// are populated; Maxon-phase fields are left at defaults. Std-phase
	// constructors are used by stdlib-cache restore and by passes that
	// synthesize helper functions; both want the function callable from
	// anywhere, so visibility defaults to `global`.
	export static function createFromStd(name String, returnType StdReturnType, paramCount ParamCount, paramTypes StdTypeArray, returnLine LineNumber, throwsTypeName String = "") returns IrFunction
		return Self{
			name: name,
			namespace: "",
			visibility: Visibility.global,
			sourceFilePath: FilePath from "",
			paramCount: paramCount,
			blockRefs: BlockRefList.create(),
			nextBlockId: 0,
			returnLine: returnLine,
			nameLine: 0,
			nameColumn: 0,
			maxonReturnType: MaxonReturnType.void,
			maxonParamTypes: MaxonTypeArray.create(),
			throwsTypeName: throwsTypeName,
			scope: Scope.create(),
			returnType: returnType,
			paramTypes: paramTypes,
			varSlotCount: 0,
			spillSize: 0,
			stackSize: 0,
			calleeSavedGprs: RegIntArray.create(),
			calleeSavedFps: RegIntArray.create()
		}
	end 'createFromStd'

	export static function clone(src IrFunction) returns IrFunction
		return Self{
			name: src.name,
			namespace: src.namespace,
			visibility: src.visibility,
			sourceFilePath: src.sourceFilePath,
			paramCount: src.paramCount,
			blockRefs: BlockRefList.create(),
			nextBlockId: src.nextBlockId,
			returnLine: src.returnLine,
			nameLine: src.nameLine,
			nameColumn: src.nameColumn,
			maxonReturnType: src.maxonReturnType,
			maxonParamTypes: src.maxonParamTypes,
			throwsTypeName: src.throwsTypeName,
			scope: src.scope,
			returnType: src.returnType,
			paramTypes: src.paramTypes,
			varSlotCount: src.varSlotCount,
			spillSize: src.spillSize,
			stackSize: src.stackSize,
			calleeSavedGprs: src.calleeSavedGprs,
			calleeSavedFps: src.calleeSavedFps
		}
	end 'clone'
end 'IrFunction'

export typealias IrFunctionArray = Array with IrFunction

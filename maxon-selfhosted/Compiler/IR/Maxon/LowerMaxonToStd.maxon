// LowerMaxonToStd (Phase 3): single unified Maxon → Std lowering.
// Takes a MaxonModule and produces a fresh StdModule.
//
// **SSA is born here.** Maxon IR ops identify values by `ByteArray` names
// (zero-copy slices over the source buffer for user-written variables, or
// per-function synthetic `$tN` names for intermediates). This pass is the
// first place those names are assigned dense, function-local `ValueId`s.
//
// Per function:
//   - funcIdRef: a fresh `ValueIdRef` starting at `paramCount` (parameters
//     implicitly occupy ValueIds 0..paramCount-1 in the Std dialect ABI).
//   - nameToId: a linear-scan parallel-array map keyed on `ByteArray`
//     byte-sequence equality. Each Maxon op with a `result` name allocates
//     a fresh ValueId and records `nameToId[name] = id`. Each operand read
//     looks up the name; a miss means an unresolved reference (parser bug
//     or an `error` op we haven't yet introduced) and emits a compile-error
//     diagnostic, with a placeholder ValueId fabricated to keep subsequent
//     use-def structure consistent.
//
// Width/signedness collapse also happens here: MaxonType fields on Maxon ops
// are translated to StdType via maxonTypeToStdType. For this initial
// redesign, integer and float arithmetic promote to i64/f64 at the Std
// level (matching current behavior); narrow-width opcodes can be added later.
//
// Lowers:
//   maxon.literal        -> std.arith.const
//   maxon.binop          -> std.arith.binary
//   maxon.unop           -> std.arith.unary
//   maxon.convert        -> std.arith.unary (fpToSiI64 / siToFpF64) or pure name alias
//   maxon.cmp            -> std.arith.binary (comparison)
//   maxon.refEq          -> std.arith.binary (comparison)
//   maxon.varDecl/Store  -> std.memory.storeSlot
//   maxon.varLoad        -> std.memory.loadSlot
//   maxon.condBr/br      -> std.control.condBr/br
//   maxon.call/ret       -> std.call.call/ret
//   maxon.printLiteral   -> std.system.globalAddr + std.arith.const + std.call.call mrt_write_stdout
//   maxon.printInt       -> std.call.call mrt_printInt
//   maxon.panic          -> std.system.globalAddr + std.call.call mrt_panic
//   maxon.structAlloc    -> std.call.call mrt_alloc
//   maxon.fieldLoad      -> std.system.loadIndirect
//   maxon.fieldStore     -> std.system.storeIndirect

// Each function produces a fresh per-function `ValueIdRef` inside `lower()`,
// so this entry point takes no shared counter — SSA numbering is born here.
//
// Panic-label minting happens through `pipeline.nextPanicLabel()`, which
// hands out unique `__panic_msg_N` / `__stdlib_panic_msg_N` names and is
// shared with insertRangeChecks so every panic in a compile is numbered
// from one monotonic counter.
export function lowerMaxonToStd(pipeline PassPipeline, maxonModule MaxonModule, project Project, globalData GlobalDataTable) returns StdModule
	return MaxonToStdLowering.create(pipeline, maxonModule: maxonModule, project: project, globalData: globalData).lower()
end 'lowerMaxonToStd'

// Convert a source-level qualified name into the linker symbol that backs the
// global in the writable .data section. The `__data_` prefix is what the x64
// and arm64 backends pattern-match on to pick the dataSection relocation kind
// (see `relocKindForLabel` in X64Backend.maxon).
export function dataSymbolName(qualifiedName String) returns String
	return "__data_{qualifiedName}"
end 'dataSymbolName'

// Encode a 64-bit value as a little-endian 8-byte ByteArray, suitable for an
// initial value in the .data section.
function encodeI64LE(value IntConstant) returns ByteArray
	var bytes = ByteArray.create()
	writeQword(bytes, value: value)
	return bytes
end 'encodeI64LE'

// Walk project.topLevelVars and feed each one into globalData's
// data-section table. Idempotent across multiple lowering runs against the
// same project because lowerMaxonToStd creates a fresh GlobalDataTable per
// build. The exported function name keeps "Globals" because the data
// section itself is link-time-global storage; the source-level decls that
// land here may or may not be `export`ed.
export function registerGlobalVarsForDataSection(project Project, globalData GlobalDataTable)
	for (_, info) in project.topLevelVars 'eachVar'
		let symbol = dataSymbolName(info.name)
		let initialBytes = encodeI64LE(info.initialValue)
		addDataSectionEntry(globalData, name: symbol, initialBytes: initialBytes)
	end 'eachVar'
end 'registerGlobalVarsForDataSection'

// Reserve the `__data_maxon_error` slot (8 bytes, zero-initialized) used by
// `mrt_set_error` / `mrt_get_error_and_clear`. The slot lives in the .data
// prelude alongside ordinary top-level vars so the two backends' existing
// `__data_*` relocation handling resolves it without any extra plumbing.
// Phase 4 of the error-handling rollout uses a thread-local-ish flag here so
// `throw` / `try` can route a non-zero variant ordinal across a function
// boundary without changing the call ABI; Phase 4d-f will revisit the flag-
// in-register design if the call cost ever shows up in profiles.
export function registerErrorStateForDataSection(globalData GlobalDataTable)
	var zeroBytes = ByteArray.create()
	writeQword(zeroBytes, value: 0)
	addDataSectionEntry(globalData, name: "__data_maxon_error", initialBytes: zeroBytes)
end 'registerErrorStateForDataSection'

// True when the given Maxon return type lowers to a floating-point Std
// type. Drives the choice of `constF64` vs `constI64` for the default
// primary return value emitted by `lowerThrow`. `void` returns count as
// non-float — the synthesized const is unread by the caller in that case.
function maxonReturnTypeLowersToFloat(project Project, ref MaxonReturnType) returns bool
	return match ref 'pick'
		void gives false
		value(inner) gives stdTypeIsFloat(maxonTypeToStdType(project, ref: inner))
	end 'pick'
end 'maxonReturnTypeLowersToFloat'

// ============================================================
// MaxonToStdLowering type
// ============================================================

type MaxonToStdLowering
	var pipeline PassPipeline
	var maxonModule MaxonModule
	var project Project
	var globalData GlobalDataTable
	var stdModule StdModule
	// Per-function name→id map. Reset at the top of each function's lowering.
	var nameToId NameToValueIdMap
	// Per-function ValueId ref. Starts at `paramCount` so that parameter
	// IDs 0..paramCount-1 remain reserved by Std-ABI convention.
	var funcIdRef ValueIdRef
	// Per-function context for resolving cross-declaration name references
	// the parser now leaves symbolic. `currentNamespace` is the function's
	// module namespace ("" for free functions before qualification, "stdlib"
	// for stdlib funcs, etc.); used by `CallContext.free` resolution.
	// `currentTypeName` is "" for free functions or the enclosing struct
	// name for methods; used by `selfFieldLoad`/`selfFieldStore` to find
	// the field offset, and as the fallback callee context for any sibling
	// resolution that isn't already encoded in the op's CallContext.
	var currentNamespace String
	var currentTypeName String
	// Source file path of the function currently being lowered, recovered
	// from its entry block's BlockSourceInfo. Diagnostics emitted from the
	// lowering pass (E3005 at call sites, etc.) anchor on this so file:line
	// reporting matches the user's source layout. Reset when a new function
	// starts lowering.
	var currentFilePath String
	// Function-level return type of the function currently being lowered.
	// Used by `throw` lowering to emit a default primary return value of
	// the correct family (i64 vs f64) — the caller's `try ... otherwise`
	// branch ignores the primary value when the error flag is non-zero, so
	// any in-range default works. Reset per function in `lower()`.
	var currentReturnType MaxonReturnType
	// Per-function value-type map: tracks each SSA value's Maxon-level type.
	// Populated as ops are lowered so that consumers (fieldLoad/Store,
	// methodCall, mixed-family binops) can resolve receiver types and pick
	// the right opcode. Reset when a new function starts lowering. The
	// float-ness predicate (`getIsFloat`) is now a derived helper that
	// matches on the stored type.
	var valueType MaxonTypeArray
	// Scratch buffers reused by slotArgsForCall to avoid per-call alloc.
	// clear()+resize() each call; capacity converges to high-water mark.
	// The result array is still freshly allocated per call (StdOp.call
	// retains it), so the scratch is never returned directly.
	var slotIdsScratch ValueIdArray
	var slotFilledScratch BoolArray

	export static function create(pipeline PassPipeline, maxonModule MaxonModule, project Project, globalData GlobalDataTable) returns MaxonToStdLowering
		return Self{
			pipeline: pipeline,
			maxonModule: maxonModule,
			project: project,
			globalData: globalData,
			stdModule: StdModule.create(),
			nameToId: NameToValueIdMap.create(),
			funcIdRef: ValueIdRef.create(0),
			currentNamespace: "",
			currentTypeName: "",
			currentFilePath: "",
			currentReturnType: MaxonReturnType.void,
			valueType: MaxonTypeArray.create(),
			slotIdsScratch: ValueIdArray.create(),
			slotFilledScratch: BoolArray.create()
		}
	end 'create'

	// --- Per-value type tracking ------------------------------------------

	function setValueType(id ValueId, t MaxonType)
		while self.valueType.count() <= id 'grow'
			self.valueType.push(MaxonType.integer)
		end 'grow'
		try self.valueType.set(id, value: t) otherwise panic("invariant: self.valueType.set OOB")
	end 'setValueType'

	function getValueType(id ValueId) returns MaxonType
		return try self.valueType.get(id) otherwise MaxonType.integer
	end 'getValueType'

	// Float-ness derives from the stored type. Callers that only know the
	// int-vs-float family use this thin wrapper instead of `setValueType`
	// directly. When the caller passes `false`, we collapse to `integer`
	// rather than preserving any prior named type — the callers in this
	// file are all op-result writers that own the slot.
	function setIsFloat(id ValueId, isFloat bool)
		if isFloat 'asFloat'
			self.setValueType(id, t: MaxonType.float)
		end 'asFloat' else 'asInt'
			self.setValueType(id, t: MaxonType.integer)
		end 'asInt'
	end 'setIsFloat'

	function getIsFloat(id ValueId) returns bool
		return stdTypeIsFloat(maxonTypeToStdType(self.project, ref: self.getValueType(id)))
	end 'getIsFloat'

	// Promote `operandId` to f64 if it is currently int-backed. Returns the
	// post-promotion ValueId (original if no promotion needed). Emitted as an
	// si→f64 convert op; the result is registered as float in the map.
	function promoteToFloat(operandId ValueId, dstBlock IrBlock) returns ValueId
		if self.getIsFloat(operandId) 'alreadyFloat'
			return operandId
		end 'alreadyFloat'
		let promId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.siToFpF64, resultId: promId, operandId: operandId))))
		self.setIsFloat(promId, isFloat: true)
		return promId
	end 'promoteToFloat'

	// --- Name→ValueId translation ----------------------------------------

	// Allocate a fresh ValueId for a Maxon op's result name. Records the
	// mapping so subsequent operand reads of the same name resolve to this
	// ValueId. Not idempotent — each call creates a fresh id.
	function defineName(name ByteArray) returns ValueId
		let id = allocValueId(self.funcIdRef)
		self.nameToId.upsert(name, value: id)
		return id
	end 'defineName'

	// Emit a parser-bug-class compile error from inside the lowering pass.
	// All `lowerMaxonToStd:` errors share the same fake source position
	// (no line/column is recoverable here — the SourceRange on the Maxon
	// op is just the producing token, which lowering already discarded by
	// the time it spots the bug). `hasErrors(project)` will short-circuit
	// before codegen, so the placeholder path string never reaches the user.
	function reportLowerError(code ErrorCode, message String)
		let placeholderPath = try FilePath.from("lowerMaxonToStd") otherwise panic("lowerMaxonToStd: FilePath.from rejected literal placeholder")
		reportCompileError(self.project, code: code, message: message, line: 0, column: 0, filePath: placeholderPath)
	end 'reportLowerError'

	// Look up an operand name in the current function's map. A miss indicates
	// the referring Maxon op names a value that was never bound — either the
	// parser emitted an `error` op that dropped the defining op, or there is
	// a real parser bug. We emit a compile-error diagnostic and fabricate a
	// placeholder ValueId so subsequent ops still form a structurally valid
	// SSA module (`hasErrors(project)` will short-circuit before codegen).
	function resolveName(name ByteArray) returns ValueId
		let found = try self.nameToId.get(name) otherwise 'missed'
			self.reportLowerError(ErrorCode.semanticMissingReturn, message: "lowerMaxonToStd: unresolved value name '{String.from(name)}' (parser did not bind this name)")
			let placeholder = allocValueId(self.funcIdRef)
			self.nameToId.upsert(name, value: placeholder)
			return placeholder
		end 'missed'
		return found
	end 'resolveName'

	// Redirect `name` to an existing ValueId — used for same-family converts,
	// which are value-level no-ops: the result name refers to the same SSA
	// value as its operand.
	function aliasName(name ByteArray, toId ValueId)
		self.nameToId.upsert(name, value: toId)
	end 'aliasName'

	// Resolve each name in an arg list to its SSA ValueId.
	function resolveArgNames(args ByteArrayArray, leadingReceiverId ValueId = 0, hasLeadingReceiver bool = false) returns ValueIdArray
		var result = ValueIdArray.create()
		if hasLeadingReceiver 'pushLead'
			result.reserve(args.count() + 1)
			result.push(leadingReceiverId)
		end 'pushLead' else 'noLead'
			result.reserve(args.count())
		end 'noLead'
		for i in 0 upto args.count() 'each'
			let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
			result.push(self.resolveName(arg))
		end 'each'
		return result
	end 'resolveArgNames'

	// --- Main driver -------------------------------------------------------

	export function lower() returns StdModule
		// Register every top-level / static-field global with the .data section
		// machinery so the X64 backend lays out their initial values before the
		// heap arena. The map iteration is order-stable per project (insertion
		// order), keeping the linker symbol layout deterministic across builds.
		registerGlobalVarsForDataSection(self.project, globalData: self.globalData)
		// Reserve the runtime error-state slot used by throw/try lowering
		// (Phase 4). Lives in the .data prelude alongside user-declared globals.
		registerErrorStateForDataSection(self.globalData)

		// Copy blocks first so block indices stay aligned 1:1 between the source
		// MaxonModule.blocks and the dest StdModule.blocks. Each resulting
		// IrBlock is initially empty; ops are appended as we walk each function.
		// The source-location footprint is copied in lock-step so the downstream
		// coverage-instrumentation pass sees the same per-block line sets.
		for i in 0 upto self.maxonModule.blocks.count() 'cloneBlocks'
			let srcBlock = try self.maxonModule.blocks.get(i) otherwise panic("lowerMaxonToStd: blocks.get out of bounds")
			self.stdModule.blocks.push(IrBlock.create(srcBlock.id, label: srcBlock.label))
			let srcInfo = try self.maxonModule.blockSourceInfo.get(i) otherwise BlockSourceInfo.empty()
			self.stdModule.blockSourceInfo.push(srcInfo)
		end 'cloneBlocks'

		// Transfer each function directly, collapsing Maxon-phase types to Std types.
		// blockRefs are already correct since we kept 1:1 block index alignment above.
		for i in 0 upto self.maxonModule.functions.count() 'transferFuncs'
			var func = try self.maxonModule.functions.get(i) otherwise panic("invariant: i < functions.count() but get failed")
			var stdParams = StdTypeArray.create()
			for paramType in func.maxonParamTypes 'eachParam'
				stdParams.push(maxonTypeToStdType(self.project, ref: paramType))
			end 'eachParam'
			func.returnType = maxonReturnTypeToStdReturnType(self.project, ref: func.maxonReturnType)
			func.paramTypes = stdParams
			self.stdModule.functions.push(func)
		end 'transferFuncs'

		// Walk each function's blocks and lower their ops.
		for srcFunc in self.maxonModule.functions 'eachFunc'
			logTrace(LogCategory.ir, message: () gives "lower-maxon-to-std: func={srcFunc.name} blocks={srcFunc.blockRefs.count()}")

			// Reset per-function state. SSA value IDs restart at paramCount in
			// each function so parameter IDs 0..paramCount-1 stay reserved.
			// Seed the value-type map from declared maxonParamTypes so
			// downstream ops see parameters as values of the right type.
			// `currentNamespace` comes directly from the IrFunction (set by
			// the parser). `currentTypeName` is recovered from func.name by
			// peeling off the last `.identifier` and probing structTypes —
			// the parser qualifies methods as `Type.method`, so a name
			// whose prefix is a registered struct denotes a method body.
			self.valueType = MaxonTypeArray.create()
			self.nameToId = NameToValueIdMap.create()
			self.funcIdRef = ValueIdRef.create(srcFunc.paramCount)
			self.currentNamespace = srcFunc.namespace
			self.currentTypeName = enclosingTypeName(self.project, name: srcFunc.name)
			// Recover the file path from the entry block's source info so
			// E3005 (and any future call-site diagnostic) anchors on the
			// caller's source file rather than the lowering pass placeholder.
			self.currentFilePath = entryBlockFilePath(self.maxonModule, func: srcFunc)
			// Phase 4: throw lowering needs to know the function's return
			// type family so it can synthesize a default primary return
			// value of the correct width (i64 vs f64). Stamp it here so
			// `lowerThrow` can read it without re-walking module.functions.
			self.currentReturnType = srcFunc.maxonReturnType
			for pIdx in 0 upto srcFunc.maxonParamTypes.count() 'seedParams'
				let pType = try srcFunc.maxonParamTypes.get(pIdx) otherwise MaxonType.integer
				self.setValueType(pIdx, t: pType)
			end 'seedParams'

			for blockRef in srcFunc.blockRefs 'eachBlock'
				let srcBlock = try self.maxonModule.blocks.get(blockRef) otherwise panic("invariant: blockRef from srcFunc.blockRefs not in maxonModule.blocks")
				var dstBlock = try self.stdModule.blocks.get(blockRef) otherwise panic("invariant: stdModule.blocks 1:1 with maxonModule.blocks but get({blockRef}) failed")

				for opIdx in srcBlock.opRefs 'eachOp'
					let hlOp = try self.maxonModule.ops.get(opIdx) otherwise panic("invariant: opIdx from srcBlock.opRefs not in maxonModule.ops")
					self.lowerOp(hlOp, dstBlock: dstBlock)
				end 'eachOp'

				if srcBlock.hasTerminatorOp() 'hasTerm'
					let termOp = try self.maxonModule.ops.get(srcBlock.terminatorIndex()) otherwise panic("invariant: terminatorIndex not in maxonModule.ops")
					self.lowerTerminator(termOp, dstBlock: dstBlock)
				end 'hasTerm'
			end 'eachBlock'
		end 'eachFunc'

		return self.stdModule
	end 'lower'

	function lowerOp(hlOp MaxonOp, dstBlock IrBlock)
		match hlOp 'lower'
			literal(result, value, litType, _) then self.lowerLiteral(result, value: value, litType: litType, dstBlock: dstBlock)
			stringConst(result, stringId, _) then self.lowerStringConst(result, stringId: stringId, dstBlock: dstBlock)
			varDecl(slotId, value, _, _) then self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: self.resolveName(value))))
			varLoad(result, slotId, slotType, _) then self.lowerVarLoad(result, slotId: slotId, slotType: slotType, dstBlock: dstBlock)
			varStore(slotId, value, _) then self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: self.resolveName(value))))
			globalLoad(result, name, slotType, _) then self.lowerGlobalLoad(result, name: name, slotType: slotType, dstBlock: dstBlock)
			globalStore(name, value, slotType, _) then self.lowerGlobalStore(name, value: value, slotType: slotType, dstBlock: dstBlock)
			binop(result, left, right, opKind, operandType, _) then self.lowerBinop(result, left: left, right: right, opKind: opKind, operandType: operandType, dstBlock: dstBlock)
			unop(result, operand, opKind, _, _) then self.lowerUnop(result, operand: operand, opKind: opKind, dstBlock: dstBlock)
			convert(result, operand, fromType, toType, _, _) then self.lowerConvert(result, operand: operand, fromType: fromType, toType: toType, dstBlock: dstBlock)
			cmp(result, left, right, predicate, _, _, operandType, _) then self.lowerCmp(result, left: left, right: right, predicate: predicate, operandType: operandType, dstBlock: dstBlock)
			refEq(result, left, right, negate, _) then self.lowerRefEq(result, left: left, right: right, negate: negate, dstBlock: dstBlock)
			condBr(cond, thenTarget, elseTarget, _) then self.stdModule.appendOp(dstBlock, op: StdOp.control(StdControlOp.condBr(self.resolveName(cond), thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
			br(target, _) then self.stdModule.appendOp(dstBlock, op: StdOp.control(StdControlOp.br(target, argIds: ValueIdArray.create())))
			call(result, callee, callContext, args, argLabels, argTypes, argRanges, _) then self.lowerCall(result, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, dstBlock: dstBlock)
			methodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, _) then self.lowerMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, dstBlock: dstBlock)
			ret(retVal, _) then self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.ret(self.resolveName(retVal))))
			printLiteral(stringId, _) then self.lowerPrintLiteral(stringId, dstBlock: dstBlock)
			printInt(value, _) then self.lowerPrintIntToCall(self.resolveName(value), dstBlock: dstBlock)
			panic(stringId, _) then self.lowerPanicToSys(stringId, dstBlock: dstBlock)
			structAlloc(result, structName, _) then self.lowerStructAlloc(result, structName: structName, dstBlock: dstBlock)
			fieldLoad(result, receiver, fieldName, _) then self.lowerFieldLoad(result, receiver: receiver, fieldName: fieldName, dstBlock: dstBlock)
			fieldStore(receiver, fieldName, value, _) then self.lowerFieldStore(receiver: receiver, fieldName: fieldName, value: value, dstBlock: dstBlock)
			selfFieldLoad(result, fieldName, _) then self.lowerSelfFieldLoad(result, fieldName: fieldName, dstBlock: dstBlock)
			selfFieldStore(fieldName, value, _) then self.lowerSelfFieldStore(fieldName: fieldName, value: value, dstBlock: dstBlock)
			// `unresolvedRead`/`unresolvedAssign` are parser-emitted placeholders
			// that the TypeResolution pass rewrites to globalLoad / globalStore /
			// constant-substitute / unknownName diagnostic before lowering runs.
			// Reaching here means the rewrite pass missed a site — pure compiler
			// bug, not a user-facing condition.
			unresolvedRead(_, name, _) then panic("lowerMaxonToStd: unresolvedRead '{name}' survived past TypeResolution")
			unresolvedAssign(name, _, _) then panic("lowerMaxonToStd: unresolvedAssign '{name}' survived past TypeResolution")
			enumMatchArm then panic("lowerMaxonToStd: enumMatchArm seen as a regular op (parser bug — should always be a terminator)")
			// Error anchor: the parser already reported a diagnostic at this span,
			// so we emit no Std op. `hasErrors(project)` will short-circuit the
			// batch compile before codegen; the LSP consumes the op directly
			// from the Maxon IR and never runs lowering.
			error then return
			// `throw` is always a block terminator; the parser must place it
			// via setTerminator. Reaching this match arm means the parser
			// emitted it as a regular op — pure compiler bug.
			throw then panic("lowerMaxonToStd: MaxonOp.throw seen as regular op (parser bug — should always be a terminator)")
			tryCall(result, callee, callContext, args, argLabels, argTypes, argRanges, errorBoundName, _) then self.lowerTryCall(result, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorBoundName, dstBlock: dstBlock)
		end 'lower'
	end 'lowerOp'

	function lowerLiteral(result ByteArray, value ParsedInt, litType MaxonType, dstBlock IrBlock)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: litType))
		var opcode = StdArithConstOpcode.constI64
		if isFloat 'asFloat'
			opcode = StdArithConstOpcode.constF64
		end 'asFloat'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(opcode, resultId: resultId, value: value))))
		self.setIsFloat(resultId, isFloat: isFloat)
	end 'lowerLiteral'

	// Lower a maxon.stringConst op. The op carries an interned StringId
	// for tracking purposes — TypeResolution's consumer-specialization
	// walk pattern-matches on `stringConst` producers to rewrite
	// downstream `printInt`/`cmp` consumers in place. The op itself
	// produces no Std-level value: the bootstrap doesn't materialize a
	// runtime String object, and any consumer that would need one is
	// expected to have been specialized by TR. Define the result name as
	// a placeholder ValueId so any downstream Std op that still
	// references it (a varLoad chain whose terminal consumer was
	// rewritten to printLiteral but whose intermediates remain) can be
	// resolved without crashing the lowering walk.
	function lowerStringConst(result ByteArray, stringId StringId, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.setValueType(resultId, t: MaxonType.string)
		// stringId/dstBlock are referenced only via the trace string so
		// the variable-must-be-used checker accepts this no-op. The op
		// emits no Std code: TR's consumer-specialization walk has
		// already rewritten every consumer (printInt/cmp/varDecl chain)
		// into a form that uses the StringId directly.
		logTrace(LogCategory.parser, message: () gives "lowerStringConst: stringId={stringId} dstBlock.id={dstBlock.id}")
	end 'lowerStringConst'

	function lowerVarLoad(result ByteArray, slotId VarSlot, slotType MaxonType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(resultId, slotId: slotId)))
		// Carry the slot's full type (named/struct, not just int-vs-float) into
		// the value-type map so downstream consumers (fieldLoad/Store, methodCall)
		// can resolve the receiver type.
		self.setValueType(resultId, t: slotType)
	end 'lowerVarLoad'

	// Lower a global load: take the .data symbol's address and dereference at
	// offset 0. Backend handles the RIP-relative encoding via the existing
	// dataSection relocation kinds keyed off the `__data_` label prefix.
	function lowerGlobalLoad(result ByteArray, name String, slotType MaxonType, dstBlock IrBlock)
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: dataSymbolName(name))))
		let resultId = self.defineName(result)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: slotType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, isFloat: isFloat)))
		self.setIsFloat(resultId, isFloat: isFloat)
	end 'lowerGlobalLoad'

	function lowerGlobalStore(name String, value ByteArray, slotType MaxonType, dstBlock IrBlock)
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: dataSymbolName(name))))
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: slotType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: 0, valueId: self.resolveName(value), isFloat: isFloat)))
	end 'lowerGlobalStore'

	// Lower a binop. If the op is float-family, ensure both operands are
	// f64-backed before emitting — int operands get a siToFpF64 convert
	// inserted. Bitwise ops are always integer.
	function lowerBinop(result ByteArray, left ByteArray, right ByteArray, opKind BinOpKind, operandType MaxonType, dstBlock IrBlock)
		var leftId = self.resolveName(left)
		var rightId = self.resolveName(right)
		let opIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: operandType)) and binOpSupportsFloat(opKind)
		if opIsFloat 'promote'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promote'
		let opcode = binOpKindToArithOpcode(self.project, opKind: opKind, operandType: operandType)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(opcode, resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: opIsFloat)
	end 'lowerBinop'

	// Integer unary ops (neg, bitNot) produce i64; lowerConvert handles any
	// subsequent widening. Float negation is normally lowered by the parser
	// as `0.0 - x` (which lands in lowerBinop), but `-x` on a named alias
	// that resolves to float (e.g. `Real`) reaches here as an integer `neg`
	// because the parser couldn't see through the alias. We detect the
	// already-float operand from the value-type map and rewrite to a float
	// subtract so targets that strictly check operand widths (wasm) accept
	// the emitted body.
	function lowerUnop(result ByteArray, operand ByteArray, opKind UnaryOpKind, dstBlock IrBlock)
		let operandId = self.resolveName(operand)
		let isFloatNeg = match opKind 'isFloatNeg'
			neg gives self.getIsFloat(operandId)
			bitNot gives false
		end 'isFloatNeg'
		if isFloatNeg 'floatNeg'
			let zeroId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constF64, resultId: zeroId, value: 0))))
			self.setIsFloat(zeroId, isFloat: true)
			let resultId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.subF64, resultId: resultId, leftId: zeroId, rightId: operandId))))
			self.setIsFloat(resultId, isFloat: true)
			return
		end 'floatNeg'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(unaryOpKindToArithOpcode(opKind), resultId: resultId, operandId: operandId))))
		self.setIsFloat(resultId, isFloat: false)
	end 'lowerUnop'

	// Lower a cmp. Same family-matching logic as binop: if the declared
	// operand type resolves to float, promote int-backed operands before
	// emitting. Result is always i64 (bool).
	function lowerCmp(result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, operandType MaxonType, dstBlock IrBlock)
		var leftId = self.resolveName(left)
		var rightId = self.resolveName(right)
		let operandIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: operandType))
		if operandIsFloat 'promote'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promote'
		let opcode = cmpPredicateToArithOpcode(self.project, predicate: predicate, operandType: operandType)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(opcode, resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: false)
	end 'lowerCmp'

	function lowerRefEq(result ByteArray, left ByteArray, right ByteArray, negate bool, dstBlock IrBlock)
		let leftId = self.resolveName(left)
		let rightId = self.resolveName(right)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(refEqOpcode(negate), resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: false)
	end 'lowerRefEq'

	// Lower a call op the parser left name-symbolic. Steps:
	//   1. Qualify the callee per CallContext.
	//   2. Look up the callee's signature, slot positional + labeled args
	//      into their declared positions, fill in integer-literal defaults.
	//   3. Emit the Std call. Record the result's MaxonType so subsequent
	//      consumers (field loads on the result, etc.) can resolve.
	function lowerCall(result ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, dstBlock IrBlock)
		let bareCallee = String.from(callee)
		// Math primitives (sqrt/floor/ceil/round/abs/trunc) inline to a single
		// Std unary op rather than going through call resolution — see
		// `lowerMathIntrinsic` for why.
		if self.lowerMathIntrinsic(result, bareCallee: bareCallee, args: args, dstBlock: dstBlock) 'didLowerMath'
			return
		end 'didLowerMath'
		let qualifiedCallee = self.qualifyCallee(bare: bareCallee, callContext: callContext)
		// One signature lookup powers both the sibling-instance probe (does
		// the resolved callee's first param name `__self`?) and the per-arg
		// type-check / default-fill in slotArgsForCall. Without this fold,
		// every call paid two redundant funcSignatures hash ops.
		let sigLookup = try self.project.funcSignatures.get(qualifiedCallee) otherwise 'noSig'
			self.emitUnsignedCall(result, qualifiedCallee: qualifiedCallee, args: args, dstBlock: dstBlock)
			return
		end 'noSig'
		let isSiblingInstance = signatureFirstParamIsSelf(sigLookup)
		var paramStart = 0
		if isSiblingInstance 'shiftStart'
			paramStart = 1
		end 'shiftStart'
		// For sibling instance calls, load __self up front so its op precedes
		// any default-fill consts emitted by slotArgsForCall, then fold its
		// id into slot 0 of the returned arg list — no second-pass copy.
		var leadingId = 0
		if isSiblingInstance 'getSelf'
			leadingId = self.loadSelfPointer(dstBlock)
		end 'getSelf'
		let finalArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: paramStart, dstBlock: dstBlock, leadingReceiverId: leadingId, hasLeadingReceiver: isSiblingInstance)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: finalArgIds, dstBlock: dstBlock)
	end 'lowerCall'

	// Method call on a value receiver. The receiver's struct type comes from
	// the per-function value-type map; we then resolve `{Type.method}` and
	// dispatch through the same slot/default fill path as a free call, with
	// the receiver prepended as the implicit __self argument.
	function lowerMethodCall(result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, dstBlock IrBlock)
		let receiverId = self.resolveName(receiver)
		let receiverType = self.getValueType(receiverId)
		let receiverStructName = maxonTypeStructName(self.project, t: receiverType)
		let qualifiedCallee = "{receiverStructName}.{String.from(methodName)}"
		// paramStartIndex: 1 because the signature counts __self at slot 0;
		// user-facing params start at index 1. slotArgsForCall folds the
		// receiver into slot 0 of the returned arg list — no second copy.
		let sigLookup = try self.project.funcSignatures.get(qualifiedCallee) otherwise 'noSig'
			let plainArgs = self.resolveArgNames(args, leadingReceiverId: receiverId, hasLeadingReceiver: true)
			self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: plainArgs, dstBlock: dstBlock)
			return
		end 'noSig'
		let allArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: 1, dstBlock: dstBlock, leadingReceiverId: receiverId, hasLeadingReceiver: true)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: allArgIds, dstBlock: dstBlock)
	end 'lowerMethodCall'

	// Emit a Std-level call op with the given pre-resolved argument ids and
	// register the result's MaxonType. Both lowerCall and lowerMethodCall
	// share this tail-end pattern; centralizing it keeps the no-signature
	// fallback and the full-slot path going through the same spot.
	function emitCallWithArgs(result ByteArray, qualifiedCallee String, argIds ValueIdArray, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: qualifiedCallee, argIds: argIds)))
		self.recordCallResultType(resultId, callee: qualifiedCallee)
	end 'emitCallWithArgs'

	// Convenience wrapper for the no-signature fallback in lowerCall: resolve
	// args verbatim (no leading receiver) and emit the call.
	function emitUnsignedCall(result ByteArray, qualifiedCallee String, args ByteArrayArray, dstBlock IrBlock)
		let argIds = self.resolveArgNames(args)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: argIds, dstBlock: dstBlock)
	end 'emitUnsignedCall'

	// Math primitives (sqrt, floor, ceil, round, abs, trunc) lower to
	// single-instruction Std unary ops. These are inlined directly into the
	// caller — no runtime wrapper, no call/ret overhead — because every
	// supported backend has native hardware for them (SQRTSD / ROUNDSD on x64,
	// FSQRT / FRINTM / FRINTP / FRINTN / FABS on ARM64, F64 unary opcodes on
	// Wasm). Going through a runtime call would dominate the cost of the work.
	// Int operands are implicitly promoted to f64; `trunc` short-circuits to
	// identity when its operand is already int (avoiding an int→f64→int round
	// trip that loses precision for ints outside f64's mantissa range).
	// Returns true if the call was lowered as an intrinsic.
	function lowerMathIntrinsic(result ByteArray, bareCallee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		let (opcode, resultType, isMath) = mathIntrinsicTarget(bare: bareCallee)
		if not isMath 'notMath'
			return false
		end 'notMath'
		// Math intrinsics take exactly one arg. If the arity is wrong, fall
		// through to normal call resolution which will surface the error.
		if args.count() != 1 'badArity'
			return false
		end 'badArity'
		let argName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let operandId = self.resolveName(argName)
		// trunc(int) is identity — alias the result to the operand directly.
		if bareCallee == "trunc" and not self.getIsFloat(operandId) 'truncOfInt'
			self.aliasName(result, toId: operandId)
			return true
		end 'truncOfInt'
		// All math intrinsics expect f64 input. Promote int operands.
		let promotedId = self.promoteToFloat(operandId, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(opcode, resultId: resultId, operandId: promotedId))))
		self.setValueType(resultId, t: resultType)
		return true
	end 'lowerMathIntrinsic'

	// Resolve a parser-emitted bare callee to its qualified name. Thin
	// wrapper over the shared `qualifyCalleeForContext` so the parser, DFE,
	// and lowering all share the same probe order. The reader path comes
	// from `currentFilePath` so cross-file fallback can filter candidates
	// by visibility against the function we're lowering.
	function qualifyCallee(bare String, callContext CallContext) returns String
		let readerPath = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
		return qualifyCalleeForContext(self.project, bare: bare, callContext: callContext, currentNamespace: self.currentNamespace, readerFilePath: readerPath)
	end 'qualifyCallee'

	// Build the Std-level argument id list for a call by:
	//   - Looking up the callee's signature (paramNames + paramTypes +
	//     paramDefaults).
	//   - Slotting each provided arg into the position named by its label
	//     (or its source order, for the leading positional arg).
	//   - Type-checking the arg's MaxonType (carried on the call op as
	//     `argTypes[i]`) against the signature's declared paramType. Same
	//     CastCategory (or compiler-recognized implicit conversion) is
	//     accepted: int↔float, int→byte, float→byte, byte→int|float emit a
	//     compile-inserted convert in `dstBlock`. Mismatches emit E3005.
	//   - Filling unfilled slots with integer-literal defaults from the
	//     signature (emitted as fresh constI64 ops, then run through the
	//     same conversion machinery so a default value of 0 lands as f64
	//     0.0 when the param is float, etc.).
	// When no signature is registered (interface calls, missing functions),
	// emits args in source order verbatim with no type-check — same fallback
	// as the previous parser-side `parseCallArgsLegacy` path.
	// `leadingReceiverId` + `hasLeadingReceiver` let method-call lowering
	// fold the receiver into slot 0 of the result without a second pass:
	// when the flag is set, the returned ValueIdArray has the receiver at
	// index 0 and the user args at indices 1..userParamCount. The slot/
	// default-fill scratch buffers stay user-arg-indexed (the receiver is
	// not a "user param") so paramStartIndex math is unchanged.
	function slotArgsForCall(signature FuncSignature, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, paramStartIndex ParsedInt, dstBlock IrBlock, leadingReceiverId ValueId = 0, hasLeadingReceiver bool = false) returns ValueIdArray
		let userParamCount = signature.paramNames.count() - paramStartIndex
		if userParamCount < 0 'badArity'
			return self.resolveArgNames(args, leadingReceiverId: leadingReceiverId, hasLeadingReceiver: hasLeadingReceiver)
		end 'badArity'
		// FP1: zero-param callee — resolveArgNames handles empty/extras the same.
		if userParamCount == 0 'noUserParams'
			return self.resolveArgNames(args, leadingReceiverId: leadingReceiverId, hasLeadingReceiver: hasLeadingReceiver)
		end 'noUserParams'
		// General path: reuse scratch buffers. resize() zero-fills new slots
		// — slot=0, filled=false — matching the old per-call init loop.
		self.slotIdsScratch.clear()
		self.slotFilledScratch.clear()
		self.slotIdsScratch.resize(userParamCount)
		self.slotFilledScratch.resize(userParamCount)
		for i in 0 upto args.count() 'placeArgs'
			let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
			let label = try argLabels.get(i) otherwise ""
			let argType = try argTypes.get(i) otherwise MaxonType.integer
			let argRange = try argRanges.get(i) otherwise SourceRange.none()
			var slot = i
			if not label.isEmpty() 'hasLabel'
				let resolved = self.resolveLabelToSlot(signature, label: label, paramStartIndex: paramStartIndex)
				if resolved < 0 'unknown'
					reportSemanticError(self.project, code: ErrorCode.semanticUndefinedVariable, message: "unknown parameter name: '{label}'")
					continue
				end 'unknown'
				slot = resolved
			end 'hasLabel'
			if slot >= userParamCount 'overflow'
				continue
			end 'overflow'
			let paramType = try signature.paramTypes.get(slot + paramStartIndex) otherwise MaxonType.integer
			let paramName = try signature.paramNames.get(slot + paramStartIndex) otherwise ""
			let coercedId = self.coerceArgToParam(argName: arg, argType: argType, paramType: paramType, paramName: paramName, range: argRange, dstBlock: dstBlock)
			try self.slotIdsScratch.set(slot, value: coercedId) otherwise panic("invariant: slotIds.set OOB")
			try self.slotFilledScratch.set(slot, value: true) otherwise panic("invariant: slotFilled.set OOB")
		end 'placeArgs'
		// Fill unfilled slots from signature defaults.
		for userIdx in 0 upto userParamCount 'fillDefaults'
			let isFilled = try self.slotFilledScratch.get(userIdx) otherwise panic("invariant: slotFilledScratch resized to userParamCount but get({userIdx}) failed")
			if isFilled 'already'
				continue
			end 'already'
			let paramIdx = userIdx + paramStartIndex
			let pd = try signature.paramDefaults.get(paramIdx) otherwise ParamDefault.none
			let defaultValue = paramDefaultAsIntLiteral(pd)
			if defaultValue.hasValue 'hasDefault'
				let constId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: constId, value: defaultValue.value))))
				self.setValueType(constId, t: MaxonType.integer)
				let paramType = try signature.paramTypes.get(paramIdx) otherwise MaxonType.integer
				let coercedId = self.coerceValueToParam(valueId: constId, fromType: MaxonType.integer, toType: paramType, dstBlock: dstBlock)
				try self.slotIdsScratch.set(userIdx, value: coercedId) otherwise panic("invariant: slotIds.set OOB")
			end 'hasDefault'
		end 'fillDefaults'
		// Materialize result. Callers retain it on the StdOp, so it must not
		// alias the scratch buffer. When hasLeadingReceiver is set, the
		// receiver occupies slot 0 and user args follow at slots 1..N — this
		// folds the method-call receiver-prepend into the same allocation.
		var result = ValueIdArray.create()
		var totalCount = userParamCount
		if hasLeadingReceiver 'reserveLead'
			totalCount = totalCount + 1
		end 'reserveLead'
		result.reserve(totalCount)
		if hasLeadingReceiver 'pushLead'
			result.push(leadingReceiverId)
		end 'pushLead'
		for i in 0 upto userParamCount 'copyOut'
			let v = try self.slotIdsScratch.get(i) otherwise panic("invariant: slotIdsScratch.get OOB at {i} (size {userParamCount})")
			result.push(v)
		end 'copyOut'
		return result
	end 'slotArgsForCall'

	// Implicitly convert an argument value to match the formal parameter
	// type. Returns the ValueId to slot into the call. Diagnostics (E3005)
	// flow through `range` so the offending argument expression is
	// highlighted, not the call site as a whole.
	//
	// Type-check-first: when argType and paramType resolve to different
	// CastCategorys AND no implicit conversion bridges them, we report
	// E3005 *before* calling resolveName. This matters because a stringConst
	// arg has no defining op — calling resolveName on its synthetic name
	// would stack a spurious E3013 ("unresolved value name") on top of the
	// real E3005 diagnostic. Reporting the type error first is also more
	// useful: it points at the actual problem.
	function coerceArgToParam(argName ByteArray, argType MaxonType, paramType MaxonType, paramName String, range SourceRange, dstBlock IrBlock) returns ValueId
		let argCategory = convertCastCategory(self.project, t: argType)
		let paramCategory = convertCastCategory(self.project, t: paramType)
		if argCategory == paramCategory 'sameCategory'
			return self.resolveName(argName)
		end 'sameCategory'
		if implicitlyConvertible(argCategory, to: paramCategory) 'canConvert'
			let argId = self.resolveName(argName)
			return self.emitImplicitConvert(argId, fromCategory: argCategory, toCategory: paramCategory, dstBlock: dstBlock)
		end 'canConvert'
		// Mismatch — surface E3005 keyed off the argument's source span.
		// Naming rule: when both endpoints are primitive numeric/bool families,
		// prefer the underlying primitive name (int/float/byte/bool) so the
		// diagnostic reads "expected 'int', got 'bool'" rather than restating
		// a typealias the caller didn't write. When either endpoint is a
		// non-primitive (string, struct, enum, …), report the source-level
		// type name so callers see exactly what they wrote.
		let expectedName = mismatchTypeName(self.project, t: paramType, ownCategory: paramCategory, otherCategory: argCategory)
		let gotName = mismatchTypeName(self.project, t: argType, ownCategory: argCategory, otherCategory: paramCategory)
		// FilePath.from rejects only truly malformed inputs (e.g. embedded
		// nuls). The lowering pass's currentFilePath comes straight from
		// BlockSourceInfo, which is either empty or a path the parser
		// already accepted — fall back to the empty FilePath sentinel
		// (matches reportCompileError sites elsewhere) on the unexpected
		// rejection rather than aborting compilation mid-diagnostic.
		let path = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
		reportCompileError(self.project, code: ErrorCode.semanticTypeMismatch, message: "argument type mismatch for '{paramName}': expected '{expectedName}', got '{gotName}'", line: range.line, column: range.column, filePath: path)
		// Return a placeholder ValueId. hasErrors(project) short-circuits
		// before codegen, so this id never reaches a backend.
		return allocValueId(self.funcIdRef)
	end 'coerceArgToParam'

	// Like coerceArgToParam but for compiler-emitted SSA values (e.g. a
	// just-emitted constI64 for a default). No diagnostic path because the
	// compiler controls both endpoints — a category mismatch here is an
	// invariant violation, not a user error.
	function coerceValueToParam(valueId ValueId, fromType MaxonType, toType MaxonType, dstBlock IrBlock) returns ValueId
		let fromCategory = convertCastCategory(self.project, t: fromType)
		let toCategory = convertCastCategory(self.project, t: toType)
		if fromCategory == toCategory 'sameCategory'
			return valueId
		end 'sameCategory'
		if implicitlyConvertible(fromCategory, to: toCategory) 'canConvert'
			return self.emitImplicitConvert(valueId, fromCategory: fromCategory, toCategory: toCategory, dstBlock: dstBlock)
		end 'canConvert'
		panic("coerceValueToParam: no implicit conversion from {castCategoryName(fromCategory)} to {castCategoryName(toCategory)} (compiler-emitted default)")
	end 'coerceValueToParam'

	// Emit the Std-level conversion ops for one of the supported implicit
	// conversions. Categorical dispatch keeps the convert kernel small —
	// caller has already validated that the (from, to) pair is admissible.
	function emitImplicitConvert(valueId ValueId, fromCategory CastCategory, toCategory CastCategory, dstBlock IrBlock) returns ValueId
		// byte → int : byte and int share the i64 representation; same-rep
		// alias, no op emitted.
		if fromCategory == CastCategory.byte and toCategory == CastCategory.int 'byteToInt'
			return valueId
		end 'byteToInt'
		// int|byte → float : both int and byte values flow as i64 internally,
		// so siToFp converts either directly.
		if (fromCategory == CastCategory.int or fromCategory == CastCategory.byte) and toCategory == CastCategory.float 'intToFloat'
			return self.emitUnaryConvert(valueId, opcode: StdArithUnaryOpcode.siToFpF64, resultType: MaxonType.float, dstBlock: dstBlock)
		end 'intToFloat'
		// float → int : fpToSi truncates toward zero.
		if fromCategory == CastCategory.float and toCategory == CastCategory.int 'floatToInt'
			return self.emitUnaryConvert(valueId, opcode: StdArithUnaryOpcode.fpToSiI64, resultType: MaxonType.integer, dstBlock: dstBlock)
		end 'floatToInt'
		// int → byte : keep low 8 bits via `and 0xFF`.
		if fromCategory == CastCategory.int and toCategory == CastCategory.byte 'intToByte'
			return self.emitByteTruncate(valueId, dstBlock: dstBlock)
		end 'intToByte'
		// float → byte : truncate to int, then mask to byte.
		if fromCategory == CastCategory.float and toCategory == CastCategory.byte 'floatToByte'
			let intId = self.emitUnaryConvert(valueId, opcode: StdArithUnaryOpcode.fpToSiI64, resultType: MaxonType.integer, dstBlock: dstBlock)
			return self.emitByteTruncate(intId, dstBlock: dstBlock)
		end 'floatToByte'
		panic("emitImplicitConvert: unhandled pair ({castCategoryName(fromCategory)} -> {castCategoryName(toCategory)})")
	end 'emitImplicitConvert'

	// Emit a single Std arith-unary conversion op (siToFp / fpToSi / etc.),
	// register the result's MaxonType in the value-type map, and return the
	// new SSA id. Centralizes the three-line pattern used by every implicit
	// convert path.
	function emitUnaryConvert(valueId ValueId, opcode StdArithUnaryOpcode, resultType MaxonType, dstBlock IrBlock) returns ValueId
		let convId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(opcode, resultId: convId, operandId: valueId))))
		self.setValueType(convId, t: resultType)
		return convId
	end 'emitUnaryConvert'

	// Truncate an i64-resident value to its low 8 bits via `and 0xFF`.
	// Used for both int→byte and float→byte (after the float→int step).
	function emitByteTruncate(valueId ValueId, dstBlock IrBlock) returns ValueId
		let maskId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: maskId, value: 255))))
		self.setValueType(maskId, t: MaxonType.integer)
		let truncId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.andI64, resultId: truncId, leftId: valueId, rightId: maskId))))
		self.setValueType(truncId, t: MaxonType.integer)
		return truncId
	end 'emitByteTruncate'

	// Resolve a `name:` label to its slot index in the user-facing portion of
	// the signature via the precomputed nameToIndex map. Returns -1 when
	// unknown (or when the label resolves to a hidden prefix slot like
	// `__self`) so callers can skip the bad arg without halting the rest of
	// the slotting work.
	function resolveLabelToSlot(signature FuncSignature, label String, paramStartIndex ParsedInt) returns ParsedInt
		// nameToIndex is sparse; -1 is the documented sentinel for unknown labels (caller surfaces E3xxx).
		let absIdx = try signature.nameToIndex.get(label) otherwise return -1
		if absIdx < paramStartIndex 'beforeUserSpace'
			return -1
		end 'beforeUserSpace'
		return absIdx - paramStartIndex
	end 'resolveLabelToSlot'

	// Record the declared return type of a resolved call into the value-type
	// map so subsequent ops that consume the call's result (field loads,
	// method calls on it, mixed-family arithmetic, etc.) can resolve.
	function recordCallResultType(resultId ValueId, callee String)
		let returnType = try self.project.funcReturnTypes.get(callee) otherwise MaxonReturnType.void
		let resultType = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		self.setValueType(resultId, t: resultType)
	end 'recordCallResultType'

	// fieldLoad: read receiver's struct type from the value-type map, find
	// the named field's offset, emit the indirect load. Records the field's
	// declared type so chained field accesses keep resolving.
	function lowerFieldLoad(result ByteArray, receiver ByteArray, fieldName ByteArray, dstBlock IrBlock)
		let receiverId = self.resolveName(receiver)
		let receiverType = self.getValueType(receiverId)
		let resultId = self.defineName(result)
		let fieldNameStr = String.from(fieldName)
		let (offset, fieldType, found) = self.lookupFieldByReceiver(receiverType: receiverType, fieldName: fieldNameStr)
		if not found 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown field '{fieldNameStr}' on type '{receiverType.toString(self.project)}'")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notFound'
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fieldType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: receiverId, offset: offset, isFloat: isFloat)))
		self.setValueType(resultId, t: fieldType)
	end 'lowerFieldLoad'

	function lowerFieldStore(receiver ByteArray, fieldName ByteArray, value ByteArray, dstBlock IrBlock)
		let receiverId = self.resolveName(receiver)
		let receiverType = self.getValueType(receiverId)
		let fieldNameStr = String.from(fieldName)
		let (offset, fieldType, found) = self.lookupFieldByReceiver(receiverType: receiverType, fieldName: fieldNameStr)
		if not found 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown field '{fieldNameStr}' on type '{receiverType.toString(self.project)}'")
			return
		end 'notFound'
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fieldType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(receiverId, offset: offset, valueId: self.resolveName(value), isFloat: isFloat)))
	end 'lowerFieldStore'

	// selfFieldLoad/selfFieldStore: synthesize a fieldLoad/Store against the
	// __self parameter. The struct type comes from `currentTypeName` which we
	// recovered from func.name at function entry. We materialize __self via
	// a `loadSlot` op (slot 0 by Std-ABI convention) so the register
	// allocator sees a normal SSA value-def rather than a bare param-id.
	function lowerSelfFieldLoad(result ByteArray, fieldName ByteArray, dstBlock IrBlock)
		let resultId = self.defineName(result)
		if self.currentTypeName.isEmpty() 'notInType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: selfFieldLoad in free function (parser bug)")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notInType'
		let fieldNameStr = String.from(fieldName)
		let (offset, fieldType, found) = self.lookupFieldByStructName(structName: self.currentTypeName, fieldName: fieldNameStr)
		if not found 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown self-field '{fieldNameStr}' on type '{self.currentTypeName}'")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notFound'
		let selfId = self.loadSelfPointer(dstBlock)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fieldType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: selfId, offset: offset, isFloat: isFloat)))
		self.setValueType(resultId, t: fieldType)
	end 'lowerSelfFieldLoad'

	function lowerSelfFieldStore(fieldName ByteArray, value ByteArray, dstBlock IrBlock)
		if self.currentTypeName.isEmpty() 'notInType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: selfFieldStore in free function (parser bug)")
			return
		end 'notInType'
		let fieldNameStr = String.from(fieldName)
		let (offset, fieldType, found) = self.lookupFieldByStructName(structName: self.currentTypeName, fieldName: fieldNameStr)
		if not found 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown self-field '{fieldNameStr}' on type '{self.currentTypeName}'")
			return
		end 'notFound'
		let selfId = self.loadSelfPointer(dstBlock)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fieldType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(selfId, offset: offset, valueId: self.resolveName(value), isFloat: isFloat)))
	end 'lowerSelfFieldStore'

	// Materialize the __self parameter into a fresh SSA ValueId via a slot
	// load. Used by selfFieldLoad/selfFieldStore — the parser-side
	// declaration `__self` lives in slot 0 of every instance method by Std
	// ABI convention (`__self` is always the first parameter). We can't pass
	// the bare param id (0) into addr operands because subsequent passes
	// (register allocator) only see SSA-style use-def chains and panic on
	// references to undefined virtual values.
	function loadSelfPointer(dstBlock IrBlock) returns ValueId
		let selfId = allocValueId(self.funcIdRef)
		let selfSlot = 0 as VarSlot
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(selfId, slotId: selfSlot)))
		self.setValueType(selfId, t: MaxonType.named(self.project.typeNames.intern(self.currentTypeName)))
		return selfId
	end 'loadSelfPointer'

	// Resolve (receiver-MaxonType, fieldName) → (offset, fieldType, found) by
	// walking the project's struct-type registry. A receiver whose type is
	// not a registered struct (or whose named() id resolves to something
	// non-struct) yields (0, integer, false) so callers can emit a clean
	// diagnostic.
	function lookupFieldByReceiver(receiverType MaxonType, fieldName String) returns (FieldOffset, MaxonType, bool)
		let structName = maxonTypeStructName(self.project, t: receiverType)
		if structName.isEmpty() 'noStruct'
			return (0 as FieldOffset, MaxonType.integer, false)
		end 'noStruct'
		return self.lookupFieldByStructName(structName: structName, fieldName: fieldName)
	end 'lookupFieldByReceiver'

	function lookupFieldByStructName(structName String, fieldName String) returns (FieldOffset, MaxonType, bool)
		// structTypes / fieldByName are sparse; the third tuple element (false) is the documented "not found" flag.
		// Callers check the bool and report an E-code on miss.
		let structType = try self.project.structTypes.get(structName) otherwise return (0 as FieldOffset, MaxonType.integer, false)
		let fieldIdx = try structType.fieldByName.get(fieldName) otherwise return (0 as FieldOffset, MaxonType.integer, false)
		let field = try structType.fields.get(fieldIdx) otherwise panic("StructType.fieldByName references missing field index {fieldIdx} on '{structName}' (count={structType.fields.count()})")
		return (field.offset, field.fieldType, true)
	end 'lookupFieldByStructName'

	// The parser only ever produces condBr/br/ret/enumMatchArm as block
	// terminators (plus `error` as a no-op anchor). Anything else appearing
	// here indicates a parser bug.
	function lowerTerminator(hlOp MaxonOp, dstBlock IrBlock)
		match hlOp 'lower'
			condBr(cond, thenTarget, elseTarget, _) then self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(self.resolveName(cond), thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
			br(target, _) then self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.br(target, argIds: ValueIdArray.create())))
			ret(retVal, _) then self.stdModule.setTerminator(dstBlock, op: StdOp.call(StdCallOp.ret(self.resolveName(retVal))))
			enumMatchArm(scrutineeName, caseName, _, rawValue, isFloat, resolved, thenTarget, elseTarget, _) then self.lowerEnumMatchArm(scrutineeName, caseName: caseName, rawValue: rawValue, isFloat: isFloat, resolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock)
			// An error op as a block terminator shouldn't come from the parser —
			// errors replace single statements, not block-terminating constructs.
			// If it ever does we drop it: a diagnostic was already reported at
			// the error op's range.
			error then return
			// Phase 4: `throw E.v` — write `ordinal+1` (0 reserved for "no
			// error in flight") into the thread-local error slot via
			// mrt_set_error, then return a default primary value of the
			// enclosing function's return type. Caller's `try` will read
			// (and clear) the slot via mrt_get_error_and_clear.
			throw(enumName, variantName, _) then self.lowerThrow(enumName: enumName, variantName: variantName, dstBlock: dstBlock)
			default panic("lowerMaxonTerminatorToStd: non-terminator op kind '{hlOp.name}' as terminator of block '{dstBlock.label}' (parser bug)")
		end 'lower'
	end 'lowerTerminator'

	// Lower a resolved `enumMatchArm` terminator to the equivalent
	// `const + cmp_eq + cond_br` Std op sequence. The const + cmp pair go
	// into the dstBlock as regular ops; the cond_br is set as the
	// terminator. TypeResolution must have resolved the case name before
	// lowering — an unresolved op is a TR bug.
	function lowerEnumMatchArm(scrutineeName ByteArray, caseName String, rawValue IntConstant, isFloat bool, resolved bool, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock)
		if not resolved 'unresolved'
			panic("lowerMaxonToStd: enumMatchArm '.{caseName}' survived past TypeResolution unresolved")
		end 'unresolved'
		var caseLiteralType = MaxonType.integer
		var constOpcode = StdArithConstOpcode.constI64
		if isFloat 'asFloat'
			caseLiteralType = MaxonType.float
			constOpcode = StdArithConstOpcode.constF64
		end 'asFloat'
		let caseLitId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(constOpcode, resultId: caseLitId, value: rawValue))))
		self.setIsFloat(caseLitId, isFloat: isFloat)
		var leftId = self.resolveName(scrutineeName)
		var rightId = caseLitId
		if isFloat 'promoteForFloatCmp'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promoteForFloatCmp'
		let cmpOpcode = cmpPredicateToArithOpcode(self.project, predicate: CmpPredicate.eq, operandType: caseLiteralType)
		let cmpId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(cmpOpcode, resultId: cmpId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(cmpId, isFloat: false)
		self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
	end 'lowerEnumMatchArm'

	// Allocates a heap struct by calling mrt_alloc with the byte size.
	// `structName` is the source-level type name; we look up the struct
	// type in the project's registry, emit a fresh constI64 for the byte
	// size, then call mrt_alloc. The result's MaxonType is recorded so
	// downstream field/method ops on it can resolve.
	function lowerStructAlloc(result ByteArray, structName ByteArray, dstBlock IrBlock)
		let structNameStr = String.from(structName)
		var byteSize = 0
		let structType = try self.project.structTypes.get(structNameStr) otherwise 'unknownType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown struct type '{structNameStr}' in structAlloc")
			byteSize = 0
			let placeholderResultId = self.defineName(result)
			self.setValueType(placeholderResultId, t: MaxonType.integer)
			return
		end 'unknownType'
		byteSize = structType.byteSize
		let sizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: sizeId, value: byteSize))))
		self.setValueType(sizeId, t: MaxonType.integer)
		var argIds = ValueIdArray.create()
		argIds.push(sizeId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern(structNameStr)))
	end 'lowerStructAlloc'

	// Lower printLiteral(stringId) to:
	//   globalAddr(addrId, "__istr_N")
	//   constI64(lenId, len)
	//   call(_, "mrt_write_stdout", [addrId, lenId])
	// The StringId is resolved against `project.strings` to recover the
	// raw bytes; the interner is the dedup key, so the rdata symbol name
	// is derived directly from the id (`__istr_<stringId>`) via
	// `addInternedString` rather than re-hashing the byte payload.
	function lowerPrintLiteral(stringId StringId, dstBlock IrBlock)
		let data = self.project.strings.get(stringId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()
		if dataLen == 0 'empty'
			return
		end 'empty'

		// Register data in global table (id-keyed dedup, no byte hash)
		let name = addInternedString(self.globalData, stringId: stringId, data: dataBytes)

		// globalAddr -> addrId
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: name)))

		// constI64 -> lenId
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: lenId, value: dataLen))))

		// call mrt_write_stdout(addrId, lenId)
		let callResultId = allocValueId(self.funcIdRef)
		var argIds = ValueIdArray.create()
		argIds.push(addrId)
		argIds.push(lenId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(callResultId, callee: "mrt_write_stdout", argIds: argIds)))
	end 'lowerPrintLiteral'

	// Lower printInt(valueId) to:
	//   call(mrt_printInt, [valueId])
	function lowerPrintIntToCall(valueId ValueId, dstBlock IrBlock)
		let callResultId = allocValueId(self.funcIdRef)
		var argIds = ValueIdArray.create()
		argIds.push(valueId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(callResultId, callee: "mrt_printInt", argIds: argIds)))
	end 'lowerPrintIntToCall'

	// Lower maxon.panic(message) to:
	//   std.system.globalAddr(addrId, "__panic_msg_N")
	//   std.call.call mrt_panic(addrId)
	//
	// The label name comes from `pipeline.nextPanicLabel()`, a monotonic
	// counter shared across every pass in this pipeline run that emits a
	// panic call (today: this pass and `insertRangeChecks`). A single
	// counter means every panic in a compile gets a unique label without
	// per-pass prefix gymnastics. The prefix (`__panic_msg_` vs
	// `__stdlib_panic_msg_`) is still picked from `pipeline.isStdlib` so
	// stdlib and user-code compiles stay in disjoint link-time namespaces.
	// Phase 4: lower MaxonOp.throw(enumName, variantName) to:
	//   const flag = ordinal_of(enumName, variantName) + 1
	//   call mrt_set_error(flag)
	//   ret <default value of enclosing function's return type>
	//
	// The +1 reserves 0 for "no error in flight" so the caller's
	// `mrt_get_error_and_clear` can distinguish a successful call from a
	// thrown variant. The default return value is just an in-range constant
	// of the right family (i64 zero for ints, f64 zero for floats, none for
	// void) — the caller's `try ... otherwise` branch ignores the primary
	// value when the flag is non-zero, so any default works. Emitted as a
	// terminator: the producing block ends here with a `ret`.
	function lowerThrow(enumName String, variantName String, dstBlock IrBlock)
		let flag = self.lookupVariantOrdinalPlusOne(enumName: enumName, variantName: variantName)
		// const flag
		let flagId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: flagId, value: flag))))
		self.setIsFloat(flagId, isFloat: false)
		// call mrt_set_error(flag) — discards the i64 0 result.
		let setErrResultId = allocValueId(self.funcIdRef)
		var setErrArgs = ValueIdArray.create()
		setErrArgs.push(flagId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(setErrResultId, callee: "mrt_set_error", argIds: setErrArgs)))
		// Terminate the block with `ret <default>` of the enclosing return type.
		let isFloat = maxonReturnTypeLowersToFloat(self.project, ref: self.currentReturnType)
		let opcode = StdArithConstOpcode.constF64 if isFloat else StdArithConstOpcode.constI64
		let zeroId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(opcode, resultId: zeroId, value: 0))))
		self.setIsFloat(zeroId, isFloat: isFloat)
		self.stdModule.setTerminator(dstBlock, op: StdOp.call(StdCallOp.ret(zeroId)))
	end 'lowerThrow'

	// Resolve `EnumName.variantName` to its declaration ordinal, then add 1.
	// `+1` keeps 0 reserved for "no error in flight" — the thread-local error
	// slot is read-then-cleared by `mrt_get_error_and_clear`, so a successful
	// call leaves it at 0 for the next caller. A miss (unknown enum, unknown
	// case) reports a compile-error diagnostic and falls back to ordinal `1`
	// so the lowering pass produces a structurally valid SSA module — the
	// `hasErrors(project)` short-circuit before codegen prevents the bogus
	// flag from reaching a real binary.
	function lookupVariantOrdinalPlusOne(enumName String, variantName String) returns IntConstant
		// The parser registers every enum into `unresolvedEnums` first;
		// TypeResolution drains it into `enumTypes`. Either map is acceptable
		// here because the case ordinals are stable across that move.
		if let resolved = try self.project.enumTypes.get(enumName) 'resolvedHit'
			if let ord = try resolved.caseByName.get(variantName) 'caseHit'
				return (ord as IntConstant) + 1
			end 'caseHit'
		end 'resolvedHit'
		if let unresolved = try self.project.unresolvedEnums.get(enumName) 'unresolvedHit'
			for i in 0 upto unresolved.cases.count() 'scan'
				let kase = try unresolved.cases.get(i) otherwise panic("lookupVariantOrdinalPlusOne: cases.get OOB")
				if kase.name == variantName 'match'
					return (i as IntConstant) + 1
				end 'match'
			end 'scan'
		end 'unresolvedHit'
		self.reportLowerError(ErrorCode.semanticEnumUnknownCase, message: "lowerMaxonToStd: throw of unknown variant '{enumName}.{variantName}'")
		return 1
	end 'lookupVariantOrdinalPlusOne'

	// Phase 4: lower MaxonOp.tryCall — same shape as a normal call followed
	// by a read-and-clear of the thread-local error slot. The flag bound to
	// `errorBoundName` is consumed by parser-emitted ops downstream (typically
	// a cmp + condBr that either propagates via mrt_set_error or falls
	// through to a fallback expression).
	function lowerTryCall(result ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, dstBlock IrBlock)
		// Reuse the exact call lowering — same signature/default-fill path.
		self.lowerCall(result, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, dstBlock: dstBlock)
		// Bind the post-call error flag to the parser-supplied name.
		let flagId = self.defineName(errorBoundName)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(flagId, callee: "mrt_get_error_and_clear", argIds: ValueIdArray.create())))
		self.setValueType(flagId, t: MaxonType.integer)
	end 'lowerTryCall'

	function lowerPanicToSys(stringId StringId, dstBlock IrBlock)
		let nameStr = self.pipeline.nextPanicLabel()

		// Build null-terminated message for global data
		let message = self.project.strings.get(stringId)
		var nullTermMsg = message.toByteArray()
		nullTermMsg.push(0x0A)  // newline
		nullTermMsg.push(0)  // null terminator

		addNamedGlobalData(self.globalData, name: nameStr, data: nullTermMsg)

		// globalAddr -> addrId
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: nameStr)))

		// call mrt_panic(addrId)
		let callResultId = allocValueId(self.funcIdRef)
		var argIds = ValueIdArray.create()
		argIds.push(addrId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(callResultId, callee: "mrt_panic", argIds: argIds)))
	end 'lowerPanicToSys'

	// Lower maxon.convert.
	//
	// All same-family conversions (int-to-int, float-to-float) are pure value
	// aliases at the Std level — SSA values flow through 64-bit registers
	// regardless of the source-level type's declared width, and the only
	// place width matters is at memory loads/stores (handled by the load
	// op opcode, not the value flow) and at function return range checks
	// (handled by insertRangeChecks). We record `result -> operand` in the
	// name map so subsequent uses of the converted name resolve to the same
	// underlying ValueId. Cross-family conversions genuinely change the
	// representation and emit fpToSiI64 / siToFpF64.
	function lowerConvert(result ByteArray, operand ByteArray, fromType MaxonType, toType MaxonType, dstBlock IrBlock)
		let operandId = self.resolveName(operand)
		let fromIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fromType))
		let toIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: toType))
		if fromIsFloat == toIsFloat 'sameFamily'
			self.aliasName(result, toId: operandId)
			return
		end 'sameFamily'
		let resultId = self.defineName(result)
		if fromIsFloat and not toIsFloat 'floatToInt'
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.fpToSiI64, resultId: resultId, operandId: operandId))))
			self.setIsFloat(resultId, isFloat: false)
			return
		end 'floatToInt'
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.siToFpF64, resultId: resultId, operandId: operandId))))
		self.setIsFloat(resultId, isFloat: true)
	end 'lowerConvert'
end 'MaxonToStdLowering'

// Maps a bare math-primitive name to the Std unary opcode that implements it
// and the MaxonType of its result. Returns isMath=false for non-intrinsic
// names so the caller can fall through to normal call resolution.
// The opcode chain is single-instruction on every native backend (SQRTSD /
// ROUNDSD / FSQRT / FRINT* / FABS), so emitting the StdArithUnaryOp directly
// rather than calling a runtime wrapper avoids an unnecessary call/ret round
// trip for what amounts to a one-instruction operation.
// Used by both TypeResolution (to set the call's result MaxonType) and
// LowerMaxonToStd (to emit the inline op).
export function mathIntrinsicTarget(bare String) returns (StdArithUnaryOpcode, MaxonType, bool)
	if bare == "sqrt" 'isSqrt'
		return (StdArithUnaryOpcode.sqrtF64, MaxonType.float, true)
	end 'isSqrt'
	if bare == "floor" 'isFloor'
		return (StdArithUnaryOpcode.floorF64, MaxonType.float, true)
	end 'isFloor'
	if bare == "ceil" 'isCeil'
		return (StdArithUnaryOpcode.ceilF64, MaxonType.float, true)
	end 'isCeil'
	if bare == "round" 'isRound'
		return (StdArithUnaryOpcode.roundF64, MaxonType.float, true)
	end 'isRound'
	if bare == "abs" 'isAbs'
		return (StdArithUnaryOpcode.absF64, MaxonType.float, true)
	end 'isAbs'
	if bare == "trunc" 'isTrunc'
		return (StdArithUnaryOpcode.fpToSiI64, MaxonType.integer, true)
	end 'isTrunc'
	return (StdArithUnaryOpcode.sqrtF64, MaxonType.unresolved, false)
end 'mathIntrinsicTarget'

// True when `signature`'s first formal parameter is the implicit `__self`
// — i.e. the callee is an instance method. Lifted out of the per-call
// signature lookup so callers that already have a FuncSignature in hand
// don't trigger another funcSignatures hash op.
export function signatureFirstParamIsSelf(signature FuncSignature) returns bool
	if signature.paramNames.count() == 0 'noParams'
		return false
	end 'noParams'
	let firstParam = try signature.paramNames.get(0) otherwise panic("invariant: paramNames.count() > 0 just checked but get(0) failed")
	return firstParam == "__self"
end 'signatureFirstParamIsSelf'

// Recover the source file path of `func` by reading its entry block's
// BlockSourceInfo entry. Returns an empty string when the entry block was
// created outside the parser (no path attached). Used by lowering's call-
// site type checker to anchor diagnostics on the user's source file, and
// by TypeResolution's per-function unresolvedRead/Assign rewriter to
// anchor visibility lookups against the reading function's file.
export function entryBlockFilePath(module MaxonModule, func IrFunction) returns String
	if func.blockRefs.count() == 0 'noBlocks'
		return ""
	end 'noBlocks'
	let entryRef = try func.blockRefs.get(0) otherwise panic("invariant: blockRefs.count() > 0 just checked but get(0) failed")
	// blockSourceInfo is pushed in lock-step with module.blocks, so any blockRef into module.blocks is also valid here.
	let info = try module.blockSourceInfo.get(entryRef) otherwise panic("invariant: blockSourceInfo 1:1 with module.blocks but get({entryRef}) failed")
	return info.filePath
end 'entryBlockFilePath'

// Pick the diagnostic-friendly name for a MaxonType in an E3005 error.
// When both endpoints of a mismatch live in the primitive numeric/bool
// families, the underlying primitive name (int/float/byte/bool) reads
// better than the user's typealias — the caller wrote `Integer` but the
// mismatch is structural at the int family level. When either endpoint
// is non-primitive (string, struct, enum, …), prefer the source-level
// name so the diagnostic mentions what the user actually wrote.
function mismatchTypeName(project Project, t MaxonType, ownCategory CastCategory, otherCategory CastCategory) returns String
	if isPrimitiveCategory(ownCategory) and isPrimitiveCategory(otherCategory) 'bothPrimitive'
		return castCategoryName(ownCategory)
	end 'bothPrimitive'
	return t.toString(project)
end 'mismatchTypeName'

// "Primitive" here means the numeric/bool families that share an i64/i1/f64
// representation at the Std level. String is intentionally NOT primitive —
// when one endpoint is a string we want the diagnostic to use the
// source-level name ("String") rather than collapsing into a category.
function isPrimitiveCategory(c CastCategory) returns bool
	return c == CastCategory.int or c == CastCategory.float or c == CastCategory.byte or c == CastCategory.bool
end 'isPrimitiveCategory'

// Categorical predicate: does `from` admit an implicit conversion to `to`
// at a call site? Mirrors the C# bootstrap's
// `ConvertArgToParamType` table — the only conversions the language permits
// at a call boundary today.
//
//   int   ↔ float : siToFp / fpToSi
//   int   → byte  : truncate to low 8 bits (and 0xFF)
//   float → byte  : fpToSi, then truncate to byte
//   byte  → int   : same i64 representation, no op emitted
//   byte  → float : siToFp on the i64-resident byte
//
// All other pairs (anything involving bool or string) reject — caller emits
// E3005. Same-category pairs short-circuit before calling this predicate.
export function implicitlyConvertible(from CastCategory, to CastCategory) returns bool
	if from == CastCategory.int and to == CastCategory.float 'intToFloat'
		return true
	end 'intToFloat'
	if from == CastCategory.float and to == CastCategory.int 'floatToInt'
		return true
	end 'floatToInt'
	if from == CastCategory.int and to == CastCategory.byte 'intToByte'
		return true
	end 'intToByte'
	if from == CastCategory.float and to == CastCategory.byte 'floatToByte'
		return true
	end 'floatToByte'
	if from == CastCategory.byte and to == CastCategory.int 'byteToInt'
		return true
	end 'byteToInt'
	if from == CastCategory.byte and to == CastCategory.float 'byteToFloat'
		return true
	end 'byteToFloat'
	return false
end 'implicitlyConvertible'

// Recover the enclosing struct-type name from a parser-qualified function
// name. The parser qualifies methods as `Type.method` (with no module
// namespace prefix — the parser uses `currentTypeName` directly as the
// qualifier in `parseFunction`). We split on the LAST dot and probe
// `project.structTypes`: a registered struct prefix denotes a method body;
// anything else (including bare names like `main`) denotes a free function.
function enclosingTypeName(project Project, name String) returns String
	let bytes = name.toByteArray()
	let dotByte = 0x2E as byte
	var lastDot = -1
	var i = bytes.count() - 1
	while i >= 0 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i in [0, bytes.count()) but get failed")
		if b == dotByte 'hit'
			lastDot = i
			break
		end 'hit'
		i = i - 1
	end 'scan'
	if lastDot < 0 'noDot'
		return ""
	end 'noDot'
	let prefixBytes = try bytes.slice(0, endIndex: lastDot) otherwise panic("invariant: 0 <= lastDot <= bytes.count() but slice failed")
	let prefix = String.from(prefixBytes)
	if project.structTypes.contains(prefix) 'isType'
		return prefix
	end 'isType'
	return ""
end 'enclosingTypeName'

// --- NameToValueIdMap ------------------------------------------------------
//
// Per-function map from a Maxon-IR value name (a `ByteArray` slice — either
// over the lexer's source buffer for user-written variables, or a synthetic
// `$tN` name for intermediates) to the dense Std-level ValueId that the
// Maxon→Std lowering has assigned it.
//
// Implementation: a real hash Map keyed on `ByteArray`. ByteArray is
// `Array<Byte>` and `Array` conditionally implements Hashable+Equatable
// when its element does, which Byte does — so we get O(1) get/put without
// any custom hashing. Hot-path callers (`resolveName` / `defineName` /
// `aliasName`) hit this map on every Maxon op being lowered, so any
// per-element scan would compound across thousands of ops per function.

export typealias NameToValueIdMap = Map with(ByteArray, ValueId)

// Byte-sequence equality. `ByteArray` is `Array with Byte`, and `Array`
// does not today expose a generic `==` over slices — this little helper
// is all we need for the per-function map hot path.
export function byteArraysEqual(a ByteArray, b ByteArray) returns bool
	if a.count() != b.count() 'len'
		return false
	end 'len'
	for i in 0 upto a.count() 'each'
		let x = try a.get(i) otherwise panic("invariant: i < a.count() but get failed")
		let y = try b.get(i) otherwise panic("invariant: i < a.count() == b.count() but get failed")
		if x != y 'ne'
			return false
		end 'ne'
	end 'each'
	return true
end 'byteArraysEqual'

// ============================================================
// Helper functions
// ============================================================

function literalToArithOpcode(project Project, valueType MaxonType) returns StdArithConstOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: valueType)) 'f'
		return StdArithConstOpcode.constF64
	end 'f'
	return StdArithConstOpcode.constI64
end 'literalToArithOpcode'

function binOpKindToArithOpcode(project Project, opKind BinOpKind, operandType MaxonType) returns StdArithBinaryOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: operandType)) 'floatOp'
		return floatBinOpKindToArithOpcode(opKind)
	end 'floatOp'
	return match opKind 'map'
		add gives StdArithBinaryOpcode.addI64
		sub gives StdArithBinaryOpcode.subI64
		mul gives StdArithBinaryOpcode.mulI64
		div gives StdArithBinaryOpcode.divI64
		mod gives StdArithBinaryOpcode.remI64
		bitAnd gives StdArithBinaryOpcode.andI64
		bitOr gives StdArithBinaryOpcode.orI64
		boolOr gives StdArithBinaryOpcode.orI1
		bitXor gives StdArithBinaryOpcode.xorI64
		shl gives StdArithBinaryOpcode.shlI64
		shr gives StdArithBinaryOpcode.shrI64
	end 'map'
end 'binOpKindToArithOpcode'

function floatBinOpKindToArithOpcode(opKind BinOpKind) returns StdArithBinaryOpcode
	match opKind 'dispatch'
		add then return StdArithBinaryOpcode.addF64
		sub then return StdArithBinaryOpcode.subF64
		mul then return StdArithBinaryOpcode.mulF64
		div then return StdArithBinaryOpcode.divF64
		mod to shr then panic("floatBinOpKindToArithOpcode: bitwise/mod ops not supported on floats")
	end 'dispatch'
end 'floatBinOpKindToArithOpcode'

// True when the opcode has a float-family variant. Bitwise / mod ops are
// integer-only, so even if the declared operandType resolves to float the
// op must stay on int operands (and the parser already guarantees that by
// forcing operandType to integer for these ops).
function binOpSupportsFloat(opKind BinOpKind) returns bool
	return match opKind 'check'
		add gives true
		sub gives true
		mul gives true
		div gives true
		mod gives false
		bitAnd gives false
		bitOr gives false
		boolOr gives false
		bitXor gives false
		shl gives false
		shr gives false
	end 'check'
end 'binOpSupportsFloat'

function unaryOpKindToArithOpcode(opKind UnaryOpKind) returns StdArithUnaryOpcode
	return match opKind 'map'
		neg gives StdArithUnaryOpcode.negI64
		bitNot gives StdArithUnaryOpcode.bitNotI64
	end 'map'
end 'unaryOpKindToArithOpcode'

function cmpPredicateToArithOpcode(project Project, predicate CmpPredicate, operandType MaxonType) returns StdArithBinaryOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: operandType)) 'f'
		return match predicate 'floatOp'
			eq gives StdArithBinaryOpcode.cmpF64Eq
			ne gives StdArithBinaryOpcode.cmpF64Ne
			lt gives StdArithBinaryOpcode.cmpF64Lt
			le gives StdArithBinaryOpcode.cmpF64Le
			gt gives StdArithBinaryOpcode.cmpF64Gt
			ge gives StdArithBinaryOpcode.cmpF64Ge
		end 'floatOp'
	end 'f'
	return match predicate 'intOp'
		eq gives StdArithBinaryOpcode.cmpI64Eq
		ne gives StdArithBinaryOpcode.cmpI64Ne
		lt gives StdArithBinaryOpcode.cmpI64Lt
		le gives StdArithBinaryOpcode.cmpI64Le
		gt gives StdArithBinaryOpcode.cmpI64Gt
		ge gives StdArithBinaryOpcode.cmpI64Ge
	end 'intOp'
end 'cmpPredicateToArithOpcode'

function refEqOpcode(negate bool) returns StdArithBinaryOpcode
	if negate 'ne'
		return StdArithBinaryOpcode.cmpI64Ne
	end 'ne'
	return StdArithBinaryOpcode.cmpI64Eq
end 'refEqOpcode'

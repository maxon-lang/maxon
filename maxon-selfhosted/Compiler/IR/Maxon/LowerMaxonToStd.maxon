function registerManagedFileMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	registerManagedBuiltinMethod(project, receiverName: "__ManagedFile", methodName: methodName, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType)

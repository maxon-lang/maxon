// Phase C: register the `__ManagedList` builtin struct, the `__ManagedListError`
// enum, and the `__ManagedList.*` method signatures so user Maxon code in
// `stdlib/List.maxon` parses and type-resolves. Bodies are absent — the
// shared `lowerManagedHandleBuiltin` dispatch intercepts these calls and
// routes to `mrt_managed_list_*` runtime helpers.
//
// Field layout matches the C# bootstrap (maxon-sharp Compiler/2-Parser.cs:1049-1058):
//   offset  0  head    i64 (first __ManagedListNode pointer, or null)
//   offset  8  tail    i64 (last __ManagedListNode pointer, or null)
//   offset 16  count   i64 (number of nodes)
//   offset 24  cursor  i64 (current iteration cursor, or null)
// Total byteSize = 32.
//
// Enum case ordinals mirror Builtins.maxon (`empty`, `endOfList`,
// `nodeNotInList`, `nodeAlreadyInList`) so the runtime helpers' error-flag
// ordinals match the user-visible enum cases at runtime.
export function registerManagedListType(project Project)
	registerManagedListStruct(project)
	registerManagedListErrorEnum(project)
	registerManagedListMethods(project)
end 'registerManagedListType'

function registerManagedListStruct(project Project)
	if project.structTypes.contains("__ManagedList") 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	fields.push(StructField.create("head", fieldType: MaxonType.integer, offset: 0, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("tail", fieldType: MaxonType.integer, offset: 8, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("count", fieldType: MaxonType.integer, offset: 16, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("cursor", fieldType: MaxonType.integer, offset: 24, isMutable: true, offsetResolved: true))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedListStruct: stdlib bootstrap path rejected")
	let st = StructType.create("__ManagedList", fields: fields, byteSize: 32, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert("__ManagedList", value: st) otherwise ignore
	_ = project.typeNames.intern("__ManagedList")
end 'registerManagedListStruct'

function registerManagedListErrorEnum(project Project)
	var names = StringArray.create()
	names.push("empty")
	names.push("endOfList")
	names.push("nodeNotInList")
	names.push("nodeAlreadyInList")
	registerManagedErrorEnum(project, typeName: "__ManagedListError", caseNames: names)
end 'registerManagedListErrorEnum'

function registerManagedListMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	registerManagedBuiltinMethod(project, receiverName: "__ManagedList", methodName: methodName, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType)
end 'registerManagedListMethod'

function registerManagedListMethods(project Project)
	let mlType = MaxonType.named(project.typeNames.intern("__ManagedList"))
	let mlnType = MaxonType.named(project.typeNames.intern("__ManagedListNode"))
	let intType = MaxonType.integer
	let boolType = MaxonType.boolean
	let intReturn = MaxonReturnType.value(intType)
	let boolReturn = MaxonReturnType.value(boolType)
	let mlReturn = MaxonReturnType.value(mlType)
	// Element-typed slot for value-carrying methods. As with __ManagedMemory,
	// the IR slot is a single 8-byte word regardless of element type; the
	// substitution pass binds Element to the concrete type at call sites where
	// the receiver is fully specialized.
	let elementParamId = project.typeParameters.intern("__ManagedList", paramName: "Element")
	let elementType = MaxonType.typeParameter(elementParamId)
	let elementReturn = MaxonReturnType.value(elementType)
	// Node-returning methods (`insertFirst`, `head`, …) keep their declared
	// return as the bare `__ManagedListNode`. The element binding is recovered
	// at the call site by `methodCallResultType`'s receiver-driven node
	// promotion (`promoteManagedNodeReturnFromReceiver`), which pairs the bare
	// node type with the list receiver's concrete element so a downstream
	// `node.value()` resolves to the real element type rather than a raw
	// `Element`. Carrying the binding in the registered return type instead
	// would require serializing a `genericInstance(__ManagedListNode, …)` whose
	// id wouldn't round-trip cleanly through the stdlib cache.
	let mlnReturn = MaxonReturnType.value(mlnType)

	// Instance methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1307-1347).
	// insertFirst(self, value Element) returns __ManagedListNode
	registerManagedListMethod(project, methodName: "insertFirst", paramNames: mmParamNames2("self", second: "value"), paramTypes: mmParamTypes2(mlType, second: elementType), returnType: mlnReturn)
	// insertLast(self, value Element) returns __ManagedListNode
	registerManagedListMethod(project, methodName: "insertLast", paramNames: mmParamNames2("self", second: "value"), paramTypes: mmParamTypes2(mlType, second: elementType), returnType: mlnReturn)
	// insertAfter(self, target __ManagedListNode, value Element) returns __ManagedListNode
	registerManagedListMethod(project, methodName: "insertAfter", paramNames: mmParamNames3("self", second: "target", third: "value"), paramTypes: mmParamTypes3(mlType, second: mlnType, third: elementType), returnType: mlnReturn)
	// insertBefore(self, target __ManagedListNode, value Element) returns __ManagedListNode
	registerManagedListMethod(project, methodName: "insertBefore", paramNames: mmParamNames3("self", second: "target", third: "value"), paramTypes: mmParamTypes3(mlType, second: mlnType, third: elementType), returnType: mlnReturn)
	// reinsertFirst(self, node __ManagedListNode) returns void
	registerManagedListMethod(project, methodName: "reinsertFirst", paramNames: mmParamNames2("self", second: "node"), paramTypes: mmParamTypes2(mlType, second: mlnType), returnType: MaxonReturnType.void)
	// reinsertLast(self, node __ManagedListNode) returns void
	registerManagedListMethod(project, methodName: "reinsertLast", paramNames: mmParamNames2("self", second: "node"), paramTypes: mmParamTypes2(mlType, second: mlnType), returnType: MaxonReturnType.void)
	// reinsertAfter(self, target __ManagedListNode, node __ManagedListNode) returns void
	registerManagedListMethod(project, methodName: "reinsertAfter", paramNames: mmParamNames3("self", second: "target", third: "node"), paramTypes: mmParamTypes3(mlType, second: mlnType, third: mlnType), returnType: MaxonReturnType.void)
	// reinsertBefore(self, target __ManagedListNode, node __ManagedListNode) returns void
	registerManagedListMethod(project, methodName: "reinsertBefore", paramNames: mmParamNames3("self", second: "target", third: "node"), paramTypes: mmParamTypes3(mlType, second: mlnType, third: mlnType), returnType: MaxonReturnType.void)
	// detach(self, node __ManagedListNode) returns void
	registerManagedListMethod(project, methodName: "detach", paramNames: mmParamNames2("self", second: "node"), paramTypes: mmParamTypes2(mlType, second: mlnType), returnType: MaxonReturnType.void)
	// remove(self, node __ManagedListNode) returns Element
	registerManagedListMethod(project, methodName: "remove", paramNames: mmParamNames2("self", second: "node"), paramTypes: mmParamTypes2(mlType, second: mlnType), returnType: elementReturn)
	// head(self) returns __ManagedListNode throws __ManagedListError
	registerManagedListMethod(project, methodName: "head", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: mlnReturn)
	// tail(self) returns __ManagedListNode throws __ManagedListError
	registerManagedListMethod(project, methodName: "tail", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: mlnReturn)
	// count(self) returns i64
	registerManagedListMethod(project, methodName: "count", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: intReturn)
	// isEmpty(self) returns bool
	registerManagedListMethod(project, methodName: "isEmpty", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: boolReturn)
	// clear(self) returns void
	registerManagedListMethod(project, methodName: "clear", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: MaxonReturnType.void)
	// cursorReset(self) returns void
	registerManagedListMethod(project, methodName: "cursorReset", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: MaxonReturnType.void)
	// cursorValue(self) returns Element
	registerManagedListMethod(project, methodName: "cursorValue", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: elementReturn)
	// cursorAdvance(self) returns void throws __ManagedListError
	registerManagedListMethod(project, methodName: "cursorAdvance", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: MaxonReturnType.void)
	// cursorStart(self) returns void throws __ManagedListError
	registerManagedListMethod(project, methodName: "cursorStart", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlType), returnType: MaxonReturnType.void)
	// Static methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1349-1350).
	// static create() returns __ManagedList
	registerManagedListMethod(project, methodName: "create", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: mlReturn)
end 'registerManagedListMethods'

// Phase C: register the `__ManagedListNode` builtin struct and its 4 instance
// methods. The node struct mirrors the C# bootstrap layout
// (maxon-sharp Compiler/2-Parser.cs:1060-1069):
//   offset  0  next   i64 (next __ManagedListNode pointer, or null)
//   offset  8  prev   i64 (previous __ManagedListNode pointer, or null)
//   offset 16  list   i64 (back-pointer to owning __ManagedList, or null when detached)
//   offset 24  value  i64 (element slot, ABI matches __ManagedMemory.set/get)
// Total byteSize = 32.
export function registerManagedListNodeType(project Project)
	registerManagedListNodeStruct(project)
	registerManagedListNodeMethods(project)
end 'registerManagedListNodeType'

function registerManagedListNodeStruct(project Project)
	if project.structTypes.contains("__ManagedListNode") 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	fields.push(StructField.create("next", fieldType: MaxonType.integer, offset: 0, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("prev", fieldType: MaxonType.integer, offset: 8, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("list", fieldType: MaxonType.integer, offset: 16, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("value", fieldType: MaxonType.integer, offset: 24, isMutable: true, offsetResolved: true))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedListNodeStruct: stdlib bootstrap path rejected")
	let st = StructType.create("__ManagedListNode", fields: fields, byteSize: 32, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert("__ManagedListNode", value: st) otherwise ignore
	_ = project.typeNames.intern("__ManagedListNode")
end 'registerManagedListNodeStruct'

function registerManagedListNodeMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	registerManagedBuiltinMethod(project, receiverName: "__ManagedListNode", methodName: methodName, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType)
end 'registerManagedListNodeMethod'

function registerManagedListNodeMethods(project Project)
	let mlnType = MaxonType.named(project.typeNames.intern("__ManagedListNode"))
	let mlnReturn = MaxonReturnType.value(mlnType)
	// __ManagedListNode shares the `Element` type-parameter family with
	// __ManagedList so a substituted instance binding (e.g. `Array with int`)
	// reaches both call sites with the same concrete Element. The intern key
	// uses the node's own type-name so the parameter registry stays scoped.
	let elementParamId = project.typeParameters.intern("__ManagedListNode", paramName: "Element")
	let elementType = MaxonType.typeParameter(elementParamId)
	let elementReturn = MaxonReturnType.value(elementType)

	// Instance methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1353-1360).
	// next(self) returns __ManagedListNode throws __ManagedListError
	registerManagedListNodeMethod(project, methodName: "next", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlnType), returnType: mlnReturn)
	// prev(self) returns __ManagedListNode throws __ManagedListError
	registerManagedListNodeMethod(project, methodName: "prev", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlnType), returnType: mlnReturn)
	// value(self) returns Element
	registerManagedListNodeMethod(project, methodName: "value", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mlnType), returnType: elementReturn)
	// setValue(self, v Element) returns void
	registerManagedListNodeMethod(project, methodName: "setValue", paramNames: mmParamNames2("self", second: "v"), paramTypes: mmParamTypes2(mlnType, second: elementType), returnType: MaxonReturnType.void)
end 'registerManagedListNodeMethods'

// Phase D: register the `__ManagedSocket` builtin struct, the
// `__ManagedSocketError` enum, and the 4 `__ManagedSocket.*` method
// signatures so user Maxon code in `stdlib/TcpClient.maxon` parses and
// type-resolves. Bodies are absent — the shared `lowerManagedHandleBuiltin`
// dispatch intercepts these calls and routes them to `mrt_managed_socket_*`
// runtime helpers.
//
// `__ManagedSocket` is a single-i64-handle struct (BSD socket fd on POSIX,
// SOCKET HANDLE on Windows). Layout matches the C# bootstrap
// (maxon-sharp Compiler/2-Parser.cs:1083-1091): `_handle` at offset 0,
// total byteSize = 8.
//
// Enum case ordinals mirror Builtins.maxon (`bufferOutOfBounds`,
// `resolveFailed`, `connectFailed`, `sendFailed`, `recvFailed`,
// `connectionClosed`, `closed`) so the runtime helpers' error-flag ordinals
// match the user-visible enum cases at runtime.
export function registerManagedSocketType(project Project)
	registerManagedSocketStruct(project)
	registerManagedSocketErrorEnum(project)
	registerManagedSocketMethods(project)
end 'registerManagedSocketType'

function registerManagedSocketStruct(project Project)
	// `_handle` matches the bootstrap field name so the destructor can pull
	// the raw socket handle out by name when the surrounding scope decrefs
	// its last reference.
	registerManagedHandleStruct(project, typeName: "__ManagedSocket", fieldName: "_handle")
end 'registerManagedSocketStruct'

function registerManagedSocketErrorEnum(project Project)
	var names = StringArray.create()
	names.push("bufferOutOfBounds")
	names.push("resolveFailed")
	names.push("connectFailed")
	names.push("sendFailed")
	names.push("recvFailed")
	names.push("connectionClosed")
	names.push("closed")
	registerManagedErrorEnum(project, typeName: "__ManagedSocketError", caseNames: names)
end 'registerManagedSocketErrorEnum'

function registerManagedSocketMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType, throwsTypeName ThrowsClause = ThrowsClause.none)
	registerManagedBuiltinMethod(project, receiverName: "__ManagedSocket", methodName: methodName, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType, throwsTypeName: throwsTypeName)
end 'registerManagedSocketMethod'

function registerManagedSocketMethods(project Project)
	let msType = MaxonType.named(project.typeNames.intern("__ManagedSocket"))
	let mmType = MaxonType.named(project.typeNames.intern("__ManagedMemory"))
	let intType = MaxonType.integer
	let intReturn = MaxonReturnType.value(intType)
	let msReturn = MaxonReturnType.value(msType)
	// Throws clause shared by the three throwing methods. The string name
	// matches the enum registered via `registerManagedSocketErrorEnum`; the
	// type resolver maps it to the `__ManagedSocketError` MaxonType when a
	// `try X otherwise (e)` site asks for `e`'s type.
	let throwsMsError = ThrowsClause.throwing("__ManagedSocketError")

	// Instance methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1180-1188).
	// sendFrom(self, managed, offset, length) returns i64 throws __ManagedSocketError
	registerManagedSocketMethod(project, methodName: "sendFrom", paramNames: mmParamNames4("self", second: "managed", third: "offset", fourth: "length"), paramTypes: mmParamTypes4(msType, second: mmType, third: intType, fourth: intType), returnType: intReturn, throwsTypeName: throwsMsError)
	// recv(self, managed) returns i64 throws __ManagedSocketError
	registerManagedSocketMethod(project, methodName: "recv", paramNames: mmParamNames2("self", second: "managed"), paramTypes: mmParamTypes2(msType, second: mmType), returnType: intReturn, throwsTypeName: throwsMsError)
	// close(self) returns void
	registerManagedSocketMethod(project, methodName: "close", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(msType), returnType: MaxonReturnType.void)

	// Static methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1186-1188).
	// static tcpConnect(host, port) returns __ManagedSocket throws __ManagedSocketError
	registerManagedSocketMethod(project, methodName: "tcpConnect", paramNames: mmParamNames2("host", second: "port"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: msReturn, throwsTypeName: throwsMsError)
end 'registerManagedSocketMethods'

function mmParamNames1(first String) returns StringArray
	var names = StringArray.create()
	names.push(first)
	return names
end 'mmParamNames1'

function mmParamNames2(first String, second String) returns StringArray
	var names = StringArray.create()
	names.push(first)
	names.push(second)
	return names
end 'mmParamNames2'

function mmParamNames3(first String, second String, third String) returns StringArray
	var names = StringArray.create()
	names.push(first)
	names.push(second)
	names.push(third)
	return names
end 'mmParamNames3'

function mmParamTypes1(first MaxonType) returns MaxonTypeArray
	var types = MaxonTypeArray.create()
	types.push(first)
	return types
end 'mmParamTypes1'

function mmParamTypes2(first MaxonType, second MaxonType) returns MaxonTypeArray
	var types = MaxonTypeArray.create()
	types.push(first)
	types.push(second)
	return types
end 'mmParamTypes2'

function mmParamTypes3(first MaxonType, second MaxonType, third MaxonType) returns MaxonTypeArray
	var types = MaxonTypeArray.create()
	types.push(first)
	types.push(second)
	types.push(third)
	return types
end 'mmParamTypes3'

function mmParamNames4(first String, second String, third String, fourth String) returns StringArray
	var names = StringArray.create()
	names.push(first)
	names.push(second)
	names.push(third)
	names.push(fourth)
	return names
end 'mmParamNames4'

function mmParamTypes4(first MaxonType, second MaxonType, third MaxonType, fourth MaxonType) returns MaxonTypeArray
	var types = MaxonTypeArray.create()
	types.push(first)
	types.push(second)
	types.push(third)
	types.push(fourth)
	return types
end 'mmParamTypes4'

// Stage E (closures): predicate distinguishing parser-lifted closure
// bodies (`{outer}$closure_<k>` post-Phase-2; `_$closure_<N>` pre-Phase-2
// fallback for the anonymous-outer edge case) from ordinary user
// functions. The parser embeds `$closure_` in every lifted name; `$` is
// rejected by the Maxon lexer so user code can never produce that
// substring in a function name, making the test unambiguous.
function isLiftedClosureName(name String) returns bool
	return name.contains("$closure_")
end 'isLiftedClosureName'

// True when the given Maxon return type lowers to a floating-point Std
// type. Drives the choice of `constF64` vs `constI64` for the default
// primary return value emitted by `lowerThrow`. `void` returns count as
// non-float — the synthesized const is unread by the caller in that case.
function maxonReturnTypeLowersToFloat(project Project, ref MaxonReturnType) returns bool
	return match ref 'pick'
		void gives false
		value(inner) gives stdTypeIsFloat(maxonTypeToStdType(project, ref: inner))
	end 'pick'
end 'maxonReturnTypeLowersToFloat'

// Phase 9 Stage 3: lookup result for a match-arm scrutinee's union type.
// Carries both a "hit" flag and the resolved EnumType so callers don't
// have to issue two project lookups. Misses correspond to bare-enum and
// non-enum scrutinees, which take the existing direct-cmp lowering path.
type UnionTypeLookup
	export var hasType as bool
	export var value as EnumType

	export static function miss() returns UnionTypeLookup
		// `value` is unread on miss; supply a zeroed EnumType so the
		// struct stays well-formed. Calling `value` on a miss is a caller
		// bug — the only consumer guards on `hasType` first.
		return Self{hasType: false, value: EnumType.create("", cases: EnumCaseArray.create(), isFloatBacked: false, visibility: Visibility.file, sourceFilePath: FilePath from "", nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), isUnion: false)}
	end 'miss'

	export static function hit(t EnumType) returns UnionTypeLookup
		return Self{hasType: true, value: t}
	end 'hit'
end 'UnionTypeLookup'

// Phase 9 Stage 3: max payload arity across all cases of a union. Drives
// the per-allocation size (`8 + maxArity*8`). All cases of the same union
// share an allocation size so the destructor (Stage 4) can iterate slots
// uniformly without consulting the per-case payload count at runtime.
function unionMaxPayloadArity(unionType EnumType) returns ParsedInt
	var maxArity = 0
	for c in unionType.cases 'scan'
		let arity = c.payloadFields.count()
		if arity > maxArity 'wider'
			maxArity = arity
		end 'wider'
	end 'scan'
	return maxArity
end 'unionMaxPayloadArity'

// Phase 9 Stage 3: true when a MaxonType lowers to a heap-allocated
// managed reference that participates in refcount discipline. Covers
// struct types (incl. the stdlib `String`), generic-instance struct
// values, and union types (heap-boxed tagged values). Bare enums,
// primitives, and function values are NOT managed: they pass by value.
// Used by union construct/read paths to decide where to insert
// `__mm_incref` calls.
function maxonTypeIsManagedRef(project Project, t MaxonType) returns bool
	return match t 'classify'
		boolean gives false
		integer gives false
		float gives false
		string gives false
		function gives false
		unresolved gives false
		typeParameter gives false
		interface gives false
		// Named types: struct → managed, union (payload-bearing enum
		// tagged as isUnion) → managed, bare enum / typealias → not
		// managed. `genericInstance` follows the struct path because
		// every generic instance currently materializes as a struct
		// (e.g. `Array<Element>`).
		named(id) gives namedTypeIsManagedRef(project, id: id)
		genericInstance gives true
		constInt to opaquePointer gives false
	end 'classify'
end 'maxonTypeIsManagedRef'

function namedTypeIsManagedRef(project Project, id TypeNameId) returns bool
	let name = project.typeNames.get(id)
	if project.structTypes.contains(name) 'isStruct'
		return true
	end 'isStruct'
	if let enumType = try project.enumTypes.get(name) 'isEnum'
		return enumType.isUnion
	end 'isEnum'
	if let unresolvedEnum = try project.unresolvedEnums.get(name) 'isUnresolvedEnum'
		return unresolvedEnum.isUnion
	end 'isUnresolvedEnum'
	// `project.typealiases` only maps to `StdType` (the ABI-level
	// representation), so it cannot carry through to managed-ness here —
	// every entry there is a primitive (i64/f64/i1). Numeric aliases
	// like `typealias ID = int(0 to 100)` therefore correctly return
	// false. Generic typealiases (`typealias ByteArray = Array with Byte`)
	// always resolve to a struct-shaped value, so they're managed.
	if project.genericTypealiases.contains(name) 'isGenericAlias'
		return true
	end 'isGenericAlias'
	return false
end 'namedTypeIsManagedRef'

// Stage E (closures): per-function map keyed on a function-pointer
// ValueId, returning the matching env-pointer ValueId (or 0 for "no env"
// — the indirectCall lowering still emits the env arg, with 0 standing in
// for a null env, which the lifted body's body never dereferences). Plain
// `Map<ValueId, ValueId>` is enough — we don't need the fancier address-
// taken bookkeeping here because the closure ABI is uniform: every
// indirect call has exactly one env in flight at a time.
typealias FnEnvMap = Map with (ValueId, ValueId)
typealias SlotToValueIdMap = Map with (VarSlot, ValueId)

// slot<->abi decoupling: function-typed PARAM scope slot -> env-companion
// scope slot. See `paramSlotToEnvSlot`.
typealias SlotToSlotMap = Map with (VarSlot, VarSlot)

// C1.c: per-function map from an interface-typed slot id to its witness
// companion slot id. Populated by `assignInterfaceWitnessSlots` after
// `collectSlotMaxonTypes` allocates fresh trailing slots for each
// interface-typed slot found in the function. Read at every interface-
// typed varDecl/varStore site to emit the second store (witness pointer)
// alongside the first (value or box pointer).
typealias InterfaceWitnessSlotMap = Map with (VarSlot, VarSlot)

// C1.d: per-function pairing of an interface-typed loaded value with its
// witness pointer (also a ValueId). Populated by `lowerVarLoad` whenever it
// reads a fat-pointer slot — the load emits two ops (value + witness) and
// stashes the pair here so a downstream `methodCall` can recover the
// witness without re-walking back to the slot. Mirrors `fnEnvVarNames`'s
// shape for the closure ABI.
typealias InterfaceWitnessValueIdMap = Map with (ValueId, ValueId)

// Per-function map from a String-literal ValueId (the outer `String` struct
// produced by `lowerStringConst`) to its parser-interned StringId. Lets
// builtin-lowering recover the literal bytes for label-shaped arguments.
typealias StringLiteralProvenanceMap = Map with (ValueId, StringId)

// Thrown by `resolveLabelToSlot` when a `name:` label doesn't bind to a
// user-visible parameter slot — covers both the unknown-label case and the
// resolves-to-hidden-prefix case (e.g. `__self`). Callers `if let` to take
// the matched-slot path and emit E3xxx + skip the bad arg on the throw.
enum LabelSlotError implements Error
	notFound
end 'LabelSlotError'

// `tryMaterializeLayoutFromConformance` distinguishes the qualified
// callee not being interface-declared from the receiver not declaring a
// matching conformance — only the latter is an unexpected gap. The
// `noWithArgs` arm fires when the conformance carries no `with` args,
// which means the interface is non-generic and the materialization
// caller's original panic should fire.
enum ConformanceLayoutLookupError implements Error
	notInterfaceCallee
	noConformance
	noWithArgs
end 'ConformanceLayoutLookupError'

// Outcome of a struct-field lookup by name. The lookup helpers throw this
// when the receiver isn't a registered struct or the struct has no field
// of that name; callers report E3xxx and bail.
type FieldHit
	export var offset as FieldOffset
	export var fieldType as MaxonType
	export var isMutable as bool
	export var structName as String

	export static function create(offset FieldOffset, fieldType MaxonType, isMutable bool, structName String) returns FieldHit
		return Self{offset: offset, fieldType: fieldType, isMutable: isMutable, structName: structName}
	end 'create'
end 'FieldHit'

enum FieldLookupError implements Error
	notFound
end 'FieldLookupError'

// Validated `__Builtins.ucd*` intrinsic args: a literal label naming a UCD
// blob and the ValueId of the caller-evaluated operand. Throws covers arity
// mismatch, non-literal label, and missing-blob — each of which has already
// been reported as a compile-time error before the throw.
type UcdReady
	export var label as String
	export var operand as ValueId

	export static function create(label String, operand ValueId) returns UcdReady
		return Self{label: label, operand: operand}
	end 'create'
end 'UcdReady'

enum UcdLoadError implements Error
	failed
end 'UcdLoadError'

// Snapshot of the per-function lowering state. Synthesizers swap this in
// for the duration of a helper body, then restore it so any future caller
// sees the original outer-function state.
type LoweringFuncStateSnapshot
	export var funcIdRef as ValueIdRef
	export var nameToId as NameToValueIdMap
	export var valueType as MaxonTypeArray

	export static function create(funcIdRef ValueIdRef, nameToId NameToValueIdMap, valueType MaxonTypeArray) returns LoweringFuncStateSnapshot
		return Self{funcIdRef: funcIdRef, nameToId: nameToId, valueType: valueType}
	end 'create'
end 'LoweringFuncStateSnapshot'

// Thrown by `recoverStringLiteral` when the SSA name passed in didn't come
// from a parser-emitted string-literal `stringConst` op (the operand was a
// runtime expression where a compile-time literal was required).
enum NotAStringLiteral implements Error
	notLiteral
end 'NotAStringLiteral'

// ============================================================
// MaxonToStdLowering type
// ============================================================

type MaxonToStdLowering
	var pipeline as PassPipeline
	var maxonModule as MaxonModule
	var project as Project
	var globalData as GlobalDataTable
	var stdModule as StdModule
	// Per-function name→id map. Reset at the top of each function's lowering.
	var nameToId as NameToValueIdMap
	// Per-function ValueId ref. Starts at `paramCount` so that parameter
	// IDs 0..paramCount-1 remain reserved by Std-ABI convention.
	var funcIdRef as ValueIdRef
	// Per-function context for resolving cross-declaration name references
	// the parser now leaves symbolic. `currentNamespace` is the function's
	// module namespace ("" for free functions before qualification, "stdlib"
	// for stdlib funcs, etc.); used by `CallContext.free` resolution.
	// `currentTypeName` is "" for free functions or the enclosing struct
	// name for methods; used by `selfFieldLoad`/`selfFieldStore` to find
	// the field offset, and as the fallback callee context for any sibling
	// resolution that isn't already encoded in the op's CallContext.
	var currentNamespace as String
	var currentTypeName as String
	// Qualified name of the function currently being lowered. Used to build
	// `project.charByteLiterals` lookup keys at call sites so char-byte
	// arg coercion (raw int → Character struct) is keyed under the right
	// per-function value-name space.
	var currentFuncName as String
	// Source file path of the function currently being lowered, recovered
	// from its entry block's BlockSourceInfo. Diagnostics emitted from the
	// lowering pass (E3005 at call sites, etc.) anchor on this so file:line
	// reporting matches the user's source layout. Reset when a new function
	// starts lowering.
	var currentFilePath as String
	// Function-level return type of the function currently being lowered.
	// Used by `throw` lowering to emit a default primary return value of
	// the correct family (i64 vs f64) — the caller's `try ... otherwise`
	// branch ignores the primary value when the error flag is non-zero, so
	// any in-range default works. Reset per function in `lower()`.
	var currentReturnType as MaxonReturnType
	// Phase 6: tracks whether the function currently being lowered is throwing
	// (non-empty `throwsTypeName`). Drives the `ret` → `errorReturn` rewrite in
	// `lowerTerminator` so every exit of a throwing function writes both
	// registers per the multi-value-return ABI.
	var currentFuncIsThrowing as bool
	// Per-function value-type map: tracks each SSA value's Maxon-level type.
	// Populated as ops are lowered so that consumers (fieldLoad/Store,
	// methodCall, mixed-family binops) can resolve receiver types and pick
	// the right opcode. Reset when a new function starts lowering. The
	// float-ness predicate (`getIsFloat`) is now a derived helper that
	// matches on the stored type.
	var valueType as MaxonTypeArray
	// Scratch buffers reused by slotArgsForCall to avoid per-call alloc.
	// clear()+resize() each call; capacity converges to high-water mark.
	// The result array is still freshly allocated per call (StdOp.call
	// retains it), so the scratch is never returned directly.
	var slotIdsScratch as ValueIdArray
	var slotFilledScratch as BoolArray
	// Stage E (closures): per-function map from a function-pointer
	// ValueId to the matching env-pointer ValueId. Populated when:
	//   - lowering a function-typed parameter slot (the param's fn-pointer
	//     ValueId is paired with its synthetic `__env_<name>` slot's
	//     load), and
	//   - lowering a `functionRef` (env = 0 sentinel) or `closureCreate`
	//     (env = the freshly-mrt_alloc'd block).
	// Read at every `indirectCall` lowering site to recover the env to
	// pass alongside the callee. Reset per function in `lower()`.
	var fnEnvVarNames as FnEnvMap
	// slot<->abi decoupling: per-function map from a function-typed PARAM's
	// scope slot id to its env-companion's scope slot id. Kept SEPARATE from
	// `fnEnvVarNames` (which is ValueId-keyed) because after the slot<->abi
	// decoupling a param scope slot id no longer equals a ValueId, so storing
	// it in the ValueId-keyed map would collide with a real ValueId entry (the
	// same hazard documented on `closureSlotToEnvValueId`). Populated by
	// `seedParams`; read by `lowerVarLoad` for param-slot loads. Both keys and
	// values are scope slot ids, used directly as `loadSlot` targets. Reset
	// per function in `lower()`.
	var paramSlotToEnvSlot as SlotToSlotMap
	// Stage E (closures): per-function map from a LOCAL SLOT id to the
	// env's SSA ValueId, populated when a `varDecl`/`varStore` writes a
	// function-typed value whose env was already bound in `fnEnvVarNames`.
	// Read by `lowerVarLoad` to propagate the env across the slot rather
	// than emitting a spurious `loadSlot` (the slot id can collide with
	// an unrelated `fnEnvVarNames` ValueId-keyed entry from `closureCreate`,
	// which would otherwise route through the 'hasEnv' branch and load
	// from a phantom slot — see closure-capture.interface-method-with-
	// captured-field for the reproducer). Reset per function in `lower()`.
	var closureSlotToEnvValueId as SlotToValueIdMap
	// Stage E (closures): per-function value-id of the lifted closure's
	// hidden `__env` parameter. Written once at function-entry lowering
	// when the function's last param is the synthetic env, read by
	// every `closureEnvLoad` op the body emits. 0 means "not a lifted
	// closure body" — `closureEnvLoad` would never appear in such a
	// function so the unused-zero is fine.
	var liftedEnvValueId as ValueId
	// Phase 11.4: per-function ValueId of the synthetic `__layout_param`
	// trailing param. 0 means "function has no implicit layout param" — its
	// body never references the descriptor so leaving the slot at 0 is
	// inert. Set when the function is detected as generic at lowering entry.
	var implicitLayoutValueId as ValueId
	// Phase 11.4: per-function ValueIds of the synthetic `__witness_*`
	// trailing params, parallel to `currentMaxonFunc.implicitWitnessConstraints`
	// (one slot per `(typeParam, interface)` constraint, in declaration order).
	// Empty when the function has no where-clauses; populated when the
	// function-body emission resolves the trailing slot ids.
	var implicitWitnessValueIds as ValueIdArray
	// Stage E (closures): the IrFunction currently being lowered. Set at
	// the top of each function's body walk and read by lowerClosureCreate
	// to look up the OUTER function's `scope` for capture-slot resolution.
	// The lowering walks `maxonModule.functions` in order; we can't reach
	// for "the last function pushed to stdModule" because every function
	// is pushed upfront in `transferFuncs`.
	var currentMaxonFunc as IrFunction
	// C1.c: per-function map from interface-typed slot id to its witness
	// companion slot id. Populated by `assignInterfaceWitnessSlots` at
	// transferFuncs time. Reset per function in `lower()` so the map
	// reflects only the current function's interface slots.
	var interfaceWitnessSlots as InterfaceWitnessSlotMap
	// C1.d: per-function map from a loaded interface-typed ValueId to the
	// matching witness ValueId loaded from the companion slot. Populated by
	// `lowerVarLoad` and consumed by `lowerMethodCall` for fat-pointer
	// receiver dispatch.
	var interfaceWitnessValueIds as InterfaceWitnessValueIdMap
	// Maps a String-literal ValueId back to its parser-interned StringId so
	// builtin-lowering can recover the literal bytes for arguments that the
	// parser would not normally surface (e.g. the label argument of
	// `__Builtins.ucdByteAt("__ucd_bmp", offset)`). Populated by
	// `lowerStringConst`; queried by `recoverStringLiteral`.
	var stringLiteralProvenance as StringLiteralProvenanceMap
	// Phase 9 Stage 1: set of enum names whose `__name` helper has been
	// requested by at least one `.name` field-load. Synthesized at the tail
	// of `lower()` (one helper per enum) — same lazy-synthesis pattern as
	// `synthesizeWitnessThunks`. Plain string set; duplicates are deduped by
	// insertion so the synthesis pass walks each enum exactly once.
	var pendingEnumNameHelpers as EnumNameHelperSet
	// Function-backed enums: set of enum names whose `__fnRaw` helper has
	// been requested by at least one `.rawValue` lowering. Mirrors the
	// pendingEnumNameHelpers pattern; emitted at the tail of `lower()`.
	var pendingEnumFnRawHelpers as EnumNameHelperSet
	// String/char-backed enums: set of enum names whose `__rawString` helper
	// has been requested by at least one `.rawValue` field-load. The helper
	// maps the receiver's ordinal to the case's declared backing literal.
	// Same lazy-synthesis pattern as the `.name` / `.fnRaw` helpers.
	var pendingEnumRawStringHelpers as EnumNameHelperSet
	// Phase 10 (closures): set of synthesized thunk names already scheduled
	// by `scheduleFnRefThunk`. The thunk for a free function `foo` is
	// `__fnref_foo` and wraps the target with the indirect-call ABI's
	// trailing `__env` param so wasm's `call_indirect` sees a matching
	// signature. The parallel `pendingFnRefThunkTargets` list records the
	// original target funcName in insertion order so `synthesizeFnRefThunks`
	// can rebuild the thunks deterministically at the tail of `lower()`.
	var pendingFnRefThunks as EnumNameHelperSet
	var pendingFnRefThunkTargets as StringArray

	export static function create(pipeline PassPipeline, maxonModule MaxonModule, project Project, globalData GlobalDataTable) returns MaxonToStdLowering
		return Self{
			pipeline: pipeline,
			maxonModule: maxonModule,
			project: project,
			globalData: globalData,
			stdModule: StdModule.create(),
			nameToId: NameToValueIdMap.create(),
			funcIdRef: ValueIdRef.create(0),
			currentNamespace: "",
			currentTypeName: "",
			currentFuncName: "",
			currentFilePath: "",
			currentReturnType: MaxonReturnType.void,
			currentFuncIsThrowing: false,
			valueType: MaxonTypeArray.create(),
			slotIdsScratch: ValueIdArray.create(),
			slotFilledScratch: BoolArray.create(),
			fnEnvVarNames: FnEnvMap.create(),
			paramSlotToEnvSlot: SlotToSlotMap.create(),
			closureSlotToEnvValueId: SlotToValueIdMap.create(),
			liftedEnvValueId: 0,
			implicitLayoutValueId: 0,
			implicitWitnessValueIds: ValueIdArray.create(),
			currentMaxonFunc: IrFunction.create("", maxonReturnType: MaxonReturnType.void, paramCount: 0, maxonParamTypes: MaxonTypeArray.create(), returnLine: 0),
			interfaceWitnessSlots: InterfaceWitnessSlotMap.create(),
			interfaceWitnessValueIds: InterfaceWitnessValueIdMap.create(),
			stringLiteralProvenance: StringLiteralProvenanceMap.create(),
			pendingEnumNameHelpers: EnumNameHelperSet.create(),
			pendingEnumFnRawHelpers: EnumNameHelperSet.create(),
			pendingEnumRawStringHelpers: EnumNameHelperSet.create(),
			pendingFnRefThunks: EnumNameHelperSet.create(),
			pendingFnRefThunkTargets: StringArray.create()
		}
	end 'create'

	// --- Per-value type tracking ------------------------------------------

	function setValueType(id ValueId, t MaxonType)
		while self.valueType.count() <= id 'grow'
			self.valueType.push(MaxonType.integer)
		end 'grow'
		try self.valueType.set(id, value: t) otherwise panic("invariant: self.valueType.set OOB")
	end 'setValueType'

	function getValueType(id ValueId) returns MaxonType
		return try self.valueType.get(id) otherwise MaxonType.integer
	end 'getValueType'

	// Float-ness derives from the stored type. Callers that only know the
	// int-vs-float family use this thin wrapper instead of `setValueType`
	// directly. When the caller passes `false`, we collapse to `integer`
	// rather than preserving any prior named type — the callers in this
	// file are all op-result writers that own the slot.
	function setIsFloat(id ValueId, isFloat bool)
		if isFloat 'asFloat'
			self.setValueType(id, t: MaxonType.float)
		end 'asFloat' else 'asInt'
			self.setValueType(id, t: MaxonType.integer)
		end 'asInt'
	end 'setIsFloat'

	function getIsFloat(id ValueId) returns bool
		return stdTypeIsFloat(maxonTypeToStdType(self.project, ref: self.getValueType(id)))
	end 'getIsFloat'

	// Promote `operandId` to f64 if it is currently int-backed. Returns the
	// post-promotion ValueId (original if no promotion needed). Emitted as an
	// si→f64 convert op; the result is registered as float in the map.
	function promoteToFloat(operandId ValueId, dstBlock IrBlock) returns ValueId
		if self.getIsFloat(operandId) 'alreadyFloat'
			return operandId
		end 'alreadyFloat'
		let promId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.siToFpF64, resultId: promId, operandId: operandId))))
		self.setIsFloat(promId, isFloat: true)
		return promId
	end 'promoteToFloat'

	// --- Name→ValueId translation ----------------------------------------

	// Allocate a fresh ValueId for a Maxon op's result name. Records the
	// mapping so subsequent operand reads of the same name resolve to this
	// ValueId. Not idempotent — each call creates a fresh id.
	function defineName(name ByteArray) returns ValueId
		let id = allocValueId(self.funcIdRef)
		self.nameToId.upsert(name, value: id)
		return id
	end 'defineName'

	// Emit a parser-bug-class compile error from inside the lowering pass.
	// All `lowerMaxonToStd:` errors share the same fake source position
	// (no line/column is recoverable here — the SourceRange on the Maxon
	// op is just the producing token, which lowering already discarded by
	// the time it spots the bug). `hasErrors(project)` will short-circuit
	// before codegen, so the placeholder path string never reaches the user.
	function reportLowerError(code ErrorCode, message String)
		let placeholderPath = try FilePath.from("lowerMaxonToStd") otherwise panic("lowerMaxonToStd: FilePath.from rejected literal placeholder")
		reportCompileError(self.project, code: code, message: message, line: 0, column: 0, filePath: placeholderPath)
	end 'reportLowerError'

	// Look up an operand name in the current function's map. A miss indicates
	// the referring Maxon op names a value that was never bound — either the
	// parser emitted an `error` op that dropped the defining op, or there is
	// a real parser bug. We emit a compile-error diagnostic and fabricate a
	// placeholder ValueId so subsequent ops still form a structurally valid
	// SSA module (`hasErrors(project)` will short-circuit before codegen).
	function resolveName(name ByteArray) returns ValueId
		let found = try self.nameToId.get(name) otherwise 'missed'
			self.reportLowerError(ErrorCode.semanticMissingReturn, message: "lowerMaxonToStd: unresolved value name '{String.from(name)}' in func '{self.currentFuncName}' (parser did not bind this name)")
			let placeholder = allocValueId(self.funcIdRef)
			self.nameToId.upsert(name, value: placeholder)
			return placeholder
		end 'missed'
		return found
	end 'resolveName'

	// Redirect `name` to an existing ValueId — used for same-family converts,
	// which are value-level no-ops: the result name refers to the same SSA
	// value as its operand.
	function aliasName(name ByteArray, toId ValueId)
		self.nameToId.upsert(name, value: toId)
	end 'aliasName'

	// Resolve each name in an arg list to its SSA ValueId.
	function resolveArgNames(args ByteArrayArray, leadingReceiverId ValueId = 0, hasLeadingReceiver bool = false) returns ValueIdArray
		var result = ValueIdArray.create()
		if hasLeadingReceiver 'pushLead'
			result.reserve(args.count() + 1)
			result.push(leadingReceiverId)
		end 'pushLead' else 'noLead'
			result.reserve(args.count())
		end 'noLead'
		for i in 0 upto args.count() 'each'
			let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
			result.push(self.resolveName(arg))
		end 'each'
		return result
	end 'resolveArgNames'

	// Variant of `resolveArgNames` that pairs a witness onto the leading
	// receiver when the callee's `__self` slot is interface-typed. Used by
	// the no-user-param early-returns in `slotArgsForCall` so an extension
	// method invoked on a concrete receiver still gets the (value, witness)
	// fat-pointer pair the callee expects at slot 0.
	function resolveArgNamesWithReceiverWitness(signature FuncSignature, args ByteArrayArray, leadingReceiverId ValueId, hasLeadingReceiver bool, dstBlock IrBlock) returns ValueIdArray
		var result = ValueIdArray.create()
		if hasLeadingReceiver 'pushLead'
			result.push(leadingReceiverId)
			let leadingParamType = try signature.paramTypes.get(0) otherwise MaxonType.unresolved
			if interfaceTypeIsFat(leadingParamType) 'leadingFat'
				let leadingWitness = self.witnessForInterfaceArg(leadingReceiverId, paramType: leadingParamType, dstBlock: dstBlock)
				result.push(leadingWitness)
			end 'leadingFat'
		end 'pushLead'
		for i in 0 upto args.count() 'each'
			let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
			result.push(self.resolveName(arg))
		end 'each'
		return result
	end 'resolveArgNamesWithReceiverWitness'

	// --- Main driver -------------------------------------------------------

	export function lower() returns StdModule
		// Register every top-level / static-field global with the .data section
		// machinery so the X64 backend lays out their initial values before the
		// heap arena. The map iteration is order-stable per project (insertion
		// order), keeping the linker symbol layout deterministic across builds.
		registerGlobalVarsForDataSection(self.project, globalData: self.globalData)
		// Step 6a.17: reserve the slab + MM allocator's mutable state globals so
		// `globalAddr __slab_*` / `globalAddr __mm_*` resolve to distinct
		// addresses. Without this every allocator-state global would alias to
		// offset 0 the moment `mrt_start` calls `__slab_init`.
		registerSlabAndMmGlobalsForDataSection(self.globalData)

		// Copy blocks first so block indices stay aligned 1:1 between the source
		// MaxonModule.blocks and the dest StdModule.blocks. Each resulting
		// IrBlock is initially empty; ops are appended as we walk each function.
		// The source-location footprint is copied in lock-step so the downstream
		// coverage-instrumentation pass sees the same per-block line sets.
		for i in 0 upto self.maxonModule.blocks.count() 'cloneBlocks'
			let srcBlock = try self.maxonModule.blocks.get(i) otherwise panic("lowerMaxonToStd: blocks.get out of bounds")
			self.stdModule.blocks.push(IrBlock.create(srcBlock.id, label: srcBlock.label))
			let srcInfo = try self.maxonModule.blockSourceInfo.get(i) otherwise BlockSourceInfo.empty()
			self.stdModule.blockSourceInfo.push(srcInfo)
		end 'cloneBlocks'

		// Transfer each function directly, collapsing Maxon-phase types to Std types.
		// blockRefs are already correct since we kept 1:1 block index alignment above.
		// Phase 11.4: generic functions get a trailing `__layout_param`
		// (and a `__witness_param` if their declaring type carries
		// where-clause constraints) — appended after the user/env slots
		// so the Std-level paramCount and paramTypes both grow in lockstep
		// with the synthetic ValueId reservations stamped below.
		for i in 0 upto self.maxonModule.functions.count() 'transferFuncs'
			var func = try self.maxonModule.functions.get(i) otherwise panic("invariant: i < functions.count() but get failed")
			let needsLayout = functionIsGenericForLowering(self.project, func: func)
			var witnessConstraints = WhereClauseArray.create()
			if needsLayout 'collectConstraints'
				witnessConstraints = collectFunctionWitnessConstraints(self.project, func: func)
			end 'collectConstraints'
			var stdParams = StdTypeArray.create()
			for paramType in func.maxonParamTypes 'eachParam'
				stdParams.push(maxonTypeToStdType(self.project, ref: paramType))
			end 'eachParam'
			// Phase 11.4 closure-inheritance: lifted closures (`_$closure_N`)
			// that inherit implicit args from a generic enclosing extension
			// don't grow positional layout/witness params — the closure is
			// reached via `indirectCall` and ABI-uniform with every other
			// function-typed slot. Instead, the args ride in env (see
			// `lowerClosureCreate` for the producer side and the per-function
			// reset below for the consumer-side env-loads). We still mark
			// `hasImplicitLayoutParam = true` and stamp the constraints so
			// `tryLowerConstrainedTypeParamDispatch` finds them, but the
			// Std-level paramCount stays at its existing user_args + __env
			// shape, and we skip `genericFunctionImplicitArity` (the direct-
			// call path that consumes it is never reached for closures).
			let inheritsImplicitsViaEnv = isLiftedClosureName(func.name) and needsLayout
			if needsLayout and not inheritsImplicitsViaEnv 'addLayout'
				stdParams.push(StdType.i64)
				func.paramCount = func.paramCount + 1
				func.hasImplicitLayoutParam = true
			end 'addLayout'
			if inheritsImplicitsViaEnv 'closureFlagsOnly'
				func.hasImplicitLayoutParam = true
			end 'closureFlagsOnly'
			// Phase 11.4: one trailing `__witness_*` slot per where-clause
			// constraint, in declaration order. Multiple constraints on a
			// single type-param (e.g. `Key is Hashable and Equatable`)
			// produce parallel slots so each `(typeParam, interface)` pair
			// has its own witness pointer. Skipped for closures inheriting
			// via env (see the comment above `addLayout`).
			if not inheritsImplicitsViaEnv 'addWitness'
				for _ in 0 upto witnessConstraints.count() 'addWitnessLoop'
					stdParams.push(StdType.i64)
					func.paramCount = func.paramCount + 1
				end 'addWitnessLoop'
			end 'addWitness'
			func.implicitWitnessConstraints = witnessConstraints
			// Phase 11.4: record the implicit shape in a project-wide map so
			// per-function pipeline runs (where the callee isn't in the local
			// stdModule.functions) can still discover whether a callsite needs
			// the synthetic layout/witness args appended. See the field comment
			// in Project.maxon for the architectural rationale.
			if needsLayout and not inheritsImplicitsViaEnv 'recordArity'
				self.project.genericFunctionImplicitArity.upsert(func.name, value: GenericFunctionImplicits.create(true, witnessConstraints: witnessConstraints))
			end 'recordArity'
			func.returnType = maxonReturnTypeToStdReturnType(self.project, ref: func.maxonReturnType)
			func.paramTypes = stdParams
			// C1.b: snapshot per-slot MaxonTypes from the persisted scope so
			// downstream Std passes (InjectDrops) can recognize type-parameter
			// slots without re-walking the parser-level Scope. Self-field
			// aliases land at well-formed slot ids too — they have a slot
			// number even though they never back a real frame slot — so we
			// stamp them into the array (consumers ignore them via
			// isSelfField on the original VarInfo if they care).
			func.slotMaxonTypes = collectSlotMaxonTypes(func, maxonModule: self.maxonModule)
			// C1.c: every interface-typed slot is a fat pointer
			// `{value, witness}` — allocate a fresh trailing slot for the
			// witness companion of each interface-typed slot. Bumps
			// `func.scope.nextSlot` and grows `func.slotMaxonTypes` so all
			// downstream passes see a single coherent slot count. The
			// per-function side map is built in lower()'s per-func reset.
			extendSlotsForInterfaceWitnesses(func)
			self.stdModule.functions.push(func)
		end 'transferFuncs'

		// Walk each function's blocks and lower their ops. The walk reads
		// `self.stdModule.functions` (not `maxonModule.functions`) so the
		// Phase 11.4 synthetic-trailing-param updates done in transferFuncs
		// (paramCount, hasImplicitLayoutParam, implicitWitnessConstraints) are
		// the values consumed below — `funcIdRef` must start past the
		// synthetic slots so SSA ids don't collide with them.
		for srcFunc in self.stdModule.functions 'eachFunc'
			logTrace(LogCategory.ir, message: function() gives "lower-maxon-to-std: func={srcFunc.name} blocks={srcFunc.blockRefs.count()}")

			// Reset per-function state. SSA value IDs restart at paramCount in
			// each function so parameter IDs 0..paramCount-1 stay reserved.
			// Seed the value-type map from declared maxonParamTypes so
			// downstream ops see parameters as values of the right type.
			// `currentNamespace` comes directly from the IrFunction (set by
			// the parser). `currentTypeName` is recovered from func.name by
			// peeling off the last `.identifier` and probing structTypes —
			// the parser qualifies methods as `Type.method`, so a name
			// whose prefix is a registered struct denotes a method body.
			self.valueType = MaxonTypeArray.create()
			self.nameToId = NameToValueIdMap.create()
			self.funcIdRef = ValueIdRef.create(srcFunc.paramCount)
			self.currentNamespace = srcFunc.namespace
			self.currentTypeName = try enclosingTypeName(self.project, name: srcFunc.name) otherwise ""
			self.currentFuncName = srcFunc.name
			// Recover the file path from the entry block's source info so
			// E3005 (and any future call-site diagnostic) anchors on the
			// caller's source file rather than the lowering pass placeholder.
			self.currentFilePath = try entryBlockFilePath(self.maxonModule, func: srcFunc) otherwise ""
			// Phase 4: throw lowering needs to know the function's return
			// type family so it can synthesize a default primary return
			// value of the correct width (i64 vs f64). Stamp it here so
			// `lowerThrow` can read it without re-walking module.functions.
			self.currentReturnType = srcFunc.maxonReturnType
			// Phase 6 (multi-value-return error ABI): a throwing function's
			// normal `ret` MUST emit `errorReturn(retVal, 0)` so the caller's
			// tryCall captures both the primary value AND a clean (zero) flag.
			// Stamp the throws-ness here so `lowerTerminator` picks the right
			// terminator shape per `ret`.
			self.currentFuncIsThrowing = match srcFunc.throwsTypeName 'isThrow'
				none gives false
				throwing gives true
			end 'isThrow'
			// Stage E (closures): clear the function-pointer→env map so
			// the previous function's bindings don't leak across function
			// boundaries. The lifted-closure env ValueId is reset to 0 by
			// default and overwritten below if the function's last param
			// is a synthetic `__env` (closure with captures).
			self.fnEnvVarNames = FnEnvMap.create()
			self.paramSlotToEnvSlot = SlotToSlotMap.create()
			self.closureSlotToEnvValueId = SlotToValueIdMap.create()
			self.liftedEnvValueId = 0
			self.implicitLayoutValueId = 0
			self.implicitWitnessValueIds = ValueIdArray.create()
			self.currentMaxonFunc = srcFunc
			// C1.c: rebuild the interface-witness-slot side map for this
			// function. Cheap walk over slotMaxonTypes; runs once per
			// function and only pays for itself when the function actually
			// declares interface-typed locals (rare in real flow today).
			self.interfaceWitnessSlots = buildInterfaceWitnessSlotMap(srcFunc)
			// C1.d: reset the (loadedValueId → witnessValueId) pairing so
			// the previous function's bindings don't leak. Populated as
			// each varLoad on a fat-pointer slot emits its sibling witness
			// load.
			self.interfaceWitnessValueIds = InterfaceWitnessValueIdMap.create()
			// Phase 11.4: layer the synthetic trailing param ValueIds AFTER
			// the env slot (if any) so the indirect-call helpers can still
			// derive their env arg from the original liftedEnvValueId. Witness
			// slots, in declaration order, sit one-by-one past the layout
			// slot so per-(typeParam, interface) dispatch can index directly.
			// Phase 11.4 closure-inheritance: lifted closures that inherit
			// implicits from their enclosing generic extension don't have
			// positional layout/witness params — the args ride in env. We
			// still need `implicitLayoutValueId` / `implicitWitnessValueIds`
			// populated so `tryLowerConstrainedTypeParamDispatch` can index
			// them; the env-load emission below allocates fresh ValueIds
			// and emits one `loadIndirect` per slot AFTER all positional
			// `param` ops are emitted in the entry block.
			let closureBodyInheritsImplicits = isLiftedClosureName(srcFunc.name) and srcFunc.hasImplicitLayoutParam
			if srcFunc.hasImplicitLayoutParam and not closureBodyInheritsImplicits 'stampLayout'
				let constraintCount = srcFunc.implicitWitnessConstraints.count()
				let firstWitnessIdx = (srcFunc.paramCount - constraintCount) as ValueId
				for wIdx in 0 upto constraintCount 'eachWitness'
					self.implicitWitnessValueIds.push((firstWitnessIdx + wIdx) as ValueId)
				end 'eachWitness'
				self.implicitLayoutValueId = (firstWitnessIdx - 1) as ValueId
			end 'stampLayout'
			for pIdx in 0 upto srcFunc.maxonParamTypes.count() 'seedParams'
				let pType = try srcFunc.maxonParamTypes.get(pIdx) otherwise MaxonType.integer
				self.setValueType(pIdx, t: pType)
				// Param companion pairing. After buildAbiParamMaps, maxonParamTypes is the
				// ABI vector with each companion inserted immediately after its param, so
				// pIdx / pIdx+1 here are ABI indices (== ValueIds, since ValueIds restart
				// at paramCount). interfaceWitnessValueIds is ValueId-keyed, so its pIdx ->
				// pIdx+1 pairing stays in ABI/ValueId space. fnEnvVarNames, however, is read
				// in lowerVarLoad keyed by the producer varLoad's SCOPE slot id (and its
				// value is used as a loadSlot scope slot), so its key/value must be the
				// param's and companion's SCOPE slots — translated from the ABI index via
				// abiParamIndexToScopeSlot. This is the slot<->abi decoupling: the ABI
				// vector still interleaves (param, companion), but scope slot ids no longer
				// equal ABI indices.
				// A function-typed param needs its env companion paired. The
				// param type may still be a `named(alias)` (e.g. `SortComparator`)
				// that resolves to a function type — chase the alias before
				// deciding, mirroring `slotArgsForCall`'s env-expansion gate.
				// Without the chase, a generic helper whose comparator param is
				// declared via the alias (as `driftsortRange(cmp SortComparator)`
				// is) skips the pairing entirely, so its `cmp` forwards with a
				// stale/zero env and the eventual indirect call faults on a null
				// environment.
				let chasedSeedType = chaseTypealiasToFunctionType(self.project, t: pType)
				if isFunctionMaxonType(chasedSeedType) 'pairEnv'
					let envParamIdx = pIdx + 1
					if envParamIdx < srcFunc.abiParamIndexToScopeSlot.count() 'inRange'
						let paramScopeSlot = try srcFunc.abiParamIndexToScopeSlot.get(pIdx) otherwise panic("seedParams: abiParamIndexToScopeSlot.get OOB at {pIdx} for fn-param in {srcFunc.name}")
						let envScopeSlot = try srcFunc.abiParamIndexToScopeSlot.get(envParamIdx) otherwise panic("seedParams: abiParamIndexToScopeSlot.get OOB at {envParamIdx} for env companion in {srcFunc.name}")
						self.paramSlotToEnvSlot.upsert(paramScopeSlot, value: envScopeSlot)
					end 'inRange'
				end 'pairEnv'
				// C1.d: interface-typed param ABI is (value, witness). The dispatch-by-
				// ValueId path keys interfaceWitnessValueIds by ValueId == ABI index, so
				// pIdx -> pIdx+1 is correct here without translation.
				if interfaceTypeIsFat(pType) 'pairWitness'
					let witnessParamIdx = pIdx + 1
					if witnessParamIdx < srcFunc.maxonParamTypes.count() 'inRange'
						self.interfaceWitnessValueIds.upsert(pIdx, value: witnessParamIdx)
					end 'inRange'
				end 'pairWitness'
			end 'seedParams'
			// Stage E (closures): a lifted closure's last param is the
			// hidden `__env` pointer. Stamp it here so `closureEnvLoad`
			// ops in the body can recover it without re-deriving from
			// the function's name. Only flips for `_$closure_*` lifted
			// functions whose maxonParamTypes was extended in
			// `parseClosure` — non-closure functions reach here with an
			// unmodified param list and `liftedEnvValueId` stays at 0.
			// Phase 11.4: env slot sits at the end of the user-visible
			// `maxonParamTypes` (the layout/witness slots were appended at
			// the Std level only — they aren't in maxonParamTypes), so
			// `maxonParamTypes.count() - 1` still names the env slot even
			// when layout/witness are present.
			if isLiftedClosureName(srcFunc.name) and srcFunc.maxonParamTypes.count() > 0 'envParam'
				self.liftedEnvValueId = (srcFunc.maxonParamTypes.count() - 1)
			end 'envParam'

			// Phase 11.4: emit explicit `param` ops at the entry block for
			// synthetic trailing slots (layout, then optional witness). The
			// existing-param scan in Mem2Reg picks them up via
			// `paramSlotHasExistingOp`, preventing duplicate emission, and
			// the X64/ARM64 backends now have a `param` op anchoring the
			// register-class allocation for the synthetic slot. Without
			// this, the synthetic ValueId would be referenced (forwarded
			// into nested calls) but never defined — which is exactly the
			// "v1 has no coloring assignment" crash.
			let entryRef = try srcFunc.blockRefs.get(0) otherwise -1
			if entryRef >= 0 and srcFunc.hasImplicitLayoutParam and not closureBodyInheritsImplicits 'emitSyntheticParams'
				var entryBlock = try self.stdModule.blocks.get(entryRef) otherwise panic("invariant: entryRef from blockRefs not in stdModule.blocks")
				self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(self.implicitLayoutValueId, paramIndex: self.implicitLayoutValueId as VarSlot, paramType: StdType.i64)))
				for witnessId in self.implicitWitnessValueIds 'witnessParam'
					self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(witnessId, paramIndex: witnessId as VarSlot, paramType: StdType.i64)))
				end 'witnessParam'
			end 'emitSyntheticParams'

			// Phase 11.4 closure-inheritance: a lifted closure with
			// env-encoded implicits recovers them at the entry block. The
			// env block holds the layout pointer at offset
			// (captureCount * 8), then per-constraint witness pointers
			// starting at offset (captureCount + 1) * 8. We allocate fresh
			// ValueIds for each slot, emit one `loadIndirect` per slot
			// against the env-base (recovered from the `__env` param via
			// `loadSlot`), and stamp the ids into `implicitLayoutValueId` /
			// `implicitWitnessValueIds` so the existing dispatch site at
			// `tryLowerConstrainedTypeParamDispatch` works unchanged. The
			// captureCount lives on `srcFunc.closureCaptureCount` (the
			// parser stamps it at `parseClosure` time and the stdlib
			// cache persists it across builds via the IrFunction codec).
			if entryRef >= 0 and closureBodyInheritsImplicits 'emitClosureImplicitLoads'
				var entryBlock = try self.stdModule.blocks.get(entryRef) otherwise panic("invariant: entryRef from blockRefs not in stdModule.blocks")
				let envSlot = self.liftedEnvValueId as VarSlot
				let envBaseId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(entryBlock, op: StdOp.memory(StdMemoryOp.loadSlot(envBaseId, slotId: envSlot)))
				let captureCount = countClosureCaptures(srcFunc)
				let layoutId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(entryBlock, op: StdOp.system(StdSystemOp.loadIndirect(layoutId, addrId: envBaseId, offset: captureCount * 8, width: StoreWidth.qword, signed: false, isFloat: false)))
				self.implicitLayoutValueId = layoutId
				let constraintCount = srcFunc.implicitWitnessConstraints.count()
				for wIdx in 0 upto constraintCount 'eachWitness'
					let witnessId = allocValueId(self.funcIdRef)
					self.stdModule.appendOp(entryBlock, op: StdOp.system(StdSystemOp.loadIndirect(witnessId, addrId: envBaseId, offset: (captureCount + 1 + wIdx) * 8, width: StoreWidth.qword, signed: false, isFloat: false)))
					self.implicitWitnessValueIds.push(witnessId)
				end 'eachWitness'
			end 'emitClosureImplicitLoads'

			for blockRef in srcFunc.blockRefs 'eachBlock'
				let srcBlock = try self.maxonModule.blocks.get(blockRef) otherwise panic("invariant: blockRef from srcFunc.blockRefs not in maxonModule.blocks")
				var dstBlock = try self.stdModule.blocks.get(blockRef) otherwise panic("invariant: stdModule.blocks 1:1 with maxonModule.blocks but get({blockRef}) failed")

				for opIdx in srcBlock.opRefs 'eachOp'
					let hlOp = try self.maxonModule.ops.get(opIdx) otherwise panic("invariant: opIdx from srcBlock.opRefs not in maxonModule.ops")
					self.lowerOp(hlOp, opIdx: opIdx, dstBlock: dstBlock)
				end 'eachOp'

				if srcBlock.hasTerminatorOp() 'hasTerm'
					let termOp = try self.maxonModule.ops.get(srcBlock.terminatorIndex()) otherwise panic("invariant: terminatorIndex not in maxonModule.ops")
					self.lowerTerminator(termOp, dstBlock: dstBlock)
				end 'hasTerm'
			end 'eachBlock'
		end 'eachFunc'

		// Phase 11.3 follow-up: synthesize per-instance witness-method
		// thunks. `BuildWitnessTables` recorded one entry on
		// `project.witnessTables.gidEntries` per `(gid, interfaceName)` it
		// emitted a blob for; each entry names one thunk per interface
		// method. The thunk's body materializes the impl method's implicit
		// `(layout, witness...)` args from the instance's concrete
		// substitution and tail-calls the impl. The thunk is itself
		// non-generic so wasm's call_indirect sees a fixed type signature.
		self.synthesizeWitnessThunks()

		// Phase 9 Stage 1: emit one `__enum_<EnumName>_name` helper per enum
		// that participated in a `.name` field-load earlier in this pass.
		// Same lazy-synthesis pattern as `synthesizeWitnessThunks`, just for
		// enum reflection instead of generic dispatch.
		self.synthesizeEnumNameHelpers()

		// Function-backed enums: emit one `__enum_<EnumName>_fnRaw` helper
		// per enum that participated in a `.rawValue` field-load earlier in
		// this pass. Same lazy-synthesis pattern as the `.name` helpers.
		self.synthesizeEnumFnRawHelpers()

		// String/char-backed enums: emit one `__enum_<EnumName>_rawString`
		// helper per enum whose `.rawValue` was read earlier in this pass.
		self.synthesizeEnumRawStringHelpers()

		// Phase 9 Stage 4: emit one `__destruct_<UnionName>(self i64) returns i64`
		// per union type with at least one managed payload field. Synthesized
		// after every user-side `enumConstruct` op has already been lowered —
		// `lowerEnumConstruct` references the destructor by symbol via a
		// `funcRef` op so the destructor body must merely exist in the std
		// module by link time. Eager synthesis (one per union, no
		// "pending-set" lazy gate) is fine because the linker's reachability
		// pass drops any destructor for a union whose constructors are also
		// unreached.
		self.synthesizeUnionDestructors()

		// Phase 10 (closures): emit one `__fnref_<funcName>` thunk per
		// free function referenced via `MaxonOp.functionRef`. Each thunk
		// wraps the target with the indirect-call ABI's trailing `__env`
		// param so wasm's `call_indirect` sees a matching signature.
		self.synthesizeFnRefThunks()

		return self.stdModule
	end 'lower'

	function lowerOp(hlOp MaxonOp, opIdx OpIndex, dstBlock IrBlock)
		match hlOp 'lower'
			literal(result, value, litType, _) then self.lowerLiteral(result, value: value, litType: litType, dstBlock: dstBlock)
			stringConst(result, stringId, _) then self.lowerStringConst(result, stringId: stringId, dstBlock: dstBlock)
			charLiteral(result, stringId, _) then self.lowerCharLiteral(result, stringId: stringId, dstBlock: dstBlock)
			byteStringLiteral(result, stringId, _) then self.lowerByteStringLiteral(result, stringId: stringId, dstBlock: dstBlock)
			stringInterp(result, parts, _) then self.lowerStringInterp(result, parts: parts, dstBlock: dstBlock)
			varDecl(slotId, value, slotType, _) then self.lowerVarDeclOrStore(slotId, value: value, slotType: slotType, dstBlock: dstBlock)
			varLoad(result, slotId, slotType, _) then self.lowerVarLoad(result, slotId: slotId, slotType: slotType, dstBlock: dstBlock)
			varStore(slotId, value, _) then self.lowerVarStore(slotId, value: value, dstBlock: dstBlock)
			globalLoad(result, name, slotType, _) then self.lowerGlobalLoad(result, name: name, slotType: slotType, dstBlock: dstBlock)
			globalStore(name, value, slotType, _) then self.lowerGlobalStore(name, value: value, slotType: slotType, dstBlock: dstBlock)
			binop(result, left, right, opKind, operandType, _) then self.lowerBinop(result, left: left, right: right, opKind: opKind, operandType: operandType, dstBlock: dstBlock)
			unop(result, operand, opKind, _, _) then self.lowerUnop(result, operand: operand, opKind: opKind, dstBlock: dstBlock)
			convert(result, operand, fromType, toType, _, _) then self.lowerConvert(result, operand: operand, fromType: fromType, toType: toType, dstBlock: dstBlock)
			cmp(result, left, right, predicate, _, _, operandType, _) then self.lowerCmp(result, left: left, right: right, predicate: predicate, operandType: operandType, dstBlock: dstBlock)
			refEq(result, left, right, negate, _) then self.lowerRefEq(result, left: left, right: right, negate: negate, dstBlock: dstBlock)
			condBr(cond, thenTarget, elseTarget, _) then self.stdModule.appendOp(dstBlock, op: StdOp.control(StdControlOp.condBr(self.resolveName(cond), thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
			br(target, _) then self.stdModule.appendOp(dstBlock, op: StdOp.control(StdControlOp.br(target, argIds: ValueIdArray.create())))
			call(result, callee, _, args, argLabels, argTypes, argRanges, _) then self.lowerCall(result, callee: callee, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock)
			methodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, _) then self.lowerMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock)
			ret(retVal, _) then self.lowerRetAsBodyOp(retVal, dstBlock: dstBlock)
			panic(stringId, _) then self.lowerPanicToSys(stringId, dstBlock: dstBlock)
			panicDynamic(stringValue, _) then self.lowerPanicDynamic(stringValue, dstBlock: dstBlock)
			structAlloc(result, structName, _) then self.lowerStructAlloc(result, structName: structName, dstBlock: dstBlock)
			fieldLoad(result, receiver, fieldName, _) then self.lowerFieldLoad(result, receiver: receiver, fieldName: fieldName, dstBlock: dstBlock)
			fieldStore(receiver, fieldName, value, isInit, range) then self.lowerFieldStore(receiver, fieldName: fieldName, value: value, isInit: isInit, range: range, dstBlock: dstBlock)
			selfFieldLoad(result, fieldName, _) then self.lowerSelfFieldLoad(result, fieldName: fieldName, dstBlock: dstBlock)
			selfFieldStore(fieldName, value, _) then self.lowerSelfFieldStore(fieldName, value: value, dstBlock: dstBlock)
			// `unresolvedRead`/`unresolvedAssign` are parser-emitted placeholders
			// that the TypeResolution pass rewrites to globalLoad / globalStore /
			// constant-substitute / unknownName diagnostic before lowering runs.
			// Reaching here means the rewrite pass missed a site — pure compiler
			// bug, not a user-facing condition.
			unresolvedRead(_, name, _) then panic("lowerMaxonToStd: unresolvedRead '{name}' survived past TypeResolution")
			unresolvedAssign(name, _, _) then panic("lowerMaxonToStd: unresolvedAssign '{name}' survived past TypeResolution")
			enumMatchArm then panic("lowerMaxonToStd: enumMatchArm seen as a regular op (parser bug — should always be a terminator)")
			rangeMatchArm then panic("lowerMaxonToStd: rangeMatchArm seen as a regular op (parser bug — should always be a terminator)")
			// Phase 9 Stage 3: heap-boxed union construction + tag/payload
			// reads. enumConstruct expands to `__mm_alloc(size, null, tag)
			// + storeIndirect tag + per-field storeIndirect`; enumTag and
			// enumPayloadRead are plain loadIndirects at offsets 0 and
			// `8 + fieldIndex*8` respectively. enumPayloadStore is Stage 4
			// territory (write-back from match-arm assignment); a sighting
			// pre-Stage-4 surfaces the unimplemented edge loudly.
			enumConstruct(result, enumName, caseName, payloadValues, _) then self.lowerEnumConstruct(result, enumName: enumName, caseName: caseName, payloadValues: payloadValues, dstBlock: dstBlock)
			enumTag(result, enumValName, _) then self.lowerEnumTag(result, enumValName: enumValName, dstBlock: dstBlock)
			enumPayloadRead(result, enumValName, _, fieldIndex, fieldType, _) then self.lowerEnumPayloadRead(result, enumValName: enumValName, fieldIndex: fieldIndex, fieldType: fieldType, dstBlock: dstBlock)
			enumPayloadStore(enumValName, _, fieldIndex, fieldType, newValueName, _) then self.lowerEnumPayloadStore(enumValName, fieldIndex: fieldIndex, fieldType: fieldType, newValueName: newValueName, dstBlock: dstBlock)
			// Error anchor: the parser already reported a diagnostic at this span,
			// so we emit no Std op. `hasErrors(project)` will short-circuit the
			// batch compile before codegen; the LSP consumes the op directly
			// from the Maxon IR and never runs lowering.
			error then return
			// `throw` is always a block terminator; the parser must place it
			// via setTerminator. Reaching this match arm means the parser
			// emitted it as a regular op — pure compiler bug.
			throw then panic("lowerMaxonToStd: MaxonOp.throw seen as regular op (parser bug — should always be a terminator)")
			rethrow then panic("lowerMaxonToStd: MaxonOp.rethrow seen as regular op (parser bug - should always be a terminator)")
			tryCall(result, callee, _, args, argLabels, argTypes, argRanges, errorBoundName, _) then self.lowerTryCall(result, callee: callee, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorBoundName, opIdx: opIdx, dstBlock: dstBlock)
			tryMethodCall(result, receiver, methodName, args, argLabels, argTypes, argRanges, errorBoundName, _) then self.lowerTryMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorBoundName, opIdx: opIdx, dstBlock: dstBlock)
			// Stage E (closures): function-pointer construction, env capture,
			// and indirect-through-pointer dispatch. functionRef has no env
			// (the matching `fnEnvVarNames` entry is 0 — see lowerFunctionRef);
			// closureCreate captures by reference into a heap-allocated env
			// block; closureEnvLoad recovers a captured value via a double-
			// indirect through the lifted function's hidden `__env` slot;
			// indirectCall forwards the env from `fnEnvVarNames` to the
			// callee as the trailing arg.
			functionRef(result, funcName, _, _) then self.lowerFunctionRef(result, funcName: funcName, dstBlock: dstBlock)
			closureCreate(result, funcName, _, capturedNames, _, _) then self.lowerClosureCreate(result, funcName: funcName, capturedNames: capturedNames, dstBlock: dstBlock)
			closureEnvLoad(result, captureIndex, _, captureType, _) then self.lowerClosureEnvLoad(result, captureIndex: captureIndex, captureType: captureType, dstBlock: dstBlock)
			indirectCall(result, callee, fnTypeId, args, _, _, _, _) then self.lowerIndirectCall(result, callee: callee, fnTypeId: fnTypeId, args: args, dstBlock: dstBlock)
			// `forInIterable` is metadata-only. The parser at
			// `parseForInIterable` (Parser.maxon) already builds the full
			// createIterator/advance/current methodCall CFG into the
			// surrounding blocks — those tryMethodCall/methodCall ops
			// lower through the standard `lowerMethodCall` path, which
			// resolves to direct stdlib calls when the source's struct
			// type is concrete (e.g. `String`, `Array`). Nothing to lower
			// here.
			forInIterable then return
			// `castCheck` is a parser-emitted placeholder that the
			// `expandCastRangeChecks` pass must rewrite before lowering.
			// Reaching it here means the pass was skipped — that's a
			// pipeline-ordering bug.
			castCheck then panic("LowerMaxonToStd: castCheck reached lowering — expandCastRangeChecks did not run")
		end 'lower'
	end 'lowerOp'

	function lowerLiteral(result ByteArray, value ParsedInt, litType MaxonType, dstBlock IrBlock)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: litType))
		var opcode = StdArithConstOpcode.constI64
		if isFloat 'asFloat'
			opcode = StdArithConstOpcode.constF64
		end 'asFloat'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(opcode, resultId: resultId, value: value))))
		// Set float-ness first (it collapses the value-type to `float` or
		// `integer`), then overwrite with the precise litType so downstream
		// type-driven dispatch (e.g. `lowerUnop` for `logicalNot`) can read
		// the bool/named distinction back. Order matters: `setIsFloat`
		// calls `setValueType(id, integer)` which would otherwise wipe the
		// litType we want preserved.
		self.setIsFloat(resultId, isFloat: isFloat)
		self.setValueType(resultId, t: litType)
	end 'lowerLiteral'

	// Lower a maxon.stringConst op to a heap-allocated String struct
	// backed by an rdata-resident __ManagedMemory record. Layout matches
	// the C# bootstrap exactly:
	//   String (16): managed@0 (ptr to MM), isAsciiFlag@8 (i64 0/1)
	//   __ManagedMemory (40): buffer@0 (rdata addr), length@8,
	//     capacity@16 (-2 = rdata-backed, suppresses free), elementSize@24 (1),
	//     parentPtr@32 (0)
	// isAscii is computed at compile time by scanning the bytes; the
	// runtime scanIsAscii path is reserved for non-literal cases.
	function lowerStringConst(result ByteArray, stringId StringId, dstBlock IrBlock)
		let data = self.project.strings.get(stringId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()

		var isAsciiFlag = 1
		for i in 0 upto dataLen 'asciiScan'
			let b = try dataBytes.get(i) otherwise panic("lowerStringConst: byte get OOB at {i} (n={dataLen})")
			if b >= 0x80 'nonAscii'
				isAsciiFlag = 0
			end 'nonAscii'
		end 'asciiScan'

		let symName = addInternedString(self.globalData, stringId: stringId, data: dataBytes)
		let bufferPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufferPtrId, name: symName)))
		self.setValueType(bufferPtrId, t: MaxonType.integer)

		// Inner __ManagedMemory (40 bytes).
		let mmSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
		self.setValueType(mmSizeId, t: MaxonType.integer)
		var mmArgIds = ValueIdArray.create()
		mmArgIds.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: bufferPtrId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 8, value: dataLen, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 16, value: -2, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// Outer String (16 bytes).
		let strSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: strSizeId, value: 16))))
		self.setValueType(strSizeId, t: MaxonType.integer)
		var strArgIds = ValueIdArray.create()
		strArgIds.push(strSizeId)
		let resultId = self.defineName(result)
		self.stringLiteralProvenance.upsert(resultId, value: stringId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: strArgIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("String")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(resultId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(resultId, offset: 8, value: isAsciiFlag, dstBlock: dstBlock)
	end 'lowerStringConst'

	// Phase 7 step 6: lower a maxon.charLiteral op to a heap-allocated
	// Character struct backed by an rdata-resident __ManagedMemory record.
	// Layout mirrors lowerStringConst minus the isAsciiFlag — Character is
	// just `managed: __ManagedMemory` at offset 0 (8 bytes total):
	//   Character (8): managed@0 (ptr to MM)
	//   __ManagedMemory (40): buffer@0 (rdata addr), length@8,
	//     capacity@16 (-2 = rdata-backed, suppresses free), elementSize@24 (1),
	//     parentPtr@32 (0)
	function lowerCharLiteral(result ByteArray, stringId StringId, dstBlock IrBlock)
		let data = self.project.strings.get(stringId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()

		let symName = addInternedString(self.globalData, stringId: stringId, data: dataBytes)
		let bufferPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufferPtrId, name: symName)))
		self.setValueType(bufferPtrId, t: MaxonType.integer)

		// Inner __ManagedMemory (40 bytes).
		let mmSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
		self.setValueType(mmSizeId, t: MaxonType.integer)
		var mmArgIds = ValueIdArray.create()
		mmArgIds.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: bufferPtrId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 8, value: dataLen, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 16, value: -2, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// Outer Character (8 bytes — only the `managed` pointer field).
		let chSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: chSizeId, value: 8))))
		self.setValueType(chSizeId, t: MaxonType.integer)
		var chArgIds = ValueIdArray.create()
		chArgIds.push(chSizeId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: chArgIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("Character")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(resultId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
	end 'lowerCharLiteral'

	// Phase 7: synthesize a Character at the call site for `<int>.<charMethod>()`
	// dispatches. The receiver flows in as an integer (single-byte char literals
	// take the int fast path in `parseCharLiteralExpr`); to dispatch to a
	// Character method like `asciiValue` we need an actual Character struct.
	// Allocate the same 8-byte Character envelope as `lowerCharLiteral`, but
	// with a heap-allocated 1-byte buffer whose contents are the low byte of
	// the receiver — i.e. the codepoint cast to a byte. Capacity is 1 (heap-
	// backed, not the -2 rdata sentinel) so the standard ManagedMemory
	// destructor cleans up the buffer when the transient Character goes out
	// of scope.
	function materializeCharacterFromByte(byteId ValueId, dstBlock IrBlock) returns ValueId
		// 1-byte heap buffer holding the low byte of byteId.
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 1))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var bufArgIds = ValueIdArray.create()
		bufArgIds.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: bufArgIds)))
		self.setValueType(bufId, t: MaxonType.integer)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(bufId, offset: 0, valueId: byteId, width: StoreWidth.byte, isFloat: false)))

		// Inner __ManagedMemory (40 bytes): buffer, length=1, capacity=1
		// (heap-backed), elementSize=1, parentPtr=0.
		let mmSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
		self.setValueType(mmSizeId, t: MaxonType.integer)
		var mmArgIds = ValueIdArray.create()
		mmArgIds.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: bufId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 8, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 16, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// Outer Character (8 bytes — only the `managed` pointer field).
		let chSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: chSizeId, value: 8))))
		self.setValueType(chSizeId, t: MaxonType.integer)
		var chArgIds = ValueIdArray.create()
		chArgIds.push(chSizeId)
		let chId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(chId, callee: "mrt_alloc", argIds: chArgIds)))
		self.setValueType(chId, t: MaxonType.named(self.project.typeNames.intern("Character")))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(chId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
		return chId
	end 'materializeCharacterFromByte'

	// Phase 7 step 7: lower a maxon.byteStringLiteral op to an `Array`-shaped
	// 8-byte struct wrapping a 40-byte rdata-backed __ManagedMemory record.
	// Mirrors lowerStringConst's two-allocation pattern (inner MM at offset 0,
	// length at offset 8, capacity = -2 to flag rdata-backed, elementSize = 1
	// for byte storage). The outer `Array` wrapper means `bytes.count()`,
	// `bytes.get(i)`, etc. dispatch to Array.maxon's methods (which forward
	// to managed.length() / managed.get(i)) instead of needing a separate
	// __ManagedMemory.count() alias.
	function lowerByteStringLiteral(result ByteArray, stringId StringId, dstBlock IrBlock)
		let data = self.project.strings.get(stringId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()

		let symName = addInternedString(self.globalData, stringId: stringId, data: dataBytes)
		let bufferPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufferPtrId, name: symName)))
		self.setValueType(bufferPtrId, t: MaxonType.integer)

		// Inner __ManagedMemory (40 bytes): buffer (rdata addr), length, capacity = -2,
		// elementSize = 1, parentPtr = 0.
		let mmSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
		self.setValueType(mmSizeId, t: MaxonType.integer)
		var mmArgIds = ValueIdArray.create()
		mmArgIds.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: bufferPtrId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 8, value: dataLen, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 16, value: -2, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// Outer Array (8 bytes): managed at offset 0.
		let arrSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: arrSizeId, value: 8))))
		self.setValueType(arrSizeId, t: MaxonType.integer)
		var arrArgIds = ValueIdArray.create()
		arrArgIds.push(arrSizeId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: arrArgIds)))
		// Pin the value-type map to the same gid TypeResolution recorded for
		// the byteStringLiteral op, so downstream `bytes.count()` and
		// `bytes.get(i)` method dispatches read a bound generic instance
		// (with a layout descriptor) instead of a bare `named(Array)` — the
		// latter trips `materializeLayoutArg`'s panic. The parser leaves the
		// type unresolved; lowering matches what the resolver wrote on the op.
		self.setValueType(resultId, t: byteStringLiteralResultType(self.project))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(resultId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
	end 'lowerByteStringLiteral'

	// Phase 7 step 5: lower a maxon.stringInterp op to a heap-allocated
	// String struct whose buffer holds the concatenation of all part
	// (buffer, length) pairs. Layout matches lowerStringConst, with two
	// differences: the buffer is heap-allocated (capacity = totalLen, NOT
	// the rdata sentinel -2) and isAscii defaults to 0 (conservative —
	// matches the C# bootstrap; runtime scanIsAscii could refine later).
	//
	// Per-part materialization:
	//   literal(stringId) → globalAddr(__istr_<id>) + constI64(byteCount)
	//   expr(name, i64)   → mrt_alloc(21) + mrt_i64_to_string(value, buf)
	//                       returning the length.
	//   expr(name, byte)  → same as i64 (the value already widens to i64
	//                       via the standard call ABI).
	//   expr(name, string)    → load String.managed.buffer, .length
	//   expr(name, character) → same shape as string (Character has the same
	//                            inner __ManagedMemory layout as String).
	//   expr(name, f64/bool/u64) → not implemented in self-hosted; emit a
	//                              placeholder literal "<unsupported>" so the
	//                              build proceeds. Stdlib does not currently
	//                              interpolate these in expression position.
	function lowerStringInterp(result ByteArray, parts StringInterpPartArray, dstBlock IrBlock)
		// Empty-parts edge case: no fragments at all. Bind result to an
		// empty stringConst-shaped allocation. (Parser shouldn't produce
		// this, but be defensive — a single empty fragment with no
		// interps takes the stringConst fast path in parseStringLiteral.)
		if parts.count() == 0 'noParts'
			let emptyId = self.project.strings.intern("")
			self.lowerStringConst(result, stringId: emptyId, dstBlock: dstBlock)
			return
		end 'noParts'

		// 1. Materialize per-part (bufferPtrId, lengthId) pairs.
		var partBufIds = ValueIdArray.create()
		var partLenIds = ValueIdArray.create()
		for i in 0 upto parts.count() 'eachPart'
			let part = try parts.get(i) otherwise panic("lowerStringInterp: parts.get OOB at {i}")
			let (bufId, lenId) = self.materializeInterpPart(part, dstBlock: dstBlock)
			partBufIds.push(bufId)
			partLenIds.push(lenId)
		end 'eachPart'

		// 2. Sum total length: fold partLens into a running total.
		var totalLenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: totalLenId, value: 0))))
		self.setValueType(totalLenId, t: MaxonType.integer)
		for i in 0 upto partLenIds.count() 'sumLens'
			let pl = try partLenIds.get(i) otherwise panic("lowerStringInterp: partLenIds.get OOB at {i}")
			let nextSumId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.addI64, resultId: nextSumId, leftId: totalLenId, rightId: pl))))
			self.setValueType(nextSumId, t: MaxonType.integer)
			totalLenId = nextSumId
		end 'sumLens'

		// 3. Allocate raw buffer (totalLen + 1 for null terminator).
		let oneId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: oneId, value: 1))))
		self.setValueType(oneId, t: MaxonType.integer)
		let allocSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.addI64, resultId: allocSizeId, leftId: totalLenId, rightId: oneId))))
		self.setValueType(allocSizeId, t: MaxonType.integer)
		var bufAllocArgs = ValueIdArray.create()
		bufAllocArgs.push(allocSizeId)
		let dataBufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(dataBufId, callee: "mrt_alloc", argIds: bufAllocArgs)))
		self.setValueType(dataBufId, t: MaxonType.integer)

		// 4. Memcopy each part into the running cursor at dataBufId + offset.
		var cursorId = dataBufId
		for i in 0 upto partBufIds.count() 'copyParts'
			let pb = try partBufIds.get(i) otherwise panic("lowerStringInterp: partBufIds.get OOB at {i}")
			let pl = try partLenIds.get(i) otherwise panic("lowerStringInterp: partLenIds.get OOB at {i}")
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.memcpy(cursorId, srcId: pb, lenId: pl)))
			let nextCursorId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.addI64, resultId: nextCursorId, leftId: cursorId, rightId: pl))))
			self.setValueType(nextCursorId, t: MaxonType.integer)
			cursorId = nextCursorId
		end 'copyParts'

		// 5. Allocate inner __ManagedMemory (40 bytes) and fill its fields.
		let mmSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
		self.setValueType(mmSizeId, t: MaxonType.integer)
		var mmArgIds = ValueIdArray.create()
		mmArgIds.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: dataBufId, width: StoreWidth.qword, isFloat: false)))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 8, valueId: totalLenId, width: StoreWidth.qword, isFloat: false)))
		// capacity = totalLen (real heap-backed; NOT the rdata -2 sentinel).
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 16, valueId: totalLenId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// 6. Allocate outer String (16 bytes); bind result name to it.
		let strSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: strSizeId, value: 16))))
		self.setValueType(strSizeId, t: MaxonType.integer)
		var strArgIds = ValueIdArray.create()
		strArgIds.push(strSizeId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: strArgIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("String")))

		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(resultId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
		// isAsciiFlag = 0 (conservative — matches C# bootstrap).
		self.storeI64Const(resultId, offset: 8, value: 0, dstBlock: dstBlock)
	end 'lowerStringInterp'

	// Phase 7 step 5 helper: emit per-part (buffer, length) materialization
	// and return the produced (bufferId, lengthId) pair.
	function materializeInterpPart(part StringInterpPart, dstBlock IrBlock) returns (ValueId, ValueId)
		return match part 'p'
			literal(stringId) gives self.materializeLiteralPart(stringId, dstBlock: dstBlock)
			expr(valueName, kind, formatSpecId) gives self.materializeExprPart(valueName, kind: kind, formatSpecId: formatSpecId, dstBlock: dstBlock)
		end 'p'
	end 'materializeInterpPart'

	function materializeLiteralPart(stringId StringId, dstBlock IrBlock) returns (ValueId, ValueId)
		let data = self.project.strings.get(stringId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()
		// Empty fragment: emit a zero-length pair pointing at any non-null
		// buffer (we use a freshly-allocated 0-length symbol via the
		// interner — the memcpy of length 0 is a no-op on every backend).
		// Reuse `addInternedString` so the symbol is the same as for any
		// other empty-fragment site.
		let symName = addInternedString(self.globalData, stringId: stringId, data: dataBytes)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufId, name: symName)))
		self.setValueType(bufId, t: MaxonType.integer)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: lenId, value: dataLen))))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeLiteralPart'

	function materializeExprPart(valueName ByteArray, kind InterpExprKind, formatSpecId StringId, dstBlock IrBlock) returns (ValueId, ValueId)
		let valueId = self.resolveName(valueName)
		let hasFormat = not self.project.strings.get(formatSpecId).isEmpty()
		// Char-byte override: a value whose source was a single-byte char
		// literal carries the codepoint as a raw integer (so byte
		// comparisons compile without coercions), but interpolation has
		// to print the character glyph, not the codepoint integer. Probe
		// `project.charByteLiterals` first so the `kind = i64` arm doesn't
		// fire for `print("{c}\n")` on `let c = 'A'`. Producer-side type
		// resolution still tags the value as `integer`, so we sidestep
		// the kind-based dispatch entirely when the provenance set has
		// the name.
		if self.project.charByteLiterals.contains(charByteLiteralKey(self.currentFuncName, valueName: valueName)) 'isCharByte'
			return self.materializeCharByteInterp(valueId, dstBlock: dstBlock)
		end 'isCharByte'
		return match kind 'k'
			i64 gives self.materializeIntToStringMaybeFmt(valueId, formatSpecId: formatSpecId, hasFormat: hasFormat, dstBlock: dstBlock)
			u64 gives self.materializeIntToStringMaybeFmt(valueId, formatSpecId: formatSpecId, hasFormat: hasFormat, dstBlock: dstBlock)
			string gives self.materializeStringStructPart(valueId, dstBlock: dstBlock)
			character gives self.materializeStringStructPart(valueId, dstBlock: dstBlock)
			f64 gives self.materializeFloatToStringMaybeFmt(valueId, formatSpecId: formatSpecId, hasFormat: hasFormat, dstBlock: dstBlock)
			bool gives self.materializeBoolToString(valueId, dstBlock: dstBlock)
			stringable gives self.materializeStringableInterpMaybeFmt(valueId, formatSpecId: formatSpecId, hasFormat: hasFormat, dstBlock: dstBlock)
			enumName gives self.materializeEnumNameInterpMaybeFmt(valueId, formatSpecId: formatSpecId, hasFormat: hasFormat, dstBlock: dstBlock)
			// charByte: reached only when TR has refined the kind to
			// charByte (which it doesn't yet). Kept for union completeness
			// and as a fallback for any future TR-level refinement that
			// wants to commit to the kind. Functionally identical to the
			// early-return branch above.
			charByte gives self.materializeCharByteInterp(valueId, dstBlock: dstBlock)
		end 'k'
	end 'materializeExprPart'

	// Stringable user type in an interpolation slot: dispatch the type's
	// `toString()` through its witness table and use the returned String's
	// `managed` buffer/length. Mirrors `lowerInterfaceMethodCall` for the
	// witnessCall opcode but specialized to the concrete (non-interface)
	// receiver case — the value flowing in is the struct heap pointer
	// itself, not a fat-pointer pair, so we materialize the witness from
	// the value's recorded MaxonType.
	function materializeStringableInterp(structValueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let concreteType = self.getValueType(structValueId)
		let witnessAddrId = self.materializeInterfaceWitness(concreteType, interfaceName: "Stringable", dstBlock: dstBlock)
		let methodIdx = methodIndexInInterface(self.project, interfaceName: "Stringable", methodName: "toString")
		var argIds = ValueIdArray.create()
		argIds.push(structValueId)
		let stringResultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.witnessCall(stringResultId, witnessAddrId: witnessAddrId, methodIndex: methodIdx, isVoid: false, argIds: argIds)))
		self.setValueType(stringResultId, t: MaxonType.named(self.project.typeNames.intern("String")))
		return self.materializeStringStructPart(stringResultId, dstBlock: dstBlock)
	end 'materializeStringableInterp'

	// Phase 7 step 5 — Stringable + format spec. When the user type
	// implements `FormattedStringable`, route through `toString(format)`
	// on that witness table; the format-spec literal is materialized as a
	// `String` struct and passed as the second argument. When the user
	// type only implements `Stringable`, the format spec is silently
	// ignored (matches the C# bootstrap's fallback choice — the spec is
	// not part of the displayed value, so dropping it preserves the
	// uninstrumented `toString()` output).
	function materializeStringableInterpMaybeFmt(structValueId ValueId, formatSpecId StringId, hasFormat bool, dstBlock IrBlock) returns (ValueId, ValueId)
		if not hasFormat 'noFmt'
			return self.materializeStringableInterp(structValueId, dstBlock: dstBlock)
		end 'noFmt'
		let concreteType = self.getValueType(structValueId)
		let concreteTypeName = match concreteType 'name'
			named(id) gives self.project.typeNames.get(id)
			boolean to string gives ""
			function to opaquePointer gives ""
		end 'name'
		if concreteTypeName.isEmpty() or not self.project.conformances.contains(concreteTypeName, interfaceName: "FormattedStringable") 'noFmtIface'
			return self.materializeStringableInterp(structValueId, dstBlock: dstBlock)
		end 'noFmtIface'
		let witnessAddrId = self.materializeInterfaceWitness(concreteType, interfaceName: "FormattedStringable", dstBlock: dstBlock)
		let methodIdx = methodIndexInInterface(self.project, interfaceName: "FormattedStringable", methodName: "toString")
		let fmtStringId = self.materializeFormatSpecAsString(formatSpecId, dstBlock: dstBlock)
		var argIds = ValueIdArray.create()
		argIds.push(structValueId)
		argIds.push(fmtStringId)
		let stringResultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.witnessCall(stringResultId, witnessAddrId: witnessAddrId, methodIndex: methodIdx, isVoid: false, argIds: argIds)))
		self.setValueType(stringResultId, t: MaxonType.named(self.project.typeNames.intern("String")))
		return self.materializeStringStructPart(stringResultId, dstBlock: dstBlock)
	end 'materializeStringableInterpMaybeFmt'

	// Build a heap-allocated `String` struct around the interned format-spec
	// bytes so they can be passed as a String argument to a witness method
	// (`FormattedStringable.toString(format String)`). Uses the same outer-
	// String+__ManagedMemory+rdata-buffer shape `materializeStringStructPart`
	// expects to unpack: an rdata-backed ManagedMemory record with
	// capacity/refcount sentinels chosen to match a literal slice.
	function materializeFormatSpecAsString(formatSpecId StringId, dstBlock IrBlock) returns ValueId
		let data = self.project.strings.get(formatSpecId)
		let dataBytes = data.toByteArray()
		let dataLen = dataBytes.count()
		let symName = addInternedString(self.globalData, stringId: formatSpecId, data: dataBytes)

		let bufPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufPtrId, name: symName)))
		self.setValueType(bufPtrId, t: MaxonType.integer)
		let lenConstId = self.emitConstI64(dataLen, dstBlock: dstBlock)

		// __ManagedMemory(40): buffer@0, length@8, capacity@16 = -2 (rdata
		// sentinel), refcount@24 = 1, parentPtr@32 = 0.
		let mmSizeId = self.emitConstI64(40, dstBlock: dstBlock)
		var mmArgs = ValueIdArray.create()
		mmArgs.push(mmSizeId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgs)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 0, valueId: bufPtrId, width: StoreWidth.qword, isFloat: false)))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmId, offset: 8, valueId: lenConstId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmId, offset: 16, value: -2, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: 1, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)

		// Outer String(16): _managed@0 = mmId, isAsciiFlag@8 = 0.
		let strSizeId = self.emitConstI64(16, dstBlock: dstBlock)
		var strArgs = ValueIdArray.create()
		strArgs.push(strSizeId)
		let strId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(strId, callee: "mrt_alloc", argIds: strArgs)))
		self.setValueType(strId, t: MaxonType.named(self.project.typeNames.intern("String")))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(strId, offset: 0, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(strId, offset: 8, value: 0, dstBlock: dstBlock)
		return strId
	end 'materializeFormatSpecAsString'

	// Phase 7 step 5 — enum + format spec. Reuses the existing enum path
	// for the no-format case. With a format spec, an enum case backed by
	// explicit rawValues is stringified with the formatted-int helper
	// (matches the `{code:04}` shape — the user wrote `:04`, they want
	// the raw int padded). Implicit-ordinal enums currently drop the
	// format spec because the select-chain over case-name rdata literals
	// doesn't have a numeric value to format against.
	function materializeEnumNameInterpMaybeFmt(enumValueId ValueId, formatSpecId StringId, hasFormat bool, dstBlock IrBlock) returns (ValueId, ValueId)
		if not hasFormat 'noFmt'
			return self.materializeEnumNameInterp(enumValueId, dstBlock: dstBlock)
		end 'noFmt'
		let enumType = self.getValueType(enumValueId)
		let enumTypeName = match enumType 'name'
			named(id) gives self.project.typeNames.get(id)
			boolean to string gives ""
			function to opaquePointer gives ""
		end 'name'
		if not enumTypeName.isEmpty() and self.project.enumTypes.contains(enumTypeName) 'hasEnumDef'
			let enumDef = try self.project.enumTypes.get(enumTypeName) otherwise panic("materializeEnumNameInterpMaybeFmt: enum '{enumTypeName}' missing from project.enumTypes")
			// String / char backings render their literal text, which has
			// no numeric value to format against. Drop the format spec and
			// fall through to the select-chain path (mirrors the implicit
			// ordinal case in `materializeEnumNameInterp`).
			let useStringLiteralBacking = enumDef.isStringBacked or enumDef.isCharBacked
			if enumHasExplicitBacking(enumDef) and not useStringLiteralBacking 'rawValueMode'
				return self.materializeIntToStringFmt(enumValueId, formatSpecId: formatSpecId, dstBlock: dstBlock)
			end 'rawValueMode'
		end 'hasEnumDef'
		return self.materializeEnumNameInterp(enumValueId, dstBlock: dstBlock)
	end 'materializeEnumNameInterpMaybeFmt'

	// Enum value in an interpolation slot. Three sub-cases, picked at
	// lowering time from the enum's declared backing kind:
	//   1. Implicit-ordinal enums (no `= N` on any case) — emit a select
	//      chain mapping the runtime value to the declared case name rdata
	//      literal. Each chain step is
	//      `(buf, len) = (val == raw) ? (caseBuf, caseLen) : (prevBuf, prevLen)`,
	//      initialized to a "?" fallback so out-of-range ordinals print legibly.
	//   2. Explicit-int / float-backing enums — stringify the runtime
	//      int / float directly via mrt_i64_to_string. Matches the
	//      bootstrap's "explicit raw values print as the raw value" rule
	//      so user-tagged enums (e.g. error codes, protocol bytes) keep
	//      their numeric semantics in `print("{x}")`.
	//   3. String / char backing — same select-chain shape as the implicit
	//      case, but the per-case rdata literal is the declared raw text
	//      (`"Active"` / `'A'`) instead of the case-identifier spelling.
	//      Runtime rep is the ordinal so the ordinal compare drives the
	//      select.
	function materializeEnumNameInterp(enumValueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let enumType = self.getValueType(enumValueId)
		let enumTypeName = match enumType 'name'
			named(id) gives self.project.typeNames.get(id)
			boolean to string gives ""
			function to opaquePointer gives ""
		end 'name'
		if enumTypeName.isEmpty() 'noName'
			panic("materializeEnumNameInterp: value id={enumValueId} has no named MaxonType — type-resolution should have classified it as plain integer")
		end 'noName'
		let enumDef = try self.project.enumTypes.get(enumTypeName) otherwise panic("materializeEnumNameInterp: enum '{enumTypeName}' missing from project.enumTypes despite interpKindForNamedTypeName classifying it")

		// Numeric-backing fast path: explicit int / float raw values
		// stringify directly. String / char backings keep the select-chain
		// form so the displayed text is the user-declared literal, not the
		// underlying ordinal.
		let useStringLiteralBacking = enumDef.isStringBacked or enumDef.isCharBacked
		if enumHasExplicitBacking(enumDef) and not useStringLiteralBacking 'rawValueMode'
			return self.materializeIntToString(enumValueId, dstBlock: dstBlock)
		end 'rawValueMode'

		let fallbackId = self.project.strings.intern("?")
		var fallbackBytes = ByteArray.create()
		fallbackBytes.push(0x3F)
		let fallbackSym = addInternedString(self.globalData, stringId: fallbackId, data: fallbackBytes)
		var currentBufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(currentBufId, name: fallbackSym)))
		self.setValueType(currentBufId, t: MaxonType.integer)
		var currentLenId = self.emitConstI64(1, dstBlock: dstBlock)

		for i in 0 upto enumDef.cases.count() 'eachCase'
			let theCase = try enumDef.cases.get(i) otherwise panic("materializeEnumNameInterp: cases.get OOB at {i}")
			let renderedStr = theCase.rawStringValue if useStringLiteralBacking else theCase.name
			let renderedBytes = renderedStr.toByteArray()
			let renderedStringId = self.project.strings.intern(renderedStr)
			let caseSym = addInternedString(self.globalData, stringId: renderedStringId, data: renderedBytes)
			let caseBufId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(caseBufId, name: caseSym)))
			self.setValueType(caseBufId, t: MaxonType.integer)
			let caseLenId = self.emitConstI64(renderedBytes.count(), dstBlock: dstBlock)
			// Match the runtime value the parser laid down for the case —
			// the ordinal, which is what default / string / char backed
			// enums store at runtime.
			let caseConstId = self.emitConstI64(theCase.ordinal as ParsedInt, dstBlock: dstBlock)
			let cmpId = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Eq, leftId: enumValueId, rightId: caseConstId, dstBlock: dstBlock)
			currentBufId = self.emitArithmeticSelect(cmpId, trueVal: caseBufId, falseVal: currentBufId, dstBlock: dstBlock)
			currentLenId = self.emitArithmeticSelect(cmpId, trueVal: caseLenId, falseVal: currentLenId, dstBlock: dstBlock)
		end 'eachCase'
		return (currentBufId, currentLenId)
	end 'materializeEnumNameInterp'

	// Interpolation lowering for a char-byte value: allocate a 1-byte buffer,
	// store the low byte of the int codepoint into it, and return the buffer
	// + a constant length of 1 so the outer concatenation memcopies just that
	// byte. Caller (parser → TR) only routes this arm for ASCII single-byte
	// char literals — multi-byte chars take `MaxonType.named("Character")`
	// and the `character` interp arm via `materializeStringStructPart`.
	function materializeCharByteInterp(valueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 1))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(bufId, offset: 0, valueId: valueId, width: StoreWidth.byte, isFloat: false)))
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: lenId, value: 1))))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeCharByteInterp'

	// Heap-allocate a 21-byte buffer, call mrt_i64_to_string(value, buf) →
	// length, and return (buf, length). 21 bytes covers the worst-case
	// decimal i64 encoding (-9223372036854775808 = 20 chars + sign).
	function materializeIntToString(valueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 21))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		var convArgs = ValueIdArray.create()
		convArgs.push(valueId)
		convArgs.push(bufId)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(lenId, callee: "mrt_i64_to_string", argIds: convArgs)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeIntToString'

	// Recover (buffer, length) from a heap-allocated String / Character
	// value. Both types share the layout: outer struct's offset 0 holds a
	// pointer to a __ManagedMemory (40 bytes) whose offset 0 is the raw
	// byte buffer pointer and offset 8 is the i64 length.
	function materializeStringStructPart(structValueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let mmId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(mmId, addrId: structValueId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(mmId, t: MaxonType.integer)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(bufId, addrId: mmId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(bufId, t: MaxonType.integer)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(lenId, addrId: mmId, offset: 8, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeStringStructPart'

	// Heap-allocate a 32-byte buffer, call mrt_f64_to_string(value, buf) →
	// length, return (buf, length). 32 bytes covers sign + ~17 integer
	// digits + '.' + 6 fractional digits with margin.
	function materializeFloatToString(valueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 32))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		var convArgs = ValueIdArray.create()
		convArgs.push(valueId)
		convArgs.push(bufId)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(lenId, callee: "mrt_f64_to_string", argIds: convArgs)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeFloatToString'

	// Phase 7 step 5 — formatted-integer dispatcher. Splits between the
	// fast `mrt_i64_to_string` path (no format spec) and the formatted
	// path (`mrt_i64_to_string_fmt(value, buf, fmt_ptr, fmt_len)`). The
	// formatted helper supports widths, zero-pad, and {x,X,b,o,d} type
	// characters per the C# bootstrap's `maxon_i64_to_string_fmt`.
	function materializeIntToStringMaybeFmt(valueId ValueId, formatSpecId StringId, hasFormat bool, dstBlock IrBlock) returns (ValueId, ValueId)
		if not hasFormat 'fast'
			return self.materializeIntToString(valueId, dstBlock: dstBlock)
		end 'fast'
		return self.materializeIntToStringFmt(valueId, formatSpecId: formatSpecId, dstBlock: dstBlock)
	end 'materializeIntToStringMaybeFmt'

	// Heap-allocate a 72-byte buffer (matches the C# bootstrap's worst-case
	// padded-binary i64 budget), stage the format-spec bytes in rdata via
	// the interner, and call `mrt_i64_to_string_fmt(value, buf, fmt_ptr,
	// fmt_len) → length`. The helper itself parses the spec at runtime —
	// the compiler-side only plumbs the spec through.
	function materializeIntToStringFmt(valueId ValueId, formatSpecId StringId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufId = self.allocFmtBuffer(dstBlock)
		let (fmtPtrId, fmtLenId) = self.materializeFormatSpecBuffer(formatSpecId, dstBlock: dstBlock)
		var convArgs = ValueIdArray.create()
		convArgs.push(valueId)
		convArgs.push(bufId)
		convArgs.push(fmtPtrId)
		convArgs.push(fmtLenId)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(lenId, callee: "mrt_i64_to_string_fmt", argIds: convArgs)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeIntToStringFmt'

	// Phase 7 step 5 — formatted-float dispatcher. Mirrors the int variant.
	function materializeFloatToStringMaybeFmt(valueId ValueId, formatSpecId StringId, hasFormat bool, dstBlock IrBlock) returns (ValueId, ValueId)
		if not hasFormat 'fast'
			return self.materializeFloatToString(valueId, dstBlock: dstBlock)
		end 'fast'
		return self.materializeFloatToStringFmt(valueId, formatSpecId: formatSpecId, dstBlock: dstBlock)
	end 'materializeFloatToStringMaybeFmt'

	function materializeFloatToStringFmt(valueId ValueId, formatSpecId StringId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufId = self.allocFmtBuffer(dstBlock)
		let (fmtPtrId, fmtLenId) = self.materializeFormatSpecBuffer(formatSpecId, dstBlock: dstBlock)
		var convArgs = ValueIdArray.create()
		convArgs.push(valueId)
		convArgs.push(bufId)
		convArgs.push(fmtPtrId)
		convArgs.push(fmtLenId)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(lenId, callee: "mrt_f64_to_string_fmt", argIds: convArgs)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeFloatToStringFmt'

	// Heap-allocate the 72-byte scratch buffer used by both formatted
	// runtime helpers. Worst-case budget = sign + 64-digit binary + null
	// + slack (well under 72).
	function allocFmtBuffer(dstBlock IrBlock) returns ValueId
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 72))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		return bufId
	end 'allocFmtBuffer'

	// Materialize an interned format-spec string as (rdata-ptr, byte-length)
	// suitable for passing to `mrt_*_to_string_fmt`. Reuses the standard
	// string interner so identical specs collapse to one rdata entry.
	function materializeFormatSpecBuffer(formatSpecId StringId, dstBlock IrBlock) returns (ValueId, ValueId)
		let data = self.project.strings.get(formatSpecId)
		let dataBytes = data.toByteArray()
		let symName = addInternedString(self.globalData, stringId: formatSpecId, data: dataBytes)
		let fmtPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(fmtPtrId, name: symName)))
		self.setValueType(fmtPtrId, t: MaxonType.integer)
		let fmtLenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: fmtLenId, value: dataBytes.count()))))
		self.setValueType(fmtLenId, t: MaxonType.integer)
		return (fmtPtrId, fmtLenId)
	end 'materializeFormatSpecBuffer'

	// Heap-allocate a 5-byte buffer, call mrt_bool_to_string(value, buf) →
	// length (4 for "true", 5 for "false"), return (buf, length).
	function materializeBoolToString(valueId ValueId, dstBlock IrBlock) returns (ValueId, ValueId)
		let bufSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: bufSizeId, value: 5))))
		self.setValueType(bufSizeId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(bufSizeId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		var convArgs = ValueIdArray.create()
		convArgs.push(valueId)
		convArgs.push(bufId)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(lenId, callee: "mrt_bool_to_string", argIds: convArgs)))
		self.setValueType(lenId, t: MaxonType.integer)
		return (bufId, lenId)
	end 'materializeBoolToString'

	// C1.c: dispatch the varDecl op. For interface-typed slots, route
	// through fat-pointer construction so the slot stores the value (or
	// box pointer if width > 8) at slot N and the witness pointer at the
	// companion slot. For all other slots, emit the plain storeSlot the
	// previous code path emitted.
	function lowerVarDeclOrStore(slotId VarSlot, value ByteArray, slotType MaxonType, dstBlock IrBlock)
		if interfaceTypeIsFat(slotType) 'fat'
			self.lowerInterfaceSlotStore(slotId, value: value, slotType: slotType, dstBlock: dstBlock)
			return
		end 'fat'
		let valueId = self.resolveName(value)
		self.captureClosureEnvIfFunctionTyped(slotId, valueId: valueId, slotType: slotType)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: valueId)))
	end 'lowerVarDeclOrStore'

	// Propagate function-value env binding across a slot store. When the
	// RHS is a `closureCreate` / `functionRef` result, its env was recorded
	// in `fnEnvVarNames` keyed by the value id. Park the env id under the
	// destination slot so `lowerVarLoad`'s pairEnv path can recover it
	// without confusing the slot id with an unrelated `fnEnvVarNames`
	// ValueId-keyed entry. No-op for non-function slot types and for stores
	// whose RHS has no recorded env (top-level functionRef, plain call
	// return, etc. — those flow `env=0` through `noEnvSlot` at load time).
	function captureClosureEnvIfFunctionTyped(slotId VarSlot, valueId ValueId, slotType MaxonType)
		// Chase function-type aliases so a store into an aliased function-typed
		// slot (e.g. `let c = cmp` where cmp is `SortComparator`) still parks
		// the env binding for the subsequent load.
		if not isFunctionMaxonType(chaseTypealiasToFunctionType(self.project, t: slotType)) 'notFunction'
			return
		end 'notFunction'
		if let envValueId = try self.fnEnvVarNames.get(valueId) 'capturedEnv'
			self.closureSlotToEnvValueId.upsert(slotId, value: envValueId)
		end 'capturedEnv'
	end 'captureClosureEnvIfFunctionTyped'

	// C1.c: dispatch the varStore op. The op itself doesn't carry a
	// slotType — recover it from `currentMaxonFunc.slotMaxonTypes` so we
	// can route interface-typed stores through fat-pointer construction.
	// A miss in slotMaxonTypes (synthesized parser internals never
	// declared via `varDecl`) falls back to the plain non-interface
	// path, which is correct because such slots can't carry an interface
	// type today.
	function lowerVarStore(slotId VarSlot, value ByteArray, dstBlock IrBlock)
		let slotType = self.lookupSlotMaxonType(slotId)
		if interfaceTypeIsFat(slotType) 'fat'
			self.lowerInterfaceSlotStore(slotId, value: value, slotType: slotType, dstBlock: dstBlock)
			return
		end 'fat'
		// Phase A widening: when this varStore feeds a slot whose declared
		// MaxonType is a float (e.g. a match-expression result slot whose
		// type was widened to float across arms) and the incoming value is
		// an int, splice in an siToFp so float bits land in the slot. Mirror
		// of the C# bootstrap's match-arm-result auto-widening — the slot
		// type is computed by TypeResolution's `recordVarStore` pass, which
		// upgrades int→float when any arm produces a float value.
		let storedValueId = self.resolveName(value)
		let storedValueType = self.getValueType(storedValueId)
		let widenedValueId = self.widenValueToType(storedValueId, fromType: storedValueType, toType: slotType, dstBlock: dstBlock)
		self.captureClosureEnvIfFunctionTyped(slotId, valueId: storedValueId, slotType: slotType)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: widenedValueId)))
	end 'lowerVarStore'

	function lookupSlotMaxonType(slotId VarSlot) returns MaxonType
		// slotMaxonTypes is populated for every slot the parser declared, so
		// an out-of-bounds read here means the lowering pass is querying a
		// slot the parser never registered — a compiler-internal invariant
		// violation. Silently returning `integer` used to corrupt the
		// downstream interface-fat-pointer detection.
		if slotId >= self.currentMaxonFunc.slotMaxonTypes.count() 'oob'
			panic("lookupSlotMaxonType: slotId {slotId} >= slotMaxonTypes.count() ({self.currentMaxonFunc.slotMaxonTypes.count()}) in func '{self.currentMaxonFunc.name}'")
		end 'oob'
		return try self.currentMaxonFunc.slotMaxonTypes.get(slotId) otherwise panic("lookupSlotMaxonType: slotMaxonTypes.get({slotId}) failed despite the in-bounds check in func '{self.currentMaxonFunc.name}'")
	end 'lookupSlotMaxonType'

	// C1.c: emit a fat-pointer store for an interface-typed slot. Two
	// stores: slot N holds the value (or box pointer for payloads
	// larger than 8 bytes), companion slot M holds the witness-table
	// address. The witness label is resolved through
	// `project.witnessTables` keyed on the RHS's concrete MaxonType and
	// the slot's interface name. When the RHS is itself interface-
	// typed (forwarding an existing fat pointer), we propagate the
	// existing witness rather than re-resolving — the parser-level
	// type system enforces interface-supertype compatibility.
	function lowerInterfaceSlotStore(slotId VarSlot, value ByteArray, slotType MaxonType, dstBlock IrBlock)
		let interfaceName = match slotType 'iface'
			interface(id) gives self.project.interfaceRegistry.getName(id)
			default panic("lowerInterfaceSlotStore: slotType is not interface despite the dispatch guard")
		end 'iface'
		let valueId = self.resolveName(value)
		let concreteType = self.getValueType(valueId)
		let companionSlot = try self.interfaceWitnessSlots.get(slotId) otherwise panic("lowerInterfaceSlotStore: slot {slotId} interface-typed but no witness companion in interfaceWitnessSlots — extendSlotsForInterfaceWitnesses did not run, or buildInterfaceWitnessSlotMap is out of sync")
		// Forwarding case: the RHS is itself interface-typed (already a fat
		// pointer from a varLoad, interface-returning call, or interface-
		// returning method call). Re-resolving the witness via
		// `materializeInterfaceWitness(interface(P), P)` would look up a
		// witness table for `(Producer, Producer)` that doesn't exist and
		// soft-fail to a null witness — corrupting later dispatch. Instead,
		// forward the already-paired witness ValueId. The pairing is seeded
		// by `lowerVarLoad` (for slot loads) and by `emitCallWithArgs`
		// (for interface-returning call results).
		if interfaceTypeIsFat(concreteType) 'forwardFat'
			let forwardedWitness = try self.interfaceWitnessValueIds.get(valueId) otherwise panic("lowerInterfaceSlotStore: source valueId={valueId} typed as interface but no witness paired in interfaceWitnessValueIds")
			self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: valueId)))
			self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(companionSlot, valueId: forwardedWitness)))
			return
		end 'forwardFat'
		let payloadId = self.materializeInterfacePayload(valueId, concreteType: concreteType, dstBlock: dstBlock)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(slotId, valueId: payloadId)))
		let witnessId = self.materializeInterfaceWitness(concreteType, interfaceName: interfaceName, dstBlock: dstBlock)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.storeSlot(companionSlot, valueId: witnessId)))
	end 'lowerInterfaceSlotStore'

	// C1.d: produce the witness half of a fat-pointer arg passed to a
	// function with an interface-typed parameter. When the arg's
	// underlying value is itself interface-typed (forward of an existing
	// fat pointer), the witness was paired in `interfaceWitnessValueIds`
	// at varLoad time; recover it. When the arg is concrete, materialize
	// the witness via the (concreteType, interfaceName) witness-table
	// lookup. Same as the slot-store construction path, just routed
	// through the call-site rather than a varDecl/varStore.
	function witnessForInterfaceArg(valueId ValueId, paramType MaxonType, dstBlock IrBlock) returns ValueId
		let interfaceName = match paramType 'iface'
			interface(id) gives self.project.interfaceRegistry.getName(id)
			default panic("witnessForInterfaceArg: paramType is not interface despite the dispatch guard")
		end 'iface'
		let argType = self.getValueType(valueId)
		if interfaceTypeIsFat(argType) 'isFatForward'
			return try self.interfaceWitnessValueIds.get(valueId) otherwise panic("witnessForInterfaceArg: arg valueId={valueId} typed as interface but no witness paired in interfaceWitnessValueIds")
		end 'isFatForward'
		return self.materializeInterfaceWitness(argType, interfaceName: interfaceName, dstBlock: dstBlock)
	end 'witnessForInterfaceArg'

	// C1.c: produce the value half of a fat pointer. For payloads that
	// fit in 8 bytes, this is the value itself. For wider payloads, the
	// value is materialized into a refcounted box and the box pointer
	// becomes the slot value. Today's only callers are the slot-store
	// path; the dispatch (C1.d) reads back through the same path.
	function materializeInterfacePayload(valueId ValueId, concreteType MaxonType, dstBlock IrBlock) returns ValueId
		let widthBytes = maxonTypeWidthBytes(self.project, t: concreteType)
		if widthBytes <= 8 'fitsInline'
			return valueId
		end 'fitsInline'
		let sizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: sizeId, value: widthBytes))))
		self.setValueType(sizeId, t: MaxonType.integer)
		let boxId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.boxValue(boxId, valueId: valueId, sizeId: sizeId)))
		self.setValueType(boxId, t: MaxonType.integer)
		return boxId
	end 'materializeInterfacePayload'

	// C1.c: produce the witness half of a fat pointer. Resolves the
	// witness-table label via `project.witnessTables.labelFor` and
	// emits a `loadWitnessTable` to materialize the address. When the
	// RHS is itself interface-typed (already a fat pointer), the
	// witness companion slot of the source is the right value to
	// forward — but this lowering is invoked only for construction,
	// where the RHS is by definition concrete. Forwarding the source
	// witness is C1.d territory.
	function materializeInterfaceWitness(concreteType MaxonType, interfaceName String, dstBlock IrBlock) returns ValueId
		let resultId = allocValueId(self.funcIdRef)
		if let label = try resolveWitnessLabel(self.project, concreteType: concreteType, interfaceName: interfaceName) 'haveLabel'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadWitnessTable(resultId, label: label)))
			self.setValueType(resultId, t: MaxonType.opaquePointer)
			return resultId
		end 'haveLabel'
		// C1.d soft-fail: no witness table for this (concrete, interface)
		// pair (transitive parent-conformance not seeded, or primitive-
		// extension gap deferred to C1.e). Emit a zero constant so the
		// build completes; any actual dispatch through this witness will
		// surface at runtime when the load dereferences null. The pre-
		// existing monomorphization pipeline still handles direct calls
		// correctly — this soft-fail keeps interface-arm propagation
		// non-fatal.
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.opaquePointer)
		return resultId
	end 'materializeInterfaceWitness'

	function lowerVarLoad(result ByteArray, slotId VarSlot, slotType MaxonType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(resultId, slotId: slotId)))
		// Carry the slot's full type (named/struct, not just int-vs-float) into
		// the value-type map so downstream consumers (fieldLoad/Store, methodCall)
		// can resolve the receiver type.
		self.setValueType(resultId, t: slotType)
		// C1.d: when the slot is interface-typed (fat-pointer), the load just
		// emitted reads only the value half. Emit a sibling load of the
		// witness companion slot and stash the (resultId → witnessId)
		// pairing so a downstream methodCall can dispatch through the
		// witness without re-walking back to the slot. The witness slot is
		// always the companion in `interfaceWitnessSlots`; a miss there
		// means this load is reading a synthetic interface slot the
		// witness-slot extender never widened — which would be a compiler
		// bug, surfaced as a hard panic so we don't silently dispatch
		// against a stale value.
		if interfaceTypeIsFat(slotType) 'pairWitness'
			let witnessSlot = try self.interfaceWitnessSlots.get(slotId) otherwise panic("lowerVarLoad: slot {slotId} interface-typed but no witness companion in interfaceWitnessSlots — extendSlotsForInterfaceWitnesses did not run, or buildInterfaceWitnessSlotMap is out of sync")
			let witnessLoadId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(witnessLoadId, slotId: witnessSlot)))
			self.setValueType(witnessLoadId, t: MaxonType.opaquePointer)
			self.interfaceWitnessValueIds.upsert(resultId, value: witnessLoadId)
		end 'pairWitness'
		// Stage E (closures): if this load reads a function-typed param,
		// emit a sibling load of the matching env-pointer slot and bind
		// the (resultId → envLoadId) pair in `fnEnvVarNames`. The
		// indirectCall lowering then forwards the env to the callee
		// without consulting the param-id directly. This keeps the
		// fn-pointer-flow well-formed even when the value passes through
		// var copies, struct-field stores, etc. — every load resolves to
		// a fresh env binding rooted at the original param.
		// Chase `named(alias)` to its underlying function type before deciding
		// — a param/local declared via a function-type alias (e.g. `cmp
		// SortComparator`) must still pair its env companion. Mirrors the
		// alias-chase gate in `slotArgsForCall` and `seedParams`.
		let chasedSlotType = chaseTypealiasToFunctionType(self.project, t: slotType)
		if isFunctionMaxonType(chasedSlotType) 'pairEnv'
			// slot<->abi decoupling: a PARAM scope slot is a key in
			// scopeSlotToAbiParamIndex (body locals are absent), and its
			// env-companion scope slot is recorded in `paramSlotToEnvSlot`
			// (scope-slot keyed — kept SEPARATE from the ValueId-keyed
			// fnEnvVarNames to avoid key-space collisions). Load the env from
			// that companion slot and bind (resultId -> envLoadId) into
			// fnEnvVarNames (ValueId-keyed) for the indirect-call site. For
			// LOCAL slots holding a function value flowed in from a
			// closureCreate / functionRef, closureSlotToEnvValueId records the
			// env's SSA ValueId — reuse it without a loadSlot.
			if self.currentMaxonFunc.scopeSlotToAbiParamIndex.contains(slotId) 'paramSlot'
				if let envSlot = try self.paramSlotToEnvSlot.get(slotId) 'paramHasEnv'
					let envLoadId = allocValueId(self.funcIdRef)
					self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(envLoadId, slotId: envSlot)))
					self.fnEnvVarNames.upsert(resultId, value: envLoadId)
				end 'paramHasEnv' else 'paramNoEnv'
					let envZeroId = self.emitConstI64(0, dstBlock: dstBlock)
					self.fnEnvVarNames.upsert(resultId, value: envZeroId)
				end 'paramNoEnv'
			end 'paramSlot' else if let envValueId = try self.closureSlotToEnvValueId.get(slotId) 'closureLocalHasEnv'
				// Local slot was last stored from a closureCreate / functionRef
				// whose env binding is already a real SSA value. Reuse it
				// directly — no loadSlot needed, and no new const-0 sentinel.
				self.fnEnvVarNames.upsert(resultId, value: envValueId)
			end 'closureLocalHasEnv' else 'noEnvSlot'
				// Function-typed local that wasn't bound to a paired env slot:
				// the value flowed in from a top-level function reference
				// (functionRef) or a non-closure call return, both of which
				// carry an implicit env=0. Materialize a `const 0` op here
				// so the env binding points at a real SSA definition — using
				// a bare ValueId `0` as a sentinel collides with the actual
				// SSA value 0 in any function whose ValueIds start at 0,
				// breaking regalloc when that v0 isn't defined locally.
				let envZeroId = self.emitConstI64(0, dstBlock: dstBlock)
				self.fnEnvVarNames.upsert(resultId, value: envZeroId)
			end 'noEnvSlot'
		end 'pairEnv'
	end 'lowerVarLoad'

	// Lower a global load: take the .data symbol's address and dereference at
	// offset 0. Backend handles the RIP-relative encoding via the existing
	// dataSection relocation kinds keyed off the `__data_` label prefix.
	function lowerGlobalLoad(result ByteArray, name String, slotType MaxonType, dstBlock IrBlock)
		// Lazy static struct-literal field: ensure the field is initialized
		// before reading it. `<name>.__lazy_init` (registered at parse time,
		// see Parser.parseLazyStaticStructDecl) is guard-checked internally so
		// the call is a no-op after the first read. Emitting the call here —
		// rather than a guarded branch at the read site — keeps the streaming
		// lowerer's single-`dstBlock` invariant intact while still deferring
		// construction to first read. The void return value is discarded.
		let lazyInitName = "{name}.__lazy_init"
		if self.project.funcSignatures.contains(lazyInitName) 'isLazyStatic'
			let initResultId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(initResultId, callee: lazyInitName, argIds: ValueIdArray.create())))
		end 'isLazyStatic'

		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: dataSymbolName(name))))
		let resultId = self.defineName(result)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: slotType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: isFloat)))
		self.setIsFloat(resultId, isFloat: isFloat)
		// Stamp the source-level slot type onto the loaded value so a
		// subsequent `methodCall` whose receiver is this load resolves the
		// concrete struct (vs. falling through to the interface-dispatch
		// stub). Without this, top-level array-literal globals like
		// `let xs = [1,2,3]` lose their `Array` type at the boundary
		// between Maxon-level globalLoad and Std-level methodCall lowering.
		self.setValueType(resultId, t: slotType)
	end 'lowerGlobalLoad'

	function lowerGlobalStore(name String, value ByteArray, slotType MaxonType, dstBlock IrBlock)
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: dataSymbolName(name))))
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: slotType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: 0, valueId: self.resolveName(value), width: StoreWidth.qword, isFloat: isFloat)))
	end 'lowerGlobalStore'

	// Lower a binop. If the op is float-family, ensure both operands are
	// f64-backed before emitting — int operands get a siToFpF64 convert
	// inserted. Bitwise ops are always integer.
	function lowerBinop(result ByteArray, left ByteArray, right ByteArray, opKind BinOpKind, operandType MaxonType, dstBlock IrBlock)
		var leftId = self.resolveName(left)
		var rightId = self.resolveName(right)
		let opIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: operandType)) and binOpSupportsFloat(opKind)
		if opIsFloat 'promote'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promote'
		let opcode = binOpKindToArithOpcode(self.project, opKind: opKind, operandType: operandType)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(opcode, resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: opIsFloat)
	end 'lowerBinop'

	// Integer unary ops (neg, bitNot) produce i64; lowerConvert handles any
	// subsequent widening. Float negation is normally lowered by the parser
	// as `0.0 - x` (which lands in lowerBinop), but `-x` on a named alias
	// that resolves to float (e.g. `Real`) reaches here as an integer `neg`
	// because the parser couldn't see through the alias. We detect the
	// already-float operand from the value-type map and rewrite to a float
	// subtract so targets that strictly check operand widths (wasm) accept
	// the emitted body.
	function lowerUnop(result ByteArray, operand ByteArray, opKind UnaryOpKind, dstBlock IrBlock)
		let operandId = self.resolveName(operand)
		let isFloatNeg = match opKind 'isFloatNeg'
			neg gives self.getIsFloat(operandId)
			bitNot gives false
			logicalNot gives false
		end 'isFloatNeg'
		if isFloatNeg 'floatNeg'
			let zeroId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constF64, resultId: zeroId, value: 0))))
			self.setIsFloat(zeroId, isFloat: true)
			let resultId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.subF64, resultId: resultId, leftId: zeroId, rightId: operandId))))
			self.setIsFloat(resultId, isFloat: true)
			return
		end 'floatNeg'
		// Logical NOT lowers to `operand XOR mask` where mask is 1 for a
		// bool operand and -1 (all-ones) for an int operand. The operand's
		// MaxonType comes from the per-value type map populated by the
		// parser / TypeResolution; bool produces the 1-flipping semantics
		// `not` expects, int produces `~` (bitwise complement) semantics
		// for the only other path the source-level `not` keyword reaches.
		let isLogicalNot = match opKind 'isLogNot'
			logicalNot gives true
			neg gives false
			bitNot gives false
		end 'isLogNot'
		if isLogicalNot 'logicalNot'
			let operandType = self.getValueType(operandId)
			let operandIsBool = match operandType 'isBool'
				boolean gives true
				integer to function gives false
				unresolved gives true
				typeParameter to opaquePointer gives false
			end 'isBool'
			let maskVal = (1 if operandIsBool else (0 - 1)) as ParsedInt
			let maskId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: maskId, value: maskVal))))
			self.setValueType(maskId, t: operandType)
			let resultId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.xorI64, resultId: resultId, leftId: operandId, rightId: maskId))))
			self.setIsFloat(resultId, isFloat: false)
			self.setValueType(resultId, t: operandType)
			return
		end 'logicalNot'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(unaryOpKindToArithOpcode(opKind), resultId: resultId, operandId: operandId))))
		self.setIsFloat(resultId, isFloat: false)
	end 'lowerUnop'

	// Lower a cmp. Same family-matching logic as binop: if the declared
	// operand type resolves to float, promote int-backed operands before
	// emitting. Result is always i64 (bool).
	//
	// Phase 11.4: when the operand type is a constrained type-parameter
	// (e.g. `Key` with `where Key is Equatable`), `==` and `!=` desugar to
	// witness-based `Equatable.equals` dispatch so the actual per-type
	// equality runs. Other comparisons on type parameters (e.g. `<`) would
	// route to `Comparable.compare`; we wire only `eq`/`ne` today since
	// that's what stdlib hash-table code reaches for. The fallback to raw
	// integer compare keeps `int`/`bool`/etc. paths unchanged.
	function lowerCmp(result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, operandType MaxonType, dstBlock IrBlock)
		let isEqOrNe = predicateIsEqOrNe(predicate)
		let isTypeParam = maxonTypeMentionsTypeParam(operandType)
		if isEqOrNe and isTypeParam 'witnessEq'
			if self.tryLowerTypeParamEquality(result, left: left, right: right, predicate: predicate, operandType: operandType, dstBlock: dstBlock) 'didDispatch'
				return
			end 'didDispatch'
			// The constraint check that gates this lives in TypeResolution's
			// `validateTypeParamComparisonConstraints` — by the time lowering
			// reaches here, an unconstrained type-param compare has already
			// emitted E3005 with the right source range. Fall through to the
			// raw integer compare for recovery so downstream passes have a
			// well-formed op to consume; the user-facing signal is the E3005
			// the earlier pass produced.
		end 'witnessEq'
		// J.4b: when the operand resolves to a concrete struct that implements
		// Equatable (post-monomorphization of an interface-extension method
		// whose body did `a == b` against an Element-typed pair), dispatch
		// `a == b` to `<StructName>.equals` directly. The non-monomorphized
		// code path still uses the typeParam witness above; this struct-direct
		// path covers the substituted shape where the typeParam has already
		// been replaced with `named(...)`.
		if isEqOrNe 'maybeNamedEq'
			if self.tryLowerNamedEqualityViaEquals(result, left: left, right: right, predicate: predicate, operandType: operandType, dstBlock: dstBlock) 'didNamedEq'
				return
			end 'didNamedEq'
		end 'maybeNamedEq'
		var leftId = self.resolveName(left)
		var rightId = self.resolveName(right)
		let operandIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: operandType))
		if operandIsFloat 'promote'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promote'
		let opcode = cmpPredicateToArithOpcode(self.project, predicate: predicate, operandType: operandType)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(opcode, resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: false)
		// Cmp opcodes produce 0 or 1 — semantically bool. Tag the result
		// as `boolean` (overriding the `integer` setIsFloat just wrote)
		// so `not <cmp>` sees a bool operand and emits XOR-with-1
		// (logical NOT) rather than XOR-with-(-1) (bitwise NOT).
		self.setValueType(resultId, t: MaxonType.boolean)
	end 'lowerCmp'

	// Phase 11.4: desugar `a == b` / `a != b` on a constrained type-param
	// operand into `a.equals(b)` (negated for `!=`) using the caller's
	// implicit witness slot for `Equatable`. Returns false when no
	// matching witness exists; the caller falls back to raw cmp.
	function tryLowerTypeParamEquality(result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, operandType MaxonType, dstBlock IrBlock) returns bool
		let pid = match operandType 'extractPid'
			typeParameter(id) gives id
			default panic("tryLowerTypeParamEquality: operandType not typeParameter despite the dispatch guard")
		end 'extractPid'
		let paramName = self.project.typeParameters.getName(pid)
		if let matched = try self.findConstraintForMethod(paramName, methodName: "equals") 'hit'
			let witnessAddrId = try self.implicitWitnessValueIds.get(matched.constraintIndex) otherwise panic("tryLowerTypeParamEquality: implicitWitnessValueIds desync at idx {matched.constraintIndex}")
			var argIds = ValueIdArray.create()
			argIds.push(self.resolveName(left))
			argIds.push(self.resolveName(right))
			let isNe = predicateIsNe(predicate)
			if isNe 'negate'
				// `!=` flips the bool result with `xor 1`, so we need a
				// separate ValueId for the underlying equals output before
				// defining the parser-visible `result` name.
				let eqResultId = allocValueId(self.funcIdRef)
				self.emitWitnessDispatch(eqResultId, witnessAddrId: witnessAddrId, interfaceName: matched.interfaceName, methodName: "equals", argIds: argIds, dstBlock: dstBlock)
				let resultId = self.defineName(result)
				let oneId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: oneId, value: 1))))
				self.setValueType(oneId, t: MaxonType.integer)
				self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.xorI64, resultId: resultId, leftId: eqResultId, rightId: oneId))))
				self.setIsFloat(resultId, isFloat: false)
			end 'negate' else 'plain'
				let resultId = self.defineName(result)
				self.emitWitnessDispatch(resultId, witnessAddrId: witnessAddrId, interfaceName: matched.interfaceName, methodName: "equals", argIds: argIds, dstBlock: dstBlock)
			end 'plain'
			return true
		end 'hit' else 'noMatch'
			return false
		end 'noMatch'
	end 'tryLowerTypeParamEquality'

	// J.4b: dispatch `a == b` / `a != b` to `<TypeName>.equals(a, b)` when
	// the operand resolves to a concrete named type whose conformance set
	// includes `Equatable`. Used inside monomorphized interface-extension
	// bodies after the typeParameter Element has been substituted to a
	// concrete struct name. The matching primitive case is handled by
	// cmpPredicateToArithOpcode (int/float compare); pointer-shaped struct
	// receivers need the user's `equals` method to honour the user's
	// semantic equality definition.
	function tryLowerNamedEqualityViaEquals(result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, operandType MaxonType, dstBlock IrBlock) returns bool
		let typeName = operandType.nameOrEmpty(self.project)
		if typeName.isEmpty() 'notNamed'
			return false
		end 'notNamed'
		if not project.structTypes.contains(typeName) 'notStruct'
			return false
		end 'notStruct'
		if not project.conformances.contains(typeName, interfaceName: "Equatable") 'notEquatable'
			return false
		end 'notEquatable'
		let equalsName = "{typeName}.equals"
		if not project.funcSignatures.contains(equalsName) 'noEquals'
			return false
		end 'noEquals'
		var argIds = ValueIdArray.create()
		// Char-byte literal operands need promotion to a real Character before
		// they reach `Character.equals`, which dereferences both args as struct
		// pointers. A single-byte char literal (`'D'`) lowers to a raw int on
		// the fast path; passing it through verbatim would have `equals` read
		// memory at the codepoint value (segfault). `materializeCharByteOperand`
		// is a no-op for any operand that is already a real Character SSA value.
		argIds.push(self.materializeCharByteOperand(left, structName: typeName, dstBlock: dstBlock))
		argIds.push(self.materializeCharByteOperand(right, structName: typeName, dstBlock: dstBlock))
		let isNe = predicateIsNe(predicate)
		if isNe 'negate'
			let eqResultId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(eqResultId, callee: equalsName, argIds: argIds)))
			self.setValueType(eqResultId, t: MaxonType.boolean)
			let resultId = self.defineName(result)
			let oneId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: oneId, value: 1))))
			self.setValueType(oneId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.xorI64, resultId: resultId, leftId: eqResultId, rightId: oneId))))
			self.setIsFloat(resultId, isFloat: false)
			self.setValueType(resultId, t: MaxonType.boolean)
		end 'negate' else 'plain'
			let resultId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: equalsName, argIds: argIds)))
			self.setValueType(resultId, t: MaxonType.boolean)
		end 'plain'
		return true
	end 'tryLowerNamedEqualityViaEquals'

	function lowerRefEq(result ByteArray, left ByteArray, right ByteArray, negate bool, dstBlock IrBlock)
		let leftId = self.resolveName(left)
		let rightId = self.resolveName(right)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(refEqOpcode(negate), resultId: resultId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(resultId, isFloat: false)
	end 'lowerRefEq'

	// Lower a call op the parser left name-symbolic. Steps:
	//   1. Qualify the callee per CallContext.
	//   2. Look up the callee's signature, slot positional + labeled args
	//      into their declared positions, fill in integer-literal defaults.
	//   3. Emit the Std call. Record the result's MaxonType so subsequent
	//      consumers (field loads on the result, etc.) can resolve.
	function lowerCall(result ByteArray, callee ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, opIdx OpIndex, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let bareCallee = String.from(callee)
		// Math primitives (sqrt/floor/ceil/round/abs/trunc) inline to a single
		// Std unary op rather than going through call resolution — see
		// `lowerMathIntrinsic` for why.
		if self.lowerMathIntrinsic(result, bareCallee: bareCallee, args: args, dstBlock: dstBlock) 'didLowerMath'
			return
		end 'didLowerMath'
		// Allocator-runtime intrinsics (`__mm_alloc`, etc.)
		// expand inline to a Std-level call into the runtime function (or a
		// load from the count globals). Their signatures are pre-registered
		// in `registerMmIntrinsicSignatures` so TypeResolution and arity
		// validation see them as ordinary functions; this branch intercepts
		// before the regular signature-driven call emission so no Std op ever
		// references the synthetic `stdlib.__mm_*` qualifier.
		if bareCallee.startsWith("__mm_") 'didLowerMm'
			if self.lowerMmIntrinsic(result, bareCallee: bareCallee, args: args, dstBlock: dstBlock) 'handled'
				return
			end 'handled'
		end 'didLowerMm'
		// Step 6b.4: static `__ManagedMemory.create(count, elementSize: 8)`
		// reaches here as a qualified call (parser sets CallContext.qualified
		// for `Type.method(...)`). Intercept before the regular signature-
		// driven emission so we expand to the runtime helper sequence rather
		// than emitting a call to a body-less signature.
		if bareCallee.startsWith("__ManagedMemory.") 'didLowerMmStatic'
			let methodName = try stripPrefix(bareCallee, prefix: "__ManagedMemory.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerManagedMemBuiltin(result, methodName: methodName, receiverId: 0, hasReceiver: false, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'didLowerMmStatic'
		// Dispatch `__ManagedFile.*` / `__ManagedDirectory.*` / `__ManagedList.*` /
		// `__ManagedListNode.*` / `__ManagedSocket.*` static calls through the
		// shared `lowerManagedHandleBuiltin` helper. Mirrors the
		// `__ManagedMemory.` static dispatch a few lines up — see that helper's
		// header comment for the rationale of routing every method through a
		// runtime helper.
		if let receiverName = try managedHandleReceiverPrefix(bareCallee) 'didLowerHandleStatic'
			let methodName = try stripPrefix(bareCallee, prefix: "{receiverName}.") otherwise panic("invariant: managedHandleReceiverPrefix succeeded but stripPrefix threw")
			if self.lowerManagedHandleBuiltin(receiverName, result: result, methodName: methodName, receiverId: 0, hasReceiver: false, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'didLowerHandleStatic'
		// Phase 7: `__Builtins.writeStdout(managed)` and friends — Phase 7
		// stdlib intrinsics. Expand to a load of buffer (off 0) + length
		// (off 8) from the MM, then a single call into `mrt_write_stdout`
		// / `mrt_write_stderr` which talks to the OS.
		if bareCallee.startsWith("__Builtins.") 'didLowerBuiltins'
			let methodName = try stripPrefix(bareCallee, prefix: "__Builtins.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerBuiltinsIntrinsic(result, methodName: methodName, args: args, dstBlock: dstBlock) 'handled'
				return
			end 'handled'
		end 'didLowerBuiltins'
		// File-path-gated raw Std-op access for `stdlib/Internals.maxon`. The
		// gate fires inside `lowerInternalsIntrinsic` — any call from a file
		// other than the designated internals file is rejected as a compile
		// error there.
		if bareCallee.startsWith("__Internals.") 'didLowerInternals'
			let methodName = try stripPrefix(bareCallee, prefix: "__Internals.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerInternalsIntrinsic(result, methodName: methodName, args: args, dstBlock: dstBlock) 'handled'
				return
			end 'handled'
		end 'didLowerInternals'
		// Resolved callee name (post typealias-chase + overload disambiguation)
		// was stashed by `resolveAllCalls` during TypeResolution. The pass
		// visits every `call` / `tryCall` op in the module, so a miss here
		// is a compiler bug (op introduced after TypeResolution, or the
		// resolver pass returned early on a shape it should have handled).
		let qualifiedCallee = try self.project.resolvedCallees.get(opIdx) otherwise panic("lowerCall: opIdx={opIdx} (callee={bareCallee}) missing from project.resolvedCallees — invariant violated, resolveAllCalls did not visit this op")
		// Re-run the prefix interceptors against the resolved (post-typealias)
		// qualified name. `ByteMemory.create(...)` (where `ByteMemory` is a
		// stdlib typealias for `__ManagedMemory with Byte`) survives past the
		// raw-callee intercepts above as `ByteMemory.create` but resolves to
		// `__ManagedMemory.create` here. Without re-routing, the call would
		// emit a body-less `call __ManagedMemory.create` op that the backend
		// can't sign-look-up.
		if qualifiedCallee.startsWith("__ManagedMemory.") 'reRouteMm'
			let methodName = try stripPrefix(qualifiedCallee, prefix: "__ManagedMemory.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerManagedMemBuiltin(result, methodName: methodName, receiverId: 0, hasReceiver: false, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'reRouteMm'
		// Re-route the `__Managed{File,Directory,List,ListNode,Socket}.*`
		// families to the shared `lowerManagedHandleBuiltin` dispatcher after
		// typealias resolution, matching the `__ManagedMemory` re-route just
		// above. User-facing typealiases (e.g.
		// `EManagedList = __ManagedList with Element`) resolve through
		// `qualifiedCallee` here even when the bare callee was a typealias.
		if let receiverName = try managedHandleReceiverPrefix(qualifiedCallee) 'reRouteHandle'
			let methodName = try stripPrefix(qualifiedCallee, prefix: "{receiverName}.") otherwise panic("invariant: managedHandleReceiverPrefix succeeded but stripPrefix threw")
			if self.lowerManagedHandleBuiltin(receiverName, result: result, methodName: methodName, receiverId: 0, hasReceiver: false, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'reRouteHandle'
		if qualifiedCallee.startsWith("__Builtins.") 'reRouteBuiltins'
			let methodName = try stripPrefix(qualifiedCallee, prefix: "__Builtins.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerBuiltinsIntrinsic(result, methodName: methodName, args: args, dstBlock: dstBlock) 'handled'
				return
			end 'handled'
		end 'reRouteBuiltins'
		if qualifiedCallee.startsWith("__Internals.") 'reRouteInternals'
			let methodName = try stripPrefix(qualifiedCallee, prefix: "__Internals.") otherwise panic("invariant: startsWith just checked but stripPrefix threw")
			if self.lowerInternalsIntrinsic(result, methodName: methodName, args: args, dstBlock: dstBlock) 'handled'
				return
			end 'handled'
		end 'reRouteInternals'
		let sigLookup = try self.project.funcSignatures.get(qualifiedCallee) otherwise 'noSig'
			self.emitUnsignedCall(result, qualifiedCallee: qualifiedCallee, args: args, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return
		end 'noSig'
		let isSiblingInstance = signatureFirstParamIsSelf(sigLookup)
		var paramStart = 0
		if isSiblingInstance 'shiftStart'
			paramStart = 1
		end 'shiftStart'
		// For sibling instance calls, load __self up front so its op precedes
		// any default-fill consts emitted by slotArgsForCall, then fold its
		// id into slot 0 of the returned arg list — no second-pass copy.
		var leadingId = 0
		var siblingReceiverType = MaxonType.unresolved
		if isSiblingInstance 'getSelf'
			leadingId = self.loadSelfPointer(dstBlock)
			// Build the genericInstance receiverContext for sibling calls
			// inside a generic method so layout-arg materialization can
			// route through the caller's `__layout_param`. The parser
			// records `__self` as a bare `named(currentType)`; for a
			// generic enclosing struct that elides the conditional shape,
			// which would force `materializeLayoutForGid` to load a
			// non-existent concrete descriptor.
			siblingReceiverType = self.enclosingTypeReceiverContext()
		end 'getSelf' else 'tryStatic'
			// `Type.staticMethod()` — TypeResolution recorded the
			// resolved receiver MaxonType (e.g. `genericInstance(Array,
			// [Byte])` for `ByteArray.init`) so layout-arg materialization
			// at the implicit-arity branch can pick the right descriptor
			// without re-chasing typealiases.
			siblingReceiverType = try self.project.resolvedReceiverTypes.get(opIdx) otherwise MaxonType.unresolved
		end 'tryStatic'
		// Free / qualified call: pass calleeQualifiedName so the per-arg
		// substitution can chase inner-aliases on the callee's enclosing
		// struct. Receiver-derived substitution comes from
		// `siblingReceiverType` (set above for both sibling and qualified
		// static call sites).
		let finalArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: paramStart, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: leadingId, hasLeadingReceiver: isSiblingInstance)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: finalArgIds, dstBlock: dstBlock, receiverContext: siblingReceiverType, errorBoundName: errorBoundName)
		// Sized generic-typealias auto-initialization: `Vec5.create()` (where
		// `Vec5 = Vector with 5 Int`) lands here with `siblingReceiverType =
		// genericInstance(Vector, [constInt(5), Int])`. The body of
		// `Vector.create()` returns `Self{}` whose managed-memory field was
		// zero-init'd by `synthesizeManagedFieldInits`; resize it to N
		// elements here so subsequent `set(0..N-1)` calls succeed. Mirrors
		// the C# bootstrap's `__capacity`-based pre-allocation for
		// `BuiltinArrayLiteral` types with a const capacity binding.
		self.maybePopulateSizedManagedMemory(result, qualifiedCallee: qualifiedCallee, receiverContext: siblingReceiverType, dstBlock: dstBlock)
	end 'lowerCall'

	// Post-call init for sized-generic factories: when `Vector.create()` is
	// called against a `Vec<N, Element>` sized typealias, the callee's body
	// returns `Self{}` whose `managed` field was zero-init'd by
	// `synthesizeManagedFieldInits` (capacity 0, length 0, no buffer).
	// Resize that managed-memory record here to length = capacity = N with
	// a buffer of `N * elementSize` bytes so subsequent set/get calls hit
	// real storage. No-op for non-Vector callees and for receiver contexts
	// without a `constInt` first arg.
	function maybePopulateSizedManagedMemory(result ByteArray, qualifiedCallee String, receiverContext MaxonType, dstBlock IrBlock)
		// Restrict the rewrite to `Vector.create()` — the only stdlib type
		// wired up this way today. Extending to other `BuiltinArrayLiteral`
		// conformers is a one-line callee-list edit once their stdlib
		// `create` shape also lands a default-init managed field.
		if qualifiedCallee != "Vector.create" 'notVectorCreate'
			return
		end 'notVectorCreate'
		let gid = match receiverContext 'pickGid'
			genericInstance(g) gives g
			boolean to typeParameter gives 0 as GenericInstanceId
			interface to opaquePointer gives 0
		end 'pickGid'
		if not maxonTypeIsGenericInstance(receiverContext) 'notGid'
			return
		end 'notGid'
		let (_, gidArgs) = self.project.genericInstances.get(gid)
		if gidArgs.count() < 2 'notSized'
			return
		end 'notSized'
		let firstArg = try gidArgs.get(0) otherwise return
		let n = match firstArg 'pickConst'
			constInt(value) gives value
			boolean to interface gives 0 as IntConstant
			opaquePointer gives 0
		end 'pickConst'
		if n <= 0 'notConst'
			return
		end 'notConst'
		let elementArg = try gidArgs.get(1) otherwise return
		let elementSize = primitiveWidth(self.project, t: elementArg)
		// Load the Vector struct's `managed` field (offset 0 in Vector,
		// which has a single field). `synthesizeManagedFieldInits` already
		// allocated the 40-byte mm record; we patch its capacity / length /
		// element_size / buffer in place rather than reallocating.
		let resultId = self.resolveName(result)
		let mmPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(mmPtrId, addrId: resultId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(mmPtrId, t: MaxonType.integer)
		self.storeI64Const(mmPtrId, offset: 16, value: n, dstBlock: dstBlock)
		self.storeI64Const(mmPtrId, offset: 24, value: elementSize, dstBlock: dstBlock)
		let totalBytes = n * (elementSize as ParsedInt)
		let totalBytesId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: totalBytesId, value: totalBytes))))
		self.setValueType(totalBytesId, t: MaxonType.integer)
		var rawAllocArgs = ValueIdArray.create()
		rawAllocArgs.push(totalBytesId)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(bufId, callee: "mrt_alloc", argIds: rawAllocArgs)))
		self.setValueType(bufId, t: MaxonType.integer)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(mmPtrId, offset: 0, valueId: bufId, width: StoreWidth.qword, isFloat: false)))
		self.storeI64Const(mmPtrId, offset: 8, value: n, dstBlock: dstBlock)
	end 'maybePopulateSizedManagedMemory'

	// Build the genericInstance receiverContext for the enclosing type
	// when the current function is an instance method. Returns
	// `genericInstance(currentType, [typeParameter(P0), ..., typeParameter(Pn)])`
	// for a generic enclosing type, or `named(currentType)` for a
	// non-generic one. Returns `unresolved` when no enclosing type is
	// active (free function); the caller already gates on
	// `isSiblingInstance` so this branch is only triggered by an
	// invariant violation in the caller chain.
	function enclosingTypeReceiverContext() returns MaxonType
		if self.currentTypeName.isEmpty() 'noType'
			return MaxonType.unresolved
		end 'noType'
		let paramNames = lookupTypeParamsForBase(self.project, baseName: self.currentTypeName)
		if paramNames.count() == 0 'nonGeneric'
			return MaxonType.named(self.project.typeNames.intern(self.currentTypeName))
		end 'nonGeneric'
		var args = MaxonTypeArray.create()
		for i in 0 upto paramNames.count() 'eachParam'
			let pname = try paramNames.get(i) otherwise panic("enclosingTypeReceiverContext: paramNames.get OOB at {i}")
			let pid = self.project.typeParameters.intern(self.currentTypeName, paramName: pname)
			args.push(MaxonType.typeParameter(pid))
		end 'eachParam'
		let baseId = self.project.typeNames.intern(self.currentTypeName)
		let gid = self.project.genericInstances.intern(baseId, args: args)
		return MaxonType.genericInstance(gid)
	end 'enclosingTypeReceiverContext'

	// Method call on a value receiver. The receiver's struct type comes from
	// the per-function value-type map; we then resolve `{Type.method}` and
	// dispatch through the same slot/default fill path as a free call, with
	// the receiver prepended as the implicit __self argument.
	function lowerMethodCall(result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, opIdx OpIndex, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let receiverId = self.resolveName(receiver)
		let rawReceiverType = self.getValueType(receiverId)
		// Phase 11.0 step 8b: normalize named-typealiases (`ElementMemory`) and
		// inner-aliases declared inside the enclosing struct's body
		// (`ElementArray`) into their underlying generic-instance form so
		// `maxonTypeStructName` returns the real struct name (`__ManagedMemory`,
		// `Array`, ...).
		let receiverType = normalizeReceiverInContext(self.project, t: rawReceiverType, enclosingType: self.currentTypeName)
		// `maxonTypeStructName` throws when the receiver isn't a struct/enum.
		// We catch the throw and recover an empty name so the existing
		// non-struct dispatch (interface fat-pointer / primitive extension /
		// stub) downstream can take over.
		let receiverStructName = try maxonTypeStructName(self.project, t: receiverType) otherwise ""
		// Receiver type didn't reduce to a concrete struct name. Three
		// sub-cases, handled in order below:
		//   1. Interface receiver — fat-pointer dispatch via the paired
		//      witness ValueId (Phase 11.3, fully wired).
		//   2. Primitive receiver with a registered extension type (e.g.
		//      `int.hash()`) — route to the extension's qualified signature.
		//   3. Anything else (free type parameter, unresolved type) —
		//      fall through to `lowerInterfaceMethodCallStub`, a runtime
		//      panic that surfaces a clear diagnostic if it ever executes.
		if receiverStructName.isEmpty() 'noStruct'
			// C1.d: when the receiver type is `MaxonType.interface(_)`, the
			// receiver is a fat-pointer pair `(value, witnessAddr)`. Look up
			// the witness ValueId paired with this receiver at varLoad time
			// and emit a `witnessMethod` + `indirectCall` to dispatch. The
			// inline-vs-box distinction (witness `flags.isFatBoxed`) is
			// deferred — every primitive and pointer-shaped value fits in 8
			// bytes; the >8-byte unbox path lights up only when a struct
			// flows through an interface, which is a follow-up.
			let isInterface = match receiverType 'isIface'
				interface gives true
				boolean to function gives false
				unresolved gives false
				typeParameter gives false
				genericInstance gives false
				constInt to opaquePointer gives false
			end 'isIface'
			if isInterface 'ifaceDispatch'
				// Iterator-shape passthrough: `for x in self` inside
				// `extension Iface` where `Iface` itself declares
				// `current()` + `advance()` (the Iterator shape) but no
				// `createIterator`. The parser unconditionally emits a
				// `createIterator` tryMethodCall on the source; here we
				// recognize that an iterator-shaped interface is its own
				// iterator and alias the result to the receiver instead
				// of trying to dispatch a method the interface doesn't
				// declare. The witness companion is reused: subsequent
				// `advance`/`current` dispatches resolve against the
				// receiver's fat-pointer pairing. Mirrors the struct-side
				// passthrough at the bottom of this function which fires
				// when a concrete Iterator-conforming type is iterated
				// directly via `for v in (1 upto 4).createIterator() ...`.
				if String.from(methodName) == "createIterator" 'maybeInterfacePassthrough'
					let ifaceName = match receiverType 'name'
						interface(id) gives self.project.interfaceRegistry.getName(id)
						boolean to function gives ""
						unresolved gives ""
						typeParameter gives ""
						genericInstance gives ""
						constInt to opaquePointer gives ""
					end 'name'
					let declaresCreateIterator = interfaceDeclaresMethodTransitive(self.project, interfaceName: ifaceName, methodName: "createIterator")
					let declaresCurrent = interfaceDeclaresMethodTransitive(self.project, interfaceName: ifaceName, methodName: "current")
					let declaresAdvance = interfaceDeclaresMethodTransitive(self.project, interfaceName: ifaceName, methodName: "advance")
					if not declaresCreateIterator and declaresCurrent and declaresAdvance 'isIteratorShape'
						self.aliasName(result, toId: receiverId)
						self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
						return
					end 'isIteratorShape'
				end 'maybeInterfacePassthrough'
				self.lowerInterfaceMethodCall(result, receiverId: receiverId, receiverType: receiverType, methodName: methodName, args: args, dstBlock: dstBlock, errorBoundName: errorBoundName)
				return
			end 'ifaceDispatch'
			// Phase 11.4: a method call on a primitive receiver (`int.hash()`,
			// `bool.compare(...)`, …) reaches an extension declared on the
			// primitive type. The struct-table lookup misses because primitives
			// aren't structs; map each primitive arm to its conventional
			// extension type-name and only route there when the qualified
			// signature is actually registered. A registered signature means
			// the stdlib's PrimitiveExtensions has been loaded; without it,
			// fall through to the existing panic stub so the build still
			// completes with a clear runtime diagnostic.
			if let primName = try primitiveExtensionTypeNameWithProject(self.project, t: receiverType) 'havePrim'
				let primQualified = "{primName}.{String.from(methodName)}"
				if let primSig = try self.project.funcSignatures.get(primQualified) 'havePrimSig'
					let primAllArgIds = self.slotArgsForCall(primSig, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: 1, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: receiverId, hasLeadingReceiver: true)
					self.emitCallWithArgs(result, qualifiedCallee: primQualified, argIds: primAllArgIds, dstBlock: dstBlock, errorBoundName: errorBoundName)
					return
				end 'havePrimSig'
				// Phase 7: single-byte character literals lower to integer-typed
				// values so `b == 'a'` byte comparisons stay free of Character
				// allocation, but a user-facing method call like
				// `c.asciiValue()` still needs to land on the Character struct.
				// When the receiver is in the int family and `int.<method>` has
				// no registered signature, materialize a heap-backed Character
				// inline (1-byte buffer holding the low byte of the receiver +
				// the standard MM/Character envelope, matching the layout
				// `lowerCharLiteral` builds for multi-byte literals) and
				// dispatch to `Character.<method>`. Mirror of the C# bootstrap's
				// TryCoerceCharLiteralToCodepoint, inverted: there the literal
				// stays Character and is coerced down to int; here we stay int
				// and promote up to Character at the call site.
				if primName == "int" 'maybeCharFallback'
					let characterCallee = "Character.{String.from(methodName)}"
					if let charSig = try self.project.funcSignatures.get(characterCallee) 'haveCharSig'
						let charValueId = self.materializeCharacterFromByte(receiverId, dstBlock: dstBlock)
						let charAllArgIds = self.slotArgsForCall(charSig, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: 1, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: charValueId, hasLeadingReceiver: true)
						self.emitCallWithArgs(result, qualifiedCallee: characterCallee, argIds: charAllArgIds, dstBlock: dstBlock, errorBoundName: errorBoundName)
						return
					end 'haveCharSig'
				end 'maybeCharFallback'
			end 'havePrim'
			// Phase 11.4: receiver is a constrained type-parameter (e.g.
			// `key Key` where `Key is Hashable`). Find the caller's witness
			// slot whose `(paramName, traitName)` declares this method, and
			// dispatch through it via `witnessMethod` + `indirectCall`. The
			// receiver is a plain value (8 bytes or fewer, same inline-fits
			// invariant the fat-pointer path relies on).
			if maxonTypeMentionsTypeParam(receiverType) 'typeParamDispatch'
				if self.tryLowerConstrainedTypeParamDispatch(result, receiverId: receiverId, receiverType: receiverType, methodName: methodName, args: args, dstBlock: dstBlock, errorBoundName: errorBoundName) 'didDispatch'
					return
				end 'didDispatch'
			end 'typeParamDispatch'
			self.lowerInterfaceMethodCallStub(result, methodName: methodName, dstBlock: dstBlock)
			self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
			return
		end 'noStruct'
		// Step 6b.4: instance methods on `__ManagedMemory` (length, get, set, ...)
		// expand inline to a sequence of Std-IR ops calling runtime helpers.
		// Same shape as `lowerMmIntrinsic` but indexed by method name; uses the
		// resolved receiverId as the implicit self pointer.
		if receiverStructName == "__ManagedMemory" 'didLowerMmMethod'
			let bareMethodName = String.from(methodName)
			if self.lowerManagedMemBuiltin(result, methodName: bareMethodName, receiverId: receiverId, hasReceiver: true, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'didLowerMmMethod'
		// Dispatch instance methods on the
		// `__Managed{File,Directory,List,ListNode,Socket}` families to the
		// shared `lowerManagedHandleBuiltin` helper (`file.size()`,
		// `file.read(...)`, `dir.next()`, `list.head()`, `node.next()`,
		// `sock.sendFrom`, etc.). Mirrors the `__ManagedMemory` instance
		// dispatch above.
		if isManagedHandleReceiver(receiverStructName) 'didLowerHandleMethod'
			let bareMethodName = String.from(methodName)
			if self.lowerManagedHandleBuiltin(receiverStructName, result: result, methodName: bareMethodName, receiverId: receiverId, hasReceiver: true, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, receiverType: receiverType, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'didLowerHandleMethod'
		// Phase 11.4: __ManagedMemoryCursor methods (current/advance/index/etc.)
		// lower inline to a sequence of loadIndirect/storeIndirect/arith ops
		// against the 40-byte cursor heap struct allocated by createCursor.
		// See `lowerManagedMemoryCursorBuiltin` for per-method details.
		if receiverStructName == "__ManagedMemoryCursor" 'didLowerCursor'
			let bareMethodName = String.from(methodName)
			var cursorArgIds = ValueIdArray.create()
			for argName in args 'eachCursorArg'
				cursorArgIds.push(self.resolveName(argName))
			end 'eachCursorArg'
			// Element type from the cursor's generic arg, when the
			// receiver is a fully-substituted instance. Inside the
			// generic stdlib body (where the cursor is
			// `__ManagedMemoryCursor with Element`), this yields a
			// `typeParameter` MaxonType and the call site does no
			// sign-extension; the user-side substitution context (if
			// available through methodCallResultType's receiver
			// substitution) supplies the concrete type at lowering for
			// monomorphized callers.
			let cursorElementType = signExtendElementType(self.project, receiverType: receiverType)
			if self.lowerManagedMemoryCursorBuiltin(result, methodName: bareMethodName, receiverId: receiverId, elementType: cursorElementType, args: cursorArgIds, dstBlock: dstBlock, errorBoundName: errorBoundName) 'handled'
				return
			end 'handled'
		end 'didLowerCursor'
		// `it.createIterator()` on a receiver that already conforms to
		// `Iterator` (without `Iterable`) is a no-op — Iterators are their
		// own iterators. The `for-in` parser unconditionally emits the
		// `createIterator` tryMethodCall so it doesn't have to know whether
		// the source resolves to an Iterable or to a bare Iterator; this
		// branch resolves the difference at lowering time by aliasing the
		// result to the receiver and binding the error flag to zero. Used by
		// `for v in (1 upto 4).createIterator() ...` (RangeIterator) and any
		// other "iterate the iterator directly" pattern.
		//
		// J.4b: also fire when the receiver implements a user-declared
		// iterator-shaped interface (declares `current` + `advance`, no
		// `createIterator`) — `extension HasItems` bodies (monomorphized for a
		// concrete conformer like `IntList`) iterate over `self` directly, the
		// same way the interface-receiver passthrough at the top of this
		// function does for `MaxonType.interface(...)`.
		if String.from(methodName) == "createIterator" 'maybeIteratorPassthrough'
			let createIteratorCallee = "{receiverStructName}.createIterator"
			let receiverHasCreateIterator = self.project.funcSignatures.contains(createIteratorCallee)
			let receiverIsIterator = typeConformsTo(self.project, t: receiverType, interfaceName: "Iterator")
			if not receiverHasCreateIterator and receiverIsIterator 'isIteratorPassthrough'
				self.aliasName(result, toId: receiverId)
				self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
				return
			end 'isIteratorPassthrough'
			if not receiverHasCreateIterator and receiverImplementsIteratorShapedInterface(self.project, receiverTypeName: receiverStructName) 'isIteratorShaped'
				self.aliasName(result, toId: receiverId)
				self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
				return
			end 'isIteratorShaped'
		end 'maybeIteratorPassthrough'
		// Resolved callee name (post-overload disambiguation) was stashed by
		// `resolveAllCalls` during TypeResolution. Same invariant as
		// `lowerCall`: a missing entry is a compiler bug.
		let qualifiedCallee = try self.project.resolvedCallees.get(opIdx) otherwise panic("lowerMethodCall: opIdx={opIdx} (receiver={receiverStructName}, method={String.from(methodName)}) missing from project.resolvedCallees — invariant violated")
		// paramStartIndex: 1 because the signature counts __self at slot 0;
		// user-facing params start at index 1. slotArgsForCall folds the
		// receiver into slot 0 of the returned arg list — no second copy.
		let sigLookup = try self.project.funcSignatures.get(qualifiedCallee) otherwise 'noSig'
			let plainArgs = self.resolveArgNames(args, leadingReceiverId: receiverId, hasLeadingReceiver: true)
			self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: plainArgs, dstBlock: dstBlock, receiverContext: receiverType, errorBoundName: errorBoundName)
			return
		end 'noSig'
		let allArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: 1, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: receiverId, hasLeadingReceiver: true)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: allArgIds, dstBlock: dstBlock, receiverContext: receiverType, errorBoundName: errorBoundName)
	end 'lowerMethodCall'

	// Emit a Std-level call op with the given pre-resolved argument ids and
	// register the result's MaxonType. Both lowerCall and lowerMethodCall
	// share this tail-end pattern; centralizing it keeps the no-signature
	// fallback and the full-slot path going through the same spot.
	//
	// Phase 11.4: when the callee is a generic body (its IrFunction has
	// `hasImplicitLayoutParam` / non-empty `implicitWitnessConstraints`),
	// append the synthetic trailing layout-descriptor and per-constraint witness arg ids before
	// emitting the call. The descriptor is resolved from `receiverContext`
	// (a `genericInstance(gid)` MaxonType produces a label via
	// `project.layoutDescriptors.labelFor(gid)`); when the context isn't a
	// concrete generic instance the lowering forwards the caller's own
	// `implicitLayoutValueId` instead — that happens in generic-to-generic
	// dispatch where the inner callee specializes on the outer's `T`.
	// Phase 4 of the multi-value-return error ABI rollout: when
	// `errorBoundName` is non-empty, allocate a fresh ValueId for the
	// parser's name and emit `StdCallOp.tryCall` with that id as the second
	// def (the backend captures the error flag from the secondary return
	// register, RDX/X1). An empty `errorBoundName` is the sentinel for "this
	// is not a try-call site" and produces a regular `StdCallOp.call` with a
	// single result def — the historic shape. Both emit modes share the same
	// implicit-arity (layout/witness) appending and the same result-
	// MaxonType recording.
	function emitCallWithArgs(result ByteArray, qualifiedCallee String, argIds ValueIdArray, dstBlock IrBlock, receiverContext MaxonType = MaxonType.unresolved, errorBoundName ByteArray = ByteArray.create())
		var finalArgIds = argIds
		// Phase 11.4: discover the callee's implicit-arity from a project-wide
		// map populated during `transferFuncs` and persisted via the stdlib
		// cache. The earlier implementation scanned `self.stdModule.functions`
		// for the callee's IrFunction, which fails in the per-function pipeline
		// where stdlib functions live in the cache (not the local stdModule)
		// — that produced under-arity calls that x64 silently ABI-corrupted on
		// and wasm rejected at validation. The project-level lookup gives a
		// consistent arity decision regardless of whether the callee is in the
		// local module or behind a cache restore.
		let calleeImplicits = try self.project.genericFunctionImplicitArity.get(qualifiedCallee) otherwise GenericFunctionImplicits.none()
		if calleeImplicits.hasLayout 'addLayout'
			finalArgIds = self.appendLayoutArg(finalArgIds, receiverContext: receiverContext, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
			for wc in calleeImplicits.witnessConstraints 'addWitness'
				finalArgIds = self.appendWitnessArg(finalArgIds, receiverContext: receiverContext, qualifiedCallee: qualifiedCallee, constraint: wc, dstBlock: dstBlock)
			end 'addWitness'
		end 'addLayout'
		let resultId = self.defineName(result)
		// Interface-returning callees encode the fat pointer across the
		// multi-value-return ABI: primary register = value half, secondary
		// register = witness pointer. Capture the secondary into a fresh
		// SSA id using the existing `tryCall` op shape (same two-def shape
		// the error-ABI uses) and pair (resultId → witnessId) in
		// `interfaceWitnessValueIds` so downstream uses (fat-pointer slot
		// stores, interface arg passing, interface dispatch) can recover
		// the witness without re-resolving via `project.witnessTables`.
		// At a real `try`-call site (errorBoundName set), the secondary
		// register is the error flag; an interface-returning callee inside
		// a try is structurally absent today and would need a separate ABI
		// resolution (R8=value, RDX=flag, no register for witness).
		let calleeReturnInterfaceName = returnTypeInterfaceName(self.project, ref: try self.project.funcReturnTypes.get(qualifiedCallee) otherwise MaxonReturnType.void)
		if not errorBoundName.isEmpty() 'tryCall'
			let flagId = self.defineName(errorBoundName)
			self.setValueType(flagId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.tryCall(resultId, callee: qualifiedCallee, argIds: finalArgIds, errorFlagId: flagId)))
		end 'tryCall' else if not calleeReturnInterfaceName.isEmpty() 'fatCall'
			let witnessId = allocValueId(self.funcIdRef)
			self.setValueType(witnessId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.tryCall(resultId, callee: qualifiedCallee, argIds: finalArgIds, errorFlagId: witnessId)))
			self.interfaceWitnessValueIds.upsert(resultId, value: witnessId)
		end 'fatCall' else 'plainCall'
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: qualifiedCallee, argIds: finalArgIds)))
		end 'plainCall'
		self.recordCallResultType(resultId, callee: qualifiedCallee, dstBlock: dstBlock, receiverContext: receiverContext)
		// Hybrid-generics ABI bridge (read side). When the callee's declared
		// return type is `typeParameter(...)` but the call-site substitution
		// binds it to a float-class concrete type, the runtime ABI hands the
		// result back in a GPR (RAX/X0) — the callee body's int-channel ABI
		// for generic returns. Reinterpret to f64 here so the caller's
		// float-typed slot reads the right register class.
		self.maybeBitcastCallResultToFloat(result, callee: qualifiedCallee, receiverContext: receiverContext, dstBlock: dstBlock)
		// Sign-extend narrow signed return values. When the callee's
		// declared return type is `typeParameter(...)` and the call site's
		// receiverContext binds that parameter to a signed narrow type
		// (`i8`/`i16`/`i32`, including alias-resolved enums whose
		// `computeOptimalIntType` picked a signed narrow StdType), the
		// runtime ABI hands back the value zero-extended in RAX/X0 (every
		// narrow-load primitive in `__managed_mem_get` / field-load is
		// zero-extending). Recover the sign bit by emitting shl + shr
		// (arithmetic) and re-aliasing the user-name to the extended SSA.
		self.maybeSignExtendCallResult(result, callee: qualifiedCallee, receiverContext: receiverContext, dstBlock: dstBlock)
	end 'emitCallWithArgs'

	// Post-call sign-extension for narrow signed return types. Resolves the
	// callee's declared return type through the call-site's `receiverContext`
	// to its concrete form (substituting type parameters), checks whether
	// the resulting `StdType` is signed and narrower than 8 bytes, and if
	// so, emits a sign-extension sequence.
	function maybeSignExtendCallResult(result ByteArray, callee String, receiverContext MaxonType, dstBlock IrBlock)
		let returnType = try self.project.funcReturnTypes.get(callee) otherwise return
		let raw = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		let concrete = substituteReturnTypeViaReceiver(self.project, raw: raw, receiverContext: receiverContext)
		if not signExtendApplies(self.project, elementType: concrete) 'noExtend'
			return
		end 'noExtend'
		let stdType = resolveMaxonTypeToStd(self.project, ref: concrete)
		let widthBytes = storeWidthBytes(storeWidthOfStdType(stdType))
		if widthBytes >= 8 'noWiden'
			return
		end 'noWiden'
		let rawId = self.resolveName(result)
		let signExtId = self.emitNarrowSignExtend(rawId, widthBytes: widthBytes, dstBlock: dstBlock)
		self.setValueType(signExtId, t: concrete)
		self.aliasName(result, toId: signExtId)
	end 'maybeSignExtendCallResult'

	// Emit a sign-extension sequence for a narrow integer value already
	// held in an i64 register with the high bits zero-extended. Uses the
	// trick `(x XOR signBit) - signBit` where `signBit = 1 << (width*8 - 1)`:
	//   - Flips the value's narrow-sign bit (bit at position width*8-1).
	//   - Subtracting `signBit` from the result subtracts 0 when the
	//     original sign bit was 0 (because XOR flipped 0 → 1, then
	//     subtracting 1*signBit moves down by signBit, matching the
	//     positive zero-extension result), and subtracts 2*signBit when
	//     the original sign bit was 1 (flipping 1 → 0 + subtraction
	//     produces the negative two's-complement form).
	// Works for widthBytes ∈ {1, 2, 4}. Uses only XOR and SUB, both of
	// which exist as unsigned-style i64 binops — sidesteps the lack of
	// a signed-shift StdOp (today's `shrI64` lowers to SHR on x64 and
	// `i64.shr_u` on wasm).
	function emitNarrowSignExtend(rawId ValueId, widthBytes MachineWord, dstBlock IrBlock) returns ValueId
		let signBit = (1 shl ((widthBytes * 8 - 1) as ParsedInt))
		let signBitId = self.emitConstI64(signBit, dstBlock: dstBlock)
		self.setValueType(signBitId, t: MaxonType.integer)
		let xoredId = self.emitBinaryI64(StdArithBinaryOpcode.xorI64, leftId: rawId, rightId: signBitId, dstBlock: dstBlock)
		let extendedId = self.emitBinaryI64(StdArithBinaryOpcode.subI64, leftId: xoredId, rightId: signBitId, dstBlock: dstBlock)
		return extendedId
	end 'emitNarrowSignExtend'

	// Resolve the layout descriptor for the call site and return an
	// updated argIds with the descriptor's address appended. If the
	// receiver context is a `genericInstance(gid)`, look up the rdata
	// label via `project.layoutDescriptors.labelFor(gid)` and emit a
	// `loadLayoutDescriptor`. Otherwise (caller is itself a generic
	// body forwarding its own `T`) forward `self.implicitLayoutValueId`
	// — the layout slot the caller received.
	function appendLayoutArg(argIds ValueIdArray, receiverContext MaxonType, qualifiedCallee String, dstBlock IrBlock) returns ValueIdArray
		var out = argIds
		let layoutId = self.materializeLayoutArg(receiverContext, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
		out.push(layoutId)
		return out
	end 'appendLayoutArg'

	function appendWitnessArg(argIds ValueIdArray, receiverContext MaxonType, qualifiedCallee String, constraint WhereClause, dstBlock IrBlock) returns ValueIdArray
		var out = argIds
		let witnessId = self.materializeWitnessArg(receiverContext, qualifiedCallee: qualifiedCallee, constraint: constraint, dstBlock: dstBlock)
		out.push(witnessId)
		return out
	end 'appendWitnessArg'

	function materializeLayoutArg(receiverContext MaxonType, qualifiedCallee String, dstBlock IrBlock) returns ValueId
		match receiverContext 'pick'
			genericInstance(gid) then return self.materializeLayoutForGid(gid, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
			typeParameter then return self.forwardCallerLayout(qualifiedCallee)
			interface then return self.forwardCallerLayout(qualifiedCallee)
			unresolved then return self.forwardCallerLayout(qualifiedCallee)
			named(id) then return self.materializeLayoutForNamed(id, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
			boolean to string then panic("materializeLayoutArg: callee '{qualifiedCallee}' takes an implicit layout descriptor but the call site's receiverContext is a primitive type ({receiverContext.toString(self.project)}); generic methods cannot be called on primitives")
			function then panic("materializeLayoutArg: callee '{qualifiedCallee}' takes an implicit layout descriptor but the call site's receiverContext is a function type ({receiverContext.toString(self.project)}); function values cannot satisfy a generic-method receiver")
			constInt then panic("materializeLayoutArg: callee '{qualifiedCallee}' was called with a constInt receiverContext — constInt is a generic-arg marker, never a value type")
			opaquePointer then panic("materializeLayoutArg: callee '{qualifiedCallee}' was called with an opaquePointer receiverContext — opaquePointer is an ABI-bookkeeping slot type, never a value type")
		end 'pick'
	end 'materializeLayoutArg'

	// `Type.staticMethod()` calls where TypeResolution couldn't recover the
	// generic-instance shape (because the source-level return type was a
	// bare `Self`/`Type` rather than `Type with (...)`) land here. If the
	// receiver's declaring type is itself generic AND the caller's
	// enclosing type has the same type-parameter names, promote the bare
	// `named` to a `genericInstance` using the caller's typeParameter ids.
	// `materializeLayoutForGid` then sees conditional args and forwards
	// the caller's layout slot. This mirrors what
	// `enclosingTypeReceiverContext` does for instance methods on Self.
	function materializeLayoutForNamed(nameId TypeNameId, qualifiedCallee String, dstBlock IrBlock) returns ValueId
		let baseName = self.project.typeNames.get(nameId)
		let baseParams = self.project.typeParameters.getParamNames(baseName)
		if baseParams.count() == 0 'notGeneric'
			// Interface-extension call: the callee's qualified prefix is an
			// interface that declares generic params, and the receiver
			// (`baseName`) is a concrete type whose `implements <Interface>
			// with [args]` conformance supplies the binding. The resulting
			// gid (`Interface with [confArgs]`) is the layout descriptor
			// `seedConformanceLayouts` in BuildLayoutDescriptors pre-interns
			// for every `with`-arg-bearing conformance.
			if let layoutId = try self.tryMaterializeLayoutFromConformance(baseName, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock) 'gotConf'
				return layoutId
			end 'gotConf'
			panic("materializeLayoutArg: callee '{qualifiedCallee}' takes an implicit layout descriptor but the call site's receiverContext is a bare named type ({baseName}); the receiver's declaring type is non-generic so no layout is available")
		end 'notGeneric'
		var args = MaxonTypeArray.create()
		for i in 0 upto baseParams.count() 'eachParam'
			let pname = try baseParams.get(i) otherwise panic("materializeLayoutForNamed: baseParams.get OOB at {i}")
			// Resolve through the caller's type-param scope so the
			// resulting gid is conditional (forwards from caller's
			// layout) rather than pinned to the callee's distinct
			// type-param ids.
			let pid = self.project.typeParameters.intern(self.currentTypeName, paramName: pname)
			args.push(MaxonType.typeParameter(pid))
		end 'eachParam'
		let baseId = self.project.typeNames.intern(baseName)
		let gid = self.project.genericInstances.intern(baseId, args: args)
		return self.materializeLayoutForGid(gid, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
	end 'materializeLayoutForNamed'

	// Recover the layout descriptor for an interface-extension call site
	// where the callee is `<Interface>.<method>` and the receiver is a
	// concrete (non-generic) type. Resolves through the receiver's
	// `implements <Interface> with [args]` clause: the withArgs supply
	// the per-typeParam bindings the interface's extension method needs.
	// Shares the `(implementer, interface)` registry walk with the
	// substitution-side helper `resolveInterfaceUsesParamThroughConformance`
	// via `findConformanceEntry` so both lookup paths stay in sync.
	function tryMaterializeLayoutFromConformance(receiverTypeName String, qualifiedCallee String, dstBlock IrBlock) returns ValueId throws ConformanceLayoutLookupError
		let calleeBytes = qualifiedCallee.toByteArray()
		let calleeLen = calleeBytes.count()
		let dotIdx = lastIndexOfDotByte(calleeBytes)
		if dotIdx >= calleeLen 'noDot'
			throw ConformanceLayoutLookupError.notInterfaceCallee
		end 'noDot'
		let interfaceName = byteSliceToString(calleeBytes, startIndex: 0, endIndex: dotIdx)
		if not self.project.interfaces.contains(interfaceName) 'notInterface'
			throw ConformanceLayoutLookupError.notInterfaceCallee
		end 'notInterface'
		let confId = try findConformanceEntry(self.project, implementerName: receiverTypeName, interfaceName: interfaceName) otherwise throw ConformanceLayoutLookupError.noConformance
		let confArgs = try self.project.conformances.withArgsList.get(confId) otherwise panic("tryMaterializeLayoutFromConformance: withArgsList.get OOB at {confId}")
		if confArgs.count() == 0 'noArgs'
			throw ConformanceLayoutLookupError.noWithArgs
		end 'noArgs'
		let baseId = self.project.typeNames.intern(interfaceName)
		let gid = self.project.genericInstances.intern(baseId, args: confArgs)
		return self.materializeLayoutForGid(gid, qualifiedCallee: qualifiedCallee, dstBlock: dstBlock)
	end 'tryMaterializeLayoutFromConformance'

	// Materialize the layout descriptor for a `genericInstance(gid)`
	// receiverContext: load the rdata blob for fully-concrete instances,
	// forward the caller's layout slot for conditional instances (any
	// type-parameter arg). The conditional case happens when a generic
	// caller calls another generic method with `Self` or `T` — the
	// receiver's gid encodes the unbound parameter and the descriptor is
	// resolved at the caller's call site, not here.
	function materializeLayoutForGid(gid GenericInstanceId, qualifiedCallee String, dstBlock IrBlock) returns ValueId
		let (_, gidArgs) = self.project.genericInstances.get(gid)
		if anyMaxonTypeIsConditional(gidArgs) 'conditional'
			return self.forwardCallerLayout(qualifiedCallee)
		end 'conditional'
		return self.emitLoadLayoutDescriptorForGid(gid, dstBlock: dstBlock)
	end 'materializeLayoutForGid'

	function emitLoadLayoutDescriptorForGid(gid GenericInstanceId, dstBlock IrBlock) returns ValueId
		if not self.project.layoutDescriptors.contains(gid) 'missing'
			// `BuildLayoutDescriptors` is supposed to emit a descriptor
			// for every interned gid before lowering runs; reaching
			// here means its worklist missed a transitive case. Panic
			// so the gap surfaces — silently substituting a wrong
			// layout would just propagate the bug into runtime
			// field-offset reads.
			let shape = genericInstanceIdToString(self.project, id: gid)
			panic("emitLoadLayoutDescriptorForGid: no descriptor for gid {gid} ({shape}) — BuildLayoutDescriptors missed a transitive case")
		end 'missing'
		let label = self.project.layoutDescriptors.labelFor(gid)
		let resultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadLayoutDescriptor(resultId, label: label)))
		self.setValueType(resultId, t: MaxonType.integer)
		return resultId
	end 'emitLoadLayoutDescriptorForGid'

	// Forward the caller's own layout-param slot. Used whenever the call
	// site's receiverContext doesn't carry a concrete genericInstance
	// (typeParameter, interface, conditional genericInstance, or an
	// unresolved free-call receiver). The caller MUST have an implicit
	// layout param — a non-generic caller passing forward a generic-call
	// arg has nothing to forward — so a zero `implicitLayoutValueId` is
	// a phase-ordering bug rather than a state we should paper over with
	// a sentinel.
	function forwardCallerLayout(qualifiedCallee String) returns ValueId
		// The legitimate layout slot can be `0` for a zero-user-param
		// generic helper (e.g. `Type.__field_init_<field>`), so we can't
		// use a sentinel-zero check here. Probe `hasImplicitLayoutParam`
		// on the current function instead.
		if not self.currentMaxonFunc.hasImplicitLayoutParam 'noSlot'
			panic("forwardCallerLayout: caller '{self.currentMaxonFunc.name}' has no implicit layout param but call to '{qualifiedCallee}' needs one forwarded — TypeResolution should have either pinned a concrete receiver or marked the caller as generic")
		end 'noSlot'
		return self.implicitLayoutValueId
	end 'forwardCallerLayout'

	// Materialize the witness pointer for one constraint of the callee's
	// where-clause. The constraint is `(paramName, requiredTraitName)` in
	// the callee's parameter scope; the substitution that maps `paramName`
	// to a concrete type is read off the call site's `receiverContext`:
	//   - `genericInstance(gid)`: pair the receiver's `usesParams` (from
	//     `getParamNames(declaringTypeName)`) with `gidArgs` to find the
	//     concrete type bound to `paramName`. If concrete, load the
	//     `(concreteType, traitName)` witness label. If still a typeParam
	//     (caller is itself generic, forwarding `T`), fall through to the
	//     forwarding path.
	//   - `typeParameter` / `unresolved`: caller is itself generic; find
	//     the matching slot in the caller's `implicitWitnessValueIds`
	//     (parallel to `currentMaxonFunc.implicitWitnessConstraints`) by
	//     `(paramName, requiredTraitName)` match.
	function materializeWitnessArg(receiverContext MaxonType, qualifiedCallee String, constraint WhereClause, dstBlock IrBlock) returns ValueId
		// Try to resolve `constraint.paramName` to a concrete type via
		// the receiverContext's substitution.
		let bound = self.resolveCalleeParamToConcreteType(receiverContext, qualifiedCallee: qualifiedCallee, paramName: constraint.paramName)
		match bound 'pick'
			concrete(typeName) then return self.emitLoadWitnessTable(typeName, interfaceName: constraint.requiredTraitName, dstBlock: dstBlock)
			concreteGid(_, gid) then return self.emitLoadWitnessTableForGid(gid, interfaceName: constraint.requiredTraitName, dstBlock: dstBlock)
			forwardFromCaller(callerParamName) then return self.forwardCallerWitness(qualifiedCallee, constraint: constraint, callerParamName: callerParamName)
		end 'pick'
	end 'materializeWitnessArg'

	function emitLoadWitnessTable(typeName String, interfaceName String, dstBlock IrBlock) returns ValueId
		if not self.project.witnessTables.contains(typeName, interfaceName: interfaceName) 'missing'
			panic("emitLoadWitnessTable: no witness table for ({typeName}, {interfaceName}) — BuildWitnessTables missed a case or constraint isn't satisfied")
		end 'missing'
		let label = self.project.witnessTables.labelFor(typeName, interfaceName: interfaceName)
		let resultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadWitnessTable(resultId, label: label)))
		self.setValueType(resultId, t: MaxonType.integer)
		return resultId
	end 'emitLoadWitnessTable'

	// Load the per-instance witness table for a generic conformer (e.g.
	// `__witness_Array_Byte_Equatable` for `Array<Byte>: Equatable`). The
	// per-instance blob's method slots reference thunks synthesized by
	// `BuildWitnessTables` that capture the instance's implicit-arg
	// substitution, so the call site's `(self, other)` shape matches the
	// thunk's signature and the underlying generic method-impl receives
	// the correct `(layout, hashWit, eqWit)` args.
	function emitLoadWitnessTableForGid(gid GenericInstanceId, interfaceName String, dstBlock IrBlock) returns ValueId
		if not self.project.witnessTables.containsForGid(gid, interfaceName: interfaceName) 'missing'
			let shape = genericInstanceIdToString(self.project, id: gid)
			panic("emitLoadWitnessTableForGid: no per-instance witness table for (gid={gid} ({shape}), {interfaceName}) — BuildWitnessTables missed a transitive case")
		end 'missing'
		let label = self.project.witnessTables.labelForGid(gid, interfaceName: interfaceName)
		let resultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadWitnessTable(resultId, label: label)))
		self.setValueType(resultId, t: MaxonType.integer)
		return resultId
	end 'emitLoadWitnessTableForGid'

	// Synthesize one Std-level IrFunction per `(gid, interfaceName, method)`
	// triple recorded by BuildWitnessTables. Each thunk's body:
	//   - Receives the interface-declared params (e.g. `(self, other)` for
	//     `Equatable.equals`) — no implicit slots, so wasm's call_indirect
	//     sees a fixed signature.
	//   - Materializes the impl's implicit `(layout, witness...)` args from
	//     the gid's concrete substitution: a `loadLayoutDescriptor` against
	//     the gid's layout label, and one `loadWitnessTable` per
	//     where-clause constraint resolved through the gid's
	//     usesParams → args pairing.
	//   - Tail-forwards to the impl method (`Array.equals`, `Array.hash`,
	//     ...) with all args including the implicit tail.
	//   - Returns the impl's result.
	function synthesizeWitnessThunks()
		// Only emit thunks for `(gid, interfaceName)` entries that
		// `BuildWitnessTables` queued during THIS pipeline run. Entries
		// restored from the stdlib cache already have their thunk
		// function compiled into stdlib's object code — re-synthesizing
		// would duplicate the symbol at link time.
		let count = self.project.pendingWitnessThunkGids.count()
		if count == 0 'noWork'
			return
		end 'noWork'
		for i in 0 upto count 'eachPending'
			let gid = try self.project.pendingWitnessThunkGids.get(i) otherwise panic("synthesizeWitnessThunks: pendingWitnessThunkGids.get OOB at {i}")
			let interfaceName = try self.project.pendingWitnessThunkInterfaces.get(i) otherwise panic("synthesizeWitnessThunks: pendingWitnessThunkInterfaces desync at {i}")
			let iface = try self.project.interfaces.get(interfaceName) otherwise 'noIface'
				continue
			end 'noIface'
			let thunkNames = self.project.witnessTables.gidMethodImplNamesFor(gid, interfaceName: interfaceName)
			self.synthesizeWitnessThunksForEntry(gid, iface: iface, thunkNames: thunkNames)
		end 'eachPending'
	end 'synthesizeWitnessThunks'

	function synthesizeWitnessThunksForEntry(gid GenericInstanceId, iface IrInterface, thunkNames StringArray)
		let (baseId, _) = self.project.genericInstances.get(gid)
		let baseName = self.project.typeNames.get(baseId)
		// Each thunk corresponds to one interface method in declaration
		// order, so the StringArray's indexing must align with
		// `iface.methods`.
		let methodCount = iface.methods.count()
		if methodCount != thunkNames.count() 'arityMismatch'
			panic("synthesizeWitnessThunksForEntry: iface.methods.count() ({methodCount}) != thunkNames.count() ({thunkNames.count()}) for interface '{iface.name}' on gid {gid} — BuildWitnessTables and lowerMaxonToStd disagree on method count")
		end 'arityMismatch'
		for mi in 0 upto methodCount 'eachMethod'
			let method = try iface.methods.get(mi) otherwise panic("synthesizeWitnessThunksForEntry: iface.methods.get OOB at {mi}")
			let thunkName = try thunkNames.get(mi) otherwise panic("synthesizeWitnessThunksForEntry: thunkNames.get OOB at {mi}")
			self.synthesizeOneWitnessThunk(gid, baseName: baseName, method: method, thunkName: thunkName)
		end 'eachMethod'
	end 'synthesizeWitnessThunksForEntry'

	function synthesizeOneWitnessThunk(gid GenericInstanceId, baseName String, method InterfaceMethodSig, thunkName String)
		let implName = "{baseName}.{method.name}"
		// The user-visible param count for the thunk is
		// `<receiverSlots> + method.paramNames.count()`. Instance methods
		// reserve one leading slot for the receiver fat-pointer; `static`
		// interface requirements (e.g. `BuiltinArrayLiteral.init`) have no
		// receiver, so the thunk forwards only the declared params plus the
		// implicit-arg tail. Stage-zero (closures/witness-receiver pairing)
		// isn't relevant for a thunk — these params are plain pointer-shaped
		// values.
		let receiverSlots = 0 if method.isStatic else 1
		let userParamCount = receiverSlots + method.paramNames.count()
		var paramTypes = StdTypeArray.create()
		for _ in 0 upto userParamCount 'fillParams'
			paramTypes.push(StdType.i64)
		end 'fillParams'
		let returnType = match method.returnType 'mapRet'
			void gives StdReturnType.void
			value gives StdReturnType.value(StdType.i64)
		end 'mapRet'
		// A throwing interface method (e.g. `Iterator.advance() throws
		// IterationError`) uses the multi-value error-return ABI: callers
		// `try_call` it and read a trailing error flag. The thunk must inherit
		// that throws-clause so LowerABI expands its signature the same way and
		// so the body below propagates the impl's error flag via `error_return`
		// instead of dropping it (which would make `for`-loop termination — a
		// `try advance()` whose thrown `exhausted` ends the loop — never fire).
		let thunkThrows = match method.throwsTypeName 'throwsCheck'
			none gives false
			throwing gives true
		end 'throwsCheck'
		var func = IrFunction.createFromStd(thunkName, returnType: returnType, paramCount: userParamCount, paramTypes: paramTypes, returnLine: 0, throwsTypeName: method.throwsTypeName)
		// `funcIdRef` reserves ValueIds 0..userParamCount-1 for the
		// declared params; SSA numbering for ops appended below picks up
		// at that index.
		var idRef = ValueIdRef.create(userParamCount)
		var entryBlock = self.stdModule.addBlock(func, label: "entry")

		// Emit `param` ops for every declared slot so backends have an
		// anchor for register-class allocation (mirrors what `lower()`
		// does for hasImplicitLayoutParam functions earlier in this pass).
		for pIdx in 0 upto userParamCount 'eachParam'
			self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(pIdx as ValueId, paramIndex: pIdx, paramType: StdType.i64)))
		end 'eachParam'

		// Build the implicit-arg tail. `Array.equals` is registered with
		// `hasLayout=true` and the parent type's where-clause constraints
		// (`Element is Hashable, Element is Equatable`); a non-generic
		// conformer's impl wouldn't have implicit args, so `none()` is the
		// natural fallback for that case.
		let implicits = try self.project.genericFunctionImplicitArity.get(implName) otherwise GenericFunctionImplicits.none()
		var implicitArgIds = ValueIdArray.create()
		if implicits.hasLayout 'addLayout'
			let layoutId = allocValueId(idRef)
			let layoutLabel = self.project.layoutDescriptors.labelFor(gid)
			self.stdModule.appendOp(entryBlock, op: StdOp.system(StdSystemOp.loadLayoutDescriptor(layoutId, label: layoutLabel)))
			implicitArgIds.push(layoutId)
			for wc in implicits.witnessConstraints 'eachConstraint'
				let witnessId = self.materializeThunkWitnessArg(gid, baseName: baseName, constraint: wc, dstBlock: entryBlock, idRef: idRef)
				implicitArgIds.push(witnessId)
			end 'eachConstraint'
		end 'addLayout'

		// Compose the tail call's full arg list: declared params followed
		// by implicit-arg ValueIds in source-of-truth order.
		var allArgIds = ValueIdArray.create()
		for pIdx in 0 upto userParamCount 'fwdParams'
			allArgIds.push(pIdx as ValueId)
		end 'fwdParams'
		for argId in implicitArgIds 'fwdImplicits'
			allArgIds.push(argId)
		end 'fwdImplicits'

		// Emit the tail call and return its result. Void-returning methods
		// don't carry a primary value — Std's `ret` still names a ValueId
		// so we allocate one and let the backend treat it as unused (the
		// existing void-return pattern in transferFuncs). A throwing impl
		// returns `(value, errorFlag)`: call it via `tryCall` and forward both
		// through `errorReturn` so the thrown error reaches the dispatch site.
		let resultId = allocValueId(idRef)
		if thunkThrows 'throwingTail'
			let errorFlagId = allocValueId(idRef)
			self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.tryCall(resultId, callee: implName, argIds: allArgIds, errorFlagId: errorFlagId)))
			self.stdModule.setTerminator(entryBlock, op: StdOp.call(StdCallOp.errorReturn(resultId, errorFlagId: errorFlagId)))
		end 'throwingTail' else 'plainTail'
			self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.call(resultId, callee: implName, argIds: allArgIds)))
			self.stdModule.setTerminator(entryBlock, op: StdOp.call(StdCallOp.ret(resultId)))
		end 'plainTail'

		// Stamp the function-level slot count so the backend's register
		// allocator and spill-slot accounting see the right number of
		// reserved value ids. `paramCount` was set at construction; the
		// post-op id-frontier is the running idRef.
		func.varSlotCount = idRef.nextId as VarSlot

		self.stdModule.functions.push(func)
	end 'synthesizeOneWitnessThunk'

	function materializeThunkWitnessArg(gid GenericInstanceId, baseName String, constraint WhereClause, dstBlock IrBlock, idRef ValueIdRef) returns ValueId
		// Resolve `constraint.paramName` against the gid's usesParams →
		// args pairing. The substitution is fully concrete here (we
		// skipped conditional gids in BuildWitnessTables), so the result
		// is either a primitive name, a non-generic struct name, or
		// another generic instance — each routes to a witness label that
		// either already exists (primitive / non-generic conformer
		// emitted by the unconditional path) or was emitted by the same
		// BuildWitnessTables pass that produced this thunk's table (for
		// nested generic conformers).
		let usesParams = self.project.typeParameters.getParamNames(baseName)
		let (_, gidArgs) = self.project.genericInstances.get(gid)
		if usesParams.count() != gidArgs.count() 'arityMismatch'
			panic("materializeThunkWitnessArg: usesParams.count() ({usesParams.count()}) != gidArgs.count() ({gidArgs.count()}) for '{baseName}' (gid={gid}) — generic instantiation arity bug")
		end 'arityMismatch'
		var bound = MaxonType.unresolved
		var foundBinding = false
		for i in 0 upto usesParams.count() 'scan'
			let p = try usesParams.get(i) otherwise panic("materializeThunkWitnessArg: usesParams.get OOB at {i}")
			if p == constraint.paramName 'hit'
				bound = try gidArgs.get(i) otherwise panic("materializeThunkWitnessArg: gidArgs.get OOB at {i}")
				foundBinding = true
				break
			end 'hit'
		end 'scan'
		if not foundBinding 'noBinding'
			panic("materializeThunkWitnessArg: constraint paramName '{constraint.paramName}' not in usesParams of '{baseName}' — TypeResolution miscarried the where-clause scope")
		end 'noBinding'
		return self.emitThunkWitnessLoadForBoundType(bound, interfaceName: constraint.requiredTraitName, dstBlock: dstBlock, idRef: idRef)
	end 'materializeThunkWitnessArg'

	function emitThunkWitnessLoadForBoundType(bound MaxonType, interfaceName String, dstBlock IrBlock, idRef ValueIdRef) returns ValueId
		let mangledIface = sanitizeIdentifier(interfaceName)
		let label = thunkWitnessLabelForBound(self.project, bound: bound, mangledIface: mangledIface, interfaceName: interfaceName)
		let resultId = allocValueId(idRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadWitnessTable(resultId, label: label)))
		return resultId
	end 'emitThunkWitnessLoadForBoundType'

	function forwardCallerWitness(qualifiedCallee String, constraint WhereClause, callerParamName String) returns ValueId
		// The caller must have an implicit witness slot whose
		// `(paramName, traitName)` pair matches the callee's constraint.
		// Look up by `callerParamName` first — the receiverContext-driven
		// resolution maps the callee's paramName onto the caller's scope,
		// so when the receiver pins `Source -> Iter` (the WithIterIterator
		// case) we look up `(Iter, Iterator)` on the caller. Fall back to
		// the historic same-name match when `callerParamName` is empty:
		// that path applies to the shared-scope shape where the caller
		// and callee inherit their type parameters from the same enclosing
		// type, so the names align by construction.
		var lookupParamName = callerParamName
		if callerParamName.isEmpty() 'fallback'
			lookupParamName = constraint.paramName
		end 'fallback'
		let constraints = self.currentMaxonFunc.implicitWitnessConstraints
		for i in 0 upto constraints.count() 'scan'
			let cc = try constraints.get(i) otherwise panic("forwardCallerWitness: constraints.get OOB at {i}")
			if cc.paramName == lookupParamName and cc.requiredTraitName == constraint.requiredTraitName 'hit'
				return try self.implicitWitnessValueIds.get(i) otherwise panic("forwardCallerWitness: implicitWitnessValueIds desync at {i}")
			end 'hit'
		end 'scan'
		panic("forwardCallerWitness: caller '{self.currentMaxonFunc.name}' has no witness for ({lookupParamName}, {constraint.requiredTraitName}) but call to '{qualifiedCallee}' needs one — TypeResolution should have either pinned a concrete receiver or matched the constraint shape")
	end 'forwardCallerWitness'

	// Resolve the callee's bare type-parameter name to a concrete type at
	// this call site. Returns `concrete(name)` when the receiverContext
	// supplies a fully-resolved binding, `forwardFromCaller` when the
	// binding is itself a type-parameter (caller is generic and forwards
	// `T`). The `callerParamName` payload pins which caller paramName
	// supplies the binding when it's recoverable; an empty string falls
	// back to the historic "use the callee's paramName as the lookup key"
	// path that holds whenever the caller and callee share a type-parameter
	// scope.
	function resolveCalleeParamToConcreteType(receiverContext MaxonType, qualifiedCallee String, paramName String) returns ResolvedCalleeParam
		match receiverContext 'pick'
			genericInstance(gid) then break 'pick'
			typeParameter then return ResolvedCalleeParam.forwardFromCaller("")
			interface then return ResolvedCalleeParam.forwardFromCaller("")
			unresolved then return ResolvedCalleeParam.forwardFromCaller("")
			named then return ResolvedCalleeParam.forwardFromCaller("")
			boolean then return ResolvedCalleeParam.concrete("bool")
			integer then return ResolvedCalleeParam.concrete("int")
			float then return ResolvedCalleeParam.concrete("float")
			string then return ResolvedCalleeParam.concrete("String")
			function then panic("resolveCalleeParamToConcreteType: callee '{qualifiedCallee}' references type-param '{paramName}' but the call site's receiverContext is a function type")
			constInt then panic("resolveCalleeParamToConcreteType: callee '{qualifiedCallee}' references type-param '{paramName}' but the call site's receiverContext is a constInt — constInt is a generic-arg marker, not a value type")
			opaquePointer then panic("resolveCalleeParamToConcreteType: callee '{qualifiedCallee}' references type-param '{paramName}' but the call site's receiverContext is an opaquePointer — opaquePointer is an ABI-bookkeeping slot type, not a value type")
		end 'pick'
		// genericInstance case: pair the declaring type's usesParams with
		// gidArgs and pluck out the entry whose paramName matches.
		let (baseTypeNameId, gidArgs) = match receiverContext 'getGid'
			genericInstance(gid) gives self.project.genericInstances.get(gid)
			default panic("resolveCalleeParamToConcreteType: receiverContext shape changed mid-resolve")
		end 'getGid'
		let baseTypeName = self.project.typeNames.get(baseTypeNameId)
		let usesParams = self.project.typeParameters.getParamNames(baseTypeName)
		if usesParams.count() != gidArgs.count() 'mismatch'
			panic("resolveCalleeParamToConcreteType: usesParams.count() ({usesParams.count()}) != gidArgs.count() ({gidArgs.count()}) for '{baseTypeName}' — generic instantiation arity bug")
		end 'mismatch'
		for i in 0 upto usesParams.count() 'scan'
			let p = try usesParams.get(i) otherwise panic("resolveCalleeParamToConcreteType: usesParams.get OOB at {i}")
			if p == paramName 'hit'
				let bound = try gidArgs.get(i) otherwise panic("resolveCalleeParamToConcreteType: gidArgs.get OOB at {i}")
				return resolvedCalleeParamFromMaxonType(self.project, t: bound)
			end 'hit'
		end 'scan'
		// paramName not in this struct's usesParams — could be a callee
		// param that doesn't appear on the receiver (e.g. a free generic
		// fn). Fall back to forwarding; the body will load whatever the
		// caller's current scope provides.
		return ResolvedCalleeParam.forwardFromCaller("")
	end 'resolveCalleeParamToConcreteType'

	// Convenience wrapper for the no-signature fallback in lowerCall: resolve
	// args verbatim (no leading receiver) and emit the call.
	function emitUnsignedCall(result ByteArray, qualifiedCallee String, args ByteArrayArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let argIds = self.resolveArgNames(args)
		self.emitCallWithArgs(result, qualifiedCallee: qualifiedCallee, argIds: argIds, dstBlock: dstBlock, errorBoundName: errorBoundName)
	end 'emitUnsignedCall'

	// Math primitives (sqrt, floor, ceil, round, abs, trunc) lower to
	// single-instruction Std unary ops. These are inlined directly into the
	// caller — no runtime wrapper, no call/ret overhead — because every
	// supported backend has native hardware for them (SQRTSD / ROUNDSD on x64,
	// FSQRT / FRINTM / FRINTP / FRINTN / FABS on ARM64, F64 unary opcodes on
	// Wasm). Going through a runtime call would dominate the cost of the work.
	// Int operands are implicitly promoted to f64; `trunc` short-circuits to
	// identity when its operand is already int (avoiding an int→f64→int round
	// trip that loses precision for ints outside f64's mantissa range).
	// Returns true if the call was lowered as an intrinsic.
	function lowerMathIntrinsic(result ByteArray, bareCallee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		let hit = try mathIntrinsicTarget(bareCallee) otherwise return self.lowerMathBinaryIntrinsic(result, bareCallee: bareCallee, args: args, dstBlock: dstBlock)
		// Math intrinsics take exactly one arg. If the arity is wrong, fall
		// through to normal call resolution which will surface the error.
		if args.count() != 1 'badArity'
			return false
		end 'badArity'
		let argName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let operandId = self.resolveName(argName)
		// trunc(int) is identity — alias the result to the operand directly.
		if bareCallee == "trunc" and not self.getIsFloat(operandId) 'truncOfInt'
			self.aliasName(result, toId: operandId)
			return true
		end 'truncOfInt'
		// All math intrinsics expect f64 input. Promote int operands.
		let promotedId = self.promoteToFloat(operandId, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(hit.opcode, resultId: resultId, operandId: promotedId))))
		self.setValueType(resultId, t: hit.resultType)
		return true
	end 'lowerMathIntrinsic'

	// Binary math intrinsics (`min`/`max`) lower to a single-instruction SSE
	// MINSD/MAXSD (x64), FMIN/FMAX (arm64), or f64.min/f64.max (wasm). Both
	// operands are promoted to f64; the result is f64. Returns false (so the
	// caller can fall through) if the callee isn't a binary intrinsic or
	// has the wrong arity.
	function lowerMathBinaryIntrinsic(result ByteArray, bareCallee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		let hit = try mathBinaryIntrinsicTarget(bareCallee) otherwise return false
		if args.count() != 2 'badArity'
			return false
		end 'badArity'
		let leftName = try args.get(0) otherwise panic("invariant: args.count() == 2 just checked")
		let rightName = try args.get(1) otherwise panic("invariant: args.count() == 2 just checked")
		let leftId = self.resolveName(leftName)
		let rightId = self.resolveName(rightName)
		let promotedLeft = self.promoteToFloat(leftId, dstBlock: dstBlock)
		let promotedRight = self.promoteToFloat(rightId, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(hit.opcode, resultId: resultId, leftId: promotedLeft, rightId: promotedRight))))
		self.setValueType(resultId, t: hit.resultType)
		return true
	end 'lowerMathBinaryIntrinsic'

	// Step 6a.19: lower one of the user-callable allocator intrinsics (whose
	// signatures are pre-registered by `registerMmIntrinsicSignatures`) into
	// a direct Std-IR sequence. Each `__mm_*` name maps to a single runtime
	// function call (or, for the count-reader intrinsics, a globalAddr +
	// loadIndirect pair against the same `__data_*` slot the runtime
	// increments). Returns true when the bareCallee matched a known
	// intrinsic; false leaves the caller to fall through to the normal
	// call-resolution path (which will end up emitting a call against the
	// pre-registered signature — typically panicking at link time because
	// no body exists). Treat that fall-through as a bug: a known prefix that
	// doesn't match here means a missing arm.
	function lowerMmIntrinsic(result ByteArray, bareCallee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		// `__mm_alloc`, `__mm_decref`, `__mm_incref`, `__mm_free` are now
		// regular stdlib functions in `stdlib/Internals.maxon` (file-visible
		// — only the stdlib internals file can call them). Internal calls
		// flow through the normal signature-driven emission to
		// `stdlib.__mm_*`. The only synthetic intrinsic left here is
		// `__mm_alloc_count`, which lowers to a `globalAddr + load` rather
		// than a function call so there's no matching parsed body.
		if bareCallee == "__mm_alloc_count" 'allocCount'
			return self.lowerMmCountRead(result, globalName: "__mm_alloc_count", args: args, dstBlock: dstBlock)
		end 'allocCount'
		return false
	end 'lowerMmIntrinsic'

	// Phase 7: lower a `__Builtins.METHOD(...)` qualified static call. Today
	// only `writeStdout` and `writeStderr` are supported — both unwrap the
	// MM (load buffer at off 0, length at off 8) and call into the runtime
	// helper (`mrt_write_stdout` / `mrt_write_stderr`). Returns true when
	// handled (caller must NOT fall through to the generic-call emission);
	// false when the method is not recognized so the caller can surface an
	// "unknown __Builtins.X" diagnostic via the regular path.
	function lowerBuiltinsIntrinsic(result ByteArray, methodName String, args ByteArrayArray, dstBlock IrBlock) returns bool
		if methodName == "writeStdout" 'isStdout'
			return self.lowerBuiltinsWriteStream(result, callee: "mrt_write_stdout", args: args, dstBlock: dstBlock)
		end 'isStdout'
		if methodName == "writeStderr" 'isStderr'
			return self.lowerBuiltinsWriteStream(result, callee: "mrt_write_stderr", args: args, dstBlock: dstBlock)
		end 'isStderr'
		if methodName == "readStdin" 'isReadStdin'
			return self.lowerBuiltinsReadStdin(result, args: args, dstBlock: dstBlock)
		end 'isReadStdin'
		if methodName == "floatToBits" 'isFloatToBits'
			return self.lowerBuiltinsFloatToBits(result, args: args, dstBlock: dstBlock)
		end 'isFloatToBits'
		if methodName == "ucdByteAt" 'isUcdByteAt'
			return self.lowerBuiltinsUcdByteAt(result, args: args, dstBlock: dstBlock)
		end 'isUcdByteAt'
		if methodName == "ucdI64At" 'isUcdI64At'
			return self.lowerBuiltinsUcdI64At(result, args: args, dstBlock: dstBlock)
		end 'isUcdI64At'
		if methodName == "commandLineCount" 'isClc'
			return self.lowerBuiltinsCommandLineCount(result, args: args, dstBlock: dstBlock)
		end 'isClc'
		if methodName == "commandLineArg" 'isCla'
			return self.lowerBuiltinsCommandLineArg(result, args: args, dstBlock: dstBlock)
		end 'isCla'
		if methodName == "executablePath" 'isExePath'
			return self.lowerBuiltinsExecutablePath(result, args: args, dstBlock: dstBlock)
		end 'isExePath'
		if methodName == "currentTimeMs" 'isCurrentTimeMs'
			return self.lowerBuiltinsCurrentTimeMs(result, args: args, dstBlock: dstBlock)
		end 'isCurrentTimeMs'
		if methodName == "sleep" 'isSleep'
			return self.lowerBuiltinsSleep(result, args: args, dstBlock: dstBlock)
		end 'isSleep'
		if methodName == "gtIsComplete" 'isGtIsComplete'
			return self.lowerBuiltinsGtIsComplete(result, args: args, dstBlock: dstBlock)
		end 'isGtIsComplete'
		// Phase 3.4: subprocess builtins each route to a fixed `maxon_subprocess_*`
		// runtime symbol. `lookupSubprocessBuiltin` keeps the (methodName ->
		// callee, arity, return-shape) mapping in one place; the actual emit is
		// shape-driven by `lowerBuiltinsSubprocessCall`.
		if let subprocessHit = try lookupSubprocessBuiltin(methodName) 'isSubprocess'
			return self.lowerBuiltinsSubprocessCall(result, args: args, dstBlock: dstBlock, methodName: methodName, hit: subprocessHit)
		end 'isSubprocess'
		return false
	end 'lowerBuiltinsIntrinsic'

	// Lower a `__Internals.METHOD(...)` qualified static call. Each method
	// expands to a single raw Std-level system op. The set is intentionally
	// minimal — only ops needed by migrated runtime helpers — and grows as
	// more helpers move out of runtime.std into stdlib/Internals.maxon.
	//
	// File-path gating: only `stdlib/Internals.maxon` may invoke these. Any
	// other caller produces a compile error. `currentFilePath` is populated
	// per-function by `processFunction`.
	function lowerInternalsIntrinsic(result ByteArray, methodName String, args ByteArrayArray, dstBlock IrBlock) returns bool
		let path = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
		if path.filename() != "Internals.maxon" 'gateRejected'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Internals.{methodName}: only stdlib/Internals.maxon may invoke __Internals.* intrinsics (caller: '{self.currentFilePath}')")
			return true
		end 'gateRejected'
		// Atomic ops
		if methodName == "atomicInc" 'isAtomicInc'
			return self.lowerInternalsAtomicUnary(methodName, result: result, args: args, dstBlock: dstBlock, isInc: true)
		end 'isAtomicInc'
		if methodName == "atomicDec" 'isAtomicDec'
			return self.lowerInternalsAtomicUnary(methodName, result: result, args: args, dstBlock: dstBlock, isInc: false)
		end 'isAtomicDec'
		if methodName == "atomicXadd" 'isAtomicXadd'
			return self.lowerInternalsAtomicXadd(result, args: args, dstBlock: dstBlock)
		end 'isAtomicXadd'
		// Memory load/store
		if methodName == "loadIndirect" 'isLoadIndirect'
			return self.lowerInternalsLoadIndirect(result, args: args, dstBlock: dstBlock)
		end 'isLoadIndirect'
		if methodName == "storeIndirect" 'isStoreIndirect'
			return self.lowerInternalsStoreIndirect(result, args: args, dstBlock: dstBlock)
		end 'isStoreIndirect'
		if methodName == "loadByte" 'isLoadByte'
			return self.lowerInternalsLoadByte(result, args: args, dstBlock: dstBlock)
		end 'isLoadByte'
		if methodName == "storeByte" 'isStoreByte'
			return self.lowerInternalsStoreByte(result, args: args, dstBlock: dstBlock)
		end 'isStoreByte'
		if methodName == "loadHalfword" 'isLoadHalfword'
			return self.lowerInternalsLoadSized(result, args: args, dstBlock: dstBlock, methodName: methodName, width: StoreWidth.halfword)
		end 'isLoadHalfword'
		if methodName == "storeHalfword" 'isStoreHalfword'
			return self.lowerInternalsStoreSized(result, args: args, dstBlock: dstBlock, methodName: methodName, width: StoreWidth.halfword)
		end 'isStoreHalfword'
		if methodName == "loadWord" 'isLoadWord'
			return self.lowerInternalsLoadSized(result, args: args, dstBlock: dstBlock, methodName: methodName, width: StoreWidth.word)
		end 'isLoadWord'
		if methodName == "storeWord" 'isStoreWord'
			return self.lowerInternalsStoreSized(result, args: args, dstBlock: dstBlock, methodName: methodName, width: StoreWidth.word)
		end 'isStoreWord'
		if methodName == "memcpy" 'isMemcpy'
			return self.lowerInternalsMemcpy(result, args: args, dstBlock: dstBlock)
		end 'isMemcpy'
		// Address-of-named-global / address-of-named-function bridges
		if let globalName = try lookupInternalsGlobalAddrTarget(methodName) 'isGlobalAddr'
			return self.lowerInternalsNamedGlobalAddr(result, args: args, dstBlock: dstBlock, globalName: globalName)
		end 'isGlobalAddr'
		if let funcName = try lookupInternalsFuncAddrTarget(methodName) 'isFuncAddr'
			return self.lowerInternalsNamedFuncAddr(result, args: args, dstBlock: dstBlock, funcName: funcName)
		end 'isFuncAddr'
		if methodName == "loadFramePtr" 'isLoadFramePtr'
			return self.lowerInternalsLoadFramePtr(result, args: args, dstBlock: dstBlock)
		end 'isLoadFramePtr'
		if methodName == "indirectCall1" 'isIndirectCall1'
			return self.lowerInternalsIndirectCall1(result, args: args, dstBlock: dstBlock)
		end 'isIndirectCall1'
		// Runtime-call bridges (each maps to a fixed runtime callee name)
		if let runtimeHit = try lookupInternalsRuntimeCallTarget(methodName) 'isRuntimeBridge'
			return self.lowerInternalsRuntimeCallN(result, args: args, dstBlock: dstBlock, callee: runtimeHit.callee, arity: runtimeHit.arity)
		end 'isRuntimeBridge'
		// OS ops
		if methodName == "osAllocPages" 'isOsAllocPages'
			return self.lowerInternalsOsAllocPages(result, args: args, dstBlock: dstBlock, large: false)
		end 'isOsAllocPages'
		if methodName == "osAllocPagesLarge" 'isOsAllocPagesLarge'
			return self.lowerInternalsOsAllocPages(result, args: args, dstBlock: dstBlock, large: true)
		end 'isOsAllocPagesLarge'
		if methodName == "osFreePages" 'isOsFreePages'
			return self.lowerInternalsOsFreePages(result, args: args, dstBlock: dstBlock)
		end 'isOsFreePages'
		if methodName == "osWrite" 'isOsWrite'
			return self.lowerInternalsOsWriteAny(result, args: args, dstBlock: dstBlock, toStderr: false)
		end 'isOsWrite'
		if methodName == "osWriteErr" 'isOsWriteErr'
			return self.lowerInternalsOsWriteAny(result, args: args, dstBlock: dstBlock, toStderr: true)
		end 'isOsWriteErr'
		if methodName == "osExit" 'isOsExit'
			return self.lowerInternalsOsExit(result, args: args, dstBlock: dstBlock)
		end 'isOsExit'
		self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Internals.{methodName}: unrecognized internals intrinsic")
		return true
	end 'lowerInternalsIntrinsic'

	// `__Internals.atomicInc(addr)` / `__Internals.atomicDec(addr)`: emit a
	// single atomic increment/decrement against [addr]. Returns void; the
	// caller's result ValueId is bound to a synthesized 0 const so any
	// downstream read still resolves.
	function lowerInternalsAtomicUnary(methodName String, result ByteArray, args ByteArrayArray, dstBlock IrBlock, isInc bool) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.{methodName}: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let addrId = self.resolveName(addrName)
		if isInc 'inc'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.atomicInc(addrId)))
		end 'inc' else 'dec'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.atomicDec(addrId)))
		end 'dec'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsAtomicUnary'

	// `__Internals.atomicXadd(addr, value)`: emit a single sys.atomic_xadd
	// op that returns the prior value at [addr] and updates it to
	// (prior + value). Used by `mm_decref` to detect transition to refcount
	// zero atomically.
	function lowerInternalsAtomicXadd(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.atomicXadd: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant: args.count() == 2 just checked (addr)")
		let valueName = try args.get(1) otherwise panic("invariant: args.count() == 2 just checked (value)")
		let addrId = self.resolveName(addrName)
		let valId = self.resolveName(valueName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.atomicXadd(resultId, addrId: addrId, valId: valId)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsAtomicXadd'

	// Bridge: `__Internals.X(arg)` → `call <callee>(arg)`. Emits a Std-level
	// call to a still-in-runtime helper. The callee is the bare runtime
	// function name (no namespace prefix) so the linker resolves it
	// directly against runtime.std's symbol. Returns void semantically; we
	// bind the result ValueId to a synthesized 0 const so downstream reads
	// (if any) resolve.
	// Runtime-call bridge: emits `call <callee>(args...)`. The arity is
	// fixed at the dispatch site (`lookupInternalsRuntimeCallTarget`), so
	// we just validate it matches and emit the Std call. The arity excludes
	// any implicit receiver — these are free-function bridges.
	function lowerInternalsRuntimeCallN(result ByteArray, args ByteArrayArray, dstBlock IrBlock, callee String, arity VarSlot) returns bool
		if args.count() != arity 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals bridge for '{callee}': expected {arity} args, got {args.count()}")
			return true
		end 'badArity'
		var argIds = ValueIdArray.create()
		for i in 0 upto args.count() 'eachArg'
			let argName = try args.get(i) otherwise panic("invariant: i < args.count()")
			argIds.push(self.resolveName(argName))
		end 'eachArg'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: callee, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsRuntimeCallN'

	// Named-global address-of: emits `globalAddr <globalName>`. The
	// globalName is baked in at the dispatch site, so there's no string
	// argument and therefore no String-allocation chain at the call site.
	function lowerInternalsNamedGlobalAddr(result ByteArray, args ByteArrayArray, dstBlock IrBlock, globalName String) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals address-of '{globalName}': expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(resultId, name: globalName)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsNamedGlobalAddr'

	function lowerInternalsNamedFuncAddr(result ByteArray, args ByteArrayArray, dstBlock IrBlock, funcName String) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals funcAddr '{funcName}': expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.funcAddr(resultId, name: funcName)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsNamedFuncAddr'

	// `__Internals.loadIndirect(addr)` -> i64. Offset is always 0 — for
	// non-zero offsets, the Maxon caller computes `addr + n` first. This
	// keeps the intrinsic shape simple and matches the runtime-helper style.
	function lowerInternalsLoadIndirect(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.loadIndirect: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant")
		let addrId = self.resolveName(addrName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsLoadIndirect'

	function lowerInternalsStoreIndirect(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.storeIndirect: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant")
		let valueName = try args.get(1) otherwise panic("invariant")
		let addrId = self.resolveName(addrName)
		let valId = self.resolveName(valueName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: 0, valueId: valId, width: StoreWidth.qword, isFloat: false)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsStoreIndirect'

	function lowerInternalsLoadByte(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.loadByte: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let baseName = try args.get(0) otherwise panic("invariant")
		let offsetName = try args.get(1) otherwise panic("invariant")
		let baseId = self.resolveName(baseName)
		let offsetId = self.resolveName(offsetName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadByte(resultId, baseId: baseId, offsetId: offsetId)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsLoadByte'

	function lowerInternalsStoreByte(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 3 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.storeByte: expected 3 args, got {args.count()}")
			return true
		end 'badArity'
		let baseName = try args.get(0) otherwise panic("invariant")
		let offsetName = try args.get(1) otherwise panic("invariant")
		let valueName = try args.get(2) otherwise panic("invariant")
		let baseId = self.resolveName(baseName)
		let offsetId = self.resolveName(offsetName)
		let valId = self.resolveName(valueName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeByte(baseId, offsetId: offsetId, byteId: valId)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsStoreByte'

	// Width-N unsigned load: `__Internals.loadHalfword(addr)` /
	// `__Internals.loadWord(addr)` → i64. Offset is always 0 — the Maxon
	// caller computes `addr + n` first. signed: false because these are the
	// raw width-N accessors; typed field loads needing sign-extension go
	// through the dedicated field-load path with signed: true.
	function lowerInternalsLoadSized(result ByteArray, args ByteArrayArray, dstBlock IrBlock, methodName String, width StoreWidth) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.{methodName}: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let addrId = self.resolveName(addrName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, width: width, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsLoadSized'

	// Width-N store: `__Internals.storeHalfword(addr, value)` /
	// `__Internals.storeWord(addr, value)`. The low N bytes of value are
	// written; high bits are discarded by the StdSystemOp.storeIndirect at
	// the chosen width.
	function lowerInternalsStoreSized(result ByteArray, args ByteArrayArray, dstBlock IrBlock, methodName String, width StoreWidth) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.{methodName}: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let addrName = try args.get(0) otherwise panic("invariant: args.count() == 2 just checked (addr)")
		let valueName = try args.get(1) otherwise panic("invariant: args.count() == 2 just checked (value)")
		let addrId = self.resolveName(addrName)
		let valId = self.resolveName(valueName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: 0, valueId: valId, width: width, isFloat: false)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsStoreSized'

	function lowerInternalsMemcpy(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 3 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.memcpy: expected 3 args, got {args.count()}")
			return true
		end 'badArity'
		let dstName = try args.get(0) otherwise panic("invariant")
		let srcName = try args.get(1) otherwise panic("invariant")
		let sizeName = try args.get(2) otherwise panic("invariant")
		let dstId = self.resolveName(dstName)
		let srcId = self.resolveName(srcName)
		let sizeId = self.resolveName(sizeName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.memcpy(dstId, srcId: srcId, lenId: sizeId)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsMemcpy'

	function lowerInternalsLoadFramePtr(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.loadFramePtr: expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadFramePtr(resultId)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsLoadFramePtr'

	function lowerInternalsIndirectCall1(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.indirectCall1: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let funcName = try args.get(0) otherwise panic("invariant")
		let argName = try args.get(1) otherwise panic("invariant")
		let funcId = self.resolveName(funcName)
		let argId = self.resolveName(argName)
		var argIds = ValueIdArray.create()
		argIds.push(argId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.indirectCall(resultId, calleeId: funcId, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsIndirectCall1'

	function lowerInternalsOsAllocPages(result ByteArray, args ByteArrayArray, dstBlock IrBlock, large bool) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.osAllocPages: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let sizeName = try args.get(0) otherwise panic("invariant")
		let sizeId = self.resolveName(sizeName)
		let resultId = self.defineName(result)
		if large 'isLarge'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osAllocPagesLarge(resultId, sizeId: sizeId)))
		end 'isLarge' else 'small'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osAllocPages(resultId, sizeId: sizeId)))
		end 'small'
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsOsAllocPages'

	function lowerInternalsOsFreePages(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.osFreePages: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let ptrName = try args.get(0) otherwise panic("invariant")
		let sizeName = try args.get(1) otherwise panic("invariant")
		let ptrId = self.resolveName(ptrName)
		let sizeId = self.resolveName(sizeName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osFreePages(ptrId, sizeId: sizeId)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsOsFreePages'

	function lowerInternalsOsWriteAny(result ByteArray, args ByteArrayArray, dstBlock IrBlock, toStderr bool) returns bool
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.osWrite: expected 2 args, got {args.count()}")
			return true
		end 'badArity'
		let ptrName = try args.get(0) otherwise panic("invariant")
		let lenName = try args.get(1) otherwise panic("invariant")
		let ptrId = self.resolveName(ptrName)
		let lenId = self.resolveName(lenName)
		if toStderr 'isErr'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osWriteErr(ptrId, lenId: lenId)))
		end 'isErr' else 'isOut'
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osWrite(ptrId, lenId: lenId)))
		end 'isOut'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsOsWriteAny'

	function lowerInternalsOsExit(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Internals.osExit: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let codeName = try args.get(0) otherwise panic("invariant")
		let codeId = self.resolveName(codeName)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.osExit(codeId)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerInternalsOsExit'

	// Phase 7 / 11.4: lower `__Builtins.floatToBits(f float) returns int` to a
	// single `bitcastF64ToI64` Std unary op. The op carries the standard
	// FP-to-GPR semantics — `movq xmm→gpr` on x64, `fmov gpr,d` on ARM64,
	// `i64.reinterpret_f64` on Wasm — without going through a stack slot.
	// Used by stdlib/PrimitiveExtensions.maxon (`float.hash` reads the bits).
	function lowerBuiltinsFloatToBits(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.floatToBits: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let valueName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let valueId = self.resolveName(valueName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.bitcastF64ToI64, resultId: resultId, operandId: valueId))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsFloatToBits'

	// Recover the bytes of a string-literal argument by walking from the
	// arg's SSA name back through `stringLiteralProvenance` to the StringId
	// the parser interned. Returns the literal bytes on success and throws
	// `NotAStringLiteral.notLiteral` if the operand was not produced by
	// `lowerStringConst` (e.g. the caller passed a runtime expression where
	// a literal was required). Used by the UCD builtins to extract the
	// rdata-blob label.
	function recoverStringLiteral(argName ByteArray) returns String throws NotAStringLiteral
		let valueId = self.resolveName(argName)
		let stringId = try self.stringLiteralProvenance.get(valueId) otherwise throw NotAStringLiteral.notLiteral
		return self.project.strings.get(stringId)
	end 'recoverStringLiteral'

	// Read a UCD blob from disk and register it in `globalData` under the
	// caller-supplied label. Idempotent — a second call for the same label
	// is an O(1) hit on `globalData.nameIndex`. The label is restricted to
	// the `__ucd_*` namespace so a crafted source string can't redirect the
	// path-join to an arbitrary file. The on-disk filename is the label
	// minus its leading `__`, located under `<stdlib>/helpers/string/`.
	function ensureUcdLoaded(label String) returns bool
		if self.globalData.nameIndex.contains(label) 'alreadyLoaded'
			return true
		end 'alreadyLoaded'
		if not label.startsWith("__ucd_") 'badLabel'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Builtins.ucd*: label '{label}' must begin with '__ucd_'")
			return false
		end 'badLabel'
		let stdlibPath = findStdlibPath()
		if stdlibPath.isEmpty() 'noStdlib'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Builtins.ucd*: cannot locate stdlib directory to load '{label}'")
			return false
		end 'noStdlib'
		let strippedLabel = try stripPrefix(label, prefix: "__") otherwise panic("invariant: ensureUcdLoaded requires __ucd_ prefix but stripPrefix __ threw on '{label}'")
		let fileName = "{strippedLabel}.bin"
		let binPath = stdlibPath.join("helpers").join("string").join(fileName)
		let bytes = try File.readBinary(binPath) otherwise 'readFail'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Builtins.ucd*: failed to read UCD blob '{binPath.path}'")
			return false
		end 'readFail'
		addNamedGlobalData(self.globalData, name: label, data: bytes)
		return true
	end 'ensureUcdLoaded'

	// Validate the (label, offsetOrIndex) shape shared by `__Builtins.ucdByteAt`
	// and `__Builtins.ucdI64At`. Throws `UcdLoadError.failed` after reporting
	// a compile-time error for arity mismatch, non-literal label, or missing
	// UCD blob; on success returns `UcdReady{label, operand}` and the caller
	// emits the actual load. The error-already-reported convention matches
	// the rest of `lowerBuiltinsIntrinsic`'s helpers.
	function prepareUcdLoadArgs(intrinsic String, args ByteArrayArray) returns UcdReady throws UcdLoadError
		if args.count() != 2 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.{intrinsic}: expected 2 args, got {args.count()}")
			throw UcdLoadError.failed
		end 'badArity'
		let labelName = try args.get(0) otherwise panic("invariant: args.count() == 2 just checked")
		let operandName = try args.get(1) otherwise panic("invariant: args.count() == 2 just checked")
		let label = try self.recoverStringLiteral(labelName) otherwise 'notLiteral'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "__Builtins.{intrinsic}: first argument must be a string literal")
			throw UcdLoadError.failed
		end 'notLiteral'
		if not self.ensureUcdLoaded(label) 'loadFailed'
			throw UcdLoadError.failed
		end 'loadFailed'
		return UcdReady.create(label, operand: self.resolveName(operandName))
	end 'prepareUcdLoadArgs'

	// Emit `globalAddr(label)` and bind the result to a fresh i64-typed
	// ValueId. Shared between the byte and i64 UCD intrinsics.
	function emitUcdGlobalAddr(label String, dstBlock IrBlock) returns ValueId
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: label)))
		self.setValueType(addrId, t: MaxonType.integer)
		return addrId
	end 'emitUcdGlobalAddr'

	// Phase 11.x: lower `__Builtins.ucdByteAt(label, offset) returns int`.
	// The label is a string literal naming a `__ucd_*` rdata blob registered
	// on first use by `ensureUcdLoaded`; `offset` is a byte offset into the
	// blob. Emits a single zero-extending `loadByte` from the blob's base
	// address — `loadByte` fuses the GEP that the C# bootstrap had to
	// materialise as a separate `lea` + `add`.
	function lowerBuiltinsUcdByteAt(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		let ready = try self.prepareUcdLoadArgs("ucdByteAt", args: args) otherwise return true
		let addrId = self.emitUcdGlobalAddr(ready.label, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadByte(resultId, baseId: addrId, offsetId: ready.operand)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsUcdByteAt'

	// Phase 11.x: lower `__Builtins.ucdI64At(label, index) returns int`.
	// `index` is in 8-byte units; scale by 8 and add to the blob base
	// before issuing an 8-byte `loadIndirect`. Used by the supplementary-
	// codepoint binary search in
	// `stdlib/helpers/string/unicodeCategory.maxon`.
	function lowerBuiltinsUcdI64At(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		let ready = try self.prepareUcdLoadArgs("ucdI64At", args: args) otherwise return true
		let addrId = self.emitUcdGlobalAddr(ready.label, dstBlock: dstBlock)
		let eightId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: eightId, value: 8))))
		self.setValueType(eightId, t: MaxonType.integer)
		let byteOffId = self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: ready.operand, rightId: eightId, dstBlock: dstBlock)
		let finalAddrId = self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: addrId, rightId: byteOffId, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: finalAddrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsUcdI64At'

	// Phase 15b: zero-arg `commandLineCount` lowers to a direct call into the
	// runtime helper, which performs the per-target argc retrieval.
	function lowerBuiltinsCommandLineCount(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.commandLineCount: expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let argIds = ValueIdArray.create()
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_command_line_count", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsCommandLineCount'

	// Phase 15b: `commandLineArg(index)` is a single-arg call. The runtime
	// helper returns a `__ManagedMemory` pointer freshly allocated for the
	// indexed argument's UTF-8 bytes; the caller (typically
	// `CommandLine.args()` in the stdlib) wraps it in a `String` via the
	// `String.init(managed)` constructor.
	function lowerBuiltinsCommandLineArg(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.commandLineArg: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let indexName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let indexId = self.resolveName(indexName)
		var argIds = ValueIdArray.create()
		argIds.push(indexId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_command_line_arg", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		return true
	end 'lowerBuiltinsCommandLineArg'

	// Phase 15f: zero-arg `executablePath` lowers to a direct call into the
	// runtime helper, which performs the per-target executable-path
	// retrieval (GetModuleFileNameW + UTF-16→UTF-8 on Windows; empty buffer
	// stub on other targets until WASI/readlink/_NSGetExecutablePath are
	// wired up). Returns a `__ManagedMemory` so the stdlib's
	// `Process.executablePath()` can wrap it in a `String` / `FilePath`.
	function lowerBuiltinsExecutablePath(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.executablePath: expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let argIds = ValueIdArray.create()
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_executable_path", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		return true
	end 'lowerBuiltinsExecutablePath'

	// Phase 3.4: zero-arg monotonic-clock primitive. Lowers to the runtime
	// helper that returns milliseconds since some fixed-but-platform-defined
	// epoch — the absolute value is meaningless, but differences are
	// meaningful (stdlib `Clock.elapsedMs` clamps to 0 on apparent skew).
	// `__Builtins.sleep(ms)`: suspend the current green thread for `ms`
	// milliseconds. Lowers to the runtime helper `maxon_sleep`. Mirrors the
	// C# bootstrap entry in Compiler/2-Parser.cs:9271. The intrinsic is
	// void-returning, so we bind a synthesized 0-const to the user-visible
	// result name (matches the void-call convention in
	// `lowerBuiltinsSubprocessCall`).
	function lowerBuiltinsSleep(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.sleep: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let msName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let msId = self.resolveName(msName)
		var argIds = ValueIdArray.create()
		argIds.push(msId)
		let throwawayId = allocValueId(self.funcIdRef)
		self.setValueType(throwawayId, t: MaxonType.integer)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(throwawayId, callee: "maxon_sleep", argIds: argIds)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsSleep'

	function lowerBuiltinsGtIsComplete(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.gtIsComplete: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let gtName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let gtId = self.resolveName(gtName)
		var argIds = ValueIdArray.create()
		argIds.push(gtId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "__gt_is_complete", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsGtIsComplete'

	function lowerBuiltinsCurrentTimeMs(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.currentTimeMs: expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		let argIds = ValueIdArray.create()
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "maxon_current_time_ms", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsCurrentTimeMs'

	// Common shape for `__Builtins.writeStdout` / `__Builtins.writeStderr`:
	// arg 0 is a `__ManagedMemory` pointer; load the buffer at offset 0
	// and length at offset 8, then call the runtime helper with both i64
	// values. The runtime returns the number of bytes written (i64).
	function lowerBuiltinsWriteStream(result ByteArray, callee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.{callee}: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let mmName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let mmId = self.resolveName(mmName)
		let bufId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(bufId, addrId: mmId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(bufId, t: MaxonType.integer)
		let lenId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(lenId, addrId: mmId, offset: 8, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(lenId, t: MaxonType.integer)
		var argIds = ValueIdArray.create()
		argIds.push(bufId)
		argIds.push(lenId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: callee, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerBuiltinsWriteStream'

	// `__Builtins.readStdin(maxBytes)`: delegate to the runtime helper
	// `mrt_read_stdin_managed`, which allocates a `__ManagedMemory` of
	// capacity `maxBytes`, reads up to `maxBytes` bytes from stdin into the
	// MM's buffer, sets the MM's length to the bytes actually read (0 on
	// EOF), and returns the MM pointer. The runtime-side construction keeps
	// the per-target MM allocation policy consistent with every other
	// MM-returning builtin (commandLineArg / executablePath).
	function lowerBuiltinsReadStdin(result ByteArray, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.readStdin: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let maxBytesName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let maxBytesId = self.resolveName(maxBytesName)
		var argIds = ValueIdArray.create()
		argIds.push(maxBytesId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_read_stdin_managed", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		return true
	end 'lowerBuiltinsReadStdin'

	// Phase 3.4: shape-driven subprocess intrinsic lowering. All subprocess
	// builtins are pure pass-through to a `maxon_subprocess_*` runtime symbol
	// — the call's arg names map directly to the runtime arg slots, no
	// per-call MM unwrap or address-of fixup. `hit.returnShape` decides how
	// the result ValueId is bound: i64 for the integer-returning family,
	// `__ManagedMemory` for the resolveOnPath / lastErrorMessage / result-
	// accessor MM family, and a synthesized constI64 0 for the void
	// `subprocessReleaseHandle` / `subprocessResultRelease` pair so any
	// downstream read of the source-level call expression still resolves.
	function lowerBuiltinsSubprocessCall(result ByteArray, args ByteArrayArray, dstBlock IrBlock, methodName String, hit SubprocessBuiltinHit) returns bool
		if args.count() != hit.arity 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "__Builtins.{methodName}: expected {hit.arity} args, got {args.count()}")
			return true
		end 'badArity'
		var argIds = ValueIdArray.create()
		for i in 0 upto args.count() 'eachArg'
			let argName = try args.get(i) otherwise panic("invariant: i < args.count() just checked")
			argIds.push(self.resolveName(argName))
		end 'eachArg'
		let mmType = MaxonType.named(self.project.typeNames.intern("__ManagedMemory"))
		let isVoid = match hit.returnShape 'pickVoid'
			returnsVoid gives true
			returnsInt gives false
			returnsManaged gives false
		end 'pickVoid'
		if isVoid 'voidCall'
			// The user-visible result name binds to a synthesized 0-const so
			// downstream reads of the source-level call expression still
			// resolve; the runtime helper has no return value. The call op's
			// own result ValueId is a throwaway — DCE drops it after the
			// call retires. Mirrors the void-call convention used by
			// `lowerInternalsAtomicUnary` and friends.
			let throwawayId = allocValueId(self.funcIdRef)
			self.setValueType(throwawayId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(throwawayId, callee: hit.callee, argIds: argIds)))
			let resultId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
			self.setValueType(resultId, t: MaxonType.integer)
			return true
		end 'voidCall'
		let resultType = match hit.returnShape 'pickType'
			returnsInt gives MaxonType.integer
			returnsManaged gives mmType
			returnsVoid gives MaxonType.integer
		end 'pickType'
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: hit.callee, argIds: argIds)))
		self.setValueType(resultId, t: resultType)
		return true
	end 'lowerBuiltinsSubprocessCall'

	// Lower a 1-arg allocator intrinsic to `runtime_callee(arg)`. The
	// runtime helpers return i64 (or "void" by always returning 0); we
	// always allocate a result ValueId so subsequent reads resolve, even
	// when the source-level call is for a void-returning helper like
	// `mm_decref` whose return is discarded.
	function lowerMmRuntimeCall1(result ByteArray, callee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 1 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "{callee}: expected 1 arg, got {args.count()}")
			return true
		end 'badArity'
		let argName = try args.get(0) otherwise panic("invariant: args.count() == 1 just checked")
		let argId = self.resolveName(argName)
		var argIds = ValueIdArray.create()
		argIds.push(argId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: callee, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerMmRuntimeCall1'

	// 3-arg variant: `mm_alloc(size, destructor, tag)`.
	function lowerMmRuntimeCall3(result ByteArray, callee String, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 3 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "{callee}: expected 3 args, got {args.count()}")
			return true
		end 'badArity'
		let sizeName = try args.get(0) otherwise panic("invariant: args.count() == 3 just checked (size)")
		let dtorName = try args.get(1) otherwise panic("invariant: args.count() == 3 just checked (destructor)")
		let tagName = try args.get(2) otherwise panic("invariant: args.count() == 3 just checked (tag)")
		var argIds = ValueIdArray.create()
		argIds.push(self.resolveName(sizeName))
		argIds.push(self.resolveName(dtorName))
		argIds.push(self.resolveName(tagName))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: callee, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerMmRuntimeCall3'

	// Lower the `__mm_alloc_count` count-reader intrinsic to
	// `loadIndirect(globalAddr(__mm_alloc_count))`. Reads the same i64 slot
	// that `mm_alloc` increments atomically — no runtime call needed.
	// Zero-arg.
	function lowerMmCountRead(result ByteArray, globalName String, args ByteArrayArray, dstBlock IrBlock) returns bool
		if args.count() != 0 'badArity'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "{globalName}: expected 0 args, got {args.count()}")
			return true
		end 'badArity'
		// The runtime registers `__mm_alloc_count` in the .data prelude
		// under its bare name (see `registerSlabAndMmGlobalsForDataSection`);
		// it is NOT a user global behind the `__data_` qualifier, so we go
		// through `globalAddr` with the raw name and skip `dataSymbolName`.
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: globalName)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerMmCountRead'

	// Step 6b.4: lower a `__ManagedMemory.METHOD(...)` call (instance or
	// static) into Std-IR. Simple read-only methods (length / capacity /
	// elementSize / clear / toCString) inline as direct loadIndirect /
	// storeIndirect ops. Throwing methods (get / set / grow / slice / ...)
	// expand to a call into a runtime helper (`__managed_mem_*`) defined
	// in runtime.std that performs bounds checking and returns a non-zero
	// variant ordinal in the secondary error register (RDX/X1) on failure —
	// the parser's `try ... otherwise` machinery picks up the flag at the
	// call site.
	//
	// Per-method dispatch table:
	//   length(self)                 -> loadIndirect(self, 8)
	//   capacity(self)               -> loadIndirect(self, 16)
	//   elementSize(self)            -> loadIndirect(self, 24)
	//   clear(self)                  -> storeIndirect(self, 8, 0)
	//   toCString(self)              -> loadIndirect(self, 0)
	//   setLength(self, n)           -> __managed_mem_set_length(self, n)
	//   get(self, i)                 -> __managed_mem_get(self, i)
	//   set(self, i, v)              -> __managed_mem_set(self, i, v)
	//   remove(self, i)              -> __managed_mem_remove(self, i)
	//   grow(self, c)                -> __managed_mem_grow(self, c)
	//   shiftRight(self, idx, c)     -> __managed_mem_shift_right(self, idx, c)
	//   shiftLeft(self, idx, c)      -> __managed_mem_shift_left(self, idx, c)
	//   byteAt(self, i)              -> __managed_mem_byte_at(self, i)
	//   setByte(self, i, v)          -> __managed_mem_set_byte(self, i, v)
	//   append(self, other)          -> __managed_mem_append(self, other)
	//   slice(self, s, e)            -> __managed_mem_slice(self, s, e)
	//   create(count, elemSize)      -> __managed_mem_create(count, elemSize)
	//
	// `slotArgsForCall` handles labels and defaults so positional+labeled
	// mixes (`mm.set(0, value: 42)`) flow into the runtime call in the
	// right slot order. Returns true when the method matched a known
	// builtin; false leaves the caller to fall through to the regular
	// call-emission path (which would then emit a call to a body-less
	// signature — a bug since every method registered in
	// `registerManagedMemoryMethods` MUST have an arm here).
	function lowerManagedMemBuiltin(result ByteArray, methodName String, receiverId ValueId, hasReceiver bool, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, opIdx OpIndex, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create()) returns bool
		let qualifiedName = "__ManagedMemory.{methodName}"
		let sigLookup = try self.project.funcSignatures.get(qualifiedName) otherwise 'noSig'
			return false
		end 'noSig'
		var paramStartIndex = 0
		if hasReceiver 'instance'
			paramStartIndex = 1
		end 'instance'
		let allArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: paramStartIndex, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: receiverId, hasLeadingReceiver: hasReceiver)

		// --- Simple inline paths ----------------------------------------
		if methodName == "length" 'mLength'
			return self.lowerMmFieldLoad(result, selfId: receiverId, offset: 8, dstBlock: dstBlock)
		end 'mLength'
		if methodName == "capacity" 'mCapacity'
			return self.lowerMmFieldLoad(result, selfId: receiverId, offset: 16, dstBlock: dstBlock)
		end 'mCapacity'
		if methodName == "elementSize" 'mElemSize'
			return self.lowerMmFieldLoad(result, selfId: receiverId, offset: 24, dstBlock: dstBlock)
		end 'mElemSize'
		if methodName == "toCString" 'mCString'
			return self.lowerMmFieldLoad(result, selfId: receiverId, offset: 0, dstBlock: dstBlock)
		end 'mCString'
		// Phase 11.4: createCursor allocates a real __ManagedMemoryCursor struct
		// and copies buffer/length/element_size from the source __ManagedMemory.
		// Cursor layout (40 bytes):
		//   offset  0  buffer        i64  (data pointer copied from source)
		//   offset  8  position      i64  (current index, starts at 0)
		//   offset 16  length        i64  (copied from source for fast access)
		//   offset 24  element_size  i64  (copied from source)
		//   offset 32  source_ptr    i64  (pointer back to source MM, retained)
		// Sets the error flag to `emptySlot` (1) when the source is empty so
		// the stdlib's `try source.createCursor() otherwise throw` machinery
		// catches it before the empty cursor leaks into a `for in` body.
		if methodName == "createCursor" 'mCreateCursor'
			self.lowerCreateCursor(result, sourceId: receiverId, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'mCreateCursor'
		if methodName == "clear" 'mClear'
			let zeroId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: zeroId, value: 0))))
			self.setValueType(zeroId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(receiverId, offset: 8, valueId: zeroId, width: StoreWidth.qword, isFloat: false)))
			let resId = self.defineName(result)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resId, value: 0))))
			self.setValueType(resId, t: MaxonType.integer)
			return true
		end 'mClear'

		// --- Constant-array-to-rdata fast path --------------------------
		// `ConstantArrayLiteralRdata` pass tagged this call op as a
		// known-constant array literal whose bytes are already emitted into
		// `.rdata`. Skip the runtime `__managed_mem_create` (which would
		// allocate a fresh writable buffer) and instead point the freshly-
		// allocated __ManagedMemory header at the rdata label with the
		// read-only sentinels (capacity = -2, parent = -2). The per-element
		// `set` / `setLength` calls were stripped by the pass.
		if methodName == "create" 'maybeRdata'
			if let info = try self.project.constantArrayRdata.get(opIdx) 'hasRdataInfo'
				self.lowerManagedMemCreateFromRdata(result, info: info, dstBlock: dstBlock)
				self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
				return true
			end 'hasRdataInfo'
		end 'maybeRdata'

		// --- Runtime-helper dispatch ------------------------------------
		if let helperName = try managedMemHelperFor(methodName) 'hasHelper'
			// Throwing helpers (e.g. `_get`, `_set`, `_grow`, `_slice`) write the
			// error flag in RDX/X1 — emit `StdCallOp.tryCall` at try-call sites
			// to capture both the result and the flag. Non-throwing helpers
			// (`_append`, `_create`) don't write the flag register; when the
			// call site is a tryCall (parser emitted a `tryMethodCall` because
			// the method is registered as throwing in the signature, even though
			// the runtime body never errors), bind the parser-supplied flag
			// virtual to a const zero so downstream readers see "no error".
			let isThrowingHelper = managedMemHelperThrows(methodName)
			let helperBoundName = errorBoundName if isThrowingHelper else ByteArray.create()
			let lowered = self.lowerManagedMemRuntimeCall(result, helperName: helperName, argIds: allArgIds, dstBlock: dstBlock, errorBoundName: helperBoundName)
			if not isThrowingHelper 'bindZeroForNonThrowing'
				self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
			end 'bindZeroForNonThrowing'
			// Per-method result-type refinement. The generic helper-call path
			// stamps integer; for methods whose declared return type is a
			// non-integer (e.g. `create returns __ManagedMemory`,
			// `slice returns __ManagedMemory`, `get returns Element`) the
			// generic stamp is wrong and downstream method dispatch on the
			// result would fall through to the interface-stub path. Look up
			// the registered MaxonReturnType and re-stamp when it disagrees.
			if lowered 'refineType'
				self.refineMmCallResultType(result, methodName: methodName)
			end 'refineType'
			// Sign-extend narrow signed reads. `__managed_mem_get` for
			// elemSize ∈ {1, 2, 4} routes through `loadByte` / `loadHalfword` /
			// `loadWord`, which zero-extend by default. For signed narrow
			// element types (`i8` / `i16` / `i32`), the SSA value must be
			// arithmetic-shifted left then right to recover the sign bit
			// before user code (or the inlined Array.get wrapper) reads
			// `arr.get(i).rawValue`. Note: this path covers direct
			// `__ManagedMemory` method calls; user `arr.get(...)` flows
			// through `Array.get` → `emitCallWithArgs`, which handles its
			// own narrow-signed sign-extension via `maybeSignExtendCallResult`.
			if methodName == "get" and hasReceiver 'maybeSignExt'
				self.maybeSignExtendNarrowGetResult(result, receiverId: receiverId, dstBlock: dstBlock)
			end 'maybeSignExt'
			return lowered
		end 'hasHelper'

		// Unknown method on `__ManagedMemory`. Falling through here means
		// the parser accepted a method name we never registered — drop a
		// compile-error breadcrumb so the build stops with a clear message
		// rather than emitting a call to a non-existent runtime helper.
		self.reportLowerError(ErrorCode.semanticUndefinedVariable, message: "lowerManagedMemBuiltin: unknown method '__ManagedMemory.{methodName}'")
		let placeholder = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: placeholder, value: 0))))
		self.setValueType(placeholder, t: MaxonType.integer)
		return true
	end 'lowerManagedMemBuiltin'

	// Shared dispatcher for `__ManagedFile.*`, `__ManagedDirectory.*`,
	// `__ManagedList.*`, `__ManagedListNode.*`, and `__ManagedSocket.*` method
	// calls. Modeled exactly on `lowerManagedMemBuiltin` above — see its header
	// comment for the shared machinery (signature lookup, argument slotting,
	// throwing-vs-non-throwing emit, result-type re-stamping). The only
	// per-receiver bits are the helper-name map and the throws-set, both keyed
	// on `receiverName` inside `managedHandleHelperFor` /
	// `managedHandleHelperThrows`.
	//
	// The runtime helpers live in `runtime.std`. The file/directory helpers
	// (Phase 15c Stream 2.3) and the socket helpers (Phase D) currently ship
	// sentinel-erroring stubs that return -1 with the error flag set for
	// throwing helpers (return 0 / sentinel for non-throwing); the real
	// per-target implementations replace each stub body in later streams. The
	// list helpers (Phase C) ship the full implementation now.
	//
	// No inline fast paths exist for any of these receivers — every method
	// flows through a runtime helper.
	function lowerManagedHandleBuiltin(receiverName String, result ByteArray, methodName String, receiverId ValueId, hasReceiver bool, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, opIdx OpIndex, dstBlock IrBlock, receiverType MaxonType = MaxonType.unresolved, errorBoundName ByteArray = ByteArray.create()) returns bool
		let qualifiedName = "{receiverName}.{methodName}"
		let sigLookup = try self.project.funcSignatures.get(qualifiedName) otherwise 'noSig'
			return false
		end 'noSig'
		var paramStartIndex = 0
		if hasReceiver 'instance'
			paramStartIndex = 1
		end 'instance'
		let allArgIds = self.slotArgsForCall(sigLookup, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, paramStartIndex: paramStartIndex, opIdx: opIdx, dstBlock: dstBlock, leadingReceiverId: receiverId, hasLeadingReceiver: hasReceiver)

		let helperName = try managedHandleHelperFor(receiverName, methodName: methodName) otherwise 'noHelper'
			self.reportUnknownManagedHandleMethod(result, qualifiedName: qualifiedName, dstBlock: dstBlock)
			return true
		end 'noHelper'

		let isThrowingHelper = managedHandleHelperThrows(receiverName, methodName: methodName)
		let helperBoundName = errorBoundName if isThrowingHelper else ByteArray.create()
		let lowered = self.lowerManagedMemRuntimeCall(result, helperName: helperName, argIds: allArgIds, dstBlock: dstBlock, errorBoundName: helperBoundName)
		if not isThrowingHelper 'bindZeroForNonThrowing'
			self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
		end 'bindZeroForNonThrowing'
		if lowered 'refineType'
			self.refineBuiltinCallResultType(result, receiverName: receiverName, methodName: methodName, receiverType: receiverType)
		end 'refineType'
		return lowered
	end 'lowerManagedHandleBuiltin'

	// Shared "unknown method" reporter for the `__ManagedFile.*` /
	// `__ManagedDirectory.*` dispatch tail. Mirrors the equivalent fallback
	// in `lowerManagedMemBuiltin`: emit a compile-error breadcrumb and stamp
	// a zero placeholder so the build stops with a clear message rather than
	// emitting a call to a non-existent runtime helper.
	function reportUnknownManagedHandleMethod(result ByteArray, qualifiedName String, dstBlock IrBlock)
		self.reportLowerError(ErrorCode.semanticUndefinedVariable, message: "lowerManagedHandleBuiltin: unknown method '{qualifiedName}'")
		let placeholder = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: placeholder, value: 0))))
		self.setValueType(placeholder, t: MaxonType.integer)
	end 'reportUnknownManagedHandleMethod'

	// Phase 11.4: lower a `__ManagedMemoryCursor.method` call inline. The
	// cursor is a real 40-byte heap struct (see `lowerCreateCursor` above);
	// each method here reads/writes fields by offset and emits the right
	// arithmetic for navigation + bounds checks. Throwing methods alias the
	// parser-supplied `errorBoundName` to the computed error-code SSA value
	// via `emitFlagBind`; the surrounding stdlib `try raw.method() otherwise
	// throw` reads the flag through that name and rethrows the user-facing
	// IterationError.
	//
	// Self-hosted's `__ManagedMemoryError` enum:
	//   0 indexOutOfBounds
	//   1 emptySlot          ← used for advance/seek/peek "exhausted"
	//   2 sliceOutOfBounds   ← used for retreat "atStart"
	//
	// Stdlib's `ArrayIterator.advance()` only checks "did anything throw";
	// it doesn't inspect the specific code, so the wrapper-side `IterationError`
	// it rethrows looks the same to the user regardless. Choosing the codes
	// above keeps the wire format consistent with the existing enum and
	// stays parallel to the C# bootstrap's two-code scheme (1 = exhausted,
	// 2 = atStart).
	function lowerManagedMemoryCursorBuiltin(result ByteArray, methodName String, receiverId ValueId, elementType MaxonType, args ValueIdArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create()) returns bool
		if methodName == "current" 'mCurrent'
			self.lowerCursorCurrent(result, cursorId: receiverId, elementType: elementType, dstBlock: dstBlock)
			return true
		end 'mCurrent'
		if methodName == "index" 'mIndex'
			self.lowerCursorIndex(result, cursorId: receiverId, dstBlock: dstBlock)
			return true
		end 'mIndex'
		if methodName == "advance" 'mAdvance'
			self.lowerCursorAdvance(result, cursorId: receiverId, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'mAdvance'
		if methodName == "retreat" 'mRetreat'
			self.lowerCursorRetreat(result, cursorId: receiverId, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'mRetreat'
		if methodName == "seek" 'mSeek'
			let indexId = try args.get(0) otherwise panic("lowerManagedMemoryCursorBuiltin: seek missing index arg")
			self.lowerCursorSeek(result, cursorId: receiverId, indexId: indexId, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'mSeek'
		if methodName == "peek" 'mPeek'
			let aheadId = try args.get(0) otherwise panic("lowerManagedMemoryCursorBuiltin: peek missing ahead arg")
			self.lowerCursorPeek(result, cursorId: receiverId, aheadId: aheadId, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'mPeek'
		// Unknown method on the cursor — fall through with a clear diagnostic
		// so the build stops loudly rather than silently emitting an unrelated
		// no-op constant.
		self.reportLowerError(ErrorCode.semanticUndefinedVariable, message: "lowerManagedMemoryCursorBuiltin: unknown method '__ManagedMemoryCursor.{methodName}'")
		let placeholder = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: placeholder, value: 0))))
		self.setValueType(placeholder, t: MaxonType.integer)
		return true
	end 'lowerManagedMemoryCursorBuiltin'

	// Phase 11.4: helper ops for the cursor lowering. Each emits a fresh
	// const op + returns the ValueId so callers compose loads / stores
	// without re-typing the boilerplate.

	// Emit `const i64 value` and return its ValueId.
	function emitConstI64(value ParsedInt, dstBlock IrBlock) returns ValueId
		let id = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: id, value: value))))
		return id
	end 'emitConstI64'

	// Materialize a `ParamDefault` as a Std value at a call-site default-fill
	// slot. Simple literal arms produce an i64-typed constant that's then
	// coerced to the declared param type via `coerceValueToParam` (matches
	// the int-literal path that pre-dated multi-arm defaults). For
	// `enumCase`, the enum's case ordinal is looked up against
	// `project.enumTypes`. For `helper`, a zero-arg call is emitted to the
	// parser-synthesized helper function that wraps the default expression
	// — its return type already matches the param type, so the result
	// flows directly without a type-coercion bridge.
	function materializeParamDefault(pd ParamDefault, paramType MaxonType, dstBlock IrBlock) returns ValueId
		// Variant dispatch. Each arm picks the source-level MaxonType the
		// constant carries so `coerceValueToParam`'s category check
		// stays inside its supported pairs:
		//   * intLiteral  → integer category (int↔float bridge applies).
		//   * boolLiteral → bool category (matches a `bool` param without
		//                   an int→bool implicit, which doesn't exist).
		//   * byteLiteral → integer (byte and char-byte both lower to i64
		//                   on the int channel).
		//   * enumCase    → integer (the case's ordinal flows as an i64).
		//   * floatLiteralBits → float (constF64 op; IEEE-754 bits land
		//                   directly without a numeric conversion).
		//   * helper      → zero-arg call to the parser-synthesized
		//                   helper, whose return type already matches.
		match pd 'pickValue'
			intLiteral(value) then return self.emitParamDefaultConstI64(value, fromType: MaxonType.integer, paramType: paramType, dstBlock: dstBlock)
			boolLiteral(value) then return self.emitParamDefaultConstI64(1 if value else 0, fromType: MaxonType.boolean, paramType: paramType, dstBlock: dstBlock)
			byteLiteral(value) then return self.emitParamDefaultConstI64(value, fromType: MaxonType.integer, paramType: paramType, dstBlock: dstBlock)
			enumCase(typeName, caseName) then return self.emitParamDefaultConstI64(self.lookupEnumCaseOrdinal(typeName, caseName: caseName), fromType: MaxonType.integer, paramType: paramType, dstBlock: dstBlock)
			floatLiteralBits(bits) then return self.emitParamDefaultConstF64(bits, paramType: paramType, dstBlock: dstBlock)
			helper(helperName) then return self.emitParamDefaultHelperCall(helperName, paramType: paramType, dstBlock: dstBlock)
			none then panic("materializeParamDefault: invariant — caller must check paramDefaultHasValue first")
		end 'pickValue'
	end 'materializeParamDefault'

	// Emit a `constI64` op for an integer-shaped parameter default.
	// `fromType` tags the SSA value with its source-level type so a
	// `bool` default lands at category bool (not int), avoiding a spurious
	// `coerceValueToParam` int→bool panic. The value still routes through
	// `coerceValueToParam` so an int default to a float-typed parameter
	// goes through the int↔float widening bridge.
	function emitParamDefaultConstI64(rawValue ParsedInt, fromType MaxonType, paramType MaxonType, dstBlock IrBlock) returns ValueId
		let constId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: constId, value: rawValue))))
		self.setValueType(constId, t: fromType)
		// Char-byte → Character: the parser stores a char-literal default
		// (`= 'A'`) as a `byteLiteral` whose value is the raw codepoint.
		// When the declared parameter type is the `Character` struct,
		// wrap the byte into a managed-memory-backed Character at the
		// call site — same materialization the arg-coercion path uses
		// for `f('a')` against a `Character` param, but the constant
		// arrives via the signature default-fill loop instead of
		// `coerceArgToParam`.
		if paramType.nameOrEmpty(self.project) == "Character" 'charWrap'
			return self.materializeCharacterFromByte(constId, dstBlock: dstBlock)
		end 'charWrap'
		return self.coerceValueToParam(constId, fromType: fromType, toType: paramType, dstBlock: dstBlock)
	end 'emitParamDefaultConstI64'

	// Emit a `constF64` op for a float-literal default. The `bits` payload
	// is the IEEE-754 representation parsed by the lexer/parser, so the
	// resulting SSA value is typed f64. `coerceValueToParam` handles the
	// (rare) target-type narrowing if the declared parameter type is a
	// ranged float typealias whose representation differs from f64.
	function emitParamDefaultConstF64(bits ParsedInt, paramType MaxonType, dstBlock IrBlock) returns ValueId
		let constId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constF64, resultId: constId, value: bits))))
		self.setValueType(constId, t: MaxonType.float)
		return self.coerceValueToParam(constId, fromType: MaxonType.float, toType: paramType, dstBlock: dstBlock)
	end 'emitParamDefaultConstF64'

	// Emit a zero-arg call to a parser-synthesized default-value helper.
	// The helper's return type is `paramType` by construction, so the
	// result lands typed-correctly without an additional coercion.
	function emitParamDefaultHelperCall(helperName String, paramType MaxonType, dstBlock IrBlock) returns ValueId
		let resultId = allocValueId(self.funcIdRef)
		let argIds = ValueIdArray.create()
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: helperName, argIds: argIds)))
		self.setValueType(resultId, t: paramType)
		return resultId
	end 'emitParamDefaultHelperCall'

	// Resolve `EnumName.caseName` to the case's ordinal (the index of the
	// case in its declaring enum's `cases` list). For ordinal-backed enums
	// the ordinal equals the runtime value; for raw-value enums the parser
	// records explicit values on each case which the lowering uses
	// elsewhere — but `paramDefault.enumCase` always materializes the
	// case's ORDINAL (matching how `EnumName.caseName` is constructed at
	// runtime in other lowering paths).
	function lookupEnumCaseOrdinal(typeName String, caseName String) returns ParsedInt
		let enumType = try self.project.enumTypes.get(typeName) otherwise panic("paramDefault.enumCase: enum '{typeName}' not found in project.enumTypes — parser accepted a default referencing an undeclared enum")
		for i in 0 upto enumType.cases.count() 'eachCase'
			let c = try enumType.cases.get(i) otherwise panic("lookupEnumCaseOrdinal: cases.get OOB at {i}")
			if c.name == caseName 'hit'
				return i as ParsedInt
			end 'hit'
		end 'eachCase'
		panic("paramDefault.enumCase: enum '{typeName}' has no case '{caseName}'")
	end 'lookupEnumCaseOrdinal'

	// Emit `result = loadIndirect(addrId + offset)` typed i64 and return resultId.
	// Used for pointer-shaped header words (managed-memory metadata, union tags,
	// payload slots) — every one of those is i64-wide so the helper hardcodes
	// width=qword, signed=false. Narrow user-struct field loads inline their
	// own `StdSystemOp.loadIndirect` because they resolve `width` / `signed`
	// from the field's MaxonType at the call site.
	function emitLoadFieldI64(addrId ValueId, offset ParsedInt, dstBlock IrBlock) returns ValueId
		let id = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(id, addrId: addrId, offset: offset, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(id, t: MaxonType.integer)
		return id
	end 'emitLoadFieldI64'

	// Emit `storeIndirect(addrId + offset, valueId)` for an i64 field. Same
	// pointer-shaped-only contract as `emitLoadFieldI64` above.
	function emitStoreFieldI64(addrId ValueId, offset ParsedInt, valueId ValueId, dstBlock IrBlock)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: offset, valueId: valueId, width: StoreWidth.qword, isFloat: false)))
	end 'emitStoreFieldI64'

	// Emit `result = leftId <op> rightId` for an i64 binary op and return resultId.
	function emitBinaryI64(opcode StdArithBinaryOpcode, leftId ValueId, rightId ValueId, dstBlock IrBlock) returns ValueId
		let id = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(opcode, resultId: id, leftId: leftId, rightId: rightId))))
		self.setValueType(id, t: MaxonType.integer)
		return id
	end 'emitBinaryI64'

	// Alias the parser-supplied error-bound name to the SSA ValueId that
	// already holds the computed error code. Used by inline-expanded throwing
	// builtins (`__ManagedMemory.createCursor`,
	// `__ManagedMemoryCursor.advance / retreat / seek / peek`) to surface
	// their failure code through the multi-value-return ABI without going
	// through a runtime helper. No op is emitted — `aliasName` simply rewrites
	// `nameToId` so subsequent `resolveName(errorBoundName)` returns
	// `codeValueId`. The success path's `codeValueId` is a 0-valued cmp/select
	// result; the failure path's `codeValueId` carries the error code.
	//
	// An empty `errorBoundName` is the sentinel for "this is not a try-call
	// site" — do nothing, the caller has no observer for the flag. The multi-
	// value-return ABI carries the flag in the secondary register (RDX/X1),
	// so an unobserved failure simply has no effect (the caller never queries
	// the flag).
	function emitFlagBind(errorBoundName ByteArray, codeValueId ValueId)
		if errorBoundName.isEmpty() 'noObserver'
			return
		end 'noObserver'
		self.aliasName(errorBoundName, toId: codeValueId)
	end 'emitFlagBind'

	// Emit `(1 - isValid) * errorCode`. When `isValid==1` (success) this is 0
	// (= no error); when `isValid==0` (failure) it's `errorCode`. Used to
	// produce the secondary-register error code without branching on the
	// failure flag.
	function emitErrorCodeForFailure(isValid ValueId, errorCode ParsedInt, dstBlock IrBlock) returns ValueId
		let one = self.emitConstI64(1, dstBlock: dstBlock)
		let inverted = self.emitBinaryI64(StdArithBinaryOpcode.subI64, leftId: one, rightId: isValid, dstBlock: dstBlock)
		let codeConst = self.emitConstI64(errorCode, dstBlock: dstBlock)
		return self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: inverted, rightId: codeConst, dstBlock: dstBlock)
	end 'emitErrorCodeForFailure'

	// Emit a branchless select: `cond ? trueVal : falseVal`, expanded as
	// `falseVal + cond * (trueVal - falseVal)`. Relies on `cond` being 0 or 1
	// (which the cmp ops guarantee).
	function emitArithmeticSelect(cond ValueId, trueVal ValueId, falseVal ValueId, dstBlock IrBlock) returns ValueId
		let delta = self.emitBinaryI64(StdArithBinaryOpcode.subI64, leftId: trueVal, rightId: falseVal, dstBlock: dstBlock)
		let scaled = self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: cond, rightId: delta, dstBlock: dstBlock)
		return self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: falseVal, rightId: scaled, dstBlock: dstBlock)
	end 'emitArithmeticSelect'

	// Emit `(target >= 0) AND (target < length)` as a 0/1 i64 — the canonical
	// "is this index in range" check for cursor seek/peek. The two cmps each
	// return 0 or 1, so a multiply produces the AND.
	function emitInBoundsZeroToLength(target ValueId, length ValueId, dstBlock IrBlock) returns ValueId
		let zero = self.emitConstI64(0, dstBlock: dstBlock)
		let isLowerOk = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Ge, leftId: target, rightId: zero, dstBlock: dstBlock)
		let isUpperOk = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Lt, leftId: target, rightId: length, dstBlock: dstBlock)
		return self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: isLowerOk, rightId: isUpperOk, dstBlock: dstBlock)
	end 'emitInBoundsZeroToLength'

	// Bind `result` to a fresh `const i64 0` — the void-return placeholder for
	// cursor methods whose Maxon return type is void.
	function emitCursorVoidResult(result ByteArray, dstBlock IrBlock)
		let resId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resId, value: 0))))
		self.setValueType(resId, t: MaxonType.integer)
	end 'emitCursorVoidResult'

	// Phase 11.4: createCursor allocates 40 bytes for the cursor struct,
	// copies buffer/length/element_size from the source __ManagedMemory,
	// initializes position=0, stores source_ptr, and signals an error
	// (`emptySlot`, code 1) when the source's length is zero so the
	// surrounding `try source.createCursor() otherwise throw` rejects empty
	// sources. The cursor pointer is bound as the call's result.
	// After `__managed_mem_get` returns, sign-extend the SSA result when
	// the element type is a signed narrow integer (i8 / i16 / i32). The
	// runtime helper's narrow load routes through `loadByte` /
	// `loadHalfword` / `loadWord` which all zero-extend; for signed slots
	// we recover the sign bit via `emitNarrowSignExtend`. The user-name
	// binding is rewritten to point at the sign-extended SSA value so
	// downstream consumers see -1 (not 255) for an i8 read of byte 0xFF.
	function maybeSignExtendNarrowGetResult(result ByteArray, receiverId ValueId, dstBlock IrBlock)
		// Recover the element MaxonType from the receiver's
		// genericInstance(`__ManagedMemory`, [Element]) and delegate to
		// the element-type variant — same XOR-SUB widening, different
		// element-type source.
		let receiverType = self.getValueType(receiverId)
		let elementType = signExtendElementType(self.project, receiverType: receiverType)
		self.maybeSignExtendNarrowReturn(result, elementType: elementType, dstBlock: dstBlock)
	end 'maybeSignExtendNarrowGetResult'

	// Constant-array-to-rdata fast path. The `ConstantArrayLiteralRdata`
	// pass registered `info` against this op's `OpIndex`; the bytes already
	// live in `.rdata` under `info.rdataLabel`. Emit:
	//
	//   newStruct = __mm_alloc(40, destructor = __destruct___ManagedMemory, tag = 0)
	//   newStruct[0]  = globalAddr(info.rdataLabel)   // buffer
	//   newStruct[8]  = info.count                    // length
	//   newStruct[16] = -2                            // capacity (read-only sentinel)
	//   newStruct[24] = info.elementSize              // element_size
	//   newStruct[32] = -2                            // parent (rdata sentinel for destructor)
	//
	// `capacity = -2` makes `__managed_mem_cow_check` allocate a fresh
	// writable buffer the first time the array is mutated (e.g. via
	// `arr.set(i, …)` from user code, which the pass doesn't remove —
	// only the literal's own statically-eliminated set chain is stripped).
	// `parent = -2` keeps `__destruct___ManagedMemory` from decref'ing the
	// rdata pointer when the wrapping struct falls out of scope.
	function lowerManagedMemCreateFromRdata(result ByteArray, info ConstantArrayRdataInfo, dstBlock IrBlock)
		// destructor function pointer.
		let dtorRefId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.funcRef(dtorRefId, funcName: "stdlib.__destruct___ManagedMemory")))
		self.setValueType(dtorRefId, t: MaxonType.integer)
		// Refcount-tracked allocation: 40-byte payload + 24-byte header,
		// destructor stored at ptr-24.
		let sizeId = self.emitConstI64(40, dstBlock: dstBlock)
		self.setValueType(sizeId, t: MaxonType.integer)
		let tagId = self.emitConstI64(0, dstBlock: dstBlock)
		self.setValueType(tagId, t: MaxonType.integer)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(sizeId)
		allocArgs.push(dtorRefId)
		allocArgs.push(tagId)
		let mmId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "stdlib.__mm_alloc", argIds: allocArgs)))
		self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
		// Buffer points at the rdata label.
		let bufferPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(bufferPtrId, name: info.rdataLabel)))
		self.setValueType(bufferPtrId, t: MaxonType.integer)
		self.emitStoreFieldI64(mmId, offset: 0, valueId: bufferPtrId, dstBlock: dstBlock)
		// Stamp length / capacity / element_size / parent.
		self.storeI64Const(mmId, offset: 8, value: info.count, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 16, value: -2, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 24, value: info.elementSize, dstBlock: dstBlock)
		self.storeI64Const(mmId, offset: 32, value: -2, dstBlock: dstBlock)
	end 'lowerManagedMemCreateFromRdata'

	function lowerCreateCursor(result ByteArray, sourceId ValueId, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		// Allocate 40 bytes via mrt_alloc. The result is an opaque i64 ptr.
		let sizeId = self.emitConstI64(40, dstBlock: dstBlock)
		var allocArgs = ValueIdArray.create()
		allocArgs.push(sizeId)
		let cursorId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(cursorId, callee: "mrt_alloc", argIds: allocArgs)))
		self.setValueType(cursorId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemoryCursor")))

		// Read source fields. __ManagedMemory layout: buffer @0, length @8,
		// capacity @16, element_size @24, parent_ptr @32.
		let buffer = self.emitLoadFieldI64(sourceId, offset: 0, dstBlock: dstBlock)
		let length = self.emitLoadFieldI64(sourceId, offset: 8, dstBlock: dstBlock)
		let elementSize = self.emitLoadFieldI64(sourceId, offset: 24, dstBlock: dstBlock)

		// Stamp the cursor fields. Position starts at 0; source_ptr is the
		// receiver pointer (kept here so a future drop pass can decref the
		// source when the cursor goes out of scope).
		let zero = self.emitConstI64(0, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 0, valueId: buffer, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 8, valueId: zero, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 16, valueId: length, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 24, valueId: elementSize, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 32, valueId: sourceId, dstBlock: dstBlock)

		// length == 0 → set error flag to `emptySlot` (1). We compute the
		// flag value as `(length == 0) * 1` (cmp returns 0 or 1) and alias
		// the parser-supplied `errorBoundName` to that SSA value via
		// `emitFlagBind`; the caller's `try ... otherwise` machinery resolves
		// the bound name and tests for non-zero. Aliasing to a 0-valued cmp on
		// the success path is correct: the caller's branch sees zero.
		let isEmpty = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Eq, leftId: length, rightId: zero, dstBlock: dstBlock)
		self.emitFlagBind(errorBoundName, codeValueId: isEmpty)
	end 'lowerCreateCursor'

	// Phase 11.4: cursor.current() — load element at current position.
	// Bounds against length come from the cursor's own length field; this is
	// the infallible read variant (the stdlib wrapper has already validated
	// via createCursor's empty-check, and advance() updates position only on
	// success). On a misuse (position == length), the loaded address may
	// dereference past the buffer; today's stdlib never reaches that path,
	// but a future revision can add an explicit bounds check + panic.
	//
	// Implementation: delegate to the stdlib runtime helper
	// `__managed_mem_cursor_current`, which dispatches on the cursor's
	// runtime `element_size` field with proper control flow (one branch
	// per supported width) and calls the matching narrow `loadByte` /
	// `loadHalfword` / `loadWord` / `loadIndirect` primitive. The
	// runtime-helper approach is the right design here because at
	// lowering time the cursor's element type is `typeParameter(Element)`
	// — the concrete element width isn't known until the user-side
	// instantiation context, which isn't visible at the stdlib-lowering
	// boundary. Doing the dispatch in the runtime helper keeps the
	// width selection at the one place that has the runtime element_size
	// value (the cursor's own field) and avoids reading bytes past the
	// element bound — critical for narrow types like `Byte`/`u8` where
	// a qword load would leak 7 bytes of adjacent buffer state and
	// historically caused the lexer's charClassTable to misfire on
	// multibyte source.
	//
	// The helper is non-throwing (cursor invariants guarantee bounds);
	// we emit a plain `call` rather than the throwing-call shape.
	// Source-level sign-extension for narrow signed element types
	// (e.g. i8-backed enums) is handled by `maybeSignExtendCallResult`
	// in `emitCallWithArgs` — but since we bypass that wrapper here
	// (the helper's declared return type is `int`/i64, not a generic
	// type parameter), we apply the sign-extension shim explicitly when
	// the call site's element type resolves to a signed narrow StdType.
	function lowerCursorCurrent(result ByteArray, cursorId ValueId, elementType MaxonType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		var argIds = ValueIdArray.create()
		argIds.push(cursorId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "stdlib.__managed_mem_cursor_current", argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.integer)
		// Sign-extend the narrow signed-element return value so the
		// i64 SSA result carries the right value. Mirror of the
		// `maybeSignExtendNarrowGetResult` shim used by Array.get's
		// __managed_mem_get call; same XOR-SUB trick because shrI64
		// lowers as unsigned on every backend.
		self.maybeSignExtendNarrowReturn(result, elementType: elementType, dstBlock: dstBlock)
	end 'lowerCursorCurrent'

	// Sign-extend a narrow signed value returned from a non-generic
	// runtime helper. Shared with the cursor-current path and any
	// future helper that returns a width-narrowed signed value through
	// the i64 ABI. No-op when `elementType` resolves to an unsigned or
	// qword `StdType` (the common case). Same shape as
	// `maybeSignExtendNarrowGetResult` but takes the element type
	// directly because the cursor receiver doesn't expose it via
	// `genericInstance` at this call site.
	function maybeSignExtendNarrowReturn(result ByteArray, elementType MaxonType, dstBlock IrBlock)
		if not signExtendApplies(self.project, elementType: elementType) 'noExtend'
			return
		end 'noExtend'
		let stdType = resolveMaxonTypeToStd(self.project, ref: elementType)
		let widthBytes = storeWidthBytes(storeWidthOfStdType(stdType))
		if widthBytes >= 8 'noWiden'
			return
		end 'noWiden'
		let rawId = self.resolveName(result)
		let signExtId = self.emitNarrowSignExtend(rawId, widthBytes: widthBytes, dstBlock: dstBlock)
		self.setValueType(signExtId, t: elementType)
		self.aliasName(result, toId: signExtId)
	end 'maybeSignExtendNarrowReturn'

	// Phase 11.4: cursor.index() — return the current position as i64.
	function lowerCursorIndex(result ByteArray, cursorId ValueId, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: cursorId, offset: 8, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
	end 'lowerCursorIndex'

	// Phase 11.4 / Phase 6: shared tail for advance/retreat/seek. Conditionally
	// writes `newPos` into the cursor's position field (only when valid) and
	// aliases the parser-supplied `errorBoundName` to a `(1 - isValid) *
	// errorCode` SSA value (zero on success, `errorCode` on failure). The
	// caller's `try ... otherwise throw` resolves the bound name and tests
	// for non-zero. Mirrors the C# `EmitCursorPositionUpdate` shape: a
	// `select` between newPos and oldPosition gates the field store; a
	// separate `(1 - isValid) * errorCode` value drives the flag alias.
	function emitCursorPositionUpdate(cursorId ValueId, newPos ValueId, isValid ValueId, oldPosition ValueId, errorCode ParsedInt, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let selected = self.emitArithmeticSelect(isValid, trueVal: newPos, falseVal: oldPosition, dstBlock: dstBlock)
		self.emitStoreFieldI64(cursorId, offset: 8, valueId: selected, dstBlock: dstBlock)
		let codeValue = self.emitErrorCodeForFailure(isValid, errorCode: errorCode, dstBlock: dstBlock)
		self.emitFlagBind(errorBoundName, codeValueId: codeValue)
	end 'emitCursorPositionUpdate'

	// Phase 11.4: cursor.advance() — position += 1 if newPos < length, else
	// set error code 1 (`emptySlot` / "exhausted"). Result is a 0 i64 because
	// the call's MaxonReturnType is void but the lowering still defines a
	// name slot.
	function lowerCursorAdvance(result ByteArray, cursorId ValueId, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let position = self.emitLoadFieldI64(cursorId, offset: 8, dstBlock: dstBlock)
		let length = self.emitLoadFieldI64(cursorId, offset: 16, dstBlock: dstBlock)
		let one = self.emitConstI64(1, dstBlock: dstBlock)
		let newPos = self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: position, rightId: one, dstBlock: dstBlock)
		let isValid = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Lt, leftId: newPos, rightId: length, dstBlock: dstBlock)
		self.emitCursorPositionUpdate(cursorId, newPos: newPos, isValid: isValid, oldPosition: position, errorCode: 1, dstBlock: dstBlock, errorBoundName: errorBoundName)
		self.emitCursorVoidResult(result, dstBlock: dstBlock)
	end 'lowerCursorAdvance'

	// Phase 11.4: cursor.retreat() — position -= 1 if newPos >= 0, else
	// set error code 2 (`sliceOutOfBounds` / "atStart").
	function lowerCursorRetreat(result ByteArray, cursorId ValueId, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let position = self.emitLoadFieldI64(cursorId, offset: 8, dstBlock: dstBlock)
		let one = self.emitConstI64(1, dstBlock: dstBlock)
		let newPos = self.emitBinaryI64(StdArithBinaryOpcode.subI64, leftId: position, rightId: one, dstBlock: dstBlock)
		let zero = self.emitConstI64(0, dstBlock: dstBlock)
		let isValid = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Ge, leftId: newPos, rightId: zero, dstBlock: dstBlock)
		self.emitCursorPositionUpdate(cursorId, newPos: newPos, isValid: isValid, oldPosition: position, errorCode: 2, dstBlock: dstBlock, errorBoundName: errorBoundName)
		self.emitCursorVoidResult(result, dstBlock: dstBlock)
	end 'lowerCursorRetreat'

	// Phase 11.4: cursor.seek(index) — jump to absolute position. Sets error
	// code 1 if `index < 0` or `index >= length`.
	function lowerCursorSeek(result ByteArray, cursorId ValueId, indexId ValueId, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let position = self.emitLoadFieldI64(cursorId, offset: 8, dstBlock: dstBlock)
		let length = self.emitLoadFieldI64(cursorId, offset: 16, dstBlock: dstBlock)
		let isValid = self.emitInBoundsZeroToLength(indexId, length: length, dstBlock: dstBlock)
		self.emitCursorPositionUpdate(cursorId, newPos: indexId, isValid: isValid, oldPosition: position, errorCode: 1, dstBlock: dstBlock, errorBoundName: errorBoundName)
		self.emitCursorVoidResult(result, dstBlock: dstBlock)
	end 'lowerCursorSeek'

	// Phase 11.4: cursor.peek(ahead) — load element at `position + ahead`
	// without moving the cursor. Sets error code 1 when the target index is
	// out of bounds; the load itself reads from a clamped address (the
	// current position) on the failure path, so the value is benign noise
	// that the caller's `try otherwise` branch discards.
	function lowerCursorPeek(result ByteArray, cursorId ValueId, aheadId ValueId, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let position = self.emitLoadFieldI64(cursorId, offset: 8, dstBlock: dstBlock)
		let length = self.emitLoadFieldI64(cursorId, offset: 16, dstBlock: dstBlock)
		let buffer = self.emitLoadFieldI64(cursorId, offset: 0, dstBlock: dstBlock)
		let elementSize = self.emitLoadFieldI64(cursorId, offset: 24, dstBlock: dstBlock)
		let target = self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: position, rightId: aheadId, dstBlock: dstBlock)
		let isValid = self.emitInBoundsZeroToLength(target, length: length, dstBlock: dstBlock)
		// Clamp on the error path so the load below dereferences a known-safe
		// address (the current position): the value is benign noise that the
		// caller's `try otherwise` discards.
		let safeTarget = self.emitArithmeticSelect(isValid, trueVal: target, falseVal: position, dstBlock: dstBlock)
		let byteOffset = self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: safeTarget, rightId: elementSize, dstBlock: dstBlock)
		let address = self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: buffer, rightId: byteOffset, dstBlock: dstBlock)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: address, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		let codeValue = self.emitErrorCodeForFailure(isValid, errorCode: 1, dstBlock: dstBlock)
		self.emitFlagBind(errorBoundName, codeValueId: codeValue)
	end 'lowerCursorPeek'

	// Inline a `loadIndirect(selfPtr, offset)` for one of the simple
	// `__ManagedMemory.*` getters (length / capacity / elementSize /
	// toCString). Always emits an i64 load — every field of the 5-field
	// struct is 8 bytes and integer-typed.
	function lowerMmFieldLoad(result ByteArray, selfId ValueId, offset ParsedInt, dstBlock IrBlock) returns bool
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: selfId, offset: offset, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerMmFieldLoad'

	// Emit `result = call helperName(...argIds)`. Used for every throwing
	// `__ManagedMemory.*` method whose body lives in runtime.std as
	// `__managed_mem_*`. The helper is responsible for bounds checking
	// and writes the error flag in RDX/X1 via the multi-value-return ABI
	// (Phase 6); the caller's surrounding `try ... otherwise` machinery
	// reads the flag by name. When `errorBoundName` is empty the call site is
	// a non-try invocation (e.g. an inline `__ManagedMemory.length` load
	// chained through `__ManagedMemory.set` for stdlib internal use) — in
	// that case emit a regular `call` and let any flag write be discarded by
	// RDX clobber; the helper's signal is unobserved by the caller.
	function lowerManagedMemRuntimeCall(result ByteArray, helperName String, argIds ValueIdArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create()) returns bool
		let resultId = self.defineName(result)
		if not errorBoundName.isEmpty() 'tryCall'
			let flagId = self.defineName(errorBoundName)
			self.setValueType(flagId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.tryCall(resultId, callee: helperName, argIds: argIds, errorFlagId: flagId)))
		end 'tryCall' else 'plainCall'
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: helperName, argIds: argIds)))
		end 'plainCall'
		self.setValueType(resultId, t: MaxonType.integer)
		return true
	end 'lowerManagedMemRuntimeCall'

	// After lowerManagedMemRuntimeCall stamps the call result as integer,
	// re-stamp it with the method's actual declared return type when that
	// disagrees. Critical for callers that chain method calls on the result
	// (e.g. `__ManagedMemory.create(...).set(...)`) without binding through
	// a typed `var` first — without this, lowerMethodCall sees integer and
	// can't pick the `__ManagedMemory` method-table arm.
	function refineMmCallResultType(result ByteArray, methodName String)
		// Chained-call context (`__ManagedMemory.create(...).set(...)`): the
		// receiver's element type isn't recoverable here, so pass an unresolved
		// receiver — `buildSubstitutionForInstance` then yields an empty
		// substitution and the declared return type is stamped verbatim, exactly
		// as before this path learned to substitute.
		self.refineBuiltinCallResultType(result, receiverName: "__ManagedMemory", methodName: methodName, receiverType: MaxonType.unresolved)
	end 'refineMmCallResultType'

	// Generalized form of refineMmCallResultType used by every `__ManagedX.method`
	// dispatch (currently __ManagedMemory, __ManagedFile, __ManagedDirectory).
	// See refineMmCallResultType's original header comment for the rationale:
	// the generic helper-call stamp uses integer, but methods that return a
	// non-integer (managed handles, managed memory) need re-stamping so
	// downstream method dispatch picks the correct method-table arm.
	function refineBuiltinCallResultType(result ByteArray, receiverName String, methodName String, receiverType MaxonType)
		let qualifiedName = "{receiverName}.{methodName}"
		let returnType = try self.project.funcReturnTypes.get(qualifiedName) otherwise return
		let declaredType = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		// The declared return for value-carrying builtins (e.g.
		// `__ManagedListNode.value` / `__ManagedMemory.get`) is the bare
		// `Element` type-parameter. Substitute it against the receiver's
		// generic instantiation so a `node.value()` whose receiver is
		// `__ManagedListNode with Item` stamps `Item`, not a raw `Element`
		// (which would trip E2004 at a downstream `.field` access). Non-generic
		// receivers yield an empty substitution and `resultType` == `declaredType`.
		let subst = buildSubstitutionForInstance(self.project, t: receiverType)
		let resultType = substituteType(self.project, t: declaredType, subst: subst)
		// Skip the re-stamp when the resolved type is integer — the generic
		// helper-call stamp already covered it.
		let isInteger = match resultType 'isInt'
			integer gives true
			boolean gives false
			float to opaquePointer gives false
		end 'isInt'
		if isInteger 'skipReStamp'
			return
		end 'skipReStamp'
		let resultId = self.resolveName(result)
		self.setValueType(resultId, t: resultType)
	end 'refineBuiltinCallResultType'

	// C1.d: dispatch a method call on a fat-pointer interface receiver.
	// The receiver's value half is `receiverId` and its witness pointer
	// was paired in `interfaceWitnessValueIds` by the corresponding
	// varLoad. Steps:
	//   1. Recover the witness ValueId for this receiver.
	//   2. Look up the method's 0-based index in the interface's method
	//      list (declaration order is the witness-table layout order).
	//   3. Emit `witnessMethod(witnessAddr, methodIndex)` to materialize
	//      the function pointer at `+24 + 8*idx`.
	//   4. Emit `indirectCall(fnPtr, [receiverValue, args...])`.
	// The result's MaxonType is stamped from the interface method's
	// declared return type so downstream consumers (callee chains,
	// further field/method access) can reason about it.
	//
	// Inline-vs-boxed: this lowering assumes the witness's flags bit 0
	// (`isFatBoxed`) is unset — every primitive and pointer-shaped value
	// fits in 8 bytes, which covers the practical cases. The unbox path
	// (read flags, conditionally `unboxValue`) is a follow-up; today's
	// specs reach interface dispatch only with inline-fitting payloads.
	function lowerInterfaceMethodCall(result ByteArray, receiverId ValueId, receiverType MaxonType, methodName ByteArray, args ByteArrayArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let interfaceName = match receiverType 'iface'
			interface(id) gives self.project.interfaceRegistry.getName(id)
			default panic("lowerInterfaceMethodCall: receiverType is not interface despite the dispatch guard")
		end 'iface'
		let witnessAddrId = try self.interfaceWitnessValueIds.get(receiverId) otherwise panic("lowerInterfaceMethodCall: no witness ValueId paired with receiverId={receiverId} (interface={interfaceName}, method={String.from(methodName)}); the receiver's varLoad did not pair its witness companion")
		let methodNameStr = String.from(methodName)
		let argIds = self.buildDispatchArgIds(receiverId, args: args)
		let resultId = self.defineName(result)
		self.emitWitnessDispatch(resultId, witnessAddrId: witnessAddrId, interfaceName: interfaceName, methodName: methodNameStr, argIds: argIds, dstBlock: dstBlock, errorBoundName: errorBoundName)
	end 'lowerInterfaceMethodCall'

	// Phase 11.4: dispatch a method call on a constrained type-parameter
	// receiver (e.g. `key.hash()` where `key: Key` and `Key is Hashable`).
	// Walks the enclosing function's `implicitWitnessConstraints`, finds
	// the `(paramName, interface)` pair whose paramName matches the
	// receiver's type-parameter and whose interface declares `methodName`,
	// then emits a witness-based dispatch identical to the fat-pointer
	// path. Receiver is a plain value (8 bytes or fewer) so it goes
	// straight in as arg 0 — no fat-pointer split.
	//
	// Returns false if no constraint covers this method. The caller falls
	// back to `lowerInterfaceMethodCallStub` which keeps the runtime panic
	// for genuinely unconstrained type parameters.
	function tryLowerConstrainedTypeParamDispatch(result ByteArray, receiverId ValueId, receiverType MaxonType, methodName ByteArray, args ByteArrayArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create()) returns bool
		let pid = match receiverType 'extractPid'
			typeParameter(id) gives id
			default panic("tryLowerConstrainedTypeParamDispatch: receiver type isn't typeParameter despite the dispatch guard")
		end 'extractPid'
		let receiverParamName = self.project.typeParameters.getName(pid)
		let methodNameStr = String.from(methodName)
		if let matched = try self.findConstraintForMethod(receiverParamName, methodName: methodNameStr) 'hit'
			let witnessAddrId = try self.implicitWitnessValueIds.get(matched.constraintIndex) otherwise panic("tryLowerConstrainedTypeParamDispatch: implicitWitnessValueIds desync at idx {matched.constraintIndex}")
			let argIds = self.buildDispatchArgIds(receiverId, args: args)
			let resultId = self.defineName(result)
			self.emitWitnessDispatch(resultId, witnessAddrId: witnessAddrId, interfaceName: matched.interfaceName, methodName: methodNameStr, argIds: argIds, dstBlock: dstBlock, errorBoundName: errorBoundName)
			return true
		end 'hit' else 'noMatch'
			return false
		end 'noMatch'
	end 'tryLowerConstrainedTypeParamDispatch'

	// Locate the `(constraintIndex, interfaceName)` pair in the enclosing
	// function's `implicitWitnessConstraints` whose typeParameter matches
	// `paramName` and whose interface declares `methodName`. Throws when
	// nothing matches; the equality and method-dispatch call sites both
	// use `if let try` to fall back to non-witness lowering.
	function findConstraintForMethod(paramName String, methodName String) returns MatchedConstraint throws ConstraintLookupError
		let constraints = self.currentMaxonFunc.implicitWitnessConstraints
		for i in 0 upto constraints.count() 'scan'
			let cc = try constraints.get(i) otherwise panic("findConstraintForMethod: constraints.get OOB at {i}")
			if cc.paramName != paramName 'paramMismatch'
				continue
			end 'paramMismatch'
			let iface = try self.project.interfaces.get(cc.requiredTraitName) otherwise 'noIface'
				continue
			end 'noIface'
			for j in 0 upto iface.methods.count() 'eachMethod'
				let m = try iface.methods.get(j) otherwise panic("findConstraintForMethod: methods.get OOB at {j}")
				if m.name == methodName 'hit'
					return MatchedConstraint.create(i as ParsedInt, interfaceName: cc.requiredTraitName)
				end 'hit'
			end 'eachMethod'
		end 'scan'
		throw ConstraintLookupError.notFound
	end 'findConstraintForMethod'

	// Emit the canonical witness-table dispatch sequence shared by every
	// path that turns an interface method call into IR:
	//   1. `witnessMethod(witnessAddr, idx)` — materializes fn pointer.
	//   2. `indirectCall(fnPtr, argIds)` — invokes through it.
	//   3. Stamp `resultId`'s MaxonType from the interface method's
	//      declared return so chained access can resolve. Void returns
	//      leave the integer default (the result slot is unused).
	function emitWitnessDispatch(resultId ValueId, witnessAddrId ValueId, interfaceName String, methodName String, argIds ValueIdArray, dstBlock IrBlock, errorBoundName ByteArray = ByteArray.create())
		let methodIdx = methodIndexInInterface(self.project, interfaceName: interfaceName, methodName: methodName)
		let returnType = interfaceMethodReturnType(self.project, interfaceName: interfaceName, methodName: methodName)
		let isVoid = match returnType 'voidCheck'
			void gives true
			value gives false
		end 'voidCheck'
		// Fused: witness-table load and call become a single op so the
		// loaded function pointer never gets its own virtual register.
		// Backends lower this directly to a memory-indirect call. Drops
		// pressure across the call site enough that hot witness loops
		// (e.g. stdlib Map.findSlot's `existing == key`) compile without
		// chain-spilling. See StdCallOp.witnessCall. `isVoid` is plumbed
		// so backends with strictly-typed indirect calls (wasm) can emit
		// a no-result signature; native backends ignore it.
		//
		// A throwing interface method writes the error flag (RDX/X1) through
		// the witness thunk, so it must lower to `witnessTryCall` (the dual-
		// define error-ABI variant) and bind `errorBoundName` to the captured
		// flag. Using the plain single-result `witnessCall` + bind-zero here
		// would silently drop the throw — the original bug, where
		// `for (iter, v) in (10 upto 13).withIterator()` infinite-looped
		// because the witness-dispatched `source.advance()` throw never
		// reached the caller's `try`.
		if interfaceMethodThrows(self.project, interfaceName: interfaceName, methodName: methodName) 'throwingMethod'
			// The thunk always writes the error flag, so we always capture it.
			// Bind it to the caller's observer name when there is a `try`
			// site; otherwise capture into a throwaway SSA id (an empty
			// errorBoundName means no observer — same sentinel emitFlagBind
			// uses). A throwing method reached without `try` is rejected
			// upstream (E3057), so the no-observer arm is defensive.
			let flagId = allocValueId(self.funcIdRef)
			self.setValueType(flagId, t: MaxonType.integer)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.witnessTryCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIdx, isVoid: isVoid, argIds: argIds, errorFlagId: flagId)))
			self.emitFlagBind(errorBoundName, codeValueId: flagId)
		end 'throwingMethod' else 'nonThrowingMethod'
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.witnessCall(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIdx, isVoid: isVoid, argIds: argIds)))
			self.bindErrorFlagToZero(errorBoundName, dstBlock: dstBlock)
		end 'nonThrowingMethod'
		match returnType 'stamp'
			void then break 'stamp'
			value(inner) then self.setValueType(resultId, t: inner)
		end 'stamp'
	end 'emitWitnessDispatch'

	// Build the `[receiver, args...]` ValueId list every witness-dispatch
	// call site assembles before emitting indirectCall.
	function buildDispatchArgIds(receiverId ValueId, args ByteArrayArray) returns ValueIdArray
		var argIds = ValueIdArray.create()
		argIds.push(receiverId)
		for argName in args 'eachArg'
			argIds.push(self.resolveName(argName))
		end 'eachArg'
		return argIds
	end 'buildDispatchArgIds'

	// Stub for method calls whose receiver type didn't reduce to a
	// concrete struct AND isn't a true interface (those go through
	// `lowerInterfaceMethodCall` above, with real witness-table dispatch).
	// What's left: free type parameters and types the resolver couldn't
	// pin down. Lower to `mrt_panic` so the build completes and any
	// actual runtime invocation surfaces a clear error.
	function lowerInterfaceMethodCallStub(result ByteArray, methodName ByteArray, dstBlock IrBlock)
		let methodNameStr = String.from(methodName)
		let panicMsg = "interface dispatch for method '{methodNameStr}' is unimplemented (Phase 11.4)"
		let panicLabel = self.pipeline.registerPanicMessage(panicMsg)
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: panicLabel)))
		var argIds = ValueIdArray.create()
		argIds.push(addrId)
		let panicResultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(panicResultId, callee: "mrt_panic", argIds: argIds)))
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: resultId, value: 0))))
		self.setValueType(resultId, t: MaxonType.integer)
	end 'lowerInterfaceMethodCallStub'

	// Resolve a parser-emitted bare callee to its qualified name. Thin
	// wrapper over the shared `qualifyCalleeForContext` so the parser, DFE,
	// and lowering all share the same probe order. The reader path comes
	// from `currentFilePath` so cross-file fallback can filter candidates
	// by visibility against the function we're lowering.

	// Build the Std-level argument id list for a call by:
	//   - Looking up the callee's signature (paramNames + paramTypes +
	//     paramDefaults).
	//   - Slotting each provided arg into the position named by its label
	//     (or its source order, for the leading positional arg).
	//   - Type-checking the arg's MaxonType (carried on the call op as
	//     `argTypes[i]`) against the signature's declared paramType. Same
	//     CastCategory (or compiler-recognized implicit conversion) is
	//     accepted: int↔float emits a compile-inserted convert in `dstBlock`.
	//     Mismatches emit E3005.
	//   - Filling unfilled slots with integer-literal defaults from the
	//     signature (emitted as fresh constI64 ops, then run through the
	//     same conversion machinery so a default value of 0 lands as f64
	//     0.0 when the param is float, etc.).
	// When no signature is registered (interface calls, missing functions),
	// emits args in source order verbatim with no type-check — same fallback
	// as the previous parser-side `parseCallArgsLegacy` path.
	// `leadingReceiverId` + `hasLeadingReceiver` let method-call lowering
	// fold the receiver into slot 0 of the result without a second pass:
	// when the flag is set, the returned ValueIdArray has the receiver at
	// index 0 and the user args at indices 1..userParamCount. The slot/
	// default-fill scratch buffers stay user-arg-indexed (the receiver is
	// not a "user param") so paramStartIndex math is unchanged.
	function slotArgsForCall(signature FuncSignature, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, paramStartIndex ParsedInt, opIdx OpIndex, dstBlock IrBlock, leadingReceiverId ValueId = 0, hasLeadingReceiver bool = false) returns ValueIdArray
		let userParamCount = signature.paramNames.count() - paramStartIndex
		if userParamCount < 0 'badArity'
			return self.resolveArgNamesWithReceiverWitness(signature, args: args, leadingReceiverId: leadingReceiverId, hasLeadingReceiver: hasLeadingReceiver, dstBlock: dstBlock)
		end 'badArity'
		// FP1: zero-param callee — resolveArgNames handles empty/extras the same.
		if userParamCount == 0 'noUserParams'
			return self.resolveArgNamesWithReceiverWitness(signature, args: args, leadingReceiverId: leadingReceiverId, hasLeadingReceiver: hasLeadingReceiver, dstBlock: dstBlock)
		end 'noUserParams'
		// Pre-substituted paramTypes were stashed by `resolveAllCalls` during
		// TypeResolution. By contract, every call op that reaches
		// `slotArgsForCall` also has a `resolvedCallees` entry (the lookup in
		// `lowerCall` / `lowerMethodCall` upstream succeeded), and the
		// resolver pass inserts both keys together — so a miss here means a
		// pass-ordering or visit-set bug.
		let resolvedParamTypes = try self.project.callParamTypes.get(opIdx) otherwise panic("slotArgsForCall: opIdx={opIdx} missing from project.callParamTypes despite having a resolvedCallees entry — resolveAllCalls invariant violated")
		// Stage K.X.1: General path: reuse scratch buffers. Array.resize()
		// only sets the length field; the underlying backing memory still
		// carries whatever the previous (longer-arity) call left there.
		// Explicitly write slot=0 / filled=false for every user slot so the
		// default-fill loop below sees a clean state. Without this, slot 1
		// of a 1-arg call can inherit `filled=true` from a prior 2-arg call
		// and the default-fill loop skips it, leaving the resulting
		// ValueIdArray pointing at a never-allocated SSA id. Cache-masked:
		// with the stdlib cache active the user pipeline lowered far fewer
		// functions and the scratch buffer never grew past the user call's
		// own arity, so the bug stayed dormant.
		self.slotIdsScratch.clear()
		self.slotFilledScratch.clear()
		self.slotIdsScratch.resize(userParamCount)
		self.slotFilledScratch.resize(userParamCount)
		for initIdx in 0 upto userParamCount 'initScratch'
			try self.slotIdsScratch.set(initIdx, value: 0) otherwise panic("invariant: slotIdsScratch.set OOB right after resize")
			try self.slotFilledScratch.set(initIdx, value: false) otherwise panic("invariant: slotFilledScratch.set OOB right after resize")
		end 'initScratch'
		for i in 0 upto args.count() 'placeArgs'
			let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
			let label = try argLabels.get(i) otherwise ""
			let argType = try argTypes.get(i) otherwise MaxonType.integer
			let argRange = try argRanges.get(i) otherwise SourceRange.none()
			var slot = i
			if not label.isEmpty() 'hasLabel'
				if let resolvedSlot = try self.resolveLabelToSlot(signature, label: label, paramStartIndex: paramStartIndex) 'foundSlot'
					slot = resolvedSlot
				end 'foundSlot' else 'unknownLabel'
					reportSemanticError(self.project, code: ErrorCode.semanticUndefinedVariable, message: "unknown parameter name: '{label}'")
					continue
				end 'unknownLabel'
			end 'hasLabel'
			if slot >= userParamCount 'overflow'
				continue
			end 'overflow'
			let paramType = try resolvedParamTypes.get(slot + paramStartIndex) otherwise MaxonType.integer
			let paramName = try signature.paramNames.get(slot + paramStartIndex) otherwise ""
			let coercedId = self.coerceArgToParam(arg, argType: argType, paramType: paramType, paramName: paramName, range: argRange, dstBlock: dstBlock)
			// Hybrid-generics ABI bridge (write side). The callee's signature
			// (`signature.paramTypes`) keeps the raw `typeParameter(Element)`
			// for generic params; substitution only refines the type at the
			// resolved-param-types snapshot. Methods are NOT monomorphized
			// per Phase 11 — a single body handles every Element type by
			// treating the slot as an opaque 8-byte int-channel. So when
			// the caller hands us a float-class SSA at a typeParameter slot,
			// we bitcast f64→i64 so the call ABI passes via GPR, matching
			// the callee's int-channel param prologue.
			let rawParamType = try signature.paramTypes.get(slot + paramStartIndex) otherwise MaxonType.integer
			let bridgedId = self.bridgeFloatArgToTypeParam(coercedId, rawParamType: rawParamType, substitutedParamType: paramType, dstBlock: dstBlock)
			try self.slotIdsScratch.set(slot, value: bridgedId) otherwise panic("invariant: slotIds.set OOB")
			try self.slotFilledScratch.set(slot, value: true) otherwise panic("invariant: slotFilled.set OOB")
		end 'placeArgs'
		// Fill unfilled slots from signature defaults.
		for userIdx in 0 upto userParamCount 'fillDefaults'
			let isFilled = try self.slotFilledScratch.get(userIdx) otherwise panic("invariant: slotFilledScratch resized to userParamCount but get({userIdx}) failed")
			if isFilled 'already'
				continue
			end 'already'
			let paramIdx = userIdx + paramStartIndex
			let pd = try signature.paramDefaults.get(paramIdx) otherwise ParamDefault.none
			if not paramDefaultHasValue(pd) 'noDefault'
				continue
			end 'noDefault'
			let paramType = try resolvedParamTypes.get(paramIdx) otherwise MaxonType.integer
			let materializedId = self.materializeParamDefault(pd, paramType: paramType, dstBlock: dstBlock)
			try self.slotIdsScratch.set(userIdx, value: materializedId) otherwise panic("invariant: slotIds.set OOB")
		end 'fillDefaults'
		// Materialize result. Callers retain it on the StdOp, so it must not
		// alias the scratch buffer. When hasLeadingReceiver is set, the
		// receiver occupies slot 0 and user args follow at slots 1..N — this
		// folds the method-call receiver-prepend into the same allocation.
		// Stage E (closures): when a user param is function-typed, the
		// callee's ABI declares a (fn-pointer, env-pointer) pair at that
		// slot — so after pushing the fn-pointer arg we also push the
		// matching env-pointer recovered from `fnEnvVarNames` (or 0 if no
		// env was recorded; this keeps codegen structurally valid for
		// values that flow through paths the parser-side capture analysis
		// didn't tag, e.g. an interface-call site whose declared param
		// was function-typed).
		var result = ValueIdArray.create()
		var totalCount = userParamCount
		if hasLeadingReceiver 'reserveLead'
			totalCount = totalCount + 1
		end 'reserveLead'
		result.reserve(totalCount)
		if hasLeadingReceiver 'pushLead'
			result.push(leadingReceiverId)
			// C1.d: when the redirected callee's `__self` is interface-typed
			// (an extension on an interface invoked via a concrete receiver),
			// the ABI expects (value, witness) at slot 0. Materialize the
			// witness for the receiver here — the user-param loop only pairs
			// witnesses for slots `>= paramStartIndex`, so the leading
			// receiver would otherwise pass through bare and the callee
			// would read uninitialised state from its second param register.
			let leadingParamType = try signature.paramTypes.get(0) otherwise MaxonType.unresolved
			if interfaceTypeIsFat(leadingParamType) 'leadingFat'
				let leadingWitness = self.witnessForInterfaceArg(leadingReceiverId, paramType: leadingParamType, dstBlock: dstBlock)
				result.push(leadingWitness)
			end 'leadingFat'
		end 'pushLead'
		for i in 0 upto userParamCount 'copyOut'
			let v = try self.slotIdsScratch.get(i) otherwise panic("invariant: slotIdsScratch.get OOB at {i} (size {userParamCount})")
			result.push(v)
			let paramType = try signature.paramTypes.get(i + paramStartIndex) otherwise MaxonType.integer
			// slot<->abi decoupling: the callee's ABI (built by buildAbiParamMaps
			// / the monomorphizer) inserts an env companion for any param that
			// RESOLVES to a function type — including a `named(alias)` that chases
			// to one. The caller's arg expansion MUST use the same resolution, or
			// it pushes one fewer arg than the callee declares (a stale
			// `isFunctionMaxonType(named(alias))` returns false) and every
			// subsequent arg/register desyncs. Chase the alias before deciding.
			let chasedParamType = chaseTypealiasToFunctionType(self.project, t: paramType)
			if isFunctionMaxonType(chasedParamType) 'expandEnv'
				// Fallback path: when the parser-side capture analysis didn't
				// tag this value with an env binding, treat it as a free-function
				// reference (env=0). Materialize a real `const 0` op rather
				// than passing the literal ValueId `0` — a bare 0 alias-collides
				// with the local v0 in any function whose first SSA value
				// isn't defined locally, breaking regalloc downstream.
				let envId = try self.fnEnvVarNames.get(v) otherwise self.emitConstI64(0, dstBlock: dstBlock)
				result.push(envId)
			end 'expandEnv'
			// C1.d: an interface-typed param's ABI is (value, witness). The
			// value half was just pushed; pair it with the witness here so
			// the callee receives both at adjacent param indices. Witness
			// comes from `interfaceWitnessValueIds` when the arg is itself
			// interface-typed (forward of an existing fat pointer); when
			// the arg is concrete, materialize the witness via the
			// (concreteType, interfaceName) registry lookup. Use the resolved
			// type so an aliased interface param expands consistently too.
			if interfaceTypeIsFat(paramType) or interfaceTypeIsFat(chasedParamType) 'expandWitness'
				let witnessForArg = self.witnessForInterfaceArg(v, paramType: paramType, dstBlock: dstBlock)
				result.push(witnessForArg)
			end 'expandWitness'
		end 'copyOut'
		return result
	end 'slotArgsForCall'

	// Implicitly convert an argument value to match the formal parameter
	// type. Returns the ValueId to slot into the call. Diagnostics (E3005)
	// flow through `range` so the offending argument expression is
	// highlighted, not the call site as a whole.
	//
	// Type-check-first: when argType and paramType resolve to different
	// CastCategorys AND no implicit conversion bridges them, we report
	// E3005 *before* calling resolveName. This matters because a stringConst
	// arg has no defining op — calling resolveName on its synthetic name
	// would stack a spurious E3013 ("unresolved value name") on top of the
	// real E3005 diagnostic. Reporting the type error first is also more
	// useful: it points at the actual problem.
	// Promote a char-byte literal operand to a transient Character struct when
	// the comparison's struct type is `Character`; otherwise resolve the name
	// verbatim. Used by `tryLowerNamedEqualityViaEquals` so a `Character == 'x'`
	// cmp (which never routes through `coerceArgToParam`) doesn't hand the raw
	// codepoint int to `Character.equals` as a pointer. The registry check
	// guarantees we only promote actual char-byte int literals, never a real
	// Character SSA value.
	function materializeCharByteOperand(operandName ByteArray, structName String, dstBlock IrBlock) returns ValueId
		if structName == "Character" and self.project.charByteLiterals.contains(charByteLiteralKey(self.currentFuncName, valueName: operandName)) 'isCharByte'
			let byteId = self.resolveName(operandName)
			return self.materializeCharacterFromByte(byteId, dstBlock: dstBlock)
		end 'isCharByte'
		return self.resolveName(operandName)
	end 'materializeCharByteOperand'

	function coerceArgToParam(argName ByteArray, argType MaxonType, paramType MaxonType, paramName String, range SourceRange, dstBlock IrBlock) returns ValueId
		// paramType comes from `project.callParamTypes` — substitution has
		// already run during TypeResolution. The one defensive short-circuit
		// left is `MaxonType.unresolved` on either side: that signals a
		// type-resolver gap and `convertCastCategory` below would panic on it.
		if isUnresolvedType(argType) or isUnresolvedType(paramType) 'unresolvedPassThrough'
			return self.resolveName(argName)
		end 'unresolvedPassThrough'
		// Char-byte → Character coercion. The single-byte char-literal fast
		// path emits a raw int so `b == 'a'` byte comparisons keep
		// type-checking; here we recover the original char-ness and synthesize
		// a transient Character struct so a `contains(character Character)`
		// overload doesn't dereference the raw codepoint as a pointer.
		//
		// The decisive signal is the registry: an arg whose value name is in
		// `charByteLiterals` IS a raw-int char literal regardless of its
		// recorded `argType`. We must not gate on `argType == integer` here:
		// the `==` → `.equals()` rewrite retypes such an operand to `Character`
		// to pass the ref-vs-ref dispatch gate, which would otherwise skip this
		// materialization and feed the raw codepoint to `Character.equals` as a
		// pointer (segfault). Targeting a named-`Character` param is the other
		// half of the signal.
		if paramTypeIsNamedCharacter(self.project, t: paramType) 'charByteCoerce'
			if self.project.charByteLiterals.contains(charByteLiteralKey(self.currentFuncName, valueName: argName)) 'isCharByteArg'
				let byteId = self.resolveName(argName)
				return self.materializeCharacterFromByte(byteId, dstBlock: dstBlock)
			end 'isCharByteArg'
		end 'charByteCoerce'
		// Interface-typed params: both the param (interface fat pointer)
		// and a concrete struct/named arg (struct pointer) collapse to
		// `CastCategory.int` at the Std level, so the category check below
		// would silently accept a non-conforming concrete type. Probe the
		// conformance registry first and surface E3005 with interface-
		// specific wording — otherwise the witness-table lookup later
		// soft-fails to a zero address and the user sees no diagnostic.
		if interfaceTypeIsFat(paramType) 'paramIsInterface'
			let interfaceName = match paramType 'iface'
				interface(id) gives self.project.interfaceRegistry.getName(id)
				default panic("coerceArgToParam: paramType passed interfaceTypeIsFat but match has no interface arm")
			end 'iface'
			if not typeConformsTo(self.project, t: argType, interfaceName: interfaceName) 'noConform'
				let argTypeName = argType.toString(self.project)
				let path = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
				reportCompileError(self.project, code: ErrorCode.semanticTypeMismatch, message: "argument type mismatch for '{paramName}': type '{argTypeName}' does not implement interface '{interfaceName}'", line: range.line, column: range.column, filePath: path)
				return allocValueId(self.funcIdRef)
			end 'noConform'
		end 'paramIsInterface'
		let argCategory = convertCastCategory(self.project, t: argType)
		let paramCategory = convertCastCategory(self.project, t: paramType)
		if argCategory == paramCategory 'sameCategory'
			return self.resolveName(argName)
		end 'sameCategory'
		if implicitlyConvertible(argCategory, to: paramCategory) 'canConvert'
			let argId = self.resolveName(argName)
			return self.emitImplicitConvert(argId, fromCategory: argCategory, toCategory: paramCategory, dstBlock: dstBlock)
		end 'canConvert'
		// Mismatch — surface E3005 keyed off the argument's source span.
		// Naming rule: when both endpoints are primitive numeric/bool families,
		// prefer the underlying primitive name (int/float/byte/bool) so the
		// diagnostic reads "expected 'int', got 'bool'" rather than restating
		// a typealias the caller didn't write. When either endpoint is a
		// non-primitive (string, struct, enum, …), report the source-level
		// type name so callers see exactly what they wrote.
		let expectedName = mismatchTypeName(self.project, t: paramType, ownCategory: paramCategory, otherCategory: argCategory)
		let gotName = mismatchTypeName(self.project, t: argType, ownCategory: argCategory, otherCategory: paramCategory)
		// FilePath.from rejects only truly malformed inputs (e.g. embedded
		// nuls). The lowering pass's currentFilePath comes straight from
		// BlockSourceInfo, which is either empty or a path the parser
		// already accepted — fall back to the empty FilePath sentinel
		// (matches reportCompileError sites elsewhere) on the unexpected
		// rejection rather than aborting compilation mid-diagnostic.
		let path = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
		reportCompileError(self.project, code: ErrorCode.semanticTypeMismatch, message: "argument type mismatch for '{paramName}': expected '{expectedName}', got '{gotName}'", line: range.line, column: range.column, filePath: path)
		// Return a placeholder ValueId. hasErrors(project) short-circuits
		// before codegen, so this id never reaches a backend.
		return allocValueId(self.funcIdRef)
	end 'coerceArgToParam'

	// Hybrid-generics ABI bridge. Maxon Phase 11 does NOT monomorphize
	// methods — a generic body declared with `typeParameter(Element)`
	// params is compiled once and passes every Element through an opaque
	// 8-byte int-channel slot. Substitution at the call site refines the
	// paramType for type checking (so `Vector with Float`'s `v.set(0, 2.5)`
	// type-checks without coercion), but the callee body's prologue still
	// loads the param from a GPR. When the caller hands us a float-class
	// SSA at such a slot, we bitcast it to int so the call ABI uses GPR;
	// the symmetric read-side bitcast lives in `maybeBitcastCallResultToFloat`.
	//
	// No-op unless: rawParamType is `typeParameter` AND the resolved/
	// substituted paramType has CastCategory.float. The first check
	// avoids triggering on concrete float params (which already pass via
	// XMM correctly); the second avoids spuriously bitcasting int-channel
	// args at int-typed type-parameter slots (which is the common case).
	function bridgeFloatArgToTypeParam(coercedId ValueId, rawParamType MaxonType, substitutedParamType MaxonType, dstBlock IrBlock) returns ValueId
		if not maxonTypeIsTypeParameter(rawParamType) 'notTypeParam'
			return coercedId
		end 'notTypeParam'
		if isUnresolvedType(substitutedParamType) 'substUnresolved'
			return coercedId
		end 'substUnresolved'
		if convertCastCategory(self.project, t: substitutedParamType) != CastCategory.float 'notFloatBind'
			return coercedId
		end 'notFloatBind'
		return self.emitUnaryConvert(coercedId, opcode: StdArithUnaryOpcode.bitcastF64ToI64, resultType: MaxonType.integer, dstBlock: dstBlock)
	end 'bridgeFloatArgToTypeParam'

	// Hybrid-generics ABI bridge (read side). Symmetric to
	// `bridgeFloatArgToTypeParam`: when the callee's declared return type
	// is `typeParameter` and the call-site substitution binds it to a
	// float-class type, the runtime ABI hands back the result in a GPR
	// (RAX/X0). Reinterpret to f64 and rebind the result name so the
	// caller's float-typed slot reads from XMM.
	function maybeBitcastCallResultToFloat(result ByteArray, callee String, receiverContext MaxonType, dstBlock IrBlock)
		let returnType = try self.project.funcReturnTypes.get(callee) otherwise return
		let raw = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		if not maxonTypeIsTypeParameter(raw) 'notTypeParam'
			return
		end 'notTypeParam'
		let concrete = substituteReturnTypeViaReceiver(self.project, raw: raw, receiverContext: receiverContext)
		if isUnresolvedType(concrete) 'substUnresolved'
			return
		end 'substUnresolved'
		if convertCastCategory(self.project, t: concrete) != CastCategory.float 'notFloatBind'
			return
		end 'notFloatBind'
		let intResultId = self.resolveName(result)
		let floatResultId = self.emitUnaryConvert(intResultId, opcode: StdArithUnaryOpcode.bitcastI64ToF64, resultType: concrete, dstBlock: dstBlock)
		self.aliasName(result, toId: floatResultId)
	end 'maybeBitcastCallResultToFloat'

	// Like coerceArgToParam but for compiler-emitted SSA values (e.g. a
	// just-emitted constI64 for a default). No diagnostic path because the
	// compiler controls both endpoints — a category mismatch here is an
	// invariant violation, not a user error.
	function coerceValueToParam(valueId ValueId, fromType MaxonType, toType MaxonType, dstBlock IrBlock) returns ValueId
		let fromCategory = convertCastCategory(self.project, t: fromType)
		let toCategory = convertCastCategory(self.project, t: toType)
		if fromCategory == toCategory 'sameCategory'
			return valueId
		end 'sameCategory'
		if implicitlyConvertible(fromCategory, to: toCategory) 'canConvert'
			return self.emitImplicitConvert(valueId, fromCategory: fromCategory, toCategory: toCategory, dstBlock: dstBlock)
		end 'canConvert'
		panic("coerceValueToParam: no implicit conversion from {castCategoryName(fromCategory)} to {castCategoryName(toCategory)} (compiler-emitted default)")
	end 'coerceValueToParam'

	// Phase A widening-only coercion: emit an implicit int→float convert if
	// `fromType`'s category is `int` and `toType`'s category is `float`.
	// Returns the original `valueId` for every other pair (same-category,
	// narrowing, bool / string / unresolved involvement) — the caller is
	// expected to be a position where ANY non-widening mismatch is either
	// already accepted (existing kind-equal case) or a separate concern.
	// Used by `lowerFieldStore` and `lowerVarStore` to mirror the C#
	// bootstrap's Phase A struct-field-store and match-arm-result auto-
	// widening, without ever performing a narrowing.
	function widenValueToType(valueId ValueId, fromType MaxonType, toType MaxonType, dstBlock IrBlock) returns ValueId
		if isUnresolvedType(fromType) or isUnresolvedType(toType) 'unresolvedSkip'
			return valueId
		end 'unresolvedSkip'
		let fromCategory = convertCastCategory(self.project, t: fromType)
		let toCategory = convertCastCategory(self.project, t: toType)
		if not isWideningCategory(fromCategory, to: toCategory) 'notWidening'
			return valueId
		end 'notWidening'
		return self.emitImplicitConvert(valueId, fromCategory: fromCategory, toCategory: toCategory, dstBlock: dstBlock)
	end 'widenValueToType'

	// Emit the Std-level conversion ops for one of the supported implicit
	// conversions. Categorical dispatch keeps the convert kernel small —
	// caller has already validated that the (from, to) pair is admissible.
	function emitImplicitConvert(valueId ValueId, fromCategory CastCategory, toCategory CastCategory, dstBlock IrBlock) returns ValueId
		// int → float : siToFp.
		if fromCategory == CastCategory.int and toCategory == CastCategory.float 'intToFloat'
			return self.emitUnaryConvert(valueId, opcode: StdArithUnaryOpcode.siToFpF64, resultType: MaxonType.float, dstBlock: dstBlock)
		end 'intToFloat'
		// float → int : fpToSi truncates toward zero.
		if fromCategory == CastCategory.float and toCategory == CastCategory.int 'floatToInt'
			return self.emitUnaryConvert(valueId, opcode: StdArithUnaryOpcode.fpToSiI64, resultType: MaxonType.integer, dstBlock: dstBlock)
		end 'floatToInt'
		panic("emitImplicitConvert: unhandled pair ({castCategoryName(fromCategory)} -> {castCategoryName(toCategory)})")
	end 'emitImplicitConvert'

	// Emit a single Std arith-unary conversion op (siToFp / fpToSi / etc.),
	// register the result's MaxonType in the value-type map, and return the
	// new SSA id. Centralizes the three-line pattern used by every implicit
	// convert path.
	function emitUnaryConvert(valueId ValueId, opcode StdArithUnaryOpcode, resultType MaxonType, dstBlock IrBlock) returns ValueId
		let convId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(opcode, resultId: convId, operandId: valueId))))
		self.setValueType(convId, t: resultType)
		return convId
	end 'emitUnaryConvert'

	// Resolve a `name:` label to its slot index in the user-facing portion of
	// the signature via the precomputed nameToIndex map. Throws
	// `LabelSlotError.notFound` for both the unknown-label case and the
	// resolves-to-a-hidden-prefix-slot case (e.g. `__self`); the caller emits
	// E3xxx and skips the bad arg.
	function resolveLabelToSlot(signature FuncSignature, label String, paramStartIndex ParsedInt) returns ParsedInt throws LabelSlotError
		let absIdx = try signature.nameToIndex.get(label) otherwise throw LabelSlotError.notFound
		if absIdx < paramStartIndex 'beforeUserSpace'
			throw LabelSlotError.notFound
		end 'beforeUserSpace'
		return absIdx - paramStartIndex
	end 'resolveLabelToSlot'

	// Record the declared return type of a resolved call into the value-type
	// map so subsequent ops that consume the call's result (field loads,
	// method calls on it, mixed-family arithmetic, etc.) can resolve.
	// Promotes a `Self`-shaped return type (parsed as `named(EnclosingType)`)
	// to the receiver's `genericInstance(EnclosingType, [...])` when the
	// caller threaded a concrete receiverContext — the bare `funcReturnTypes`
	// entry doesn't carry the type-arg binding the call site implies.
	function recordCallResultType(resultId ValueId, callee String, dstBlock IrBlock, receiverContext MaxonType = MaxonType.unresolved)
		let returnType = try self.project.funcReturnTypes.get(callee) otherwise MaxonReturnType.void
		let raw = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		// Apply inner-alias chase, Self-shape promotion, bare-generic-to-
		// receiver-scope promotion, and typeParameter substitution so the
		// lowering-side value-type tracks TypeResolution exactly. Required
		// for callees whose return type carries an enclosing-struct alias
		// (e.g. `MapIterator.current()` returns `Entry`) or a bare-generic
		// name (e.g. `Map.createIterator()` returns `MapIterator`) — both
		// only resolve once the receiver's substitution is in scope.
		let substituted = substituteReturnTypeViaReceiver(self.project, raw: raw, receiverContext: receiverContext)
		// Chase one hop through a function-type alias so a methodCall
		// returning `named(UnaryOp)` (where UnaryOp = (Integer) returns
		// Integer) sees its underlying function shape. Type-parameter
		// substitution from the receiver's type args lands an arg-typed
		// named value here — without the chase, the function-typed return
		// stays nominal and the indirect-call env recording below misses.
		let chased = chaseTypealiasToFunctionType(self.project, t: substituted)
		self.setValueType(resultId, t: chased)
		// Function-typed call results enter the indirect-call ABI with
		// env=0 — the returned value is a code pointer to a top-level
		// function reference (no captured environment). Materialize a real
		// `const 0` op so the env binding has a defining SSA op; a literal
		// `0 as ValueId` would alias whatever ValueId 0 is in this function
		// and panic regalloc when that v0 has no def.
		if isFunctionMaxonType(chased) 'isFnReturn'
			let envZeroId = self.emitConstI64(0, dstBlock: dstBlock)
			self.fnEnvVarNames.upsert(resultId, value: envZeroId)
		end 'isFnReturn'
	end 'recordCallResultType'

	// fieldLoad: read receiver's struct type from the value-type map, find
	// the named field's offset, emit the indirect load. Records the field's
	// declared type so chained field accesses keep resolving.
	function lowerFieldLoad(result ByteArray, receiver ByteArray, fieldName ByteArray, dstBlock IrBlock)
		let receiverId = self.resolveName(receiver)
		let receiverType = self.getValueType(receiverId)
		let fieldNameStr = String.from(fieldName)
		// Enum builtin accessors:
		//   `.rawValue` is always a value-level no-op — the receiver's SSA
		//     value already carries the raw bits (int or float).
		//   `.ordinal` on an ordinal-backed enum (no explicit raw values, so
		//     rawValue == ordinal by construction) is also a no-op.
		//   `.ordinal` on an int/float-backed enum needs a runtime lookup
		//     from raw value back to declaration position — emitted as a
		//     branchless arithmetic chain (one cmp+mul per case, all summed).
		let enumName = receiverType.namedAliasNameOrEmpty(self.project)
		if not enumName.isEmpty() 'maybeEnum'
			if let enumType = try self.project.enumTypes.get(enumName) 'isEnum'
				if fieldNameStr == "rawValue" 'isRaw'
					if enumType.isFunctionBacked 'isFnBacked'
						// Function-backed enums map their ordinal to a function
						// pointer via a synthesized helper. The result is a
						// function-typed value; the call into the helper is a
						// regular `call`, but the SSA result must carry the
						// enum's shared FunctionTypeId and an env entry of 0
						// (free functions) so a subsequent indirect call site
						// can find the right thunk and dispatch correctly.
						self.lowerFunctionBackedEnumRawValue(result, receiverId: receiverId, enumType: enumType, dstBlock: dstBlock)
						return
					end 'isFnBacked'
					if enumType.isStringBacked or enumType.isCharBacked 'isStringChar'
						// String/char-backed enums store the ordinal at runtime,
						// so `.rawValue` must materialize the case's declared
						// backing literal (String / Character) from the ordinal
						// via a synthesized helper — analogous to `.name`.
						self.lowerStringBackedEnumRawValue(result, receiverId: receiverId, enumType: enumType, dstBlock: dstBlock)
						return
					end 'isStringChar'
					// int / float / ordinal / struct backings: the receiver's
					// SSA value already carries the raw bits.
					self.aliasName(result, toId: receiverId)
					return
				end 'isRaw'
				if fieldNameStr == "ordinal" 'isOrdinal'
					if enumIsOrdinalBacked(enumType) 'ordinalEqRaw'
						self.aliasName(result, toId: receiverId)
						return
					end 'ordinalEqRaw'
					self.lowerEnumOrdinalLookup(result, receiverId: receiverId, enumType: enumType, dstBlock: dstBlock)
					return
				end 'isOrdinal'
				if fieldNameStr == "name" 'isName'
					self.lowerEnumNameLookup(result, receiverId: receiverId, enumType: enumType, dstBlock: dstBlock)
					return
				end 'isName'
			end 'isEnum'
		end 'maybeEnum'
		let resultId = self.defineName(result)
		let hit = try self.lookupFieldByReceiver(receiverType, fieldName: fieldNameStr) otherwise 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown field '{fieldNameStr}' on type '{receiverType.toString(self.project)}' in func '{self.currentFuncName}'")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notFound'
		// Phase 15e: for a tuple receiver like `genericInstance(__Tuple2, [int, float])`,
		// the raw struct field type is `_T1` (typeParameter). Substitute through the
		// receiver's args so the load width / float-ness matches the actual element
		// type.
		//
		// Phase 11.7: also substitute for any other concrete generic instance whose
		// args don't themselves mention type parameters — `WrapperHolder = Holder
		// with Wrapper` (gid args: [named(Wrapper)]) needs its `T item` field to
		// surface as `Wrapper` at the use site so `h.item.value()` lowers to a
		// concrete `Wrapper.value` call rather than hitting the type-param
		// dispatch stub. The "args have no type parameters" gate avoids
		// substituting through a partially-bound generic receiver (e.g. inside an
		// extension method on `Array`, the receiver still mentions
		// `typeParameter(Element)`) where the substitution would return
		// `MaxonType.unresolved` and break downstream lowering.
		let resolvedFieldType = pickFieldTypeViaReceiver(self.project, raw: hit.fieldType, receiverType: receiverType)
		let fieldStdType = maxonTypeToStdType(self.project, ref: resolvedFieldType)
		let fieldWidth = storeWidthOfStdType(fieldStdType)
		let fieldSigned = stdTypeIsSigned(fieldStdType)
		let isFloat = stdTypeIsFloat(fieldStdType)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: receiverId, offset: hit.offset, width: fieldWidth, signed: fieldSigned, isFloat: isFloat)))
		self.setValueType(resultId, t: resolvedFieldType)
		// Interface-typed fields are fat pointers — emit a sibling load at
		// `offset + 8` for the witness half and pair the (resultId →
		// witnessId) so a downstream call site that passes this field to a
		// function with an interface-typed parameter can recover the witness
		// via `witnessForInterfaceArg` instead of hitting the no-pairing
		// panic. Mirrors the slot-load witness pairing in `lowerVarLoad`.
		if interfaceTypeIsFat(hit.fieldType) 'pairWitness'
			let witnessId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(witnessId, addrId: receiverId, offset: (hit.offset + 8) as FieldOffset, width: StoreWidth.qword, signed: false, isFloat: false)))
			self.setValueType(witnessId, t: MaxonType.integer)
			self.interfaceWitnessValueIds.upsert(resultId, value: witnessId)
		end 'pairWitness'
	end 'lowerFieldLoad'

	// Snapshot + reset the per-function lowering state for a synthesized
	// helper whose parameter count is `paramCount` (param ValueIds 0..N-1
	// are reserved by ValueIdRef.create). Pair every call with
	// `endSynthesizedFunc` once the helper is fully emitted.
	function beginSynthesizedFunc(paramCount VarSlot) returns LoweringFuncStateSnapshot
		let snapshot = LoweringFuncStateSnapshot.create(self.funcIdRef, nameToId: self.nameToId, valueType: self.valueType)
		self.funcIdRef = ValueIdRef.create(paramCount)
		self.nameToId = NameToValueIdMap.create()
		self.valueType = MaxonTypeArray.create()
		return snapshot
	end 'beginSynthesizedFunc'

	// Finalize a synthesized helper: record its slot count, push it onto
	// the std module, and restore the outer-function state captured by
	// `beginSynthesizedFunc`.
	function endSynthesizedFunc(func IrFunction, snapshot LoweringFuncStateSnapshot)
		func.varSlotCount = self.funcIdRef.nextId as VarSlot
		self.stdModule.functions.push(func)
		self.funcIdRef = snapshot.funcIdRef
		self.nameToId = snapshot.nameToId
		self.valueType = snapshot.valueType
	end 'endSynthesizedFunc'

	// Bind `result` to a fresh int-typed placeholder ValueId. Used by ops
	// whose own lowering failed (TR ought to have caught the upstream error
	// already); the placeholder keeps the SSA dag well-formed so downstream
	// passes don't re-trip on the dangling name.
	function definePlaceholderInt(result ByteArray)
		let placeholderId = self.defineName(result)
		self.setValueType(placeholderId, t: MaxonType.integer)
	end 'definePlaceholderInt'

	// Phase 9 Stage 1: synthesize one `__enum_<EnumName>_name(rawValue) returns
	// String` helper per enum recorded in `pendingEnumNameHelpers`. The body
	// is a chain of cmp+condBr blocks: each leaf allocates a String for the
	// matching case name (via the same lowerStringConst layout used for user
	// string literals) and returns it. Only the matching branch executes its
	// allocation at runtime — so a `.name` call costs exactly one String +
	// __ManagedMemory pair, no leak.
	function synthesizeEnumNameHelpers()
		for enumName in self.pendingEnumNameHelpers 'eachEnum'
			let enumType = try self.project.enumTypes.get(enumName) otherwise panic("synthesizeEnumNameHelpers: enumTypes lookup failed for registered enum '{enumName}'")
			self.synthesizeOneEnumNameHelper(enumType)
		end 'eachEnum'
	end 'synthesizeEnumNameHelpers'

	// Emit the body for one enum's `.name` helper. The function takes a
	// single param (the receiver's rawValue — f64 for float-backed enums, i64
	// otherwise) and returns a String. For each case i, the entry → next_1 →
	// ... → next_{N-1} chain compares the param against `case_i.rawValue` and
	// branches into a per-case block that emits the lowerStringConst layout for
	// `case_i.name` and rets. The final tail block runs unconditionally for the
	// last case — equivalent to "if all earlier cases missed, it must be the
	// last one" — so there is no panic-on-no-match path. Invariant: any caller
	// has already validated the receiver as a real enum value (the type system
	// guarantees this; out-of-band raw values are undefined behavior).
	//
	// A float-backed enum's receiver carries the IEEE-754 rawValue, so the
	// param (and the cmp chain) must be f64 — otherwise the caller hands an f64
	// into an i64 param and wasm validation rejects the type mismatch (x64
	// tolerates it because registers are untyped).
	function synthesizeOneEnumNameHelper(enumType EnumType)
		let helperName = enumNameHelperSymbol(enumType.name)
		var paramStdType = StdType.i64
		if enumType.isFloatBacked 'floatParam'
			paramStdType = StdType.f64
		end 'floatParam'
		let returnType = StdReturnType.value(StdType.i64)
		var paramTypes = StdTypeArray.create()
		paramTypes.push(paramStdType)
		var func = IrFunction.createFromStd(helperName, returnType: returnType, paramCount: 1, paramTypes: paramTypes, returnLine: 0)
		let snapshot = self.beginSynthesizedFunc(1)

		var entryBlock = self.stdModule.addBlock(func, label: "entry")
		// Param op anchors the receiver-rawValue slot for the backend's
		// register allocator. The param's ValueId is 0 by construction
		// (ValueIdRef.create(1) reserves id 0 for the single param).
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(0 as ValueId, paramIndex: 0, paramType: paramStdType)))
		self.setIsFloat(0 as ValueId, isFloat: enumType.isFloatBacked)

		let caseCount = enumType.cases.count()
		let constOpcode = StdArithConstOpcode.constF64 if enumType.isFloatBacked else StdArithConstOpcode.constI64
		let cmpOpcode = StdArithBinaryOpcode.cmpF64Eq if enumType.isFloatBacked else StdArithBinaryOpcode.cmpI64Eq

		var currentEntry = entryBlock
		for i in 0 upto caseCount 'eachCase'
			let c = try enumType.cases.get(i) otherwise panic("synthesizeOneEnumNameHelper: cases.get OOB at {i}")
			var caseBlock = self.stdModule.addBlock(func, label: "case_{i}")
			let isLast = i == caseCount - 1
			if isLast 'noMoreCmps'
				// Last case: unconditionally branch into its body. The
				// preceding cmp chain has already eliminated every other case
				// value, so this is equivalent to the "no match" fallthrough.
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.br(caseBlock.id, argIds: ValueIdArray.create())))
			end 'noMoreCmps' else 'emitCmp'
				let caseLitId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(currentEntry, op: StdOp.arith(StdArithOp.const(StdArithConst.create(constOpcode, resultId: caseLitId, value: c.rawValue))))
				self.setIsFloat(caseLitId, isFloat: enumType.isFloatBacked)
				let cmpId = self.emitBinaryI64(cmpOpcode, leftId: 0 as ValueId, rightId: caseLitId, dstBlock: currentEntry)
				let nextEntry = self.stdModule.addBlock(func, label: "name_check_{i + 1}")
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: caseBlock.id, thenArgIds: ValueIdArray.create(), elseTarget: nextEntry.id, elseArgIds: ValueIdArray.create())))
				currentEntry = nextEntry
			end 'emitCmp'
			// Per-case block emits the lowerStringConst layout for the case
			// name, then returns. `lowerStringConst` writes its result into
			// `nameToId` under the synthetic result-name we hand it; we
			// resolve back through `nameToId` to feed the ret op.
			let resultName = "__name_result_{i}".toByteArray()
			self.lowerStringConst(resultName, stringId: self.project.strings.intern(c.name), dstBlock: caseBlock)
			let resultId = self.resolveName(resultName)
			self.stdModule.setTerminator(caseBlock, op: StdOp.call(StdCallOp.ret(resultId)))
		end 'eachCase'

		self.endSynthesizedFunc(func, snapshot: snapshot)
	end 'synthesizeOneEnumNameHelper'

	// Emit one `__enum_<EnumName>_rawString(ordinal)` helper per string/char-
	// backed enum recorded in `pendingEnumRawStringHelpers`. Structurally
	// identical to `synthesizeOneEnumNameHelper`, except each per-case leaf
	// materializes the case's declared backing literal (`rawStringValue`)
	// instead of its name — as a String for string-backed enums, or a
	// Character for char-backed enums.
	function synthesizeEnumRawStringHelpers()
		for enumName in self.pendingEnumRawStringHelpers 'eachEnum'
			let enumType = try self.project.enumTypes.get(enumName) otherwise panic("synthesizeEnumRawStringHelpers: enumTypes lookup failed for registered enum '{enumName}'")
			self.synthesizeOneEnumRawStringHelper(enumType)
		end 'eachEnum'
	end 'synthesizeEnumRawStringHelpers'

	function synthesizeOneEnumRawStringHelper(enumType EnumType)
		let helperName = enumRawStringHelperSymbol(enumType.name)
		let returnType = StdReturnType.value(StdType.i64)
		var paramTypes = StdTypeArray.create()
		paramTypes.push(StdType.i64)
		var func = IrFunction.createFromStd(helperName, returnType: returnType, paramCount: 1, paramTypes: paramTypes, returnLine: 0)
		let snapshot = self.beginSynthesizedFunc(1)

		var entryBlock = self.stdModule.addBlock(func, label: "entry")
		// Param op anchors the receiver-ordinal slot; its ValueId is 0 by
		// construction (the single param reserves id 0).
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(0 as ValueId, paramIndex: 0, paramType: StdType.i64)))
		self.setValueType(0 as ValueId, t: MaxonType.integer)

		let caseCount = enumType.cases.count()
		var currentEntry = entryBlock
		for i in 0 upto caseCount 'eachCase'
			let c = try enumType.cases.get(i) otherwise panic("synthesizeOneEnumRawStringHelper: cases.get OOB at {i}")
			var caseBlock = self.stdModule.addBlock(func, label: "case_{i}")
			let isLast = i == caseCount - 1
			if isLast 'noMoreCmps'
				// Last case runs unconditionally — the cmp chain already
				// eliminated every other ordinal (equivalent to the no-match
				// fallthrough; an out-of-band ordinal is undefined behavior).
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.br(caseBlock.id, argIds: ValueIdArray.create())))
			end 'noMoreCmps' else 'emitCmp'
				let caseLitId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(currentEntry, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: caseLitId, value: c.rawValue))))
				let cmpId = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Eq, leftId: 0 as ValueId, rightId: caseLitId, dstBlock: currentEntry)
				let nextEntry = self.stdModule.addBlock(func, label: "rawstr_check_{i + 1}")
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: caseBlock.id, thenArgIds: ValueIdArray.create(), elseTarget: nextEntry.id, elseArgIds: ValueIdArray.create())))
				currentEntry = nextEntry
			end 'emitCmp'
			// Per-case leaf materializes the declared backing literal and rets.
			let resultName = "__rawstr_result_{i}".toByteArray()
			let backingStringId = self.project.strings.intern(c.rawStringValue)
			if enumType.isCharBacked 'charLeaf'
				self.lowerCharLiteral(resultName, stringId: backingStringId, dstBlock: caseBlock)
			end 'charLeaf' else 'stringLeaf'
				self.lowerStringConst(resultName, stringId: backingStringId, dstBlock: caseBlock)
			end 'stringLeaf'
			let resultId = self.resolveName(resultName)
			self.stdModule.setTerminator(caseBlock, op: StdOp.call(StdCallOp.ret(resultId)))
		end 'eachCase'

		self.endSynthesizedFunc(func, snapshot: snapshot)
	end 'synthesizeOneEnumRawStringHelper'

	// Phase 9 Stage 4: walk every resolved enum type and synthesize a
	// `__destruct_<UnionName>(self i64) returns i64` per union with managed
	// payloads. Unions with only scalar payloads (and bare-enum types) skip
	// emission entirely — `lowerEnumConstruct` passes a null destructor for
	// those allocations and the slab path on `mm_decref → mm_free` handles
	// the box without per-payload teardown.
	function synthesizeUnionDestructors()
		for (_, enumType) in self.project.enumTypes 'eachEnum'
			if not enumType.isUnion 'notUnion'
				continue
			end 'notUnion'
			if not unionHasManagedPayload(self.project, unionType: enumType) 'scalarOnly'
				continue
			end 'scalarOnly'
			self.synthesizeOneUnionDestructor(enumType)
		end 'eachEnum'
	end 'synthesizeUnionDestructors'

	// Phase 10 (closures): emit one wrapper thunk per free function
	// referenced via `MaxonOp.functionRef`. The thunk's signature mirrors
	// the target's user-visible signature plus a trailing `__env i64` arg
	// that satisfies the indirect-call ABI (every call_indirect site
	// pushes the env after the user args). The body just calls the target
	// with the user args (env discarded) and rets the result.
	function synthesizeFnRefThunks()
		for i in 0 upto self.pendingFnRefThunkTargets.count() 'eachThunk'
			let targetName = try self.pendingFnRefThunkTargets.get(i) otherwise panic("synthesizeFnRefThunks: target lookup OOB at {i}")
			self.synthesizeOneFnRefThunk(targetName)
		end 'eachThunk'
	end 'synthesizeFnRefThunks'

	function synthesizeOneFnRefThunk(targetName String)
		// Pull the target's signature from project tables — the parser
		// registered every free function under its qualified name with
		// both `funcSignatures` and `funcReturnTypes`.
		let targetSig = try self.project.funcSignatures.get(targetName) otherwise panic("synthesizeOneFnRefThunk: funcSignatures.get failed for target '{targetName}' (functionRef must have referenced a registered function)")
		let targetReturn = try self.project.funcReturnTypes.get(targetName) otherwise panic("synthesizeOneFnRefThunk: funcReturnTypes.get failed for target '{targetName}'")
		let userParamCount = targetSig.paramTypes.count()
		let thunkParamCount = (userParamCount + 1) as VarSlot
		let thunkName = "__fnref_{targetName}"
		var stdParamTypes = StdTypeArray.create()
		for pIdx in 0 upto userParamCount 'eachParam'
			let pType = try targetSig.paramTypes.get(pIdx) otherwise panic("synthesizeOneFnRefThunk: paramTypes.get OOB at {pIdx}")
			stdParamTypes.push(maxonTypeToStdType(self.project, ref: pType))
		end 'eachParam'
		// Trailing `__env` param — always i64 regardless of target body's
		// captures (or lack thereof). The wasm call_indirect type machinery
		// reads this slot's width directly off the StdTypeArray.
		stdParamTypes.push(StdType.i64)
		let stdReturn = maxonReturnTypeToStdReturnType(self.project, ref: targetReturn)
		var thunkFunc = IrFunction.createFromStd(thunkName, returnType: stdReturn, paramCount: thunkParamCount, paramTypes: stdParamTypes, returnLine: 0)
		let snapshot = self.beginSynthesizedFunc(thunkParamCount)
		var entryBlock = self.stdModule.addBlock(thunkFunc, label: "entry")
		// Anchor each param with a param op so the regalloc sees the source.
		var forwardArgIds = ValueIdArray.create()
		for pIdx in 0 upto userParamCount 'paramOp'
			let stdType = try stdParamTypes.get(pIdx) otherwise panic("synthesizeOneFnRefThunk: stdParamTypes.get OOB at {pIdx}")
			self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(pIdx as ValueId, paramIndex: pIdx, paramType: stdType)))
			forwardArgIds.push(pIdx as ValueId)
		end 'paramOp'
		// Anchor the trailing `__env` param even though we don't use it;
		// the regalloc needs the param op so the wasm signature includes
		// the slot.
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(userParamCount, paramIndex: userParamCount, paramType: StdType.i64)))
		// Function-typed value calls (`apply(f, x)`) always consume a non-
		// void return — `f(x)` always produces a result the caller uses,
		// and parser-level type-checking rejects passing a void-returning
		// function to a (T) returns R signature. The unreached branch
		// keeps the StdReturnType match total.
		let isVoidReturn = match stdReturn 'r'
			void gives true
			value gives false
		end 'r'
		if isVoidReturn 'voidReturn'
			panic("synthesizeOneFnRefThunk: void-returning target '{targetName}' cannot satisfy any (T) returns R indirect-call signature")
		end 'voidReturn'
		let resultId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.call(resultId, callee: targetName, argIds: forwardArgIds)))
		self.stdModule.setTerminator(entryBlock, op: StdOp.call(StdCallOp.ret(resultId)))
		self.endSynthesizedFunc(thunkFunc, snapshot: snapshot)
	end 'synthesizeOneFnRefThunk'

	// Emit a single union's destructor. Shape:
	//
	//   func __destruct_<UnionName> 1 i64
	//     block entry:
	//       v0 = std param 0 i64           // self
	//       v_tag = std loadIndirect v0 0  // tag at offset 0
	//       (tag-switch chain — case_i blocks)
	//     ...
	//     block case_i:
	//       (for each managed payload field at offset 8+j*8:
	//          v_load = std loadIndirect v0 (8+j*8)
	//          _ = std call mm_decref v_load)
	//       std br done
	//     ...
	//     block default:
	//       std br done                    // unreachable in practice — every
	//                                       // tag corresponds to a real case;
	//                                       // emit a no-op br rather than panic
	//                                       // so out-of-band reads (e.g. a
	//                                       // future debug tool inspecting a
	//                                       // half-initialized box) don't crash
	//                                       // the destructor.
	//     block done:
	//       v_zero = std constI64 0
	//       std ret v_zero
	//
	// Return type is `i64 = 0` rather than void: `mm_alloc`'s indirect-call
	// ABI (see runtime.std `__destruct___ManagedMemory`) requires the
	// destructor signature to be `(i64) -> i64` so the wasm `call_indirect`
	// type tag matches across every destructor. The X64/Arm64 backends
	// silently discard the returned value.
	function synthesizeOneUnionDestructor(unionType EnumType)
		let helperName = unionDestructorSymbol(unionType.name)
		let returnType = StdReturnType.value(StdType.i64)
		var paramTypes = StdTypeArray.create()
		paramTypes.push(StdType.i64)
		var func = IrFunction.createFromStd(helperName, returnType: returnType, paramCount: 1, paramTypes: paramTypes, returnLine: 0)
		let snapshot = self.beginSynthesizedFunc(1)

		var entryBlock = self.stdModule.addBlock(func, label: "entry")
		// Anchor the self pointer as the synthesized function's only param.
		// ValueIdRef.create(1) reserves id 0 for it.
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(0 as ValueId, paramIndex: 0, paramType: StdType.i64)))
		self.setValueType(0 as ValueId, t: MaxonType.named(self.project.typeNames.intern(unionType.name)))
		let selfId = 0 as ValueId

		// Load the tag once at the entry; every per-case block branches off
		// the same SSA value.
		let tagId = self.emitLoadFieldI64(selfId, offset: 0, dstBlock: entryBlock)

		// Pre-create a `done` block; every case body and the default fall
		// through to it so the ret happens exactly once.
		var doneBlock = self.stdModule.addBlock(func, label: "done")

		// One per-case decref block per union case. Cases with zero managed
		// payload fields still get a block — the tag-switch fall-through path
		// hits them and they immediately `br done`. Trying to merge those
		// cases into the default block would require dynamic discovery of
		// which tags are "scalar-only", which complicates the switch chain
		// for no real win; the empty blocks DCE/simplify away in later
		// passes.
		var caseBlockIds = BlockIdArray.create()
		for i in 0 upto unionType.cases.count() 'eachCase'
			let c = try unionType.cases.get(i) otherwise panic("synthesizeOneUnionDestructor: cases.get OOB at {i}")
			var caseBlock = self.stdModule.addBlock(func, label: "case_{i}")
			for fi in 0 upto c.payloadFields.count() 'eachField'
				let field = try c.payloadFields.get(fi) otherwise panic("synthesizeOneUnionDestructor: payloadFields.get OOB at {fi}")
				if not maxonTypeIsManagedRef(self.project, t: field.fieldType) 'isScalar'
					continue
				end 'isScalar'
				let payloadOffset = 8 + fi * 8
				let payloadId = self.emitLoadFieldI64(selfId, offset: payloadOffset, dstBlock: caseBlock)
				var decrefArgs = ValueIdArray.create()
				decrefArgs.push(payloadId)
				let decrefRetId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(caseBlock, op: StdOp.call(StdCallOp.call(decrefRetId, callee: "stdlib.__mm_decref", argIds: decrefArgs)))
				self.setValueType(decrefRetId, t: MaxonType.integer)
			end 'eachField'
			self.stdModule.setTerminator(caseBlock, op: StdOp.control(StdControlOp.br(doneBlock.id, argIds: ValueIdArray.create())))
			caseBlockIds.push(caseBlock.id)
		end 'eachCase'

		// Default block — never taken in well-formed code but the verifier
		// requires every condBr's else target to point somewhere. Plain `br
		// done` rather than panic: the destructor running on a malformed box
		// would already have been preceded by an invalid `mm_alloc`/store
		// sequence in user code, and surfacing that as a destructor panic is
		// strictly less helpful than letting the rest of the teardown
		// continue.
		var defaultBlock = self.stdModule.addBlock(func, label: "default")
		self.stdModule.setTerminator(defaultBlock, op: StdOp.control(StdControlOp.br(doneBlock.id, argIds: ValueIdArray.create())))

		var ordinals = TagValueArray.create()
		for i in 0 upto unionType.cases.count() 'collectOrdinals'
			let c = try unionType.cases.get(i) otherwise panic("synthesizeOneUnionDestructor: ordinals.get OOB at {i}")
			ordinals.push(c.ordinal as IntConstant)
		end 'collectOrdinals'
		self.emitTagSwitch(tagId, ordinals: ordinals, caseBlockIds: caseBlockIds, defaultBlockId: defaultBlock.id, entryBlock: entryBlock, func: func)

		// Tail: ret 0. Every case + default block already branched here.
		let zeroId = self.emitConstI64(0, dstBlock: doneBlock)
		self.stdModule.setTerminator(doneBlock, op: StdOp.call(StdCallOp.ret(zeroId)))

		self.endSynthesizedFunc(func, snapshot: snapshot)
	end 'synthesizeOneUnionDestructor'

	// Phase 9 Stage 4: emit a tag-dispatch chain.
	//
	// Given a tag SSA value, a parallel `(ordinals, caseBlockIds)` pair, and
	// a fall-through `defaultBlockId`, emits `cmpI64Eq + condBr` per case
	// across a chain of "tag_check_i" blocks linked off `entryBlock`. After
	// the last cmp fails, control branches into `defaultBlockId`.
	//
	// Used by the union destructor synthesizer today; structured so the
	// match-arm lowering path can adopt the same helper when range patterns
	// over union tags land (Stage 0's int-tag chain is conceptually the same
	// shape, factored along this seam).
	function emitTagSwitch(tagId ValueId, ordinals TagValueArray, caseBlockIds BlockIdArray, defaultBlockId BlockId, entryBlock IrBlock, func IrFunction)
		if ordinals.count() != caseBlockIds.count() 'lengthMismatch'
			panic("emitTagSwitch: ordinals.count ({ordinals.count()}) != caseBlockIds.count ({caseBlockIds.count()})")
		end 'lengthMismatch'
		var currentEntry = entryBlock
		let caseCount = ordinals.count()
		for i in 0 upto caseCount 'eachCase'
			let ord = try ordinals.get(i) otherwise panic("emitTagSwitch: ordinals.get OOB at {i}")
			let caseBlockId = try caseBlockIds.get(i) otherwise panic("emitTagSwitch: caseBlockIds.get OOB at {i}")
			let constId = self.emitConstI64(ord as ParsedInt, dstBlock: currentEntry)
			let cmpId = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Eq, leftId: tagId, rightId: constId, dstBlock: currentEntry)
			let isLast = i == caseCount - 1
			if isLast 'tailToDefault'
				// Last cmp routes the miss directly to the default block —
				// no need to chain another "tag_check_N" block whose only op
				// would be an unconditional br.
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: caseBlockId, thenArgIds: ValueIdArray.create(), elseTarget: defaultBlockId, elseArgIds: ValueIdArray.create())))
			end 'tailToDefault' else 'chainNext'
				let nextEntry = self.stdModule.addBlock(func, label: "tag_check_{i + 1}")
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: caseBlockId, thenArgIds: ValueIdArray.create(), elseTarget: nextEntry.id, elseArgIds: ValueIdArray.create())))
				currentEntry = nextEntry
			end 'chainNext'
		end 'eachCase'
	end 'emitTagSwitch'

	// Phase 9 Stage 1: lower `enumValue.name` to a call to the per-enum
	// `__enum_<EnumName>_name` helper synthesized at the tail of `lower()`.
	// The helper takes the enum's rawValue (passed in receiverId verbatim —
	// the SSA value is identical to .rawValue) and returns the matching
	// case-name String. Registering the enum here adds it to
	// `pendingEnumNameHelpers`; the actual function body is emitted once
	// per enum in `synthesizeEnumNameHelpers`.
	function lowerEnumNameLookup(result ByteArray, receiverId ValueId, enumType EnumType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern("String")))
		let helperName = enumNameHelperSymbol(enumType.name)
		self.pendingEnumNameHelpers.insert(enumType.name)
		var argIds = ValueIdArray.create()
		argIds.push(receiverId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: helperName, argIds: argIds)))
	end 'lowerEnumNameLookup'

	// String/char-backed `.rawValue`: call the synthesized helper
	// `__enum_<EnumName>_rawString(ordinal)` that maps the receiver's runtime
	// ordinal to the case's declared backing literal. String-backed enums
	// return a `String`; char-backed enums return a `Character`. Mirrors
	// `lowerEnumNameLookup`.
	function lowerStringBackedEnumRawValue(result ByteArray, receiverId ValueId, enumType EnumType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		let resultTypeName = "Character" if enumType.isCharBacked else "String"
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern(resultTypeName)))
		let helperName = enumRawStringHelperSymbol(enumType.name)
		self.pendingEnumRawStringHelpers.insert(enumType.name)
		var argIds = ValueIdArray.create()
		argIds.push(receiverId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: helperName, argIds: argIds)))
	end 'lowerStringBackedEnumRawValue'

	// Phase 9 Stage 1: branchless `rawValue → ordinal` lookup for int/float-
	// backed enums. Each case contributes `i * (receiverRaw == case_i.raw)` —
	// at most one comparison is 1, so the running sum equals the matching
	// ordinal. For float-backed enums we compare against the case's IEEE-754
	// bit pattern (stored as the case's `rawValue`) using `cmpF64Eq`; the
	// comparison result is already an i64-shaped 0/1, so the surrounding
	// arithmetic stays in i64. Cases with ordinal 0 are skipped — they
	// contribute nothing to the sum.
	function lowerEnumOrdinalLookup(result ByteArray, receiverId ValueId, enumType EnumType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		let cmpOpcode = StdArithBinaryOpcode.cmpF64Eq if enumType.isFloatBacked else StdArithBinaryOpcode.cmpI64Eq
		let constOpcode = StdArithConstOpcode.constF64 if enumType.isFloatBacked else StdArithConstOpcode.constI64
		var runningSumId = self.emitConstI64(0, dstBlock: dstBlock)
		for i in 0 upto enumType.cases.count() 'eachCase'
			let c = try enumType.cases.get(i) otherwise panic("lowerEnumOrdinalLookup: cases.get OOB at {i}")
			if i == 0 'firstCaseSkipped'
				// Ordinal 0 contributes 0 regardless of the comparison — skip
				// emitting the cmp+mul pair entirely.
				continue
			end 'firstCaseSkipped'
			let caseLitId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(constOpcode, resultId: caseLitId, value: c.rawValue))))
			self.setIsFloat(caseLitId, isFloat: enumType.isFloatBacked)
			let cmpId = self.emitBinaryI64(cmpOpcode, leftId: receiverId, rightId: caseLitId, dstBlock: dstBlock)
			let ordinalConstId = self.emitConstI64(i as ParsedInt, dstBlock: dstBlock)
			let contribId = self.emitBinaryI64(StdArithBinaryOpcode.mulI64, leftId: cmpId, rightId: ordinalConstId, dstBlock: dstBlock)
			runningSumId = self.emitBinaryI64(StdArithBinaryOpcode.addI64, leftId: runningSumId, rightId: contribId, dstBlock: dstBlock)
		end 'eachCase'
		self.aliasName(result, toId: runningSumId)
		self.setValueType(resultId, t: MaxonType.integer)
	end 'lowerEnumOrdinalLookup'

	// Function-backed enum `.rawValue`: call the synthesized helper
	// `__enum_<EnumName>_fnRaw(ordinal) returns i64`. The returned i64 IS
	// the function pointer for the matching case. We register the result as
	// `MaxonType.function(functionBackingTypeId)` and stamp env=0 in
	// `fnEnvVarNames` so a later indirect-call site treats it the same as
	// any other free-function reference.
	function lowerFunctionBackedEnumRawValue(result ByteArray, receiverId ValueId, enumType EnumType, dstBlock IrBlock)
		let resultId = self.defineName(result)
		let helperName = enumFnRawHelperSymbol(enumType.name)
		self.pendingEnumFnRawHelpers.insert(enumType.name)
		var argIds = ValueIdArray.create()
		argIds.push(receiverId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: helperName, argIds: argIds)))
		self.setValueType(resultId, t: MaxonType.function(enumType.functionBackingTypeId))
		// Env = 0 (free function ABI): the helper returns a thunk scheduled
		// via `scheduleFnRefThunk`, and those thunks discard env. Materialize
		// a real `const 0` op for the env binding — a literal `0 as ValueId`
		// is a dangling sentinel in any function whose ValueId 0 has no
		// defining op (caller paramCount > 0, no synth-anchored slot 0).
		let envZeroId = self.emitConstI64(0, dstBlock: dstBlock)
		self.fnEnvVarNames.upsert(resultId, value: envZeroId)
	end 'lowerFunctionBackedEnumRawValue'

	// One helper per fn-backed enum, mirroring synthesizeEnumNameHelpers but
	// emitting `funcRef(thunk_for_case_function)` per case instead of a
	// String literal. The dispatch shape is the same cmp/condBr chain.
	function synthesizeEnumFnRawHelpers()
		for enumName in self.pendingEnumFnRawHelpers 'eachEnum'
			let enumType = try self.project.enumTypes.get(enumName) otherwise panic("synthesizeEnumFnRawHelpers: enumTypes lookup failed for registered enum '{enumName}'")
			self.synthesizeOneEnumFnRawHelper(enumType)
		end 'eachEnum'
	end 'synthesizeEnumFnRawHelpers'

	function synthesizeOneEnumFnRawHelper(enumType EnumType)
		let helperName = enumFnRawHelperSymbol(enumType.name)
		let returnType = StdReturnType.value(StdType.i64)
		var paramTypes = StdTypeArray.create()
		paramTypes.push(StdType.i64)
		var func = IrFunction.createFromStd(helperName, returnType: returnType, paramCount: 1, paramTypes: paramTypes, returnLine: 0)
		let snapshot = self.beginSynthesizedFunc(1)

		var entryBlock = self.stdModule.addBlock(func, label: "entry")
		self.stdModule.appendOp(entryBlock, op: StdOp.call(StdCallOp.param(0 as ValueId, paramIndex: 0, paramType: StdType.i64)))
		self.setValueType(0 as ValueId, t: MaxonType.integer)

		let caseCount = enumType.cases.count()
		var currentEntry = entryBlock
		for i in 0 upto caseCount 'eachCase'
			let c = try enumType.cases.get(i) otherwise panic("synthesizeOneEnumFnRawHelper: cases.get OOB at {i}")
			var caseBlock = self.stdModule.addBlock(func, label: "fnraw_case_{i}")
			let isLast = i == caseCount - 1
			if isLast 'noMoreCmps'
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.br(caseBlock.id, argIds: ValueIdArray.create())))
			end 'noMoreCmps' else 'emitCmp'
				let caseLitId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(currentEntry, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: caseLitId, value: c.rawValue))))
				let cmpId = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Eq, leftId: 0 as ValueId, rightId: caseLitId, dstBlock: currentEntry)
				let nextEntry = self.stdModule.addBlock(func, label: "fnraw_check_{i + 1}")
				self.stdModule.setTerminator(currentEntry, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: caseBlock.id, thenArgIds: ValueIdArray.create(), elseTarget: nextEntry.id, elseArgIds: ValueIdArray.create())))
				currentEntry = nextEntry
			end 'emitCmp'
			// Per-case block: emit funcRef to the case's function (via the
			// env-aware thunk, same as a user-written bare function reference)
			// and return its i64 address. Use defineName + resolveName so the
			// regalloc tracks the result via the same nameToId table that user
			// functionRef ops use (a raw allocValueId works for the simple
			// inline case but trips SSA-coloring for the non-inlined helper).
			let refName = "__fnraw_ref_{i}".toByteArray()
			self.lowerFunctionRef(refName, funcName: c.rawFunctionName, dstBlock: caseBlock)
			let refId = self.resolveName(refName)
			self.stdModule.setTerminator(caseBlock, op: StdOp.call(StdCallOp.ret(refId)))
		end 'eachCase'

		self.endSynthesizedFunc(func, snapshot: snapshot)
	end 'synthesizeOneEnumFnRawHelper'

	function lowerFieldStore(receiver ByteArray, fieldName ByteArray, value ByteArray, isInit bool, range SourceRange, dstBlock IrBlock)
		let receiverId = self.resolveName(receiver)
		let receiverType = self.getValueType(receiverId)
		let fieldNameStr = String.from(fieldName)
		let hit = try self.lookupFieldByReceiver(receiverType, fieldName: fieldNameStr) otherwise 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown field '{fieldNameStr}' on type '{receiverType.toString(self.project)}' in func '{self.currentFuncName}'")
			return
		end 'notFound'
		// `let` fields are immutable post-construction, but writable when the
		// store is an in-literal initializer; the parser tags those stores with
		// `isInit: true` (struct literals + factory writeback paths).
		if not isInit and not hit.isMutable 'immutableField'
			let path = try FilePath.from(self.currentFilePath) otherwise FilePath from ""
			reportCompileError(self.project, code: ErrorCode.parserImmutableVariable, message: "cannot assign to field '{hit.structName}.{fieldNameStr}' because it is immutable (declare with 'var' to make it mutable)", line: range.line, column: range.column, filePath: path)
			return
		end 'immutableField'
		// Phase 15e: mirror the substitution lowerFieldLoad does — a tuple
		// receiver's raw field type is `_TN` (typeParameter), but the
		// fieldStore needs the substituted concrete type so float values flow
		// through the SSE-register store path instead of getting reinterpreted
		// as i64 in a general-purpose register. Restricted to tuple receivers
		// because for other generic types the substitution may collapse
		// typeParameter to MaxonType.unresolved on a missed binding.
		let resolvedFieldType = pickTupleFieldType(self.project, raw: hit.fieldType, receiverType: receiverType)
		// Interface-typed fields are 16-byte fat pointers (data + witness).
		// Emit the data half at the field's offset and the witness half at
		// `offset + 8`. layoutAllStructs reserved the trailing 8 bytes so
		// the witness store doesn't trample the next field.
		if interfaceTypeIsFat(resolvedFieldType) 'fat'
			self.lowerInterfaceFieldStore(receiverId, offset: hit.offset, value: value, fieldType: resolvedFieldType, dstBlock: dstBlock)
			return
		end 'fat'
		let fieldStdType = maxonTypeToStdType(self.project, ref: resolvedFieldType)
		let fieldWidth = storeWidthOfStdType(fieldStdType)
		let isFloat = stdTypeIsFloat(fieldStdType)
		// Phase A widening: when the value's recorded MaxonType is an int
		// and the field's type is float, splice in an siToFp before the
		// storeIndirect so the float field receives an IEEE-754 bit pattern
		// rather than an integer bit pattern reinterpreted as float. Mirror
		// of the C# bootstrap's struct-field-store auto-widening.
		let storedValueId = self.resolveName(value)
		let storedValueType = self.getValueType(storedValueId)
		let widenedValueId = self.widenValueToType(storedValueId, fromType: storedValueType, toType: resolvedFieldType, dstBlock: dstBlock)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(receiverId, offset: hit.offset, valueId: widenedValueId, width: fieldWidth, isFloat: isFloat)))
	end 'lowerFieldStore'

	// Emit a fat-pointer store into an interface-typed struct field. The
	// data half goes at `offset`, the witness half at `offset + 8`. When
	// the source value is itself interface-typed (forwarding an existing
	// fat pointer), reuse its data ValueId as the data half and recover
	// its paired witness from `interfaceWitnessValueIds`. When the source
	// is concrete, materialize both halves via the same helpers the
	// slot-store path uses so primitives/large payloads route through the
	// box-or-inline rule and the witness comes from the witness-table
	// registry.
	function lowerInterfaceFieldStore(receiverId ValueId, offset FieldOffset, value ByteArray, fieldType MaxonType, dstBlock IrBlock)
		let interfaceName = match fieldType 'iface'
			interface(id) gives self.project.interfaceRegistry.getName(id)
			default panic("lowerInterfaceFieldStore: fieldType is not interface despite the dispatch guard")
		end 'iface'
		let valueId = self.resolveName(value)
		let concreteType = self.getValueType(valueId)
		var payloadId = valueId
		var witnessId = 0 as ValueId
		if interfaceTypeIsFat(concreteType) 'forward'
			witnessId = try self.interfaceWitnessValueIds.get(valueId) otherwise panic("lowerInterfaceFieldStore: source valueId={valueId} typed as interface but no witness paired in interfaceWitnessValueIds")
		end 'forward' else 'concrete'
			payloadId = self.materializeInterfacePayload(valueId, concreteType: concreteType, dstBlock: dstBlock)
			witnessId = self.materializeInterfaceWitness(concreteType, interfaceName: interfaceName, dstBlock: dstBlock)
		end 'concrete'
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(receiverId, offset: offset, valueId: payloadId, width: StoreWidth.qword, isFloat: false)))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(receiverId, offset: (offset + 8) as FieldOffset, valueId: witnessId, width: StoreWidth.qword, isFloat: false)))
	end 'lowerInterfaceFieldStore'

	// selfFieldLoad/selfFieldStore: synthesize a fieldLoad/Store against the
	// __self parameter. The struct type comes from `currentTypeName` which we
	// recovered from func.name at function entry. We materialize __self via
	// a `loadSlot` op (slot 0 by Std-ABI convention) so the register
	// allocator sees a normal SSA value-def rather than a bare param-id.
	function lowerSelfFieldLoad(result ByteArray, fieldName ByteArray, dstBlock IrBlock)
		let resultId = self.defineName(result)
		if self.currentTypeName.isEmpty() 'notInType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: selfFieldLoad in free function (parser bug)")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notInType'
		let fieldNameStr = String.from(fieldName)
		let hit = try self.lookupFieldByStructName(self.currentTypeName, fieldName: fieldNameStr) otherwise 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown self-field '{fieldNameStr}' on type '{self.currentTypeName}'")
			self.setValueType(resultId, t: MaxonType.integer)
			return
		end 'notFound'
		let selfId = self.loadSelfPointer(dstBlock)
		let fieldStdType = maxonTypeToStdType(self.project, ref: hit.fieldType)
		let fieldWidth = storeWidthOfStdType(fieldStdType)
		let fieldSigned = stdTypeIsSigned(fieldStdType)
		let isFloat = stdTypeIsFloat(fieldStdType)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: selfId, offset: hit.offset, width: fieldWidth, signed: fieldSigned, isFloat: isFloat)))
		self.setValueType(resultId, t: hit.fieldType)
	end 'lowerSelfFieldLoad'

	function lowerSelfFieldStore(fieldName ByteArray, value ByteArray, dstBlock IrBlock)
		if self.currentTypeName.isEmpty() 'notInType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: selfFieldStore in free function (parser bug)")
			return
		end 'notInType'
		let fieldNameStr = String.from(fieldName)
		let hit = try self.lookupFieldByStructName(self.currentTypeName, fieldName: fieldNameStr) otherwise 'notFound'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown self-field '{fieldNameStr}' on type '{self.currentTypeName}'")
			return
		end 'notFound'
		let selfId = self.loadSelfPointer(dstBlock)
		let fieldStdType = maxonTypeToStdType(self.project, ref: hit.fieldType)
		let fieldWidth = storeWidthOfStdType(fieldStdType)
		let isFloat = stdTypeIsFloat(fieldStdType)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(selfId, offset: hit.offset, valueId: self.resolveName(value), width: fieldWidth, isFloat: isFloat)))
	end 'lowerSelfFieldStore'

	// Materialize the __self parameter into a fresh SSA ValueId via a slot
	// load. Used by selfFieldLoad/selfFieldStore — the parser-side
	// declaration `__self` lives in slot 0 of every instance method by Std
	// ABI convention (`__self` is always the first parameter). We can't pass
	// the bare param id (0) into addr operands because subsequent passes
	// (register allocator) only see SSA-style use-def chains and panic on
	// references to undefined virtual values.
	function loadSelfPointer(dstBlock IrBlock) returns ValueId
		let selfId = allocValueId(self.funcIdRef)
		let selfSlot = 0 as VarSlot
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(selfId, slotId: selfSlot)))
		self.setValueType(selfId, t: MaxonType.named(self.project.typeNames.intern(self.currentTypeName)))
		return selfId
	end 'loadSelfPointer'

	// Resolve (receiver-MaxonType, fieldName) by walking the project's
	// struct-type registry. Throws `FieldLookupError.notFound` when the
	// receiver isn't a registered struct (or its named-id resolves to
	// something non-struct), or when the struct has no such field; callers
	// catch the throw and emit a clean diagnostic.
	function lookupFieldByReceiver(receiverType MaxonType, fieldName String) returns FieldHit throws FieldLookupError
		let structName = try maxonTypeStructName(self.project, t: receiverType) otherwise throw FieldLookupError.notFound
		return try self.lookupFieldByStructName(structName, fieldName: fieldName)
	end 'lookupFieldByReceiver'

	function lookupFieldByStructName(structName String, fieldName String) returns FieldHit throws FieldLookupError
		let structType = try self.project.structTypes.get(structName) otherwise throw FieldLookupError.notFound
		let fieldIdx = try structType.fieldByName.get(fieldName) otherwise throw FieldLookupError.notFound
		let field = try structType.fields.get(fieldIdx) otherwise panic("StructType.fieldByName references missing field index {fieldIdx} on '{structName}' (count={structType.fields.count()})")
		// Guard against any path that constructs a StructField but bypasses
		// `layoutAllStructs`. `FieldOffset = 0` is also the offset of the
		// leading field on every struct, so an unresolved sentinel is the
		// only way to detect a missed-stamp bug before it silently corrupts
		// loads/stores by aliasing every field at offset 0.
		if not field.offsetResolved 'unresolved'
			panic("lowerMaxonToStd: field '{fieldName}' on struct '{structName}' has unresolved offset — layoutAllStructs pass did not run")
		end 'unresolved'
		return FieldHit.create(field.offset, fieldType: field.fieldType, isMutable: field.isMutable, structName: structName)
	end 'lookupFieldByStructName'

	// The parser only ever produces condBr/br/ret/enumMatchArm as block
	// terminators (plus `error` as a no-op anchor). Anything else appearing
	// here indicates a parser bug.
	function lowerTerminator(hlOp MaxonOp, dstBlock IrBlock)
		match hlOp 'lower'
			condBr(cond, thenTarget, elseTarget, _) then self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(self.resolveName(cond), thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
			br(target, _) then self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.br(target, argIds: ValueIdArray.create())))
			ret(retVal, _) then self.lowerRet(retVal, dstBlock: dstBlock)
			enumMatchArm(scrutineeName, caseName, scrutineeType, rawValue, isFloat, resolved, thenTarget, elseTarget, _, _) then self.lowerEnumMatchArm(scrutineeName, caseName: caseName, scrutineeType: scrutineeType, rawValue: rawValue, isFloat: isFloat, resolved: resolved, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock)
			rangeMatchArm(scrutineeName, loValue, hiValue, isUpto, hasMinSentinel, hasMaxSentinel, enumOwnerName, thenTarget, elseTarget, _) then self.lowerRangeMatchArm(scrutineeName, loValue: loValue, hiValue: hiValue, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: hasMaxSentinel, enumOwnerName: enumOwnerName, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock)
			// An error op as a block terminator shouldn't come from the parser —
			// errors replace single statements, not block-terminating constructs.
			// If it ever does we drop it: a diagnostic was already reported at
			// the error op's range.
			error then return
			// Phase 6: `throw E.v` lowers to a single `errorReturn(zero, flag)`
			// terminator — the multi-value-return ABI puts the primary value
			// in R8/X0 and the error flag (`ordinal+1`, 0 reserved for "no
			// error") in RDX/X1. The caller's `try` reads the flag from the
			// post-call mov.
			throw (enumName, variantName, payloadValueName, _) then self.lowerThrow(enumName, variantName: variantName, payloadValueName: payloadValueName, dstBlock: dstBlock)
			rethrow(flagName, _) then self.lowerRethrow(flagName, dstBlock: dstBlock)
			default panic("lowerMaxonTerminatorToStd: non-terminator op kind '{hlOp.name}' as terminator of block '{dstBlock.label}' (parser bug)")
		end 'lower'
	end 'lowerTerminator'

	// Lower a resolved `enumMatchArm` terminator to the equivalent
	// `const + cmp_eq + cond_br` Std op sequence. The const + cmp pair go
	// into the dstBlock as regular ops; the cond_br is set as the
	// terminator. TypeResolution must have resolved the case name before
	// lowering — an unresolved op is a TR bug.
	//
	// Phase 9 Stage 3: when the scrutineeType is a union (heap-boxed value
	// with an i64 tag at offset 0), we compare against the tag rather than
	// the heap-pointer itself, and emit `enumPayloadRead`-equivalent loads
	// at the head of the thenTarget block for any non-discard binding
	// names. Bare enum scrutinees (where the parser passed empty
	// bindingNames) take the original direct-cmp path unchanged.
	function lowerEnumMatchArm(scrutineeName ByteArray, caseName String, scrutineeType MaxonType, rawValue IntConstant, isFloat bool, resolved bool, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock)
		if not resolved 'unresolved'
			panic("lowerMaxonToStd: enumMatchArm '.{caseName}' survived past TypeResolution unresolved")
		end 'unresolved'
		// Stage 3 keeps `bindingNames` on the dialect for parity with the
		// match-arm parser/TR contract, but lowering reads payloads via the
		// dedicated `enumPayloadRead` ops the parser now emits at the head
		// of the arm body — see `emitUnionArmBindings`. The field is kept
		// for forward compatibility (Stage 4 write-back may consult it).
		let unionType = self.unionTypeForScrutinee(scrutineeType)
		var caseLiteralType = MaxonType.integer
		var constOpcode = StdArithConstOpcode.constI64
		if isFloat 'asFloat'
			caseLiteralType = MaxonType.float
			constOpcode = StdArithConstOpcode.constF64
		end 'asFloat'
		// For union scrutinees, the comparison subject is the heap-boxed
		// value's tag (loaded via loadIndirect at offset 0). Float-backed
		// unions don't exist — payload-bearing unions are int-tagged.
		var leftId = self.resolveName(scrutineeName)
		if unionType.hasType 'loadTag'
			leftId = self.emitLoadFieldI64(leftId, offset: 0, dstBlock: dstBlock)
		end 'loadTag'
		let caseLitId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(constOpcode, resultId: caseLitId, value: rawValue))))
		self.setIsFloat(caseLitId, isFloat: isFloat)
		var rightId = caseLitId
		if isFloat 'promoteForFloatCmp'
			leftId = self.promoteToFloat(leftId, dstBlock: dstBlock)
			rightId = self.promoteToFloat(rightId, dstBlock: dstBlock)
		end 'promoteForFloatCmp'
		let cmpOpcode = cmpPredicateToArithOpcode(self.project, predicate: CmpPredicate.eq, operandType: caseLiteralType)
		let cmpId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(cmpOpcode, resultId: cmpId, leftId: leftId, rightId: rightId))))
		self.setIsFloat(cmpId, isFloat: false)
		self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(cmpId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
	end 'lowerEnumMatchArm'

	// Phase 9 Stage 3: detect union scrutinee. Returns the resolved
	// `EnumType` so the binding-emission path can index its payloadFields.
	// Plain enums (int/float-backed, no payloads on any case) and non-enum
	// scrutinees return a no-hit so the bare-cmp lowering path stays
	// unchanged.
	function unionTypeForScrutinee(scrutineeType MaxonType) returns UnionTypeLookup
		let nameStr = scrutineeType.nameOrEmpty(self.project)
		if nameStr.isEmpty() 'notNamed'
			return UnionTypeLookup.miss()
		end 'notNamed'
		let resolved = try self.project.enumTypes.get(nameStr) otherwise return UnionTypeLookup.miss()
		if not resolved.isUnion 'notUnion'
			return UnionTypeLookup.miss()
		end 'notUnion'
		return UnionTypeLookup.hit(resolved)
	end 'unionTypeForScrutinee'

	// Phase 9 Stage 3: lower `MaxonOp.enumConstruct(result, EnumName, caseName,
	// payloadValues)` to the heap-boxed layout the bootstrap uses:
	// `__mm_alloc(size, destructor=null, tag=ordinal)` followed by a
	// `storeIndirect` for the tag word at offset 0 and one `storeIndirect`
	// per payload field at offset 8 + i*8. Managed-pointer payloads
	// (struct/string/array/other-union) get an `__mm_incref` so the union
	// owns its own reference. The destructor pointer is null in Stage 3
	// — leaks of payload-bearing unions are the expected signal that
	// Stage 4's destructor synthesis still needs to land.
	function lowerEnumConstruct(result ByteArray, enumName String, caseName String, payloadValues ByteArrayArray, dstBlock IrBlock)
		let unionType = try self.project.enumTypes.get(enumName) otherwise 'unknownUnion'
			self.reportLowerError(ErrorCode.semanticTypeMismatch, message: "lowerEnumConstruct: unknown union type '{enumName}'")
			self.definePlaceholderInt(result)
			return
		end 'unknownUnion'
		let caseIdx = try unionType.caseByName.get(caseName) otherwise 'unknownCase'
			self.reportLowerError(ErrorCode.semanticEnumUnknownCase, message: "lowerEnumConstruct: unknown case '{enumName}.{caseName}'")
			self.definePlaceholderInt(result)
			return
		end 'unknownCase'
		let theCase = try unionType.cases.get(caseIdx) otherwise panic("lowerEnumConstruct: cases.get OOB at {caseIdx} for '{enumName}'")
		if payloadValues.count() != theCase.payloadFields.count() 'arityMismatch'
			self.reportLowerError(ErrorCode.semanticWrongArgCount, message: "lowerEnumConstruct: '{enumName}.{caseName}' expects {theCase.payloadFields.count()} payload(s), got {payloadValues.count()}")
			self.definePlaceholderInt(result)
			return
		end 'arityMismatch'
		let maxArity = unionMaxPayloadArity(unionType)
		let allocBytes = 8 + maxArity * 8
		let sizeId = self.emitConstI64(allocBytes as ParsedInt, dstBlock: dstBlock)
		self.setValueType(sizeId, t: MaxonType.integer)
		// Phase 9 Stage 4: pass `funcRef("__destruct_<UnionName>")` so that
		// `mm_free` (invoked when refcount drops to zero) indirect-calls the
		// per-union destructor, which `mm_decref`s each managed payload field
		// of the live case. Unions whose payloads are all scalar (or which
		// have no payload cases at all) keep the null destructor — the slab
		// path frees the box and there's nothing managed to release. The
		// helper symbol matches what `synthesizeUnionDestructors` will emit
		// at the tail of this pass; `synthesizeUnionDestructors` skips
		// scalar-only unions, so emitting `funcRef` here for those would
		// dangle. Predicate must agree with the synthesizer on the same
		// invariant — both consult `unionHasManagedPayload`.
		var dtorId = self.emitConstI64(0, dstBlock: dstBlock)
		if unionHasManagedPayload(self.project, unionType: unionType) 'hasManaged'
			let dtorRefId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.funcRef(dtorRefId, funcName: unionDestructorSymbol(unionType.name))))
			dtorId = dtorRefId
		end 'hasManaged'
		self.setValueType(dtorId, t: MaxonType.integer)
		let tagOrdinalId = self.emitConstI64(theCase.ordinal as ParsedInt, dstBlock: dstBlock)
		self.setValueType(tagOrdinalId, t: MaxonType.integer)
		var allocArgIds = ValueIdArray.create()
		allocArgIds.push(sizeId)
		allocArgIds.push(dtorId)
		allocArgIds.push(tagOrdinalId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "stdlib.__mm_alloc", argIds: allocArgIds)))
		self.setValueType(resultId, t: MaxonType.named(self.project.typeNames.intern(unionType.name)))
		// `__mm_alloc`'s `tag` parameter is a placeholder slot in the
		// current runtime (see stdlib/Internals.maxon) — it does NOT
		// populate the user region. Storing the tag explicitly here is
		// what the match-side `enumTag` load reads back.
		self.emitStoreFieldI64(resultId, offset: 0, valueId: tagOrdinalId, dstBlock: dstBlock)
		for i in 0 upto theCase.payloadFields.count() 'eachField'
			let field = try theCase.payloadFields.get(i) otherwise panic("lowerEnumConstruct: payloadFields.get OOB at {i}")
			let payloadValueName = try payloadValues.get(i) otherwise panic("lowerEnumConstruct: payloadValues.get OOB at {i}")
			let payloadValueId = self.resolveName(payloadValueName)
			let offset = 8 + i * 8
			let stdType = maxonTypeToStdType(self.project, ref: field.fieldType)
			if stdTypeIsFloat(stdType) 'asFloat'
				// Stage 3 supports int + managed-pointer payloads. Float
				// payloads need a `bitcastF64ToI64` for the store and a
				// matching `bitcastI64ToF64` for the read — the latter
				// opcode doesn't exist in StdArithUnaryOpcode yet. Surface
				// the gap explicitly rather than emit a half-correct store.
				panic("lowerEnumConstruct: float-typed union payload field is not supported yet ('{unionType.name}.{theCase.name}.{field.name}' : {field.fieldType.toString(self.project)})")
			end 'asFloat'
			self.emitStoreFieldI64(resultId, offset: offset, valueId: payloadValueId, dstBlock: dstBlock)
			if maxonTypeIsManagedRef(self.project, t: field.fieldType) 'managedBump'
				var argIds = ValueIdArray.create()
				argIds.push(payloadValueId)
				let increfResultId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(increfResultId, callee: "stdlib.__mm_incref", argIds: argIds)))
				self.setValueType(increfResultId, t: MaxonType.integer)
			end 'managedBump'
		end 'eachField'
		// Zero-fill unused slots so destructor enumeration (Stage 4) and
		// any debugging dump see a deterministic 0 rather than residual
		// stack/heap garbage.
		for j in theCase.payloadFields.count() upto maxArity 'zeroPad'
			let zeroId = self.emitConstI64(0, dstBlock: dstBlock)
			self.emitStoreFieldI64(resultId, offset: 8 + j * 8, valueId: zeroId, dstBlock: dstBlock)
		end 'zeroPad'
	end 'lowerEnumConstruct'

	// Phase 9 Stage 3: lower `MaxonOp.enumTag(result, enumValName)` to a
	// single `loadIndirect i64 [enumValName + 0]`. The match-side tag
	// dispatch path uses `lowerEnumMatchArm`'s inline load — this op is
	// only emitted explicitly when user code asks for the raw tag (no
	// current source-level surface). Kept for parity with the dialect.
	function lowerEnumTag(result ByteArray, enumValName ByteArray, dstBlock IrBlock)
		let enumValId = self.resolveName(enumValName)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: enumValId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: MaxonType.integer)
	end 'lowerEnumTag'

	// Phase 9 Stage 3: lower `MaxonOp.enumPayloadRead(result, enumValName,
	// fieldIndex, fieldType)` to `loadIndirect <fieldType>
	// [enumValName + 8 + fieldIndex*8]`. Managed-pointer fields
	// (struct/string/array/union) bump the refcount so the binding owns
	// its own reference; the matching decref will be inserted by Stage 4's
	// extension to the drop pipeline. Float-typed payloads are deferred
	// until a `bitcastI64ToF64` arith op exists.
	function lowerEnumPayloadRead(result ByteArray, enumValName ByteArray, fieldIndex IntConstant, fieldType MaxonType, dstBlock IrBlock)
		let stdType = maxonTypeToStdType(self.project, ref: fieldType)
		if stdTypeIsFloat(stdType) 'asFloat'
			panic("lowerEnumPayloadRead: float-typed payload is not supported yet (need StdArithUnaryOpcode.bitcastI64ToF64). Field type: {fieldType.toString(self.project)}")
		end 'asFloat'
		let enumValId = self.resolveName(enumValName)
		let resultId = self.defineName(result)
		let offset = 8 + fieldIndex * 8
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: enumValId, offset: offset, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(resultId, t: fieldType)
		if maxonTypeIsManagedRef(self.project, t: fieldType) 'managedBump'
			var argIds = ValueIdArray.create()
			argIds.push(resultId)
			let increfResultId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(increfResultId, callee: "stdlib.__mm_incref", argIds: argIds)))
			self.setValueType(increfResultId, t: MaxonType.integer)
		end 'managedBump'
	end 'lowerEnumPayloadRead'

	// Phase 9 Stage 4: lower `MaxonOp.enumPayloadStore(enumValName,
	// fieldIndex, fieldType, newValueName)` — the match-arm write-back op
	// emitted when a binding like `value = 42` is assigned inside an arm
	// body on a `var` union scrutinee.
	//
	// For scalar payloads (int, bool, char, byte etc.), the store collapses
	// to a single `storeIndirect [scrutinee + 8 + fieldIndex*8] = newValue`.
	//
	// For managed-pointer payloads (struct / String / Array / another union),
	// the slot already holds a refcounted reference. Overwriting requires:
	//   1. load the old payload ptr
	//   2. mm_incref the new value (the slot now owns one reference to it)
	//   3. storeIndirect the new value into the slot
	//   4. mm_decref the old value (after the new value is safely stored,
	//      so a self-assign `value = value` doesn't free the still-live
	//      target between decref and store).
	// This mirrors how struct-field stores handle managed fields and how
	// `lowerEnumConstruct` bumps refcounts on each managed payload at
	// construction time.
	//
	// Float payloads are not yet supported (Stage 3 also defers them) —
	// surfacing the gap loudly keeps the unsupported edge visible.
	function lowerEnumPayloadStore(enumValName ByteArray, fieldIndex IntConstant, fieldType MaxonType, newValueName ByteArray, dstBlock IrBlock)
		let stdType = maxonTypeToStdType(self.project, ref: fieldType)
		if stdTypeIsFloat(stdType) 'asFloat'
			panic("lowerEnumPayloadStore: float-typed payload is not supported yet (need StdArithUnaryOpcode.bitcastF64ToI64). Field type: {fieldType.toString(self.project)}")
		end 'asFloat'
		let enumValId = self.resolveName(enumValName)
		let newValueId = self.resolveName(newValueName)
		let offset = 8 + fieldIndex * 8
		if maxonTypeIsManagedRef(self.project, t: fieldType) 'managedReplace'
			// Pre-load old value before the store, then incref new and
			// decref old AFTER the store — keeps `value = value` (which
			// resolves the same SSA on both sides) from briefly observing
			// refcount zero on the live target.
			let oldValueId = self.emitLoadFieldI64(enumValId, offset: offset, dstBlock: dstBlock)
			var increfArgs = ValueIdArray.create()
			increfArgs.push(newValueId)
			let increfRetId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(increfRetId, callee: "stdlib.__mm_incref", argIds: increfArgs)))
			self.setValueType(increfRetId, t: MaxonType.integer)
			self.emitStoreFieldI64(enumValId, offset: offset, valueId: newValueId, dstBlock: dstBlock)
			var decrefArgs = ValueIdArray.create()
			decrefArgs.push(oldValueId)
			let decrefRetId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(decrefRetId, callee: "stdlib.__mm_decref", argIds: decrefArgs)))
			self.setValueType(decrefRetId, t: MaxonType.integer)
		end 'managedReplace' else 'scalarReplace'
			self.emitStoreFieldI64(enumValId, offset: offset, valueId: newValueId, dstBlock: dstBlock)
		end 'scalarReplace'
	end 'lowerEnumPayloadStore'

	// Phase 9 Stage 0: lower a range match-arm terminator. Emits up to two
	// comparison ops (lower-bound + upper-bound), AND-combines them when
	// both bounds are present, and terminates the block with a cond_br
	// to thenTarget/elseTarget. Sentinel bounds (`min`/`max`) drop the
	// corresponding comparison. The parser rejects the impossible
	// "min ... max" form at parse time so we never reach the
	// degenerate "always true" case here.
	function lowerRangeMatchArm(scrutineeName ByteArray, loValue ParsedInt, hiValue ParsedInt, isUpto bool, hasMinSentinel bool, hasMaxSentinel bool, enumOwnerName String, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock)
		var scrutineeId = self.resolveName(scrutineeName)
		// Float-backed enum range arm: parser stored case ordinals as the
		// bounds, but the scrutinee is the f64 raw value. Range semantics
		// are ordinal-based, so an i64 ge/le directly against the f64
		// scrutinee would (a) fail wasm type-validation and (b) mean
		// raw-value comparison rather than ordinal-range coverage. Emit a
		// disjunction of f64-eq checks against each in-range case's raw
		// f64 instead — independent of raw-value monotonicity.
		if not enumOwnerName.isEmpty() 'isEnumRange'
			if let enumType = try self.project.enumTypes.get(enumOwnerName) 'isResolvedEnum'
				if enumType.isFloatBacked 'isFloatBacked'
					self.lowerFloatBackedEnumRangeArm(scrutineeId, enumType: enumType, loOrdinal: loValue, hiOrdinal: hiValue, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: hasMaxSentinel, thenTarget: thenTarget, elseTarget: elseTarget, dstBlock: dstBlock)
					return
				end 'isFloatBacked'
				// Union scrutinee: the SSA value is a heap pointer; the tag
				// sits at offset 0 in the boxed layout. Load the tag before
				// the i64 ge/le compares — without this, the range checks
				// the pointer address against the case-ordinal bounds and
				// every match either always-fires or never-fires depending
				// on the heap address. Mirrors `lowerEnumMatchArm`'s
				// `unionTypeForScrutinee` tag-load.
				if enumType.isUnion 'isUnion'
					scrutineeId = self.emitLoadFieldI64(scrutineeId, offset: 0, dstBlock: dstBlock)
				end 'isUnion'
			end 'isResolvedEnum'
		end 'isEnumRange'
		var combinedId = 0 as ValueId
		var hasCombined = false
		if not hasMinSentinel 'emitLow'
			let loId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: loId, value: loValue))))
			let loCmpId = self.emitBinaryI64(StdArithBinaryOpcode.cmpI64Ge, leftId: scrutineeId, rightId: loId, dstBlock: dstBlock)
			combinedId = loCmpId
			hasCombined = true
		end 'emitLow'
		if not hasMaxSentinel 'emitHigh'
			let hiId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: hiId, value: hiValue))))
			let hiOpcode = StdArithBinaryOpcode.cmpI64Lt if isUpto else StdArithBinaryOpcode.cmpI64Le
			let hiCmpId = self.emitBinaryI64(hiOpcode, leftId: scrutineeId, rightId: hiId, dstBlock: dstBlock)
			if hasCombined 'foldBoth'
				combinedId = self.emitBinaryI64(StdArithBinaryOpcode.andI64, leftId: combinedId, rightId: hiCmpId, dstBlock: dstBlock)
			end 'foldBoth' else 'highOnly'
				combinedId = hiCmpId
				hasCombined = true
			end 'highOnly'
		end 'emitHigh'
		if not hasCombined 'noBounds'
			panic("lowerRangeMatchArm: both sentinels set — parser should have rejected this")
		end 'noBounds'
		self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(combinedId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
	end 'lowerRangeMatchArm'

	// Float-backed enum range arm: emit `(s == raw[lo]) | (s == raw[lo+1]) |
	// ... | (s == raw[hi])` where `s` is the f64 scrutinee and `raw[i]` is
	// the i-th case's raw value. `hi` is exclusive when `isUpto`. `min`/`max`
	// sentinels expand to ordinal 0 / lastOrdinal respectively. Avoids any
	// reliance on raw-value monotonicity — ordinal-range coverage is
	// strictly by declared case order.
	function lowerFloatBackedEnumRangeArm(scrutineeId ValueId, enumType EnumType, loOrdinal ParsedInt, hiOrdinal ParsedInt, isUpto bool, hasMinSentinel bool, hasMaxSentinel bool, thenTarget BlockId, elseTarget BlockId, dstBlock IrBlock)
		let caseCount = enumType.cases.count()
		let loBound = 0 as ParsedInt if hasMinSentinel else loOrdinal
		var hiBound = (caseCount - 1) as ParsedInt if hasMaxSentinel else hiOrdinal
		if isUpto and not hasMaxSentinel 'uptoAdjust'
			hiBound = (hiBound - 1) as ParsedInt
		end 'uptoAdjust'
		var combinedId = 0 as ValueId
		var hasCombined = false
		var ord = loBound
		while ord <= hiBound 'eachOrdinal'
			let caseRec = try enumType.cases.get(ord) otherwise panic("lowerFloatBackedEnumRangeArm: case ordinal {ord} OOB for enum '{enumType.name}'")
			let caseRawId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constF64, resultId: caseRawId, value: caseRec.rawValue))))
			self.setIsFloat(caseRawId, isFloat: true)
			let eqId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.binary(StdArithBinaryOp.create(StdArithBinaryOpcode.cmpF64Eq, resultId: eqId, leftId: scrutineeId, rightId: caseRawId))))
			self.setIsFloat(eqId, isFloat: false)
			if hasCombined 'foldOr'
				combinedId = self.emitBinaryI64(StdArithBinaryOpcode.orI64, leftId: combinedId, rightId: eqId, dstBlock: dstBlock)
			end 'foldOr' else 'firstEq'
				combinedId = eqId
				hasCombined = true
			end 'firstEq'
			ord = ord + 1
		end 'eachOrdinal'
		if not hasCombined 'emptyRange'
			panic("lowerFloatBackedEnumRangeArm: empty ordinal range [{loBound}, {hiBound}] for enum '{enumType.name}' (parser should have rejected single-value / inverted ranges earlier)")
		end 'emptyRange'
		self.stdModule.setTerminator(dstBlock, op: StdOp.control(StdControlOp.condBr(combinedId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create())))
	end 'lowerFloatBackedEnumRangeArm'

	// Stage E (closures): emit a function-pointer-of-named-function op.
	// Records (refId → 0) in `fnEnvVarNames` so a downstream `indirectCall`
	// through this value passes a 0 env-pointer, matching the paired-
	// pointer ABI shape that lifted closures and user free functions both
	// satisfy.
	//
	// Free-function refs (everything that is NOT a lifted closure body) get
	// routed through a synthesized thunk `__fnref_<funcName>` whose
	// signature includes the trailing `__env i64` param the indirect-call
	// ABI requires. The thunk body discards env and tail-calls the original
	// function. Without this, wasm's `call_indirect` traps with "indirect
	// call type mismatch" because the table element's wasm functype
	// (`(args) -> R`) doesn't match the call-site type (`(args, env) -> R`).
	function lowerFunctionRef(result ByteArray, funcName String, dstBlock IrBlock)
		let resultId = self.defineName(result)
		var refTarget = funcName
		if not isLiftedClosureName(funcName) 'isFreeFunc'
			refTarget = self.scheduleFnRefThunk(funcName)
		end 'isFreeFunc'
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.funcRef(resultId, funcName: refTarget)))
		// Phase 11.4 closure-inheritance: a zero-capture closure inside a
		// generic enclosing extension reaches lowering through `functionRef`
		// (the parser only emits `closureCreate` when there's at least one
		// outer-name capture). Its body still needs the enclosing's layout
		// + per-constraint witness pointers, which travel through env. We
		// allocate a small env block here with implicitCount slots and
		// store the enclosing's `implicitLayoutValueId` /
		// `implicitWitnessValueIds` into env[0..implicitCount].
		if self.liftedClosureInheritsImplicits(funcName) 'allocImplicitsEnv'
			let implicitValueIds = self.collectInheritedImplicits()
			let envBaseId = self.allocEnvAndStoreImplicits(dstBlock, captureCount: 0, implicitValueIds: implicitValueIds)
			self.fnEnvVarNames.upsert(resultId, value: envBaseId)
			return
		end 'allocImplicitsEnv'
		// Free-function refs carry env=0. Materialize a real `const 0` op
		// so the env binding has a defining SSA op — bare ValueId `0` is a
		// dangling sentinel in any function whose v0 has no local definition.
		let envZeroId = self.emitConstI64(0, dstBlock: dstBlock)
		self.fnEnvVarNames.upsert(resultId, value: envZeroId)
	end 'lowerFunctionRef'

	// Reserve (and lazily synthesize) an env-aware thunk for a free
	// function referenced via `functionRef`. The thunk wraps the target
	// in a wrapper whose signature is `(args..., __env i64) -> R`, calls
	// the target with `args` (env discarded), and returns the result.
	// Calls to this helper are idempotent: thunk synthesis runs once per
	// unique target funcName per LowerMaxonToStd run.
	function scheduleFnRefThunk(targetFunc String) returns String
		let thunkName = "__fnref_{targetFunc}"
		if self.pendingFnRefThunks.contains(thunkName) 'alreadyScheduled'
			return thunkName
		end 'alreadyScheduled'
		self.pendingFnRefThunks.insert(thunkName)
		self.pendingFnRefThunkTargets.push(targetFunc)
		return thunkName
	end 'scheduleFnRefThunk'

	// Stage E (closures): construct a closure value as a (fn-pointer, env)
	// pair. The fn-pointer side is just `funcRef`; the env side allocates
	// a fresh heap block via `mrt_alloc(N*8)` and stores the address of
	// each captured outer-scope slot at env[i]. The capture-by-reference
	// shape lets the closure body observe outer-state mutation between
	// creation and indirect call. The result name is bound to the fn-
	// pointer; the env id travels alongside via `fnEnvVarNames`.
	function lowerClosureCreate(result ByteArray, funcName String, capturedNames StringArray, dstBlock IrBlock)
		let fnRefId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.funcRef(fnRefId, funcName: funcName)))

		let captureCount = capturedNames.count()
		// Materialize each capture's source-slot address. The captured
		// name maps to a Maxon-level slot via the function's scope —
		// recovered at lowering time by walking the parser's scope. The
		// outer function's scope is preserved on the IrFunction's
		// `scope` field, but lowerClosureCreate runs in the OUTER
		// function's context (not the lifted body's), so `currentFunc`
		// here is the enclosing function whose scope we need.
		var captureAddrs = ValueIdArray.create()
		for i in 0 upto captureCount 'eachCap'
			let captureName = try capturedNames.get(i) otherwise panic("lowerClosureCreate: capturedNames.get OOB at {i}")
			let slotId = self.lookupOuterSlotForCapture(captureName)
			let addrId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.stackAddr(addrId, slotId: slotId)))
			captureAddrs.push(addrId)
		end 'eachCap'

		// Phase 11.4 closure-inheritance: when the lifted closure inherits
		// implicit args from a generic enclosing extension, the env block
		// also carries the enclosing's layout pointer + per-constraint
		// witness pointers (in that order, past the user captures). The
		// closure body recovers them at its entry block via a single
		// indirect load each — see the per-function reset in `lower()`.
		// The outer function (this call's host) reads its OWN
		// `self.implicitLayoutValueId` / `self.implicitWitnessValueIds` —
		// which `tryLowerConstrainedTypeParamDispatch` would also consume
		// — so the forwarded values match what the closure body needs.
		var implicitValueIds = ValueIdArray.create()
		if self.liftedClosureInheritsImplicits(funcName) 'collectImplicits'
			implicitValueIds = self.collectInheritedImplicits()
		end 'collectImplicits'

		let envBaseId = self.allocEnvAndStoreImplicits(dstBlock, captureCount: captureCount, implicitValueIds: implicitValueIds)

		// Store each capture address into env[i*8].
		for i in 0 upto captureCount 'eachStore'
			let addrId = try captureAddrs.get(i) otherwise panic("lowerClosureCreate: captureAddrs.get OOB at {i}")
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(envBaseId, offset: i * 8, valueId: addrId, width: StoreWidth.qword, isFloat: false)))
		end 'eachStore'

		self.fnEnvVarNames.upsert(fnRefId, value: envBaseId)
	end 'lowerClosureCreate'

	// Phase 11.4 closure-inheritance: snapshot the outer function's
	// implicit layout/witness ValueIds into a fresh array, in the order
	// the closure body expects them (layout first, then witnesses in
	// declaration order). Producers (`lowerFunctionRef` zero-capture +
	// `lowerClosureCreate`) feed this into `allocEnvAndStoreImplicits`.
	function collectInheritedImplicits() returns ValueIdArray
		var implicitValueIds = ValueIdArray.create()
		implicitValueIds.push(self.implicitLayoutValueId)
		for wId in self.implicitWitnessValueIds 'eachWitness'
			implicitValueIds.push(wId)
		end 'eachWitness'
		return implicitValueIds
	end 'collectInheritedImplicits'

	// Phase 11.4 closure-inheritance: allocate an env block sized for
	// `captureCount` user captures plus `implicitValueIds.count()`
	// trailing layout/witness slots, then store the implicits at
	// env[captureCount..]. Returns the env-base ValueId; the caller is
	// responsible for filling env[0..captureCount] with capture
	// addresses (capturing path) or nothing (zero-capture path).
	function allocEnvAndStoreImplicits(dstBlock IrBlock, captureCount ParsedInt, implicitValueIds ValueIdArray) returns ValueId
		let implicitCount = implicitValueIds.count()
		let totalSlots = captureCount + implicitCount
		let envSizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: envSizeId, value: totalSlots * 8))))
		var allocArgs = ValueIdArray.create()
		allocArgs.push(envSizeId)
		let envBaseId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(envBaseId, callee: "mrt_alloc", argIds: allocArgs)))
		// Implicits are single-deref slots — the closure body's entry-
		// block load issues one `loadIndirect` per slot, not the double-
		// deref the by-reference capture path uses, because
		// layout/witness pointers are immutable for the lifetime of the
		// closure.
		for i in 0 upto implicitCount 'eachImplicit'
			let valId = try implicitValueIds.get(i) otherwise panic("allocEnvAndStoreImplicits: implicitValueIds.get OOB at {i}")
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(envBaseId, offset: (captureCount + i) * 8, valueId: valId, width: StoreWidth.qword, isFloat: false)))
		end 'eachImplicit'
		return envBaseId
	end 'allocEnvAndStoreImplicits'

	// Phase 11.4 closure-inheritance: true iff a lifted closure body
	// receives its layout/witness args through env (via the producer side
	// of `lowerClosureCreate`) rather than as positional params. Read by
	// `lowerClosureCreate` to decide whether to extend the env block.
	// Mirrors the check in `transferFuncs` and ultimately defers to the
	// closure's own `hasImplicitLayoutParam` flag — which only flips for
	// closures whose enclosing chain reaches a generic extension. Linear
	// scan over `stdModule.functions`; closures are rare in real flow.
	function liftedClosureInheritsImplicits(funcName String) returns bool
		if not isLiftedClosureName(funcName) 'notClosure'
			return false
		end 'notClosure'
		for i in 0 upto self.stdModule.functions.count() 'scan'
			let f = try self.stdModule.functions.get(i) otherwise panic("liftedClosureInheritsImplicits: stdModule.functions.get OOB at {i}")
			if f.name == funcName 'hit'
				return f.hasImplicitLayoutParam
			end 'hit'
		end 'scan'
		return false
	end 'liftedClosureInheritsImplicits'

	// Phase 11.4 closure-inheritance: capture count for a lifted closure.
	// The parser stamps `liftedFunc.closureCaptureCount` at `parseClosure`
	// time and the stdlib cache restores the field via the regular
	// IrFunction codec. The captureCount drives the env-block layout —
	// implicit layout/witness slots live AFTER all user captures so a
	// 0-capture closure parks its layout at env[0]. Zero for non-closure
	// IrFunctions and for closures without captures.
	function countClosureCaptures(srcFunc IrFunction) returns ParsedInt
		return srcFunc.closureCaptureCount as ParsedInt
	end 'countClosureCaptures'

	// Stage E (closures): recover the outer slot id for a captured name.
	// Captures are by reference — the `stackAddr` op needs the original
	// local's slot id, not a fresh one. The parser only emits
	// `closureCreate` for names whose `closureOuterScope.contains(name)`
	// returned true, and that scope is preserved on the enclosing
	// function's IrFunction (in `currentMaxonFunc.scope`). A miss here
	// means the parser handed us a capture name the lowering's outer
	// function doesn't know about — a compiler bug, not a user error.
	function lookupOuterSlotForCapture(captureName String) returns VarSlot
		let func = self.currentMaxonFunc
		if not func.scope.contains(captureName) 'missing'
			panic("lowerClosureCreate: captured name '{captureName}' not found in outer scope of '{func.name}' (parser/lowering invariant violated)")
		end 'missing'
		return func.scope.getInfo(captureName).slot
	end 'lookupOuterSlotForCapture'

	// Stage E (closures): inside a lifted closure body, recover a
	// captured value via two indirect loads. env[i*8] holds the captured
	// outer slot's address; *<that address> holds the live value. The
	// load width of the second deref matches the captured value's
	// MaxonType — pointers and integers go through the GP load,
	// floats through the XMM one.
	function lowerClosureEnvLoad(result ByteArray, captureIndex ParsedInt, captureType MaxonType, dstBlock IrBlock)
		// Recover the env-pointer ValueId by emitting a slot load of the
		// lifted closure's hidden `__env` parameter. The parser appended
		// it as the LAST param so its slot id is `paramCount - 1`.
		let envSlot = self.liftedEnvValueId as VarSlot
		let envBaseId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.memory(StdMemoryOp.loadSlot(envBaseId, slotId: envSlot)))

		// env[i*8] → captured slot's address.
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(addrId, addrId: envBaseId, offset: captureIndex * 8, width: StoreWidth.qword, signed: false, isFloat: false)))

		// *<address> → the live value.
		let resultId = self.defineName(result)
		let isFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: captureType))
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(resultId, addrId: addrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: isFloat)))
		self.setValueType(resultId, t: captureType)
	end 'lowerClosureEnvLoad'

	// Stage E (closures): call through a function-typed value. The callee
	// ValueId resolves to a function pointer (from `funcRef` /
	// `closureCreate` / a function-typed param load); its matching env
	// pointer comes from `fnEnvVarNames`. The env arg is appended as the
	// LAST positional arg, mirroring the lifted closure's param-list
	// expansion. `slotArgsForCall` runs against the user-facing
	// FunctionTypeRegistry signature so default insertion + slot ordering
	// stay un-affected by the trailing env. argLabels / argTypes /
	// argRanges from the indirectCall op are intentionally dropped on the
	// caller side — a future call-site signature validator will read them
	// from the op directly without a parser rewrite.
	function lowerIndirectCall(result ByteArray, callee ByteArray, fnTypeId FunctionTypeId, args ByteArrayArray, dstBlock IrBlock)
		let calleeId = self.resolveName(callee)
		var argIds = self.resolveArgNames(args)
		// Every function-pointer value reaching an indirect call must have
		// been bound in `fnEnvVarNames` by an upstream `functionRef` (env
		// = const-0 op), `closureCreate` (env = freshly-allocated block),
		// or function-typed-param load (env = paired `__env_<name>` slot).
		// All three producer paths register a real defining-op ValueId —
		// no sentinels — so the env arg is always a well-formed SSA value
		// the downstream regalloc/codegen can color and emit. A miss here
		// is a compiler invariant violation, not a user error.
		let envId = try self.fnEnvVarNames.get(calleeId) otherwise panic("lowerIndirectCall: no env recorded for function-pointer value (upstream functionRef/closureCreate/param binding missed)")
		argIds.push(envId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.indirectCall(resultId, calleeId: calleeId, argIds: argIds)))
		let returnType = functionTypeIdReturnType(self.project, id: fnTypeId)
		self.setValueType(resultId, t: indirectCallResultType(self.project, returnType: returnType))
	end 'lowerIndirectCall'

	// Allocates a heap struct by calling mrt_alloc with the byte size.
	// `structName` is the source-level type name; we look up the struct
	// type in the project's registry, emit a fresh constI64 for the byte
	// size, then call mrt_alloc. The result's MaxonType is recorded so
	// downstream field/method ops on it can resolve.
	function lowerStructAlloc(result ByteArray, structName ByteArray, dstBlock IrBlock)
		let rawNameStr = String.from(structName)
		// Chase typealias chains so `KeyArray{}` (where
		// `typealias KeyArray = Array with Key`) resolves to the
		// underlying `Array` struct. Inner-aliases (declared inside the
		// enclosing struct's body) and top-level generic aliases both
		// route through `chaseTypealiasNameToStruct`. Initialize with
		// an empty `""` and overwrite below so we don't accidentally
		// alias `rawNameStr` (E3078 — a mutable binding can't be
		// initialized from a `let`-bound value without cloning).
		var structNameStr = ""
		structNameStr = rawNameStr
		if not self.project.structTypes.contains(rawNameStr) 'tryChase'
			if let chased = try chaseTypealiasNameToStruct(self.project, name: rawNameStr, enclosingType: self.currentTypeName) 'didChase'
				structNameStr = chased
			end 'didChase'
		end 'tryChase'
		var byteSize = 0
		let structType = try self.project.structTypes.get(structNameStr) otherwise 'unknownType'
			self.reportLowerError(ErrorCode.parserExpectedExpression, message: "lowerMaxonToStd: unknown struct type '{rawNameStr}' in structAlloc")
			byteSize = 0
			let placeholderResultId = self.defineName(result)
			self.setValueType(placeholderResultId, t: MaxonType.integer)
			return
		end 'unknownType'
		byteSize = structType.byteSize
		let sizeId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: sizeId, value: byteSize))))
		self.setValueType(sizeId, t: MaxonType.integer)
		var argIds = ValueIdArray.create()
		argIds.push(sizeId)
		let resultId = self.defineName(result)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(resultId, callee: "mrt_alloc", argIds: argIds)))
		// Phase 15e: a `__TupleN` allocation whose element types were
		// concrete at parse time has its specialised `genericInstance` gid
		// pinned in `project.tupleAllocGids` (keyed by the structAlloc op's
		// result name). Use that gi as the receiver's lowering value-type
		// so fieldStore/fieldLoad substitute `_TN` typeParameter fields
		// through to their concrete arg types — without it, float elements
		// would store/load through the GP-register width path instead of
		// movsd/SSE, corrupting the bits round-trip. Stage K.X.A: gate the
		// hint on the struct name actually being `__TupleN` — synthesized
		// result names (`$t3`, `$t10`, …) reset per function, so a flat
		// module-keyed map collides between user tuples and stdlib struct
		// allocations of the same shape (e.g. `RangeIterator.create`
		// happens to mint `$t3`). Without this guard the stdlib alloc
		// gets typed as the user's specialised tuple gi and downstream
		// fieldStores for its real fields trip the field-lookup walk.
		var receiverValueType = MaxonType.named(self.project.typeNames.intern(structNameStr))
		if rawNameStr.startsWith("__Tuple") 'maybeTuple'
			if let tupleGid = try self.project.tupleAllocGids.get(result) 'tupleHint'
				receiverValueType = MaxonType.genericInstance(tupleGid)
			end 'tupleHint'
		end 'maybeTuple'
		self.setValueType(resultId, t: receiverValueType)
		// Phase 11.0 step 8.8 (mirrors C# bootstrap `EmitEmptyBuiltinManagedLiteral`):
		// auto-initialize fields whose declared type resolves to the
		// `__ManagedMemory` builtin. Without this, `Array.create()`
		// (which lowers to `Self{}` with no fieldStores) leaves
		// `managed` as a null pointer; subsequent `arr.push` calls
		// then dereference null when reading length/capacity.
		// Subsequent explicit `fieldStore` ops in user code (e.g.
		// `Self{managed: someManaged}`) overwrite the synthesized
		// pointer, so this is safe to do unconditionally.
		self.synthesizeManagedFieldInits(resultId, structType: structType, dstBlock: dstBlock)
	end 'lowerStructAlloc'

	// For each field on `structType` whose declared type resolves to the
	// `__ManagedMemory` builtin, allocate a 40-byte __ManagedMemory record
	// (zero buffer/length/capacity, element_size = 8, parent_ptr = 0) and
	// store its pointer at the field's offset in the parent struct. This
	// matches the C# bootstrap's parser-time synthesis for missing managed
	// fields in `Self{}` literals — in the hybrid generic model the
	// concrete element_size will eventually come from a layout descriptor
	// (Phase 11.4); for now, every user-visible Array element type is
	// 8 bytes, so the constant 8 is correct.
	function synthesizeManagedFieldInits(parentId ValueId, structType StructType, dstBlock IrBlock)
		for field in structType.fields 'eachField'
			// Chase named/inner-aliases on the field type so a declared
			// `var managed ElementMemory` (where `ElementMemory` is the
			// inner alias `__ManagedMemory with Element`) resolves to
			// the underlying `__ManagedMemory` builtin. Same chase covers
			// `var chain as EManagedList` where `EManagedList` aliases
			// `__ManagedList with Element`.
			let directBase = try baseNameOfMaxonType(self.project, t: field.fieldType) otherwise continue
			var fieldBaseName = ""
			fieldBaseName = directBase
			if directBase != "__ManagedMemory" and directBase != "__ManagedList" 'tryChase'
				if let chased = try chaseTypealiasNameToStruct(self.project, name: directBase, enclosingType: structType.name) 'didChase'
					fieldBaseName = chased
				end 'didChase'
			end 'tryChase'
			if fieldBaseName != "__ManagedMemory" and fieldBaseName != "__ManagedList" 'notManaged'
				continue
			end 'notManaged'
			// Same sentinel check as `lookupFieldByStructName` — see the
			// extended comment there. Catches any path that constructs a
			// StructField but bypasses `layoutAllStructs`.
			if not field.offsetResolved 'unresolved'
				panic("synthesizeManagedFieldInits: field '{field.name}' on struct '{structType.name}' has unresolved offset — layoutAllStructs pass did not run")
			end 'unresolved'
			if fieldBaseName == "__ManagedList" 'isManagedList'
				// Allocate a fresh `__ManagedList` via the runtime helper.
				// `mrt_managed_list_create` calls `mm_alloc(32, dtor=__destruct___ManagedList)`
				// with refcount=1 so the list survives until the parent
				// struct's destructor decrefs the chain pointer.
				let mlArgIds = ValueIdArray.create()
				let mlId = allocValueId(self.funcIdRef)
				self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mlId, callee: "mrt_managed_list_create", argIds: mlArgIds)))
				self.setValueType(mlId, t: MaxonType.named(self.project.typeNames.intern("__ManagedList")))
				self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(parentId, offset: field.offset, valueId: mlId, width: StoreWidth.qword, isFloat: false)))
				continue
			end 'isManagedList'
			// Allocate 40 bytes for the inner __ManagedMemory record.
			let mmSizeId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: mmSizeId, value: 40))))
			self.setValueType(mmSizeId, t: MaxonType.integer)
			var mmArgIds = ValueIdArray.create()
			mmArgIds.push(mmSizeId)
			let mmId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(mmId, callee: "mrt_alloc", argIds: mmArgIds)))
			self.setValueType(mmId, t: MaxonType.named(self.project.typeNames.intern("__ManagedMemory")))
			// Initialize fields: buffer=0, length=0, capacity=0,
			// element_size=8, parent_ptr=0.
			self.storeI64Const(mmId, offset: 0, value: 0, dstBlock: dstBlock)
			self.storeI64Const(mmId, offset: 8, value: 0, dstBlock: dstBlock)
			self.storeI64Const(mmId, offset: 16, value: 0, dstBlock: dstBlock)
			self.storeI64Const(mmId, offset: 24, value: 8, dstBlock: dstBlock)
			self.storeI64Const(mmId, offset: 32, value: 0, dstBlock: dstBlock)
			// Store mmId pointer at field's offset in the parent.
			self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(parentId, offset: field.offset, valueId: mmId, width: StoreWidth.qword, isFloat: false)))
		end 'eachField'
	end 'synthesizeManagedFieldInits'

	// Helper: emit `constI64 value` then `storeIndirect addrId offset value`.
	function storeI64Const(addrId ValueId, offset FieldOffset, value ParsedInt, dstBlock IrBlock)
		let valId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: valId, value: value))))
		self.setValueType(valId, t: MaxonType.integer)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.storeIndirect(addrId, offset: offset, valueId: valId, width: StoreWidth.qword, isFloat: false)))
	end 'storeI64Const'

	// Lower `ret retVal` as a block terminator. In a non-throwing function this
	// is a plain `StdCallOp.ret(retVal)`. In a throwing function (per Phase 6
	// of the multi-value-return error ABI), every exit must write BOTH the
	// primary register AND the error flag — so `ret retVal` becomes
	// `errorReturn(retVal, 0)`. The zero flag tells the caller's tryCall site
	// "no error in flight."
	function lowerRet(retVal ByteArray, dstBlock IrBlock)
		self.emitRetOrErrorReturn(retVal, dstBlock: dstBlock, asTerminator: true)
	end 'lowerRet'

	// Same shape as `lowerRet` but appends as a body op. Hit only on the rare
	// path where the parser emits a `ret` mid-block (e.g. closure-lifted bodies
	// that were partially terminated by an outer pass). Maintains the throwing
	// vs non-throwing distinction so the multi-value-return ABI invariant
	// holds at every textual exit.
	function lowerRetAsBodyOp(retVal ByteArray, dstBlock IrBlock)
		self.emitRetOrErrorReturn(retVal, dstBlock: dstBlock, asTerminator: false)
	end 'lowerRetAsBodyOp'

	// Shared body for the two lowerRet shapes. `asTerminator` toggles between
	// `setTerminator` (block-final) and `appendOp` (mid-block).
	//
	// Interface-typed (fat-pointer) returns from non-throwing functions reuse
	// the multi-value-return ABI: the secondary register (RDX/X1) — normally
	// the error flag — carries the witness-table address instead. Same
	// register convention, same op shape (`errorReturn`); only the semantic
	// interpretation of the secondary slot differs. Callers of interface-
	// returning functions capture the secondary register via the parallel
	// `tryCall`/`witnessCall` path in `emitCallWithArgs`.
	function emitRetOrErrorReturn(retVal ByteArray, dstBlock IrBlock, asTerminator bool)
		let retValId = self.resolveName(retVal)
		let returnInterfaceName = returnTypeInterfaceName(self.project, ref: self.currentReturnType)
		if not returnInterfaceName.isEmpty() and not self.currentFuncIsThrowing 'fatRet'
			let witnessId = self.materializeReturnWitness(retValId, interfaceName: returnInterfaceName, dstBlock: dstBlock)
			let fatOp = StdOp.call(StdCallOp.errorReturn(retValId, errorFlagId: witnessId))
			if asTerminator 'asTermFat'
				self.stdModule.setTerminator(dstBlock, op: fatOp)
			end 'asTermFat' else 'asBodyFat'
				self.stdModule.appendOp(dstBlock, op: fatOp)
			end 'asBodyFat'
			return
		end 'fatRet'
		if self.currentFuncIsThrowing 'throwingExit'
			let zeroFlagId = allocValueId(self.funcIdRef)
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: zeroFlagId, value: 0))))
			self.setIsFloat(zeroFlagId, isFloat: false)
			let errOp = StdOp.call(StdCallOp.errorReturn(retValId, errorFlagId: zeroFlagId))
			if asTerminator 'asTerm'
				self.stdModule.setTerminator(dstBlock, op: errOp)
			end 'asTerm' else 'asBody'
				self.stdModule.appendOp(dstBlock, op: errOp)
			end 'asBody'
			return
		end 'throwingExit'
		let plainOp = StdOp.call(StdCallOp.ret(retValId))
		if asTerminator 'asTerm2'
			self.stdModule.setTerminator(dstBlock, op: plainOp)
		end 'asTerm2' else 'asBody2'
			self.stdModule.appendOp(dstBlock, op: plainOp)
		end 'asBody2'
	end 'emitRetOrErrorReturn'

	// Materialize the witness half of an interface-typed return value. The
	// returned ValueId is the secondary value paired with `retValId` at the
	// fat-pointer return site. Mirrors `witnessForInterfaceArg`: when the
	// return value is itself interface-typed (forwarding an existing fat
	// pointer), recover its paired witness; otherwise resolve the witness
	// label from the concrete value type's MaxonType and emit a
	// `loadWitnessTable`.
	function materializeReturnWitness(retValId ValueId, interfaceName String, dstBlock IrBlock) returns ValueId
		let retValueType = self.getValueType(retValId)
		if interfaceTypeIsFat(retValueType) 'forwardFat'
			return try self.interfaceWitnessValueIds.get(retValId) otherwise panic("materializeReturnWitness: retValId={retValId} typed as interface but no witness paired in interfaceWitnessValueIds")
		end 'forwardFat'
		return self.materializeInterfaceWitness(retValueType, interfaceName: interfaceName, dstBlock: dstBlock)
	end 'materializeReturnWitness'

	// Phase 4: lower MaxonOp.throw(enumName, variantName) to a single
	// multi-value-return op:
	//   const flagId  = ordinal_of(enumName, variantName) + 1
	//   const zeroId  = <default value of enclosing return type>
	//   errorReturn(zeroId, errorFlagId: flagId)
	//
	// The +1 reserves 0 for "no error in flight" so the caller's try-call
	// can distinguish a successful call from a thrown variant. The default
	// primary value is just an in-range constant of the right family (i64
	// zero for ints, f64 zero for floats, unused for void — but still
	// emitted because the multi-value ABI always writes both registers) —
	// the caller's `try ... otherwise` branch ignores the primary value
	// when the flag is non-zero. errorReturn is the block terminator.
	//
	// Phase 9 Stage 5c (option-1 union throws ABI): when `payloadValueName`
	// is non-empty, the caller is throwing an associated-value union value.
	// The constructed union pointer is non-null by construction (mm_alloc
	// never returns 0), so we re-use the flag slot as the carrier: the
	// caller's `flag != 0` test still recognises this as an error AND the
	// same SSA value doubles as the union pointer for the `(e)` binding.
	// The value slot stays a default zero. The variant tag is recoverable
	// at `[union_ptr + 0]`, so `match e` lowers exactly the same way it
	// does for any other union-typed scrutinee.
	function lowerThrow(enumName String, variantName String, payloadValueName ByteArray, dstBlock IrBlock)
		let isFloat = maxonReturnTypeLowersToFloat(self.project, ref: self.currentReturnType)
		let zeroOpcode = StdArithConstOpcode.constF64 if isFloat else StdArithConstOpcode.constI64
		let zeroId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(zeroOpcode, resultId: zeroId, value: 0))))
		self.setIsFloat(zeroId, isFloat: isFloat)
		if not payloadValueName.isEmpty() 'unionThrow'
			// Union-typed error: the constructor result IS the flag. We
			// preserve `lookupVariantOrdinalPlusOne` as a sanity-check call
			// — if the variant is unresolved the helper reports E3034 and we
			// fall through to the bare-enum lowering so the verifier still
			// sees a well-formed terminator.
			let unionPtrId = self.resolveName(payloadValueName)
			self.stdModule.setTerminator(dstBlock, op: StdOp.call(StdCallOp.errorReturn(zeroId, errorFlagId: unionPtrId)))
			return
		end 'unionThrow'
		let flag = self.lookupVariantOrdinalPlusOne(enumName, variantName: variantName)
		// const flag
		let flagId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(StdArithConstOpcode.constI64, resultId: flagId, value: flag))))
		self.setIsFloat(flagId, isFloat: false)
		self.stdModule.setTerminator(dstBlock, op: StdOp.call(StdCallOp.errorReturn(zeroId, errorFlagId: flagId)))
	end 'lowerThrow'

	// Resolve `EnumName.variantName` to its declaration ordinal, then add 1.
	// `+1` keeps 0 reserved for "no error in flight" — the secondary error
	// register (RDX/X1) carries the variant ordinal across the call boundary,
	// and 0 means the call returned successfully. A miss (unknown enum,
	// unknown case) reports a compile-error diagnostic and falls back to
	// ordinal `1`
	// so the lowering pass produces a structurally valid SSA module — the
	// `hasErrors(project)` short-circuit before codegen prevents the bogus
	// flag from reaching a real binary.
	function lookupVariantOrdinalPlusOne(enumName String, variantName String) returns IntConstant
		// The parser registers every enum into `unresolvedEnums` first;
		// TypeResolution drains it into `enumTypes`. Either map is acceptable
		// here because the case ordinals are stable across that move.
		if let resolved = try self.project.enumTypes.get(enumName) 'resolvedHit'
			if let ord = try resolved.caseByName.get(variantName) 'caseHit'
				return (ord as IntConstant) + 1
			end 'caseHit'
		end 'resolvedHit'
		if let unresolved = try self.project.unresolvedEnums.get(enumName) 'unresolvedHit'
			for i in 0 upto unresolved.cases.count() 'scan'
				let kase = try unresolved.cases.get(i) otherwise panic("lookupVariantOrdinalPlusOne: cases.get OOB")
				if kase.name == variantName 'match'
					return (i as IntConstant) + 1
				end 'match'
			end 'scan'
		end 'unresolvedHit'
		self.reportLowerError(ErrorCode.semanticEnumUnknownCase, message: "lowerMaxonToStd: throw of unknown variant '{enumName}.{variantName}'")
		return 1
	end 'lookupVariantOrdinalPlusOne'

	// Phase 4: lower MaxonOp.tryCall — emit a single multi-value-return
	// `StdCallOp.tryCall` op that yields BOTH the primary result (in R8/X0
	// at the backend level) AND the error flag (in RDX/X1). The flag bound
	// to `errorBoundName` is consumed by parser-emitted ops downstream
	// (typically a cmp + condBr that either propagates the error or falls
	// through to the fallback expression).
	//
	// We pre-allocate and bind the error-flag ValueId before delegating to
	// `lowerCall`, then thread it through `emitCallWithArgs` so the SINGLE
	// op produced is `StdCallOp.tryCall` (not a regular `call` followed by
	// any helper op). The tryCall op is the source-of-truth for the multi-
	// value-return error ABI: the backend lowers it to a call that picks up
	// the flag from the secondary return register (RDX/X1).
	function lowerTryCall(result ByteArray, callee ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, opIdx OpIndex, dstBlock IrBlock)
		// Reuse the exact call lowering — same signature/default-fill path —
		// but pass `errorBoundName` so the leaf emit step (a `StdCallOp.tryCall`
		// for real callees, or `aliasName` for inline-expanded builtins) binds
		// the flag through the right mechanism. opIdx is forwarded so resolved-
		// callee / paramTypes sidetable lookups pull this site's resolution.
		self.lowerCall(result, callee: callee, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName)
	end 'lowerTryCall'

	// Phase 5 (multi-value-return error ABI): lower MaxonOp.tryMethodCall by
	// pre-allocating the error-flag ValueId and threading it through
	// `lowerMethodCall` so the SINGLE op produced is `StdCallOp.tryCall` -
	// mirroring `lowerTryCall`'s relationship to `lowerCall`. The tryCall
	// op carries the multi-value-return error ABI: the backend picks up the
	// flag from the secondary return register (RDX/X1).
	function lowerTryMethodCall(result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, opIdx OpIndex, dstBlock IrBlock)
		// Defer binding of `errorBoundName` to the leaf emit step:
		//   - The real-call path allocates a fresh ValueId via `defineName`
		//     and uses it as the second def of `StdCallOp.tryCall`.
		//   - Inline-expanded builtins (`__ManagedMemory.createCursor`,
		//     `__ManagedMemoryCursor.advance` / `retreat` / `seek` / `peek`)
		//     compute the error code as an ordinary SSA value and `aliasName`
		//     the parser's name to it — no copy op emitted.
		// This avoids the legacy `addI64 errorFlagId, codeValueId, 0` "move"
		// stand-in, which used to survive into the final assembly as a
		// literal `add r8, 0`.
		self.lowerMethodCall(result, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, opIdx: opIdx, dstBlock: dstBlock, errorBoundName: errorBoundName)
	end 'lowerTryMethodCall'

	// Phase 5 (multi-value-return error ABI): bind the parser-supplied error-
	// bound name to a fresh const-zero SSA value. Used by `lowerMethodCall`'s
	// early-return paths (interface stubs, primitive extensions without a
	// registered signature) when those paths emit no `StdCallOp.tryCall` that
	// would otherwise produce the flag. An empty `errorBoundName` is the "not
	// a try-call site" sentinel — no-op in that case. Builtin-method early-
	// returns synthesize a "no error" flag so downstream readers see a well-
	// formed SSA value.
	function bindErrorFlagToZero(errorBoundName ByteArray, dstBlock IrBlock)
		if errorBoundName.isEmpty() 'notATryCallSite'
			return
		end 'notATryCallSite'
		let zeroId = self.emitConstI64(0, dstBlock: dstBlock)
		self.aliasName(errorBoundName, toId: zeroId)
	end 'bindErrorFlagToZero'

	// Phase 5: lower MaxonOp.rethrow(flagName) to a single multi-value-return
	// `errorReturn` op. Same shape as lowerThrow's tail except the flag value
	// is a runtime SSA name (resolveName) rather than a compile-time-known
	// `ordinal+1` literal. Caller's `try` reads the flag through the multi-
	// value-return ABI (RDX/X1) just as it does for lowerThrow / lowerTryCall.
	function lowerRethrow(flagName ByteArray, dstBlock IrBlock)
		let flagId = self.resolveName(flagName)
		let isFloat = maxonReturnTypeLowersToFloat(self.project, ref: self.currentReturnType)
		let opcode = StdArithConstOpcode.constF64 if isFloat else StdArithConstOpcode.constI64
		let zeroId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.const(StdArithConst.create(opcode, resultId: zeroId, value: 0))))
		self.setIsFloat(zeroId, isFloat: isFloat)
		self.stdModule.setTerminator(dstBlock, op: StdOp.call(StdCallOp.errorReturn(zeroId, errorFlagId: flagId)))
	end 'lowerRethrow'

	// Lower maxon.panic(message) to:
	//   std.system.globalAddr(addrId, "__panic_msg_<hash>")
	//   std.call.call mrt_panic(addrId)
	//
	// The label comes from `pipeline.panicLabelFor(message)` — a content hash
	// of the message, shared with `insertRangeChecks`. Identical messages
	// dedupe to one label/rdata entry; the label is independent of lowering
	// order. The prefix (`__panic_msg_` vs `__stdlib_panic_msg_`) is picked
	// from `pipeline.isStdlib` so stdlib and user-code compiles stay in
	// disjoint link-time namespaces.
	function lowerPanicToSys(stringId StringId, dstBlock IrBlock)
		let message = self.project.strings.get(stringId)
		let nameStr = self.pipeline.registerPanicMessage(message)

		// globalAddr -> addrId
		let addrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.globalAddr(addrId, name: nameStr)))

		// call mrt_panic(addrId)
		let callResultId = allocValueId(self.funcIdRef)
		var argIds = ValueIdArray.create()
		argIds.push(addrId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(callResultId, callee: "mrt_panic", argIds: argIds)))
	end 'lowerPanicToSys'

	// Lower maxon.panic_dynamic — the message argument is an SSA `String` value
	// produced by an upstream `stringInterp` op. The String layout is
	// `{ managed __ManagedMemory@0, isAsciiFlag bool@8 }`, and __ManagedMemory's
	// own layout starts with `buffer i64@0` (a raw byte pointer into a
	// null-terminated heap allocation owned by the String). Two indirect
	// loads recover the C-string pointer; we pass that directly to mrt_panic.
	// stringInterp already null-terminates its buffer (LowerStringInterp's
	// `Allocate raw buffer (totalLen + 1 for null terminator)` step), and the
	// parser prepends the location prefix + appends `\n` into the leading /
	// trailing literal fragments, so this lowering does no further fixup.
	function lowerPanicDynamic(stringValue ByteArray, dstBlock IrBlock)
		let stringPtrId = self.resolveName(stringValue)

		// Load managed __ManagedMemory pointer from String's field 0.
		let managedPtrId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(managedPtrId, addrId: stringPtrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(managedPtrId, t: MaxonType.integer)

		// Load buffer pointer from __ManagedMemory's field 0.
		let bufferId = allocValueId(self.funcIdRef)
		self.stdModule.appendOp(dstBlock, op: StdOp.system(StdSystemOp.loadIndirect(bufferId, addrId: managedPtrId, offset: 0, width: StoreWidth.qword, signed: false, isFloat: false)))
		self.setValueType(bufferId, t: MaxonType.integer)

		// call mrt_panic(buffer)
		let callResultId = allocValueId(self.funcIdRef)
		var argIds = ValueIdArray.create()
		argIds.push(bufferId)
		self.stdModule.appendOp(dstBlock, op: StdOp.call(StdCallOp.call(callResultId, callee: "mrt_panic", argIds: argIds)))
	end 'lowerPanicDynamic'

	// Lower maxon.convert.
	//
	// All same-family conversions (int-to-int, float-to-float) are pure value
	// aliases at the Std level — SSA values flow through 64-bit registers
	// regardless of the source-level type's declared width, and the only
	// place width matters is at memory loads/stores (handled by the load
	// op opcode, not the value flow) and at function return range checks
	// (handled by insertRangeChecks). We record `result -> operand` in the
	// name map so subsequent uses of the converted name resolve to the same
	// underlying ValueId. Cross-family conversions genuinely change the
	// representation and emit fpToSiI64 / siToFpF64.
	function lowerConvert(result ByteArray, operand ByteArray, fromType MaxonType, toType MaxonType, dstBlock IrBlock)
		let operandId = self.resolveName(operand)
		let fromIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: fromType))
		let toIsFloat = stdTypeIsFloat(maxonTypeToStdType(self.project, ref: toType))
		if fromIsFloat == toIsFloat 'sameFamily'
			self.aliasName(result, toId: operandId)
			return
		end 'sameFamily'
		let resultId = self.defineName(result)
		if fromIsFloat and not toIsFloat 'floatToInt'
			self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.fpToSiI64, resultId: resultId, operandId: operandId))))
			self.setIsFloat(resultId, isFloat: false)
			return
		end 'floatToInt'
		self.stdModule.appendOp(dstBlock, op: StdOp.arith(StdArithOp.unary(StdArithUnaryOp.create(StdArithUnaryOpcode.siToFpF64, resultId: resultId, operandId: operandId))))
		self.setIsFloat(resultId, isFloat: true)
	end 'lowerConvert'
end 'MaxonToStdLowering'

export type MathIntrinsicHit
	export var opcode as StdArithUnaryOpcode
	export var resultType as MaxonType

	export static function create(opcode StdArithUnaryOpcode, resultType MaxonType) returns MathIntrinsicHit
		return Self{opcode: opcode, resultType: resultType}
	end 'create'
end 'MathIntrinsicHit'

export type MathBinaryIntrinsicHit
	export var opcode as StdArithBinaryOpcode
	export var resultType as MaxonType

	export static function create(opcode StdArithBinaryOpcode, resultType MaxonType) returns MathBinaryIntrinsicHit
		return Self{opcode: opcode, resultType: resultType}
	end 'create'
end 'MathBinaryIntrinsicHit'

export enum MathIntrinsicError implements Error
	notIntrinsic
end 'MathIntrinsicError'

// Maps a bare math-primitive name to the Std unary opcode that implements it
// and the MaxonType of its result. Throws `MathIntrinsicError.notIntrinsic`
// for non-intrinsic names so the caller can `try ... otherwise` to fall
// through to normal call resolution. The opcode chain is single-instruction
// on every native backend (SQRTSD / ROUNDSD / FSQRT / FRINT* / FABS), so
// emitting the StdArithUnaryOp directly rather than calling a runtime
// wrapper avoids an unnecessary call/ret round trip for what amounts to a
// one-instruction operation. Used by both TypeResolution (to set the call's
// result MaxonType) and LowerMaxonToStd (to emit the inline op).
export function mathIntrinsicTarget(bare String) returns MathIntrinsicHit throws MathIntrinsicError
	if bare == "sqrt" 'isSqrt'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.sqrtF64, resultType: MaxonType.float)
	end 'isSqrt'
	if bare == "floor" 'isFloor'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.floorF64, resultType: MaxonType.float)
	end 'isFloor'
	if bare == "ceil" 'isCeil'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.ceilF64, resultType: MaxonType.float)
	end 'isCeil'
	if bare == "round" 'isRound'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.roundF64, resultType: MaxonType.float)
	end 'isRound'
	if bare == "abs" 'isAbs'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.absF64, resultType: MaxonType.float)
	end 'isAbs'
	if bare == "trunc" 'isTrunc'
		return MathIntrinsicHit.create(StdArithUnaryOpcode.fpToSiI64, resultType: MaxonType.integer)
	end 'isTrunc'
	throw MathIntrinsicError.notIntrinsic
end 'mathIntrinsicTarget'

// Maps a bare math-binary-primitive name (`min`/`max`) to the StdArithBinary
// opcode that lowers to single-instruction SSE MINSD/MAXSD (x64), FMIN/FMAX
// (arm64), or f64.min/f64.max (wasm). Both operands are promoted to f64; the
// result is f64. Throws so callers can fall through to normal call resolution
// for non-binary-intrinsic names. Separate from `mathIntrinsicTarget` because
// the StdArithUnaryOpcode and StdArithBinaryOpcode unions can't share a hit
// type.
export function mathBinaryIntrinsicTarget(bare String) returns MathBinaryIntrinsicHit throws MathIntrinsicError
	if bare == "min" 'isMin'
		return MathBinaryIntrinsicHit.create(StdArithBinaryOpcode.minF64, resultType: MaxonType.float)
	end 'isMin'
	if bare == "max" 'isMax'
		return MathBinaryIntrinsicHit.create(StdArithBinaryOpcode.maxF64, resultType: MaxonType.float)
	end 'isMax'
	throw MathIntrinsicError.notIntrinsic
end 'mathBinaryIntrinsicTarget'

export function isMathIntrinsic(bare String) returns bool
	try mathIntrinsicTarget(bare) otherwise 'unaryMiss'
		try mathBinaryIntrinsicTarget(bare) otherwise return false
		return true
	end 'unaryMiss'
	return true
end 'isMathIntrinsic'

// `__Internals.*` per-method lookup tables. Each map a method-name suffix
// to the runtime symbol it bakes into the emitted Std op. The mapping is
// closed (every `__Internals.<bridgeName>` registered in
// `registerInternalsIntrinsicSignatures` must have a corresponding entry
// here, and every entry here must have a matching signature registration).
// Throws on unknown name so callers can `try ... otherwise` to fall through
// to the next matcher in `lowerInternalsIntrinsic`'s dispatch.

export enum InternalsBridgeLookupError implements Error
	notBridge
end 'InternalsBridgeLookupError'

export type InternalsRuntimeCallHit
	export var callee as String
	export var arity as VarSlot

	export static function create(callee String, arity VarSlot) returns InternalsRuntimeCallHit
		return Self{callee: callee, arity: arity}
	end 'create'
end 'InternalsRuntimeCallHit'

// `__Internals.<globalAddrBridge>()` -> globalAddr <runtimeGlobalName>.
export function lookupInternalsGlobalAddrTarget(methodName String) returns String throws InternalsBridgeLookupError
	if methodName == "mmAllocCountAddr" 'a'
		return "__mm_alloc_count"
	end 'a'
	if methodName == "slabArenaListHeadAddr" 'a'
		return "__slab_arena_list_head"
	end 'a'
	if methodName == "slabArenaLastBaseAddr" 'a'
		return "__slab_arena_last_base"
	end 'a'
	if methodName == "slabInitDoneAddr" 'a'
		return "__slab_init_done"
	end 'a'
	if methodName == "slabMetaFreeHeadAddr" 'a'
		return "__slab_meta_free_head"
	end 'a'
	if methodName == "slabMetaBumpPtrAddr" 'a'
		return "__slab_meta_bump_ptr"
	end 'a'
	if methodName == "slabMetaBumpEndAddr" 'a'
		return "__slab_meta_bump_end"
	end 'a'
	if methodName == "slabMcentralArrayAddr" 'a'
		return "__slab_mcentral_array"
	end 'a'
	if methodName == "slabMcacheBaseAddr" 'a'
		return "__slab_mcache_base"
	end 'a'
	if methodName == "slabArenaMapL1Addr" 'a'
		return "__slab_arena_map_l1"
	end 'a'
	if methodName == "slabOsDirectCountAddr" 'a'
		return "__slab_os_direct_count"
	end 'a'
	if methodName == "slabOsDirectCapacityAddr" 'a'
		return "__slab_os_direct_capacity"
	end 'a'
	if methodName == "slabOsDirectArrayAddr" 'a'
		return "__slab_os_direct_array"
	end 'a'
	if methodName == "dataCovCountersAddr" 'a'
		return "__data_cov_counters"
	end 'a'
	if methodName == "dataCovNumSitesAddr" 'a'
		return "__data_cov_num_sites"
	end 'a'
	throw InternalsBridgeLookupError.notBridge
end 'lookupInternalsGlobalAddrTarget'

// `__Internals.<funcAddrBridge>()` -> funcAddr <runtimeFuncName>.
export function lookupInternalsFuncAddrTarget(methodName String) returns String throws InternalsBridgeLookupError
	if methodName == "mrtStartAddr" 'a'
		return "mrt_start"
	end 'a'
	if methodName == "symtableAddr" 'a'
		return "__symtable"
	end 'a'
	if methodName == "destructManagedMemoryAddr" 'a'
		// Resolves to the stdlib-side destructor body (registered when
		// stdlib/Internals.maxon's __destruct___ManagedMemory is loaded).
		// The runtime.std body of the same name still exists for the C#
		// bootstrap, but any caller routed through this intrinsic ends up
		// pointing at the stdlib copy via the qualified linker name.
		return "stdlib.__destruct___ManagedMemory"
	end 'a'
	throw InternalsBridgeLookupError.notBridge
end 'lookupInternalsFuncAddrTarget'

// `__Internals.<callBridge>(args...)` -> `call <runtimeFuncName>(args...)`.
// Returns the callee name and arity (the latter is the number of args the
// bridge accepts). TypeResolution validated the call shape against the
// registered intrinsic signature, so the lowering helper just consumes that
// many SSA names from the args array.
export function lookupInternalsRuntimeCallTarget(methodName String) returns InternalsRuntimeCallHit throws InternalsBridgeLookupError
	if methodName == "slabAlloc" 'a'
		return InternalsRuntimeCallHit.create("__slab_alloc", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabFree" 'a'
		return InternalsRuntimeCallHit.create("__slab_free", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabInit" 'a'
		return InternalsRuntimeCallHit.create("__slab_init", arity: 0 as VarSlot)
	end 'a'
	if methodName == "slabArenaAllocChunks" 'a'
		return InternalsRuntimeCallHit.create("__slab_arena_alloc_chunks", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabArenaFreeChunks" 'a'
		return InternalsRuntimeCallHit.create("__slab_arena_free_chunks", arity: 3 as VarSlot)
	end 'a'
	if methodName == "slabMemzero" 'a'
		return InternalsRuntimeCallHit.create("__slab_memzero", arity: 2 as VarSlot)
	end 'a'
	if methodName == "slabClassSize" 'a'
		return InternalsRuntimeCallHit.create("__slab_class_size", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabObjsPerSpan" 'a'
		return InternalsRuntimeCallHit.create("__slab_objs_per_span", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabMetaAlloc" 'a'
		return InternalsRuntimeCallHit.create("__slab_meta_alloc", arity: 0 as VarSlot)
	end 'a'
	if methodName == "slabMetaFree" 'a'
		return InternalsRuntimeCallHit.create("__slab_meta_free", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabRefillMcache" 'a'
		return InternalsRuntimeCallHit.create("__slab_refill_mcache", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabAllocClass" 'a'
		return InternalsRuntimeCallHit.create("__slab_alloc_class", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabFreeClassWithMspan" 'a'
		return InternalsRuntimeCallHit.create("__slab_free_class_with_mspan", arity: 2 as VarSlot)
	end 'a'
	if methodName == "slabArenaMapEnsure" 'a'
		return InternalsRuntimeCallHit.create("__slab_arena_map_ensure", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabArenaMapSet" 'a'
		return InternalsRuntimeCallHit.create("__slab_arena_map_set", arity: 3 as VarSlot)
	end 'a'
	if methodName == "slabArenaMapGet" 'a'
		return InternalsRuntimeCallHit.create("__slab_arena_map_get", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabOsDirectAlloc" 'a'
		return InternalsRuntimeCallHit.create("__slab_os_direct_alloc", arity: 1 as VarSlot)
	end 'a'
	if methodName == "slabOsDirectFree" 'a'
		return InternalsRuntimeCallHit.create("__slab_os_direct_free", arity: 1 as VarSlot)
	end 'a'
	if methodName == "mmRealloc" 'a'
		// mm_realloc is still in runtime.std (Phase 4 migrated only
		// __managed_mem_* + __destruct___ManagedMemory). Bridge it so
		// __managed_mem_grow in stdlib/Internals.maxon can invoke it.
		return InternalsRuntimeCallHit.create("mm_realloc", arity: 2 as VarSlot)
	end 'a'
	throw InternalsBridgeLookupError.notBridge
end 'lookupInternalsRuntimeCallTarget'

// Phase 3.4: subprocess builtins. Each entry is `(methodName -> callee,
// arity, return-shape)`. The lowering helper consumes the shape to decide
// whether the call's result ValueId carries i64, a __ManagedMemory pointer,
// or is synthesized as a 0-const stand-in for a void runtime call (so any
// downstream read of the call-result name still resolves).
export enum SubprocessReturnShape
	returnsInt
	returnsManaged
	returnsVoid
end 'SubprocessReturnShape'

export type SubprocessBuiltinHit
	export var callee as String
	export var arity as VarSlot
	export var returnShape as SubprocessReturnShape

	export static function create(callee String, arity VarSlot, returnShape SubprocessReturnShape) returns SubprocessBuiltinHit
		return Self{callee: callee, arity: arity, returnShape: returnShape}
	end 'create'
end 'SubprocessBuiltinHit'

export enum SubprocessBuiltinLookupError implements Error
	notSubprocess
end 'SubprocessBuiltinLookupError'

// `__Builtins.subprocess*` / `__Builtins.managedIsNull` -> (runtime callee,
// arity, return-shape). Callers route the hit through
// `lowerBuiltinsSubprocessCall`. Throws
// `SubprocessBuiltinLookupError.notSubprocess` when `methodName` isn't a
// subprocess intrinsic so the caller can fall through to the regular
// dispatch path. The runtime-symbol names mirror the bootstrap's parser
// table (maxon-sharp/Compiler/2-Parser.cs:8919) so any program compiled by
// either compiler resolves to the same `maxon_*` symbol.
export function lookupSubprocessBuiltin(methodName String) returns SubprocessBuiltinHit throws SubprocessBuiltinLookupError
	if methodName == "subprocessResolveOnPath" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_resolve_on_path", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'a'
	if methodName == "subprocessSpawn" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_spawn", arity: 14 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessDetach" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_detach", arity: 14 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessLastErrorMessage" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_last_error_message", arity: 0 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'a'
	if methodName == "subprocessGetPid" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_get_pid", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessWaitCollect" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_wait_collect", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessResultStatusKind" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_status_kind", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessResultStatusCode" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_status_code", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessResultStdout" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_stdout", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'a'
	if methodName == "subprocessResultStderr" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_stderr", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'a'
	if methodName == "subprocessResultDurationMs" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_duration_ms", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessResultRelease" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_result_release", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsVoid)
	end 'a'
	if methodName == "subprocessKill" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_kill", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessSendSignal" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_send_signal", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	if methodName == "subprocessReleaseHandle" 'a'
		return SubprocessBuiltinHit.create("maxon_subprocess_release_handle", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsVoid)
	end 'a'
	if methodName == "subprocessSpawnStreaming" 'isSubprocessSpawnStreaming'
		return SubprocessBuiltinHit.create("maxon_subprocess_spawn_streaming", arity: 4 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'isSubprocessSpawnStreaming'
	if methodName == "subprocessWriteStdinAll" 'isSubprocessWriteStdinAll'
		return SubprocessBuiltinHit.create("maxon_subprocess_write_stdin_all", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'isSubprocessWriteStdinAll'
	if methodName == "subprocessReadStdoutLine" 'isSubprocessReadStdoutLine'
		return SubprocessBuiltinHit.create("maxon_subprocess_read_stdout_line", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'isSubprocessReadStdoutLine'
	if methodName == "subprocessReadStderrLine" 'isSubprocessReadStderrLine'
		return SubprocessBuiltinHit.create("maxon_subprocess_read_stderr_line", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsManaged)
	end 'isSubprocessReadStderrLine'
	if methodName == "subprocessCloseStdin" 'isSubprocessCloseStdin'
		return SubprocessBuiltinHit.create("maxon_subprocess_close_stdin", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsVoid)
	end 'isSubprocessCloseStdin'
	if methodName == "subprocessWaitExit" 'isSubprocessWaitExit'
		return SubprocessBuiltinHit.create("maxon_subprocess_wait_exit", arity: 2 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'isSubprocessWaitExit'
	if methodName == "managedIsNull" 'a'
		return SubprocessBuiltinHit.create("maxon_managed_is_null", arity: 1 as VarSlot, returnShape: SubprocessReturnShape.returnsInt)
	end 'a'
	throw SubprocessBuiltinLookupError.notSubprocess
end 'lookupSubprocessBuiltin'

// True when `signature`'s first formal parameter is the implicit `__self`
// — i.e. the callee is an instance method. Lifted out of the per-call
// signature lookup so callers that already have a FuncSignature in hand
// don't trigger another funcSignatures hash op.
export function signatureFirstParamIsSelf(signature FuncSignature) returns bool
	if signature.paramNames.count() == 0 'noParams'
		return false
	end 'noParams'
	let firstParam = try signature.paramNames.get(0) otherwise panic("invariant: paramNames.count() > 0 just checked but get(0) failed")
	return firstParam == "__self"
end 'signatureFirstParamIsSelf'

// Recover the source file path of `func` by reading its entry block's
// BlockSourceInfo entry. Throws `EntryBlockFilePathError.detached` when the
// entry block was created outside the parser (no path attached) — callers
// use `if let` to take the path-anchored diagnostic path and fall through
// to a placeholder otherwise. Used by lowering's call-site type checker to
// anchor diagnostics on the user's source file, and by TypeResolution's
// per-function unresolvedRead/Assign rewriter to anchor visibility lookups
// against the reading function's file.
export function entryBlockFilePath(module MaxonModule, func IrFunction) returns String throws EntryBlockFilePathError
	if func.blockRefs.count() == 0 'noBlocks'
		throw EntryBlockFilePathError.detached
	end 'noBlocks'
	let entryRef = try func.blockRefs.get(0) otherwise panic("invariant: blockRefs.count() > 0 just checked but get(0) failed")
	// blockSourceInfo is pushed in lock-step with module.blocks, so any blockRef into module.blocks is also valid here.
	let info = try module.blockSourceInfo.get(entryRef) otherwise panic("invariant: blockSourceInfo 1:1 with module.blocks but get({entryRef}) failed")
	return info.filePath
end 'entryBlockFilePath'

export enum EntryBlockFilePathError implements Error
	detached
end 'EntryBlockFilePathError'

// Map a MaxonType primitive arm to the type-name that an `extension` block
// declares its impl methods under. The stdlib's PrimitiveExtensions.maxon
// declares extensions on the lowercase primitive names (`int`, `float`,
// `bool`, `byte`); a method call on a primitive-typed receiver qualifies
// through that name. Throws `NotPrimitiveExtension.notPrimitive` for any
// non-primitive arm — callers use `if let` to take the primitive-extension
// dispatch path and fall through to the regular struct-name path otherwise.
export function primitiveExtensionTypeName(t MaxonType) returns String throws NotPrimitiveExtension
	return match t 'p'
		integer gives "int"
		float gives "float"
		boolean gives "bool"
		string gives "String"
		default throws NotPrimitiveExtension.notPrimitive
	end 'p'
end 'primitiveExtensionTypeName'

// Phase 7 / 11.4: chase named typealiases down to a primitive arm before
// returning the extension type name. Bridges typealias-narrowed receivers
// (`Byte` = `byte(0 to u8.max)`, `Integer` = `int(i64.min to i64.max)`) to
// the lowercase extension names registered by stdlib/PrimitiveExtensions.
// Throws `NotPrimitiveExtension.notPrimitive` when the receiver is a
// struct, enum, interface, or genuinely non-primitive named type.
export function primitiveExtensionTypeNameWithProject(project Project, t MaxonType) returns String throws NotPrimitiveExtension
	if let direct = try primitiveExtensionTypeName(t) 'haveDirect'
		return direct
	end 'haveDirect'
	// Named arm: probe the resolved typealiases sidecar. The StdType the
	// alias resolves to determines the extension family. Non-named arms
	// (boolean/integer/float/string/function/typeParameter/genericInstance/
	// interface/unresolved) were already rejected by `primitiveExtensionTypeName`
	// above; they can't be the LHS of a typealias declaration that names a
	// primitive.
	let name = match t 'getName'
		named(id) gives project.typeNames.get(id)
		default throws NotPrimitiveExtension.notPrimitive
	end 'getName'
	if not project.typealiases.contains(name) 'notTypealias'
		throw NotPrimitiveExtension.notPrimitive
	end 'notTypealias'
	let stdType = try project.typealiases.get(name) otherwise throw NotPrimitiveExtension.notPrimitive
	return match stdType.rawValue.castCategory 'cat'
		int gives "int"
		float gives "float"
		bool gives "bool"
		string gives "String"
	end 'cat'
end 'primitiveExtensionTypeNameWithProject'

export enum NotPrimitiveExtension implements Error
	notPrimitive
end 'NotPrimitiveExtension'

// Pick the diagnostic-friendly name for a MaxonType in an E3005 error.
// When both endpoints of a mismatch live in the primitive numeric/bool
// families, the underlying primitive name (int/float/byte/bool) reads
// better than the user's typealias — the caller wrote `Integer` but the
// mismatch is structural at the int family level. When either endpoint
// is non-primitive (string, struct, enum, …), prefer the source-level
// name so the diagnostic mentions what the user actually wrote.
function mismatchTypeName(project Project, t MaxonType, ownCategory CastCategory, otherCategory CastCategory) returns String
	if isPrimitiveCategory(ownCategory) and isPrimitiveCategory(otherCategory) 'bothPrimitive'
		return castCategoryName(ownCategory)
	end 'bothPrimitive'
	return t.toString(project)
end 'mismatchTypeName'

// "Primitive" here means the numeric/bool families that share an i64/i1/f64
// representation at the Std level. String is intentionally NOT primitive —
// when one endpoint is a string we want the diagnostic to use the
// source-level name ("String") rather than collapsing into a category.
function isPrimitiveCategory(c CastCategory) returns bool
	return c == CastCategory.int or c == CastCategory.float or c == CastCategory.bool
end 'isPrimitiveCategory'

// True iff `paramType` is `named("Character")`. The char-byte → Character
// coercion in `coerceArgToParam` keys off this (plus the `charByteLiterals`
// registry) rather than the arg's recorded type, because the `==` → `.equals()`
// rewrite can retype a char-byte operand to `Character` before lowering runs.
function paramTypeIsNamedCharacter(project Project, t MaxonType) returns bool
	let name = match t 'name'
		named(id) gives project.typeNames.get(id)
		boolean to string gives ""
		function to opaquePointer gives ""
	end 'name'
	return name == "Character"
end 'paramTypeIsNamedCharacter'

// Categorical predicate: does `from` admit an implicit conversion to `to`
// at a call site? The only cross-category conversions the language permits
// today are int ↔ float (siToFp / fpToSi). All other pairs reject and the
// caller emits E3005. Same-category pairs short-circuit before calling
// this predicate.
export function implicitlyConvertible(from CastCategory, to CastCategory) returns bool
	if from == CastCategory.int and to == CastCategory.float 'intToFloat'
		return true
	end 'intToFloat'
	if from == CastCategory.float and to == CastCategory.int 'floatToInt'
		return true
	end 'floatToInt'
	return false
end 'implicitlyConvertible'

// Categorical predicate: is `from → to` a non-narrowing widening? Unlike
// `implicitlyConvertible`, this rejects float→int (which loses fractional
// values). Used by Phase A auto-widening at sites where narrowing would be
// unsafe — struct field stores, match arm result-slot unification — and the
// C# bootstrap parser only inserts widening casts.
export function isWideningCategory(from CastCategory, to CastCategory) returns bool
	if from == CastCategory.int and to == CastCategory.float 'intToFloat'
		return true
	end 'intToFloat'
	return false
end 'isWideningCategory'

// Recover the enclosing struct-type name from a parser-qualified function
// name. The parser qualifies methods as `Type.method` (with no module
// namespace prefix — the parser uses `currentTypeName` directly as the
// qualifier in `parseFunction`). We split on the LAST dot and probe
// `project.structTypes`: a registered struct prefix denotes a method body;
// anything else (including bare names like `main`) denotes a free function.
// Phase 11.4: a function counts as "generic" if any of its declared
// parameter types is a `MaxonType.typeParameter`, OR its receiver type
// is a generic struct (one with type parameters declared via `uses`).
// J.4a prereq.2: interface-extension methods (`Iterable.map`,
// `Iterator.advanceBy`, ...) are equally generic — the parser stamps
// the interface's `uses Element` params into the typeParameters
// registry under the interface name, and the body may call other
// generic methods like `Array.push` which need an `__layout_param`
// forwarded. Recognizing them here is the gate that triggers synthetic
// `__layout_param` / `__witness_*` insertion for those bodies.
// Matches the spine spec from the Phase-11.4 plan and is the gate that
// triggers synthetic `__layout_param` insertion.
function functionIsGenericForLowering(project Project, func IrFunction) returns bool
	for i in 0 upto func.maxonParamTypes.count() 'eachParam'
		let pType = try func.maxonParamTypes.get(i) otherwise MaxonType.integer
		if maxonTypeMentionsTypeParam(pType) 'hit'
			return true
		end 'hit'
	end 'eachParam'
	if let recvType = try enclosingTypeName(project, name: func.name) 'haveRecv'
		// Mirrors `lookupTypeParamsForBase` (TypeResolution.maxon): for
		// interface receivers the `uses` params live on the IrInterface
		// record itself, not in TypeParamRegistry, so a bare
		// `getParamNames` lookup would miss them.
		if let iface = try project.interfaces.get(recvType) 'ifaceParams'
			return iface.usesParams.count() > 0
		end 'ifaceParams'
		let params = project.typeParameters.getParamNames(recvType)
		return params.count() > 0
	end 'haveRecv'
	// Phase 11.4 closure-inheritance: lifted closure bodies carry no
	// enclosing receiver of their own. Recover the enclosing function
	// name from the closure's embedded prefix (`{outer}$closure_<k>`)
	// and re-ask the question against that name. If the enclosing
	// function lives in a generic extension (or itself is a generic
	// body), the closure inherits its layout/witness slots through env
	// (see `lowerClosureCreate`).
	if isLiftedClosureName(func.name) 'isClosure'
		let enclosingName = enclosingFuncOfClosure(func.name)
		if not enclosingName.isEmpty() 'haveEnc'
			return enclosingNameIsGenericForLowering(project, name: enclosingName)
		end 'haveEnc'
	end 'isClosure'
	return false
end 'functionIsGenericForLowering'

// Mirror of `functionIsGenericForLowering`'s enclosing-type lookup keyed
// by a name string (rather than an IrFunction). Used by closure
// inheritance to ask "is this name's enclosing extension generic?"
// without re-finding the IrFunction record.
function enclosingNameIsGenericForLowering(project Project, name String) returns bool
	if let recvType = try enclosingTypeName(project, name: name) 'haveRecv'
		if let iface = try project.interfaces.get(recvType) 'ifaceParams'
			return iface.usesParams.count() > 0
		end 'ifaceParams'
		let params = project.typeParameters.getParamNames(recvType)
		return params.count() > 0
	end 'haveRecv'
	return false
end 'enclosingNameIsGenericForLowering'

// True iff a `MaxonType` mentions `typeParameter` anywhere in its tree.
// We only need a one-level walk for now: `genericInstance(gid)` arms
// recursing into their args is what would unlock deeper detection, but
// every Phase-11.4 priority spec exercises only the surface form
// (`fn push(self, x T)` style).
function maxonTypeMentionsTypeParam(t MaxonType) returns bool
	return match t 'check'
		typeParameter gives true
		boolean to function gives false
		unresolved gives false
		genericInstance to opaquePointer gives false
	end 'check'
end 'maxonTypeMentionsTypeParam'

// Phase 11.4: result of mapping a callee's bare type-parameter name to its
// concrete binding at a specific call site. `concrete(name)` carries the
// pinned struct/primitive type name (e.g. "int", "Map"); `concreteGid`
// additionally pins a generic instance id (e.g. `Array<Byte>`) so the
// witness loader can pick the per-instance table whose method slots
// reference the thunks BuildWitnessTables synthesized for this exact
// instantiation; `forwardFromCaller` means the binding is itself a
// type-parameter from the caller's scope — the witness should ride the
// caller's own implicit witness slot. `callerParamName` is empty when the
// binding shape (interface/unresolved/named) doesn't expose a concrete
// caller paramName, falling back to "match the callee's paramName" — the
// historic alignment assumption that holds whenever the caller and callee
// share a type-parameter scope (e.g. two methods on the same generic type).
// When the receiver pins the binding to a specific caller paramName (the
// `WithIterIterator<Iter, Element>` case where the callee's `Source` is
// bound to the caller's `Iter`), `callerParamName` carries that name so
// `forwardCallerWitness` can look up the correct caller slot without
// requiring the names to match.
union ResolvedCalleeParam
	concrete(typeName String)
	concreteGid(typeName String, gid GenericInstanceId)
	forwardFromCaller(callerParamName String)
end 'ResolvedCalleeParam'

// Phase 11.4: result of locating a where-clause witness slot covering a
// specific method call. `constraintIndex` is parallel to
// `implicitWitnessValueIds` / `implicitWitnessConstraints`; `interfaceName`
// is the trait the chosen constraint requires.
type MatchedConstraint
	export var constraintIndex as ParsedInt
	export var interfaceName as String

	export static function create(constraintIndex ParsedInt, interfaceName String) returns MatchedConstraint
		return Self{constraintIndex: constraintIndex, interfaceName: interfaceName}
	end 'create'
end 'MatchedConstraint'

enum ConstraintLookupError implements Error
	notFound
end 'ConstraintLookupError'

// Project a `MaxonType` (a callee param's bound) onto the witness-table
// key space. Concrete struct/primitive types route to a witness lookup;
// `typeParameter` and unresolved forms forward to the caller. `interface`
// bindings would imply a witness-of-an-interface — not modeled today; we
// fall through to forwarding so the caller's witness slot supplies it,
// which is the correct shape for the only path that hits this today
// (caller is generic, callee is constrained on the same `T`).
function resolvedCalleeParamFromMaxonType(project Project, t MaxonType) returns ResolvedCalleeParam
	return match t 'pick'
		boolean gives ResolvedCalleeParam.concrete("bool")
		integer gives ResolvedCalleeParam.concrete("int")
		float gives ResolvedCalleeParam.concrete("float")
		string gives ResolvedCalleeParam.concrete("String")
		named(id) gives resolvedCalleeParamFromNamed(project, id: id)
		genericInstance(gid) gives resolvedCalleeParamFromGenericInstance(project, gid: gid)
		typeParameter(id) gives ResolvedCalleeParam.forwardFromCaller(project.typeParameters.getName(id))
		interface gives ResolvedCalleeParam.forwardFromCaller("")
		unresolved gives ResolvedCalleeParam.forwardFromCaller("")
		function gives ResolvedCalleeParam.forwardFromCaller("")
		constInt to opaquePointer gives ResolvedCalleeParam.forwardFromCaller("")
	end 'pick'
end 'resolvedCalleeParamFromMaxonType'

// Chase a `named` typealias down to its primitive extension name (`int`,
// `float`, `bool`, `String`) so witness-table lookups against typealiased
// primitive bindings (`typealias Int = int(...)`, `typealias ByteVal =
// int(0 to u8.max)`) resolve to the primitive's pre-emitted witness blob
// instead of panicking on a missing `__witness_<AliasName>_*` table.
// Non-primitive named types (structs, enums) pass through unchanged.
//
// Generic typealiases (`typealias IntArr = Array with Val`) live in
// `project.genericTypealiases` mapping to the resolved `MaxonType` (e.g.
// `genericInstance(Array, [Val])`). Witness lookup needs to see the
// underlying generic instance — the bare alias name has no witness table
// of its own — so we chase one level and recurse via
// `resolvedCalleeParamFromMaxonType`.
function resolvedCalleeParamFromNamed(project Project, id TypeNameId) returns ResolvedCalleeParam
	let bareName = project.typeNames.get(id)
	if let aliasTarget = try project.genericTypealiases.get(bareName) 'genericAlias'
		return resolvedCalleeParamFromMaxonType(project, t: aliasTarget)
	end 'genericAlias'
	let aliasName = try primitiveExtensionTypeNameWithProject(project, t: MaxonType.named(id)) otherwise return ResolvedCalleeParam.concrete(bareName)
	return ResolvedCalleeParam.concrete(aliasName)
end 'resolvedCalleeParamFromNamed'

// A `genericInstance(gid)` binding is preserved as `concreteGid` so the
// witness loader can pick the per-instance table for this exact
// instantiation. The bare-name `concrete` arm stays in service for
// primitives and non-generic struct conformers (which share a single
// `__witness_<TypeName>_<InterfaceName>` blob across the project).
function resolvedCalleeParamFromGenericInstance(project Project, gid GenericInstanceId) returns ResolvedCalleeParam
	let (baseId, _) = project.genericInstances.get(gid)
	return ResolvedCalleeParam.concreteGid(project.typeNames.get(baseId), gid: gid)
end 'resolvedCalleeParamFromGenericInstance'

// Compute the witness-table label for a per-instance thunk's implicit
// witness arg. The bound type is the conformer's type-parameter resolved
// against its concrete substitution (e.g. `Element=Byte` for
// `Array<Byte>`). Each arm picks the matching `__witness_<typeMangle>_<iface>`
// label. The unconditional-path label scheme for primitives (`bool`,
// `int`, ...) matches what `BuildWitnessTables` produces for the
// primitives' own conformances. The conditional arms are unreachable
// because `BuildWitnessTables` skips conditional gids before emission;
// any reachable invocation here means a phase-ordering bug.
//
// A `named(id)` arm may itself be a typealias (`typealias IntArr = Array
// with Val` or `typealias Byte = int(0 to u8.max)`). Chase one level
// through `genericTypealiases` / `typealiases` so the label lands on the
// concrete witness table BuildWitnessTables actually emitted — without
// the chase, the bare alias name is sanitized into a label like
// `__witness_IntArr_Hashable` that no pass ever registered, and the wasm
// backend panics at globalDataOffsets lookup time.
function thunkWitnessLabelForBound(project Project, bound MaxonType, mangledIface String, interfaceName String) returns String
	let resolved = resolveAliasedBound(project, bound: bound)
	return match resolved 'pick'
		boolean gives "__witness_bool_{mangledIface}"
		integer gives "__witness_int_{mangledIface}"
		float gives "__witness_float_{mangledIface}"
		string gives "__witness_String_{mangledIface}"
		named(id) gives "__witness_{sanitizeIdentifier(project.typeNames.get(id))}_{mangledIface}"
		genericInstance(innerGid) gives "__witness_{sanitizeIdentifier(genericInstanceIdToString(project, id: innerGid))}_{mangledIface}"
		typeParameter gives thunkBoundFatal("typeParameter", interfaceName: interfaceName)
		interface gives thunkBoundFatal("interface", interfaceName: interfaceName)
		unresolved gives thunkBoundFatal("unresolved", interfaceName: interfaceName)
		function gives thunkBoundFatal("function", interfaceName: interfaceName)
		constInt gives thunkBoundFatal("constInt", interfaceName: interfaceName)
		opaquePointer gives thunkBoundFatal("opaquePointer", interfaceName: interfaceName)
	end 'pick'
end 'thunkWitnessLabelForBound'

// Chase a `named(typealias)` bound down to its underlying MaxonType so
// witness-label construction lands on the entry BuildWitnessTables
// actually emitted. Two alias forms exist:
//   - generic typealiases (`typealias IntArr = Array with Val`) — stored
//     in `project.genericTypealiases` as MaxonType.genericInstance.
//   - ranged-primitive aliases (`typealias Val = int(...)`) — stored in
//     `project.typealiases` keyed by name, whose `castCategory` picks
//     the primitive arm (int/float/bool/string).
// Non-aliased bounds (primitives, struct names with their own witness
// table, fresh generic instances) pass through unchanged.
function resolveAliasedBound(project Project, bound MaxonType) returns MaxonType
	let nameId = try maxonTypeNamedId(bound) otherwise return bound
	let name = project.typeNames.get(nameId)
	if let aliasTarget = try project.genericTypealiases.get(name) 'genericAlias'
		return resolveAliasedBound(project, bound: aliasTarget)
	end 'genericAlias'
	if let stdType = try project.typealiases.get(name) 'rangedAlias'
		return match stdType.rawValue.castCategory 'cat'
			int gives MaxonType.integer
			float gives MaxonType.float
			bool gives MaxonType.boolean
			string gives MaxonType.string
		end 'cat'
	end 'rangedAlias'
	return bound
end 'resolveAliasedBound'

// Extract the typename id from a `named` MaxonType; throws for every
// other arm so `resolveAliasedBound` can short-circuit non-named inputs
// via `try ... otherwise return bound`.
function maxonTypeNamedId(t MaxonType) returns TypeNameId throws NotNamedType
	return match t 'pickId'
		named(id) gives id
		default throws NotNamedType.notNamed
	end 'pickId'
end 'maxonTypeNamedId'

enum NotNamedType implements Error
	notNamed
end 'NotNamedType'

// Wrap `panic` as a value-returning function so the unreachable match
// arms above can be expressed as `gives thunkBoundFatal(...)`. The
// returned String value is never observed — `panic` aborts the process.
function thunkBoundFatal(kind String, interfaceName String) returns String
	panic("emitThunkWitnessLoadForBoundType: thunk witness arg for interface '{interfaceName}' resolved to unsupported MaxonType arm '{kind}' — BuildWitnessTables emitted a thunk for a shape it shouldn't have")
end 'thunkBoundFatal'

// Phase 11.4: walk the enclosing type's interned type-parameters and emit a
// `WhereClause` per `(paramName, requiredTraitName)` pair in declaration
// order. Multiple constraints on a single param (e.g. `Key is Hashable and
// Equatable`) produce one entry each — every entry corresponds to one
// trailing `__witness_*` slot on the lowered function.
//
// Iteration order is the typeParam declaration order (outer loop) crossed
// with the constraint declaration order from `addConstraint` (inner loop),
// matching the parser's left-to-right walk of the `where` clause. This is
// the canonical order both the function body and every call site rely on
// when indexing witness slots.
function collectFunctionWitnessConstraints(project Project, func IrFunction) returns WhereClauseArray
	var out = WhereClauseArray.create()
	// Phase 11.4 closure-inheritance: lifted closure bodies have no
	// enclosing receiver of their own — chase the back-pointer to the
	// outermost real function and read its receiver / extension where-
	// clauses instead. Closures whose enclosing chain doesn't reach a
	// generic context fall through to the empty array (the closure
	// stays non-generic at lowering).
	var lookupName = func.name
	if isLiftedClosureName(func.name) 'isClosure'
		let enclosingName = enclosingFuncOfClosure(func.name)
		if not enclosingName.isEmpty() 'haveEnc'
			lookupName = enclosingName
		end 'haveEnc'
	end 'isClosure'
	if let recvType = try enclosingTypeName(project, name: lookupName) 'haveRecv'
		for i in 0 upto project.typeParameters.declaringTypeNames.count() 'scan'
			let d = try project.typeParameters.declaringTypeNames.get(i) otherwise panic("collectFunctionWitnessConstraints: declaringTypeNames.get OOB at {i}")
			if d == recvType 'match'
				let paramName = project.typeParameters.getName(i)
				let cs = project.typeParameters.getConstraints(i)
				for j in 0 upto cs.count() 'eachTrait'
					let traitName = try cs.get(j) otherwise panic("collectFunctionWitnessConstraints: constraints.get OOB at {j}")
					out.push(WhereClause.createScoped(paramName, requiredTraitName: traitName, declaringTypeName: recvType))
				end 'eachTrait'
			end 'match'
		end 'scan'
		inferImplicitWitnessConstraints(project, recvType: recvType, out: out)
	end 'haveRecv'
	// Extension-scoped where-clauses (e.g. `extension Array where Element is
	// Equatable`) attach constraints to the methods declared inside the
	// extension body, not to the underlying struct's TypeParamRegistry entry.
	// Pull those in by methodKey so witness-routed dispatch sees the
	// constraints the user wrote on the extension. Without this, an extension
	// body using `item == element` would fail witness lookup and (post-Stream
	// A E3005 emission) report "type parameter not constrained" even though
	// the user did constrain it.
	//
	// `extensionMethodWhereClauses` is keyed by the function's actual
	// registered name (which may be overload-mangled, e.g. `Array.sort$Self`
	// vs `Array.sort$SortComparator`). The parser inserts under the
	// post-mangling key and `rekeyExistingFunction` migrates the existing
	// overload's entry when a sibling forces re-mangling. The lookup uses
	// the function's exact name so two overloads in different extensions
	// with different where-clauses don't share an entry — without per-
	// overload keying, the no-Comparable comparator overload of `Array.sort`
	// would inherit the Comparable overload's `where Element is Comparable`
	// clause and demand a `(String, Comparable)` witness that
	// `BuildWitnessTables` (correctly) never builds.
	if let extClauses = try project.extensionMethodWhereClauses.get(lookupName) 'haveExtWhere'
		for i in 0 upto extClauses.count() 'eachExtClause'
			let clause = try extClauses.get(i) otherwise panic("collectFunctionWitnessConstraints: extClauses.get OOB at {i}")
			if whereClauseArrayContains(out, clause: clause) 'duplicate'
				continue
			end 'duplicate'
			out.push(clause)
		end 'eachExtClause'
	end 'haveExtWhere'
	return out
end 'collectFunctionWitnessConstraints'

// J.4a prereq.5: append structurally-implied constraints that the source
// doesn't write down explicitly but the language semantics guarantee.
//
// Today's single rule covers the Iterable contract: when interface `I`
// declares `function createIterator() returns T` and `T` is one of `I`'s
// `uses` parameters, the language uses `T` as an iterator (for-in expands
// to `iter.current()` / `iter.advance()`), so every conformer of `I` must
// supply a `T : Iterator` witness. The C# bootstrap recovers this via
// monomorphization; the dictionary-passing self-hosted compiler needs an
// explicit witness slot so methods like `Iterable.withIterator` (whose body
// instantiates `WithIterIterator with Iter, Element where Source is Iterator`)
// can forward the witness without panicking in `forwardCallerWitness`.
//
// Skip the inference when the user already wrote `where T is Iterator`
// (don't double-slot the same constraint), and only fire on actual
// interface receivers — struct receivers with `createIterator` follow the
// concrete-conformer path that goes through `BuildWitnessTables` and
// doesn't need the slot.
function inferImplicitWitnessConstraints(project Project, recvType String, out WhereClauseArray)
	let iface = try project.interfaces.get(recvType) otherwise return
	for i in 0 upto iface.methods.count() 'eachMethod'
		let m = try iface.methods.get(i) otherwise panic("inferImplicitWitnessConstraints: methods.get OOB at {i}")
		if m.name != "createIterator" 'notCreate'
			continue
		end 'notCreate'
		let returnedName = try returnTypeNamedName(project, ref: m.returnType) otherwise continue
		if not stringArrayContains(iface.usesParams, value: returnedName) 'notUsesParam'
			continue
		end 'notUsesParam'
		let existing = WhereClause.createScoped(returnedName, requiredTraitName: "Iterator", declaringTypeName: recvType)
		if whereClauseArrayContains(out, clause: existing) 'alreadyHave'
			continue
		end 'alreadyHave'
		out.push(existing)
	end 'eachMethod'
end 'inferImplicitWitnessConstraints'

// Extract the bare named-type name from a `MaxonReturnType`, or throw when
// the return is `void` or a non-named MaxonType shape (genericInstance,
// typeParameter, interface, ...). Inference rules above only need to
// recognize the parser's `MaxonType.named(<usesParam>)` shape that
// interface-method return positions emit when the source writes a bare
// uses-param name.
function returnTypeNamedName(project Project, ref MaxonReturnType) returns String throws NamedReturnError
	let inner = match ref 'unwrap'
		void gives MaxonType.unresolved
		value(t) gives t
	end 'unwrap'
	match inner 'pick'
		named(id) then return project.typeNames.get(id)
		boolean to string then throw NamedReturnError.notNamed
		function to opaquePointer then throw NamedReturnError.notNamed
	end 'pick'
end 'returnTypeNamedName'

enum NamedReturnError implements Error
	notNamed
end 'NamedReturnError'

function stringArrayContains(arr StringArray, value String) returns bool
	for i in 0 upto arr.count() 'scan'
		let item = try arr.get(i) otherwise panic("stringArrayContains: arr.get OOB at {i}")
		if item == value 'hit'
			return true
		end 'hit'
	end 'scan'
	return false
end 'stringArrayContains'

function whereClauseArrayContains(arr WhereClauseArray, clause WhereClause) returns bool
	for i in 0 upto arr.count() 'scan'
		let item = try arr.get(i) otherwise panic("whereClauseArrayContains: arr.get OOB at {i}")
		if item.paramName == clause.paramName and item.requiredTraitName == clause.requiredTraitName and item.declaringTypeName == clause.declaringTypeName 'hit'
			return true
		end 'hit'
	end 'scan'
	return false
end 'whereClauseArrayContains'

// J.4a prereq.2: also accept interface prefixes so extension methods on
// generic interfaces (`Iterable.map`, `Iterator.advanceBy`, ...) are
// recognized as methods whose enclosing type carries type parameters.
// `project.interfaces` is populated by TypeResolution's
// `resolveAllInterfaces` drain before lowering runs; the unresolved map
// is consulted as a belt-and-braces fallback for stdlib-cache paths that
// may have skipped the drain for a particular interface.
function enclosingTypeName(project Project, name String) returns String throws EnclosingTypeError
	let bytes = name.toByteArray()
	let dotByte = 0x2E
	var lastDot = -1
	var i = bytes.count() - 1
	while i >= 0 'scan'
		let b = try bytes.get(i) otherwise panic("invariant: i in [0, bytes.count()) but get failed")
		if b == dotByte 'hit'
			lastDot = i
			break
		end 'hit'
		i = i - 1
	end 'scan'
	if lastDot < 0 'noDot'
		throw EnclosingTypeError.notAMethod
	end 'noDot'
	let prefixBytes = try bytes.slice(0, endIndex: lastDot) otherwise panic("invariant: 0 <= lastDot <= bytes.count() but slice failed")
	let prefix = String.from(prefixBytes)
	if project.structTypes.contains(prefix) 'structHit'
		return prefix
	end 'structHit'
	if project.interfaces.contains(prefix) 'ifaceHit'
		return prefix
	end 'ifaceHit'
	if project.unresolvedInterfaces.contains(prefix) 'unresolvedIfaceHit'
		return prefix
	end 'unresolvedIfaceHit'
	throw EnclosingTypeError.notAMethod
end 'enclosingTypeName'

// Return the runtime helper-function name for a `__ManagedMemory.METHOD`
// builtin. Throws `ManagedMemHelperError.noHelper` when the method is
// handled inline (length / capacity / ...) and therefore has no helper
// dispatch entry. The runtime helpers live in runtime.std and are
// responsible for bounds checking + returning a non-zero variant ordinal
// in the secondary error register (RDX/X1) on failure (sentinel-zero
// primary return).
// Phase 11.0 step 8b helpers (chaseTypealiasInQualifiedCallee, ...) live in
// MaxonDialect.maxon so both TypeResolution and lowering apply the same
// canonicalization to qualified callee names.

function managedMemHelperFor(methodName String) returns String throws ManagedMemHelperError
	// Phase 4 migration: every __managed_mem_* body now lives in
	// stdlib/Internals.maxon. We emit the qualified `stdlib.<name>` callee
	// so the linker resolves to the new bodies. Runtime.std still contains
	// the original copies (kept for C# bootstrap parity); both coexist
	// harmlessly because no other code path references the unqualified
	// runtime names anymore.
	if methodName == "setLength" 'mSetLen'
		return "stdlib.__managed_mem_set_length"
	end 'mSetLen'
	if methodName == "get" 'mGet'
		return "stdlib.__managed_mem_get"
	end 'mGet'
	if methodName == "set" 'mSet'
		return "stdlib.__managed_mem_set"
	end 'mSet'
	if methodName == "remove" 'mRemove'
		return "stdlib.__managed_mem_remove"
	end 'mRemove'
	if methodName == "grow" 'mGrow'
		return "stdlib.__managed_mem_grow"
	end 'mGrow'
	if methodName == "shiftRight" 'mSR'
		return "stdlib.__managed_mem_shift_right"
	end 'mSR'
	if methodName == "shiftLeft" 'mSL'
		return "stdlib.__managed_mem_shift_left"
	end 'mSL'
	if methodName == "byteAt" 'mBA'
		return "stdlib.__managed_mem_byte_at"
	end 'mBA'
	if methodName == "setByte" 'mSB'
		return "stdlib.__managed_mem_set_byte"
	end 'mSB'
	if methodName == "append" 'mApp'
		return "stdlib.__managed_mem_append"
	end 'mApp'
	if methodName == "slice" 'mSlice'
		return "stdlib.__managed_mem_slice"
	end 'mSlice'
	if methodName == "create" 'mCreate'
		return "stdlib.__managed_mem_create"
	end 'mCreate'
	throw ManagedMemHelperError.noHelper
end 'managedMemHelperFor'

enum ManagedMemHelperError implements Error
	noHelper
end 'ManagedMemHelperError'

// Multi-value-return error ABI: which `__managed_mem_*` helpers actually
// throw (i.e. write the error flag in RDX/X1). Throwing helpers must be
// invoked via `StdCallOp.tryCall` so the post-call mov captures the flag.
// `append` (does its own grow, never errors) and `create` (allocator) are
// non-throwing — calling them via plain `call` is correct because the flag
// register is unread by the caller.
function managedMemHelperThrows(methodName String) returns bool
	if methodName == "append" 'mApp'
		return false
	end 'mApp'
	if methodName == "create" 'mCreate'
		return false
	end 'mCreate'
	return true
end 'managedMemHelperThrows'

// Phase 15c Stream 2.3: helper-name map for `__ManagedFile.*` methods. Maps
// the camelCase Maxon method name on `__ManagedFile` to the snake_case
// `mrt_file_*` runtime helper that implements it (Streams 3.1/3.2/3.3 ship
// the real per-target bodies; Stream 2.3 ships sentinel-erroring stubs in
// runtime.std). The names are NOT `stdlib.`-prefixed — these helpers live
// in runtime.std, not in stdlib/Internals.maxon. Throws
// `ManagedFileHelperError.noHelper` when the method isn't one the lowering
// dispatch knows how to route (no inline fast paths exist for file methods,
// so `noHelper` here is a real "unknown method" error).
function managedFileHelperFor(methodName String) returns String throws ManagedFileHelperError
	if methodName == "openRead" 'mOpenRead'
		return "mrt_file_open_read"
	end 'mOpenRead'
	if methodName == "openWrite" 'mOpenWrite'
		return "mrt_file_open_write"
	end 'mOpenWrite'
	if methodName == "openWriteExecutable" 'mOpenWriteExe'
		return "mrt_file_open_write_executable"
	end 'mOpenWriteExe'
	if methodName == "read" 'mRead'
		return "mrt_file_read"
	end 'mRead'
	if methodName == "write" 'mWrite'
		return "mrt_file_write"
	end 'mWrite'
	if methodName == "close" 'mClose'
		return "mrt_file_close"
	end 'mClose'
	if methodName == "exists" 'mExists'
		return "mrt_file_exists"
	end 'mExists'
	if methodName == "delete" 'mDelete'
		return "mrt_file_delete"
	end 'mDelete'
	if methodName == "stat" 'mStat'
		return "mrt_file_stat"
	end 'mStat'
	if methodName == "statField" 'mStatField'
		return "mrt_file_stat_field"
	end 'mStatField'
	if methodName == "statFree" 'mStatFree'
		return "mrt_file_stat_free"
	end 'mStatFree'
	if methodName == "size" 'mSize'
		return "mrt_file_size"
	end 'mSize'
	throw ManagedFileHelperError.noHelper
end 'managedFileHelperFor'

enum ManagedFileHelperError implements Error
	noHelper
end 'ManagedFileHelperError'

// Which `__ManagedFile.*` methods invoke a runtime helper that writes the
// multi-value-return error flag. Throwing helpers must be invoked via
// `StdCallOp.tryCall`; non-throwing helpers via plain `StdCallOp.call`.
// The throws/non-throws split is determined by reading the user-facing
// call sites in `stdlib/File.maxon` — every `try X.method() otherwise ...`
// site marks the helper as throwing.
function managedFileHelperThrows(methodName String) returns bool
	// Non-throwing: close (cleanup, can't fail meaningfully), exists (returns
	// 0/1 directly), statField (pure field read from a stat buffer pointer),
	// statFree (frees the buffer — caller never sees a failure).
	if methodName == "close" 'mClose'
		return false
	end 'mClose'
	if methodName == "exists" 'mExists'
		return false
	end 'mExists'
	if methodName == "statField" 'mStatField'
		return false
	end 'mStatField'
	if methodName == "statFree" 'mStatFree'
		return false
	end 'mStatFree'
	return true
end 'managedFileHelperThrows'

// Phase 15c Stream 2.3: helper-name map for `__ManagedDirectory.*` methods.
// Mirrors `managedFileHelperFor` — see that function's header comment for
// the naming convention and runtime-vs-stdlib distinction.
function managedDirectoryHelperFor(methodName String) returns String throws ManagedDirectoryHelperError
	if methodName == "openSearch" 'mOpenSearch'
		return "mrt_directory_open_search"
	end 'mOpenSearch'
	if methodName == "create" 'mCreate'
		return "mrt_directory_create"
	end 'mCreate'
	if methodName == "currentPath" 'mCurPath'
		return "mrt_directory_current_path"
	end 'mCurPath'
	if methodName == "next" 'mNext'
		return "mrt_directory_next"
	end 'mNext'
	if methodName == "filename" 'mFilename'
		return "mrt_directory_filename"
	end 'mFilename'
	if methodName == "close" 'mClose'
		return "mrt_directory_close"
	end 'mClose'
	if methodName == "exists" 'mExists'
		return "mrt_directory_exists"
	end 'mExists'
	throw ManagedDirectoryHelperError.noHelper
end 'managedDirectoryHelperFor'

enum ManagedDirectoryHelperError implements Error
	noHelper
end 'ManagedDirectoryHelperError'

// Which `__ManagedDirectory.*` methods invoke a runtime helper that writes
// the multi-value-return error flag. Mirrors `managedFileHelperThrows`.
function managedDirectoryHelperThrows(methodName String) returns bool
	// Non-throwing: filename (pure field read on the iterator block),
	// close (cleanup), exists (returns 0/1 directly).
	if methodName == "filename" 'mFilename'
		return false
	end 'mFilename'
	if methodName == "close" 'mClose'
		return false
	end 'mClose'
	if methodName == "exists" 'mExists'
		return false
	end 'mExists'
	return true
end 'managedDirectoryHelperThrows'

// Phase C: helper-name map for `__ManagedList.*` methods. Maps the camelCase
// Maxon method name on `__ManagedList` to the snake_case `mrt_managed_list_*`
// runtime helper that implements it. The helpers live in runtime.std (NOT
// stdlib.-prefixed) and operate directly on the 32-byte list struct + the
// 32-byte node structs allocated by `mm_alloc` from the slab allocator.
// Throws `ManagedListHelperError.noHelper` when the method isn't routed.
function managedListHelperFor(methodName String) returns String throws ManagedListHelperError
	if methodName == "create" 'mCreate'
		return "mrt_managed_list_create"
	end 'mCreate'
	if methodName == "insertFirst" 'mInsertFirst'
		return "mrt_managed_list_insert_first_value"
	end 'mInsertFirst'
	if methodName == "insertLast" 'mInsertLast'
		return "mrt_managed_list_insert_last_value"
	end 'mInsertLast'
	if methodName == "insertAfter" 'mInsertAfter'
		return "mrt_managed_list_insert_after_value"
	end 'mInsertAfter'
	if methodName == "insertBefore" 'mInsertBefore'
		return "mrt_managed_list_insert_before_value"
	end 'mInsertBefore'
	if methodName == "reinsertFirst" 'mReinsertFirst'
		return "mrt_managed_list_reinsert_first"
	end 'mReinsertFirst'
	if methodName == "reinsertLast" 'mReinsertLast'
		return "mrt_managed_list_reinsert_last"
	end 'mReinsertLast'
	if methodName == "reinsertAfter" 'mReinsertAfter'
		return "mrt_managed_list_reinsert_after"
	end 'mReinsertAfter'
	if methodName == "reinsertBefore" 'mReinsertBefore'
		return "mrt_managed_list_reinsert_before"
	end 'mReinsertBefore'
	if methodName == "detach" 'mDetach'
		return "mrt_managed_list_detach"
	end 'mDetach'
	if methodName == "remove" 'mRemove'
		return "mrt_managed_list_remove"
	end 'mRemove'
	if methodName == "head" 'mHead'
		return "mrt_managed_list_head"
	end 'mHead'
	if methodName == "tail" 'mTail'
		return "mrt_managed_list_tail"
	end 'mTail'
	if methodName == "count" 'mCount'
		return "mrt_managed_list_count"
	end 'mCount'
	if methodName == "isEmpty" 'mIsEmpty'
		return "mrt_managed_list_is_empty"
	end 'mIsEmpty'
	if methodName == "clear" 'mClear'
		return "mrt_managed_list_clear"
	end 'mClear'
	if methodName == "cursorReset" 'mCursorReset'
		return "mrt_managed_list_cursor_reset"
	end 'mCursorReset'
	if methodName == "cursorValue" 'mCursorValue'
		return "mrt_managed_list_cursor_value"
	end 'mCursorValue'
	if methodName == "cursorAdvance" 'mCursorAdvance'
		return "mrt_managed_list_cursor_advance"
	end 'mCursorAdvance'
	if methodName == "cursorStart" 'mCursorStart'
		return "mrt_managed_list_cursor_start"
	end 'mCursorStart'
	throw ManagedListHelperError.noHelper
end 'managedListHelperFor'

enum ManagedListHelperError implements Error
	noHelper
end 'ManagedListHelperError'

// Which `__ManagedList.*` methods invoke a runtime helper that writes the
// multi-value-return error flag. Throwing helpers must be invoked via
// `StdCallOp.tryCall`; non-throwing helpers via plain `StdCallOp.call`.
//
// Throwing: head/tail (null when empty -> __ManagedListError.empty),
// cursorStart (null when empty -> empty), cursorAdvance (null when past
// tail -> endOfList).
function managedListHelperThrows(methodName String) returns bool
	if methodName == "head" 'mHead'
		return true
	end 'mHead'
	if methodName == "tail" 'mTail'
		return true
	end 'mTail'
	if methodName == "cursorStart" 'mCursorStart'
		return true
	end 'mCursorStart'
	if methodName == "cursorAdvance" 'mCursorAdvance'
		return true
	end 'mCursorAdvance'
	return false
end 'managedListHelperThrows'

// Phase C: helper-name map for `__ManagedListNode.*` methods. Maps the
// camelCase Maxon method name on `__ManagedListNode` to the snake_case
// `mrt_managed_list_node_*` runtime helper that implements it.
function managedListNodeHelperFor(methodName String) returns String throws ManagedListNodeHelperError
	if methodName == "next" 'mNext'
		return "mrt_managed_list_node_next"
	end 'mNext'
	if methodName == "prev" 'mPrev'
		return "mrt_managed_list_node_prev"
	end 'mPrev'
	if methodName == "value" 'mValue'
		return "mrt_managed_list_node_value"
	end 'mValue'
	if methodName == "setValue" 'mSetValue'
		return "mrt_managed_list_node_set_value"
	end 'mSetValue'
	throw ManagedListNodeHelperError.noHelper
end 'managedListNodeHelperFor'

enum ManagedListNodeHelperError implements Error
	noHelper
end 'ManagedListNodeHelperError'

// Which `__ManagedListNode.*` methods invoke a runtime helper that writes
// the multi-value-return error flag.
//
// Throwing: next/prev (null at end/start of list -> __ManagedListError.endOfList).
// Non-throwing: value (raw value read), setValue (raw value write).
function managedListNodeHelperThrows(methodName String) returns bool
	if methodName == "next" 'mNext'
		return true
	end 'mNext'
	if methodName == "prev" 'mPrev'
		return true
	end 'mPrev'
	return false
end 'managedListNodeHelperThrows'

// Phase D: helper-name map for `__ManagedSocket.*` methods. Maps the
// camelCase Maxon method name on `__ManagedSocket` to the snake_case
// `mrt_managed_socket_*` runtime helper that implements it. The helpers
// live in runtime.std (NOT `stdlib.`-prefixed) and wrap the OS-level
// socket APIs (Winsock on Windows, BSD sockets on Linux/macOS).
// Throws `ManagedSocketHelperError.noHelper` when the method isn't routed.
function managedSocketHelperFor(methodName String) returns String throws ManagedSocketHelperError
	if methodName == "sendFrom" 'mSendFrom'
		return "mrt_managed_socket_send"
	end 'mSendFrom'
	if methodName == "recv" 'mRecv'
		return "mrt_managed_socket_recv"
	end 'mRecv'
	if methodName == "close" 'mClose'
		return "mrt_managed_socket_close"
	end 'mClose'
	if methodName == "tcpConnect" 'mTcpConnect'
		return "mrt_managed_socket_tcp_connect"
	end 'mTcpConnect'
	throw ManagedSocketHelperError.noHelper
end 'managedSocketHelperFor'

enum ManagedSocketHelperError implements Error
	noHelper
end 'ManagedSocketHelperError'

// Which `__ManagedSocket.*` methods invoke a runtime helper that writes
// the multi-value-return error flag. Throwing helpers must be invoked via
// `StdCallOp.tryCall`; non-throwing via plain `StdCallOp.call`.
//
// Throwing: sendFrom (bufferOutOfBounds / sendFailed), recv (recvFailed),
// tcpConnect (resolveFailed / connectFailed).
// Non-throwing: close (idempotent cleanup; the destructor also calls it
// after explicit close()s zero out the handle).
function managedSocketHelperThrows(methodName String) returns bool
	if methodName == "close" 'mClose'
		return false
	end 'mClose'
	return true
end 'managedSocketHelperThrows'

// The set of builtin "handle" type names whose method calls dispatch
// through `lowerManagedHandleBuiltin`. Single source of truth for
// `isManagedHandleReceiver` / `managedHandleReceiverPrefix` /
// `managedHandleHelperFor` / `managedHandleHelperThrows` — the previous
// per-function open-coded cases drifted as new types were added (List,
// ListNode, Socket).
//
// Excludes `__ManagedMemory` (it has its own dispatcher with inline fast
// paths) and `__ManagedMemoryCursor` (it lowers inline to load/store
// sequences).
function managedHandleReceiverNames() returns StringArray
	var names = StringArray.create()
	names.push("__ManagedFile")
	names.push("__ManagedDirectory")
	names.push("__ManagedList")
	names.push("__ManagedListNode")
	names.push("__ManagedSocket")
	return names
end 'managedHandleReceiverNames'

// True iff `name` is the type name of a builtin "handle" type whose method
// calls dispatch through `lowerManagedHandleBuiltin`.
function isManagedHandleReceiver(name String) returns bool
	for h in managedHandleReceiverNames() 'each'
		if name == h 'hit'
			return true
		end 'hit'
	end 'each'
	return false
end 'isManagedHandleReceiver'

// Look up the receiver name in a `Receiver.method` callee string. Returns the
// receiver name when it is one handled by `lowerManagedHandleBuiltin`;
// throws otherwise. Used by the static- and re-route dispatch sites that
// scan a callee string for a known handle prefix.
function managedHandleReceiverPrefix(callee String) returns String throws ManagedHandleHelperError
	for h in managedHandleReceiverNames() 'each'
		if callee.startsWith("{h}.") 'hit'
			return h
		end 'hit'
	end 'each'
	throw ManagedHandleHelperError.noHelper
end 'managedHandleReceiverPrefix'

// Dispatch table keyed on `(receiverName, methodName)`. Routes to the
// per-receiver `managed{X}HelperFor` map and rewraps the error so a single
// `otherwise 'noHelper'` arm at the call site covers every receiver.
function managedHandleHelperFor(receiverName String, methodName String) returns String throws ManagedHandleHelperError
	if receiverName == "__ManagedFile" 'mf'
		return try managedFileHelperFor(methodName) otherwise throw ManagedHandleHelperError.noHelper
	end 'mf'
	if receiverName == "__ManagedDirectory" 'md'
		return try managedDirectoryHelperFor(methodName) otherwise throw ManagedHandleHelperError.noHelper
	end 'md'
	if receiverName == "__ManagedList" 'ml'
		return try managedListHelperFor(methodName) otherwise throw ManagedHandleHelperError.noHelper
	end 'ml'
	if receiverName == "__ManagedListNode" 'mln'
		return try managedListNodeHelperFor(methodName) otherwise throw ManagedHandleHelperError.noHelper
	end 'mln'
	if receiverName == "__ManagedSocket" 'ms'
		return try managedSocketHelperFor(methodName) otherwise throw ManagedHandleHelperError.noHelper
	end 'ms'
	throw ManagedHandleHelperError.noHelper
end 'managedHandleHelperFor'

enum ManagedHandleHelperError implements Error
	noHelper
end 'ManagedHandleHelperError'

// Dispatch table for the throws-set, keyed on `(receiverName, methodName)`.
// Returns false for any unknown receiver (defensive — the call site only
// reaches here after `managedHandleHelperFor` succeeded).
function managedHandleHelperThrows(receiverName String, methodName String) returns bool
	if receiverName == "__ManagedFile" 'mf'
		return managedFileHelperThrows(methodName)
	end 'mf'
	if receiverName == "__ManagedDirectory" 'md'
		return managedDirectoryHelperThrows(methodName)
	end 'md'
	if receiverName == "__ManagedList" 'ml'
		return managedListHelperThrows(methodName)
	end 'ml'
	if receiverName == "__ManagedListNode" 'mln'
		return managedListNodeHelperThrows(methodName)
	end 'mln'
	if receiverName == "__ManagedSocket" 'ms'
		return managedSocketHelperThrows(methodName)
	end 'ms'
	return false
end 'managedHandleHelperThrows'

// Strip a leading `prefix` from `s` and return the remainder. Throws
// `StripPrefixError.noMatch` when the string doesn't begin with prefix.
// Used by static-method dispatch (`__ManagedMemory.create(...)`) to
// recover the bare method name.
function stripPrefix(s String, prefix String) returns String throws StripPrefixError
	if not s.startsWith(prefix) 'noMatch'
		throw StripPrefixError.noMatch
	end 'noMatch'
	let bytes = s.toByteArray()
	let prefixLen = prefix.byteLength()
	let suffixBytes = try bytes.slice(prefixLen, endIndex: bytes.count()) otherwise panic("invariant: startsWith(prefix) but slice(prefixLen, end) failed")
	return String.from(suffixBytes)
end 'stripPrefix'

enum StripPrefixError implements Error
	noMatch
end 'StripPrefixError'

// --- NameToValueIdMap ------------------------------------------------------
//
// Per-function map from a Maxon-IR value name (a `ByteArray` slice — either
// over the lexer's source buffer for user-written variables, or a synthetic
// `$tN` name for intermediates) to the dense Std-level ValueId that the
// Maxon→Std lowering has assigned it.
//
// Implementation: a real hash Map keyed on `ByteArray`. ByteArray is
// `Array<Byte>` and `Array` conditionally implements Hashable+Equatable
// when its element does, which Byte does — so we get O(1) get/put without
// any custom hashing. Hot-path callers (`resolveName` / `defineName` /
// `aliasName`) hit this map on every Maxon op being lowered, so any
// per-element scan would compound across thousands of ops per function.

export typealias NameToValueIdMap = Map with (ByteArray, ValueId)

// Byte-sequence equality. `ByteArray` is `Array with Byte`, and `Array`
// does not today expose a generic `==` over slices — this little helper
// is all we need for the per-function map hot path.
export function byteArraysEqual(a ByteArray, b ByteArray) returns bool
	if a.count() != b.count() 'len'
		return false
	end 'len'
	for i in 0 upto a.count() 'each'
		let x = try a.get(i) otherwise panic("invariant: i < a.count() but get failed")
		let y = try b.get(i) otherwise panic("invariant: i < a.count() == b.count() but get failed")
		if x != y 'ne'
			return false
		end 'ne'
	end 'each'
	return true
end 'byteArraysEqual'

// ============================================================
// Helper functions
// ============================================================

function literalToArithOpcode(project Project, valueType MaxonType) returns StdArithConstOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: valueType)) 'f'
		return StdArithConstOpcode.constF64
	end 'f'
	return StdArithConstOpcode.constI64
end 'literalToArithOpcode'

function binOpKindToArithOpcode(project Project, opKind BinOpKind, operandType MaxonType) returns StdArithBinaryOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: operandType)) 'floatOp'
		return floatBinOpKindToArithOpcode(opKind)
	end 'floatOp'
	return match opKind 'map'
		add gives StdArithBinaryOpcode.addI64
		sub gives StdArithBinaryOpcode.subI64
		mul gives StdArithBinaryOpcode.mulI64
		div gives StdArithBinaryOpcode.divI64
		mod gives StdArithBinaryOpcode.remI64
		bitAnd gives StdArithBinaryOpcode.andI64
		bitOr gives StdArithBinaryOpcode.orI64
		boolOr gives StdArithBinaryOpcode.orI1
		bitXor gives StdArithBinaryOpcode.xorI64
		shl gives StdArithBinaryOpcode.shlI64
		shr gives StdArithBinaryOpcode.shrI64
	end 'map'
end 'binOpKindToArithOpcode'

function floatBinOpKindToArithOpcode(opKind BinOpKind) returns StdArithBinaryOpcode
	match opKind 'dispatch'
		add then return StdArithBinaryOpcode.addF64
		sub then return StdArithBinaryOpcode.subF64
		mul then return StdArithBinaryOpcode.mulF64
		div then return StdArithBinaryOpcode.divF64
		mod to shr then panic("floatBinOpKindToArithOpcode: bitwise/mod ops not supported on floats")
	end 'dispatch'
end 'floatBinOpKindToArithOpcode'

// True when the opcode has a float-family variant. Bitwise / mod ops are
// integer-only, so even if the declared operandType resolves to float the
// op must stay on int operands (and the parser already guarantees that by
// forcing operandType to integer for these ops).
function binOpSupportsFloat(opKind BinOpKind) returns bool
	return match opKind 'check'
		add gives true
		sub gives true
		mul gives true
		div gives true
		mod gives false
		bitAnd gives false
		bitOr gives false
		boolOr gives false
		bitXor gives false
		shl gives false
		shr gives false
	end 'check'
end 'binOpSupportsFloat'

function unaryOpKindToArithOpcode(opKind UnaryOpKind) returns StdArithUnaryOpcode
	match opKind 'verify'
		neg then break 'verify'
		bitNot then break 'verify'
		logicalNot then panic("unaryOpKindToArithOpcode: logicalNot is handled inline by lowerUnop and must not reach this opcode map")
	end 'verify'
	return match opKind 'map'
		neg gives StdArithUnaryOpcode.negI64
		bitNot gives StdArithUnaryOpcode.bitNotI64
		logicalNot gives StdArithUnaryOpcode.bitNotI64
	end 'map'
end 'unaryOpKindToArithOpcode'

function cmpPredicateToArithOpcode(project Project, predicate CmpPredicate, operandType MaxonType) returns StdArithBinaryOpcode
	if stdTypeIsFloat(maxonTypeToStdType(project, ref: operandType)) 'f'
		return match predicate 'floatOp'
			eq gives StdArithBinaryOpcode.cmpF64Eq
			ne gives StdArithBinaryOpcode.cmpF64Ne
			lt gives StdArithBinaryOpcode.cmpF64Lt
			le gives StdArithBinaryOpcode.cmpF64Le
			gt gives StdArithBinaryOpcode.cmpF64Gt
			ge gives StdArithBinaryOpcode.cmpF64Ge
		end 'floatOp'
	end 'f'
	return match predicate 'intOp'
		eq gives StdArithBinaryOpcode.cmpI64Eq
		ne gives StdArithBinaryOpcode.cmpI64Ne
		lt gives StdArithBinaryOpcode.cmpI64Lt
		le gives StdArithBinaryOpcode.cmpI64Le
		gt gives StdArithBinaryOpcode.cmpI64Gt
		ge gives StdArithBinaryOpcode.cmpI64Ge
	end 'intOp'
end 'cmpPredicateToArithOpcode'

function refEqOpcode(negate bool) returns StdArithBinaryOpcode
	if negate 'ne'
		return StdArithBinaryOpcode.cmpI64Ne
	end 'ne'
	return StdArithBinaryOpcode.cmpI64Eq
end 'refEqOpcode'

function predicateIsEqOrNe(predicate CmpPredicate) returns bool
	return match predicate 'p'
		eq gives true
		ne gives true
		lt gives false
		le gives false
		gt gives false
		ge gives false
	end 'p'
end 'predicateIsEqOrNe'

function predicateIsNe(predicate CmpPredicate) returns bool
	return match predicate 'p'
		ne gives true
		eq gives false
		lt gives false
		le gives false
		gt gives false
		ge gives false
	end 'p'
end 'predicateIsNe'

// Pick the element MaxonType of a __ManagedMemory receiver. Returns
// `unresolved` for any non-genericInstance receiver (cursor calls,
// constrained generic receivers, …) — `signExtendApplies` then short-
// circuits, leaving the call result as-is.
function signExtendElementType(project Project, receiverType MaxonType) returns MaxonType
	return match receiverType 'pick'
		genericInstance(gid) gives firstGenericArgOf(project, gid: gid)
		boolean to function gives MaxonType.unresolved
		unresolved gives MaxonType.unresolved
		typeParameter gives MaxonType.unresolved
		interface to opaquePointer gives MaxonType.unresolved
	end 'pick'
end 'signExtendElementType'

// Pull the first type-arg of a generic instance. Mirrors
// TypeResolution.firstGenericArg but lives here so LowerMaxonToStd
// doesn't pull TypeResolution into its call graph.
function firstGenericArgOf(project Project, gid GenericInstanceId) returns MaxonType
	let (_, args) = project.genericInstances.get(gid)
	return try args.get(0) otherwise MaxonType.unresolved
end 'firstGenericArgOf'

// Phase 15e: identify a `genericInstance(__TupleN, [...])` receiver. Used to
// gate the typeParameter-substitution path in lowerFieldLoad/lowerFieldStore
// so we never collapse a non-tuple struct's typeParameter to
// `MaxonType.unresolved` via a missed substitution binding.
function receiverIsTupleGenericInstance(project Project, t MaxonType) returns bool
	let baseName = match t 'pick'
		genericInstance(id) gives tupleGenericInstanceBaseName(project, gid: id)
		boolean to string gives ""
		named gives ""
		function gives ""
		unresolved gives ""
		typeParameter gives ""
		interface to opaquePointer gives ""
	end 'pick'
	if baseName.isEmpty() 'notGeneric'
		return false
	end 'notGeneric'
	if not baseName.startsWith("__Tuple") 'notTuple'
		return false
	end 'notTuple'
	return true
end 'receiverIsTupleGenericInstance'

function tupleGenericInstanceBaseName(project Project, gid GenericInstanceId) returns String
	let (baseId, _) = project.genericInstances.get(gid)
	return project.typeNames.get(baseId)
end 'tupleGenericInstanceBaseName'

// Phase 15e: pick the resolved field type for a struct's `fieldLoad` /
// `fieldStore` against a tuple receiver. Substitution is gated to tuple
// receivers so it doesn't drag typeParameter fields on other generic
// receivers (Array, Map, ...) through a missed-binding lookup that would
// return `MaxonType.unresolved`.
function pickTupleFieldType(project Project, raw MaxonType, receiverType MaxonType) returns MaxonType
	if not receiverIsTupleGenericInstance(project, t: receiverType) 'notTuple'
		return raw
	end 'notTuple'
	return substituteReturnTypeViaReceiver(project, raw: raw, receiverContext: receiverType)
end 'pickTupleFieldType'

// Phase 11.7: substitute a struct field's declared type through the receiver
// when the receiver is a fully concrete generic instance. Returns `raw`
// unchanged for non-generic receivers, tuple receivers (handled by the
// `pickTupleFieldType` legacy path), or receivers whose args still mention
// type parameters (extension methods on a generic struct see the receiver as
// `Array<typeParameter(Element)>`, where substituting would collapse to
// `MaxonType.unresolved`). This is the gate that lets `WrapperHolder.item`
// surface as `Wrapper` rather than as the unsubstituted `typeParameter(T)`,
// which downstream method-call lowering would route through the type-param
// dispatch stub.
function pickFieldTypeViaReceiver(project Project, raw MaxonType, receiverType MaxonType) returns MaxonType
	if receiverIsTupleGenericInstance(project, t: receiverType) 'tupleReceiver'
		return substituteReturnTypeViaReceiver(project, raw: raw, receiverContext: receiverType)
	end 'tupleReceiver'
	if not maxonTypeIsConcreteGenericInstance(project, t: receiverType) 'notConcrete'
		return raw
	end 'notConcrete'
	let substituted = substituteReturnTypeViaReceiver(project, raw: raw, receiverContext: receiverType)
	// Defensive: a typeParameter raw whose param-name isn't in the receiver's
	// substitution table comes back as `MaxonType.unresolved` from
	// `substituteType`. Fall back to `raw` in that case so we don't hand the
	// downstream loader an unresolved field type.
	if maxonTypeIsUnresolved(substituted) 'fellThrough'
		return raw
	end 'fellThrough'
	return substituted
end 'pickFieldTypeViaReceiver'

// True when `t` is a `genericInstance` whose args contain no
// `typeParameter` arm at the top level. Conservative: doesn't recurse into
// nested generic instances, since the current substitution machinery only
// resolves one level deep.
function maxonTypeIsConcreteGenericInstance(project Project, t MaxonType) returns bool
	let isGeneric = match t 'isGen'
		genericInstance gives true
		boolean gives false
		integer gives false
		float gives false
		string gives false
		named gives false
		function gives false
		unresolved gives false
		typeParameter gives false
		interface to opaquePointer gives false
	end 'isGen'
	if not isGeneric 'notGeneric'
		return false
	end 'notGeneric'
	let gid = match t 'extractGid'
		genericInstance(id) gives id
		boolean gives 0 as GenericInstanceId
		integer gives 0
		float gives 0
		string gives 0
		named gives 0
		function gives 0
		unresolved gives 0
		typeParameter gives 0
		interface to opaquePointer gives 0
	end 'extractGid'
	let (_, args) = project.genericInstances.get(gid)
	for i in 0 upto args.count() 'eachArg'
		let arg = try args.get(i) otherwise panic("maxonTypeIsConcreteGenericInstance: args.get OOB at {i}")
		if maxonTypeMentionsTypeParam(arg) 'hasParam'
			return false
		end 'hasParam'
	end 'eachArg'
	return true
end 'maxonTypeIsConcreteGenericInstance'

function maxonTypeIsUnresolved(t MaxonType) returns bool
	return match t 'extract'
		unresolved gives true
		boolean to function gives false
		typeParameter to opaquePointer gives false
	end 'extract'
end 'maxonTypeIsUnresolved'

// Substitute type parameters in `raw` (the callee's declared return type)
// through the receiver context's generic-instance args. Mirrors what
// `methodCallResultType` does at TypeResolution time, but happens at
// lowering time where the `producerTypes` map is no longer live. The
// `raw` type might mention `typeParameter(Element)`; the receiver
// context might bind `Element -> Signal`. Returns `raw` unchanged when
// no substitution applies (non-generic receiver, primitive return
// type, …).
//
// Three transforms applied in order so the result tracks TR exactly:
//   1. Inner-alias chase via the receiver's struct: `MapIterator.current()`
//      returns the parser-shape `named(Entry)` which only resolves to the
//      `(Key, Value)` tuple after consulting MapIterator's `innerAliases`.
//   2. `Self`-shape promotion: `named(EnclosingType)` -> the receiver's
//      genericInstance so substitution flows through the receiver's args.
//   3. Bare-generic promotion to the receiver's struct scope: `named(GT)`
//      where `GT` is itself generic and shares param names with the
//      enclosing type — paired so the upcoming substitution binds the
//      types through the receiver. Mirrors
//      `promoteBareGenericReturnToScope` in TypeResolution.
//   4. typeParameter substitution via the receiver's bindings.
// Without (1), `for (_, v) in m` on a `Map<K, V>` lowers a fieldLoad on
// `named(Entry)` and reports "unknown field '_0' on type 'Entry'"; without
// (3), `Map.createIterator()` (returns bare `MapIterator`) hits
// `forwardCallerLayout` because the iterator slot's lowering-side type
// stays `named(MapIterator)` and the call-site context for `iter.advance()`
// has no concrete gid to materialize a layout from.
function substituteReturnTypeViaReceiver(project Project, raw MaxonType, receiverContext MaxonType) returns MaxonType
	let receiverStructName = try maxonTypeStructName(project, t: receiverContext) otherwise ""
	let aliasResolved = applyInnerAliasFromReceiverStruct(project, t: raw, receiverStructName: receiverStructName)
	let selfPromoted = promoteNamedToGenericInstance(project, raw: aliasResolved, candidate: receiverContext)
	let scopePromoted = promoteBareGenericReturnToReceiverScope(project, t: selfPromoted, receiverStructName: receiverStructName)
	let subst = buildSubstitutionForInstance(project, t: receiverContext)
	return substituteType(project, t: scopePromoted, subst: subst)
end 'substituteReturnTypeViaReceiver'

// Mirror of `TypeResolution.applyInnerAliasFromReceiver`: chase the
// receiver's struct innerAliases. Lowering-side independent copy so this
// file's signature surface stays self-contained.
function applyInnerAliasFromReceiverStruct(project Project, t MaxonType, receiverStructName String) returns MaxonType
	if receiverStructName.isEmpty() 'noStruct'
		return t
	end 'noStruct'
	let st = try project.structTypes.get(receiverStructName) otherwise return t
	if st.innerAliases.count() == 0 'noAliases'
		return t
	end 'noAliases'
	return applyInnerAliasIfNamed(project, t: t, innerAliases: st.innerAliases)
end 'applyInnerAliasFromReceiverStruct'

// Lowering-side mirror of `TypeResolution.promoteBareGenericReturnToScope`:
// promote `named(X)` to `genericInstance(X, [typeParameter(<scope>, p)...])`
// when X is generic and the enclosing scope declares the same param names.
// Necessary at lowering time because `recordCallResultType` runs against
// `funcReturnTypes` (parser-shape) rather than TR's already-resolved
// producer type — without this, a non-generic caller hitting a generic
// stdlib method that returns a bare-generic name loses the args and
// downstream layout/witness materialization can't recover them.
function promoteBareGenericReturnToReceiverScope(project Project, t MaxonType, receiverStructName String) returns MaxonType
	if not maxonTypeIsNamed(t) 'notNamed'
		return t
	end 'notNamed'
	if receiverStructName.isEmpty() 'noScope'
		return t
	end 'noScope'
	let targetName = t.nameOrEmpty(project)
	if targetName.isEmpty() 'noName'
		return t
	end 'noName'
	let targetParams = project.typeParameters.getParamNames(targetName)
	if targetParams.count() == 0 'notGeneric'
		return t
	end 'notGeneric'
	var args = MaxonTypeArray.create()
	for i in 0 upto targetParams.count() 'eachParam'
		let pname = try targetParams.get(i) otherwise panic("promoteBareGenericReturnToReceiverScope: targetParams.get OOB at {i}")
		if not project.typeParameters.contains(receiverStructName, paramName: pname) 'missingInScope'
			return t
		end 'missingInScope'
		let pid = project.typeParameters.intern(receiverStructName, paramName: pname)
		args.push(MaxonType.typeParameter(pid))
	end 'eachParam'
	let baseId = project.typeNames.intern(targetName)
	let gid = project.genericInstances.intern(baseId, args: args)
	return MaxonType.genericInstance(gid)
end 'promoteBareGenericReturnToReceiverScope'

// True when an `__managed_mem_get` result should be sign-extended to fill
// the i64 register. Holds for signed narrow integer types (`i8`, `i16`,
// `i32`); the qword case is a no-op, the unsigned cases zero-extend
// already, floats are unaffected.
function signExtendApplies(project Project, elementType MaxonType) returns bool
	let signedNamed = match elementType 'arm'
		named gives stdTypeIsSigned(resolveMaxonTypeToStd(project, ref: elementType))
		integer gives false
		boolean gives false
		float gives false
		string gives false
		function to opaquePointer gives false
	end 'arm'
	if not signedNamed 'notSigned'
		return false
	end 'notSigned'
	let width = storeWidthBytes(storeWidthOfStdType(resolveMaxonTypeToStd(project, ref: elementType)))
	return width < 8
end 'signExtendApplies'

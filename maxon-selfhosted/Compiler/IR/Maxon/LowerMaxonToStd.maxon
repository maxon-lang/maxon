// LowerMaxonToStd (Phase 3): single unified Maxon → Std lowering.
// Takes a MaxonModule and produces a fresh StdModule.
//
// **SSA is born here.** Maxon IR ops identify values by `ByteArray` names
// (zero-copy slices over the source buffer for user-written variables, or
// per-function synthetic `$tN` names for intermediates). This pass is the
// first place those names are assigned dense, function-local `ValueId`s.
//
// Per function:
//   - funcIdRef: a fresh `ValueIdRef` starting at `paramCount` (parameters
//     implicitly occupy ValueIds 0..paramCount-1 in the Std dialect ABI).
//   - nameToId: a linear-scan parallel-array map keyed on `ByteArray`
//     byte-sequence equality. Each Maxon op with a `result` name allocates
//     a fresh ValueId and records `nameToId[name] = id`. Each operand read
//     looks up the name; a miss means an unresolved reference (parser bug
//     or an `error` op we haven't yet introduced) and emits a compile-error
//     diagnostic, with a placeholder ValueId fabricated to keep subsequent
//     use-def structure consistent.
//
// Width/signedness collapse also happens here: MaxonType fields on Maxon ops
// are translated to StdType via maxonTypeToStdType. For this initial
// redesign, integer and float arithmetic promote to i64/f64 at the Std
// level (matching current behavior); narrow-width opcodes can be added later.
//
// Lowers:
//   maxon.literal        -> std.arith.const
//   maxon.binop          -> std.arith.binary
//   maxon.unop           -> std.arith.unary
//   maxon.convert        -> std.arith.unary (fpToSiI64 / siToFpF64) or pure name alias
//   maxon.cmp            -> std.arith.binary (comparison)
//   maxon.refEq          -> std.arith.binary (comparison)
//   maxon.varDecl/Store  -> std.memory.storeSlot
//   maxon.varLoad        -> std.memory.loadSlot
//   maxon.condBr/br      -> std.control.condBr/br
//   maxon.call/ret       -> std.call.call/ret
//   maxon.panic          -> std.system.globalAddr + std.call.call mrt_panic
//   maxon.structAlloc    -> std.call.call mrt_alloc
//   maxon.fieldLoad      -> std.system.loadIndirect
//   maxon.fieldStore     -> std.system.storeIndirect

// Each function produces a fresh per-function `ValueIdRef` inside `lower()`,
// so this entry point takes no shared counter — SSA numbering is born here.
//
// Panic-label minting happens through `pipeline.panicLabelFor(message)`, which
// returns a content-derived `__panic_msg_<hash>` / `__stdlib_panic_msg_<hash>`
// name (a hash of the message bytes), shared with insertRangeChecks. Being
// content-derived rather than counter-derived makes the label independent of
// lowering order — required for the demand-driven stdlib cache.
export function lowerMaxonToStd(pipeline PassPipeline, maxonModule MaxonModule, project Project, globalData GlobalDataTable) returns StdModule
	return MaxonToStdLowering.create(pipeline, maxonModule: maxonModule, project: project, globalData: globalData).lower()
end 'lowerMaxonToStd'

// Phase 9 Stage 1: backing set for `pendingEnumNameHelpers`. A plain string
// set; the lowering pass writes one entry per enum that participates in a
// `.name` field-load. Synthesis at the tail of `lower()` walks the set and
// emits one helper per enum.
typealias EnumNameHelperSet = Set with String

// Phase 9 Stage 4: parallel arrays of (tag-value, target-block-id) pairs
// consumed by `emitTagSwitch`. Tag values are `IntConstant` because the
// caller (destructor synthesizer) reads them out of `EnumCase.ordinal`,
// which is range-typed in the same domain.
typealias TagValueArray = Array with IntConstant

// Phase 9 Stage 1: linker symbol for the synthesized `.name` helper. The
// `__enum_<EnumName>_name` prefix avoids collision with any user-declared
// `<EnumName>.method` symbol (which would dot-qualify) and matches the
// `__field_init_*` naming convention used for other parser-synthesized
// helpers.
function enumNameHelperSymbol(enumName String) returns String
	return "__enum_{enumName}_name"
end 'enumNameHelperSymbol'

// Linker symbol for the synthesized `.rawValue` helper of a string/char-backed
// enum. Maps the receiver's runtime ordinal to the case's declared backing
// String / Character literal. Mirrors `enumNameHelperSymbol`'s naming.
function enumRawStringHelperSymbol(enumName String) returns String
	return "__enum_{enumName}_rawString"
end 'enumRawStringHelperSymbol'

// Linker symbol for the synthesized function-backed-enum `.rawValue` helper.
// One per fn-backed enum: takes the ordinal i64 and returns a function
// pointer (i64). Body is the cmp/condBr chain over case ordinals; each leaf
// returns `funcRef(thunk_for_case_function)`.
function enumFnRawHelperSymbol(enumName String) returns String
	return "__enum_{enumName}_fnRaw"
end 'enumFnRawHelperSymbol'

// Phase 9 Stage 4: linker symbol for a synthesized union destructor. Matches
// the convention used by the runtime's `__destruct___ManagedMemory` so wasm
// `funcAddr` fixups and the X64/Arm64 backends find a uniform name shape
// for every destructor that may end up referenced by `mm_alloc`.
function unionDestructorSymbol(unionName String) returns String
	return "__destruct_{unionName}"
end 'unionDestructorSymbol'

// Phase 9 Stage 4: true when at least one case of `unionType` carries a
// managed payload field that must be `mm_decref`'d when the union value
// dies. Drives both the destructor-synthesis decision (skip emission for
// scalar-only unions) and `lowerEnumConstruct`'s funcRef-vs-null choice
// for the `mm_alloc(size, dtor, tag)` destructor argument.
function unionHasManagedPayload(project Project, unionType EnumType) returns bool
	for c in unionType.cases 'scanCases'
		for f in c.payloadFields 'scanFields'
			if maxonTypeIsManagedRef(project, t: f.fieldType) 'isManaged'
				return true
			end 'isManaged'
		end 'scanFields'
	end 'scanCases'
	return false
end 'unionHasManagedPayload'

// Phase 9 Stage 1: true when every case's rawValue equals its declaration
// ordinal — the receiver's SSA value carries the rawValue, so on such an
// enum the `.ordinal` accessor is a value-level no-op. Int-backed enums
// with explicit raw values that happen to match ordinals (e.g. `red=0`)
// still get folded onto the no-op path here. Float-backed enums always
// require the lookup since their rawValue is a bit pattern, not the ordinal.
function enumIsOrdinalBacked(enumType EnumType) returns bool
	if enumType.isFloatBacked 'isFloat'
		return false
	end 'isFloat'
	for i in 0 upto enumType.cases.count() 'each'
		let c = try enumType.cases.get(i) otherwise panic("enumIsOrdinalBacked: cases.get OOB at {i}")
		if c.rawValue != i as IntConstant 'mismatch'
			return false
		end 'mismatch'
	end 'each'
	return true
end 'enumIsOrdinalBacked'

// Convert a source-level qualified name into the linker symbol that backs the
// global in the writable .data section. The `__data_` prefix is what the x64
// and arm64 backends pattern-match on to pick the dataSection relocation kind
// (see `relocKindForLabel` in X64Backend.maxon).
export function dataSymbolName(qualifiedName String) returns String
	return "__data_{qualifiedName}"
end 'dataSymbolName'

// Encode a 64-bit value as a little-endian 8-byte ByteArray, suitable for an
// initial value in the .data section.
function encodeI64LE(value IntConstant) returns ByteArray
	var bytes = ByteArray.create()
	writeQword(bytes, value: value)
	return bytes
end 'encodeI64LE'

// Walk project.topLevelVars and feed each one into globalData's
// data-section table. Idempotent across multiple lowering runs against the
// same project because lowerMaxonToStd creates a fresh GlobalDataTable per
// build. The exported function name keeps "Globals" because the data
// section itself is link-time-global storage; the source-level decls that
// land here may or may not be `export`ed.
export function registerGlobalVarsForDataSection(project Project, globalData GlobalDataTable)
	for (_, info) in project.topLevelVars 'eachVar'
		let symbol = dataSymbolName(info.name)
		let initialBytes = encodeI64LE(info.initialValue)
		addDataSectionEntry(globalData, name: symbol, initialBytes: initialBytes)
	end 'eachVar'
end 'registerGlobalVarsForDataSection'

// C1.b: snapshot per-slot MaxonTypes by walking the function's Maxon ops.
// The Scope's persistent VarInfoMap drops block-scoped names on popScope,
// so iterating `scope.allVars()` would miss any slot whose declaring scope
// has been closed. The Maxon-level varDecl op carries the source-level
// MaxonType directly, so we walk every block once and stamp the type at
// the slot's index. Slots without a varDecl (parameters, self-field
// aliases) get MaxonType.integer as a benign filler — consumers
// (InjectDrops C1.b) only key off MaxonType.typeParameter, which never
// appears for those slots.
function collectSlotMaxonTypes(func IrFunction, maxonModule MaxonModule) returns MaxonTypeArray
	var result = MaxonTypeArray.create()
	let nextSlot = func.scope.nextSlot
	if nextSlot == 0 'noSlots'
		return result
	end 'noSlots'
	for _ in 0 upto nextSlot 'fill'
		result.push(MaxonType.integer)
	end 'fill'
	// C1.d: seed interface-typed parameter slots from `maxonParamTypes`
	// so `function f(g Greeter)`'s slot 0 is recognized as a fat-pointer
	// by `extendSlotsForInterfaceWitnesses`. Without this, parameter
	// slots fall through to the integer filler and the witness-companion
	// slot is never allocated — a downstream varLoad of `g` would then
	// hit the no-companion panic. Restricted to interface arms only so
	// no existing pass (InjectDrops keys off `typeParameter`) inherits a
	// new behavior for non-interface params.
	// slot<->abi decoupling: maxonParamTypes is the ABI vector indexed by ABI
	// index, but `result` is indexed by SCOPE slot id. Translate each interface
	// param's ABI index to its scope slot via abiParamIndexToScopeSlot before
	// seeding. Functions with empty maps (closures / synthesized) fall through
	// the count guard.
	let paramSlotCount = func.maxonParamTypes.count()
	for pIdx in 0 upto paramSlotCount 'eachParam'
		let pType = try func.maxonParamTypes.get(pIdx) otherwise continue
		if not interfaceTypeIsFat(pType) 'notInterface'
			continue
		end 'notInterface'
		if pIdx >= func.abiParamIndexToScopeSlot.count() 'noMapEntry'
			continue
		end 'noMapEntry'
		let scopeSlot = try func.abiParamIndexToScopeSlot.get(pIdx) otherwise continue
		if scopeSlot >= nextSlot 'beyondAllocated'
			continue
		end 'beyondAllocated'
		try result.set(scopeSlot, value: pType) otherwise panic("collectSlotMaxonTypes: result.set OOB at scope slot {scopeSlot} (nextSlot={nextSlot})")
	end 'eachParam'
	for blockRef in func.blockRefs 'eachBlock'
		let block = try maxonModule.blocks.get(blockRef) otherwise panic("collectSlotMaxonTypes: blockRef {blockRef} OOB (count={maxonModule.blocks.count()})")
		for opIdx in block.opRefs 'eachOp'
			let op = try maxonModule.ops.get(opIdx) otherwise continue
			recordSlotTypeFromOp(op, slotMaxonTypes: result, nextSlot: nextSlot)
		end 'eachOp'
	end 'eachBlock'
	return result
end 'collectSlotMaxonTypes'

function recordSlotTypeFromOp(op MaxonOp, slotMaxonTypes MaxonTypeArray, nextSlot VarSlot)
	if op.name != "varDecl" 'notVarDecl'
		return
	end 'notVarDecl'
	match op 'check'
		varDecl(slotId, _, slotType, _) then recordSlotType(slotMaxonTypes, slotId: slotId, slotType: slotType, nextSlot: nextSlot)
		default panic("recordSlotTypeFromOp: op.name == varDecl but match did not extract")
	end 'check'
end 'recordSlotTypeFromOp'

function recordSlotType(slotMaxonTypes MaxonTypeArray, slotId VarSlot, slotType MaxonType, nextSlot VarSlot)
	if slotId >= nextSlot 'oob'
		return
	end 'oob'
	try slotMaxonTypes.set(slotId, value: slotType) otherwise panic("recordSlotType: slotMaxonTypes.set OOB despite slotId < nextSlot")
end 'recordSlotType'

// C1.c/d: walk the function's recorded slot MaxonTypes and, for every
// interface-typed slot, ensure a witness-pointer companion slot exists.
//
// PARAM slots (those present in `scopeSlotToAbiParamIndex`): the parser
// reserved their witness companion scope slot (recorded in paramReservations);
// nothing to append — rely on the existing reserved slot.
//
// LOCAL slots (absent from `scopeSlotToAbiParamIndex`): append a fresh trailing
// slot. Bumps `func.scope.nextSlot` and pushes a `MaxonType.integer` filler.
//
// slot<->abi decoupling: param classification is by map membership, not a
// `slotId < paramCount` boundary. The old boundary test mis-classified a local
// interface slot whose id happened to fall below the `transferFuncs`-augmented
// ABI count as a param (e.g. a `for item in self` loop slot once an implicit
// layout param shifted the boundary); membership in the parser-built map is
// exact and immune to those later ABI augmentations.
function extendSlotsForInterfaceWitnesses(func IrFunction)
	let originalSlotCount = func.slotMaxonTypes.count()
	if originalSlotCount == 0 'noSlots'
		return
	end 'noSlots'
	// slot<->abi decoupling: a PARAM scope slot is a key in
	// scopeSlotToAbiParamIndex (its witness companion was reserved by the
	// parser and recorded in paramReservations). Only LOCAL interface slots
	// (absent from the map) need a fresh trailing companion appended here.
	for slotId in 0 upto originalSlotCount 'eachSlot'
		let slotType = try func.slotMaxonTypes.get(slotId) otherwise continue
		if not interfaceTypeIsFat(slotType) 'notInterface'
			continue
		end 'notInterface'
		if func.scopeSlotToAbiParamIndex.contains(slotId) 'isParam'
			logTrace(LogCategory.ir, message: function() gives "extendSlotsForInterfaceWitnesses: param slot_{slotId} interface — using reserved witness companion")
			continue
		end 'isParam'
		logTrace(LogCategory.ir, message: function() gives "extendSlotsForInterfaceWitnesses: local slot_{slotId} interface — appending witness companion at slot_{func.scope.nextSlot}")
		func.slotMaxonTypes.push(MaxonType.opaquePointer)
		func.scope.nextSlot = func.scope.nextSlot + 1
	end 'eachSlot'
end 'extendSlotsForInterfaceWitnesses'

// C1.c/d: rebuild the per-function `interfaceWitnessSlots` side map
// (interface scope slot -> witness companion scope slot).
//
// slot<->abi decoupling: PARAM interface slots take their witness companion
// from the parser's paramReservations (companionKind == witness), NOT slotId+1.
// LOCAL interface slots (absent from scopeSlotToAbiParamIndex) get a trailing
// companion appended by extendSlotsForInterfaceWitnesses, walked here in the
// same iteration order so the ids line up.
function buildInterfaceWitnessSlotMap(func IrFunction) returns InterfaceWitnessSlotMap
	var map = InterfaceWitnessSlotMap.create()
	let totalSlots = func.slotMaxonTypes.count()
	if totalSlots == 0 'noSlots'
		return map
	end 'noSlots'

	// Param interface slots: pair from reservations.
	for ri in 0 upto func.paramReservations.count() 'eachReservation'
		let reservation = try func.paramReservations.get(ri) otherwise continue
		if reservation.hasWitnessCompanion() 'paramWitness'
			map.upsert(reservation.paramSlot, value: reservation.companionSlot)
		end 'paramWitness'
	end 'eachReservation'

	// Count LOCAL interface slots so the trailing-companion ids match what
	// extendSlotsForInterfaceWitnesses appended (it appends one opaquePointer
	// per local interface slot, at the end, in slot-id order).
	var localInterfaceCount = 0 as VarSlot
	for slotId in 0 upto totalSlots 'count'
		if func.scopeSlotToAbiParamIndex.contains(slotId) 'skipParam'
			continue
		end 'skipParam'
		let slotType = try func.slotMaxonTypes.get(slotId) otherwise continue
		if interfaceTypeIsFat(slotType) 'isInterface'
			localInterfaceCount = localInterfaceCount + 1
		end 'isInterface'
	end 'count'
	let originalSlotCount = totalSlots - localInterfaceCount
	var nextCompanion = originalSlotCount as VarSlot
	for slotId in 0 upto originalSlotCount 'pair'
		if func.scopeSlotToAbiParamIndex.contains(slotId) 'skipParamPair'
			continue
		end 'skipParamPair'
		let slotType = try func.slotMaxonTypes.get(slotId) otherwise continue
		if not interfaceTypeIsFat(slotType) 'notInterface'
			continue
		end 'notInterface'
		map.upsert(slotId as VarSlot, value: nextCompanion)
		nextCompanion = nextCompanion + 1
	end 'pair'
	return map
end 'buildInterfaceWitnessSlotMap'

// C1.c: resolve the rdata witness-table label for a (concreteType,
// interfaceName) pair. Concrete types are named, generic-instance
// (substituted base name), or primitives (mapped to their canonical
// extension type-name). A miss in `project.witnessTables` is a hard
// error — it means BuildWitnessTables didn't seed the conformance,
// which is an upstream bug. C1.e will ensure primitive conformances
// are seeded; until then, a missing primitive witness is a graceful
// hard panic so the build fails loudly rather than producing a
// dangling reloc.
// C1.d: 0-based index of `methodName` in `interfaceName`'s method list.
// Declaration order is the witness-table layout order (BuildWitnessTables
// emits methodImplNames in the same order it walks `iface.methods`), so
// this index also names the slot at +24 + 8*idx in the rdata witness blob
// that `witnessMethod` reads.
//
// `extends` parents are NOT walked: the conformance machinery (Phase 11.3
// processExtensions) projects every parent method into the child's
// witness table, so a child `BidirectionalIterator`'s witness already
// carries the inherited `next()` slot under its child interface's index
// — there's no separate parent-witness chase at dispatch time.
//
// Hard error on miss: a missing method name means upstream conformance
// validation failed to detect it, so we surface the bug here rather than
// emit a witness load against a stale offset.
export function methodIndexInInterface(project Project, interfaceName String, methodName String) returns MachineWord
	let iface = try project.interfaces.get(interfaceName) otherwise panic("methodIndexInInterface: interface '{interfaceName}' not in project.interfaces (resolveAllInterfaces drained or never seeded)")
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("methodIndexInInterface: methods.get OOB at {i}")
		if m.name == methodName 'hit'
			return i as MachineWord
		end 'hit'
	end 'scan'
	panic("methodIndexInInterface: method '{methodName}' not found on interface '{interfaceName}'; conformance validation should have rejected this call site upstream")
end 'methodIndexInInterface'

// Walk `interfaceName`'s direct methods plus its transitive `extends`
// parents, returning true when any of them declares `methodName`. Mirrors
// the parser's `interfaceDeclaresMethod` but reads only `project.interfaces`
// (the resolved table) — by lowering time `unresolvedInterfaces` has been
// drained. Used by the for-in createIterator passthrough below to detect
// "this interface is itself iterator-shaped (declares current+advance) and
// has no createIterator of its own."
export function interfaceDeclaresMethodTransitive(project Project, interfaceName String, methodName String) returns bool
	var visited = StringArray.create()
	return interfaceDeclaresMethodTransitiveHelper(project, interfaceName: interfaceName, methodName: methodName, visited: visited)
end 'interfaceDeclaresMethodTransitive'

// J.4b: true when `receiverTypeName` conforms to at least one
// iterator-shaped interface (declares `current` + `advance` and no
// `createIterator`). Used by `for x in self` inside a monomorphized
// extension body: the receiver is now the concrete conformer, but the
// extension body's `createIterator` tryMethodCall is still there because
// the parser emitted it unconditionally. Without this check the call
// would fall through to a missing `<ReceiverType>.createIterator`
// dispatch and panic in lowering. The struct-side mirror of the
// interface-receiver passthrough in `lowerMethodCall`.
export function receiverImplementsIteratorShapedInterface(project Project, receiverTypeName String) returns bool
	let total = project.conformances.count()
	for i in 0 upto total 'eachConf'
		let (confType, ifaceName, _) = project.conformances.get(i)
		if confType != receiverTypeName 'skipOther'
			continue
		end 'skipOther'
		let declaresCreateIterator = interfaceDeclaresMethodTransitive(project, interfaceName: ifaceName, methodName: "createIterator")
		let declaresCurrent = interfaceDeclaresMethodTransitive(project, interfaceName: ifaceName, methodName: "current")
		let declaresAdvance = interfaceDeclaresMethodTransitive(project, interfaceName: ifaceName, methodName: "advance")
		if not declaresCreateIterator and declaresCurrent and declaresAdvance 'isIteratorShape'
			return true
		end 'isIteratorShape'
	end 'eachConf'
	return false
end 'receiverImplementsIteratorShapedInterface'

function interfaceDeclaresMethodTransitiveHelper(project Project, interfaceName String, methodName String, visited StringArray) returns bool
	for v in visited 'cycleGuard'
		if v == interfaceName 'seen'
			return false
		end 'seen'
	end 'cycleGuard'
	visited.push(interfaceName)
	let iface = try project.interfaces.get(interfaceName) otherwise return false
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("interfaceDeclaresMethodTransitiveHelper: methods.get OOB at {i}")
		if m.name == methodName 'hit'
			return true
		end 'hit'
	end 'scan'
	for j in 0 upto iface.extendsNames.count() 'parents'
		let parent = try iface.extendsNames.get(j) otherwise panic("interfaceDeclaresMethodTransitiveHelper: extendsNames.get OOB at {j}")
		if interfaceDeclaresMethodTransitiveHelper(project, interfaceName: parent, methodName: methodName, visited: visited) 'parentMatch'
			return true
		end 'parentMatch'
	end 'parents'
	return false
end 'interfaceDeclaresMethodTransitiveHelper'

// C1.d: lookup the declared return type of an interface method so a
// methodCall result lands with the right MaxonType. Used by the
// interface-dispatch lowering to stamp the result ValueId. Same lookup
// rules as `methodIndexInInterface`; missing names are an upstream bug.
export function interfaceMethodReturnType(project Project, interfaceName String, methodName String) returns MaxonReturnType
	let iface = try project.interfaces.get(interfaceName) otherwise panic("interfaceMethodReturnType: interface '{interfaceName}' not in project.interfaces")
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("interfaceMethodReturnType: methods.get OOB at {i}")
		if m.name == methodName 'hit'
			return m.returnType
		end 'hit'
	end 'scan'
	panic("interfaceMethodReturnType: method '{methodName}' not found on interface '{interfaceName}'")
end 'interfaceMethodReturnType'

// True when the interface method declares a `throws` clause. Witness-table
// dispatch of a throwing method must capture the error flag (RDX/X1), so the
// caller's `try` can observe the throw; non-throwing methods drop straight to
// the single-result witnessCall path. Same lookup rules as
// `interfaceMethodReturnType`; missing names are an upstream bug.
export function interfaceMethodThrows(project Project, interfaceName String, methodName String) returns bool
	let iface = try project.interfaces.get(interfaceName) otherwise panic("interfaceMethodThrows: interface '{interfaceName}' not in project.interfaces")
	for i in 0 upto iface.methods.count() 'scan'
		let m = try iface.methods.get(i) otherwise panic("interfaceMethodThrows: methods.get OOB at {i}")
		if m.name == methodName 'hit'
			return match m.throwsTypeName 'check'
				none gives false
				throwing gives true
			end 'check'
		end 'hit'
	end 'scan'
	panic("interfaceMethodThrows: method '{methodName}' not found on interface '{interfaceName}'")
end 'interfaceMethodThrows'

// Unwrap a MaxonReturnType to the bare interface name when it represents an
// interface-typed return. Empty string means "not an interface return"
// (void, primitive, struct, generic-instance, etc.). Used by the return-site
// and call-site lowerings to decide whether to emit a fat-pointer return
// (errorReturn-shaped) or capture a fat-pointer result (tryCall-shaped).
export function returnTypeInterfaceName(project Project, ref MaxonReturnType) returns String
	let raw = match ref 'unwrap'
		void gives MaxonType.unresolved
		value(inner) gives inner
	end 'unwrap'
	return match raw 'iface'
		interface(id) gives project.interfaceRegistry.getName(id)
		boolean to function gives ""
		unresolved gives ""
		typeParameter gives ""
		genericInstance gives ""
		constInt to opaquePointer gives ""
	end 'iface'
end 'returnTypeInterfaceName'

// C1.d soft-fail: parent-interface witnesses (transitive conformance via
// `extends`) aren't seeded by today's BuildWitnessTables, and primitive
// conformances are deferred to C1.e. Throws so the caller can fall back
// rather than hard-crashing the build. Direct conformances always succeed.
export function resolveWitnessLabel(project Project, concreteType MaxonType, interfaceName String) returns String throws WitnessLabelError
	let typeName = match concreteType 'pickName'
		boolean gives "bool"
		integer gives "int"
		float gives "float"
		string gives "String"
		named(id) gives project.typeNames.get(id)
		genericInstance(gid) gives genericInstanceIdBaseName(project, id: gid)
		typeParameter(id) gives project.typeParameters.getName(id)
		interface(id) gives project.interfaceRegistry.getName(id)
		function gives ""
		unresolved gives ""
		constInt to opaquePointer gives ""
	end 'pickName'
	if typeName.isEmpty() 'noName'
		throw WitnessLabelError.notResolved
	end 'noName'
	if not project.witnessTables.contains(typeName, interfaceName: interfaceName) 'missing'
		throw WitnessLabelError.notResolved
	end 'missing'
	return project.witnessTables.labelFor(typeName, interfaceName: interfaceName)
end 'resolveWitnessLabel'

export enum WitnessLabelError implements Error
	notResolved
end 'WitnessLabelError'

// Build a `sizeBytes`-byte zero-filled ByteArray for the .data prelude. Used by
// the slab/MM global registration below for fixed-size scratch arrays
// (`__slab_mcentral_array`, `__slab_mcache_base`) and single-word state slots.
function zeroBytesOfSize(sizeBytes IntConstant) returns ByteArray
	var bytes = ByteArray.create()
	for _ in 0 upto sizeBytes 'fill'
		bytes.push(0)
	end 'fill'
	return bytes
end 'zeroBytesOfSize'

// Step 6a.17: register every slab/MM allocator-runtime global in the .data
// prelude so `globalAddr __slab_*` / `globalAddr __mm_*` resolves to a unique
// address. Without these entries every name aliased to offset 0 (the
// `lookupRdataOffset` "miss" sentinel), so the new allocator functions written
// in steps 6a.12–6a.16 would clobber each other the moment any of them runs.
//
// Sizes follow the C# bootstrap (`RuntimeEmitter.Allocator.cs`) so the layout
// is byte-for-byte compatible:
//   - Per-class arrays (`__slab_mcentral_array`, `__slab_mcache_base`) are
//     embedded directly at the registered base address — `__slab_alloc_class`
//     and `__slab_refill_mcache` index them as `globalAddr + class_idx * stride`
//     and dereference, so the array IS the global rather than a pointer to a
//     separately-allocated block.
//   - All other globals are 8-byte slots holding either a state flag or a
//     pointer; `buildDataPreludeSection` zero-fills initial bytes that fall
//     short of `sizeBytes`, but we encode the full zero payload here for clarity.
//
// TODO(threading): the per-class mcentral spinlocks (`__slab_mcentral_lock_0`
// .. `__slab_mcentral_lock_17`) are intentionally NOT registered yet —
// runtime.std's lock acquire/release helpers are no-ops while the runtime is
// single-threaded. When threading lands, register one 8-byte slot per class
// here and wire the helpers in `__slab_refill_mcache` to a real CAS loop.
export function registerSlabAndMmGlobalsForDataSection(globalData GlobalDataTable)
	// Slab bottom-layer state (step 6a.12).
	addDataSectionEntry(globalData, name: "__slab_init_done", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_arena_list_head", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_arena_last_base", initialBytes: zeroBytesOfSize(8))

	// Slab middle-layer state (step 6a.13): metadata bump-region + free-list,
	// per-class mcentral / mcache arrays.
	addDataSectionEntry(globalData, name: "__slab_meta_free_head", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_meta_bump_ptr", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_meta_bump_end", initialBytes: zeroBytesOfSize(8))
	// 18 size classes × {partial_head(8), full_head(8)} = 288 bytes.
	addDataSectionEntry(globalData, name: "__slab_mcentral_array", initialBytes: zeroBytesOfSize(288))
	// 18 size classes × mspan* (8 bytes) = 144 bytes.
	addDataSectionEntry(globalData, name: "__slab_mcache_base", initialBytes: zeroBytesOfSize(144))

	// Slab top-layer state (step 6a.14): two-level arena map + OS-direct
	// (>32KB) tracker.
	addDataSectionEntry(globalData, name: "__slab_arena_map_l1", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_os_direct_array", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_os_direct_count", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__slab_os_direct_capacity", initialBytes: zeroBytesOfSize(8))

	// MM-layer leak counter. Atomic-tracked count of live allocations;
	// spec tests assert this reaches zero.
	addDataSectionEntry(globalData, name: "__mm_alloc_count", initialBytes: zeroBytesOfSize(8))

	// Phase B3: lazy-init cache for the hand-rolled `mrt_win32_get_argc` /
	// `mrt_win32_get_argv` helpers. First call to either helper populates
	// `__mrt_win32_argc` (the argument count) and `__mrt_win32_argv_cache_ptr`
	// (heap-allocated array of UTF-8 NUL-terminated argv strings) and sets
	// `__mrt_win32_argv_init_done` to 1. Subsequent calls observe the flag and
	// skip re-initialization. The globals are emitted in every target's data
	// section (the helpers themselves are only emitted on Windows; on other
	// targets the slots are unused).
	addDataSectionEntry(globalData, name: "__mrt_win32_argv_init_done", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__mrt_win32_argc", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__mrt_win32_argv_cache_ptr", initialBytes: zeroBytesOfSize(8))

	// Phase D2: kernel-supplied argc/argv stashed by `mrt_start`'s prologue on
	// Linux/macOS. The `stashEntryArgv` backend pseudo-op writes rdi/rsi (x64)
	// or x0/x1 (arm64) into these slots before any other code in the entry
	// function runs. The Linux/macOS lowerings of `osGetArgc` / `osGetArgv`
	// read from these globals. Reserved unconditionally so the .data layout is
	// uniform across targets — on Windows and WASI these slots are 16 bytes
	// of unused .data (Win32 uses GetCommandLineW + cache; WASI uses the
	// argv-cache in scratch memory).
	addDataSectionEntry(globalData, name: "__mrt_argc", initialBytes: zeroBytesOfSize(8))
	addDataSectionEntry(globalData, name: "__mrt_argv", initialBytes: zeroBytesOfSize(8))

	// Phase D1: NUL-terminated `/proc/self/exe` path used by the Linux
	// `osGetExecutablePath` lowering. 15 bytes of payload + 1 NUL = 16 bytes,
	// rounded for natural 8-byte alignment. Lives in writable .data because
	// that's the only data section the prelude builder emits today, but it
	// is never written by anyone.
	var procSelfExeBytes = ByteArray.create()
	procSelfExeBytes.append(b"/proc/self/exe")
	procSelfExeBytes.push(0)
	procSelfExeBytes.push(0)
	addDataSectionEntry(globalData, name: "__mrt_proc_self_exe", initialBytes: procSelfExeBytes)
end 'registerSlabAndMmGlobalsForDataSection'

// Register the allocator-count reader as a callable signature. The
// `__mm_alloc`, `__mm_decref`, `__mm_incref` functions are now real
// stdlib bodies in `stdlib/Internals.maxon` (declared as `export
// function __mm_*`), so the parser populates their signatures directly.
// Only `__mm_alloc_count()` remains a synthetic intrinsic — it lowers
// to a single `globalAddr + load` rather than a call, so there's no
// matching parsed body.
export function registerMmIntrinsicSignatures(project Project)
	let intReturn = MaxonReturnType.value(MaxonType.integer)
	registerMmIntrinsicSignature(project, bareName: "__mm_alloc_count", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
end 'registerMmIntrinsicSignatures'

// Phase 7: register `__Builtins.writeStdout(managed)` and friends as
// qualified-static signatures so TypeResolution accepts the call shape.
// The lowering pass intercepts before the regular emission and expands
// to the appropriate runtime helper. Mirrors the C# bootstrap's
// `__Builtins` parser table (Compiler/2-Parser.cs:8788).
export function registerBuiltinsIntrinsicSignatures(project Project)
	let intReturn = MaxonReturnType.value(MaxonType.integer)
	let mmType = MaxonType.named(project.typeNames.intern("__ManagedMemory"))
	let mmReturn = MaxonReturnType.value(mmType)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.writeStdout", paramNames: mmParamNames1("buffer"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.writeStderr", paramNames: mmParamNames1("buffer"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// `readStdin(maxBytes)`: reads up to maxBytes from stdin and returns a fresh
	// __ManagedMemory whose length reflects the bytes actually read (0 on EOF).
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.readStdin", paramNames: mmParamNames1("maxBytes"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.floatToBits", paramNames: mmParamNames1("value"), paramTypes: mmParamTypes1(MaxonType.float), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.ucdByteAt", paramNames: mmParamNames2("label", second: "offset"), paramTypes: mmParamTypes2(MaxonType.string, second: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.ucdI64At", paramNames: mmParamNames2("label", second: "index"), paramTypes: mmParamTypes2(MaxonType.string, second: MaxonType.integer), returnType: intReturn)
	// Phase 15b: command-line argument retrieval.
	// `commandLineCount()` returns argc (i64; includes argv[0]).
	// `commandLineArg(index)` returns a __ManagedMemory holding the UTF-8 bytes
	// of argv[index]. The runtime helpers allocate the MM via the standard
	// `mm_alloc` path so user code can let it flow into a String like any other
	// managed buffer.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.commandLineCount", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.commandLineArg", paramNames: mmParamNames1("index"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: mmReturn)
	// Phase 15f: executable-path retrieval. Zero-arg call; returns a fresh
	// `__ManagedMemory` whose buffer holds the running module's absolute
	// path as UTF-8 bytes (length excludes trailing NUL). The stdlib's
	// `Process.executablePath()` wraps the result in a `FilePath`.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.executablePath", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: mmReturn)
	// Phase 3.4: monotonic clock primitive used by `stdlib/Clock.maxon`.
	// Routes through the runtime's per-target time source — Windows
	// QueryPerformanceCounter, POSIX clock_gettime(CLOCK_MONOTONIC), WASI
	// `monotonic-clock` — and returns the result in milliseconds.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.currentTimeMs", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	// Phase 3.4: subprocess builtins. Each call lowers to a fixed
	// `maxon_subprocess_*` runtime symbol that the bootstrap-emitted runtime
	// provides; the self-hosted backend just dispatches by name. The
	// 14-arg spawn/detach contract carries argv/cwd as __ManagedMemory and a
	// triple-of-triples for stdin/stdout/stderr (kind, data, limit) — see
	// `stdlib/Subprocess.maxon` for the matching call sites and the parent
	// plan for the runtime-side argument-layout contract.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResolveOnPath", paramNames: mmParamNames1("name"), paramTypes: mmParamTypes1(mmType), returnType: mmReturn)
	let spawnNames = subprocessSpawnParamNames()
	let spawnTypes = subprocessSpawnParamTypes(mmType)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessSpawn", paramNames: spawnNames, paramTypes: spawnTypes, returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessDetach", paramNames: spawnNames, paramTypes: spawnTypes, returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessLastErrorMessage", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessGetPid", paramNames: mmParamNames1("handle"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessWaitCollect", paramNames: mmParamNames2("handle", second: "timeoutMs"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultStatusKind", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultStatusCode", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultStdout", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultStderr", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultDurationMs", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessResultRelease", paramNames: mmParamNames1("resultPtr"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessKill", paramNames: mmParamNames2("handle", second: "force"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessSendSignal", paramNames: mmParamNames2("handle", second: "sig"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessReleaseHandle", paramNames: mmParamNames1("handle"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: MaxonReturnType.void)
	// Streaming subprocess API (persistent-worker pool). Same runtime-symbol
	// mapping as the bootstrap (maxon-sharp/Compiler/2-Parser.cs:9247) so
	// either compiler resolves to the same `maxon_subprocess_*_streaming/...`
	// runtime entry. Streaming spawn takes (argv, argc, cwd, flags) — pipes
	// are wired implicitly by the runtime (always stdin+stdout+stderr collect,
	// no drain threads). The line readers take (handle, maxBytes) — the
	// runtime blocks until \n / EOF, and truncates lines longer than maxBytes
	// across calls. No timeout knob exists at the runtime layer today.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessSpawnStreaming", paramNames: mmParamNames4("argv", second: "argc", third: "cwd", fourth: "flags"), paramTypes: mmParamTypes4(mmType, second: MaxonType.integer, third: mmType, fourth: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessWriteStdinAll", paramNames: mmParamNames2("handle", second: "data"), paramTypes: mmParamTypes2(MaxonType.integer, second: mmType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessReadStdoutLine", paramNames: mmParamNames2("handle", second: "maxBytes"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessReadStderrLine", paramNames: mmParamNames2("handle", second: "maxBytes"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: mmReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessCloseStdin", paramNames: mmParamNames1("handle"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.subprocessWaitExit", paramNames: mmParamNames2("handle", second: "timeoutMs"), paramTypes: mmParamTypes2(MaxonType.integer, second: MaxonType.integer), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.managedIsNull", paramNames: mmParamNames1("m"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// `sleep(ms)` suspends the current green thread for the given milliseconds.
	// Lowers to the runtime helper `maxon_sleep`. Matches the C# bootstrap entry
	// in Compiler/2-Parser.cs:9271 (RuntimeCallIntrinsic "maxon_sleep", arity 1).
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.sleep", paramNames: mmParamNames1("ms"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: MaxonReturnType.void)
	// Non-blocking promise readiness peek. Returns 1 if the GT (raw promise
	// inner pointer) is in status=completed, 0 otherwise. Mirrors the
	// bootstrap entry in 2-Parser.cs (RuntimeCallIntrinsic "__gt_is_complete").
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Builtins.gtIsComplete", paramNames: mmParamNames1("gt"), paramTypes: mmParamTypes1(MaxonType.integer), returnType: intReturn)
end 'registerBuiltinsIntrinsicSignatures'

// 14-arg spawn/detach contract: argv (MM), argc (int), cwd (MM), envBlock (MM),
// envInherit (int), then three (kind:int, data:MM, limit:int) stdio triples
// for stdin/stdout/stderr — stdin has a zero limit by convention but still
// occupies the slot — plus a final flags bitfield. Names match the stdlib
// call site so future signature-driven error messages line up with source.
function subprocessSpawnParamNames() returns StringArray
	var names = StringArray.create()
	names.push("argv")
	names.push("argc")
	names.push("cwd")
	names.push("envBlock")
	names.push("envInherit")
	names.push("stdinKind")
	names.push("stdinData")
	names.push("stdoutKind")
	names.push("stdoutData")
	names.push("stdoutLimit")
	names.push("stderrKind")
	names.push("stderrData")
	names.push("stderrLimit")
	names.push("flags")
	return names
end 'subprocessSpawnParamNames'

function subprocessSpawnParamTypes(mmType MaxonType) returns MaxonTypeArray
	let intType = MaxonType.integer
	var types = MaxonTypeArray.create()
	types.push(mmType)
	types.push(intType)
	types.push(mmType)
	types.push(mmType)
	types.push(intType)
	types.push(intType)
	types.push(mmType)
	types.push(intType)
	types.push(mmType)
	types.push(intType)
	types.push(intType)
	types.push(mmType)
	types.push(intType)
	types.push(intType)
	return types
end 'subprocessSpawnParamTypes'

function registerBuiltinsIntrinsicSignature(project Project, qualifiedName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	var paramDefaults = ParamDefaultArray.create()
	for _ in 0 upto paramNames.count() 'fillDefaults'
		paramDefaults.push(ParamDefault.none)
	end 'fillDefaults'
	try project.funcReturnTypes.insert(qualifiedName, value: returnType) otherwise ignore
	try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	project.methodNameIndex.record(qualifiedName)
end 'registerBuiltinsIntrinsicSignature'

// `__Internals.*` is a file-path-gated namespace that exposes raw Std-level
// system ops as callable methods. Only `stdlib/Internals.maxon` is allowed to
// invoke these — every other file is rejected at lowering time. The point is
// to let platform-neutral runtime helpers (refcount, slab allocator, managed
// memory) be expressed in plain Maxon syntax so they participate in the full
// stdlib optimization pipeline (canonicalize, cse, licm, dce, Stage A const
// hoist, inliner) instead of living in runtime.std with only mem2reg applied.
//
// Mirrors `registerBuiltinsIntrinsicSignatures` exactly — TypeResolution
// validates argument shape against these signatures and the lowering pass
// (`lowerInternalsIntrinsic`) intercepts the call before any signature-driven
// `StdOp.call` would emit.
export function registerInternalsIntrinsicSignatures(project Project)
	let intReturn = MaxonReturnType.value(MaxonType.integer)
	let intType = MaxonType.integer
	// Atomic ops
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.atomicInc", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.atomicDec", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.atomicXadd", paramNames: mmParamNames2("addr", second: "value"), paramTypes: mmParamTypes2(intType, second: intType), returnType: intReturn)
	// Memory load/store
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.loadIndirect", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.storeIndirect", paramNames: mmParamNames2("addr", second: "value"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.loadByte", paramNames: mmParamNames2("addr", second: "offset"), paramTypes: mmParamTypes2(intType, second: intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.storeByte", paramNames: mmParamNames3("addr", second: "offset", third: "value"), paramTypes: mmParamTypes3(intType, second: intType, third: intType), returnType: MaxonReturnType.void)
	// Width-2 / width-4 raw loads/stores. Unsigned reads (signed extension on
	// typed field loads goes through the StdSystemOp.loadIndirect path with
	// signed: true at the lowering site for that field). Used by the runtime
	// `__managed_mem_*` dispatch to honor the element_size encoded in a
	// __ManagedMemory header for u16/u32/i16/i32 element arrays.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.loadHalfword", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.storeHalfword", paramNames: mmParamNames2("addr", second: "value"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.loadWord", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.storeWord", paramNames: mmParamNames2("addr", second: "value"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.memcpy", paramNames: mmParamNames3("dst", second: "src", third: "size"), paramTypes: mmParamTypes3(intType, second: intType, third: intType), returnType: MaxonReturnType.void)
	// Address-of-named-global ops. Each maps to `globalAddr <bakedName>` in
	// the Std IR. No string-literal args: passing a Maxon string would
	// trigger a String allocation for the literal at runtime (mrt_alloc
	// chain), defeating the purpose of having a raw address-of op. Each
	// global the runtime helpers need has a dedicated intrinsic here.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.mmAllocCountAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaListHeadAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaLastBaseAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabInitDoneAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMetaFreeHeadAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMetaBumpPtrAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMetaBumpEndAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMcentralArrayAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMcacheBaseAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaMapL1Addr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabOsDirectCountAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabOsDirectCapacityAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabOsDirectArrayAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.dataCovCountersAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.dataCovNumSitesAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	// Address-of-named-function. Same rationale as globals: dedicated
	// intrinsics avoid the string-literal allocation chain.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.mrtStartAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.symtableAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.destructManagedMemoryAddr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.loadFramePtr", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	// Indirect call (one-arg variant, used by destructors)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.indirectCall1", paramNames: mmParamNames2("funcPtr", second: "arg"), paramTypes: mmParamTypes2(intType, second: intType), returnType: intReturn)
	// Runtime-call bridges: invoke a still-in-runtime helper from a migrated
	// Internals function. As each runtime helper migrates to Internals.maxon,
	// its bridge becomes redundant and can be removed (the migrated function
	// becomes directly callable as a regular stdlib function with the
	// `stdlib.` qualified name).
	//
	// Each bridge maps `__Internals.<bridgeName>(args)` to an unqualified
	// `call <runtime_name>(args)` Std op. No string literals — the runtime
	// callee name is baked into the bridge's lowering case.
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabAlloc", paramNames: mmParamNames1("size"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabFree", paramNames: mmParamNames1("ptr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabInit", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaAllocChunks", paramNames: mmParamNames1("num"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaFreeChunks", paramNames: mmParamNames3("arenaBase", second: "chunkIndex", third: "numChunks"), paramTypes: mmParamTypes3(intType, second: intType, third: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMemzero", paramNames: mmParamNames2("ptr", second: "size"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabClassSize", paramNames: mmParamNames1("idx"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabObjsPerSpan", paramNames: mmParamNames1("idx"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMetaAlloc", paramNames: StringArray.create(), paramTypes: MaxonTypeArray.create(), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabMetaFree", paramNames: mmParamNames1("ptr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabRefillMcache", paramNames: mmParamNames1("classIdx"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabAllocClass", paramNames: mmParamNames1("classIdx"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabFreeClassWithMspan", paramNames: mmParamNames2("slot", second: "mspan"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaMapEnsure", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaMapSet", paramNames: mmParamNames3("addr", second: "endAddr", third: "mspan"), paramTypes: mmParamTypes3(intType, second: intType, third: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabArenaMapGet", paramNames: mmParamNames1("addr"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabOsDirectAlloc", paramNames: mmParamNames1("size"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.slabOsDirectFree", paramNames: mmParamNames1("ptr"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.mmRealloc", paramNames: mmParamNames2("ptr", second: "newSize"), paramTypes: mmParamTypes2(intType, second: intType), returnType: intReturn)
	// OS ops
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osAllocPages", paramNames: mmParamNames1("size"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osAllocPagesLarge", paramNames: mmParamNames1("size"), paramTypes: mmParamTypes1(intType), returnType: intReturn)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osFreePages", paramNames: mmParamNames2("ptr", second: "size"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osWrite", paramNames: mmParamNames2("ptr", second: "len"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osWriteErr", paramNames: mmParamNames2("ptr", second: "len"), paramTypes: mmParamTypes2(intType, second: intType), returnType: MaxonReturnType.void)
	registerBuiltinsIntrinsicSignature(project, qualifiedName: "__Internals.osExit", paramNames: mmParamNames1("code"), paramTypes: mmParamTypes1(intType), returnType: MaxonReturnType.void)
end 'registerInternalsIntrinsicSignatures'

// Helper for registerMmIntrinsicSignatures: register a single intrinsic
// under the qualified name `stdlib.{bareName}` so the second probe in
// `qualifyCalleeForContext` (the `stdlib.<bare>` fallback) hits and yields
// a stable qualified name. Idempotent across multiple project instances:
// the registries reject duplicates with `otherwise ignore`, matching the
// `restoreStdlibMetadata` pattern.
function registerMmIntrinsicSignature(project Project, bareName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	let qualifiedName = qualifyName("stdlib", name: bareName)
	var paramDefaults = ParamDefaultArray.create()
	for _ in 0 upto paramNames.count() 'fillDefaults'
		paramDefaults.push(ParamDefault.none)
	end 'fillDefaults'
	try project.funcReturnTypes.insert(qualifiedName, value: returnType) otherwise ignore
	try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	project.methodNameIndex.record(qualifiedName)
end 'registerMmIntrinsicSignature'

// Step 6b.1 + 6b.2: register the `__ManagedMemory` builtin struct, the
// `__ManagedMemoryError` enum, and the 18 `__ManagedMemory.*` method
// signatures so user Maxon code parses, type-resolves, and arity-validates
// expressions like `__ManagedMemory.create(4, elementSize: 8)` and
// `mm.length()`. Bodies are intentionally absent — the lowering pass
// (step 6b.4) intercepts every `__ManagedMemory.*` call before it would
// otherwise lower to a `StdOp.call` against an undefined symbol.
//
// Field layout matches the C# bootstrap exactly (Compiler/2-Parser.cs:917-928):
//   offset 0  buffer        i64 (heap pointer to mm_alloc'd buffer)
//   offset 8  length        i64 (live element count)
//   offset 16 capacity      i64 (allocated element slots)
//   offset 24 element_size  i64 (sizeof(Element); 1 for Byte, 8 otherwise)
//   offset 32 parent_ptr    i64 (-1 root; -2 rdata-backed; otherwise parent ptr)
// Total byteSize = 40.
//
// Enum case ordinals mirror stdlib/Builtins.maxon:97-106 so a stdlib value
// observed at runtime matches whatever the bootstrap would have emitted.
//
// All inserts are idempotent — duplicate-key collisions silently win-on-first
// to match the `registerMmIntrinsicSignature` and `restoreStdlibMetadata`
// pattern. Idempotency is required because `getStdlibModule` may run
// multiple times per process (cache hit vs cache miss vs cross-target).
export function registerManagedMemoryType(project Project)
	registerManagedMemoryStruct(project)
	registerManagedMemoryErrorEnum(project)
	registerManagedMemoryMethods(project)
	registerManagedMemoryCursorStruct(project)
	registerManagedMemoryCursorMethods(project)
	registerManagedMemoryCursorOnMm(project)
end 'registerManagedMemoryType'

// Phase 11.0 step 8a: register the `__ManagedMemoryCursor` builtin struct
// so Array's iterator wrapping (`__ManagedMemoryCursor with Element`) has
// somewhere for the parser/type-resolver to chase method-call result
// types. Layout matches what Phase 6's slab + cursor runtime advertises:
//   offset 0  buffer    i64 (parent __ManagedMemory pointer)
//   offset 8  position  i64 (current cursor index)
// Total byteSize = 16. Phase 11 lowers `__ManagedMemoryCursor.*` calls
// through Phase 6 runtime helpers; the type registration here gives the
// type-resolver the metadata it needs to compute method-call result
// types in user code (Array.maxon and friends) before that lowering
// fires.
function registerManagedMemoryCursorStruct(project Project)
	if project.structTypes.contains("__ManagedMemoryCursor") 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	let i64Type = MaxonType.integer
	// These offsets match the Phase 6 runtime cursor ABI; flag them
	// resolved so `layoutAllStructs` leaves them alone.
	fields.push(StructField.create("buffer", fieldType: i64Type, offset: 0, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("position", fieldType: i64Type, offset: 8, isMutable: true, offsetResolved: true))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedMemoryCursorStruct: stdlib bootstrap path rejected")
	let st = StructType.create("__ManagedMemoryCursor", fields: fields, byteSize: 16, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert("__ManagedMemoryCursor", value: st) otherwise ignore
	_ = project.typeNames.intern("__ManagedMemoryCursor")
end 'registerManagedMemoryCursorStruct'

function registerManagedMemoryCursorMethods(project Project)
	let cursorType = MaxonType.named(project.typeNames.intern("__ManagedMemoryCursor"))
	let intType = MaxonType.integer
	let intReturn = MaxonReturnType.value(intType)
	let elementType = MaxonType.integer
	let elementReturn = MaxonReturnType.value(elementType)

	// current(self) returns Element
	registerCursorMethod(project, methodName: "current", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(cursorType), returnType: elementReturn)
	// index(self) returns i64
	registerCursorMethod(project, methodName: "index", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(cursorType), returnType: intReturn)
	// advance(self) returns void throws __ManagedMemoryError
	registerCursorMethod(project, methodName: "advance", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(cursorType), returnType: MaxonReturnType.void)
	// retreat(self) returns void throws __ManagedMemoryError
	registerCursorMethod(project, methodName: "retreat", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(cursorType), returnType: MaxonReturnType.void)
	// seek(self, index) returns void throws __ManagedMemoryError
	registerCursorMethod(project, methodName: "seek", paramNames: mmParamNames2("self", second: "index"), paramTypes: mmParamTypes2(cursorType, second: intType), returnType: MaxonReturnType.void)
	// peek(self, ahead) returns Element throws __ManagedMemoryError
	registerCursorMethod(project, methodName: "peek", paramNames: mmParamNames2("self", second: "ahead"), paramTypes: mmParamTypes2(cursorType, second: intType), returnType: elementReturn)
end 'registerManagedMemoryCursorMethods'

function registerCursorMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	let qualifiedName = "__ManagedMemoryCursor.{methodName}"
	var paramDefaults = ParamDefaultArray.create()
	for _ in 0 upto paramNames.count() 'fillDefaults'
		paramDefaults.push(ParamDefault.none)
	end 'fillDefaults'
	try project.funcReturnTypes.insert(qualifiedName, value: returnType) otherwise ignore
	try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	project.methodNameIndex.record(qualifiedName)
end 'registerCursorMethod'

// Phase 11.0 step 8a: register `__ManagedMemory.createCursor(self) returns
// __ManagedMemoryCursor throws __ManagedMemoryError`. Lives outside the
// main `registerManagedMemoryMethods` block so the cursor type is
// available before this fires (createCursor's return type names it).
function registerManagedMemoryCursorOnMm(project Project)
	let mmType = MaxonType.named(project.typeNames.intern("__ManagedMemory"))
	let cursorType = MaxonType.named(project.typeNames.intern("__ManagedMemoryCursor"))
	let cursorReturn = MaxonReturnType.value(cursorType)
	registerManagedMemoryMethod(project, methodName: "createCursor", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: cursorReturn)
end 'registerManagedMemoryCursorOnMm'

function registerManagedMemoryStruct(project Project)
	if project.structTypes.contains("__ManagedMemory") 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	let i64Type = MaxonType.integer
	// These offsets match the Phase 6 runtime managed-memory ABI; flag them
	// resolved so `layoutAllStructs` leaves them alone.
	fields.push(StructField.create("buffer", fieldType: i64Type, offset: 0, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("length", fieldType: i64Type, offset: 8, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("capacity", fieldType: i64Type, offset: 16, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("element_size", fieldType: i64Type, offset: 24, isMutable: true, offsetResolved: true))
	fields.push(StructField.create("parent_ptr", fieldType: i64Type, offset: 32, isMutable: true, offsetResolved: true))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedMemoryStruct: stdlib bootstrap path rejected")
	let st = StructType.create("__ManagedMemory", fields: fields, byteSize: 40, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert("__ManagedMemory", value: st) otherwise ignore
	// Intern the type name so MaxonType.named lookups resolve later.
	_ = project.typeNames.intern("__ManagedMemory")
end 'registerManagedMemoryStruct'

function registerManagedMemoryErrorEnum(project Project)
	if project.enumTypes.contains("__ManagedMemoryError") 'alreadyDone'
		return
	end 'alreadyDone'
	var cases = EnumCaseArray.create()
	cases.push(EnumCase.create("indexOutOfBounds", ordinal: 0, rawValue: 0, line: 0, column: 0))
	cases.push(EnumCase.create("emptySlot", ordinal: 1, rawValue: 1, line: 0, column: 0))
	cases.push(EnumCase.create("sliceOutOfBounds", ordinal: 2, rawValue: 2, line: 0, column: 0))
	cases.push(EnumCase.create("invalidLength", ordinal: 3, rawValue: 3, line: 0, column: 0))
	cases.push(EnumCase.create("invalidCapacity", ordinal: 4, rawValue: 4, line: 0, column: 0))
	cases.push(EnumCase.create("shiftOutOfBounds", ordinal: 5, rawValue: 5, line: 0, column: 0))
	cases.push(EnumCase.create("invalidByteRange", ordinal: 6, rawValue: 6, line: 0, column: 0))
	cases.push(EnumCase.create("invalidAllocation", ordinal: 7, rawValue: 7, line: 0, column: 0))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedMemoryErrorEnum: stdlib bootstrap path rejected")
	let et = EnumType.create("__ManagedMemoryError", cases: cases, isFloatBacked: false, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create())
	try project.enumTypes.insert("__ManagedMemoryError", value: et) otherwise ignore
	_ = project.typeNames.intern("__ManagedMemoryError")
end 'registerManagedMemoryErrorEnum'

// Register one builtin method signature on `__ManagedMemory`. Mirrors
// `registerMmIntrinsicSignature` but uses the `__ManagedMemory.{name}`
// qualified-name form (no `stdlib.` prefix) so `mm.method()` and
// `__ManagedMemory.staticMethod()` resolve through the same registry as
// user-defined methods.
//
// throwsTypeName is captured into IrFunction at function-creation sites by
// the parser; FuncSignature itself doesn't carry it. For builtin signatures
// the type-resolution pass and the call-site arity check only consult
// FuncSignature/funcReturnTypes, so the throws info is bookkept by 6b.4
// when it implements the `try ... otherwise` lowering for these calls.
// Shared helper for registering a builtin method on a `__ManagedX` builtin
// type. Populates `funcReturnTypes`/`funcSignatures`/`methodNameIndex` with
// a synthesized signature carrying no defaults; throws metadata is captured
// by the future lowering pass rather than the signature itself.
function registerManagedBuiltinMethod(project Project, receiverName String, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType, throwsTypeName ThrowsClause = ThrowsClause.none)
	let qualifiedName = "{receiverName}.{methodName}"
	var paramDefaults = ParamDefaultArray.create()
	for _ in 0 upto paramNames.count() 'fillDefaults'
		paramDefaults.push(ParamDefault.none)
	end 'fillDefaults'
	try project.funcReturnTypes.insert(qualifiedName, value: returnType) otherwise ignore
	try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise ignore
	// Record the throws-clause so `try receiver.method() otherwise (e)`
	// resolves `e` to the right error-enum MaxonType. Without this, the
	// parser's `parseTryExpression` falls back to `ThrowsClause.none` and
	// the bound `e` ends up typed as `integer`, which then trips E3005
	// when matched against enum cases.
	let hasThrows = match throwsTypeName 'kind'
		none gives false
		throwing gives true
	end 'kind'
	if hasThrows 'recordThrows'
		try project.funcThrowsTypes.insert(qualifiedName, value: throwsTypeName) otherwise ignore
	end 'recordThrows'
	project.methodNameIndex.record(qualifiedName)
end 'registerManagedBuiltinMethod'

function registerManagedMemoryMethod(project Project, methodName String, paramNames StringArray, paramTypes MaxonTypeArray, returnType MaxonReturnType)
	registerManagedBuiltinMethod(project, receiverName: "__ManagedMemory", methodName: methodName, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType)
end 'registerManagedMemoryMethod'

function registerManagedMemoryMethods(project Project)
	let mmType = MaxonType.named(project.typeNames.intern("__ManagedMemory"))
	let intType = MaxonType.integer
	let intReturn = MaxonReturnType.value(intType)
	let mmReturn = MaxonReturnType.value(mmType)
	// `__ManagedMemory.set/get/remove` are polymorphic in the element type —
	// at the IR level they store/load a single 8-byte slot regardless of
	// whether the caller is using `Array<int>` or `Array<String>`. Mark the
	// element-typed slots as `typeParameter("__ManagedMemory","Element")`
	// instead of hardcoding `int`. When the call site has a typed receiver
	// (`genericInstance(__ManagedMemory, [E])`) the substitution pass binds
	// Element → E and the slot reaches lowering as a concrete type; when
	// substitution can't bind (e.g. inside `Array.push(item)` where the
	// caller is itself generic), the slot stays `typeParameter(...)` and
	// `coerceArgToParam` treats it as `int`-category — the same fallback
	// that integer-array literals exercise today.
	let elementParamId = project.typeParameters.intern("__ManagedMemory", paramName: "Element")
	let elementType = MaxonType.typeParameter(elementParamId)
	let elementReturn = MaxonReturnType.value(elementType)

	// length(self) returns i64
	registerManagedMemoryMethod(project, methodName: "length", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// capacity(self) returns i64
	registerManagedMemoryMethod(project, methodName: "capacity", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// elementSize(self) returns i64
	registerManagedMemoryMethod(project, methodName: "elementSize", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// clear(self) returns void
	registerManagedMemoryMethod(project, methodName: "clear", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: MaxonReturnType.void)
	// setLength(self, newLength) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "setLength", paramNames: mmParamNames2("self", second: "newLength"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: MaxonReturnType.void)
	// get(self, index) returns Element throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "get", paramNames: mmParamNames2("self", second: "index"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: elementReturn)
	// set(self, index, value) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "set", paramNames: mmParamNames3("self", second: "index", third: "value"), paramTypes: mmParamTypes3(mmType, second: intType, third: elementType), returnType: MaxonReturnType.void)
	// remove(self, index) returns Element throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "remove", paramNames: mmParamNames2("self", second: "index"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: elementReturn)
	// grow(self, newCapacity) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "grow", paramNames: mmParamNames2("self", second: "newCapacity"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: MaxonReturnType.void)
	// shiftRight(self, index, count) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "shiftRight", paramNames: mmParamNames3("self", second: "index", third: "count"), paramTypes: mmParamTypes3(mmType, second: intType, third: intType), returnType: MaxonReturnType.void)
	// shiftLeft(self, index, count) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "shiftLeft", paramNames: mmParamNames3("self", second: "index", third: "count"), paramTypes: mmParamTypes3(mmType, second: intType, third: intType), returnType: MaxonReturnType.void)
	// byteAt(self, index) returns i64 throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "byteAt", paramNames: mmParamNames2("self", second: "index"), paramTypes: mmParamTypes2(mmType, second: intType), returnType: intReturn)
	// setByte(self, index, value) returns void throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "setByte", paramNames: mmParamNames3("self", second: "index", third: "value"), paramTypes: mmParamTypes3(mmType, second: intType, third: intType), returnType: MaxonReturnType.void)
	// append(self, other) returns void
	registerManagedMemoryMethod(project, methodName: "append", paramNames: mmParamNames2("self", second: "other"), paramTypes: mmParamTypes2(mmType, second: mmType), returnType: MaxonReturnType.void)
	// slice(self, start, end) returns __ManagedMemory throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "slice", paramNames: mmParamNames3("self", second: "start", third: "endIndex"), paramTypes: mmParamTypes3(mmType, second: intType, third: intType), returnType: mmReturn)
	// static create(count, elementSize) returns __ManagedMemory throws __ManagedMemoryError
	registerManagedMemoryMethod(project, methodName: "create", paramNames: mmParamNames2("count", second: "elementSize"), paramTypes: mmParamTypes2(intType, second: intType), returnType: mmReturn)
	// toCString(self) returns i64
	registerManagedMemoryMethod(project, methodName: "toCString", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
end 'registerManagedMemoryMethods'

// Phase 15c: register the `__ManagedFile` builtin struct, the
// `__ManagedFileError` enum, and the 12 `__ManagedFile.*` method
// signatures so user Maxon code in `stdlib/File.maxon` parses and
// type-resolves expressions like `__ManagedFile.openRead(path.managed)`
// and `file.size()`. Bodies are intentionally absent — Stream 2.3 will
// add the lowering dispatch that intercepts these calls before the
// generic callee resolver runs.
//
// Field layout matches the C# bootstrap exactly (maxon-sharp Compiler/2-Parser.cs:1035-1042):
//   offset 0  _handle  i64 (HANDLE on Win32, fd on Linux/WASI)
// Total byteSize = 8.
//
// Enum case ordinals mirror maxon-sharp Compiler/2-Parser.cs:1076-1090
// so a stdlib value observed at runtime matches whatever the bootstrap
// would have emitted.
//
// All inserts are idempotent — duplicate-key collisions silently win-on-
// first to match `registerManagedMemoryType`. Idempotency is required
// because `getStdlibModule` may run multiple times per process (cache
// hit vs cache miss vs cross-target).
export function registerManagedFileType(project Project)
	registerManagedFileStruct(project)
	registerManagedFileErrorEnum(project)
	registerManagedFileMethods(project)
end 'registerManagedFileType'

// Register an 8-byte single-i64-field builtin struct with the given type
// name and single field name. Used by the `__ManagedFile` / `__ManagedDirectory`
// registrations (their layouts are identical: one private i64 handle word).
function registerManagedHandleStruct(project Project, typeName String, fieldName String)
	if project.structTypes.contains(typeName) 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	fields.push(StructField.create(fieldName, fieldType: MaxonType.integer, offset: 0, isMutable: true, offsetResolved: true))
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedHandleStruct: stdlib bootstrap path rejected")
	let st = StructType.create(typeName, fields: fields, byteSize: 8, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert(typeName, value: st) otherwise ignore
	_ = project.typeNames.intern(typeName)
end 'registerManagedHandleStruct'

// Lazily register the `__Tuple{arity}` builtin struct. The parser mints
// these names on demand whenever it sees an N-tuple type expression
// (`(int, float)`) or an N-tuple literal (`(a, b)`); rather than reserving
// a fixed range up-front, each mint site calls through here first so the
// declaration shows up in `project.structTypes` before any consumer reads
// it. Idempotent: subsequent calls for the same arity return immediately.
//
// Field shape mirrors the original source-level decl that lived in the
// synthesized bootstrap prelude before Phase 16 closure:
//   type __TupleN uses _T0, _T1, ..., _T{N-1}
//       export var _0 as _T0  // offset 0
//       export var _1 as _T1  // offset 8
//       ...
//   end '__TupleN'
//
// All tuple fields are typeParameter-typed so substitution at use-site
// (e.g. `genericInstance(__Tuple2, [int, float])`) recovers the concrete
// element types. `byteSize = arity * 8` because each typeParameter slot
// lowers to one 64-bit machine word.
export function ensureTupleStructRegistered(project Project, arity ParsedInt)
	if arity < 2 'badArity'
		panic("ensureTupleStructRegistered: arity must be >= 2 (got {arity})")
	end 'badArity'
	let typeName = "__Tuple{arity}"
	if project.structTypes.contains(typeName) 'alreadyDone'
		return
	end 'alreadyDone'
	var fields = StructFieldArray.create()
	for i in 0 upto arity 'eachField'
		let paramName = "_T{i}"
		let paramId = project.typeParameters.intern(typeName, paramName: paramName)
		let fieldType = MaxonType.typeParameter(paramId)
		let fieldName = "_{i}"
		let offset = (i * 8) as FieldOffset
		// `isExported: true` mirrors the original source decl's `export var _N as _TN`.
		// Cross-file consumers (e.g. helpers/http/httpHelpers.maxon's `for (k, v)
		// in headers` destructure of a `__Tuple2`) need to access the fields.
		fields.push(StructField.create(fieldName, fieldType: fieldType, offset: offset, isMutable: true, offsetResolved: true, isExported: true))
	end 'eachField'
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("ensureTupleStructRegistered: stdlib bootstrap path rejected")
	let byteSize = (arity * 8) as FieldOffset
	let st = StructType.create(typeName, fields: fields, byteSize: byteSize, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create(), innerAliases: ResolvedInnerAliasMap.create())
	try project.structTypes.insert(typeName, value: st) otherwise ignore
	_ = project.typeNames.intern(typeName)
end 'ensureTupleStructRegistered'

function registerManagedFileStruct(project Project)
	// `_handle` matches the bootstrap field name so destructor lowering
	// (when Stream 3.1 lands the real `mrt_file_close` runtime body) can
	// pull the raw handle out by name.
	registerManagedHandleStruct(project, typeName: "__ManagedFile", fieldName: "_handle")
end 'registerManagedFileStruct'

// Register a builtin error-enum with the given name and ordered case names.
// Each case gets `ordinal == rawValue == its position in `caseNames`. Used by
// the `__ManagedFileError` / `__ManagedDirectoryError` registrations and any
// future `__ManagedX` error enums.
function registerManagedErrorEnum(project Project, typeName String, caseNames StringArray)
	if project.enumTypes.contains(typeName) 'alreadyDone'
		return
	end 'alreadyDone'
	var cases = EnumCaseArray.create()
	for i in 0 upto caseNames.count() 'eachCase'
		let name = try caseNames.get(i) otherwise panic("registerManagedErrorEnum: caseNames.get OOB")
		cases.push(EnumCase.create(name, ordinal: i, rawValue: i, line: 0, column: 0))
	end 'eachCase'
	let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise panic("registerManagedErrorEnum: stdlib bootstrap path rejected")
	let et = EnumType.create(typeName, cases: cases, isFloatBacked: false, visibility: Visibility.global, sourceFilePath: bootstrapPath, nameLine: 0, nameColumn: 0, expectedMethods: InterfaceMethodSigArray.create())
	try project.enumTypes.insert(typeName, value: et) otherwise ignore
	_ = project.typeNames.intern(typeName)
end 'registerManagedErrorEnum'

function registerManagedFileErrorEnum(project Project)

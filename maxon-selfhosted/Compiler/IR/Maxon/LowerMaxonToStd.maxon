	// static delete(path) returns void throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "delete", paramNames: mmParamNames1("path"), paramTypes: mmParamTypes1(mmType), returnType: MaxonReturnType.void)
	// static stat(path) returns i64 (buffer ptr) throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "stat", paramNames: mmParamNames1("path"), paramTypes: mmParamTypes1(mmType), returnType: intReturn)
	// static statField(buffer, index) returns i64
	registerManagedFileMethod(project, methodName: "statField", paramNames: mmParamNames2("buffer", second: "index"), paramTypes: mmParamTypes2(intType, second: intType), returnType: intReturn)
	// static statFree(buffer) returns void

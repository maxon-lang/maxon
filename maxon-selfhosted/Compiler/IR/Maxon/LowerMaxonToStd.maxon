function registerManagedFileMethods(project Project)
	let mfType = MaxonType.named(project.typeNames.intern("__ManagedFile"))
	let mmType = MaxonType.named(project.typeNames.intern("__ManagedMemory"))
	let intType = MaxonType.integer
	let intReturn = MaxonReturnType.value(intType)
	let mfReturn = MaxonReturnType.value(mfType)

	// Instance methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1152-1159).
	// size(self) returns i64 throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "size", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mfType), returnType: intReturn)
	// read(self, managed, size) returns i64 throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "read", paramNames: mmParamNames3("self", second: "managed", third: "size"), paramTypes: mmParamTypes3(mfType, second: mmType, third: intType), returnType: intReturn)
	// write(self, managed) returns i64 throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "write", paramNames: mmParamNames2("self", second: "managed"), paramTypes: mmParamTypes2(mfType, second: mmType), returnType: intReturn)
	// close(self) returns void
	registerManagedFileMethod(project, methodName: "close", paramNames: mmParamNames1("self"), paramTypes: mmParamTypes1(mfType), returnType: MaxonReturnType.void)

	// Static methods (signatures mirror maxon-sharp Compiler/2-Parser.cs:1161-1176).
	// static openRead(path) returns __ManagedFile throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "openRead", paramNames: mmParamNames1("path"), paramTypes: mmParamTypes1(mmType), returnType: mfReturn)
	// static openWrite(path) returns __ManagedFile throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "openWrite", paramNames: mmParamNames1("path"), paramTypes: mmParamTypes1(mmType), returnType: mfReturn)
	// static openWriteExecutable(path) returns __ManagedFile throws __ManagedFileError
	registerManagedFileMethod(project, methodName: "openWriteExecutable", paramNames: mmParamNames1("path"), paramTypes: mmParamTypes1(mmType), returnType: mfReturn)
	// static exists(path) returns i64

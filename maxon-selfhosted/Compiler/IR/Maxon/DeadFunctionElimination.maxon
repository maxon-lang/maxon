// Dead Function Elimination
// Removes functions not reachable from main. Runs at the Maxon phase, so
// every op in every block is a MaxonOp and there is no dialect dispatch.

typealias StringSet = Set with String
typealias IrFunctionMap = Map with String, IrFunction

export function eliminateDeadFunctions(module MaxonModule) returns MaxonModule
	// Build function lookup map for O(1) access by name
	var funcMap = IrFunctionMap.create()
	for func in module.functions 'buildMap'
		funcMap.upsert(func.name, value: func)
	end 'buildMap'

	// Worklist with Set for O(1) dedup
	var worklist = ["main"]
	var seen = StringSet from ["main"]

	var i = 0
	while i < worklist.count() 'worklist'
		let name = try worklist.get(i) otherwise panic("worklist index {i} out of bounds")
		if let func = try funcMap.get(name) 'found'
			collectCallees(module, func: func, worklist: worklist, seen: seen)
		end 'found'
		i = i + 1
	end 'worklist'

	// Filter module to only reachable functions
	var newFunctions = IrFunctionArray.create()
	for func in module.functions 'filter'
		if seen.contains(func.name) 'keep'
			newFunctions.push(func)
		end 'keep'
	end 'filter'
	module.functions = newFunctions
	return module
end 'eliminateDeadFunctions'

function collectCallees(module MaxonModule, func IrFunction, worklist StringArray, seen StringSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise continue
		for opIdx in block.opRefs 'eachOp'
			addCalleeFromOpIndex(module, opIdx: opIdx, worklist: worklist, seen: seen)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			addCalleeFromOpIndex(module, opIdx: block.terminatorIndex(), worklist: worklist, seen: seen)
		end 'hasTerm'
	end 'eachBlock'
end 'collectCallees'

function addCalleeFromOpIndex(module MaxonModule, opIdx OpIndex, worklist StringArray, seen StringSet)
	let callee = extractCalleeFromOp(module, opIdx: opIdx)
	if callee.isEmpty() 'noCall'
		return
	end 'noCall'
	if not seen.contains(callee) 'new'
		seen.insert(element: callee)
		worklist.push(callee)
	end 'new'
end 'addCalleeFromOpIndex'

// Returns the callee name if opIdx refers to a call op, else "" (part of the
// data model — non-call ops and missing indices both mean "no callee to record").
function extractCalleeFromOp(module MaxonModule, opIdx OpIndex) returns String
	let hlOp = try module.ops.get(opIdx) otherwise return ""
	return extractMaxonCallee(hlOp)
end 'extractCalleeFromOp'

function extractMaxonCallee(hlOp MaxonOp) returns String
	return match hlOp 'extract'
		call(_, callee, _) gives callee
		literal to refEq gives ""
		condBr to br gives ""
		ret gives ""
		printLiteral to panic gives ""
		structAlloc to fieldStore gives ""
	end 'extract'
end 'extractMaxonCallee'

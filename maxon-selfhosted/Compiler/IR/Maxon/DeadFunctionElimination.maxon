// Dead Function Elimination
// Removes functions not reachable from main. Runs at the Maxon phase, so
// every op in every block is a MaxonOp and there is no dialect dispatch.
//
// The parser leaves cross-declaration callee names symbolic — `call` ops
// carry an unqualified `callee` plus a `CallContext` describing how the
// name should be resolved. DFE re-runs the same resolution lowering does
// (free → currentNamespace.callee → stdlib.callee → bare; sibling →
// typeName.callee first, then free) so the worklist seeds the same set
// of qualified names that ultimately appear in the linked binary.
// `methodCall` ops have a runtime-typed receiver, so DFE conservatively
// marks every `*.methodName` registered in the project. False positives
// (over-marking) only inflate binary size, not break correctness.

typealias StringSet = Set with String
typealias IrFunctionMap = Map with String, IrFunction

export function eliminateDeadFunctions(project Project, module MaxonModule) returns MaxonModule
	// Build function lookup map for O(1) access by name
	var funcMap = IrFunctionMap.create()
	for func in module.functions 'buildMap'
		funcMap.upsert(func.name, value: func)
	end 'buildMap'

	// Worklist with Set for O(1) dedup. Phase 11.2/11.3 push thunk and
	// witness-method names into `project.livenessRoots`; those callees are
	// referenced only as static rdata payload (funcAbs64InRdata relocs into
	// layout descriptors and witness tables), never as `call` ops, so the
	// op-walking algorithm can't see them. Seeding from the registry keeps
	// them alive without a special case for static-pointer references.
	var worklist = ["main"]
	var seen = StringSet from ["main"]
	for root in project.livenessRoots 'seedRoots'
		if not seen.contains(root) 'fresh'
			seen.insert(root)
			worklist.push(root)
		end 'fresh'
	end 'seedRoots'
	// Stage K.4: Maxon-DFE walks `call` ops only; it can't see witness-
	// table / layout-descriptor demand because those ops are synthesized
	// at Std lowering time. Std-DFE has the precise machinery to drop
	// unreached witness/layout impls — at the Maxon level we
	// conservatively seed every name registered in
	// `witnessConditionalRoots` so the thunks / impls survive into the
	// Std module where Std-DFE can re-prune them based on actual
	// `loadWitnessTable` / `loadLayoutDescriptor` demand.
	for (_, bucket) in project.witnessConditionalRoots 'seedCondRoots'
		for funcName in bucket 'eachCondImpl'
			if not seen.contains(funcName) 'freshCond'
				seen.insert(funcName)
				worklist.push(funcName)
			end 'freshCond'
		end 'eachCondImpl'
	end 'seedCondRoots'

	// Stage K.X.1: keep every stdlib function alive at the Maxon phase.
	// Several reachability paths can't be statically traced from Maxon ops:
	//   - LowerMaxonToStd synthesizes direct `call stdlib.__managed_mem_*`
	//     / `stdlib.__mm_*` / `stdlib.__destruct___ManagedMemory` ops that
	//     have no Maxon-level `call` predecessor.
	//   - Interface conformances reach stdlib accessors (Array.create from
	//     BuiltinArrayLiteral, Map/Set witnesses) via funcAbs64InRdata
	//     pointers populated after DFE runs.
	//   - Generic-method monomorphization is driven by witness tables that
	//     reference stdlib accessors by name; the Maxon walk can't resolve
	//     those pointers.
	// Keeping every stdlib name on the worklist is the conservative
	// preservation strategy; the Std-level DFE pass (eliminateDeadStd
	// Functions) runs after lowering and prunes truly unreachable bodies
	// based on the emitted call ops. On tryold the stdlib cache still
	// serves stdlib bodies at link time, but the cache itself is built by
	// running this same DFE pass — so stripping here would write a broken
	// cache.
	for func in module.functions 'seedStdlib'
		if isStdlibNamespace(func.namespace) and not seen.contains(func.name) 'fresh'
			seen.insert(func.name)
			worklist.push(func.name)
		end 'fresh'
	end 'seedStdlib'

	var i = 0
	while i < worklist.count() 'worklist'
		let name = try worklist.get(i) otherwise panic("worklist index {i} out of bounds")
		if let func = try funcMap.get(name) 'found'
			// Use the parser-supplied namespace directly. `func.name` for the
			// `main` entrypoint is bare so deriving from name is unreliable;
			// the namespace field is set explicitly by the parser. The
			// function's `sourceFilePath` anchors visibility-aware
			// cross-namespace callee resolution.
			collectCallees(project, module: module, func: func, currentNamespace: func.namespace, readerFilePath: func.sourceFilePath, worklist: worklist, seen: seen)
		end 'found'
		i = i + 1
	end 'worklist'

	// Filter module to only reachable functions
	var newFunctions = IrFunctionArray.create()
	for func in module.functions 'filter'
		if seen.contains(func.name) 'keep'
			newFunctions.push(func)
		end 'keep'
	end 'filter'
	module.functions = newFunctions
	return module
end 'eliminateDeadFunctions'

function collectCallees(project Project, module MaxonModule, func IrFunction, currentNamespace String, readerFilePath FilePath, worklist StringArray, seen StringSet)
	for blockRef in func.blockRefs 'eachBlock'
		let block = try module.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in module.blocks")
		for opIdx in block.opRefs 'eachOp'
			addCalleesFromOpIndex(project, module: module, opIdx: opIdx, currentNamespace: currentNamespace, readerFilePath: readerFilePath, worklist: worklist, seen: seen)
		end 'eachOp'
		if block.hasTerminatorOp() 'hasTerm'
			addCalleesFromOpIndex(project, module: module, opIdx: block.terminatorIndex(), currentNamespace: currentNamespace, readerFilePath: readerFilePath, worklist: worklist, seen: seen)
		end 'hasTerm'
	end 'eachBlock'
end 'collectCallees'

function addCalleesFromOpIndex(project Project, module MaxonModule, opIdx OpIndex, currentNamespace String, readerFilePath FilePath, worklist StringArray, seen StringSet)
	let hlOp = try module.ops.get(opIdx) otherwise panic("invariant: opIdx not in module.ops")
	match hlOp 'op'
		call(_, callee, callContext, _, _, _, _, _) then markCalleeFromCall(project, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, worklist: worklist, seen: seen)
		methodCall(_, _, methodName, _, _, _, _, _) then markEveryMethodNamed(project, methodName: String.from(methodName), worklist: worklist, seen: seen)
		// tryCall has the same callee-marking semantics as `call`. The
		// multi-value-return error ABI carries the flag in RDX/X1 with no
		// runtime-helper drain, so no extra root needs marking.
		tryCall(_, callee, callContext, _, _, _, _, _, _) then markCalleeFromCall(project, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, worklist: worklist, seen: seen)
		// Throwing methodCall: same callee-marking semantics as `methodCall`
		// (mark every method with that name; receiver discrimination is too
		// narrow for DFE). The multi-value-return ABI carries the flag in
		// RDX/X1 with no runtime-helper drain.
		tryMethodCall(_, _, methodName, _, _, _, _, _, _) then markEveryMethodNamed(project, methodName: String.from(methodName), worklist: worklist, seen: seen)
		// A read of a lazy static struct-literal field demands its
		// `<name>.__lazy_init` function: lowering injects a call to it
		// ahead of every globalLoad, but that call is synthesized after DFE
		// runs, so the call edge isn't visible here. Root the init from the
		// read site instead — liveness flows from the read just as the
		// injected call will. Detected by the init function's existence in
		// `funcSignatures` (registered at parse time). Unread fields leave
		// no globalLoad, so the init stays correctly dead.
		globalLoad(_, name, _, _) then markLazyStaticInit(project, fieldName: name, worklist: worklist, seen: seen)
		literal to varStore then return
		globalStore to refEq then return
		condBr to br then return
		ret then return
		panic then return
		panicDynamic then return
		structAlloc to selfFieldStore then return
		// Parser-emitted unresolved placeholders carry no callee names; they
		// hold simple identifiers. DFE walks them as no-ops; TypeResolution
		// will rewrite them before lowering.
		unresolvedRead to error then return
		// `throw E.v` lowers to a single `errorReturn` op under the multi-
		// value-return error ABI — no runtime helper call to root.
		throw then return
		// Stage D (closures): functionRef / closureCreate name the lifted
		// closure body (or a free function whose address is taken). Both
		// must root the named function so DFE doesn't drop a body that is
		// only reached through an indirect call. The parser emits these
		// with already-qualified names (lifted closures use synthetic
		// `_$closure_<n>` names; raw function references use the full
		// qualified name), so we mark them directly without re-running the
		// CallContext-driven resolver. closureEnvLoad references no
		// function and indirectCall reaches its target through a
		// runtime-typed pointer — both stay no-ops here, which is correct
		// because the upstream functionRef/closureCreate already rooted
		// every lifted body.
		functionRef(_, funcName, _, _) then markCallee(funcName, worklist: worklist, seen: seen)
		closureCreate(_, funcName, _, _, _, _) then markCallee(funcName, worklist: worklist, seen: seen)
		closureEnvLoad then return
		indirectCall then return
		// Phase 11 Step 9 (parser-only): forInIterable carries no callee
		// names — the iterator-protocol method resolution that *would*
		// reference `Iterable.createIterator` etc. is deferred to Step 8.
		// No worklist seeding happens here; if Step 8 needs to keep
		// iterator-protocol implementations alive it will hook in then.
		forInIterable then return
		// Phase 5: rethrow lowers directly to `StdCallOp.errorReturn` and
		// references no callee names.
		rethrow then return
		// Tier 4 async: `asyncCall` spawns its callee on a green thread, so the
		// callee is reachable — mark it exactly like `call`. The await /
		// try_await / cancel ops reference a runtime promise handle, not a callee
		// name, so they root nothing (the spawning asyncCall already kept the
		// spawned body alive).
		asyncCall(_, callee, callContext, _, _, _, _, _, _, _, _) then markCalleeFromCall(project, callee: callee, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath, worklist: worklist, seen: seen)
		awaitPromise to cancelPromise then return
	end 'op'
end 'addCalleesFromOpIndex'

function markCalleeFromCall(project Project, callee ByteArray, callContext CallContext, currentNamespace String, readerFilePath FilePath, worklist StringArray, seen StringSet)
	let qualified = qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath)
	// Overloaded callee: the bare qualified name has no funcReturnTypes entry
	// (the parser rekeyed each variant under a mangled suffix). Mark every
	// variant in the bucket so DFE doesn't drop overload candidates that
	// TypeResolution will pick at the call site. Resolving precisely here
	// would require per-call argType propagation which DFE doesn't track
	// (correctness only — over-marking only inflates binary size).
	if let bucket = try project.overloadedNames.get(qualified) 'isOverloaded'
		for variant in bucket 'eachVariant'
			markCallee(variant, worklist: worklist, seen: seen)
		end 'eachVariant'
		return
	end 'isOverloaded'
	markCallee(qualified, worklist: worklist, seen: seen)
end 'markCalleeFromCall'

// Root a lazy static field's `<fieldName>.__lazy_init` when one exists. The
// init's signature is registered at parse time (parseLazyStaticStructDecl), so
// its presence in `funcSignatures` distinguishes a lazy static field read from
// an ordinary top-level var read. Non-lazy globalLoads no-op here.
function markLazyStaticInit(project Project, fieldName String, worklist StringArray, seen StringSet)
	let initName = "{fieldName}.__lazy_init"
	if project.funcSignatures.contains(initName) 'isLazy'
		markCallee(initName, worklist: worklist, seen: seen)
	end 'isLazy'
end 'markLazyStaticInit'

function markCallee(callee String, worklist StringArray, seen StringSet)
	if callee.isEmpty() 'noName'
		return
	end 'noName'
	if not seen.contains(callee) 'new'
		seen.insert(callee)
		worklist.push(callee)
	end 'new'
end 'markCallee'

// Conservative methodCall handling: walk the bare-name bucket in the
// project's method-name index and seed the worklist with each candidate.
// Over-marks when the method exists on multiple types but the receiver
// could only ever be one of them; under-marking is impossible. The index
// turns this into O(matches) per methodCall instead of O(N) over the
// whole funcReturnTypes map.
function markEveryMethodNamed(project Project, methodName String, worklist StringArray, seen StringSet)
	let candidates = project.methodNameIndex.get(methodName)
	for qualifiedName in candidates 'each'
		markCallee(qualifiedName, worklist: worklist, seen: seen)
	end 'each'
end 'markEveryMethodNamed'

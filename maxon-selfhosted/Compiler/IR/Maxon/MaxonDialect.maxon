// Maxon Dialect
// High-level, closest to source. Parser emits these ops directly.
// Lowered to Std ops by the lowerMaxonToStd pass.
//
// The Maxon dialect owns MaxonType — a source-level type union with no concept
// of width unification. An i32 is an i32, not "a 32-bit int that lowers to i64".
// Width/signedness collapse happens only in lowerMaxonToStd.

export typealias ValueIdArray = Array with ValueId

// Array of name slices — used by call ops to pass the names of their
// positional arguments. Each element is a `ByteArray` slice, typically a
// zero-copy view over the lexer's source buffer for user-written names or
// a per-function arena for synthetic intermediates.
export typealias ByteArrayArray = Array with ByteArray

// --- MaxonType: source-level type system ---
// The Maxon language has only three kinds of types at the source level:
//   - bool (the only standalone primitive that users can write directly)
//   - named (user-defined via `typealias`, `type`, `enum`, `union`, or stdlib aliases
//     like ExitCode, AsciiValue — these resolve to concrete widths via the
//     typealias registry at Std lowering time)
//   - integer / float (unconstrained numeric literals without a named context)
//
// The i8/i16/.../u64/f32/f64 identifiers exist only as namespaces for compile-time
// constants (`u64.max`, `i32.min`, etc.) — they are NOT standalone types.
// Width and signedness information lives in the typealias registry, not MaxonType.
//
// Void is NOT a MaxonType — a non-value can't be a value-type. Function
// return types use MaxonReturnType (below), which is a union of void and
// MaxonType.

// `named` carries a TypeNameId that indexes the project's type-name interner
// so identical named references share a single backing String. All producers
// go through `internMaxonType`; consumers that need the printable form call
// `t.toString(project)` (display) or `t.nameOrEmpty(project)` (named-only).
// --- CallContext: how a `call` op's bare callee should be resolved at lowering ---
// The parser emits the unqualified callee name as written; CallContext tells
// LowerMaxonToStd how to walk the registries to find the real qualified target.
//   - free: bare name in non-method context. Try `currentNamespace.callee`,
//     then `stdlib.callee`, then bare.
//   - sibling: bare name inside an instance method. Try `typeName.callee`
//     first, then fall through to `free` resolution.
//   - qualified: callee already carries the final qualified name (e.g.
//     parser saw `Foo.bar(...)`). Lowering uses callee verbatim.
export union CallContext
	free
	sibling(typeName String)
	qualified
end 'CallContext'

// Identifier for a function-type signature interned in `Project.functionTypes`.
// The registry is unbounded (one entry per distinct `(P1, P2) returns R`
// signature seen in source), so we use the wide `0 to u64.max` range — there
// is no concrete upper bound to encode.
export typealias FunctionTypeId = int(0 to u64.max)

// Phase 11.0: identifier for a type-parameter binding interned in
// `Project.typeParameters`. Mirrors FunctionTypeId — wide range, no concrete
// upper bound on the number of distinct (declaringTypeName, paramName) pairs
// a project may carry.
export typealias TypeParamId = int(0 to u64.max)

// Phase 11.0: identifier for an interface-typed value interned in
// `Project.interfaces` registry by interface name. Used to represent
// existential interface values like `Iterable with Element` as a value type.
export typealias InterfaceTypeId = int(0 to u64.max)

export union MaxonType
	boolean
	integer
	float
	string
	named(id TypeNameId)
	// Function-typed parameter (and, eventually, closure value). Carries an
	// id into `Project.functionTypes` rather than the param/return types
	// directly so MaxonType stays cheap to copy and so structural identity
	// (two parameters of the same `(Integer) returns Integer` shape) is a
	// single integer compare.
	function(id FunctionTypeId)
	// Placeholder for type-flow operands the parser cannot fill in without
	// cross-declaration lookups. Produced by parser sites that previously
	// peeked into `project.funcReturnTypes`, `project.structTypes`, etc.
	// (call results, methodCall results, fieldLoad results, and the operand
	// types those flow into — convert.fromType, cmp.leftType/rightType,
	// call.argTypes, etc.). The TypeResolution pass walks every Maxon op
	// after parsing finishes and replaces every `unresolved` with the
	// concrete type derived from the now-fully-populated registries.
	// Lowering must never see this arm — TypeResolution should have removed
	// it. Lowering's match arms panic if they encounter it.
	unresolved
	// Phase 11.0: an unbound type parameter (`T`, `Element`) declared via
	// `type Foo uses Element` or `extension Foo uses Element`. Carries an id
	// into `Project.typeParameters` (keyed by declaringTypeName + paramName)
	// where the constraint set lives.
	typeParameter(id TypeParamId)
	// Phase 11.0: an instantiated generic type like `Array with Int` or
	// `__ManagedMemory with Element`. Carries a GenericInstanceId interned
	// through `Project.genericInstances`; the registry stores the (baseId,
	// args) pair. We can't inline `args MaxonTypeArray` here — that would
	// give MaxonType a recursive aggregate which the language rejects with
	// E4014 (`Array with MaxonType` recurses through `MaxonType`).
	genericInstance(id GenericInstanceId)
	// Phase 11.0: an existential interface-typed value (e.g. a variable of
	// type `Iterable with Int`). Carries an InterfaceTypeId. Lowering will
	// represent these as fat pointers in Phase 11.3; for now the arm exists
	// only on the parser-AST surface.
	interface(id InterfaceTypeId)
	// Phase 13 (sized typealiases): a compile-time integer constant carried
	// as a generic-instance arg. Used by `typealias Vec1 = Vector with 1 Int`
	// — the gid's args become `[constInt(1), named(Int)]` so distinct N
	// produce distinct gids. This arm appears ONLY in a genericInstance's
	// args list; it is never a value type a user can write. Lowering reads
	// the payload to size __ManagedMemory allocations and per-instance
	// layout descriptors.
	constInt(value IntConstant)
	// An i64-sized synthetic ABI-bookkeeping slot — closure env pointers,
	// interface witness pointers, and any future i64-sized opaque value
	// the parser introduces alongside a user-visible param/local. NOT a
	// user-writable type; it never appears in source syntax. Lowering
	// collapses it to `StdType.i64` just like `integer`, but during
	// Maxon-level passes it lets a slot say "I am ABI bookkeeping, do
	// not iterate me as a user-visible scope entry" without overloading
	// `MaxonType.integer`. Role (env vs witness) is recovered at lowering
	// time from slot adjacency + the paired user-visible slot's type, not
	// from this tag — see `interfaceWitnessSlots` / `fnEnvVarNames`.
	opaquePointer
	// A NUL-terminated UTF-8 byte pointer, distinct from `__ManagedMemory`
	// (which is sized by a length header and is NOT guaranteed to have a `\0`
	// at `buffer[length]`). Used for `__Builtins.*` runtime intrinsic params
	// whose underlying runtime `strlen`s the pointer (subprocess cwd / argv
	// entries / stdio data, PATH resolution) and for the result of
	// `String.cstr()` / `__ManagedMemory.toCString()`. The type check is what
	// makes the `.cstr()` / `.toCString()` conversion mandatory at the source
	// level, closing the buffer-overrun gap a bare `__ManagedMemory` would
	// leave. Lowers to `StdType.i64` (a raw pointer) like `opaquePointer`.
	cstring

	// Render the source-level spelling of this type, or its display name
	// for primitives. Used by diagnostic messages and IR printers — the
	// printable form a user would recognize, not the internal tag.
	export function toString(project Project) returns String
		return match self 'str'
			boolean gives "bool"
			integer gives "int"
			float gives "float"
			string gives "String"
			named(id) gives project.typeNames.get(id)
			function(id) gives functionTypeToString(project, id: id)
			unresolved gives "<unresolved>"
			typeParameter(id) gives project.typeParameters.getName(id)
			genericInstance(id) gives genericInstanceIdToString(project, id: id)
			interface(id) gives project.interfaceRegistry.getName(id)
			constInt(value) gives "{value}"
			opaquePointer gives "<opaquePtr>"
			cstring gives "cstring"
		end 'str'
	end 'toString'

	// Returns the source-level name for a named type, or "" for primitives.
	// Used by serializers (StdlibCache) that round-trip a MaxonType through
	// a string key — primitives encode their tag separately, so the empty
	// string is fine for those cases. Function types have no source-level
	// "name" — they're structurally typed — so they fall under the same
	// empty-string convention as primitives. opaquePointer has no
	// source-level spelling either.
	export function nameOrEmpty(project Project) returns String
		return match self 'name'
			named(id) gives project.typeNames.get(id)
			boolean to string gives ""
			function to unresolved gives ""
			typeParameter(id) gives project.typeParameters.getName(id)
			genericInstance(id) gives genericInstanceIdBaseName(project, id: id)
			interface(id) gives project.interfaceRegistry.getName(id)
			constInt to cstring gives ""
		end 'name'
	end 'nameOrEmpty'

	// Source-level name iff this is a `named(id)` typealias, "" otherwise.
	// Stricter than `nameOrEmpty` — the cast-range-check pass and convert-
	// validation walker only care about typealias-shaped targets and need
	// "" for type-parameters / generic-instances / interfaces so they can
	// short-circuit cleanly.
	export function namedAliasNameOrEmpty(project Project) returns String
		return match self 'name'
			named(id) gives project.typeNames.get(id)
			boolean to string gives ""
			function to cstring gives ""
		end 'name'
	end 'namedAliasNameOrEmpty'
end 'MaxonType'

// True iff `t` is a `MaxonType.function(_)`. Cheap discriminator for the
// parser's indirect-call detection — when a bare callee resolves to a
// function-typed local, the parser routes through `indirectCall` instead
// of emitting a name-symbolic `call`.
export function isFunctionMaxonType(t MaxonType) returns bool
	return match t 'check'
		function gives true
		boolean to named gives false
		unresolved to cstring gives false
	end 'check'
end 'isFunctionMaxonType'

// Chase a single hop through a function-type alias. When `t` is
// `MaxonType.named("UnaryOp")` and `UnaryOp` resolves (or is on its way
// to resolving) to a `MaxonType.function(id)` alias, return that
// function type. Otherwise return `t` unchanged so callers that don't
// care about aliasing can pipe values through unconditionally.
//
// Used at parse time — the resolved `genericTypealiases` entry isn't
// populated until `drainResolvableTypealiases` runs, so we also probe
// `unresolvedTypealiases` for the parser's own pending entries (the
// alias's RHS was carried as `UnresolvedTypeExpr.functionAlias(target)`
// with the fully-resolved MaxonType already inside it).
export function chaseTypealiasToFunctionType(project Project, t MaxonType) returns MaxonType
	let aliasName = t.namedAliasNameOrEmpty(project)
	if aliasName.isEmpty() 'noAlias'
		return t
	end 'noAlias'
	if let resolved = try project.genericTypealiases.get(aliasName) 'fromResolved'
		if isFunctionMaxonType(resolved) 'isFn'
			return resolved
		end 'isFn'
	end 'fromResolved'
	if let entry = try project.unresolvedTypealiases.get(aliasName) 'fromUnresolved'
		match entry.expr 'extract'
			functionAlias(target) then return target
			boolPrim then return t
			rangedInt then return t
			rangedFloat then return t
			aliasName then return t
			genericAlias then return t
			sizedGenericAlias then return t
			invalid then return t
		end 'extract'
	end 'fromUnresolved'
	// Interface and struct inner aliases — function-type aliases declared
	// inside `extension SomeInterface ... end` (e.g. `ElementTransform`
	// declared inside `extension Iterable`) land on the interface's
	// `innerAliases`. Probe both registries so a `named(alias)` that
	// resolves through an inner alias still chases to its function type.
	for (_, iface) in project.interfaces 'eachIface'
		if let resolved = try iface.innerAliases.get(aliasName) 'innerHit'
			if isFunctionMaxonType(resolved) 'innerIsFn'
				return resolved
			end 'innerIsFn'
		end 'innerHit'
	end 'eachIface'
	for (_, structEntry) in project.structTypes 'eachStruct'
		if let resolved = try structEntry.innerAliases.get(aliasName) 'structInnerHit'
			if isFunctionMaxonType(resolved) 'structInnerIsFn'
				return resolved
			end 'structInnerIsFn'
		end 'structInnerHit'
	end 'eachStruct'
	// Parse-time fallback: extension bodies merge their inner typealiases
	// into `project.unresolvedStructTypes[target].innerAliases` immediately
	// (see `mergeExtensionInnerAliases`), but the parsed entries land as
	// `UnresolvedTypeExpr.functionAlias(target)` rather than a fully-
	// resolved MaxonType. Probing unresolved entries here lets a sibling
	// file's `cmp(a, b)` call recognize `cmp` as a function value before
	// the type-resolution pass runs to promote the alias.
	for (_, unresolvedStruct) in project.unresolvedStructTypes 'eachUnresolved'
		if let expr = try unresolvedStruct.innerAliases.get(aliasName) 'unresolvedHit'
			let chased = match expr 'extract'
				functionAlias(target) gives target
				rangedInt gives t
				rangedFloat gives t
				boolPrim gives t
				aliasName gives t
				genericAlias gives t
				sizedGenericAlias gives t
				invalid gives t
			end 'extract'
			if isFunctionMaxonType(chased) 'isFn'
				return chased
			end 'isFn'
		end 'unresolvedHit'
	end 'eachUnresolved'
	return t
end 'chaseTypealiasToFunctionType'

// Phase 11.3: True iff `t` is a `MaxonType.interface(_)`. Interface-typed
// values are 16-byte fat pointers (`{value, witness}`); the construction
// side of the lowering uses this discriminator to decide whether to emit
// fat-pointer stores at slot/return/parameter sites.
export function interfaceTypeIsFat(t MaxonType) returns bool
	return match t 'check'
		interface gives true
		boolean to function gives false
		unresolved gives false
		typeParameter gives false
		genericInstance gives false
		constInt to cstring gives false
	end 'check'
end 'interfaceTypeIsFat'

// True iff `t` is a `MaxonType.opaquePointer` — i.e. an ABI-bookkeeping
// slot (closure env, interface witness companion). Used by the lowering
// to recognize slots that should not be iterated as user-visible scope
// entries.
export function isOpaquePointerMaxonType(t MaxonType) returns bool
	return match t 'check'
		opaquePointer gives true
		boolean to constInt gives false
		cstring gives false
	end 'check'
end 'isOpaquePointerMaxonType'

// Phase 11.3: byte width of a MaxonType viewed as a single ABI value.
// Primitives at their hardware width (Bool=1, Byte=1, Int=8, Float=8);
// strings, structs, enum instances and interface fat-pointers report 8
// (pointer-shaped at this stage — the fat-pointer 16-byte width is a
// downstream concern of the lowering, not a single-value width). Generic
// instances substitute through the base struct's `byteSize`; unknown bases
// fall back to 8. Used by BuildWitnessTables to pick the inline-vs-box bit
// in the witness-table flags slot.
export function maxonTypeWidthBytes(project Project, t MaxonType) returns MachineWord
	return match t 'w'
		boolean gives 1
		integer gives 8
		float gives 8
		string gives 8
		named(id) gives namedTypeWidthBytes(project, id: id)
		function gives 8
		unresolved gives 8
		typeParameter gives 8
		genericInstance(gid) gives genericInstanceWidthBytes(project, gid: gid)
		interface to cstring gives 8
	end 'w'
end 'maxonTypeWidthBytes'

function namedTypeWidthBytes(project Project, id TypeNameId) returns MachineWord
	let name = project.typeNames.get(id)
	if let st = try project.structTypes.get(name) 'isStruct'
		return st.byteSize
	end 'isStruct'
	return 8
end 'namedTypeWidthBytes'

function genericInstanceWidthBytes(project Project, gid GenericInstanceId) returns MachineWord
	let (baseId, _) = project.genericInstances.get(gid)
	let baseName = project.typeNames.get(baseId)
	if let st = try project.structTypes.get(baseName) 'isStruct'
		return st.byteSize
	end 'isStruct'
	return 8
end 'genericInstanceWidthBytes'

// Extract the FunctionTypeId payload from a `MaxonType.function`. Panics
// for any other arm — callers must guard with `isFunctionMaxonType` first.
export function functionMaxonTypeId(t MaxonType) returns FunctionTypeId
	return match t 'unwrap'
		function(id) gives id
		default panic("functionMaxonTypeId: MaxonType is not a function arm — caller must guard with isFunctionMaxonType")
	end 'unwrap'
end 'functionMaxonTypeId'

// Phase 11.0: structural equality between two MaxonTypeArrays. Used by the
// generic-instance interner when checking whether an existing instance entry
// matches a fresh `(baseId, args)` candidate.
export function maxonTypeArraysStructurallyEqual(a MaxonTypeArray, b MaxonTypeArray) returns bool
	if a.count() != b.count() 'arity'
		return false
	end 'arity'
	for i in 0 upto a.count() 'each'
		let pA = try a.get(i) otherwise panic("maxonTypeArraysStructurallyEqual: a.get OOB at {i} (arity already validated)")
		let pB = try b.get(i) otherwise panic("maxonTypeArraysStructurallyEqual: b.get OOB at {i} (arity already validated)")
		if not maxonTypesStructurallyEqual(pA, b: pB) 'mismatch'
			return false
		end 'mismatch'
	end 'each'
	return true
end 'maxonTypeArraysStructurallyEqual'

// Resolve a `MaxonType.function` to its return-type entry in
// `Project.functionTypes`. Used by parser `indirectCall` emission to stamp
// the result's MaxonType without re-walking the registry at every call site.
export function functionMaxonReturnType(project Project, t MaxonType) returns MaxonReturnType
	return functionTypeIdReturnType(project, id: functionMaxonTypeId(t))
end 'functionMaxonReturnType'

// Look up the return type for a FunctionTypeId. Shared by every site
// that needs the return-type half of a function-type signature (parser
// indirect-call emission, TypeResolution result-type stamping, and the
// Std lowering's indirect-call result type stamping).
export function functionTypeIdReturnType(project Project, id FunctionTypeId) returns MaxonReturnType
	let (_, returnType) = project.functionTypes.get(id)
	return returnType
end 'functionTypeIdReturnType'

// Project a MaxonReturnType to a MaxonType for ExprResult propagation. Void
// returns get mapped to `unresolved` so the consumer either flags an error
// (statement-context vs expression-context) or simply drops the value.
export function maxonReturnTypeValueOrUnresolved(rt MaxonReturnType) returns MaxonType
	return match rt 'pick'
		void gives MaxonType.unresolved
		value(inner) gives inner
	end 'pick'
end 'maxonReturnTypeValueOrUnresolved'

// Resolve an indirect-call return type the same way direct calls do: unwrap
// the value(...) wrapper, then chase through a function-typed typealias so
// `function(...) returns SomeFnAlias` is observed identically whether the
// callee was reached by name or through a function-valued local. Enum and
// struct typealias names (e.g. `Ordering`, `SortIndex`) pass through
// untouched — they stay as `named(...)` so downstream enum lookups
// (`.ordinal`, `== EnumCase`) and struct dispatch still hit. Without this,
// `let r = cmp(a, b)` on a `cmp SortComparator` left the slot typed as the
// raw `named("Ordering")` from the registry without the chase symmetry the
// direct-call path applies — which silently mis-shaped the value when the
// alias's RHS was itself a function type.
export function indirectCallResultType(project Project, returnType MaxonReturnType) returns MaxonType
	let raw = maxonReturnTypeValueOrUnresolved(returnType)
	return chaseTypealiasToFunctionType(project, t: raw)
end 'indirectCallResultType'

// Render a function type as `(P1, P2) returns R` (or `() returns void` for
// the no-arg / void-return shape). Lives outside `MaxonType` so the union's
// `toString` arm stays a one-liner; called from there and from anywhere else
// that wants the display form. Cold path — diagnostics and IR dumps only.
export function functionTypeToString(project Project, id FunctionTypeId) returns String
	let (paramTypes, returnType) = project.functionTypes.get(id)
	var result = "("
	for i in 0 upto paramTypes.count() 'each'
		let p = try paramTypes.get(i) otherwise panic("functionTypeToString: paramTypes.get OOB at {i}")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}{p.toString(project)}"
	end 'each'
	result = "{result}) returns {maxonReturnTypeToString(project, ref: returnType)}"
	return result
end 'functionTypeToString'

// Phase 11.0: render a `genericInstance` MaxonType (resolved through its id)
// as `BaseName with (Arg1, Arg2)`. Single-arg form drops the parens to match
// the source-level spelling (`Array with Int`); zero-arg should never be
// produced by the parser but is rendered defensively. Cold path —
// diagnostics and IR dumps only.
export function genericInstanceIdToString(project Project, id GenericInstanceId) returns String
	let (baseId, args) = project.genericInstances.get(id)
	return genericInstanceToString(project, baseId: baseId, args: args)
end 'genericInstanceIdToString'

// Phase 11.0: name-only accessor for `nameOrEmpty`. Returns just the base
// type's interned name (no `with ...` suffix) so callers using the printable
// form for diagnostic messages match the spelling user-side code carries.
export function genericInstanceIdBaseName(project Project, id GenericInstanceId) returns String
	let (baseId, _) = project.genericInstances.get(id)
	return project.typeNames.get(baseId)
end 'genericInstanceIdBaseName'

// True when `name` is one of the three compiler-internal managed builtin base
// types. These handles are zero-/`create()`-initialized by structAlloc lowering
// and intercept their mutating methods before callee resolution, so the
// field-init (E3086) and immutable-receiver (E3019) passes both exempt them.
// Single source of truth for the set so those passes stay in sync.
export function isBuiltinManagedTypeName(name String) returns bool
	return name == "__ManagedMemory" or name == "__ManagedList" or name == "__ManagedListNode"
end 'isBuiltinManagedTypeName'

export function genericInstanceToString(project Project, baseId TypeNameId, args MaxonTypeArray) returns String
	let baseName = project.typeNames.get(baseId)
	if args.count() == 0 'noArgs'
		return "{baseName} with ()"
	end 'noArgs'
	if args.count() == 1 'oneArg'
		let only = try args.get(0) otherwise panic("genericInstanceToString: args.get(0) failed despite count==1")
		return "{baseName} with {only.toString(project)}"
	end 'oneArg'
	var result = "{baseName} with ("
	for i in 0 upto args.count() 'each'
		let a = try args.get(i) otherwise panic("genericInstanceToString: args.get OOB at {i}")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}{a.toString(project)}"
	end 'each'
	result = "{result})"
	return result
end 'genericInstanceToString'

// Phase 11.2: visitor set used by `walkInstantiations` to dedupe reachable
// GenericInstanceIds. Pulled out as a typealias so the recursive helper's
// signature stays readable.
export typealias GenericInstanceIdSet = Set with GenericInstanceId

// Phase 11.2: collect every `genericInstance(gid)` reachable through `t`
// — including transitive instances inside arg lists. Adds each id to
// `out` (idempotent via the Set). Used by BuildLayoutDescriptors to
// discover that walking `Array with (Pair with Int)` exposes BOTH
// `Pair with Int` and `Array with (Pair with Int)` for separate
// descriptor emission.
//
// Function and interface arms are leaves for layout purposes (the
// existential value type carries no layout-descriptor argument), so the
// walk does not recurse through them. Other arms (primitives, named,
// typeParameter, unresolved) carry no instances.
export function walkInstantiations(project Project, t MaxonType, out GenericInstanceIdSet)
	match t 'walk'
		genericInstance(gid) then walkInstanceArm(project, gid: gid, out: out)
		boolean to function then return
		unresolved then return
		typeParameter then return
		interface to cstring then return
	end 'walk'
end 'walkInstantiations'

function walkInstanceArm(project Project, gid GenericInstanceId, out GenericInstanceIdSet)
	if out.contains(gid) 'alreadyKnown'
		return
	end 'alreadyKnown'
	out.insert(gid)
	let (_, args) = project.genericInstances.get(gid)
	for i in 0 upto args.count() 'each'
		let a = try args.get(i) otherwise panic("walkInstantiations: args.get OOB at {i}")
		walkInstantiations(project, t: a, out: out)
	end 'each'
end 'walkInstanceArm'

// Intern a function type by structural identity. A linear scan over the
// registry suffices today — function-typed parameters are rare, and the
// signatures are small. If profiling shows this is hot we can swap in a
// hash-keyed lookup, but the identity it preserves (same params + same
// return type ⇒ same id) is what matters for downstream equality checks.
export function internFunctionType(project Project, paramTypes MaxonTypeArray, returnType MaxonReturnType) returns FunctionTypeId
	for i in 0 upto project.functionTypes.count() 'scan'
		let (existingParams, existingReturn) = project.functionTypes.get(i)
		if functionTypesEqual(existingParams, existingReturn: existingReturn, paramTypes: paramTypes, returnType: returnType) 'hit'
			return i
		end 'hit'
	end 'scan'
	return project.functionTypes.append(paramTypes, returnType: returnType)
end 'internFunctionType'

// Structural equality between two captured signatures. The element-wise
// MaxonType compare uses the same equality discipline as TypeResolution:
// matching tags ⇒ matching payload (TypeNameId / FunctionTypeId) — no
// nominal name walks, so two signatures referencing the same named type
// via different ids would NOT compare equal here. That's acceptable for
// today's usage (every named MaxonType comes from `internMaxonType`, which
// already collapses duplicates by name).
function functionTypesEqual(aParams MaxonTypeArray, existingReturn MaxonReturnType, paramTypes MaxonTypeArray, returnType MaxonReturnType) returns bool
	if aParams.count() != paramTypes.count() 'arity'
		return false
	end 'arity'
	for i in 0 upto aParams.count() 'each'
		let pA = try aParams.get(i) otherwise panic("functionTypesEqual: aParams.get OOB at {i} (arity already validated)")
		let pB = try paramTypes.get(i) otherwise panic("functionTypesEqual: paramTypes.get OOB at {i} (arity already validated)")
		if not maxonTypesStructurallyEqual(pA, b: pB) 'mismatch'
			return false
		end 'mismatch'
	end 'each'
	return maxonReturnTypesStructurallyEqual(existingReturn, b: returnType)
end 'functionTypesEqual'

// Structural equality on MaxonType. Two function-typed values compare
// equal iff their interned FunctionTypeId matches — `internFunctionType`
// guarantees same-shape signatures share an id, so this is the right
// equivalence even for function types whose param/return types are
// other function types. Used both by FunctionTypeRegistry interning and
// by TypeResolution's fillCmp change-detection.
export function maxonTypesStructurallyEqual(a MaxonType, b MaxonType) returns bool
	return match a 'lhs'
		boolean gives matchesBooleanArm(b)
		integer gives matchesIntegerArm(b)
		float gives matchesFloatArm(b)
		string gives matchesStringArm(b)
		named(idA) gives matchesNamedArm(b, idA: idA)
		function(idA) gives matchesFunctionArm(b, idA: idA)
		unresolved gives matchesUnresolvedArm(b)
		typeParameter(idA) gives matchesTypeParameterArm(b, idA: idA)
		genericInstance(idA) gives matchesGenericInstanceArm(b, idA: idA)
		interface(idA) gives matchesInterfaceArm(b, idA: idA)
		constInt(valueA) gives matchesConstIntArm(b, valueA: valueA)
		opaquePointer gives isOpaquePointerMaxonType(b)
		cstring gives matchesCstringArm(b)
	end 'lhs'
end 'maxonTypesStructurallyEqual'

// `cstring` is a distinct user-visible type — structurally equal only to
// another `cstring`, never to the synthetic `opaquePointer` ABI slot.
function matchesCstringArm(b MaxonType) returns bool
	return match b 'm'
		cstring gives true
		boolean to opaquePointer gives false
	end 'm'
end 'matchesCstringArm'

function matchesBooleanArm(b MaxonType) returns bool
	return match b 'm'
		boolean gives true
		integer to cstring gives false
	end 'm'
end 'matchesBooleanArm'

function matchesIntegerArm(b MaxonType) returns bool
	return match b 'm'
		integer gives true
		boolean gives false
		float to cstring gives false
	end 'm'
end 'matchesIntegerArm'

function matchesFloatArm(b MaxonType) returns bool
	return match b 'm'
		float gives true
		boolean to integer gives false
		string to cstring gives false
	end 'm'
end 'matchesFloatArm'

function matchesStringArm(b MaxonType) returns bool
	return match b 'm'
		string gives true
		boolean to float gives false
		named to cstring gives false
	end 'm'
end 'matchesStringArm'

function matchesNamedArm(b MaxonType, idA TypeNameId) returns bool
	return match b 'm'
		named(idB) gives idA == idB
		boolean to string gives false
		function to cstring gives false
	end 'm'
end 'matchesNamedArm'

function matchesFunctionArm(b MaxonType, idA FunctionTypeId) returns bool
	return match b 'm'
		function(idB) gives idA == idB
		boolean to named gives false
		unresolved to cstring gives false
	end 'm'
end 'matchesFunctionArm'

function matchesUnresolvedArm(b MaxonType) returns bool
	return match b 'm'
		unresolved gives true
		boolean to function gives false
		typeParameter to cstring gives false
	end 'm'
end 'matchesUnresolvedArm'

function matchesTypeParameterArm(b MaxonType, idA TypeParamId) returns bool
	return match b 'm'
		typeParameter(idB) gives idA == idB
		boolean to unresolved gives false
		genericInstance to cstring gives false
	end 'm'
end 'matchesTypeParameterArm'

function matchesGenericInstanceArm(b MaxonType, idA GenericInstanceId) returns bool
	return match b 'm'
		genericInstance(idB) gives idA == idB
		boolean to unresolved gives false
		typeParameter gives false
		interface to cstring gives false
	end 'm'
end 'matchesGenericInstanceArm'

function matchesInterfaceArm(b MaxonType, idA InterfaceTypeId) returns bool
	return match b 'm'
		interface(idB) gives idA == idB
		boolean to unresolved gives false
		typeParameter to genericInstance gives false
		constInt to cstring gives false
	end 'm'
end 'matchesInterfaceArm'

function matchesConstIntArm(b MaxonType, valueA IntConstant) returns bool
	return match b 'm'
		constInt(valueB) gives valueA == valueB
		boolean to interface gives false
		opaquePointer to cstring gives false
	end 'm'
end 'matchesConstIntArm'

export function maxonReturnTypesStructurallyEqual(a MaxonReturnType, b MaxonReturnType) returns bool
	return match a 'lhs'
		void gives returnTypeIsVoid(b)
		value(innerA) gives returnTypeMatchesValue(b, innerA: innerA)
	end 'lhs'
end 'maxonReturnTypesStructurallyEqual'

function returnTypeIsVoid(b MaxonReturnType) returns bool
	return match b 'm'
		void gives true
		value gives false
	end 'm'
end 'returnTypeIsVoid'

function returnTypeMatchesValue(b MaxonReturnType, innerA MaxonType) returns bool
	return match b 'm'
		void gives false
		value(innerB) gives maxonTypesStructurallyEqual(innerA, b: innerB)
	end 'm'
end 'returnTypeMatchesValue'

export typealias MaxonTypeArray = Array with MaxonType

// Convert a source-level type name token to a MaxonType, interning the name
// when it is not a primitive. The empty string and "void" are not valid
// MaxonTypes — callers needing to represent an optional/void return type
// should use internMaxonReturnType instead.
//
// C1.d: when `name` matches a registered interface (resolved or still in
// `unresolvedInterfaces` from earlier in the same parse), produce a
// `MaxonType.interface(_)` arm instead of `named(_)`. This is the upstream
// half that lets fat-pointer construction (C1.c) and witness-method dispatch
// (C1.d) actually fire on real input — without it, every interface name
// reaches lowering as `named` and the dispatch arm is structurally
// unreachable.
export function internMaxonType(project Project, name String) returns MaxonType
	if name == "bool" 'isBool'
		return MaxonType.boolean
	end 'isBool'
	// Phase 7 / 11.4: lowercase primitive names like `int`, `float`,
	// `byte`, `string` are used as type names by `extension int { … }`
	// blocks. Map them to their primitive MaxonType arms so the
	// extension's `__self` parameter lands with the correct primitive
	// type (otherwise interpolation `"{self}"` and other type-driven
	// dispatches would see `MaxonType.named("float")` and fall back to
	// generic struct-receiver paths).
	if name == "int" 'isInt'
		return MaxonType.integer
	end 'isInt'
	if name == "float" 'isFloat'
		return MaxonType.float
	end 'isFloat'
	if name == "byte" 'isByte'
		return MaxonType.integer
	end 'isByte'
	if name == "string" 'isString'
		return MaxonType.string
	end 'isString'
	if project.interfaces.contains(name) or project.unresolvedInterfaces.contains(name) 'isInterface'
		return MaxonType.interface(project.interfaceRegistry.intern(name))
	end 'isInterface'
	return MaxonType.named(project.typeNames.intern(name))
end 'internMaxonType'

// --- MaxonReturnType: function return type slot ---
// A function either returns nothing (void) or a value of some MaxonType.
// The parser produces this for every function's return type; lowerMaxonToStd
// maps it to the corresponding StdReturnType.

export union MaxonReturnType
	void
	value(inner MaxonType)
end 'MaxonReturnType'

// Parse a source-level return type token. An empty/missing token or the
// literal "void" means the function returns nothing.
export function internMaxonReturnType(project Project, name String) returns MaxonReturnType
	if name == "void" or name == "" 'isVoid'
		return MaxonReturnType.void
	end 'isVoid'
	return MaxonReturnType.value(internMaxonType(project, name: name))
end 'internMaxonReturnType'

export function maxonReturnTypeToString(project Project, ref MaxonReturnType) returns String
	return match ref 'str'
		void gives "void"
		value(inner) gives inner.toString(project)
	end 'str'
end 'maxonReturnTypeToString'

export function maxonReturnTypeIsVoid(ref MaxonReturnType) returns bool
	return match ref 'check'
		void gives true
		value gives false
	end 'check'
end 'maxonReturnTypeIsVoid'

// Returns the source-level name of a return type, or "" for void/primitives.
export function maxonReturnTypeName(project Project, ref MaxonReturnType) returns String
	return match ref 'name'
		void gives ""
		value(inner) gives inner.nameOrEmpty(project)
	end 'name'
end 'maxonReturnTypeName'

// --- Cache codecs ---
//
// Symmetric (de)serialization for MaxonType / MaxonReturnType using the
// .unionCases pattern: writers emit the variant ordinal, readers lift it
// through fromRawValue and match on the .unionCases enum (exhaustive).
// Adding a variant produces non-exhaustive-match errors on both sides
// until the codec is updated. See specs/union-cases.md for the contract.

export function writeMaxonType(project Project, buf ByteArray, t MaxonType) throws CacheCorruption
	writeDword(buf, value: t.ordinal)
	match t 'payload'
		// `unresolved` is the polymorphic-slot sentinel used by builtin
		// signatures (notably `__ManagedMemory.set/get/...`'s Element axis,
		// see registerManagedMemoryType). Serialise as a payload-less variant
		// so the slot survives the cache round trip and continues to trigger
		// `coerceArgToParam`'s early-exit on the user-code side.
		unresolved then break
		boolean then break
		integer then break
		float then break
		string then break
		named(id) then try writeString(buf, s: project.typeNames.get(id))
		// Cache v49: persist function-type signatures so stdlib functions with
		// function-typed parameters (e.g. `Iterable.map(transform(Element)
		// returns Element)`) survive cache round-trip. The reader re-interns
		// the (paramTypes, returnType) pair in the destination project's
		// `functionTypes` registry, reproducing a structurally equal id.
		function(id) then try writeFunctionTypePayload(project, buf: buf, id: id)
		// Phase 11.0 (cache v7): persist generic-aware MaxonType arms with
		// enough payload that the read side can re-intern into the
		// destination project's registries and reproduce the *same* MaxonType
		// shape (typeParameter/genericInstance/interface). Earlier versions
		// of this codec collapsed these arms to a printable name and read
		// them back as `MaxonType.named(intern(name))`, which broke the
		// inner-typealias substitution path on stdlib cache hits — e.g.
		// `Array.init(managed ElementMemory)` would surface a bare
		// `MaxonType.named("ElementMemory")` that lowering's namedIdCastCategory
		// could not resolve.
		typeParameter(id) then try writeTypeParameterPayload(project, buf: buf, id: id)
		genericInstance(id) then try writeGenericInstancePayload(project, buf: buf, id: id)
		interface(id) then try writeString(buf, s: project.interfaceRegistry.getName(id))
		// Phase 13 (sized typealiases): const-int args in generic instances.
		// Persist the i64 payload verbatim; the reader rebuilds the same arm.
		constInt(value) then writeQword(buf, value: value)
		// Synthetic ABI-bookkeeping slot. No payload — the tag itself carries
		// the entire signal. Reader rebuilds via `MaxonType.opaquePointer`.
		opaquePointer to cstring then break
	end 'payload'
end 'writeMaxonType'

// Phase 11 cache v7: a typeParameter is interned in `Project.typeParameters`
// by `(declaringTypeName, paramName)`. Persist both halves so the reader can
// reproduce the same id by re-interning into the destination project's
// registry. Constraints (where-clause traits) are not persisted because
// stdlib generic decls don't surface where-clauses through `funcSignatures`
// — every constraint is enforced at declaration parse time, not at the
// stdlib's function-call boundaries the cache replays.
function writeTypeParameterPayload(project Project, buf ByteArray, id TypeParamId) throws CacheCorruption
	try writeString(buf, s: project.typeParameters.getDeclaringTypeName(id))
	try writeString(buf, s: project.typeParameters.getName(id))
end 'writeTypeParameterPayload'

// Phase 11 cache v7: a genericInstance is interned in
// `Project.genericInstances` by `(baseId, args)`. Persist the base name +
// recursive arg list so the reader can reintern by walking into
// `readMaxonType` for each arg. Recursion bottoms out at primitive arms /
// named arms / typeParameter arms — generic instances of bounded depth
// only.
function writeGenericInstancePayload(project Project, buf ByteArray, id GenericInstanceId) throws CacheCorruption
	let (baseId, args) = project.genericInstances.get(id)
	try writeString(buf, s: project.typeNames.get(baseId))
	writeDword(buf, value: args.count())
	for i in 0 upto args.count() 'eachArg'
		let a = try args.get(i) otherwise panic("writeGenericInstancePayload: args.get OOB at {i}")
		try writeMaxonType(project, buf: buf, t: a)
	end 'eachArg'
end 'writeGenericInstancePayload'

// Cache v49: persist a function-type payload as (paramCount, paramType*,
// returnType). The reader walks the params + return type and re-interns
// through `internFunctionType`, which is content-addressed so structurally
// equal signatures round-trip to the same FunctionTypeId in the destination
// project. Bounded recursion: param/return types may themselves be function
// types but only the stdlib's hand-written signatures reach the codec.
function writeFunctionTypePayload(project Project, buf ByteArray, id FunctionTypeId) throws CacheCorruption
	let (paramTypes, returnType) = project.functionTypes.get(id)
	writeDword(buf, value: paramTypes.count())
	for i in 0 upto paramTypes.count() 'eachParam'
		let p = try paramTypes.get(i) otherwise panic("writeFunctionTypePayload: paramTypes.get OOB at {i}")
		try writeMaxonType(project, buf: buf, t: p)
	end 'eachParam'
	try writeMaxonReturnType(project, buf: buf, rt: returnType)
end 'writeFunctionTypePayload'

function readMaxonFunctionType(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let paramCount = readDword(buf, offset: offset)
	var pos = offset + 4
	var paramTypes = MaxonTypeArray.create()
	for _ in 0 upto paramCount 'eachParam'
		let (p, nextPos) = try readMaxonType(project, buf: buf, offset: pos)
		paramTypes.push(p)
		pos = nextPos
	end 'eachParam'
	let (returnType, endPos) = try readMaxonReturnType(project, buf: buf, offset: pos)
	let id = internFunctionType(project, paramTypes: paramTypes, returnType: returnType)
	return (MaxonType.function(id), endPos)
end 'readMaxonFunctionType'

function readMaxonTypeNamed(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let (name, nextPos) = try readString(buf, offset: offset)
	return (MaxonType.named(project.typeNames.intern(name)), nextPos)
end 'readMaxonTypeNamed'

// Phase 11 cache v7: read a typeParameter payload (declaringTypeName,
// paramName) and re-intern through `Project.typeParameters` so the
// returned id is meaningful in the destination project's registry. The
// destination project is the user project (already populated with the
// stdlib decls' bare struct/interface names), so this intern call also
// has the side effect of registering the type-parameter binding the
// stdlib decl used — which is exactly what `buildSubstitution` needs to
// produce when it later resolves a generic call site.
function readMaxonTypeParameter(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let (declaringTypeName, p1) = try readString(buf, offset: offset)
	let (paramName, p2) = try readString(buf, offset: p1)
	let id = project.typeParameters.intern(declaringTypeName, paramName: paramName)
	return (MaxonType.typeParameter(id), p2)
end 'readMaxonTypeParameter'

// Phase 11 cache v7: read a genericInstance payload (baseName, args) and
// re-intern through `Project.genericInstances`. Recurses into
// `readMaxonType` for each arg so any nested generic-aware MaxonType is
// rebuilt with the destination project's id space.
function readMaxonGenericInstance(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let (baseName, p1) = try readString(buf, offset: offset)
	let argCount = readDword(buf, offset: p1)
	var pos = p1 + 4
	var args = MaxonTypeArray.create()
	for _ in 0 upto argCount 'eachArg'
		let (a, p2) = try readMaxonType(project, buf: buf, offset: pos)
		pos = p2
		args.push(a)
	end 'eachArg'
	let baseId = project.typeNames.intern(baseName)
	let gid = project.genericInstances.intern(baseId, args: args)
	return (MaxonType.genericInstance(gid), pos)
end 'readMaxonGenericInstance'

// Phase 11 cache v7: read an interface payload (name) and re-intern
// through `Project.interfaceRegistry`. Symmetric counterpart to the
// `interface(id)` writer arm.
function readMaxonInterface(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let (name, nextPos) = try readString(buf, offset: offset)
	let id = project.interfaceRegistry.intern(name)
	return (MaxonType.interface(id), nextPos)
end 'readMaxonInterface'

export function readMaxonType(project Project, buf ByteArray, offset ByteOffset) returns (MaxonType, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let pos = offset + 4
	let kase = try MaxonType.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown MaxonType tag {raw}")
	match kase 'tag'
		boolean then return (MaxonType.boolean, pos)
		integer then return (MaxonType.integer, pos)
		float then return (MaxonType.float, pos)
		string then return (MaxonType.string, pos)
		named then return try readMaxonTypeNamed(project, buf: buf, offset: pos)
		// Cache v49: round-trip function-type signatures (param list +
		// return type). Symmetric with the `function(id)` writer arm.
		function then return try readMaxonFunctionType(project, buf: buf, offset: pos)
		unresolved then return (MaxonType.unresolved, pos)
		// Phase 11 cache v7: round-trip generic-aware arms with their full
		// payload so the reader rebuilds the same MaxonType the writer saw.
		// The earlier "named placeholder" reader broke inner-alias
		// substitution on stdlib cache hits (see writeMaxonType comment).
		typeParameter then return try readMaxonTypeParameter(project, buf: buf, offset: pos)
		genericInstance then return try readMaxonGenericInstance(project, buf: buf, offset: pos)
		interface then return try readMaxonInterface(project, buf: buf, offset: pos)
		// Phase 13 (sized typealiases): mirror writer's constInt payload.
		constInt then return (MaxonType.constInt(readQword(buf, offset: pos)), pos + 8)
		// Synthetic ABI-bookkeeping slot. No payload; mirror writer.
		opaquePointer then return (MaxonType.opaquePointer, pos)
		cstring then return (MaxonType.cstring, pos)
	end 'tag'
end 'readMaxonType'

export function writeMaxonReturnType(project Project, buf ByteArray, rt MaxonReturnType) throws CacheCorruption
	writeDword(buf, value: rt.ordinal)
	match rt 'payload'
		void then break
		value(inner) then try writeMaxonType(project, buf: buf, t: inner)
	end 'payload'
end 'writeMaxonReturnType'

function readMaxonReturnTypeValue(project Project, buf ByteArray, offset ByteOffset) returns (MaxonReturnType, ByteOffset) throws CacheCorruption
	let (inner, nextPos) = try readMaxonType(project, buf: buf, offset: offset)
	return (MaxonReturnType.value(inner), nextPos)
end 'readMaxonReturnTypeValue'

export function readMaxonReturnType(project Project, buf ByteArray, offset ByteOffset) returns (MaxonReturnType, ByteOffset) throws CacheCorruption
	let raw = readDword(buf, offset: offset)
	let pos = offset + 4
	let kase = try MaxonReturnType.unionCases.fromRawValue(raw) otherwise panic("corrupt cache: unknown MaxonReturnType tag {raw}")
	match kase 'tag'
		void then return (MaxonReturnType.void, pos)
		value then return try readMaxonReturnTypeValue(project, buf: buf, offset: pos)
	end 'tag'
end 'readMaxonReturnType'

// --- Op kinds ---

export union BinOpKind
	add = "add"
	sub = "sub"
	mul = "mul"
	div = "div"
	mod = "mod"
	bitAnd = "bitAnd"
	bitOr = "bitOr"
	boolOr = "or"
	bitXor = "bitXor"
	shl = "shl"
	shr = "shr"
end 'BinOpKind'

export union UnaryOpKind
	neg = "neg"
	// Bitwise complement (`~` semantics): for a 64-bit operand, flips every
	// bit. Currently the parser doesn't emit this directly — `not` always
	// emits `logicalNot` — but the kind is kept so a future `~` operator
	// or a TypeResolution rewrite of `logicalNot` over int operands has a
	// distinct lowering target.
	bitNot = "bitNot"
	// Logical NOT (`not` keyword): on a bool, produces the opposite bool;
	// on an integer with a constrained range that includes 0 and 1, the
	// lowerer interprets it as XOR-with-1. Parser emits this unconditionally;
	// lowerUnop picks the right opcode based on the operand's resolved type.
	logicalNot = "logicalNot"
end 'UnaryOpKind'

export union CmpPredicate
	eq = "eq"
	ne = "ne"
	lt = "lt"
	le = "le"
	gt = "gt"
	ge = "ge"
end 'CmpPredicate'

// Classification for `MaxonOp.error` ops. Keeps the error op itself small
// while letting diagnostic consumers (batch compile, future LSP) distinguish
// syntax-shape failures from semantic ones without parsing the message text.
export union MaxonErrorKind
	unexpectedToken = "unexpected-token"
	expectedExpression = "expected-expression"
	missingType = "missing-type"
	unresolvedName = "unresolved-name"
	other = "other"
end 'MaxonErrorKind'

// Phase 7 step 5: classification of an interpolation expression part used by
// `MaxonOp.stringInterp`. Discriminates how lowering should produce the
// (buffer, length) pair for a given expression value:
//   - i64/byte → call `mrt_i64_to_string` into a stack/heap buffer.
//   - f64/bool → reserved (no runtime helper yet in self-hosted runtime.std);
//     parser today rejects these with a diagnostic until the helpers ship.
//   - string  → load `String.managed.buffer` and `String.managed.length`.
//   - character → load `Character.managed.buffer` and `length` (same shape
//     as `string`, but the outer struct has only the `managed` field).
//   - stringable → call `toString()` through the type's Stringable witness
//     table; the returned String's `managed` buffer/length is the output.
//   - enumName → emit a select chain mapping the enum ordinal to its
//     declared case name; the case-name rdata literal supplies buffer/length.
export union InterpExprKind
	i64
	u64
	f64
	bool
	string
	character
	stringable
	enumName
	// Single-byte char-literal value carried as a raw integer codepoint.
	// Distinct from `character` (which expects a Character struct's
	// `__ManagedMemory` layout) because the parser's single-byte char-literal
	// fast path emits a raw integer rather than a Character struct so that
	// `b == 'a'` byte comparisons keep compiling without coercions. Lowering
	// encodes the codepoint as UTF-8 bytes and appends them to the
	// interpolation buffer at runtime.
	charByte
end 'InterpExprKind'

// Phase 7 step 5: one part of an interpolated string. Either a raw literal
// fragment (interned StringId; lowered to a globalAddr+constI64 length pair)
// or an expression value whose .toString() materialization is performed at
// lowering time per `kind`.
//
// `formatSpecId` on `expr` carries the optional `:format` clause text
// (e.g. `04x`, `.3`, `6.2`, `verbose`). An empty interned string means no
// format spec was written. Lowering routes formatted numeric parts through
// `mrt_i64_to_string_fmt` / `mrt_f64_to_string_fmt`; non-formatted parts
// keep the legacy fast paths.
export union StringInterpPart
	literal(stringId StringId)
	expr(valueName ByteArray, kind InterpExprKind, formatSpecId StringId)
end 'StringInterpPart'

export typealias StringInterpPartArray = Array with StringInterpPart

// --- MaxonOp union ---
// Every typed op carries a source-level MaxonType. Width selection and
// int-vs-float dispatch happen in lowerMaxonToStd.
//
// Every variant also carries a `range SourceRange` as its final field, locating
// the source span that produced the op. Synthetic ops (compiler-inserted
// conversions, runtime glue) pass `SourceRange.none()`; parser-emitted ops
// compute the range from the tokens they consumed. Used by diagnostic messages
// and by the LSP to map cursor positions to ops.
//
// **Value operands are names, not SSA ids.** Every result and operand that
// used to be a `ValueId` is now a `ByteArray` — a zero-copy slice over the
// lexer's source buffer for user-written variable references, or a per-function
// synthetic name (`$t0`, `$t1`, …) for intermediate results. SSA numbering is
// assigned later, at the Maxon→Std lowering boundary, so the Maxon dialect
// stays source-proximate and LSP-queryable.

export union MaxonOp
	// Literals
	literal(result ByteArray, value ParsedInt, valueType MaxonType, range SourceRange)
	// String literal materialization. Carries an interned StringId into
	// `project.strings`. Produced by TypeResolution when an
	// `unresolvedRead` resolves to a string-typed top-level constant.
	// Consumers downstream (cmp folding, varDecl with string-typed
	// initializer) read the StringId back from the producer-type map.
	// Result has type MaxonType.string.
	stringConst(result ByteArray, stringId StringId, range SourceRange)
	// Phase 7 step 6: multi-byte character literal materialization. Emitted
	// by `parseCharLiteralExpr` only when the decoded char literal exceeds
	// one byte; the single-byte fast path stays as an integer literal so
	// existing byte-comparison sites (`if b == 'a'` in the lexer) keep
	// compiling. The bytes are interned via `project.strings`. Lowering
	// allocates a fresh Character struct (8 bytes: managed@0 ptr to MM) over
	// an rdata-resident __ManagedMemory record. Result type is
	// MaxonType.named("Character").
	charLiteral(result ByteArray, stringId StringId, range SourceRange)
	// Phase 7 step 7: byte-string literal `b"..."` materialization. The
	// bytes are interned via `project.strings`. Lowering produces an
	// rdata-backed __ManagedMemory pointer (capacity = -2, elementSize = 1,
	// parentPtr = 0) — no outer wrapper struct. Result type is
	// MaxonType.named("__ManagedMemory") which TypeResolution treats as
	// alias-compatible with the user-visible `ByteArray` typealias.
	byteStringLiteral(result ByteArray, stringId StringId, range SourceRange)
	// Phase 7 step 5: interpolated-string materialization in expression
	// position. `parts` is a parallel sequence of literal fragments and
	// expression operands, in left-to-right source order. Lowering allocates
	// a fresh String + __ManagedMemory + buffer triple, materializes each
	// part's (buffer, length) pair (per-part runtime call for numeric
	// expressions; rdata addr + length for literals; double-load for string
	// expressions), memcopies them into the final buffer, and binds `result`
	// to the outer String pointer. Result has type MaxonType.string.
	stringInterp(result ByteArray, parts StringInterpPartArray, range SourceRange)
	// Variables
	varDecl(slotId VarSlot, value ByteArray, slotType MaxonType, range SourceRange)
	varLoad(result ByteArray, slotId VarSlot, slotType MaxonType, range SourceRange)
	varStore(slotId VarSlot, value ByteArray, range SourceRange)
	// Mutable top-level / static-field globals. `name` is the symbol used by
	// the data-section relocation (`__data_<qualifiedName>`); slotType drives
	// load width selection at lowering time.
	globalLoad(result ByteArray, name String, slotType MaxonType, range SourceRange)
	globalStore(name String, value ByteArray, slotType MaxonType, range SourceRange)
	// Arithmetic and bitwise binary ops
	binop(result ByteArray, left ByteArray, right ByteArray, opKind BinOpKind, operandType MaxonType, range SourceRange)
	// Unary ops
	unop(result ByteArray, operand ByteArray, opKind UnaryOpKind, operandType MaxonType, range SourceRange)
	// Type conversion. Both fromType and toType are explicit; lowerMaxonToStd
	// picks the right StdArithUnaryOpcode based on the type pair. `implicit` is
	// true for compiler-inserted conversions (e.g. `trunc(float)` → int) which
	// bypass the widening-only validation. Source location was formerly carried
	// by `line` / `column` fields on this variant specifically; it now flows
	// through the uniform `range` field along with every other op.
	convert(result ByteArray, operand ByteArray, fromType MaxonType, toType MaxonType, implicit bool, range SourceRange)
	// Runtime range-check placeholder for `EXPR as RangedAlias`. Emitted by
	// the parser immediately after a `convert` whose target is a named type
	// — the parser has no way to know yet whether the alias has a narrow
	// range. The `expandCastRangeChecks` pass runs after TypeResolution,
	// looks up `aliasName` in `project.typealiasRanges`, and either drops
	// the op (full-range alias, literal-only operand handled by E3005) or
	// splits the host block into a comparison + condBr + panic guard.
	// Lowering must never see this op — the expander rewrites every
	// instance before LowerMaxonToStd runs.
	castCheck(value ByteArray, aliasName String, range SourceRange)
	// Comparisons. leftType and rightType carry each operand's source-level type
	// so TypeResolution can diagnose mismatched comparisons (E3005) and lowering
	// can pick the correct opcode family. operandType is the advisory "joined"
	// type used by lowering for opcode selection.
	cmp(result ByteArray, left ByteArray, right ByteArray, predicate CmpPredicate, leftType MaxonType, rightType MaxonType, operandType MaxonType, range SourceRange)
	// Reference identity (pointer comparison)
	refEq(result ByteArray, left ByteArray, right ByteArray, negate bool, range SourceRange)
	// Control flow (terminators — placed as block terminators, not regular ops)
	condBr(cond ByteArray, thenTarget BlockId, elseTarget BlockId, range SourceRange)
	br(target BlockId, range SourceRange)
	// Functions. `callee` is a ByteArray slice over the call-site name
	// token — the *unqualified* name as written. Parser does NOT consult
	// the function registry; lowering qualifies the callee per `callContext`
	// (see CallContext docs above) and looks up the resolved signature there.
	// `argLabels` is parallel to `args`: each entry is the source-level
	// `name:` label for the corresponding positional arg, or "" if the arg
	// was unlabeled. `argTypes` is parallel to `args`: each entry carries
	// the parser-inferred MaxonType of the corresponding argument
	// expression — lowering uses this directly to type-check against the
	// callee signature without re-walking the value-type map. `argRanges`
	// is parallel to `args`: each entry locates the argument expression's
	// source span so per-arg diagnostics (E3005) point at the offending
	// expression rather than the call site as a whole. Lowering performs
	// the signature-driven slot fill, default insertion, and implicit
	// conversion the parser used to do at parse time.
	call(result ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, range SourceRange)
	// Method call on a value receiver: `receiver.methodName(args)`. Parser
	// emits this for any postfix `.identifier(` form on a value receiver.
	// Lowering looks up the receiver's struct type via the per-function
	// value-type map, builds `{receiverType}.{methodName}` as the qualified
	// callee, prepends the receiver as the implicit __self argument, then
	// lowers as a normal call. `argTypes` and `argRanges` carry the same
	// parser-inferred per-arg metadata as `call` (see above).
	methodCall(result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, range SourceRange)
	ret(retVal ByteArray, range SourceRange)
	// Range check panic (emitted by parser, lowered to std.system.globalAddr +
	// std.call in lowerMaxonToStd). The panic-message label (`__panic_msg_N`)
	// used by the Std dialect is assigned at lowering time from a lowering-
	// pass-local counter, not from an SSA ValueId — the Maxon op itself just
	// carries the interned id of the message text via `project.strings`.
	panic(stringId StringId, range SourceRange)
	// Runtime-formatted panic message. `stringValue` is a ByteArray name
	// referring to the SSA value of a `String` struct produced by an upstream
	// `stringInterp` op (the heap-allocated message + null terminator). The
	// lowering walks the String's `.managed` field then the inner
	// `__ManagedMemory.buffer` field to recover the C-string pointer it
	// passes to `mrt_panic`. The interp lowering already null-terminates and
	// already includes the location prefix and trailing newline (those are
	// baked into the leading/trailing fragments of the interpolation by the
	// parser), so this lowering does no further mutation of the buffer.
	panicDynamic(stringValue ByteArray, range SourceRange)
	// Struct operations. All carry source-level *names*, not pre-computed
	// offsets/sizes — lowering walks `project.structTypes` to resolve.
	//   - structAlloc: `structName` is the source-level type name. Lowering
	//     looks up its `byteSize` from `project.structTypes.get(structName)`
	//     and emits the const + `mrt_alloc` call.
	//   - fieldLoad/Store: `receiver` is the value-name holding the struct
	//     pointer; `fieldName` is the source-level field identifier.
	//     Lowering reads the receiver's struct type from its value-type map
	//     and resolves `(structType, fieldName)` to a numeric offset.
	//   - selfFieldLoad/Store: bare-name field access inside an instance
	//     method (`self.x` or just `x` when `x` is a self-field). Lowering
	//     recovers the enclosing type from `func.name` (which is always
	//     `Type.method`), then resolves the field as for fieldLoad/Store.
	structAlloc(result ByteArray, structName ByteArray, range SourceRange)
	fieldLoad(result ByteArray, receiver ByteArray, fieldName ByteArray, range SourceRange)
	// `isInit` distinguishes a struct-literal field initialization (where
	// writing a `let`-declared field is part of construction) from a post-
	// construction reassignment (where `let` rejects with E2013). Lowering
	// only enforces immutability when `isInit == false`.
	fieldStore(receiver ByteArray, fieldName ByteArray, value ByteArray, isInit bool, range SourceRange)
	selfFieldLoad(result ByteArray, fieldName ByteArray, range SourceRange)
	selfFieldStore(fieldName ByteArray, value ByteArray, range SourceRange)
	// Parser-emitted placeholder for a bare or qualified name read whose
	// kind the parser can't decide without cross-file knowledge:
	//   - bare `name`   → may be a global var read or a top-level constant
	//   - `Type.field`  → may be a global var read or a top-level constant
	// `name` is the source-level identifier (with the dot present for the
	// qualified form). TypeResolution rewrites this op to `globalLoad`,
	// substitutes a literal value when it resolves to a top-level constant,
	// or emits a `semanticUnknownName` diagnostic. Lowering must never see
	// this op.
	unresolvedRead(result ByteArray, name String, range SourceRange)
	// Parser-emitted placeholder for an LHS write whose kind the parser
	// can't decide without cross-file knowledge:
	//   - bare `name = expr`        → may be a global var write
	//   - `Type.field = expr`       → may be a global var write
	// `name` is the source-level identifier (with the dot present for the
	// qualified form). TypeResolution rewrites this op to `globalStore`,
	// or emits a `semanticUnknownName` diagnostic. Top-level constants are
	// not assignable, so a write that resolves to one becomes a diagnostic.
	// Lowering must never see this op.
	unresolvedAssign(name String, value ByteArray, range SourceRange)
	// Parser-emitted block terminator for one match arm's dispatch:
	// "if scrutinee == EnumName.caseName then thenTarget else elseTarget".
	// The parser cannot resolve the case name to its raw value at parse
	// time without breaking the rule that the parser performs no type
	// inference — so it emits this placeholder carrying the case name
	// verbatim and lets TypeResolution fill in `rawValue` / `isFloat`
	// once the scrutinee's enum type is known. `resolved` flips to true
	// when TR has filled the slot; lowering panics on an unresolved op.
	// On a TR-detected miss (unknown case, non-enum scrutinee) TR
	// rewrites the op to `br(elseTarget, ...)` after reporting the
	// diagnostic, so the block still has a valid terminator.
	// Phase 9 Stage 2: `bindingNames` carries the destructured payload names
	// emitted by `caseName(x, _, var y) then ...`. Empty for bare-case match
	// arms (which is every arm parsed before Stage 2). When non-empty,
	// Stage 3 lowering emits an `enumPayloadRead` for each non-discard
	// binding before the user body executes. The slot is `ByteArrayArray`
	// rather than a richer struct so this stays a pure plumbing extension;
	// the parser writes empty for discards and the binding's varDecl owns
	// the type info on the read side.
	enumMatchArm(scrutineeName ByteArray, caseName String, scrutineeType MaxonType, rawValue IntConstant, isFloat bool, resolved bool, thenTarget BlockId, elseTarget BlockId, bindingNames ByteArrayArray, range SourceRange)
	// Phase 9 Stage 2: union value construction. Emitted inside the body
	// of each synthesized `__construct_{UnionName}_{caseName}` function.
	// Stage 3 lowers to `mm_alloc(size, destructorPtr, tag) + tag-store +
	// per-field stores`. Stage 2 leaves the constructor bodies empty
	// (single `error` placeholder), so no production site emits this op
	// yet — it's reserved here as part of the dialect skeleton.
	enumConstruct(result ByteArray, enumName String, caseName String, payloadValues ByteArrayArray, range SourceRange)
	// Phase 9 Stage 2: load the tag (case ordinal) from a union value.
	// Stage 3 lowers to `loadIndirect i64 [enumValName + 0]`. Used by the
	// match-arm dispatch path and by `__destruct_{UnionName}` (Stage 4)
	// to branch on the live variant.
	enumTag(result ByteArray, enumValName ByteArray, range SourceRange)
	// Phase 9 Stage 2: read one payload field from a union value. Stage 3
	// lowers to `loadIndirect <fieldType> [enumValName + 8 + fieldIndex*8]`
	// plus a refcount-bump for managed types. `fieldType` carries the
	// concrete field type so lowering picks the right load width and
	// managed-aware bump. Float fields bit-cast i64->f64 inside the lowering.
	// `caseName` identifies which union case this read belongs to;
	// TR uses it to resolve `fieldType` when the parser left it
	// `unresolved`, since the field's type depends on the case (different
	// cases of the same union have independent payload field types).
	enumPayloadRead(result ByteArray, enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType, range SourceRange)
	// Phase 9 Stage 2: write one payload field of a union value.
	// Reserved for Stage 4 (match-binding write-back): an assignment
	// `value = 42` inside an arm body on a `var` scrutinee rewrites
	// to this op. Stage 2 declares it but never emits it; lowering
	// panics on a stray sighting to surface a misordered pipeline early.
	enumPayloadStore(enumValName ByteArray, caseName String, fieldIndex IntConstant, fieldType MaxonType, newValueName ByteArray, range SourceRange)
	// Phase 9 Stage 0: range match-arm terminator. Lowers to
	// `scrutinee >= lo AND scrutinee <= hi (or < hi for upto)` plus
	// `cond_br thenTarget elseTarget`. `loValue` / `hiValue` are
	// integer literals; when `hasMinSentinel` is true the lower
	// comparison is skipped (matches any value <= hi); when
	// `hasMaxSentinel` is true the upper comparison is skipped
	// (matches any value >= lo). `isUpto` selects `<` over `<=` on the
	// upper bound. When `enumOwnerName` is non-empty the bounds are
	// case ordinals against that enum (float-backed enums need a raw→
	// ordinal lookup at lowering since the scrutinee is the f64 raw
	// value, not the ordinal); empty means a numeric-scrutinee range.
	rangeMatchArm(scrutineeName ByteArray, loValue ParsedInt, hiValue ParsedInt, isUpto bool, hasMinSentinel bool, hasMaxSentinel bool, enumOwnerName String, thenTarget BlockId, elseTarget BlockId, range SourceRange)
	// Error anchor. The parser emits this when it cannot produce a well-formed
	// op for a given source span (expected a type and got nothing, expected an
	// expression and got a stray keyword, etc.). Batch compile already routes
	// a matching `reportCompileError` diagnostic into `project.diagnostics` at
	// the same point; the `error` op gives the future LSP a durable anchor to
	// attach its squiggle to at the op's `range`. `LowerMaxonToStd` emits no
	// Std op for this variant and simply continues — later passes pattern-match
	// `error` in their `default`/`literal to refEq` bounds and skip it too.
	error(kind MaxonErrorKind, message String, range SourceRange)
	// Phase 4: throw a typed enum variant. Terminator. `enumName` is the
	// bare error-enum name as written (e.g. "FileError"); `variantName` is
	// the bare case name (e.g. "notFound"). LowerMaxonToStd resolves the
	// variant ordinal via project.unresolvedEnums / project.enumTypes, and
	// emits a `StdCallOp.errorReturn` that returns `ordinal + 1` (0 reserved
	// for "no error in flight") in the secondary error register (RDX/X1)
	// alongside a default primary value of the enclosing function's primary
	// return type — the multi-value-return error ABI.
	//
	// Phase 9 Stage 5c: `payloadValueName` is the SSA name of a pre-emitted
	// union constructor result for associated-value error enums (empty
	// ByteArray when the enum is a bare-case enum and the value slot is a
	// throw-time default). When non-empty, lowering threads that value into
	// the primary return register so the caller's `try ... otherwise (e)`
	// binding sees the union pointer through the existing multi-value-return
	// ABI — the value slot's MEANING flips from "default placeholder" to
	// "union pointer" while the slot count stays at two (option-1 ABI from
	// the Phase 9 plan).
	throw(enumName String, variantName String, payloadValueName ByteArray, range SourceRange)
	// Phase 4: throwing call. Same shape as `call` plus an `errorBoundName`
	// — the synthetic name the parser allocated to receive the post-call
	// error flag. LowerMaxonToStd emits a single `StdCallOp.tryCall` whose
	// SSA def for the secondary value is bound to `errorBoundName`. The
	// backend lowers tryCall to a call that picks up the flag from the
	// secondary return register (RDX/X1). Subsequent parser-emitted ops
	// (cmp + condBr) branch on that flag to either propagate or fall through.
	tryCall(result ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, range SourceRange)
	// Phase 5 (multi-value-return error ABI): throwing method call. Same
	// shape as `methodCall` plus an `errorBoundName` - the synthetic name
	// the parser allocated to receive the post-call error flag. The parser
	// emits this for every methodCall site that immediately precedes an
	// error-flag drain (try-expression non-call inner, for-in iterator
	// `createIterator`/`advance`, array-literal `__mm.set`/`setLength`).
	// LowerMaxonToStd routes through `lowerMethodCall` with a non-zero
	// `errorFlagId` so the emitted Std op is a single `StdCallOp.tryCall`
	// (multi-value-return) — mirroring `tryCall`'s relationship to `call`.
	// The backend picks up the flag from the secondary return register
	// (RDX/X1) and binds it to `errorBoundName`.
	tryMethodCall(result ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorBoundName ByteArray, range SourceRange)
	// Phase 5: re-publish a runtime-bound error flag and return. Terminator.
	// `parseTryPropagation` emits this for the propagation arm of `try EXPR`
	// (no `otherwise`): the flag bound by the preceding tryCall /
	// tryMethodCall must be re-raised in the current function. Lowering
	// emits `StdCallOp.errorReturn(zeroDefault, errorFlagId: resolveName(flagName))`
	// - same shape as `MaxonOp.throw`'s lowering except the flag value is a
	// runtime SSA name rather than a compile-time-known variant ordinal.
	rethrow(flagName ByteArray, range SourceRange)
	// Stage D (closures): address-of a named function with no captured env.
	// Emitted by parseClosure when the closure body references no outer
	// locals. `funcName` is the qualified name of the lifted function
	// (`_$closure_<n>` for closure expressions, full qualified name for
	// raw function references). `fnTypeId` indexes Project.functionTypes
	// for type-flow propagation. Lowered (Stage E) to an StdCallOp.funcRef
	// paired with a null env so a downstream indirectCall passes a 0
	// env-pointer through the standard ABI slot.
	functionRef(result ByteArray, funcName String, fnTypeId FunctionTypeId, range SourceRange)
	// Stage D (closures): construct a closure value as a function pointer
	// plus a heap-allocated env block holding addresses of captured outer
	// locals. `capturedNames` lists outer-variable names in
	// capture-index order; `capturedTypes` is parallel and carries each
	// capture's MaxonType so lowering can pick the correct load width
	// when materializing dereferences. Lowered (Stage E) to mrt_alloc +
	// per-capture stackAddr/storeIndirect plus the funcRef pair, with
	// the env-name recorded in a per-function map keyed by the funcRef
	// value-id so the matching indirectCall can forward the env.
	closureCreate(result ByteArray, funcName String, fnTypeId FunctionTypeId, capturedNames StringArray, capturedTypes MaxonTypeArray, range SourceRange)
	// Stage D (closures): inside a lifted closure body, recover a captured
	// value by indirect double-load through the hidden `__env`
	// parameter. `captureIndex` is the env-array slot index for this
	// capture; `captureName` is the original outer-variable name (used
	// by the printer and by capture-bookkeeping diagnostics).
	// `captureType` is the MaxonType of the captured value, retained so
	// downstream type-flow sees a concrete type without re-deriving it
	// from the env layout. Lowered (Stage E) to two loadIndirect ops:
	// the first reads the captured slot's address from the env array,
	// the second dereferences it to recover the live value.
	closureEnvLoad(result ByteArray, captureIndex ParsedInt, captureName ByteArray, captureType MaxonType, range SourceRange)
	// Stage D (closures): call through a function-typed value. `callee`
	// is the value-name holding the function pointer (always the result
	// of an upstream functionRef or closureCreate); `fnTypeId` resolves
	// the calling-convention shape via Project.functionTypes. `args`,
	// `argLabels`, `argTypes`, `argRanges` mirror the matching fields on
	// `call` and `methodCall`. Lowered (Stage E) by forwarding the
	// matching `__env_<callee>` slot as the trailing arg before the
	// user-visible args, so `apply(f, x)` and a closure-with-captures
	// share one compiled body via the paired-pointer ABI.
	indirectCall(result ByteArray, callee ByteArray, fnTypeId FunctionTypeId, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, range SourceRange)
	// Phase 11 Step 9 (parser-only): a `for X in iterable 'label'` loop whose
	// source is an arbitrary expression (not a `to`/`upto` range). The
	// parser emits this placeholder as a regular op so the body still
	// parses and downstream errors surface; full lowering through the
	// iterator-protocol witness calls (`createIterator`/`current`/
	// `advance`) is deferred to Step 8 of the Phase 11 plan. Reaching
	// `LowerMaxonToStd` with this op panics ("not implemented yet —
	// Step 8") because no current code path emits it for a function
	// that downstream actually compiles.
	//   - iterName: source-level loop variable name
	//   - iterType: inferred element type (MaxonType.unresolved at parse
	//     time; later filled by Step 8's resolution)
	//   - sourceValue: the value-name of the iterable expression's result
	//   - sourceType: parser-inferred MaxonType of `sourceValue` (may be
	//     unresolved; resolution fills it)
	//   - bodyBlockId: first block of the parsed loop body
	//   - exitBlockId: post-loop join block (target of break)
	//   - label: source-level loop label (already without surrounding `'`)
	forInIterable(iterName String, iterSlot VarSlot, iterType MaxonType, sourceValue ByteArray, sourceType MaxonType, bodyBlockId BlockId, exitBlockId BlockId, label String, range SourceRange)
end 'MaxonOp'

export typealias MaxonOpArray = Array with MaxonOp

// Maxon IR values are now identified by name slices (ByteArray). The printer
// renders each operand as %{name} by materializing a fresh String from the
// underlying bytes — cold-path work only reached by --emit-ir and friends.
export function maxonOpToString(project Project, op MaxonOp, blocks IrBlockArray) returns String
	let lb = "\{"
	let rb = "\}"
	return match op 'print'
		literal(result, value, valueType, _) gives "%{String.from(result)} = maxon.literal {lb}value = {value} : {valueType.toString(project)}{rb}"
		stringConst(result, stringId, _) gives "%{String.from(result)} = maxon.string_const \"{project.strings.get(stringId)}\" #{stringId}"
		charLiteral(result, stringId, _) gives "%{String.from(result)} = maxon.char_literal \"{project.strings.get(stringId)}\" #{stringId}"
		byteStringLiteral(result, stringId, _) gives "%{String.from(result)} = maxon.byte_string_literal \"{project.strings.get(stringId)}\" #{stringId}"
		stringInterp(result, parts, _) gives "%{String.from(result)} = maxon.string_interp [{formatStringInterpParts(project, parts: parts)}]"
		varDecl(slotId, value, slotType, _) gives "maxon.var_decl slot_{slotId}, %{String.from(value)} : {slotType.toString(project)}"
		varLoad(result, slotId, slotType, _) gives "%{String.from(result)} = maxon.var_load slot_{slotId} : {slotType.toString(project)}"
		varStore(slotId, value, _) gives "maxon.var_store slot_{slotId}, %{String.from(value)}"
		globalLoad(result, name, slotType, _) gives "%{String.from(result)} = maxon.global_load @{name} : {slotType.toString(project)}"
		globalStore(name, value, slotType, _) gives "maxon.global_store @{name}, %{String.from(value)} : {slotType.toString(project)}"
		binop(result, left, right, opKind, operandType, _) gives "%{String.from(result)} = maxon.binop %{String.from(left)}, %{String.from(right)} {lb}op = {opKind.rawValue}{rb} {lb}type = {operandType.toString(project)}{rb}"
		unop(result, operand, opKind, operandType, _) gives "%{String.from(result)} = maxon.unop %{String.from(operand)} {lb}op = {opKind.rawValue}{rb} {lb}type = {operandType.toString(project)}{rb}"
		convert(result, operand, fromType, toType, _, _) gives "%{String.from(result)} = maxon.convert %{String.from(operand)} : {fromType.toString(project)} -> {toType.toString(project)}"
		castCheck(value, aliasName, _) gives "maxon.cast_check %{String.from(value)} : {aliasName}"
		cmp(result, left, right, predicate, _, _, operandType, _) gives "%{String.from(result)} = maxon.cmp %{String.from(left)}, %{String.from(right)} {lb}op = {predicate.name}{rb} {lb}type = {operandType.toString(project)}{rb}"
		refEq(result, left, right, negate, _) gives "%{String.from(result)} = maxon.{refEqMnemonic(negate)} %{String.from(left)}, %{String.from(right)}"
		condBr(cond, thenTarget, elseTarget, _) gives maxonCondBrToString(cond, thenTarget: thenTarget, elseTarget: elseTarget, blocks: blocks)
		br(target, _) gives maxonBrToString(target, blocks: blocks)
		call(result, callee, callContext, args, argLabels, _, _, _) gives "%{String.from(result)} = maxon.call @{String.from(callee)} {lb}ctx = {callContextToString(callContext)}{rb}({formatArgNamesWithLabels(args, argLabels: argLabels)})"
		methodCall(result, receiver, methodName, args, argLabels, _, _, _) gives "%{String.from(result)} = maxon.method_call %{String.from(receiver)}.{String.from(methodName)}({formatArgNamesWithLabels(args, argLabels: argLabels)})"
		ret(retVal, _) gives "maxon.return %{String.from(retVal)}"
		panic(stringId, _) gives "maxon.panic \"{project.strings.get(stringId)}\" #{stringId}"
		panicDynamic(stringValue, _) gives "maxon.panic_dynamic %{String.from(stringValue)}"
		structAlloc(result, structName, _) gives "%{String.from(result)} = maxon.struct_alloc {lb}type = {String.from(structName)}{rb}"
		fieldLoad(result, receiver, fieldName, _) gives "%{String.from(result)} = maxon.field_load %{String.from(receiver)}.{String.from(fieldName)}"
		fieldStore(receiver, fieldName, value, _, _) gives "maxon.field_store %{String.from(receiver)}.{String.from(fieldName)}, %{String.from(value)}"
		selfFieldLoad(result, fieldName, _) gives "%{String.from(result)} = maxon.self_field_load .{String.from(fieldName)}"
		selfFieldStore(fieldName, value, _) gives "maxon.self_field_store .{String.from(fieldName)}, %{String.from(value)}"
		unresolvedRead(result, name, _) gives "%{String.from(result)} = maxon.unresolved_read @{name}"
		unresolvedAssign(name, value, _) gives "maxon.unresolved_assign @{name}, %{String.from(value)}"
		enumMatchArm(scrutineeName, caseName, _, _, _, _, thenTarget, elseTarget, bindingNames, _) gives maxonEnumMatchArmToString(scrutineeName, caseName: caseName, bindingNames: bindingNames, thenTarget: thenTarget, elseTarget: elseTarget, blocks: blocks)
		enumConstruct(result, enumName, caseName, payloadValues, _) gives "%{String.from(result)} = maxon.enum_construct {enumName}.{caseName}({formatArgNames(payloadValues)})"
		enumTag(result, enumValName, _) gives "%{String.from(result)} = maxon.enum_tag %{String.from(enumValName)}"
		enumPayloadRead(result, enumValName, _, fieldIndex, fieldType, _) gives "%{String.from(result)} = maxon.enum_payload_read %{String.from(enumValName)}[{fieldIndex}] : {fieldType.toString(project)}"
		enumPayloadStore(enumValName, _, fieldIndex, fieldType, newValueName, _) gives "maxon.enum_payload_store %{String.from(enumValName)}[{fieldIndex}] = %{String.from(newValueName)} : {fieldType.toString(project)}"
		rangeMatchArm(scrutineeName, loValue, hiValue, isUpto, hasMinSentinel, hasMaxSentinel, _, thenTarget, elseTarget, _) gives maxonRangeMatchArmToString(scrutineeName, loValue: loValue, hiValue: hiValue, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: hasMaxSentinel, thenTarget: thenTarget, elseTarget: elseTarget, blocks: blocks)
		error(kind, message, _) gives "maxon.error [{kind.rawValue}] \"{message}\""
		throw (enumName, variantName, payloadValueName, _) gives maxonThrowToString(enumName, variantName: variantName, payloadValueName: payloadValueName)
		tryCall(result, callee, callContext, args, argLabels, _, _, errorBoundName, _) gives "%{String.from(result)} = maxon.try_call @{String.from(callee)} {lb}ctx = {callContextToString(callContext)}{rb}({formatArgNamesWithLabels(args, argLabels: argLabels)}) -> err %{String.from(errorBoundName)}"
		tryMethodCall(result, receiver, methodName, args, argLabels, _, _, errorBoundName, _) gives "%{String.from(result)} = maxon.try_method_call %{String.from(receiver)}.{String.from(methodName)}({formatArgNamesWithLabels(args, argLabels: argLabels)}) -> err %{String.from(errorBoundName)}"
		rethrow(flagName, _) gives "maxon.rethrow %{String.from(flagName)}"
		functionRef(result, funcName, fnTypeId, _) gives "%{String.from(result)} = maxon.function_ref @{funcName} {lb}fnType = #{fnTypeId}{rb}"
		closureCreate(result, funcName, fnTypeId, capturedNames, _, _) gives "%{String.from(result)} = maxon.closure_create @{funcName} {lb}fnType = #{fnTypeId}{rb} captures=[{formatCaptureNames(capturedNames)}]"
		closureEnvLoad(result, captureIndex, captureName, _, _) gives "%{String.from(result)} = maxon.closure_env_load idx={captureIndex} name={String.from(captureName)}"
		indirectCall(result, callee, fnTypeId, args, argLabels, _, _, _) gives "%{String.from(result)} = maxon.indirect_call %{String.from(callee)}({formatArgNamesWithLabels(args, argLabels: argLabels)}) {lb}fnType = #{fnTypeId}{rb}"
		forInIterable(iterName, _, iterType, sourceValue, sourceType, bodyBlockId, exitBlockId, label, _) gives "maxon.for_in_iterable {iterName} : {iterType.toString(project)} in %{String.from(sourceValue)} : {sourceType.toString(project)} {lb}body = {resolveBlockLabel(bodyBlockId, blocks: blocks)}, exit = {resolveBlockLabel(exitBlockId, blocks: blocks)}, label = '{label}'{rb}"
	end 'print'
end 'maxonOpToString'

// Phase 9 Stage 5c: pretty-print `MaxonOp.throw`. Bare-enum throws (empty
// `payloadValueName`) keep the original `maxon.throw EnumName.case` form;
// associated-value throws emit `maxon.throw EnumName.case via %ssaName` so IR
// dumps reveal the union pointer being threaded through the value-return slot.
function maxonThrowToString(enumName String, variantName String, payloadValueName ByteArray) returns String
	if payloadValueName.isEmpty() 'noPayload'
		return "maxon.throw {enumName}.{variantName}"
	end 'noPayload'
	return "maxon.throw {enumName}.{variantName} via %{String.from(payloadValueName)}"
end 'maxonThrowToString'

function maxonCondBrToString(cond ByteArray, thenTarget BlockId, elseTarget BlockId, blocks IrBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenTarget, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseTarget, blocks: blocks)
	return "maxon.cond_br %{String.from(cond)} [then: {thenLabel}, else: {elseLabel}]"
end 'maxonCondBrToString'

function maxonEnumMatchArmToString(scrutineeName ByteArray, caseName String, bindingNames ByteArrayArray, thenTarget BlockId, elseTarget BlockId, blocks IrBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenTarget, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseTarget, blocks: blocks)
	var bindingSuffix = ""
	if bindingNames.count() > 0 'hasBindings'
		bindingSuffix = "({formatArgNames(bindingNames)})"
	end 'hasBindings'
	return "maxon.enum_match_arm %{String.from(scrutineeName)} == .{caseName}{bindingSuffix} [then: {thenLabel}, else: {elseLabel}]"
end 'maxonEnumMatchArmToString'

function maxonRangeMatchArmToString(scrutineeName ByteArray, loValue ParsedInt, hiValue ParsedInt, isUpto bool, hasMinSentinel bool, hasMaxSentinel bool, thenTarget BlockId, elseTarget BlockId, blocks IrBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenTarget, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseTarget, blocks: blocks)
	let loDisplay = "min" if hasMinSentinel else "{loValue}"
	let hiDisplay = "max" if hasMaxSentinel else "{hiValue}"
	let opName = "upto" if isUpto else "to"
	return "maxon.range_match_arm %{String.from(scrutineeName)} in {loDisplay} {opName} {hiDisplay} [then: {thenLabel}, else: {elseLabel}]"
end 'maxonRangeMatchArmToString'

function maxonBrToString(target BlockId, blocks IrBlockArray) returns String
	let label = resolveBlockLabel(target, blocks: blocks)
	return "maxon.br {label}"
end 'maxonBrToString'

function refEqMnemonic(negate bool) returns String
	if negate 'neg'
		return "ref_ne"
	end 'neg'
	return "ref_eq"
end 'refEqMnemonic'

// Phase 7 step 5: cold-path printer for `MaxonOp.stringInterp` parts.
// Renders each part as either `"...lit..." #id` for literals or
// `%name : kind` for expression parts.
export function formatStringInterpParts(project Project, parts StringInterpPartArray) returns String
	var out = ""
	for i in 0 upto parts.count() 'each'
		let part = try parts.get(i) otherwise panic("formatStringInterpParts: parts.get OOB at {i}")
		if i > 0 'comma'
			out = "{out}, "
		end 'comma'
		match part 'k'
			literal(stringId) then out = "{out}\"{project.strings.get(stringId)}\" #{stringId}"
			expr(valueName, kind, formatSpecId) then out = "{out}{formatInterpExprPart(project, valueName: valueName, kind: kind, formatSpecId: formatSpecId)}"
		end 'k'
	end 'each'
	return out
end 'formatStringInterpParts'

// Helper for `formatStringInterpParts` — separated out because match `then`
// arms only accept a single statement and the format-spec suffix needs an
// `if not isEmpty` check before tacking on `:spec`.
function formatInterpExprPart(project Project, valueName ByteArray, kind InterpExprKind, formatSpecId StringId) returns String
	var out = "%{String.from(valueName)} : {interpExprKindName(kind)}"
	let fmtStr = project.strings.get(formatSpecId)
	if not fmtStr.isEmpty() 'hasFmt'
		out = "{out}:{fmtStr}"
	end 'hasFmt'
	return out
end 'formatInterpExprPart'

function interpExprKindName(kind InterpExprKind) returns String
	return match kind 'n'
		i64 gives "i64"
		u64 gives "u64"
		f64 gives "f64"
		bool gives "bool"
		string gives "string"
		character gives "character"
		stringable gives "stringable"
		enumName gives "enumName"
		charByte gives "charByte"
	end 'n'
end 'interpExprKindName'

export function formatArgIds(argIds ValueIdArray) returns String
	var result = ""
	for i in 0 upto argIds.count() 'each'
		let argId = try argIds.get(i) otherwise panic("invariant: i < argIds.count() but get failed")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}%{argId}"
	end 'each'
	return result
end 'formatArgIds'

// Name-slice variant of the above, used by the new call printer. Converts
// each ByteArray operand to a String for display (cold path).
export function formatArgNames(args ByteArrayArray) returns String
	var result = ""
	for i in 0 upto args.count() 'each'
		let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}%{String.from(arg)}"
	end 'each'
	return result
end 'formatArgNames'

// Like formatArgNames, but prefixes each arg with its source label when one
// is present (empty label = positional). Used by call/methodCall printers.
export function formatArgNamesWithLabels(args ByteArrayArray, argLabels StringArray) returns String
	var result = ""
	for i in 0 upto args.count() 'each'
		let arg = try args.get(i) otherwise panic("invariant: i < args.count() but get failed")
		let label = try argLabels.get(i) otherwise ""
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		if label.isEmpty() 'positional'
			result = "{result}%{String.from(arg)}"
		end 'positional' else 'labeled'
			result = "{result}{label}: %{String.from(arg)}"
		end 'labeled'
	end 'each'
	return result
end 'formatArgNamesWithLabels'

// Comma-joined capture-name list for the closure-create printer. The op
// stores capture names as plain `String` (not the byte-slice ByteArray used
// for source identifiers), so this is a straight join — no `String.from`
// conversion needed.
export function formatCaptureNames(names StringArray) returns String
	var result = ""
	for i in 0 upto names.count() 'each'
		let n = try names.get(i) otherwise panic("invariant: i < names.count() but get failed")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}{n}"
	end 'each'
	return result
end 'formatCaptureNames'

// Pretty-print a CallContext for IR dumps. Cold path.
export function callContextToString(ctx CallContext) returns String
	return match ctx 'show'
		free gives "free"
		sibling(typeName) gives "sibling({typeName})"
		qualified gives "qualified"
	end 'show'
end 'callContextToString'

// `qualified` callees short-circuit name resolution — used by all three
// CallContext consumers (parser type-flow, DFE worklist seeding, Maxon→Std
// lowering) so the predicate lives here next to CallContext itself.
export function isQualifiedCallContext(ctx CallContext) returns bool
	return match ctx 'check'
		qualified gives true
		free gives false
		sibling gives false
	end 'check'
end 'isQualifiedCallContext'

// Returns the enclosing-type prefix carried by a `sibling` CallContext, or ""
// for `free`/`qualified`. Used to build the first probe (`{Type}.{bare}`)
// when resolving a bare callee inside an instance-method body.
export function siblingTypeNameOfContext(ctx CallContext) returns String
	return match ctx 'check'
		sibling(typeName) gives typeName
		qualified gives ""
		free gives ""
	end 'check'
end 'siblingTypeNameOfContext'

// Resolve a parser-emitted bare callee to its qualified name by walking the
// CallContext-driven candidate qualifications. Three call sites — parser
// type-flow propagation, DeadFunctionElimination's worklist seeding, and
// LowerMaxonToStd's call lowering — all need the same probe order, so the
// algorithm lives here. Returns the bare name as a last-resort fallback so
// downstream diagnostics still see a sensible callee string.
//
// Probe order:
//   1. sibling type prefix (when inside a method body)
//   2. local namespace
//   3. `stdlib` namespace
//   4. cross-file fallback: any `{otherNs}.{bare}` whose declaring file
//      is visible from `readerFilePath`. Single visible match wins; if
//      multiple files are visible, the first one wins (deterministic over
//      `methodNameIndex` insertion order). When no visible candidate
//      exists this returns `localName` so downstream diagnostics still
//      see the name the user wrote, qualified to their own namespace.
//
// `readerFilePath` is the file the bare call is being emitted from. It
// anchors the visibility filter at step 4. Empty string is acceptable —
// `isVisibleFrom` then only matches `global` candidates, which is
// exactly what we want for parser-time fallbacks before block source
// info is available.
export function qualifyCalleeForContext(project Project, bare String, callContext CallContext, currentNamespace String, readerFilePath FilePath) returns String
	let (qualified, _) = qualifyCalleeForContextWithType(project, bare: bare, callContext: callContext, currentNamespace: currentNamespace, readerFilePath: readerFilePath)
	return qualified
end 'qualifyCalleeForContext'

// Same as `qualifyCalleeForContext` but also returns the receiver
// MaxonType the typealias chase landed on (for `qualified`/`sibling`
// contexts). Resolvers that need to thread the receiver's
// `genericInstance(...)` shape into a call-site sidecar (e.g.
// `resolvedReceiverTypes` for layout-arg materialization) read this
// instead of re-chasing the resolved name.
export function qualifyCalleeForContextWithType(project Project, bare String, callContext CallContext, currentNamespace String, readerFilePath FilePath, enclosingType String = "") returns (String, MaxonType)
	if isQualifiedCallContext(callContext) 'isQualified'
		// Phase 5: directory-as-module qualified-call resolution. The head
		// of `head.tail` may itself name a namespace, with `tail` a
		// registered function under it. Probe the full callee first
		// (covers both `dir.fn` and `stdlib.fmt.print` multi-segment
		// forms — `funcReturnTypes` is keyed by the canonical qualified
		// name so this directly catches every namespace-qualified call
		// without per-level walking). Falls back to the struct/typealias
		// chase on miss so qualified calls on user types still work.
		if project.funcReturnTypes.contains(bare) 'isNsCall'
			return (bare, MaxonType.unresolved)
		end 'isNsCall'
		if project.overloadedNames.contains(bare) 'isNsOverloadedCall'
			return (bare, MaxonType.unresolved)
		end 'isNsOverloadedCall'
		// Forward enclosingType so an inner typealias declared on the
		// enclosing struct (chased via `chaseTypealiasNameToType`'s
		// `innerAliases` branch) wins over a global-scope miss.
		return chaseTypealiasInQualifiedCalleeWithType(project, callee: bare, enclosingType: enclosingType)
	end 'isQualified'
	// `sibling` first tries the enclosing-type prefix; on miss, falls
	// through to the same probe order as `free`. The receiver MaxonType
	// stays `unresolved` for free/sibling resolution — `lowerCall`
	// re-derives it from `currentTypeName` for sibling instance calls.
	let siblingTypeName = siblingTypeNameOfContext(callContext)
	if not siblingTypeName.isEmpty() 'inSibling'
		let siblingName = "{siblingTypeName}.{bare}"
		if project.funcReturnTypes.contains(siblingName) 'isSibling'
			return (siblingName, MaxonType.unresolved)
		end 'isSibling'
		// Overloaded sibling: `overloadedNames` is keyed by the bare
		// qualified name and `funcReturnTypes` only has the mangled
		// variants. Returning the bare key here lets `resolveOverloadedCallee`
		// downstream pick the matching variant from the bucket.
		if project.overloadedNames.contains(siblingName) 'isSiblingOverloaded'
			return (siblingName, MaxonType.unresolved)
		end 'isSiblingOverloaded'
	end 'inSibling'
	if bare == "main" 'isMain'
		return (bare, MaxonType.unresolved)
	end 'isMain'
	let localName = qualifyName(currentNamespace, name: bare)
	// Under directory-as-module, multiple sibling files share
	// `currentNamespace`, so the local probe may land on a non-exported
	// decl in a sibling file. Filter via `isVisibleFrom` so the
	// cross-file fallback's diagnostic (or the downstream "not exported"
	// error) fires instead of silently picking the sibling decl. The
	// filter only applies to actually-bare names — a user-written
	// qualified call (`Type.method`) lets the lookup pass through; the
	// type-visibility error or instance-call gate handles those.
	let bareCall = not bare.contains(".")
	if project.funcReturnTypes.contains(localName) 'isLocal'
		if not bareCall 'qualifiedLocal'
			return (localName, MaxonType.unresolved)
		end 'qualifiedLocal'
		let info = funcVisibilityOrDefault(project, qualifiedName: localName)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'localVisible'
			return (localName, MaxonType.unresolved)
		end 'localVisible'
	end 'isLocal'
	// Overloaded local: the bare-name slot in `funcReturnTypes` was
	// vacated by `rekeyExistingFunction` when the second overload was
	// registered, so `contains(localName)` misses. The `overloadedNames`
	// bucket is keyed by the bare qualified name — handing that back lets
	// `resolveOverloadedCallee` pick the matching mangled variant via
	// `argTypes`. Same visibility gate as the resolved-name path so a
	// sibling-file overload bucket doesn't silently win either.
	if project.overloadedNames.contains(localName) 'isLocalOverloaded'
		if not bareCall 'qualifiedLocalOverloaded'
			return (localName, MaxonType.unresolved)
		end 'qualifiedLocalOverloaded'
		let info = funcVisibilityOrDefault(project, qualifiedName: localName)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'localOverloadedVisible'
			return (localName, MaxonType.unresolved)
		end 'localOverloadedVisible'
	end 'isLocalOverloaded'
	let stdlibName = qualifyName("stdlib", name: bare)
	if project.funcReturnTypes.contains(stdlibName) 'isStdlib'
		// `__`-prefixed stdlib functions are compiler internals declared
		// only in `stdlib/Internals.maxon` (or `stdlib/Builtins.maxon` for
		// the type-system bridge). User code and other stdlib files must
		// NOT reach them by bare name — only the exempted internals files
		// themselves and the lowering pass's intrinsic interceptors. The
		// `funcVisibilities` round-trip through the stdlib cache currently
		// drops the `(file, declPath)` sidecar, so a pure visibility check
		// would let cached-stdlib user builds bypass the gate. Gating on
		// the `__`-prefix + reader-file pair survives the cache (no extra
		// state required) and is symmetric with `checkReservedDeclName`'s
		// declaration rule.
		if bare.startsWith("__") and not readerCanCallStdlibInternals(readerFilePath) 'rejectInternalsRef'
			return (localName, MaxonType.unresolved)
		end 'rejectInternalsRef'
		return (stdlibName, MaxonType.unresolved)
	end 'isStdlib'
	// Overloaded stdlib: same shape as the local path — bare-key bucket
	// exists in `overloadedNames` while `funcReturnTypes` only has the
	// mangled variants. Apply the same `__`-prefix gate the resolved-name
	// stdlib branch applies above so user code doesn't accidentally bind
	// to a stdlib internals overload.
	if project.overloadedNames.contains(stdlibName) 'isStdlibOverloaded'
		if bare.startsWith("__") and not readerCanCallStdlibInternals(readerFilePath) 'rejectInternalsOverloadedRef'
			return (localName, MaxonType.unresolved)
		end 'rejectInternalsOverloadedRef'
		return (stdlibName, MaxonType.unresolved)
	end 'isStdlibOverloaded'
	// Cross-file fallback: scan candidates with matching trailing
	// segment, pick the first visible from `readerFilePath`. `__`-prefix
	// references from non-internals files are blocked here too, matching
	// the stdlibName branch above (the gate is over the SHAPE of the
	// reference, not over the visibility sidecar — which doesn't survive
	// the stdlib cache).
	if bare.startsWith("__") and not readerCanCallStdlibInternals(readerFilePath) 'rejectInternalsCrossFile'
		return (localName, MaxonType.unresolved)
	end 'rejectInternalsCrossFile'
	// Decision #1 (E3095) probe: collect every visible candidate, de-duped
	// by the candidate's canonical qualified name. Pick the first
	// deterministically so the legacy probe shape (first visible wins)
	// stays intact. A future TypeResolution pass that has a SourceRange in
	// hand can re-walk this same set and surface E3095 when more than one
	// distinct definition was reachable — see ErrorCode.maxon.
	//
	// Phase C: skip `__`-prefixed candidates for non-internals readers. The
	// gate above only catches references whose BARE name starts with `__`;
	// a bare `count` in user code reaches the cross-file fallback and the
	// method-name index returns `__ManagedList.count` as a candidate.
	// Without this filter the parser binds `count` to the builtin method
	// and synthesizes an `__fnref___ManagedList.count` thunk whose body
	// calls a body-less compiler-internal name, which then panics at the
	// codegen lookup phase. Symmetric with the `bare.startsWith("__")` gate
	// just above for the same reason.
	let readerInternals = readerCanCallStdlibInternals(readerFilePath)
	let candidates = project.methodNameIndex.get(bare)
	for candidate in candidates 'each'
		if not project.funcReturnTypes.contains(candidate) 'notFunc'
			continue
		end 'notFunc'
		if candidate.startsWith("__") and not readerInternals 'rejectInternalsCandidate'
			continue
		end 'rejectInternalsCandidate'
		let info = funcVisibilityOrDefault(project, qualifiedName: candidate)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'visible'
			return (candidate, MaxonType.unresolved)
		end 'visible'
	end 'each'
	return (localName, MaxonType.unresolved)
end 'qualifyCalleeForContextWithType'

// True when `readerFilePath` is one of the stdlib internals files that may
// reference `__`-prefixed stdlib functions by bare name. Matches the
// declaration-side exemption list in `Parser.checkReservedDeclName`.
export function readerCanCallStdlibInternals(readerFilePath FilePath) returns bool
	let name = readerFilePath.filename()
	return name == "Internals.maxon" or name == "Builtins.maxon" or name == "stdlib-bootstrap.maxon"
end 'readerCanCallStdlibInternals'

// E3095 ambiguity detection: re-walks the same candidate set the cross-file
// fallback in `qualifyCalleeForContextWithType` considers, but collects ALL
// visible candidates (deduped by canonical name) instead of stopping at the
// first match. Returns the list so callers with a SourceRange can emit
// E3095 when more than one distinct definition was reachable. Callers must
// pre-filter to bare-name (`free`-context) calls whose resolved name was
// reached via the cross-file fallback — local-namespace, stdlib-namespace,
// and sibling-typed probes are unambiguous by construction.
export function visibleCrossFileCandidates(project Project, bare String, readerFilePath FilePath) returns QualifiedNameArray
	var results = QualifiedNameArray.create()
	if bare.startsWith("__") and not readerCanCallStdlibInternals(readerFilePath) 'rejectInternals'
		return results
	end 'rejectInternals'
	let readerInternals = readerCanCallStdlibInternals(readerFilePath)
	let candidates = project.methodNameIndex.get(bare)
	for candidate in candidates 'each'
		if not project.funcReturnTypes.contains(candidate) 'notFunc'
			continue
		end 'notFunc'
		// Phase C: mirror the `__`-candidate filter from
		// `qualifyCalleeForContextWithType` — user files must not see
		// compiler-internal methods (e.g. `__ManagedList.count`) as candidates
		// when probing a bare name like `count`.
		if candidate.startsWith("__") and not readerInternals 'rejectInternalsCandidate'
			continue
		end 'rejectInternalsCandidate'
		let info = funcVisibilityOrDefault(project, qualifiedName: candidate)
		if isVisibleFrom(info.visibility, declFilePath: info.sourceFilePath, readerFilePath: readerFilePath) 'visible'
			results.push(candidate)
		end 'visible'
	end 'each'
	return results
end 'visibleCrossFileCandidates'

// True iff `path` is the virtual `stdlib-bootstrap.maxon` synthesis anchor.
// Functions attributed there are compiler-synthesized helpers (struct-literal
// field-init thunks, witness-table dispatch shims, etc.); they manipulate
// struct fields directly as part of the lowering contract and aren't subject
// to source-level visibility (E3014 unexported-field-access).
export function isStdlibBootstrapVirtualPath(path FilePath) returns bool
	return path.filename() == "stdlib-bootstrap.maxon"
end 'isStdlibBootstrapVirtualPath'

// Look up the visibility/sourceFilePath for a function. Missing entries
// default to `(global, stdlibBootstrapPath)` — stdlib functions are
// restored from the cache without a sidecar entry, and treating them as
// always-visible matches their actual semantics.
export function funcVisibilityOrDefault(project Project, qualifiedName String) returns FuncVisibilityInfo
	if let info = try project.funcVisibilities.get(qualifiedName) 'hit'
		return info
	end 'hit'
	let stdlibPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise FilePath from ""
	return FuncVisibilityInfo.create(Visibility.global, sourceFilePath: stdlibPath)
end 'funcVisibilityOrDefault'

// Phase 11.0 step 8b: chase per-struct inner typealiases on the receiver
// portion of a qualified callee like `ArrayIter.create` or `IntArray.create`.
// When the head is an inner alias of `ArrayIterator with Element` on the
// enclosing struct, or a top-level generic typealias for `Array with
// Integer`, swap it for the alias's base struct name. Falls through
// unchanged on any miss (no dot, unknown receiver, no alias, etc.).
//
// Returns the rewritten callee name and the resolved receiver MaxonType
// — `genericInstance(Array, [Byte])` for `ByteArray`, `named(Array)`
// for a non-generic alias, or `unresolved` when the head isn't a known
// typealias. Lowering's `materializeLayoutArg` keys off the returned
// MaxonType to thread the matching layout descriptor at a
// `Type.staticMethod()` call site.
//
// Used by both TypeResolution (`callResultType`/`qualifyCalleeForContext`)
// and lowering (`LowerMaxonToStd.lowerCall`/`lowerMethodCall`) so a
// qualified call always resolves to a registered struct/method name.
export function chaseTypealiasInQualifiedCalleeWithType(project Project, callee String, enclosingType String) returns (String, MaxonType)
	let bytes = callee.toByteArray()
	let count = bytes.count()
	let dotIdx = lastIndexOfDotByte(bytes)
	if dotIdx >= count 'noDot'
		return (callee, MaxonType.unresolved)
	end 'noDot'
	let head = byteSliceToString(bytes, startIndex: 0, endIndex: dotIdx)
	// Phase 9 Stage 2: a qualified call `UnionName.caseName` on a union case
	// with non-empty payload fields rewrites to the synthesized constructor
	// `__construct_UnionName_caseName`. Bare cases (payloadFields empty)
	// stay routed through the TopLevelConstant path and never reach a
	// `call` op. The receiver type lands as the union's named identity so
	// the call's result type propagates correctly through producer flow.
	let tail = byteSliceToString(bytes, startIndex: dotIdx + 1, endIndex: count)
	let unionRewrite = tryRewriteUnionCaseCall(project, unionName: head, caseName: tail)
	if unionRewrite.hit 'unionConstructor'
		return (unionRewrite.calleeName, unionRewrite.receiverType)
	end 'unionConstructor'
	if project.structTypes.contains(head) 'alreadyResolved'
		return (callee, MaxonType.named(project.typeNames.intern(head)))
	end 'alreadyResolved'
	if let resolvedType = try chaseTypealiasNameToType(project, name: head, enclosingType: enclosingType) 'didResolve'
		let resolvedName = resolvedType.nameOrEmpty(project)
		if resolvedName.isEmpty() or resolvedName == head 'sameName'
			return (callee, resolvedType)
		end 'sameName'
		return ("{resolvedName}.{tail}", resolvedType)
	end 'didResolve'
	return (callee, MaxonType.unresolved)
end 'chaseTypealiasInQualifiedCalleeWithType'

// Phase 9 Stage 2: when `head.tail` names a union case with a non-empty
// payload, rewrite the call to the parser-synthesized constructor name.
// `hit=false` on miss; consumers fall back to the unrewritten callee.
// Helper kept here so both TR's call-result resolution and lowering's
// callee-qualification step share one source of truth for the union →
// constructor name mangling.
export type UnionCaseRewriteResult
	export var hit as bool
	export var calleeName as String
	export var receiverType as MaxonType

	export static function miss() returns UnionCaseRewriteResult
		return Self{hit: false, calleeName: "", receiverType: MaxonType.unresolved}
	end 'miss'

	export static function found(calleeName String, receiverType MaxonType) returns UnionCaseRewriteResult
		return Self{hit: true, calleeName: calleeName, receiverType: receiverType}
	end 'found'
end 'UnionCaseRewriteResult'

// Mangled name for the synthesized constructor function backing a
// payload-bearing union case. Centralized here so the parser, the call-
// rewrite path, and the lowering pass all mint identical names.
export function unionConstructorSymbolName(unionName String, caseName String) returns String
	return "__construct_{unionName}_{caseName}"
end 'unionConstructorSymbolName'

// Phase 9 Stage 5: mangled names for the per-enum `.fromRawValue` /
// `.fromName` lookup helpers. The parser synthesizes one helper per
// enum (and per union companion) and rewrites `EnumName.fromRawValue(x)`
// / `EnumName.fromName(s)` calls to these names. Centralized so the
// parser-side synthesis and the parser-side call-site rewrite mint
// identical symbols.
export function enumFromRawValueSymbolName(enumName String) returns String
	return "__enum_{enumName}_fromRawValue"
end 'enumFromRawValueSymbolName'

export function enumFromNameSymbolName(enumName String) returns String
	return "__enum_{enumName}_fromName"
end 'enumFromNameSymbolName'

export function tryRewriteUnionCaseCall(project Project, unionName String, caseName String) returns UnionCaseRewriteResult
	let info = lookupUnionCasePayloadArity(project, unionName: unionName, caseName: caseName)
	// Phase 9 Stage 3: every union case (including bare cases with
	// payloadArity == 0) routes through its synthesized constructor so
	// values share a uniform heap-boxed shape. The earlier `payloadArity
	// <= 0` short-circuit applied while bare cases still lived in
	// `topLevelConstants`; that registration is gone now, so the only
	// non-call cases left are plain (non-union) enums.
	if not info.isUnion 'notUnion'
		return UnionCaseRewriteResult.miss()
	end 'notUnion'
	let ctorName = unionConstructorSymbolName(unionName, caseName: caseName)
	if not project.funcReturnTypes.contains(ctorName) 'noCtor'
		// Constructor synthesis should have run at parse time; if we reach
		// here the union was registered without its constructor — caller
		// falls back to the original name so the downstream "unknown name"
		// diagnostic fires at the original source location.
		return UnionCaseRewriteResult.miss()
	end 'noCtor'
	let recvType = MaxonType.named(project.typeNames.intern(unionName))
	return UnionCaseRewriteResult.found(ctorName, receiverType: recvType)
end 'tryRewriteUnionCaseCall'

export type UnionCaseInfo
	export var isUnion as bool
	export var payloadArity as ParsedInt

	export static function notUnion() returns UnionCaseInfo
		return Self{isUnion: false, payloadArity: 0}
	end 'notUnion'

	export static function union(payloadArity ParsedInt) returns UnionCaseInfo
		return Self{isUnion: true, payloadArity: payloadArity}
	end 'union'
end 'UnionCaseInfo'

export function lookupUnionCasePayloadArity(project Project, unionName String, caseName String) returns UnionCaseInfo
	if let et = try project.enumTypes.get(unionName) 'resolved'
		if not et.isUnion 'notUnion'
			return UnionCaseInfo.notUnion()
		end 'notUnion'
		if let idx = try et.caseByName.get(caseName) 'haveCase'
			let c = try et.cases.get(idx) otherwise return UnionCaseInfo.union(0)
			return UnionCaseInfo.union(c.payloadFields.count())
		end 'haveCase'
		return UnionCaseInfo.union(0)
	end 'resolved'
	if let ut = try project.unresolvedEnums.get(unionName) 'unresolved'
		if not ut.isUnion 'notUnion2'
			return UnionCaseInfo.notUnion()
		end 'notUnion2'
		for c in ut.cases 'eachCase'
			if c.name == caseName 'hit'
				return UnionCaseInfo.union(c.payloadFields.count())
			end 'hit'
		end 'eachCase'
		return UnionCaseInfo.union(0)
	end 'unresolved'
	return UnionCaseInfo.notUnion()
end 'lookupUnionCasePayloadArity'

// Return the resolved MaxonType behind a typealias `name`. Mirrors
// `chaseTypealiasNameToStruct` but stops at the MaxonType layer rather
// than collapsing to the base struct's bare name — so generic instances
// keep their `with` arg list, which the call-site receiver-context plumbing
// needs.
//
// `enclosingType` may name a struct (`project.structTypes`), a resolved
// interface (`project.interfaces`), or an interface that hasn't yet been
// drained (`project.unresolvedInterfaces`). The interface paths exist so a
// method declared inside `extension <SomeInterface> ... end` can resolve
// inner-typealias names captured by `mergeExtensionInnerAliases` the same
// way a struct extension does.
export function chaseTypealiasNameToType(project Project, name String, enclosingType String) returns MaxonType throws TypealiasChaseError
	if not enclosingType.isEmpty() 'tryInner'
		if let st = try project.structTypes.get(enclosingType) 'haveStruct'
			if let inner = try st.innerAliases.get(name) 'haveInner'
				return inner
			end 'haveInner'
		end 'haveStruct'
		if let iface = try project.interfaces.get(enclosingType) 'haveIface'
			if let inner = try iface.innerAliases.get(name) 'haveIfaceInner'
				return inner
			end 'haveIfaceInner'
		end 'haveIface'
		if let unresolvedIface = try project.unresolvedInterfaces.get(enclosingType) 'haveUnresolvedIface'
			if let expr = try unresolvedIface.innerAliases.get(name) 'haveExpr'
				return resolveInterfaceInnerAliasExpr(project, declaringTypeName: enclosingType, aliasName: name, expr: expr)
			end 'haveExpr'
		end 'haveUnresolvedIface'
		// J.4f.2 (MaxonType view): when the enclosingType is a conformer struct
		// and the alias lives in one of the interfaces it implements rather than
		// its own body, recover it via the conformance set. Mirrors
		// `chaseTypealiasNameToStruct`. The canonical case is the monomorphized
		// `OpenRange.withIterator` body calling `WithIterSelf.create`, where
		// `WithIterSelf` is an inner alias of `Iterable` (which OpenRange
		// conforms to) — without this walk the literal `WithIterSelf.create`
		// callee leaks to the backend and panics in `lookupFuncParamTypes`.
		if let viaIface = try chaseTypealiasTypeViaConformingInterfaces(project, name: name, structName: enclosingType) 'viaIface'
			return viaIface
		end 'viaIface'
	end 'tryInner'
	return try project.genericTypealiases.get(name) otherwise throw TypealiasChaseError.unresolved
end 'chaseTypealiasNameToType'

// On-demand resolver mirroring the drain-pass logic in
// `resolveAllInterfaces`: generic-form aliases resolve through
// `resolveGenericAliasExpr` so type-parameter args (`Element`, ...) scope
// correctly to the declaring interface, and non-generic aliases fall back to
// a named placeholder. Used by the chase helpers so a chase fired before the
// interface drain has run still returns the same MaxonType the drain would
// have stored.
function resolveInterfaceInnerAliasExpr(project Project, declaringTypeName String, aliasName String, expr UnresolvedTypeExpr) returns MaxonType
	if isGenericAliasExpr(expr) 'isGeneric'
		return resolveGenericAliasExpr(project, expr: expr, declaringTypeName: declaringTypeName)
	end 'isGeneric'
	return internMaxonType(project, name: aliasName)
end 'resolveInterfaceInnerAliasExpr'

export typealias ByteSliceIndex = int(0 to u64.max)

// Copy a half-open byte slice [startIndex, endIndex) out of `bytes` and
// return it as a String. Both bounds must already be validated by the
// caller — out-of-range get's panic. Shared between the qualified-callee
// splitter above and TypeResolution's `enclosingTypeNameForFunc` so each
// site doesn't re-implement the same byte-array slice loop.
export function byteSliceToString(bytes ByteArray, startIndex ByteSliceIndex, endIndex ByteSliceIndex) returns String
	var out = ByteArray.create()
	for i in startIndex upto endIndex 'copy'
		let b = try bytes.get(i) otherwise panic("byteSliceToString: get OOB at {i}")
		out.push(b)
	end 'copy'
	return String.from(out)
end 'byteSliceToString'

// Index of the rightmost ASCII '.' (byte 46) in `bytes`, or `bytes.count()`
// when no dot is present. Used by qualified-callee parsing to split
// `Type.method` into receiver + method-name halves; shared with the
// TypeResolution pass via the export.
export typealias DotByteIndex = int(0 to u64.max)

export function lastIndexOfDotByte(bytes ByteArray) returns DotByteIndex
	let count = bytes.count()
	var i = count
	while i > 0 'scan'
		let next = i - 1
		let ch = try bytes.get(next) otherwise panic("lastIndexOfDotByte: OOB at {next}")
		if ch == 46 'dot'
			return next
		end 'dot'
		i = next
	end 'scan'
	return count
end 'lastIndexOfDotByte'

// Resolve `name` through inner-aliases on `enclosingType`, then through
// `genericTypealiases`, returning the underlying struct name. Throws
// `TypealiasChaseError.unresolved` when no path resolves to a name that
// `baseNameOfMaxonType` can render — callers should use `if let` to take
// the resolved-struct path and fall through to their alternate handling on
// throw.
//
// `enclosingType` may name a struct, a resolved interface, or an interface
// that hasn't yet been drained from `unresolvedInterfaces`. The interface
// paths exist so a method declared inside `extension <SomeInterface>` can
// chase inner-typealias names the same way a struct extension does.
export function chaseTypealiasNameToStruct(project Project, name String, enclosingType String) returns String throws TypealiasChaseError
	if not enclosingType.isEmpty() 'tryInner'
		if let st = try project.structTypes.get(enclosingType) 'haveStruct'
			if let inner = try st.innerAliases.get(name) 'haveInner'
				return try baseNameOfMaxonType(project, t: inner) otherwise throw TypealiasChaseError.unresolved
			end 'haveInner'
		end 'haveStruct'
		if let iface = try project.interfaces.get(enclosingType) 'haveIface'
			if let inner = try iface.innerAliases.get(name) 'haveIfaceInner'
				return try baseNameOfMaxonType(project, t: inner) otherwise throw TypealiasChaseError.unresolved
			end 'haveIfaceInner'
		end 'haveIface'
		if let unresolvedIface = try project.unresolvedInterfaces.get(enclosingType) 'haveUnresolvedIface'
			if let expr = try unresolvedIface.innerAliases.get(name) 'haveExpr'
				let resolved = resolveInterfaceInnerAliasExpr(project, declaringTypeName: enclosingType, aliasName: name, expr: expr)
				return try baseNameOfMaxonType(project, t: resolved) otherwise throw TypealiasChaseError.unresolved
			end 'haveExpr'
		end 'haveUnresolvedIface'
		// J.4f.2: when the enclosingType is a struct and the alias wasn't
		// declared inside the struct's own body or in an `extension <Struct>`
		// block (mergeExtensionInnerAliases drops only those into the
		// struct's innerAliases), the alias may live in one of the
		// interfaces the struct implements. Stdlib `Iterable.ElementArray`
		// is the canonical example — declared inside
		// `extension Iterable { typealias ElementArray = Array with Element }`
		// so it lands on Iterable's innerAliases, not on Map's. Walk every
		// interface the struct conforms to and try its body's innerAliases
		// before falling back to top-level genericTypealiases. First hit
		// wins; stdlib alias names are unique across the conformance set
		// so there's no ambiguity in practice.
		if let result = try chaseTypealiasViaConformingInterfaces(project, name: name, structName: enclosingType) 'viaIface'
			return result
		end 'viaIface'
	end 'tryInner'
	return try chaseTypealiasNameThroughGeneric(project, name: name)
end 'chaseTypealiasNameToStruct'

// Substitute an interface inner-alias type's type-parameter args with the
// concrete `with` args from a specific conformance. The inner alias is
// declared in the interface's own scope, so a generic instance like
// `WithIterIterator with Iter, Element` carries the interface's `usesParams`
// (`Iter`, `Element`) as its args. When chased for a concrete conformer
// (e.g. `OpenRange implements Iterable with (RangeIterator, RangeBound)`),
// those params must be bound to the conformance args so the result is a
// fully-concrete `genericInstance(WithIterIterator, [RangeIterator,
// RangeBound])` — otherwise the call site's layout/witness materialization
// sees a conditional gid and tries to forward a layout from a caller that
// has none. Non-generic-instance inner aliases (and args that aren't
// interface params) pass through unchanged.
function bindInterfaceParamsToConformanceArgs(project Project, t MaxonType, usesParams StringArray, confArgs MaxonTypeArray) returns MaxonType
	if usesParams.count() == 0 or usesParams.count() != confArgs.count() 'noBinding'
		return t
	end 'noBinding'
	return match t 'kind'
		genericInstance(gid) gives bindGenericInstanceArgs(project, gid: gid, usesParams: usesParams, confArgs: confArgs)
		typeParameter(id) gives substituteInterfaceParamArgByName(t, argName: project.typeParameters.getName(id), usesParams: usesParams, confArgs: confArgs)
		named(id) gives substituteInterfaceParamArgByName(t, argName: project.typeNames.get(id), usesParams: usesParams, confArgs: confArgs)
		boolean to string gives t
		function gives t
		unresolved gives t
		interface gives t
		constInt to cstring gives t
	end 'kind'
end 'bindInterfaceParamsToConformanceArgs'

// Rebuild a generic instance with each type-parameter arg bound to its
// conformance arg. Recurses through nested generic instances so a deeper
// `Foo with Bar with Element` still binds `Element`.
function bindGenericInstanceArgs(project Project, gid GenericInstanceId, usesParams StringArray, confArgs MaxonTypeArray) returns MaxonType
	let (baseId, args) = project.genericInstances.get(gid)
	var newArgs = MaxonTypeArray.create()
	for i in 0 upto args.count() 'eachArg'
		let a = try args.get(i) otherwise panic("bindGenericInstanceArgs: args.get OOB at {i}")
		newArgs.push(bindInterfaceParamsToConformanceArgs(project, t: a, usesParams: usesParams, confArgs: confArgs))
	end 'eachArg'
	let newGid = project.genericInstances.intern(baseId, args: newArgs)
	return MaxonType.genericInstance(newGid)
end 'bindGenericInstanceArgs'

// Map a single arg (already reduced to its `argName`) to its conformance
// binding when it names one of the interface's `usesParams`. Both
// `typeParameter(Element)` and the pre-drain `named(Element)` placeholder
// shapes feed in via their name. A non-param name (concrete struct, etc.)
// passes through as the original `t`.
function substituteInterfaceParamArgByName(t MaxonType, argName String, usesParams StringArray, confArgs MaxonTypeArray) returns MaxonType
	for i in 0 upto usesParams.count() 'findParam'
		let p = try usesParams.get(i) otherwise panic("substituteInterfaceParamArgByName: usesParams.get OOB at {i}")
		if p == argName 'matched'
			return try confArgs.get(i) otherwise panic("substituteInterfaceParamArgByName: confArgs.get OOB at {i}")
		end 'matched'
	end 'findParam'
	return t
end 'substituteInterfaceParamArgByName'

// J.4f.2: walk every conformance registry entry for `structName` and probe
// each implemented interface's `innerAliases` for `name`. Returns the
// resolved `MaxonType` on hit (so generic instances keep their `with` arg
// list for receiver-context plumbing), with the interface's type params
// bound to the conformance args; otherwise propagates
// `TypealiasChaseError.unresolved` so the caller can fall through to the
// top-level generic-typealias chase. Used to recover stdlib interface-
// declared aliases like `Iterable.ElementArray` / `Iterable.WithIterSelf`
// for conformer struct receivers (Map / Set / List / OpenRange) that don't
// re-declare the alias in their own body.
function chaseTypealiasTypeViaConformingInterfaces(project Project, name String, structName String) returns MaxonType throws TypealiasChaseError
	for confId in 0 upto project.conformances.typeNames.count() 'scan'
		let implName = try project.conformances.typeNames.get(confId) otherwise panic("chaseTypealiasTypeViaConformingInterfaces: typeNames.get OOB at {confId}")
		if implName != structName 'skip'
			continue
		end 'skip'
		let ifaceName = try project.conformances.interfaceNames.get(confId) otherwise panic("chaseTypealiasTypeViaConformingInterfaces: interfaceNames.get OOB at {confId}")
		let confArgs = try project.conformances.withArgsList.get(confId) otherwise panic("chaseTypealiasTypeViaConformingInterfaces: withArgsList.get OOB at {confId}")
		if let iface = try project.interfaces.get(ifaceName) 'haveIface'
			if let inner = try iface.innerAliases.get(name) 'hit'
				return bindInterfaceParamsToConformanceArgs(project, t: inner, usesParams: iface.usesParams, confArgs: confArgs)
			end 'hit'
		end 'haveIface'
		if let unresolvedIface = try project.unresolvedInterfaces.get(ifaceName) 'haveUnresolvedIface'
			if let expr = try unresolvedIface.innerAliases.get(name) 'hitU'
				let resolved = resolveInterfaceInnerAliasExpr(project, declaringTypeName: ifaceName, aliasName: name, expr: expr)
				return bindInterfaceParamsToConformanceArgs(project, t: resolved, usesParams: unresolvedIface.usesParams, confArgs: confArgs)
			end 'hitU'
		end 'haveUnresolvedIface'
	end 'scan'
	throw TypealiasChaseError.unresolved
end 'chaseTypealiasTypeViaConformingInterfaces'

// Base-name view of `chaseTypealiasTypeViaConformingInterfaces` — chases the
// conformance set and collapses the resolved `MaxonType` to its underlying
// struct base name for callers that only need the name (struct allocation,
// element-array sizing). Generic-instance-aware callers use the MaxonType
// helper directly.
function chaseTypealiasViaConformingInterfaces(project Project, name String, structName String) returns String throws TypealiasChaseError
	let resolved = try chaseTypealiasTypeViaConformingInterfaces(project, name: name, structName: structName)
	return try baseNameOfMaxonType(project, t: resolved) otherwise throw TypealiasChaseError.unresolved
end 'chaseTypealiasViaConformingInterfaces'

function chaseTypealiasNameThroughGeneric(project Project, name String) returns String throws TypealiasChaseError
	let resolved = try project.genericTypealiases.get(name) otherwise throw TypealiasChaseError.unresolved
	return try baseNameOfMaxonType(project, t: resolved) otherwise throw TypealiasChaseError.unresolved
end 'chaseTypealiasNameThroughGeneric'

// Outcome of `chaseTypealiasNameToStruct` / `chaseTypealiasNameThroughGeneric`
// when no resolution path produces a renderable type name.
export enum TypealiasChaseError implements Error
	unresolved
end 'TypealiasChaseError'

export enum BaseNameError implements Error
	unrenderable
end 'BaseNameError'

// Render a type's underlying base name. Throws `BaseNameError.unrenderable`
// for arms that have no source-level name (primitives, function, unresolved,
// typeParameter, interface). Callers use `try ... otherwise` or `if let` to
// take the named-type path.
export function baseNameOfMaxonType(project Project, t MaxonType) returns String throws BaseNameError
	return match t 'pick'
		named(id) gives project.typeNames.get(id)
		genericInstance(id) gives genericInstanceIdBaseName(project, id: id)
		default throws BaseNameError.unrenderable
	end 'pick'
end 'baseNameOfMaxonType'

// --- First-param overload mangling ---
//
// Compute a stable mangle suffix from a single MaxonType. Used by both the
// parser-side collision handling and the call-site disambiguation walk so
// the same type produces the same suffix at registration and lookup. The
// suffix always begins with `$` so the mangled name (`Array.contains$Element`)
// stays distinguishable from a naturally-occurring qualified name.
//
// Encoding (kept narrow on purpose; matches the minimum needed for
// `Array.contains(Element)` vs `Array.contains(Array<Element>)`):
//   - primitives:        `$bool`, `$int`, `$float`, `$String`
//   - named types:       `$<TypeName>`
//   - type parameters:   `$<ParamName>`        (bare param name like `Element`)
//   - generic instances: `$<Base>_<Arg1>_...`  (e.g. `$Array_Element`)
//   - function/interface/unresolved: `$_` (degenerate fallback; these never
//     produce overload collisions in current stdlib)
export function mangleSuffixForMaxonType(project Project, t MaxonType) returns String
	return match t 'mangle'
		boolean gives "$bool"
		integer gives "$int"
		float gives "$float"
		string gives "$String"
		// Named types may be typealiases for primitives (`typealias Integer =
		// int(i64.min to i64.max)`); fold them to the primitive suffix so an
		// `int` literal argument and an `Integer` parameter mangle identically.
		// Non-aliased struct names fall through to the user-facing name.
		named(id) gives namedTypeMangleSuffix(project, name: project.typeNames.get(id))
		typeParameter(id) gives "${project.typeParameters.getName(id)}"
		genericInstance(id) gives "${mangleSuffixForGenericInstance(project, id: id)}"
		function gives "$_"
		interface(id) gives "${project.interfaceRegistry.getName(id)}"
		unresolved gives "$_"
		constInt(value) gives "${value}"
		opaquePointer gives "$_"
		cstring gives "$cstring"
	end 'mangle'
end 'mangleSuffixForMaxonType'

// Resolve a named type's mangle suffix. Typealiases to primitives fold to
// the primitive's suffix so overload registration (which sees the declared
// parameter type, e.g. `value Integer`) and call-site resolution (which sees
// the literal's primitive type, e.g. `21` → `integer`) produce matching
// suffixes. Non-aliased names emit the bare user-facing name.
//
// Checks `project.typealiases` first (populated by TypeResolution) then
// `project.unresolvedTypealiases` (populated at parse time) so the mangle
// is stable whether resolution has run yet or not — parser-side
// overload registration needs the parse-time path; call-site resolution
// (after TypeResolution) hits the resolved path.
function namedTypeMangleSuffix(project Project, name String) returns String
	if let stdType = try project.typealiases.get(name) 'isPrimAlias'
		return match stdType.rawValue.castCategory 'cat'
			int gives "$int"
			float gives "$float"
			bool gives "$bool"
			string gives "$String"
			cstring gives "$cstring"
		end 'cat'
	end 'isPrimAlias'
	if let unresolved = try project.unresolvedTypealiases.get(name) 'isUnresolvedPrim'
		if let category = try parseTimeTypealiasCategory(project, expr: unresolved.expr) 'haveCat'
			return match category 'cat'
				int gives "$int"
				float gives "$float"
				bool gives "$bool"
				string gives "$String"
				cstring gives "$cstring"
			end 'cat'
		end 'haveCat'
	end 'isUnresolvedPrim'
	return "${name}"
end 'namedTypeMangleSuffix'

// Walk a parse-time `UnresolvedTypeExpr` chain to its primitive category,
// matching what TypeResolution will eventually fold it to. Returns
// `unresolved` for shapes that aren't primitive aliases (generic /
// invalid) so the caller can fall back to the bare-name mangling.
function parseTimeTypealiasCategory(project Project, expr UnresolvedTypeExpr) returns CastCategory throws TypealiasCategoryError
	return match expr 'kind'
		rangedInt gives CastCategory.int
		rangedFloat gives CastCategory.float
		boolPrim gives CastCategory.bool
		aliasName(name) gives try parseTimeTypealiasCategoryByName(project, name: name) otherwise throw TypealiasCategoryError.notPrimitive
		genericAlias throws TypealiasCategoryError.notPrimitive
		sizedGenericAlias throws TypealiasCategoryError.notPrimitive
		functionAlias throws TypealiasCategoryError.notPrimitive
		invalid throws TypealiasCategoryError.notPrimitive
	end 'kind'
end 'parseTimeTypealiasCategory'

function parseTimeTypealiasCategoryByName(project Project, name String) returns CastCategory throws TypealiasCategoryError
	// Primitive built-in shortcut: `int`/`float`/`bool`/`string` may surface
	// inside an `aliasName(int)` from `typealias Foo = int` without bounds.
	if name == "int" or name == "byte" 'isInt'
		return CastCategory.int
	end 'isInt'
	if name == "float" 'isFloat'
		return CastCategory.float
	end 'isFloat'
	if name == "bool" 'isBool'
		return CastCategory.bool
	end 'isBool'
	if name == "String" or name == "string" 'isString'
		return CastCategory.string
	end 'isString'
	if let stdType = try project.typealiases.get(name) 'haveResolved'
		return stdType.rawValue.castCategory
	end 'haveResolved'
	if let unresolved = try project.unresolvedTypealiases.get(name) 'haveUnresolved'
		return try parseTimeTypealiasCategory(project, expr: unresolved.expr) otherwise throw TypealiasCategoryError.notPrimitive
	end 'haveUnresolved'
	throw TypealiasCategoryError.notPrimitive
end 'parseTimeTypealiasCategoryByName'

enum TypealiasCategoryError implements Error
	notPrimitive
end 'TypealiasCategoryError'

// Helper: render a genericInstance as `Base_Arg1_Arg2`, recursing into args
// so nested generics still produce a stable string. Returns the raw token
// (no leading `$`) so the caller can prepend `$` exactly once.
function mangleSuffixForGenericInstance(project Project, id GenericInstanceId) returns String
	let (baseId, args) = project.genericInstances.get(id)
	var result = project.typeNames.get(baseId)
	for i in 0 upto args.count() 'eachArg'
		let a = try args.get(i) otherwise panic("mangleSuffixForGenericInstance: args.get OOB at {i}")
		result = "{result}_{mangleTokenForMaxonType(project, t: a)}"
	end 'eachArg'
	return result
end 'mangleSuffixForGenericInstance'

// Bare-token (no `$` prefix) variant for use when the token is being joined
// with `_` separators inside a larger mangle string.
function mangleTokenForMaxonType(project Project, t MaxonType) returns String
	return match t 'token'
		boolean gives "bool"
		integer gives "int"
		float gives "float"
		string gives "String"
		named(id) gives project.typeNames.get(id)
		typeParameter(id) gives project.typeParameters.getName(id)
		genericInstance(id) gives mangleSuffixForGenericInstance(project, id: id)
		function gives "_"
		interface(id) gives project.interfaceRegistry.getName(id)
		unresolved gives "_"
		constInt(value) gives "{value}"
		opaquePointer gives "_"
		cstring gives "cstring"
	end 'token'
end 'mangleTokenForMaxonType'

// Compute the mangle suffix for a function's non-self parameter types.
// `paramTypes` is the parser-collected user-facing param list (instance
// methods carry __self at index 0). Zero-arg methods (and instance methods
// with only __self) get `$` as their suffix — there is no value-type to
// disambiguate on, so a bare-name collision is a real duplicate.
//
// To allow overloads that share a first-param type but differ in later
// params (e.g. `String.slice(StringIndex, StringIndex)` vs
// `String.slice(StringIndex, GraphemeCount)`), the suffix concatenates
// every non-self param's per-type suffix.
export function mangleSuffixForFirstParam(project Project, paramTypes MaxonTypeArray, hasSelf bool) returns String
	var startIdx = 0
	if hasSelf 'skipSelf'
		startIdx = 1
	end 'skipSelf'
	if startIdx >= paramTypes.count() 'noParam'
		return "$"
	end 'noParam'
	var suffix = ""
	for i in startIdx upto paramTypes.count() 'eachParam'
		let pt = try paramTypes.get(i) otherwise panic("mangleSuffixForFirstParam: paramTypes.get OOB at {i}")
		suffix = "{suffix}{mangleSuffixForMaxonType(project, t: pt)}"
	end 'eachParam'
	return suffix
end 'mangleSuffixForFirstParam'

// Name-based mangle suffix. Used as a fallback when two overloads share
// the same type signature but differ in param names (e.g.
// `slice(start Integer, endIndex Integer)` vs
// `slice(start Integer, length Integer)`). Concatenates every non-self
// param's name with `_` separators, prefixed with `$`. Zero-arg signatures
// collapse to `$` (no name to distinguish).
export function mangleSuffixForParamNames(paramNames StringArray, hasSelf bool) returns String
	var startIdx = 0
	if hasSelf 'skipSelf'
		startIdx = 1
	end 'skipSelf'
	if startIdx >= paramNames.count() 'noParam'
		return "$"
	end 'noParam'
	var suffix = "$"
	for i in startIdx upto paramNames.count() 'eachParam'
		let name = try paramNames.get(i) otherwise panic("mangleSuffixForParamNames: paramNames.get OOB at {i}")
		if i > startIdx 'separator'
			suffix = "{suffix}_"
		end 'separator'
		suffix = "{suffix}{name}"
	end 'eachParam'
	return suffix
end 'mangleSuffixForParamNames'

// Resolve a call's qualified callee against the overload registry. When the
// bare qualified name has overload variants registered, pick the one whose
// first non-self param-type suffix matches the call's first non-self
// argument-type suffix. `hasSelf` mirrors the receiver-prefix rule used at
// registration: methodCall sites pass true (receiver consumes slot 0 of
// the candidate signature), free-call sites pass false.
//
// Returns the bare name unchanged when:
//   - the bare name has no overload variants (the common case), or
//   - no variant's first-param suffix matches the call's first-arg suffix
//     (caller's downstream lookup will then miss and report appropriately).
//
// Returns the bare name when multiple variants match (currently unreachable —
// the parser rejects same-suffix overloads as E2001 — but kept defensive).
export function resolveOverloadedCallee(project Project, bareQualifiedName String, argTypes MaxonTypeArray, hasSelf bool, argLabels StringArray = StringArray.create()) returns String
	let variants = try project.overloadedNames.get(bareQualifiedName) otherwise return bareQualifiedName
	var startIdx = 0
	if hasSelf 'skipSelf'
		startIdx = 1
	end 'skipSelf'
	if startIdx >= argTypes.count() 'noArg'
		// Zero-arg call against an overloaded set — pick the zero-arg variant
		// if one exists. The parser registers it under the bare name + `$`.
		let zeroArgCandidate = "{bareQualifiedName}$"
		for v in variants 'scanZero'
			if v == zeroArgCandidate 'hit'
				return zeroArgCandidate
			end 'hit'
		end 'scanZero'
		return bareQualifiedName
	end 'noArg'
	let firstArgType = try argTypes.get(startIdx) otherwise return bareQualifiedName
	// Build the full-arg suffix (every non-self arg's per-type suffix
	// concatenated), matching the registration mangling at parseFunction's
	// tryRegisterOverload site.
	var argSuffix = ""
	for i in startIdx upto argTypes.count() 'eachArg'
		let at = try argTypes.get(i) otherwise return bareQualifiedName
		argSuffix = "{argSuffix}{mangleSuffixForMaxonType(project, t: at)}"
	end 'eachArg'
	let target = "{bareQualifiedName}{argSuffix}"
	for v in variants 'scan'
		if v == target 'hit'
			return target
		end 'hit'
	end 'scan'
	// Type-suffix miss: the variant might have been registered under the
	// name-based fallback (same types, different param names). Resolve by
	// matching each variant's signature paramNames against the call's
	// argLabels — labeled args bind name-to-name; unlabeled args fall to
	// the bucket's variant whose first non-self paramName matches the
	// first labeled arg (positional args after a label retain their
	// declared position). When exactly one variant's labeled positions
	// match the call's label sequence, return it.
	if let nameMatch = try resolveOverloadByLabels(project, variants: variants, argLabels: argLabels, hasSelf: hasSelf) 'haveNameMatch'
		return nameMatch
	end 'haveNameMatch'
	// Conditional-extension dispatch: a registered variant whose first
	// user-param mentions a type-parameter (`Array.contains$Element`,
	// `Array.contains$Array_Element`) accepts any concrete arg type
	// post-substitution. The exact-suffix scan above only matches concrete
	// encodings (`$int`, `$bool`, `$Array_int`) so a `[int].contains(20)`
	// or `[int].contains([20])` falls through to here. Walk each variant's
	// first user-facing param type and accept if a `typeParameter` arm
	// appears anywhere (including inside a `genericInstance`'s type-args).
	// We additionally compare the variant's first-arg shape category to the
	// caller's so `contains(Element)` and `contains(Array<Element>)` route
	// to the right monomorph: scalar args prefer the typeParameter variant,
	// genericInstance args prefer the genericInstance variant.
	//
	// J.4c: a variant whose first param is declared via an inner-typealias
	// (e.g. `sequence ElementArray` where `typealias ElementArray = Array
	// with Element`) parses as `named("ElementArray")` — neither
	// `paramTypeMentionsTypeParam` nor `paramTypeShape` see the underlying
	// `Array with Element` shape without first chasing the alias through
	// the enclosing type's `innerAliases`. The enclosing type name is the
	// prefix of `bareQualifiedName` before the last `.`.
	let enclosingForChase = enclosingTypeNameFromBareQualified(bareQualifiedName)
	let argShape = paramTypeShape(firstArgType)
	var firstParamMatch = ""
	for v in variants 'scanGeneric'
		let sig = try project.funcSignatures.get(v) otherwise continue
		let userParamIdx = signatureFirstUserParamIndex(sig)
		let rawParamType = try sig.paramTypes.get(userParamIdx) otherwise continue
		let paramType = chaseParamTypeThroughInnerAlias(project, t: rawParamType, enclosingType: enclosingForChase)
		let variantShape = paramTypeShape(paramType)
		// Two acceptance paths:
		//   1. The variant's first param mentions a type parameter (`Element`,
		//      `Array with Element`, etc.). Accept when shapes match, fall
		//      back to first-such variant otherwise.
		//   2. The chased param is a function type that matches the call's
		//      function-typed argument. This catches `function sort(cmp
		//      SortComparator)` where `SortComparator = function(Element,
		//      Element) returns Ordering` — the typealias chases to a
		//      function type, but `paramTypeMentionsTypeParam` doesn't peek
		//      inside function shapes. Without this arm, a literal function
		//      passed as `arr.sort(myCmp)` mangles to `$_` while the variant
		//      registered as `Array.sort$SortComparator` never matches.
		let isGenericMatch = paramTypeMentionsTypeParam(project, t: paramType)
		let isFunctionMatch = variantShape == 6 and argShape == 6
		if not (isGenericMatch or isFunctionMatch) 'concreteOnly'
			continue
		end 'concreteOnly'
		if variantShape == argShape 'shapeMatch'
			return v
		end 'shapeMatch'
		if firstParamMatch.isEmpty() 'recordFirst'
			firstParamMatch = v
		end 'recordFirst'
	end 'scanGeneric'
	if not firstParamMatch.isEmpty() 'haveFirst'
		return firstParamMatch
	end 'haveFirst'
	return bareQualifiedName
end 'resolveOverloadedCallee'

// Resolve overload by matching call's labeled args against each variant's
// paramNames. Used as a fallback when type-only mangling collides (e.g.
// `slice(start, endIndex)` vs `slice(start, length)` — same types, different
// names). Walks each variant; for each labeled arg position the variant's
// param name must match the label exactly; unlabeled positions match any
// param name. Returns the first variant that matches all labeled positions
// and rejects nothing. Empty argLabels means "no label-based disambiguation
// possible" — returns missing. Multiple matches (none distinguished by
// labels) also returns missing — caller falls back to its own diagnostic.
function resolveOverloadByLabels(project Project, variants QualifiedNameArray, argLabels StringArray, hasSelf bool) returns String throws OverloadLabelError
	var hasAnyLabel = false
	for label in argLabels 'scanLabels'
		if not label.isEmpty() 'isLabeled'
			hasAnyLabel = true
			break
		end 'isLabeled'
	end 'scanLabels'
	if not hasAnyLabel 'noLabels'
		throw OverloadLabelError.noMatch
	end 'noLabels'
	var matched = ""
	for v in variants 'scanVariant'
		let sig = try project.funcSignatures.get(v) otherwise continue
		var startIdx = 0
		if hasSelf 'skipSelf'
			startIdx = 1
		end 'skipSelf'
		var ok = true
		for i in 0 upto argLabels.count() 'eachArg'
			let label = try argLabels.get(i) otherwise return v
			if label.isEmpty() 'unlabeled'
				continue
			end 'unlabeled'
			let paramIdx = startIdx + i
			let paramName = try sig.paramNames.get(paramIdx) otherwise 'paramOob'
				ok = false
				break
			end 'paramOob'
			if paramName != label 'mismatch'
				ok = false
				break
			end 'mismatch'
		end 'eachArg'
		if not ok 'noMatch'
			continue
		end 'noMatch'
		if not matched.isEmpty() 'ambiguous'
			throw OverloadLabelError.ambiguous
		end 'ambiguous'
		matched = v
	end 'scanVariant'
	if matched.isEmpty() 'noMatch'
		throw OverloadLabelError.noMatch
	end 'noMatch'
	return matched
end 'resolveOverloadByLabels'

export enum OverloadLabelError implements Error
	noMatch
	ambiguous
end 'OverloadLabelError'

// Phase 11.0 step 8c: helper to skip the implicit `__self` slot when a
// signature's first param is the receiver. Used by the overload-resolution
// fallback that probes each variant's first user-facing param type. Reads
// `paramNames.get(0)` rather than passing `hasSelf` down — the signature
// itself already records whether `__self` is present.
function signatureFirstUserParamIndex(sig FuncSignature) returns ParsedInt
	let firstParam = try sig.paramNames.get(0) otherwise return 0
	if firstParam == "__self" 'hasSelf'
		return 1
	end 'hasSelf'
	return 0
end 'signatureFirstUserParamIndex'

// Phase 11.0 step 8c: True iff `t` mentions a `typeParameter` arm anywhere
// inside its structure. Used by overload resolution to decide whether a
// variant's first user-param is "generic-shaped" (any concrete arg matches
// it post-substitution) versus a fully concrete signature. The
// `genericInstance` arm is treated as generic-shaped without recursing
// into its args because the bootstrap stdlib only registers
// `genericInstance` paramTypes when a type-parameter is in fact threaded
// through (e.g. `Array.contains(sequence: ElementArray)` where
// `ElementArray = Array with Element`); a fully concrete generic instance
// would have been caught by the exact-suffix scan before reaching here.
// J.4c: split `<Type>.<method>` on the last `.` and return `<Type>`. Used by
// `resolveOverloadedCallee` to drive the inner-typealias chase through the
// receiver type's `innerAliases`. Returns "" for non-qualified bucket keys
// (`free.function`-style names that don't have a `.`).
function enclosingTypeNameFromBareQualified(bareQualifiedName String) returns String
	let bytes = bareQualifiedName.toByteArray()
	let dotIdx = lastIndexOfDotByte(bytes)
	if dotIdx >= bytes.count() 'noDot'
		return ""
	end 'noDot'
	return byteSliceToString(bytes, startIndex: 0, endIndex: dotIdx)
end 'enclosingTypeNameFromBareQualified'

// J.4c: when `t` is a `named(...)` arm that matches an inner-typealias on
// `enclosingType` (e.g. `Array.contains(sequence ElementArray)` where
// `typealias ElementArray = Array with Element`), return the alias's
// resolved underlying type. Otherwise return `t` unchanged. Used so the
// overload resolver sees the underlying `Array with Element` shape and
// `paramTypeMentionsTypeParam` / `paramTypeShape` correctly route the
// genericInstance-shaped variant.
function chaseParamTypeThroughInnerAlias(project Project, t MaxonType, enclosingType String) returns MaxonType
	if enclosingType.isEmpty() 'noEnclosing'
		return t
	end 'noEnclosing'
	return match t 'check'
		named(id) gives chaseNamedThroughInnerAlias(project, name: project.typeNames.get(id), enclosingType: enclosingType, fallback: t)
		boolean to string gives t
		typeParameter gives t
		genericInstance gives t
		function gives t
		interface gives t
		unresolved gives t
		constInt to cstring gives t
	end 'check'
end 'chaseParamTypeThroughInnerAlias'

function chaseNamedThroughInnerAlias(project Project, name String, enclosingType String, fallback MaxonType) returns MaxonType
	return try chaseTypealiasNameToType(project, name: name, enclosingType: enclosingType) otherwise fallback
end 'chaseNamedThroughInnerAlias'

function paramTypeMentionsTypeParam(project Project, t MaxonType) returns bool
	return match t 'check'
		typeParameter gives true
		genericInstance(id) gives genericInstanceMentionsTypeParamWalk(project, gid: id)
		boolean to named gives false
		function gives false
		interface gives false
		unresolved gives false
		constInt to cstring gives false
	end 'check'
end 'paramTypeMentionsTypeParam'

function genericInstanceMentionsTypeParamWalk(project Project, gid GenericInstanceId) returns bool
	let (_, args) = project.genericInstances.get(gid)
	for i in 0 upto args.count() 'eachArg'
		let a = try args.get(i) otherwise panic("genericInstanceMentionsTypeParamWalk: args.get OOB at {i}")
		if paramTypeMentionsTypeParam(project, t: a) 'mentionsArg'
			return true
		end 'mentionsArg'
	end 'eachArg'
	return false
end 'genericInstanceMentionsTypeParamWalk'

// Coarse shape category for first-arg overload routing. Mirrors the
// `mangleSuffixForMaxonType` arms but collapses each MaxonType to a single
// integer the call-site walk can compare cheaply. Used to disambiguate two
// generic-shaped overloads of the same bare name (e.g.
// `Array.contains$Element` vs `Array.contains$Array_Element`) — the call
// passes whichever variant's first-param shape matches the caller's first
// argument shape; if neither matches, the first generic-shaped variant
// wins.
function paramTypeShape(t MaxonType) returns ParsedInt
	return match t 'shape'
		boolean gives 1
		integer gives 2
		float gives 3
		string gives 4
		named gives 5
		function gives 6
		interface gives 7
		typeParameter gives 8
		genericInstance gives 9
		unresolved gives 0
		constInt gives 10
		opaquePointer gives 11
		cstring gives 12
	end 'shape'
end 'paramTypeShape'

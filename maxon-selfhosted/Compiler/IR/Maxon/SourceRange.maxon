// Source-level byte range over a file's source buffer.
//
// Every MaxonOp carries a SourceRange locating the syntactic span that
// produced it. Used by diagnostic messages today and by the future LSP's
// hover/goto-def/rename queries, which map cursor positions to ops by
// finding the innermost op whose range contains a given byte offset.
//
// The range is a half-open byte interval [startByte, endByte) into the
// source ByteArray the lexer produced. For synthetic ops that have no
// source span (e.g. compiler-inserted conversions), use `SourceRange.none()`
// which carries both fields as 0.

export type SourceRange
	export let startByte ByteOffset
	export let endByte ByteOffset

	export static function create(startByte ByteOffset, endByte ByteOffset) returns SourceRange
		return Self{startByte: startByte, endByte: endByte}
	end 'create'

	// Sentinel range for synthetic / positionless ops. Downstream consumers
	// (diagnostics, LSP queries) treat `startByte == endByte == 0` as "no
	// source origin".
	export static function none() returns SourceRange
		return Self{startByte: 0, endByte: 0}
	end 'none'

	// Range spanning a single token — convenience for the many single-token
	// ops (literals, variable loads) whose source span is exactly one token.
	export static function ofToken(t Token) returns SourceRange
		return Self{startByte: t.startByte, endByte: t.endByte}
	end 'ofToken'

	// Range spanning from one token through another (inclusive of the second
	// token's end byte). Used for composite ops like binop, call, convert.
	export static function between(first Token, last Token) returns SourceRange
		return Self{startByte: first.startByte, endByte: last.endByte}
	end 'between'

	export function isEmpty() returns bool
		return startByte == endByte
	end 'isEmpty'
end 'SourceRange'

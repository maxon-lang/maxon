// IrPrinter: serializes an IrModule to text.

export function moduleToString(module IrModule, skipStdlib bool, cpu CpuArch) returns String
	let lb = "\{"
	let rb = "\}"
	var sb = "module "
	sb = "{sb}{lb}\n"

	for func in module.functions 'eachFunc'
		if skipStdlib 'filter'
			if skipFunction(func.name) 'isRuntime'
				continue
			end 'isRuntime'
		end 'filter'
		sb = "{sb}{functionToString(module, func: func, cpu: cpu)}"
	end 'eachFunc'

	sb = "{sb}{rb}\n"
	return sb
end 'moduleToString'

function functionToString(module IrModule, func IrFunction, cpu CpuArch) returns String
	let lb = "\{"
	let rb = "\}"
	var sb = "  func @{func.name}("

	for i in 0 upto func.paramCount 'eachParam'
		if i > 0 'comma'
			sb = "{sb}, "
		end 'comma'
		let regName = paramRegName(i, paramTypes: func.paramTypes, cpu: cpu)
		let paramType = try func.paramTypes.get(i) otherwise StdType.i64
		sb = "{sb}{regName}: {paramType.name}"
	end 'eachParam'

	sb = "{sb})"
	if not maxonTypeIsVoid(func.returnType) 'hasReturn'
		sb = "{sb} -> {func.returnStdType.name}"
	end 'hasReturn'
	sb = "{sb} {lb}\n"

	// Resolve function's block refs to blocks for label resolution
	let funcBlocks = resolveFuncBlocks(module, func: func)

	for block in funcBlocks 'eachBlock'

		sb = "{sb}  {block.label}:\n"

		for packed in block.opRefs 'eachOp'
			let opText = opRefToString(module, packed: packed, blocks: funcBlocks)
			sb = "{sb}    {opText}\n"
		end 'eachOp'

		if block.hasTerminator 'hasTerm'
			let termText = opRefToString(module, packed: block.terminator, blocks: funcBlocks)
			sb = "{sb}    {termText}\n"
		end 'hasTerm'
	end 'eachBlock'

	sb = "{sb}  {rb}\n"
	return sb
end 'functionToString'

// Resolve a packed op reference to its string representation.
export function opRefToString(module IrModule, packed OpRef, blocks IrBlockArray) returns String
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_MAXON 'isMaxon'
		let op = try module.maxonOps.get(idx) otherwise 'noMaxon'
			return "??maxon??"
		end 'noMaxon'
		return maxonOpToString(op, blocks: blocks)
	end 'isMaxon'

	if tag == TAG_STD 'isStd'
		let op = try module.stdOps.get(idx) otherwise 'noStd'
			return "??std??"
		end 'noStd'
		return stdOpToString(op, blocks: blocks)
	end 'isStd'

	if tag == TAG_MIR 'isMir'
		let op = try module.mirOps.get(idx) otherwise 'noMir'
			return "??mir??"
		end 'noMir'
		return mirOpToString(op, blocks: blocks)
	end 'isMir'

	if tag == TAG_X64 'isX64'
		let op = try module.x64Ops.get(idx) otherwise 'noX64'
			return "??x64??"
		end 'noX64'
		return x64OpToString(op, blocks: blocks)
	end 'isX64'

	if tag == TAG_ARM64 'isArm64'
		let op = try module.arm64Ops.get(idx) otherwise 'noArm64'
			return "??arm64??"
		end 'noArm64'
		return arm64OpToString(op, blocks: blocks)
	end 'isArm64'

	panic("opRefToString: unknown dialect tag {tag}")
	return ""
end 'opRefToString'

function resolveFuncBlocks(module IrModule, func IrFunction) returns IrBlockArray
	var result = IrBlockArray.create()
	for blockRef in func.blockRefs 'each'
		let block = try module.blocks.get(blockRef) otherwise 'skip'
			continue
		end 'skip'
		result.push(block)
	end 'each'
	return result
end 'resolveFuncBlocks'

// Runtime/stdlib/internal functions should be excluded from IR output.
export function skipFunction(name String) returns bool
	if name.startsWith("mrt_") 'mrtPrefix'
		return true
	end 'mrtPrefix'
	if name.startsWith("__destruct_") 'destructPrefix'
		return true
	end 'destructPrefix'
	if name.startsWith("maxon_") 'maxonPrefix'
		return true
	end 'maxonPrefix'
	if name.startsWith("mm_") 'mmPrefix'
		return true
	end 'mmPrefix'
	if name.startsWith("stdlib.") 'stdlibPrefix'
		return true
	end 'stdlibPrefix'
	if name.startsWith("stdlibTest") 'stdlibTestPrefix'
		return true
	end 'stdlibTestPrefix'
	return false
end 'skipFunction'

// Produces a summary of the module state for pipeline tracing.
// Walks live functions/blocks/ops to count only reachable ops per level.
export function dumpModuleSummary(module IrModule, passName String) returns String
	var totalFuncs = 0
	var totalBlocks = 0
	var totalOps = 0
	var nMaxon = 0
	var nStd = 0
	var nMir = 0
	var nX64 = 0
	var nArm64 = 0

	for func in module.functions 'eachFunc'
		totalFuncs = totalFuncs + 1
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise 'skipBlock'
				continue
			end 'skipBlock'
			totalBlocks = totalBlocks + 1

			// Collect all ops including terminator for unified counting
			var allOps = OpRefList.create()
			for packed in block.opRefs 'collectOps'
				allOps.append(packed)
			end 'collectOps'
			if block.hasTerminator 'addTerm'
				allOps.append(block.terminator)
			end 'addTerm'

			for packed in allOps 'eachOp'
				totalOps = totalOps + 1
				let tag = opRefDialect(packed)
				if tag == TAG_MAXON 'cntMaxon'
					nMaxon = nMaxon + 1
				end 'cntMaxon' else if tag == TAG_STD 'cntStd'
					nStd = nStd + 1
				end 'cntStd' else if tag == TAG_MIR 'cntMir'
					nMir = nMir + 1
				end 'cntMir' else if tag == TAG_X64 'cntX64'
					nX64 = nX64 + 1
				end 'cntX64' else if tag == TAG_ARM64 'cntArm64'
					nArm64 = nArm64 + 1
				end 'cntArm64' else 'unknownOpTag'
					panic("dumpModuleSummary: unknown dialect tag {tag}")
				end 'unknownOpTag'
			end 'eachOp'
		end 'eachBlock'
	end 'eachFunc'

	return "=== After {passName} ===\nFunctions: {totalFuncs}, Blocks: {totalBlocks}, Ops: {totalOps}\n  maxon: {nMaxon}, std: {nStd}, mir: {nMir}, x64: {nX64}, arm64: {nArm64}"
end 'dumpModuleSummary'

function paramRegName(paramIndex VarSlot, paramTypes StdTypeArray, cpu CpuArch) returns String
	let slotIdx = computeParamSlotIndex(paramIndex, paramTypes: paramTypes)
	let paramType = try paramTypes.get(paramIndex) otherwise StdType.i64

	if stdTypeIsFloat(paramType) 'isFloat'
		return match cpu 'cpuDispatchFloat'
			x64 gives x64XmmName(slotIdx)
			arm64 gives arm64FpName(slotIdx)
			wasm32 gives "local{paramIndex}"
		end 'cpuDispatchFloat'
	end 'isFloat'

	return match cpu 'cpuDispatchInt'
		x64 gives x64GprName(slotIdx)
		arm64 gives arm64GprName(slotIdx)
		wasm32 gives "local{paramIndex}"
	end 'cpuDispatchInt'
end 'paramRegName'

function x64GprName(slotIdx VarSlot) returns String
	let names = ["rcx", "rdx", "rax", "r9", "rsi", "rdi", "rbx"]
	return try names.get(slotIdx) otherwise "stack"
end 'x64GprName'

function x64XmmName(slotIdx VarSlot) returns String
	let names = ["xmm0", "xmm1", "xmm2", "xmm3", "xmm4", "xmm5", "xmm6", "xmm7"]
	return try names.get(slotIdx) otherwise "stack"
end 'x64XmmName'

function arm64GprName(slotIdx VarSlot) returns String
	let names = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
	return try names.get(slotIdx) otherwise "stack"
end 'arm64GprName'

function arm64FpName(slotIdx VarSlot) returns String
	let names = ["d0", "d1", "d2", "d3", "d4", "d5", "d6", "d7"]
	return try names.get(slotIdx) otherwise "stack"
end 'arm64FpName'

// MirPrinter: textual dump of a MirModule.
// Provides both a module-level summary (used by the pipeline driver
// for spec test golden-files) and a full module-to-string renderer
// (used by the WASM backend to populate the CompiledIR section of
// spec test fragments — the native targets render their TargetModule
// via TargetPrinter, but WASM bypasses target lowering so we print
// its MIR instead).

// Full module printer. Emits the same outer `module { ... }` shape as
// TargetPrinter so fragment files have a uniform layout across targets.
export function mirModuleToString(module MirModule, skipStdlib bool) returns String
	var body = ""
	for func in module.functions 'eachFunc'
		if skipStdlib 'filter'
			if skipFunction(func.name) 'isRuntime'
				continue
			end 'isRuntime'
		end 'filter'
		body = "{body}{mirFunctionToString(module, func: func)}"
	end 'eachFunc'
	return formatModuleWrapper(body)
end 'mirModuleToString'

function mirFunctionToString(module MirModule, func IrFunction) returns String
	let rb = "\}"
	var sb = formatStdFuncHeader(func)

	// Resolve function's block refs to blocks for label resolution
	let funcBlocks = resolveFuncBlocks(module.blocks, blockRefs: func.blockRefs)

	for block in funcBlocks 'eachBlock'
		sb = "{sb}  {block.label}:\n"

		for opIdx in block.opRefs 'eachOp'
			let opText = mirOpIdxToString(module, opIdx: opIdx, blocks: funcBlocks)
			sb = "{sb}    {opText}\n"
		end 'eachOp'

		if block.hasTerminatorOp() 'hasTerm'
			let termText = mirOpIdxToString(module, opIdx: block.terminatorIndex(), blocks: funcBlocks)
			sb = "{sb}    {termText}\n"
		end 'hasTerm'
	end 'eachBlock'

	sb = "{sb}  {rb}\n"
	return sb
end 'mirFunctionToString'

function mirOpIdxToString(module MirModule, opIdx OpIndex, blocks IrBlockArray) returns String
	// Printer is best-effort — never crash on print; emit a sentinel string instead.
	let op = try module.ops.get(opIdx) otherwise return "??mir??"
	return mirOpToString(op, blocks: blocks)
end 'mirOpIdxToString'

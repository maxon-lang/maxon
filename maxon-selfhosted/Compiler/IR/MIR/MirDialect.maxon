// MIR (Machine IR) Dialect -- Target-independent machine instruction representation.
// Sits between the mid-level dialects (arith/cf/func/memref/sys) and
// the target-specific dialects (x64/arm64). Uses infinite virtual registers
// (ValueId) in SSA form.

export union MirBinOpcode
	addI64 = "mir.add.i64"
	subI64 = "mir.sub.i64"
	mulI64 = "mir.mul.i64"
	divI64 = "mir.div.i64"
	remI64 = "mir.rem.i64"
	andI64 = "mir.and.i64"
	orI64 = "mir.or.i64"
	xorI64 = "mir.xor.i64"
	shlI64 = "mir.shl.i64"
	shrI64 = "mir.shr.i64"
	addF64 = "mir.add.f64"
	subF64 = "mir.sub.f64"
	mulF64 = "mir.mul.f64"
	divF64 = "mir.div.f64"
	minF64 = "mir.min.f64"
	maxF64 = "mir.max.f64"
end 'MirBinOpcode'

export union MirUnaryOpcode
	negI64 = "mir.neg.i64"
	bitNotI64 = "mir.not.i64"
	fpToSiI64 = "mir.fptosi.i64"
	bitcastF64ToI64 = "mir.bitcast.f64.i64"
	siToFpF64 = "mir.sitofp.f64"
	sqrtF64 = "mir.sqrt.f64"
	floorF64 = "mir.floor.f64"
	ceilF64 = "mir.ceil.f64"
	roundF64 = "mir.round.f64"
	absF64 = "mir.abs.f64"
end 'MirUnaryOpcode'

export union MirCmpPredicate
	eq
	ne
	lt
	le
	gt
	ge
	ugt
	feq
	fne
	flt
	fle
	fgt
	fge
end 'MirCmpPredicate'

export union MirOp
	// Constants & moves
	movImm(resultId ValueId, value ParsedInt, isFloat bool)
	movReg(resultId ValueId, srcId ValueId)
	// ALU
	binOp(resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode)
	unaryOp(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode)
	// Compare & branch
	cmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate)
	condBranch(condId ValueId, thenBlock BlockId, thenArgs ValueIdArray, elseBlock BlockId, elseArgs ValueIdArray)
	branch(targetBlock BlockId, args ValueIdArray)
	// Functions
	call(resultId ValueId, callee String, argIds ValueIdArray)
	indirectCall(resultId ValueId, calleeId ValueId, argIds ValueIdArray)
	// Fused witness-table dispatch: load function pointer from
	// witnessAddr at WITNESS_OFFSET_METHODS + 8*methodIndex, then call
	// it with argIds. Backends lower this to a memory-indirect call
	// (`call qword ptr [witnessAddr + offset]` on x64) so the loaded
	// pointer never occupies a virtual GPR. Reduces register pressure
	// at hot witness call sites — see StdCallOp.witnessCall.
	witnessCall(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray)
	ret(retValId ValueId)
	param(resultId ValueId, paramIndex VarSlot, paramType StdType)
	// Memory. `isFloat` on `load`/`store` selects between a GP `mov reg,
	// [base+off]` and a `movsd xmm, [base+off]` at the X64 backend; ARM64
	// picks ldr/x vs ldr/d the same way. Plumbed in by lowerStdToMir from
	// the StdOp's declared slotType so float-typed globals / fields read
	// into XMM directly instead of staging through a GP register. `signed`
	// on `load` chooses sign- vs zero-extension at narrower widths; for
	// `qword` and `isFloat` the bit is unused.
	load(resultId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool)
	store(valueId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, isFloat bool)
	loadSlot(resultId ValueId, slotId VarSlot)
	storeSlot(slotId VarSlot, valueId ValueId)
	stackSlotAddr(resultId ValueId, slotId VarSlot)
	globalAddr(resultId ValueId, name String)
	funcAddr(resultId ValueId, name String)
	loadFramePtr(resultId ValueId)
	// System
	syscall(resultId ValueId, number MachineWord, argIds ValueIdArray)
	iatCall(resultId ValueId, slotIndex MachineWord, argIds ValueIdArray)
	osExit(codeId ValueId)
	osWrite(ptrId ValueId, lenId ValueId)
	osWriteErr(ptrId ValueId, lenId ValueId)
	osOpenWrite(resultId ValueId, pathPtrId ValueId, pathLenId ValueId)
	osWriteFd(fdId ValueId, ptrId ValueId, lenId ValueId)
	osClose(fdId ValueId)
	osGetEnv(resultId ValueId, namePtrId ValueId, nameLenId ValueId, outBufPtrId ValueId, outBufLenId ValueId)
	memcpy(dstId ValueId, srcId ValueId, lenId ValueId)
	storeByte(baseId ValueId, offsetId ValueId, byteId ValueId)
	loadByte(resultId ValueId, baseId ValueId, offsetId ValueId)
	// Page allocation: VirtualAlloc on Windows / mmap on Linux.
	osAllocPages(resultId ValueId, sizeId ValueId)
	osAllocPagesLarge(resultId ValueId, sizeId ValueId)
	osFreePages(ptrId ValueId, sizeId ValueId)
	// Atomic 64-bit memory ops. atomicDec sets ZF when the result is 0.
	// atomicXadd returns the prior value.
	atomicInc(addrId ValueId)
	atomicDec(addrId ValueId)
	atomicXadd(resultId ValueId, addrId ValueId, valId ValueId)
	// Platform locks. Init is a no-op on Linux; spinlock acquire/release on Linux,
	// CRITICAL_SECTION calls on Windows.
	osLockInit(addrId ValueId)
	osLockAcquire(addrId ValueId)
	osLockRelease(addrId ValueId)
	// Multi-value-return error ABI. `tryCall` defines BOTH `resultId` (primary
	// return register: R8 / X0) AND `errorFlagId` (error flag register: RDX /
	// X1) at the same op-position. `errorReturn` USES both `retValId` and
	// `errorFlagId` and is a terminator that emits the dual-register epilogue.
	// Appended at the END of MirOp so existing `to`-range patterns in match
	// expressions (e.g. `osAllocPages to osLockRelease`) keep covering the
	// system-ops band without reshuffling.
	tryCall(resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId)
	errorReturn(retValId ValueId, errorFlagId ValueId)
end 'MirOp'

export typealias MirOpArray = Array with MirOp

// Shared by MIR printer — formats arg IDs with SSA % prefix for IR output
function formatMirArgs(argIds ValueIdArray) returns String
	var result = ""
	for i in 0 upto argIds.count() 'each'
		let argId = try argIds.get(i) otherwise panic("invariant: i < argIds.count() but get failed")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}%{argId}"
	end 'each'
	return result
end 'formatMirArgs'

function mirOpWitnessCallToString(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray) returns String
	if isVoid 'voidFmt'
		return "mir.witness_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
	end 'voidFmt'
	return "%{resultId} = mir.witness_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
end 'mirOpWitnessCallToString'

export function mirOpToString(op MirOp, blocks IrBlockArray) returns String
	return match op 'dispatch'
		// Constants & moves
		movImm(resultId, value, isFloat) gives mirMovImmToString(resultId, value: value, isFloat: isFloat)
		movReg(resultId, srcId) gives "%{resultId} = mir.mov %{srcId}"
		// ALU
		binOp(resultId, leftId, rightId, opcode) gives "%{resultId} = {opcode.rawValue} %{leftId}, %{rightId}"
		unaryOp(resultId, operandId, opcode) gives "%{resultId} = {opcode.rawValue} %{operandId}"
		// Compare & branch
		cmp(resultId, leftId, rightId, predicate) gives "%{resultId} = mir.cmp {predicate.name}, %{leftId}, %{rightId}"
		condBranch(condId, thenBlock, thenArgs, elseBlock, elseArgs) gives mirCondBranchToString(condId, thenBlock: thenBlock, thenArgs: thenArgs, elseBlock: elseBlock, elseArgs: elseArgs, blocks: blocks)
		branch(targetBlock, args) gives mirBranchToString(targetBlock, args: args, blocks: blocks)
		// Functions
		call(resultId, callee, argIds) gives "%{resultId} = mir.call @{callee}({formatMirArgs(argIds)})"
		indirectCall(resultId, calleeId, argIds) gives "%{resultId} = mir.indirect_call %{calleeId}({formatMirArgs(argIds)})"
		witnessCall(resultId, witnessAddrId, methodIndex, isVoid, argIds) gives mirOpWitnessCallToString(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds)
		ret(retValId) gives "mir.ret %{retValId}"
		param(resultId, paramIndex, paramType) gives "%{resultId} = mir.param local{paramIndex} : {paramType.name}"
		// Memory
		load(resultId, baseId, offset, width, signed, isFloat) gives mirLoadToString(resultId, baseId: baseId, offset: offset, width: width, signed: signed, isFloat: isFloat)
		store(valueId, baseId, offset, width, isFloat) gives mirStoreToString(valueId, baseId: baseId, offset: offset, width: width, isFloat: isFloat)
		loadSlot(resultId, slotId) gives "%{resultId} = mir.load_slot slot_{slotId}"
		storeSlot(slotId, valueId) gives "mir.store_slot slot_{slotId}, %{valueId}"
		stackSlotAddr(resultId, slotId) gives "%{resultId} = mir.stack_slot_addr slot_{slotId}"
		globalAddr(resultId, name) gives "%{resultId} = mir.global_addr @{name}"
		funcAddr(resultId, name) gives "%{resultId} = mir.func_addr @{name}"
		loadFramePtr(resultId) gives "%{resultId} = mir.load_frame_ptr"
		// System
		syscall(resultId, number, argIds) gives "%{resultId} = mir.syscall {number}({formatMirArgs(argIds)})"
		iatCall(resultId, slotIndex, argIds) gives "%{resultId} = mir.iat_call [{slotIndex}]({formatMirArgs(argIds)})"
		osExit(codeId) gives "mir.os_exit %{codeId}"
		osWrite(ptrId, lenId) gives "mir.os_write %{ptrId}, %{lenId}"
		osWriteErr(ptrId, lenId) gives "mir.os_write_err %{ptrId}, %{lenId}"
		osOpenWrite(resultId, pathPtrId, pathLenId) gives "%{resultId} = mir.os_open_write %{pathPtrId}, %{pathLenId}"
		osWriteFd(fdId, ptrId, lenId) gives "mir.os_write_fd %{fdId}, %{ptrId}, %{lenId}"
		osClose(fdId) gives "mir.os_close %{fdId}"
		osGetEnv(resultId, namePtrId, nameLenId, outBufPtrId, outBufLenId) gives "%{resultId} = mir.os_get_env %{namePtrId}, %{nameLenId}, %{outBufPtrId}, %{outBufLenId}"
		memcpy(dstId, srcId, lenId) gives "mir.memcpy %{dstId}, %{srcId}, %{lenId}"
		storeByte(baseId, offsetId, byteId) gives "mir.store_byte %{baseId}, %{offsetId}, %{byteId}"
		loadByte(resultId, baseId, offsetId) gives "%{resultId} = mir.load_byte %{baseId}, %{offsetId}"
		osAllocPages(resultId, sizeId) gives "%{resultId} = mir.os_alloc_pages %{sizeId}"
		osAllocPagesLarge(resultId, sizeId) gives "%{resultId} = mir.os_alloc_pages_large %{sizeId}"
		osFreePages(ptrId, sizeId) gives "mir.os_free_pages %{ptrId}, %{sizeId}"
		atomicInc(addrId) gives "mir.atomic_inc %{addrId}"
		atomicDec(addrId) gives "mir.atomic_dec %{addrId}"
		atomicXadd(resultId, addrId, valId) gives "%{resultId} = mir.atomic_xadd %{addrId}, %{valId}"
		osLockInit(addrId) gives "mir.os_lock_init %{addrId}"
		osLockAcquire(addrId) gives "mir.os_lock_acquire %{addrId}"
		osLockRelease(addrId) gives "mir.os_lock_release %{addrId}"
		tryCall(resultId, callee, argIds, errorFlagId) gives "%{resultId}, %{errorFlagId} = mir.try_call @{callee}({formatMirArgs(argIds)})"
		errorReturn(retValId, errorFlagId) gives "mir.error_return %{retValId}, %{errorFlagId}"
	end 'dispatch'
end 'mirOpToString'

function mirMovImmToString(resultId ValueId, value ParsedInt, isFloat bool) returns String
	if isFloat 'float'
		return "%{resultId} = mir.mov_imm {value} : f64"
	end 'float'
	return "%{resultId} = mir.mov_imm {value} : i64"
end 'mirMovImmToString'

function mirLoadToString(resultId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool) returns String
	if isFloat 'float'
		return "%{resultId} = mir.load %{baseId}, {offset} width: {storeWidthName(width)} : f64"
	end 'float'
	// `signed` is meaningless at qword width — a 64-bit load fills the
	// register naturally — so suppress the tag to match what the backend
	// actually emits (plain `mov`/`ldr`, never `movsx`/`ldrsw`).
	let signTag = match width 'w'
		qword gives ""
		byte gives " signed" if signed else ""
		halfword gives " signed" if signed else ""
		word gives " signed" if signed else ""
	end 'w'
	return "%{resultId} = mir.load %{baseId}, {offset} width: {storeWidthName(width)}{signTag}"
end 'mirLoadToString'

function mirStoreToString(valueId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, isFloat bool) returns String
	if isFloat 'float'
		return "mir.store %{valueId}, %{baseId}, {offset} width: {storeWidthName(width)} : f64"
	end 'float'
	return "mir.store %{valueId}, %{baseId}, {offset} width: {storeWidthName(width)}"
end 'mirStoreToString'

function mirCondBranchToString(condId ValueId, thenBlock BlockId, thenArgs ValueIdArray, elseBlock BlockId, elseArgs ValueIdArray, blocks IrBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenBlock, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseBlock, blocks: blocks)
	let thenArgsStr = formatMirArgs(thenArgs)
	let elseArgsStr = formatMirArgs(elseArgs)
	return "mir.cond_br %{condId} [then: {thenLabel}({thenArgsStr}), else: {elseLabel}({elseArgsStr})]"
end 'mirCondBranchToString'

function mirBranchToString(targetBlock BlockId, args ValueIdArray, blocks IrBlockArray) returns String
	let label = resolveBlockLabel(targetBlock, blocks: blocks)
	let argsStr = formatMirArgs(args)
	return "mir.br {label}({argsStr})"
end 'mirBranchToString'

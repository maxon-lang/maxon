// MIR (Machine IR) Dialect -- Target-independent machine instruction representation.
// Sits between the mid-level dialects (arith/cf/func/memref/sys) and
// the target-specific dialects (x64/arm64). Uses infinite virtual registers
// (ValueId) in SSA form.

export union MirBinOpcode
	addI64 = "mir.add.i64"
	subI64 = "mir.sub.i64"
	mulI64 = "mir.mul.i64"
	divI64 = "mir.div.i64"
	remI64 = "mir.rem.i64"
	andI64 = "mir.and.i64"
	orI64 = "mir.or.i64"
	xorI64 = "mir.xor.i64"
	shlI64 = "mir.shl.i64"
	shrI64 = "mir.shr.i64"
	addF64 = "mir.add.f64"
	subF64 = "mir.sub.f64"
	mulF64 = "mir.mul.f64"
	divF64 = "mir.div.f64"
	minF64 = "mir.min.f64"
	maxF64 = "mir.max.f64"
end 'MirBinOpcode'

export union MirUnaryOpcode
	negI64 = "mir.neg.i64"
	bitNotI64 = "mir.not.i64"
	fpToSiI64 = "mir.fptosi.i64"
	bitcastF64ToI64 = "mir.bitcast.f64.i64"
	bitcastI64ToF64 = "mir.bitcast.i64.f64"
	siToFpF64 = "mir.sitofp.f64"
	sqrtF64 = "mir.sqrt.f64"
	floorF64 = "mir.floor.f64"
	ceilF64 = "mir.ceil.f64"
	roundF64 = "mir.round.f64"
	absF64 = "mir.abs.f64"
end 'MirUnaryOpcode'

export union MirCmpPredicate
	eq
	ne
	lt
	le
	gt
	ge
	ugt
	feq
	fne
	flt
	fle
	fgt
	fge
end 'MirCmpPredicate'

export type MirOpMeta
	// True for ops that access memory or have observable side effects that
	// the scheduler must treat as a memory barrier. Covers loads, stores,
	// calls, syscalls, atomics, and locks. See isStore notes for the
	// policy on file-I/O ops (osFileOpen .. osDirMkdir): they read/write
	// caller buffers and have external syscall side effects, so they
	// participate in both the memory and store bands.
	export let isMemory as bool
	// True for ops that write memory or have externally-observable side
	// effects (must order with subsequent loads). Distinct from isMemory:
	// pure loads are memory but not stores.
	export let isStore as bool
	// True for ops with full call-barrier semantics (clobber caller-saved
	// regs, may observe/modify arbitrary memory). Also true for `param`
	// since param ops read physical CC registers and must be ordered.
	export let isCall as bool
	// True if the op may clobber x64 EFLAGS / ARM64 NZCV when lowered.
	// Used to pin the cmp feeding a cond_br adjacent to its consumer in
	// the schedule. Conservative: anything that isn't a pure register-
	// to-register or memory-to-register move clobbers flags. movImm is
	// covered because the zero case lowers to `xor reg, reg` which sets
	// flags. Calls/OS ops are not flagged here because they already
	// participate in the call-barrier chain.
	export let clobbersFlags as bool
	// Single-variant flags used as one-shot tag checks. Kept as metadata
	// for uniformity; reading `.rawValue.isParam` matches the pattern the
	// X64/Arm64 backends already use for similar single-variant queries.
	export let isParam as bool
	export let isCmp as bool
end 'MirOpMeta'

export union MirOp
	// Constants & moves
	movImm(resultId ValueId, value ParsedInt, isFloat bool) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	movReg(resultId ValueId, srcId ValueId) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	// ALU
	binOp(resultId ValueId, leftId ValueId, rightId ValueId, opcode MirBinOpcode) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	unaryOp(resultId ValueId, operandId ValueId, opcode MirUnaryOpcode) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	// Compare & branch
	cmp(resultId ValueId, leftId ValueId, rightId ValueId, predicate MirCmpPredicate) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: true, isParam: false, isCmp: true}
	condBranch(condId ValueId, thenBlock BlockId, thenArgs ValueIdArray, elseBlock BlockId, elseArgs ValueIdArray) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	branch(targetBlock BlockId, args ValueIdArray) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	// Functions
	call(resultId ValueId, callee String, argIds ValueIdArray) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// `isVoid`/`throws` mirror StdCallOp.indirectCall: void targets emit a
	// no-result wasm `call_indirect` signature; throwing targets append a
	// trailing i64 error flag and define `errorFlagId` as a second result.
	// Only the wasm green-thread runtime (`__gt_invoke`) produces the void/
	// throwing forms; native backends only ever see the (false,false) form.
	indirectCall(resultId ValueId, calleeId ValueId, argIds ValueIdArray, isVoid bool, isThrowing bool, errorFlagId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Fused witness-table dispatch: load function pointer from
	// witnessAddr at WITNESS_OFFSET_METHODS + 8*methodIndex, then call
	// it with argIds. Backends lower this to a memory-indirect call
	// (`call qword ptr [witnessAddr + offset]` on x64) so the loaded
	// pointer never occupies a virtual GPR. Reduces register pressure
	// at hot witness call sites — see StdCallOp.witnessCall.
	witnessCall(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	ret(retValId ValueId) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	param(resultId ValueId, paramIndex VarSlot, paramType StdType) = MirOpMeta{isMemory: false, isStore: false, isCall: true, clobbersFlags: false, isParam: true, isCmp: false}
	// Memory. `isFloat` on `load`/`store` selects between a GP `mov reg,
	// [base+off]` and a `movsd xmm, [base+off]` at the X64 backend; ARM64
	// picks ldr/x vs ldr/d the same way. Plumbed in by lowerStdToMir from
	// the StdOp's declared slotType so float-typed globals / fields read
	// into XMM directly instead of staging through a GP register. `signed`
	// on `load` chooses sign- vs zero-extension at narrower widths; for
	// `qword` and `isFloat` the bit is unused.
	load(resultId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool) = MirOpMeta{isMemory: true, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	store(valueId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, isFloat bool) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	loadSlot(resultId ValueId, slotId VarSlot) = MirOpMeta{isMemory: true, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	storeSlot(slotId VarSlot, valueId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	stackSlotAddr(resultId ValueId, slotId VarSlot) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	globalAddr(resultId ValueId, name String) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	funcAddr(resultId ValueId, name String) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	loadFramePtr(resultId ValueId) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	// System
	osExit(codeId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// OS-neutral green-thread sleep. See StdSystemOp.osSleep for semantics.
	osSleep(msId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osWrite(ptrId ValueId, lenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osWriteErr(ptrId ValueId, lenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osRead(resultId ValueId, ptrId ValueId, lenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osOpenWrite(resultId ValueId, pathPtrId ValueId, pathLenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osWriteFd(fdId ValueId, ptrId ValueId, lenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osClose(fdId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osGetEnv(resultId ValueId, namePtrId ValueId, nameLenId ValueId, outBufPtrId ValueId, outBufLenId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Intent-level argv / executable-path ops. Each backend chooses the
	// underlying mechanism per-OS. Mirror the placement of `osGetEnv` so
	// the system-ops band stays contiguous for `to`-range matches.
	// osGetArgc is a pure read (returns a process-state integer);
	// osGetArgv returns a pointer without touching caller memory;
	// osGetExecutablePath writes into the caller-supplied buffer, so it
	// participates in the store band.
	osGetArgc(resultId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osGetArgv(resultId ValueId, indexId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osGetExecutablePath(resultId ValueId, bufPtrId ValueId, bufSizeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	memcpy(dstId ValueId, srcId ValueId, lenId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	storeByte(baseId ValueId, offsetId ValueId, byteId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	loadByte(resultId ValueId, baseId ValueId, offsetId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
	// Page allocation: VirtualAlloc on Windows / mmap on Linux.
	// alloc returns a pointer to fresh pages — no aliased caller memory
	// is written from the caller's perspective, so isStore stays false.
	// osFreePages releases pages and is treated as a store barrier.
	osAllocPages(resultId ValueId, sizeId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osAllocPagesLarge(resultId ValueId, sizeId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFreePages(ptrId ValueId, sizeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Phase 15c Stream 4.1: Linux file-I/O ops. Each lowers to a raw syscall
	// on x64-linux / arm64-linux backends. Path arguments are mm_alloc'd
	// NUL-terminated buffers; the helper bodies that emit these ops own
	// the alloc/free of the temp C-string. Conservative isStore: true —
	// every op has external syscall side effects observable from other
	// threads/files, so the scheduler must treat them as stores.
	osFileOpen(resultId ValueId, cStringPtrId ValueId, flagsId ValueId, fileModeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileRead(resultId ValueId, fdId ValueId, bufPtrId ValueId, countId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileWrite(resultId ValueId, fdId ValueId, bufPtrId ValueId, countId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileClose(resultId ValueId, fdId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileLseek(resultId ValueId, fdId ValueId, offsetId ValueId, whenceId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileStat(resultId ValueId, cStringPtrId ValueId, statBufPtrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileAccess(resultId ValueId, cStringPtrId ValueId, modeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osFileUnlink(resultId ValueId, cStringPtrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osDirGetdents64(resultId ValueId, fdId ValueId, bufPtrId ValueId, bufSizeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osDirGetcwd(resultId ValueId, bufPtrId ValueId, bufSizeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osDirMkdir(resultId ValueId, cStringPtrId ValueId, modeId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Atomic 64-bit memory ops. atomicDec sets ZF when the result is 0.
	// atomicXadd returns the prior value. All three clobber flags via the
	// LOCK INC/DEC/XADD lowering.
	atomicInc(addrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	atomicDec(addrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	atomicXadd(resultId ValueId, addrId ValueId, valId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: false, clobbersFlags: true, isParam: false, isCmp: false}
	// Platform locks. Init is a no-op on Linux; spinlock acquire/release on Linux,
	// CRITICAL_SECTION calls on Windows.
	osLockInit(addrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osLockAcquire(addrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	osLockRelease(addrId ValueId) = MirOpMeta{isMemory: true, isStore: true, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Multi-value-return error ABI. `tryCall` defines BOTH `resultId` (primary
	// return register: R8 / X0) AND `errorFlagId` (error flag register: RDX /
	// X1) at the same op-position. `errorReturn` USES both `retValId` and
	// `errorFlagId` and is a terminator that emits the dual-register epilogue.
	// Appended at the END of MirOp so existing `to`-range patterns in match
	// expressions (e.g. `osAllocPages to osLockRelease`) keep covering the
	// system-ops band without reshuffling. errorReturn is a terminator with
	// no body-side effect on subsequent ops in this block (control falls
	// off the function), so it doesn't need barrier treatment.
	tryCall(resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	// Throwing witness-table dispatch: union of `witnessCall` (load fn ptr
	// from witnessAddr at WITNESS_OFFSET_METHODS + 8*methodIndex, then
	// memory-indirect call) and `tryCall` (defines BOTH `resultId` AND
	// `errorFlagId` — the error flag in RDX / X1). Emitted for `throws`
	// interface methods reached through a witness so the thrown error
	// propagates to the caller's `try`.
	witnessTryCall(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray, errorFlagId ValueId) = MirOpMeta{isMemory: true, isStore: false, isCall: true, clobbersFlags: false, isParam: false, isCmp: false}
	errorReturn(retValId ValueId, errorFlagId ValueId) = MirOpMeta{isMemory: false, isStore: false, isCall: false, clobbersFlags: false, isParam: false, isCmp: false}
end 'MirOp'

export typealias MirOpArray = Array with MirOp

// Shared by MIR printer — formats arg IDs with SSA % prefix for IR output
function formatMirArgs(argIds ValueIdArray) returns String
	var result = ""
	for i in 0 upto argIds.count() 'each'
		let argId = try argIds.get(i) otherwise panic("invariant: i < argIds.count() but get failed")
		if i > 0 'comma'
			result = "{result}, "
		end 'comma'
		result = "{result}%{argId}"
	end 'each'
	return result
end 'formatMirArgs'

function mirOpWitnessCallToString(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray) returns String
	if isVoid 'voidFmt'
		return "mir.witness_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
	end 'voidFmt'
	return "%{resultId} = mir.witness_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
end 'mirOpWitnessCallToString'

function mirOpWitnessTryCallToString(resultId ValueId, witnessAddrId ValueId, methodIndex MachineWord, isVoid bool, argIds ValueIdArray, errorFlagId ValueId) returns String
	if isVoid 'voidFmt'
		return "%{errorFlagId} = mir.witness_try_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
	end 'voidFmt'
	return "%{resultId}, %{errorFlagId} = mir.witness_try_call %{witnessAddrId}, [{methodIndex}]({formatMirArgs(argIds)})"
end 'mirOpWitnessTryCallToString'

export function mirOpToString(op MirOp, blocks IrBlockArray) returns String
	return match op 'dispatch'
		// Constants & moves
		movImm(resultId, value, isFloat) gives mirMovImmToString(resultId, value: value, isFloat: isFloat)
		movReg(resultId, srcId) gives "%{resultId} = mir.mov %{srcId}"
		// ALU
		binOp(resultId, leftId, rightId, opcode) gives "%{resultId} = {opcode.rawValue} %{leftId}, %{rightId}"
		unaryOp(resultId, operandId, opcode) gives "%{resultId} = {opcode.rawValue} %{operandId}"
		// Compare & branch
		cmp(resultId, leftId, rightId, predicate) gives "%{resultId} = mir.cmp {predicate.name}, %{leftId}, %{rightId}"
		condBranch(condId, thenBlock, thenArgs, elseBlock, elseArgs) gives mirCondBranchToString(condId, thenBlock: thenBlock, thenArgs: thenArgs, elseBlock: elseBlock, elseArgs: elseArgs, blocks: blocks)
		branch(targetBlock, args) gives mirBranchToString(targetBlock, args: args, blocks: blocks)
		// Functions
		call(resultId, callee, argIds) gives "%{resultId} = mir.call @{callee}({formatMirArgs(argIds)})"
		indirectCall(resultId, calleeId, argIds, _, _, _) gives "%{resultId} = mir.indirect_call %{calleeId}({formatMirArgs(argIds)})"
		witnessCall(resultId, witnessAddrId, methodIndex, isVoid, argIds) gives mirOpWitnessCallToString(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds)
		ret(retValId) gives "mir.ret %{retValId}"
		param(resultId, paramIndex, paramType) gives "%{resultId} = mir.param local{paramIndex} : {paramType.name}"
		// Memory
		load(resultId, baseId, offset, width, signed, isFloat) gives mirLoadToString(resultId, baseId: baseId, offset: offset, width: width, signed: signed, isFloat: isFloat)
		store(valueId, baseId, offset, width, isFloat) gives mirStoreToString(valueId, baseId: baseId, offset: offset, width: width, isFloat: isFloat)
		loadSlot(resultId, slotId) gives "%{resultId} = mir.load_slot slot_{slotId}"
		storeSlot(slotId, valueId) gives "mir.store_slot slot_{slotId}, %{valueId}"
		stackSlotAddr(resultId, slotId) gives "%{resultId} = mir.stack_slot_addr slot_{slotId}"
		globalAddr(resultId, name) gives "%{resultId} = mir.global_addr @{name}"
		funcAddr(resultId, name) gives "%{resultId} = mir.func_addr @{name}"
		loadFramePtr(resultId) gives "%{resultId} = mir.load_frame_ptr"
		// System
		osExit(codeId) gives "mir.os_exit %{codeId}"
		osSleep(msId) gives "mir.os_sleep %{msId}"
		osWrite(ptrId, lenId) gives "mir.os_write %{ptrId}, %{lenId}"
		osWriteErr(ptrId, lenId) gives "mir.os_write_err %{ptrId}, %{lenId}"
		osRead(resultId, ptrId, lenId) gives "%{resultId} = mir.os_read %{ptrId}, %{lenId}"
		osOpenWrite(resultId, pathPtrId, pathLenId) gives "%{resultId} = mir.os_open_write %{pathPtrId}, %{pathLenId}"
		osWriteFd(fdId, ptrId, lenId) gives "mir.os_write_fd %{fdId}, %{ptrId}, %{lenId}"
		osClose(fdId) gives "mir.os_close %{fdId}"
		osGetEnv(resultId, namePtrId, nameLenId, outBufPtrId, outBufLenId) gives "%{resultId} = mir.os_get_env %{namePtrId}, %{nameLenId}, %{outBufPtrId}, %{outBufLenId}"
		osGetArgc(resultId) gives "%{resultId} = mir.os_get_argc"
		osGetArgv(resultId, indexId) gives "%{resultId} = mir.os_get_argv %{indexId}"
		osGetExecutablePath(resultId, bufPtrId, bufSizeId) gives "%{resultId} = mir.os_get_executable_path %{bufPtrId}, %{bufSizeId}"
		memcpy(dstId, srcId, lenId) gives "mir.memcpy %{dstId}, %{srcId}, %{lenId}"
		storeByte(baseId, offsetId, byteId) gives "mir.store_byte %{baseId}, %{offsetId}, %{byteId}"
		loadByte(resultId, baseId, offsetId) gives "%{resultId} = mir.load_byte %{baseId}, %{offsetId}"
		osAllocPages(resultId, sizeId) gives "%{resultId} = mir.os_alloc_pages %{sizeId}"
		osAllocPagesLarge(resultId, sizeId) gives "%{resultId} = mir.os_alloc_pages_large %{sizeId}"
		osFreePages(ptrId, sizeId) gives "mir.os_free_pages %{ptrId}, %{sizeId}"
		osFileOpen(resultId, cStringPtrId, flagsId, fileModeId) gives "%{resultId} = mir.os_file_open %{cStringPtrId}, %{flagsId}, %{fileModeId}"
		osFileRead(resultId, fdId, bufPtrId, countId) gives "%{resultId} = mir.os_file_read %{fdId}, %{bufPtrId}, %{countId}"
		osFileWrite(resultId, fdId, bufPtrId, countId) gives "%{resultId} = mir.os_file_write %{fdId}, %{bufPtrId}, %{countId}"
		osFileClose(resultId, fdId) gives "%{resultId} = mir.os_file_close %{fdId}"
		osFileLseek(resultId, fdId, offsetId, whenceId) gives "%{resultId} = mir.os_file_lseek %{fdId}, %{offsetId}, %{whenceId}"
		osFileStat(resultId, cStringPtrId, statBufPtrId) gives "%{resultId} = mir.os_file_stat %{cStringPtrId}, %{statBufPtrId}"
		osFileAccess(resultId, cStringPtrId, modeId) gives "%{resultId} = mir.os_file_access %{cStringPtrId}, %{modeId}"
		osFileUnlink(resultId, cStringPtrId) gives "%{resultId} = mir.os_file_unlink %{cStringPtrId}"
		osDirGetdents64(resultId, fdId, bufPtrId, bufSizeId) gives "%{resultId} = mir.os_dir_getdents64 %{fdId}, %{bufPtrId}, %{bufSizeId}"
		osDirGetcwd(resultId, bufPtrId, bufSizeId) gives "%{resultId} = mir.os_dir_getcwd %{bufPtrId}, %{bufSizeId}"
		osDirMkdir(resultId, cStringPtrId, modeId) gives "%{resultId} = mir.os_dir_mkdir %{cStringPtrId}, %{modeId}"
		atomicInc(addrId) gives "mir.atomic_inc %{addrId}"
		atomicDec(addrId) gives "mir.atomic_dec %{addrId}"
		atomicXadd(resultId, addrId, valId) gives "%{resultId} = mir.atomic_xadd %{addrId}, %{valId}"
		osLockInit(addrId) gives "mir.os_lock_init %{addrId}"
		osLockAcquire(addrId) gives "mir.os_lock_acquire %{addrId}"
		osLockRelease(addrId) gives "mir.os_lock_release %{addrId}"
		tryCall(resultId, callee, argIds, errorFlagId) gives "%{resultId}, %{errorFlagId} = mir.try_call @{callee}({formatMirArgs(argIds)})"
		witnessTryCall(resultId, witnessAddrId, methodIndex, isVoid, argIds, errorFlagId) gives mirOpWitnessTryCallToString(resultId, witnessAddrId: witnessAddrId, methodIndex: methodIndex, isVoid: isVoid, argIds: argIds, errorFlagId: errorFlagId)
		errorReturn(retValId, errorFlagId) gives "mir.error_return %{retValId}, %{errorFlagId}"
	end 'dispatch'
end 'mirOpToString'

function mirMovImmToString(resultId ValueId, value ParsedInt, isFloat bool) returns String
	if isFloat 'float'
		return "%{resultId} = mir.mov_imm {value} : f64"
	end 'float'
	return "%{resultId} = mir.mov_imm {value} : i64"
end 'mirMovImmToString'

function mirLoadToString(resultId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, signed bool, isFloat bool) returns String
	if isFloat 'float'
		return "%{resultId} = mir.load %{baseId}, {offset} width: {storeWidthName(width)} : f64"
	end 'float'
	// `signed` is meaningless at qword width — a 64-bit load fills the
	// register naturally — so suppress the tag to match what the backend
	// actually emits (plain `mov`/`ldr`, never `movsx`/`ldrsw`).
	let signTag = match width 'w'
		qword gives ""
		byte gives " signed" if signed else ""
		halfword gives " signed" if signed else ""
		word gives " signed" if signed else ""
	end 'w'
	return "%{resultId} = mir.load %{baseId}, {offset} width: {storeWidthName(width)}{signTag}"
end 'mirLoadToString'

function mirStoreToString(valueId ValueId, baseId ValueId, offset MachineWord, width StoreWidth, isFloat bool) returns String
	if isFloat 'float'
		return "mir.store %{valueId}, %{baseId}, {offset} width: {storeWidthName(width)} : f64"
	end 'float'
	return "mir.store %{valueId}, %{baseId}, {offset} width: {storeWidthName(width)}"
end 'mirStoreToString'

function mirCondBranchToString(condId ValueId, thenBlock BlockId, thenArgs ValueIdArray, elseBlock BlockId, elseArgs ValueIdArray, blocks IrBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenBlock, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseBlock, blocks: blocks)
	let thenArgsStr = formatMirArgs(thenArgs)
	let elseArgsStr = formatMirArgs(elseArgs)
	return "mir.cond_br %{condId} [then: {thenLabel}({thenArgsStr}), else: {elseLabel}({elseArgsStr})]"
end 'mirCondBranchToString'

function mirBranchToString(targetBlock BlockId, args ValueIdArray, blocks IrBlockArray) returns String
	let label = resolveBlockLabel(targetBlock, blocks: blocks)
	let argsStr = formatMirArgs(args)
	return "mir.br {label}({argsStr})"
end 'mirBranchToString'

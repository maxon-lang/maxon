// IrModule: generic top-level container for all pre-target IR phases.
// Parameterized by the op type (MaxonOp, StdOp, MirOp) so that the
// type checker enforces phase separation while the implementation is
// written once.
//
// Each phase instantiates this as a typealias:
//   typealias MaxonModule = IrModule with MaxonOp
//   typealias StdModule   = IrModule with StdOp
//   typealias MirModule   = IrModule with MirOp

// Thrown by IrModule.findBlockRef when the given block isn't registered in
// the function's block list — used by the parser's statement-line recorder
// to silently skip detached sink blocks produced by newDetachedBlock.
export enum BlockRefLookupError implements Error
	notInFunction
end 'BlockRefLookupError'

export type IrModule uses Op
	typealias OpArray = Array with Op

	export var functions IrFunctionArray = IrFunctionArray.create()
	export var blocks IrBlockArray = IrBlockArray.create()
	export var ops OpArray = OpArray.create()
	// Parallel to `blocks`: entry at index i describes the source footprint
	// of blocks[i]. Populated by the parser at every block-creation site,
	// preserved through lowerMaxonToStd, and consumed by the coverage
	// instrumentation pass to map each block to the source lines it covers.
	// Blocks created outside the parser (e.g. by later passes) keep the
	// BlockSourceInfo.empty() sentinel.
	export var blockSourceInfo BlockSourceInfoArray = BlockSourceInfoArray.create()

	export static function create() returns Self
		return Self{}
	end 'create'

	export function opCount() returns Count
		return self.ops.count()
	end 'opCount'

	export function appendOps(source Self)
		self.ops.append(source.ops)
	end 'appendOps'

	export function blockCount() returns Count
		return self.blocks.count()
	end 'blockCount'

	export function getBlock(index Count) returns IrBlock
		return try self.blocks.get(index) otherwise panic("getBlock: index out of bounds")
	end 'getBlock'

	export function pushBlock(block IrBlock)
		self.blocks.push(block)
		self.blockSourceInfo.push(BlockSourceInfo.empty())
	end 'pushBlock'

	export function funcCount() returns Count
		return self.functions.count()
	end 'funcCount'

	export function getFunc(index Count) returns IrFunction
		return try self.functions.get(index) otherwise panic("getFunc: index out of bounds")
	end 'getFunc'

	export function pushFunc(func IrFunction)
		self.functions.push(func)
	end 'pushFunc'

	export function cloneFunc(src IrFunction, blockOffset Count) returns IrFunction
		var func = IrFunction.clone(src)
		for blockRef in src.blockRefs 'eachBlockRef'
			func.blockRefs.append(blockRef + blockOffset)
		end 'eachBlockRef'
		return func
	end 'cloneFunc'

	export function appendOp(block IrBlock, op Op)
		let idx = self.ops.count()
		self.ops.push(op)
		block.opRefs.append(idx)
	end 'appendOp'

	export function setTerminator(block IrBlock, op Op)
		let idx = self.ops.count()
		self.ops.push(op)
		block.terminator = Terminator.opIndex(idx)
	end 'setTerminator'

	export function addBlock(func IrFunction, label String) returns IrBlock
		let id = func.nextBlockId
		func.nextBlockId = func.nextBlockId + 1
		let block = createAndRegisterBlock(func.blockRefs, id: id, label: label)
		self.blockSourceInfo.push(BlockSourceInfo.empty())
		return block
	end 'addBlock'

	// Parser-facing variant of addBlock that records the block's source
	// footprint (file path + opening line) in the parallel blockSourceInfo
	// table. `firstLine` is the line of the token that triggered the block's
	// creation — the condition/while keyword, the entry token of a function
	// body, etc.
	export function addBlockAt(func IrFunction, label String, filePath String, firstLine LineNumber) returns IrBlock
		let id = func.nextBlockId
		func.nextBlockId = func.nextBlockId + 1
		let block = createAndRegisterBlock(func.blockRefs, id: id, label: label)
		self.blockSourceInfo.push(BlockSourceInfo.create(filePath, firstLine: firstLine))
		return block
	end 'addBlockAt'

	// Create a new IrBlock, append it to the blocks array, and register its
	// index in the function's blockRefs. The caller must bump func.nextBlockId
	// after calling this (the function returns the allocated id via the block).
	function createAndRegisterBlock(blockRefs BlockRefList, id BlockId, label String) returns IrBlock
		let blockIdx = blocks.count()
		let block = IrBlock.create(id, label: label)
		blocks.push(block)
		blockRefs.append(blockIdx)
		return block
	end 'createAndRegisterBlock'

	// Locate the flat blocks[] index of `block` within `func`'s block set.
	// Used by the parser's statement-line recorder. BlockId is only unique
	// within a single function, so restricting the scan to func.blockRefs
	// disambiguates even when multiple functions share the same id space.
	// Throws when the block isn't registered in `func` — that happens only
	// for detached sink blocks (the dead block produced by newDetachedBlock),
	// which carry no source info and must not be recorded against.
	export function findBlockRef(func IrFunction, block IrBlock) returns Count throws BlockRefLookupError
		for blockRef in func.blockRefs 'each'
			let candidate = try self.blocks.get(blockRef) otherwise panic("invariant: blockRef from func.blockRefs not in self.blocks")
			if candidate.id == block.id 'match'
				return blockRef
			end 'match'
		end 'each'
		throw BlockRefLookupError.notInFunction
	end 'findBlockRef'

	// Enforce the invariant that every block in the module has committed to a
	// terminator (real op, dead, or fallthrough). Parser ops emit ops into
	// blocks starting with Terminator.unset — any block still in that state
	// after parsing is a bug in the parser, not a user error. Callers invoke
	// this on success paths only; error paths may legitimately leave blocks
	// unfinished (e.g. missing-return aborts emission).
	export function assertAllBlocksTerminated()
		for block in self.blocks 'eachBlock'
			block.assertTerminated()
		end 'eachBlock'
	end 'assertAllBlocksTerminated'

	// Merge all data from a source module into this module.
	// Adjusts block indices in functions and op indices in blocks to account
	// for the existing entries in the destination arrays. Block source info
	// entries are carried across 1:1 so coverage/debug metadata survives the
	// runtime-merge step.
	export function merge(source Self)
		let opOffset = self.ops.count()
		let blockOffset = self.blocks.count()

		self.ops.append(source.ops)

		for i in 0 upto source.blocks.count() 'eachBlock'
			let srcBlock = try source.blocks.get(i) otherwise panic("merge: blocks.get out of bounds")
			self.blocks.push(cloneIrBlock(srcBlock, opOffset: opOffset))
			let srcInfo = try source.blockSourceInfo.get(i) otherwise BlockSourceInfo.empty()
			self.blockSourceInfo.push(srcInfo)
		end 'eachBlock'

		for srcFunc in source.functions 'eachFunc'
			self.functions.push(self.cloneFunc(srcFunc, blockOffset: blockOffset))
		end 'eachFunc'
	end 'merge'
end 'IrModule'

// Clone a block, adjusting op indices by the given offset.
// Used by MergeableModule.merge to relocate blocks into a destination module.
function cloneIrBlock(src IrBlock, opOffset Count) returns IrBlock
	var block = IrBlock.create(src.id, label: src.label)
	block.blockArgs = src.blockArgs
	block.branchEdges = src.branchEdges
	for opIdx in src.opRefs 'eachOp'
		block.opRefs.append(opIdx + opOffset)
	end 'eachOp'
	block.terminator = match src.terminator 'relocate'
		unset gives Terminator.unset
		dead gives Terminator.dead
		fallthrough gives Terminator.fallthrough
		opIndex(index) gives Terminator.opIndex(index + opOffset)
	end 'relocate'
	return block
end 'cloneIrBlock'

export typealias MaxonModule = IrModule with MaxonOp

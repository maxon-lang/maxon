// Self-hosted Maxon compiler core.

// Compiles a file or directory and returns the output executable path.
export function compile(path String) returns String throws CompileError
    logDebug(LogCategory.compiler, message: "Starting compilation")
    var sources = SourceFileArray{}

    if File.exists(path) 'isFile'
        let bytes = try File.readBinary(path) otherwise 'readErr'
            throw CompileError.readError
        end 'readErr'

        sources.push({ path: path, content: bytes })
    end 'isFile' else if Directory.exists(path) 'isDir'
        let entries = try Directory.list(path) otherwise 'listErr'
            throw CompileError.directoryNotFound
        end 'listErr'

        for name in entries 'loop'
            if name.endsWith(".maxon") 'isMaxon'
                let filePath = "{path}\\{name}"
                let bytes = try File.readBinary(filePath) otherwise 'skip'
                    continue
                end 'skip'

                sources.push({ path: filePath, content: bytes })
            end 'isMaxon'
        end 'loop'
    end 'isDir' else 'notFound'
        throw CompileError.fileNotFound
    end 'notFound'

    if sources.count() == 0 'noFiles'
        throw CompileError.noSourceFiles
    end 'noFiles'

    logDebug(LogCategory.compiler, message: "Compiling {sources.count()} source files")
    var allOps = MaxonOpArray{}
    for source in sources 'compile'
        let tokens = tokenize(source.content)
        let ops = parse(tokens)
        allOps.append(ops)
    end 'compile'

    logDebug(LogCategory.mlir, message: "Starting MLIR pipeline")
    let stdOps = lowerMaxonOpsToStd(allOps)
    logDebug(LogCategory.mlir, message: "Lowered Maxon to Standard")

    let x86Ops = lowerStdOpsToX86(stdOps)
    logDebug(LogCategory.mlir, message: "Lowered Standard to X86")

    let codeResult = emit(x86Ops)

    let first = try sources.get(0) otherwise 'unreachable'
        throw CompileError.noSourceFiles
    end 'unreachable'

    let outputPath = changeExtension(first.path, ext: ".exe")
    writePe(outputPath, codeResult: codeResult)

    logInfo(LogCategory.compiler, message: "Wrote {codeResult.code.count()} bytes code to {outputPath}")
    return outputPath
end 'compile'

export enum CompileError implements Error
    fileNotFound
    directoryNotFound
    noSourceFiles
    readError
end 'CompileError'

type SourceFile
    export var path String
    export var content ByteArray
end 'SourceFile'

typealias SourceFileArray = Array with SourceFile

// Replaces the file extension (e.g. ".maxon" -> ".exe").
function changeExtension(path String, ext String) returns String
    let dotIdx = try path.findLast(".") otherwise path.endIndex()
    let base = path.slice(path.startIndex(), endIndex: dotIdx)
    return base.concat(ext)
end 'changeExtension'

// Recursive descent parser.
// Consumes tokens and emits Maxon ops into an MaxonModule with block-based CFG.
//
// ===== Helper contract =====
//
//   entry: cursor AT the opening token of the construct this helper parses
//          (e.g. `return`, `let`, `function`, `(`, or the first operand token).
//   exit:  cursor AT the LAST token the helper consumed. The caller — typically
//          a `for token in cursor` dispatch loop — advances past that last
//          token on the next iteration's header step.
//
// Corollary: helpers do NOT call `try cursor.advance()` or `expect()` on the token they
// want the caller to see as "last-consumed." The helper's final action is an
// `at(kind)` assertion (no advance), a recursive call to a helper that itself
// ends AT its last-consumed token, or a loop whose body leaves the cursor in
// the right place.
//
// ===== End-of-file semantics =====
//
// There is no `TokenKind.eof` sentinel. The cursor signals exhaustion by
// throwing `IterationError.exhausted` from `try cursor.advance()` / `peek(n)`. A
// `for token in cursor` loop terminates naturally when the cursor runs out.
//
// Unclosed constructs (missing `end`, `)`, `}`, truncated expression) are
// parse errors, not silent terminations. Helpers that expect a closing
// terminator check for it explicitly and report `unexpected end of input`
// with the opener's source range when the cursor exhausts before they find it.
//
// ===== Panics vs diagnostics =====
//
// The parser NEVER calls `panic()` on input-driven failures. Malformed or
// incomplete input produces a diagnostic (via `reportCompileError`) or a
// `ParserError` throw that the caller converts to one. Panics are reserved
// for internal-invariant failures — loop guards that just succeeded yet a
// subsequent `get()` failed, map `contains()` returning true yet `get()`
// failing, etc. Those are parser bugs, not user errors.

export typealias BoolArray = Array with bool

union ParamLookupError implements Error
	unknownName(name String)
end 'ParamLookupError'

typealias TokenIter = ArrayIterator with Token

// --- Standalone pure functions ---

// --- MaxonType predicates for parser use ---
// Named types are "unresolved" at parse time: whether they're struct/enum/
// typealias is a property of the registries maintained alongside the parse,
// so helpers consult Project to answer concrete questions.

function maxonTypeIsFloat(t MaxonType) returns bool
	return match t 'check'
		float gives true
		integer gives false
		boolean gives false
		named gives false
	end 'check'
end 'maxonTypeIsFloat'

// A named type is a "reference" (heap-allocated struct/enum/function) when
// the project knows about it in the corresponding registry. For named types
// that aren't yet registered (forward references across files), we
// conservatively return false; the TypeResolution pass catches truly-unknown
// names after all files have been parsed.
function maxonTypeIsRef(project Project, t MaxonType) returns bool
	let nameStr = maxonTypeName(project, ref: t)
	return not nameStr.isEmpty() and project.structTypes.contains(nameStr)
end 'maxonTypeIsRef'

// Return the underlying struct-type name for a named MaxonType, or "" when
// the type is not currently registered as a struct. Used by postfix-chain
// parsing to resolve `foo.field` / `foo.method()`.
function maxonTypeStructName(project Project, t MaxonType) returns String
	let nameStr = maxonTypeName(project, ref: t)
	if nameStr.isEmpty() 'noName'
		return ""
	end 'noName'
	if project.structTypes.contains(nameStr) 'isStruct'
		return nameStr
	end 'isStruct'
	return ""
end 'maxonTypeStructName'

// Create a block that is not added to the function's block list.
// Used as a sink for dead code after fully-terminated if/else branches.
// Terminator.dead marks it unreachable so later checks can distinguish
// it from a real block that simply has not had its terminator set yet.
function newDetachedBlock(func IrFunction) returns IrBlock
	let id = func.nextBlockId
	func.nextBlockId = func.nextBlockId + 1
	var block = IrBlock.create(id, label: "dead")
	block.terminator = Terminator.dead
	return block
end 'newDetachedBlock'

function tokenValueToString(value String) returns String
	if value.isEmpty() 'empty'
		return "(empty)"
	end 'empty'
	return value
end 'tokenValueToString'

// Qualify a function name with namespace: "ns.name".
// Returns the raw name if namespace is empty.
function qualifyName(ns String, name String) returns String
	if ns.isEmpty() 'noNs'
		return name
	end 'noNs'
	return "{ns}.{name}"
end 'qualifyName'

// --- Pratt parser binding power ---

typealias BindingPower = int(0 to 14)

// Throws for non-operator tokens; the call site uses `otherwise 0` to stop the Pratt loop.
function infixBindingPower(kind TokenKind) returns BindingPower throws ParserError
	return match kind 'bp'
		or gives 2
		xor gives 4
		and gives 6
		shl gives 8
		shr gives 8
		equalsEquals gives 10
		bangEquals gives 10
		is gives 10
		lessThan gives 10
		lessEquals gives 10
		greaterThan gives 10
		greaterEquals gives 10
		plus gives 12
		minus gives 12
		star gives 14
		slash gives 14
		mod gives 14
		default throws ParserError.unhandledToken
	end 'bp'
end 'infixBindingPower'

// --- Type bound parsing helpers ---

typealias BoundValue = int(i64.min to i64.max)

let typeBoundsTable = [
	"u8.min": 0, "u8.max": 255, "u16.min": 0, "u16.max": 65535, "u32.min": 0, "u32.max": 4294967295, "u64.min": 0, "u64.max": -1,
	"i8.min": -128, "i8.max": 127, "i16.min": -32768, "i16.max": 32767, "i32.min": -2147483648, "i32.max": 2147483647, "i64.min": -9223372036854775808, "i64.max": 9223372036854775807
]

function resolveTypeBound(typeName String, field String) returns BoundValue
	let key = "{typeName}.{field}"
	// Sentinel: 0 means "not a known type-qualified bound"; callers treat 0 as "fall through to literal parsing".
	return try typeBoundsTable.get(key) otherwise 0
end 'resolveTypeBound'

// Pick the narrowest StdType that can hold a typealias's range of values.
// Negative lower bounds fall through to signed i64 because signed narrow
// widths aren't yet used at the Std level.
function computeOptimalIntType(lower BoundValue, upper BoundValue) returns StdType
	if lower >= 0 'unsigned'
		if upper < 0 'wrappedU64'
			return StdType.u64
		end 'wrappedU64'
		if upper <= u8.max 'u8'
			return StdType.u8
		end 'u8'
		if upper <= u16.max 'u16'
			return StdType.u16
		end 'u16'
		if upper <= u32.max 'u32'
			return StdType.u32
		end 'u32'
		return StdType.u64
	end 'unsigned'
	return StdType.i64
end 'computeOptimalIntType'

// --- ExprResult enum ---

// Result of parsing an expression. The parser only ever tracks the
// source-level MaxonType on the value; int-vs-float dispatch and width
// selection happen in lowerMaxonToStd, not here.
//
// The `name` field carries a `ByteArray` — either a zero-copy slice over the
// lexer's source buffer (for a user-written variable) or a synthetic name
// (`$tN`) minted by the parser for an intermediate. SSA numbering is assigned
// only when the Maxon dialect is lowered to Std.
export union ExprResult
	// Computed value — already emitted as an op
	direct(name ByteArray, valueType MaxonType)
	// Compile-time string constant — for constant folding of == on strings
	stringConst(name ByteArray, value String)
end 'ExprResult'

// --- ExprResult helpers ---

function exprName(expr ExprResult) returns ByteArray
	return match expr 'getName'
		direct(name, _) gives name
		stringConst(name, _) gives name
	end 'getName'
end 'exprName'

function exprType(expr ExprResult) returns MaxonType
	return match expr 'getType'
		direct(_, valueType) gives valueType
		stringConst gives MaxonType.integer
	end 'getType'
end 'exprType'

function exprIsStringConst(expr ExprResult) returns bool
	return match expr 'check'
		stringConst gives true
		direct gives false
	end 'check'
end 'exprIsStringConst'


function exprStringConstValue(expr ExprResult) returns String
	return match expr 'getValue'
		stringConst(_, value) gives value
		direct gives ""
	end 'getValue'
end 'exprStringConstValue'

// --- Context stacks for loops and match ---

type LoopContext
	export var sourceLabel String
	export var headerBlockId BlockId
	export var exitBlockId BlockId

	export static function create(sourceLabel String, headerBlockId BlockId, exitBlockId BlockId) returns LoopContext
		return Self{sourceLabel: sourceLabel, headerBlockId: headerBlockId, exitBlockId: exitBlockId}
	end 'create'
end 'LoopContext'

typealias LoopContextArray = Array with LoopContext

type MatchContext
	export var sourceLabel String
	export var mergeBlockId BlockId

	export static function create(sourceLabel String, mergeBlockId BlockId) returns MatchContext
		return Self{sourceLabel: sourceLabel, mergeBlockId: mergeBlockId}
	end 'create'
end 'MatchContext'

typealias MatchContextArray = Array with MatchContext

// Tracks the source location of a parameter so CheckUnusedVariables can pin
// an E3012 error back to the declaration site rather than the function header.
type ParamLocation
	export let name String
	export let line ErrorLineNumber
	export let column ErrorColumnNumber

	export static function create(name String, line ErrorLineNumber, column ErrorColumnNumber) returns ParamLocation
		return Self{name: name, line: line, column: column}
	end 'create'
end 'ParamLocation'

typealias ParamLocationArray = Array with ParamLocation
typealias ReferencedVarSet = Set with String

// Optional Token wrapper returned by consumeArgLabel. Maxon has no built-in
// optional type, so a small struct with a presence flag keeps the call-site
// unwrap obvious (hasValue/token) without resorting to sentinel tokens.
type OptionalToken
	export let hasValue bool
	export let token Token

	export static function some(token Token) returns OptionalToken
		return Self{hasValue: true, token: token}
	end 'some'

	export static function empty() returns OptionalToken
		return Self{hasValue: false, token: Token.eof()}
	end 'empty'
end 'OptionalToken'

// --- Parser type ---

export type Parser
	var project Project
	// Original token array kept for absolute-index lookups (e.g. "previous
	// token"). The cursor drives consumption; this array stays fixed.
	var tokens TokenArray
	var cursor TokenIter
	var filePath FilePath
	// Module namespace supplied by the caller — used to qualify declarations
	// and resolve unqualified calls within this module.
	var namespace String
	// Current type name when parsing inside a type declaration (for Self resolution)
	var currentTypeName String
	var scope Scope
	// Context stacks for break/continue and match
	var loopStack LoopContextArray
	var matchStack MatchContextArray
	// Error counter for max-errors bail-out
	var errorCount ParsedInt
	// Set when an unexpected statement token aborts the enclosing function body,
	// mirroring the C# bootstrap compiler's throw-to-top-level recovery. Suppresses
	// cascading E3013 (missing-return) and out-of-place `end` consumption.
	var abortBody bool
	// Per-function unused-parameter tracking. paramLocations records each
	// parameter's declaration site; referencedVars records every name read by
	// identifier/assignment/dot-call paths in the body. Both are reset at the
	// top of parseFunctionLike and consulted by checkUnusedParameters.
	var paramLocations ParamLocationArray
	var referencedVars ReferencedVarSet
	// Per-function counter for minting synthetic intermediate names (`$t0`,
	// `$t1`, …). Reset to 0 at the top of each function parse. Each synthetic
	// name is the ASCII byte sequence of `$t` + the integer, wrapped in a
	// ByteArray so it flows as a zero-copy name slice through the Maxon IR.
	// SSA numbering at the Std level is assigned later (in LowerMaxonToStd).
	var synthNameCounter ParsedInt

	export static function create(project Project, tokens TokenArray, filePath FilePath, namespace String) returns Parser throws ParserError
		// Empty token array (empty or whitespace-only source) is a legitimate
		// input — caller must handle by throwing ParserError.unexpectedEof so
		// empty-file handling is explicit rather than a silent empty module.
		let cursor = try tokens.cursor() otherwise throw ParserError.unexpectedEof
		return Self{project: project, tokens: tokens, cursor: cursor, filePath: filePath, namespace: namespace, currentTypeName: "", scope: Scope.create(), loopStack: LoopContextArray.create(), matchStack: MatchContextArray.create(), errorCount: 0, abortBody: false, paramLocations: ParamLocationArray.create(), referencedVars: ReferencedVarSet.create(), synthNameCounter: 0}
	end 'create'

	// --- Token navigation helpers ---
	//
	// Navigation goes through the cursor (ArrayIterator<Token>). Core methods:
	//   cursor.current()       current token (next to consume)
	//   cursor.advance(n)      move forward by n (throws past end)
	//   cursor.peek(n)         lookahead by n (throws out of range)
	//   cursor.retreat(n)      step back (throws before start)
	//   cursor.index()         absolute position — save for backtracking
	//   cursor.seek(idx)       jump to saved position (throws out of range)
	//
	// Parser-specific helpers add kind-matching, error reporting, and common
	// loops on top. Navigation uses `cursor.current()` etc. directly at call
	// sites; only non-trivial wrappers (`consume`, `expect`, `skipNewlines`)
	// remain.

	// Return the current token and advance past it. If the consumed token was
	// the last in the stream, cursor stays at last-valid — consistent with
	// the exit-AT-last-consumed contract at helper boundaries.
	function consume() returns Token
		let token = cursor.current()
		try cursor.advance() otherwise return token
		return token
	end 'consume'

	// Verify the current token is `kind` and advance past it. If the matched
	// token is the last in the stream, silently stop (no error — the helper's
	// exit position AT the last token is a valid terminator under the flipped
	// contract). Wrong-kind reports parserExpectedToken.
	function expect(kind TokenKind)
		if cursor.current().kind == kind 'matched'
			try cursor.advance() otherwise return
			return
		end 'matched'
		let token = cursor.current()
		reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected {kind.name} but got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
	end 'expect'

	function skipNewlines()
		// Iterate until we land on a non-newline. The for-header's implicit
		// advance eats each newline; the body breaks on the first other kind,
		// leaving cursor AT that non-newline token.
		for token in cursor 'skip'
			if token.kind != TokenKind.newline 'notNewline'
				break
			end 'notNewline'
		end 'skip'
	end 'skipNewlines'

	function expectNewlineAfterLabel()
		if cursor.current().kind != TokenKind.newline 'noNewline'
			let token = cursor.current()
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected newline after block label, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		end 'noNewline'
		skipNewlines()
	end 'expectNewlineAfterLabel'

	// Parse an optional block label of the form `'label'` after control-flow
	// keywords like `if` or `while`. Returns the label string if present,
	// otherwise the provided default. Consumes the trailing newline in both cases.
	function parseOptionalBlockLabel(defaultLabel String) returns String throws ParserError
		if cursor.current().kind == TokenKind.stringLiteral 'hasLabel'
			let label = cursor.current().value
			try cursor.advance() otherwise 'eof'
				reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "unexpected end of input after block label '{label}'", line: cursor.current().line, column: cursor.current().column, filePath: filePath)
				throw ParserError.unexpectedEof
			end 'eof'
			expectNewlineAfterLabel()
			return label
		end 'hasLabel'
		skipNewlines()
		return defaultLabel
	end 'parseOptionalBlockLabel'

	// entry: cursor AT `end`.
	// exit:  cursor AT `end` (if no label) OR AT the label string literal.
	function skipEndAndLabel() throws ParserError
		// Assertion: caller should have placed cursor at `end`.
		if cursor.current().kind != TokenKind.end 'notEnd'
			let t = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected 'end' but got '{tokenValueToString(t.value)}'", line: t.line, column: t.column, filePath: filePath)
			return
		end 'notEnd'
		let nextTok = try cursor.peek(1) otherwise return
		if nextTok.kind == TokenKind.stringLiteral 'hasLabel'
			try cursor.advance() otherwise 'eof'
				reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "unexpected end of input after 'end'", line: cursor.current().line, column: cursor.current().column, filePath: filePath)
				throw ParserError.unexpectedEof
			end 'eof'
		end 'hasLabel'
	end 'skipEndAndLabel'

	function skipToNextLine()
		// Iterate until we land on a newline (or exhaust at EOF). Body breaks
		// the moment we see one, leaving cursor AT the newline.
		for token in cursor 'skip'
			if token.kind == TokenKind.newline 'atEnd'
				return
			end 'atEnd'
		end 'skip'
	end 'skipToNextLine'

	// Error recovery: skip to next statement boundary.
	// Always advances at least 1 token to prevent infinite loops. Swallows
	// exhaustion because we're already in an error-recovery state.
	function synchronize()
		try cursor.advance() otherwise return
		for token in cursor 'sync'
			if token.kind == TokenKind.end 'atBoundary'
				return
			end 'atBoundary'
			if token.kind == TokenKind.newline 'atNewline'
				// Leave cursor AT newline (new contract — the statement's
				// last-consumed token, from the parser's POV). The dispatch
				// loop's compensating advance past this will land on the next
				// statement's opener.
				return
			end 'atNewline'
		end 'sync'
	end 'synchronize'

	// Synchronize to the next top-level declaration after an error.
	function synchronizeToTopLevel()
		for token in cursor 'sync'
			if token.kind == TokenKind.function or token.kind == TokenKind.type or token.kind == TokenKind.union or token.kind == TokenKind.enum or token.kind == TokenKind.export or token.kind == TokenKind.let or token.kind == TokenKind.typealias 'atTopLevel'
				return
			end 'atTopLevel'
		end 'sync'
	end 'synchronizeToTopLevel'

	function tooManyErrors() returns bool
		return errorCount > 20
	end 'tooManyErrors'

	function trackError()
		errorCount = errorCount + 1
	end 'trackError'

	// --- Emission helpers ---

	// Mint a fresh synthetic intermediate name. Used for every op result that
	// doesn't directly correspond to a source-level variable (e.g. the result
	// of `a + b`). The `$t` prefix keeps these names disjoint from any
	// lexer-emitted identifier. Counter resets per function in resetSymbolTable.
	function freshSynthName() returns ByteArray
		let n = synthNameCounter
		synthNameCounter = synthNameCounter + 1
		return "$t{n}".toByteArray()
	end 'freshSynthName'

	// When the literal has an originating source token (int/float/bool
	// literal, type-bound constant like `u64.max`), callers pass its range
	// so hover/rename can map back to the source. Compiler-synthesized
	// literals (zero for implicit return, struct-byte-size, default arg
	// fallback) pass `SourceRange.none()` because they have no source origin.
	function emitLiteral(module MaxonModule, block IrBlock, value ParsedInt, valueType MaxonType, range SourceRange = SourceRange.none()) returns ByteArray
		let name = freshSynthName()
		module.appendOp(block, op: MaxonOp.literal(name, value: value, valueType: valueType, range: range))
		return name
	end 'emitLiteral'

	function emitImplicitReturn(module MaxonModule, block IrBlock)
		let zeroName = emitLiteral(module, block: block, value: 0, valueType: MaxonType.integer)
		module.setTerminator(block, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	end 'emitImplicitReturn'

	// Finalize an if/else by emitting the condBr and returning either a
	// detached block (both branches terminated) or a new merge block.
	// Uses captured block IDs to avoid stale references from nested parsing.
	// `mergeLine` is the source line for the synthetic merge block — typically
	// the line just past the if's closing `end`, i.e. where post-if statements
	// will land.
	function finalizeIfElseById(module MaxonModule, func IrFunction, condBlock IrBlock, condName ByteArray, thenBlockId BlockId, thenExit IrBlock, elseBlockId BlockId, elseExit IrBlock, baseLabel String, mergeLine LineNumber) returns IrBlock
		module.setTerminator(condBlock, op: MaxonOp.condBr(condName, thenTarget: thenBlockId, elseTarget: elseBlockId, range: SourceRange.none()))
		// isTerminated covers both real terminators and dead blocks, so
		// a branch whose arm ends in a fully-terminated nested if/else
		// contributes no live path to the merge.
		if thenExit.isTerminated() and elseExit.isTerminated() 'bothTerminated'
			return newDetachedBlock(func)
		end 'bothTerminated'
		let mergeBlock = module.addBlockAt(func, label: "{baseLabel}.merge", filePath: filePath.toString(), firstLine: mergeLine)
		branchIfNeeded(module, block: thenExit, target: mergeBlock.id)
		branchIfNeeded(module, block: elseExit, target: mergeBlock.id)
		return mergeBlock
	end 'finalizeIfElseById'

	function branchIfNeeded(module MaxonModule, block IrBlock, target BlockId)
		// Dead blocks are already terminated (unreachably), so isTerminated
		// is enough — leaving them without an op keeps them absent from the CFG.
		if not block.isTerminated() 'needsBranch'
			module.setTerminator(block, op: MaxonOp.br(target, range: SourceRange.none()))
		end 'needsBranch'
	end 'branchIfNeeded'

	// --- Symbol table helpers ---

	function resetSymbolTable()
		scope.reset()
		paramLocations = ParamLocationArray.create()
		referencedVars = ReferencedVarSet.create()
		synthNameCounter = 0
	end 'resetSymbolTable'

	// Emit E3012 for the first parameter whose name never appeared on a read
	// path in the body, matching the C# compiler's throw-on-first behavior.
	// Reporting every unused parameter would add noise that isn't in the spec.
	// `_` is the discard convention and is skipped. Local `var`/`let` bindings
	// are not yet tracked in self-hosted.
	function checkUnusedParameters()
		for param in paramLocations 'eachParam'
			if param.name == "_" 'isDiscard'
				continue
			end 'isDiscard'
			if not referencedVars.contains(param.name) 'unused'
				reportCompileError(project, code: ErrorCode.semanticUnusedVariable, message: "unused variable: '{param.name}'", line: param.line, column: param.column, filePath: filePath)
				return
			end 'unused'
		end 'eachParam'
	end 'checkUnusedParameters'

	function pushScope()
		scope.pushScope()
	end 'pushScope'

	function popScope()
		scope.popScope()
	end 'popScope'

	// Declare a variable carrying the given source-level MaxonType. Slot
	// width is NOT picked here — lowerMaxonToStd resolves MaxonType via the
	// typealias registry after TypeResolution has run.
	function defineVariableWithType(name String, varType MaxonType) returns VarSlot
		return scope.declare(name, varType: varType, mutable: true)
	end 'defineVariableWithType'

	function getVariableStructType(name String) returns String
		if not scope.contains(name) 'notFound'
			return ""
		end 'notFound'
		return maxonTypeStructName(project, t: scope.getType(name))
	end 'getVariableStructType'

	function lookupVariable(name String, token Token) returns VarSlot
		if let slot = try scope.lookup(name) 'found'
			referencedVars.insert(element: name)
			return slot
		end 'found'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Undefined variable '{tokenValueToString(name)}'", line: token.line, column: token.column, filePath: filePath)
		return 0
	end 'lookupVariable'

	function resolveConstant(module MaxonModule, block IrBlock, name String) returns ExprResult
		let constVal = try project.topLevelConstants.get(name) otherwise return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)

		// Exit AT the identifier token (new contract); don't advance past it.

		let isString = match constVal 'checkKind'
			stringValue gives true
			intValue gives false
		end 'checkKind'

		if isString 'str'
			let strVal = match constVal 'getStr'
				stringValue(v) gives v
				intValue gives ""
			end 'getStr'
			return ExprResult.stringConst(freshSynthName(), value: strVal)
		end 'str'

		let intVal = match constVal 'getInt'
			intValue(v) gives v
			stringValue gives 0
		end 'getInt'
		let constName = emitLiteral(module, block: block, value: intVal, valueType: MaxonType.integer)
		return ExprResult.direct(constName, valueType: MaxonType.integer)
	end 'resolveConstant'

	// --- Scoped statement parsing ---

	function parseScopedStatements(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		pushScope()
		var lastWasReturn = false
		let exitBlock = try parseStatements(module, func: func, block: block, lastWasReturn: lastWasReturn)
		popScope()
		return exitBlock
	end 'parseScopedStatements'

	// --- Top-level parsing ---

	export function parseModule() returns MaxonModule throws ParserError
		logDebug(LogCategory.parser, message: () gives "parser: module={filePath}")

		var module = MaxonModule.create()
		skipNewlines()

		// Dispatch-loop Pattern D: iterate over the cursor. Each helper exits
		// AT its last-consumed token; the for-header then advances onto the
		// next top-level opener (or the loop terminates on cursor exhaustion).
		for token in cursor 'parseLoop'
			if tooManyErrors() 'bail'
				break
			end 'bail'
			let prevPos = cursor.index()

			if token.kind == TokenKind.function 'isFunc'
				try parseFunctionLike(module, typeName: "", isInstance: false, fields: StructFieldArray.create())
			end 'isFunc' else if token.kind == TokenKind.type 'isType'
				try parseTypeDecl(module)
			end 'isType' else if token.kind == TokenKind.let 'isLet'
				try parseTopLevelLet()
			end 'isLet' else if token.kind == TokenKind.typealias 'isTypealias'
				try parseTopLevelTypealias()
			end 'isTypealias' else if token.kind == TokenKind.export 'isExport'
				try parseExport()
			end 'isExport' else if token.kind == TokenKind.newline 'isNewline'
				// Blank lines between decls — for-header will advance.
				continue
			end 'isNewline' else 'unexpectedTopLevel'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected function declaration, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
				return module
			end 'unexpectedTopLevel'

			if cursor.index() <= prevPos 'stuck'
				try cursor.seek(prevPos + 1) otherwise panic("Parser.parseModule: stuck-guard seek({prevPos + 1}) out of bounds")
			end 'stuck'

			// abortBody (from synchronizeToTopLevel) leaves cursor AT next
			// top-level opener. For-header's auto-advance would skip it, so
			// retreat to compensate.
			if abortBody 'aborted'
				abortBody = false
				// synchronizeToTopLevel either parked us AT a top-level opener
				// (function/type/etc) or ran to exhaustion. If at an opener,
				// retreat so for-header advances onto it for re-dispatch.
				// Otherwise, break out of the loop entirely.
				let curKind = cursor.current().kind
				let atTopLevel = curKind == TokenKind.function or curKind == TokenKind.type or curKind == TokenKind.union or curKind == TokenKind.enum or curKind == TokenKind.export or curKind == TokenKind.let or curKind == TokenKind.typealias
				if atTopLevel 'redispatch'
					try cursor.retreat() otherwise panic("Parser.parseModule: retreat from top-level re-dispatch position failed at index {cursor.index()}")
				end 'redispatch' else 'noMore'
					break
				end 'noMore'
			end 'aborted'
		end 'parseLoop'

		// Invariant: every block we emit must have committed to a terminator
		// (a real op, dead, or fallthrough). A lingering Terminator.unset
		// means the parser left a block in an intermediate state — a bug
		// that would otherwise surface as mysterious failures deep in the
		// pipeline. Skip the check on error paths: reported errors may
		// legitimately leave blocks unfinished (e.g. missing-return aborts
		// emission).
		if project.diagnostics.count() == 0 'validate'
			for block in module.blocks 'eachBlock'
				block.assertTerminated()
			end 'eachBlock'
		end 'validate'

		return module
	end 'parseModule'

	// --- Function parsing ---

	// Parse a parenthesized parameter list of the form `name Type, name Type, ...`
	// with optional default values `name Type = literal`.
	// Appends each parameter to the symbol table and to paramTypes, and updates
	// paramCount. Also fills paramNames and paramDefaults (parallel arrays) for
	// the call-site reordering pass. Caller is responsible for the leading `(`
	// and trailing `)`.
	function parseFunctionParameters(paramCount ParsedInt, paramTypes MaxonTypeArray, paramNames StringArray, paramDefaults ParamDefaultArray) throws ParserError
		if cursor.current().kind == TokenKind.rightParen 'noParams'
			return
		end 'noParams'
		while true 'paramLoop'
			let paramNameToken = consume()
			let paramTypeToken = consume()

			let paramMaxonType = internMaxonType(project, name: paramTypeToken.value)

			// Define the parameter as a variable so it's accessible in the body
			_ = defineVariableWithType(paramNameToken.value, varType: paramMaxonType)
			paramLocations.push(ParamLocation.create(paramNameToken.value, line: paramNameToken.line, column: paramNameToken.column))
			paramTypes.push(paramMaxonType)
			paramNames.push(paramNameToken.value)
			paramDefaults.push(try parseOptionalParamDefault())
			paramCount = paramCount + 1

			if cursor.current().kind == TokenKind.rightParen 'endParams'
				break
			end 'endParams'
		end 'paramLoop'
	end 'parseFunctionParameters'

	// Parse an optional `= <literal>` default value for a parameter. Only
	// integer literals (optionally prefixed with `-`) are supported — the C#
	// bootstrap captures tokens and re-evaluates arbitrary expressions, but the
	// self-hosted parser needs only the literal form the current specs use.
	function parseOptionalParamDefault() returns ParamDefault throws ParserError
		if cursor.current().kind != TokenKind.equals 'noDefault'
			return ParamDefault.none
		end 'noDefault'
		expect(TokenKind.equals)
		var negate = false
		if cursor.current().kind == TokenKind.minus 'negative'
			negate = true
			expect(TokenKind.minus)
		end 'negative'
		let litToken = consume()
		if litToken.kind != TokenKind.intLiteral 'notInt'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "parameter default value must be an integer literal", line: litToken.line, column: litToken.column, filePath: filePath)
			return ParamDefault.none
		end 'notInt'
		var value = try parseInt(litToken.value) otherwise 'overflow'
			reportLiteralOverflow(TokenKind.intLiteral, token: litToken, message: "Integer literal '{tokenValueToString(litToken.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ParamDefault.none
		end 'overflow'
		if negate 'applyNeg'
			value = 0 - value
		end 'applyNeg'
		return ParamDefault.intLiteral(value)
	end 'parseOptionalParamDefault'

	// Skip an optional `throws ErrorType` clause.
	function skipThrowsClause() throws ParserError
		if cursor.current().kind == TokenKind.throws 'hasThrows'
			expect(TokenKind.throws)
			expect(TokenKind.identifier)
		end 'hasThrows'
	end 'skipThrowsClause'

	// Parse an optional `returns Type` clause. Returns MaxonReturnType.void if
	// the clause is absent. When isMethod is true and the return type is
	// `Self`, resolves to the enclosing type (typeName). For plain functions,
	// `Self` is consumed via the normal identifier path.
	function parseOptionalReturnType(isMethod bool, typeName String) returns MaxonReturnType throws ParserError
		if cursor.current().kind != TokenKind.returns 'noReturns'
			return MaxonReturnType.void
		end 'noReturns'
		expect(TokenKind.returns)
		if isMethod 'methodReturns'
			let typeToken = cursor.current()
			if typeToken.kind == TokenKind.selfType 'isSelfReturn'
				try cursor.advance()
				return MaxonReturnType.value(internMaxonType(project, name: typeName))
			end 'isSelfReturn'
		end 'methodReturns'
		let typeToken = consume()
		return MaxonReturnType.value(internMaxonType(project, name: typeToken.value))
	end 'parseOptionalReturnType'

	// Unified parser for both free functions and methods (static or instance).
	// When typeName is empty, parses a free function. When typeName is non-empty,
	// parses a method on that type; isInstance controls whether an implicit
	// `__self` parameter and field-load prologue / writeback epilogue are added.
	function parseFunctionLike(module MaxonModule, typeName String, isInstance bool, fields StructFieldArray) throws ParserError
		let isMethod = not typeName.isEmpty()

		expect(TokenKind.function)
		resetSymbolTable()
		let nameToken = consume()

		// Derive the qualified name used for symbol registration and logging.
		var qualifiedName = ""
		if isMethod 'methodName'
			qualifiedName = "{typeName}.{nameToken.value}"
			logTrace(LogCategory.parser, message: () gives "parser: method '{qualifiedName}'")
		end 'methodName' else 'freeName'
			if nameToken.value == "main" 'isMain'
				qualifiedName = nameToken.value
			end 'isMain' else 'qualifyNonMain'
				qualifiedName = qualifyName(namespace, name: nameToken.value)
			end 'qualifyNonMain'
			logTrace(LogCategory.parser, message: () gives "parser: function '{nameToken.value}'")
		end 'freeName'

		expect(TokenKind.leftParen)

		var paramCount = 0
		var paramTypes = MaxonTypeArray.create()
		var paramNames = StringArray.create()
		var paramDefaults = ParamDefaultArray.create()

		// Instance methods get an implicit self pointer parameter, registered
		// before explicit parameters so the parameter order matches the
		// calling convention. Self is a named MaxonType matching the
		// enclosing type; lowerMaxonToStd resolves it to i64 (pointer width).
		if isInstance 'addSelfParam'
			_ = defineVariableWithType("__self", varType: internMaxonType(project, name: typeName))
			paramTypes.push(internMaxonType(project, name: typeName))
			paramNames.push("__self")
			paramDefaults.push(ParamDefault.none)
			paramCount = paramCount + 1
		end 'addSelfParam'

		try parseFunctionParameters(paramCount, paramTypes: paramTypes, paramNames: paramNames, paramDefaults: paramDefaults)
		expect(TokenKind.rightParen)

		let returnType_ = try parseOptionalReturnType(isMethod: isMethod, typeName: typeName)
		// Capture the void-ness up front so we can release the `returnType_`
		// borrow before calling into parseStatements (which mutates self.cursor).
		let returnIsVoid = maxonReturnTypeIsVoid(returnType_)

		try skipThrowsClause()

		skipNewlines()

		var func = IrFunction.create(qualifiedName, maxonReturnType: returnType_, paramCount: paramCount, maxonParamTypes: paramTypes, returnLine: 0)
		// Register return type so callers can determine result kind. Display
		// the bare name for free functions and the qualified name for methods
		// in duplicate diagnostics.
		try project.funcReturnTypes.insert(qualifiedName, value: returnType_) otherwise 'dupFunc'
			if isMethod 'methodDisplay'
				reportDuplicateFunction(qualifiedName, nameToken: nameToken)
			end 'methodDisplay' else 'freeDisplay'
				reportDuplicateFunction(nameToken.value, nameToken: nameToken)
			end 'freeDisplay'
		end 'dupFunc'
		// Register signature for call-site named-arg reordering and defaults.
		// If funcReturnTypes.insert already reported a duplicate, silently
		// ignore the duplicate signature too — we only need one entry.
		try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramDefaults: paramDefaults)) otherwise ignore
		var block = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: nameToken.line)

		// For instance methods, register each field as a self-field alias.
		// Reads/writes lower directly to fieldLoad/fieldStore through __self,
		// not to a local slot — so a nested call that mutates self.field sees
		// the new value on return (and the caller sees callee's mutations).
		if isInstance 'emitFieldAccess'
			for field in fields 'eachField'
				_ = scope.declareSelfField(field.name, varType: field.fieldType, offset: field.offset)
			end 'eachField'
		end 'emitFieldAccess'

		// Parse body
		var bodyReturns = false
		block = try parseStatements(module, func: func, block: block, lastWasReturn: bodyReturns)

		// Body aborted on an unexpected statement token — the parser has already
		// synchronized past this function. Suppress the missing-return cascade and
		// don't attempt to consume a closing `end`: it belongs to a top-level
		// construct that the outer loop will re-dispatch. The partial function
		// body is dropped: an error was already reported so no binary will be
		// produced, and registering it risks downstream passes tripping over
		// unterminated blocks.
		if abortBody 'aborted'
			// Keep abortBody=true so parseModule's compensating-advance logic
			// knows cursor is already parked at the next top-level opener.
			return
		end 'aborted'

		checkUnusedParameters()

		// Functions with a declared return type must terminate on every path —
		// report E3013 rather than silently falling through to an implicit 0.
		// Dead blocks are unreachable (isTerminated returns true) so they
		// trigger neither the implicit return nor the missing-return error.
		// Self-fields are aliased directly to __self so there is no writeback
		// phase: every field mutation already went through fieldStore.
		if not block.isTerminated() 'needsImplicitRet'
			if returnIsVoid 'emitVoid'
				emitImplicitReturn(module, block: block)
			end 'emitVoid' else 'reportMissing'
				reportCompileError(project, code: ErrorCode.semanticMissingReturn, message: "missing return statement: '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'reportMissing'
		end 'needsImplicitRet'

		// Hand the parser's per-function scope state off to the IrFunction so
		// it persists for downstream consumers. Today this is inspection-only;
		// later commits add the name-resolution query on top.
		func.scope = scope
		module.functions.push(func)

		// Skip 'end' and optional label string
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.
	end 'parseFunctionLike'

	// --- Statement parsing ---

	// Record a statement's starting line against the block it will append to.
	// Looks up the flat blockRef within the current function's block set and
	// delegates to recordBlockLine for the de-dup-against-last append. When
	// the block is a detached dead sink (not in func.blockRefs) the findBlockRef
	// lookup throws and we silently drop the record — unreachable statements
	// don't contribute to coverage.
	function recordStmtLine(module MaxonModule, func IrFunction, block IrBlock, line LineNumber)
		let blockRef = try module.findBlockRef(func, block: block) otherwise return
		recordBlockLine(module.blockSourceInfo, blockRef: blockRef, line: line)
	end 'recordStmtLine'

	// Parse statements until 'end' is reached. Returns the current block.
	// Sets lastWasReturn to true if the last statement was a return.
	function parseStatements(module MaxonModule, func IrFunction, block IrBlock, lastWasReturn bool) returns IrBlock throws ParserError
		lastWasReturn = false

		// Dispatch-loop Pattern D: iterate over the cursor. Each helper exits
		// AT its last-consumed token; the for-header advances onto the next
		// statement's opener (or `end`, or terminates on cursor exhaustion).
		for stmtToken in cursor 'body'
			let stmtPrevPos = cursor.index()
			if stmtToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if stmtToken.kind == TokenKind.newline 'isBlank'
				continue
			end 'isBlank'

			lastWasReturn = false

			recordStmtLine(module, func: func, block: block, line: stmtToken.line)

			if stmtToken.kind == TokenKind.return 'isReturn'
				if func.returnLine == 0 'noRetLine'
					func.returnLine = stmtToken.line
				end 'noRetLine'
				try parseReturnStatement(module, block: block)
				lastWasReturn = true
			end 'isReturn' else if stmtToken.kind == TokenKind.var or stmtToken.kind == TokenKind.let 'isVarDecl'
				try parseVarDecl(module, block: block)
			end 'isVarDecl' else if stmtToken.kind == TokenKind.print 'isPrint'
				try parsePrintStatement(module, block: block)
			end 'isPrint' else if stmtToken.kind == TokenKind.panic 'isPanic'
				try parsePanicStatement(module, block: block)
				lastWasReturn = true
			end 'isPanic' else if stmtToken.kind == TokenKind.if 'isIf'
				block = try parseIfStatement(module, func: func, block: block)
			end 'isIf' else if stmtToken.kind == TokenKind.while 'isWhile'
				block = try parseWhileStatement(module, func: func, block: block)
			end 'isWhile' else if stmtToken.kind == TokenKind.identifier 'isIdent'
				try parseIdentifierStatement(module, block: block)
			end 'isIdent' else 'unexpectedToken'
				reportUnexpectedToken()
			end 'unexpectedToken'

			// abortBody (from reportUnexpectedToken) means synchronizeToTopLevel
			// already parked cursor at next top-level opener; break so the
			// outer parseFunctionLike can re-dispatch it.
			if abortBody 'aborted'
				break
			end 'aborted'

			// Stuck-guard: if cursor didn't advance, force advance to prevent
			// infinite loops on malformed input.
			if cursor.index() <= stmtPrevPos 'stmtStuck'
				try cursor.seek(stmtPrevPos + 1) otherwise panic("Parser.parseStatements: stmt-stuck seek({stmtPrevPos + 1}) out of bounds")
			end 'stmtStuck'
		end 'body'

		return block
	end 'parseStatements'

	// --- Identifier statement dispatch ---

	// Dispatches an identifier at statement level: assignment, function call, or error.
	function parseIdentifierStatement(module MaxonModule, block IrBlock) throws ParserError
		let peekToken = try cursor.peek(1)
		if cursor.current().value == "_" and peekToken.kind == TokenKind.equals 'isDiscard'
			try parseDiscardAssignment(module, block: block)
			return
		end 'isDiscard' else if peekToken.kind == TokenKind.equals 'isAssign'
			try parseVarAssignment(module, block: block)
			return
		end 'isAssign' else if peekToken.kind == TokenKind.leftParen 'isCall'
			// Statement-level function call — parse as expression, discard result
			_ = try parseExpression(module, block: block)
			return
		end 'isCall' else if peekToken.kind == TokenKind.dot 'maybeDotCall'
			// Dot call: variable.method(args) or Type.staticMethod(args) or field access
			_ = try parseExpression(module, block: block)
			return
		end 'maybeDotCall'

		reportUnexpectedToken()
	end 'parseIdentifierStatement'

	// Reports an unexpected statement-level token and aborts the enclosing function
	// body. Mirrors the C# bootstrap's throw-to-top-level behavior: one error is
	// reported and recovery skips to the next top-level declaration. Continuing
	// inside the body would consume a stray `end 'label'` meant for an outer
	// construct and cascade into E3013 (missing return) at the real `end`.
	function reportUnexpectedToken()
		let stmtToken = cursor.current()
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token: '{tokenValueToString(stmtToken.value)}'", line: stmtToken.line, column: stmtToken.column, filePath: filePath)
		trackError()
		abortBody = true
		synchronizeToTopLevel()
	end 'reportUnexpectedToken'

	// Reports a duplicate top-level constant declaration at the given name token.
	function reportDuplicateConstant(nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateConstant'

	// Reports a duplicate function/method declaration. Callers pass the display
	// name separately because free functions use the bare name while methods
	// use the type-qualified name.
	function reportDuplicateFunction(displayName String, nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate function '{displayName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateFunction'

	// Reports a literal-overflow error at `token` with the fully-formatted
	// `message` and then consumes the literal token so parsing can continue
	// without cascading errors. Callers pass the pre-formatted message so each
	// site can keep its exact wording (int vs float, with/without range suffix).
	function reportLiteralOverflow(tokenKind TokenKind, token Token, message String)
		reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: message, line: token.line, column: token.column, filePath: filePath)
		expect(tokenKind)
	end 'reportLiteralOverflow'

	// --- Top-level let ---

	// Parse top-level `let NAME = <expr>` — stores as compile-time constant.
	// Supports string literals and constant integer expressions.
	function parseTopLevelLet() throws ParserError
		expect(TokenKind.let)

		let nameToken = consume()

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			synchronize()
			return
		end 'notEquals'

		expect(TokenKind.equals)
		let valueToken = cursor.current()
		if valueToken.kind == TokenKind.doubleStringLiteral 'isString'
			expect(TokenKind.doubleStringLiteral)
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(valueToken.value)) otherwise 'dupConst1'
				reportDuplicateConstant(nameToken)
			end 'dupConst1'
			logTrace(LogCategory.parser, message: () gives "parser: const string '{nameToken.value}'")
			return
		end 'isString'

		// Single-quote strings are not valid top-level constants
		if valueToken.kind == TokenKind.stringLiteral 'isSingleQuoteString'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected constant expression, got '{valueToken.value}'", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'isSingleQuoteString'

		// Try to evaluate a compile-time integer constant expression
		let constValue = try evalConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Top-level let only supports string literals and constant integer expressions", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.intValue(constValue)) otherwise 'dupConst2'
			reportDuplicateConstant(nameToken)
		end 'dupConst2'
		logTrace(LogCategory.parser, message: () gives "parser: const int '{nameToken.value}' = {constValue}")
	end 'parseTopLevelLet'

	// Evaluate a compile-time integer constant expression.
	// Supports: integer literals, hex literals, `not <expr>`, `-<expr>`.
	function evalConstExpr() returns ParsedInt throws ParserError
		let token = cursor.current()

		if token.kind == TokenKind.not 'isNot'
			expect(TokenKind.not)
			return not try evalConstExpr()
		end 'isNot'

		if token.kind == TokenKind.minus 'isNeg'
			expect(TokenKind.minus)
			return 0 - try evalConstExpr()
		end 'isNeg'

		if token.kind == TokenKind.intLiteral 'isInt'
			let intVal = try parseInt(token.value)
			expect(TokenKind.intLiteral)
			return intVal
		end 'isInt'

		throw ParserError.unhandledToken
	end 'evalConstExpr'

	// --- Export dispatch ---

	// entry: cursor AT `export`.
	// exit:  for function/type re-dispatch, leaves cursor AT `function`/`type`
	//        so main loop re-dispatches. for typealias, after typealias body.
	function parseExport() throws ParserError
		try cursor.advance()  // past 'export'

		if cursor.current().kind == TokenKind.function 'isExportFunc'
			return
		end 'isExportFunc' else if cursor.current().kind == TokenKind.typealias 'isExportTypealias'
			try parseTopLevelTypealias()
		end 'isExportTypealias' else if cursor.current().kind == TokenKind.type 'isExportType'
			return
		end 'isExportType' else 'isExportOther'
			skipToNextLine()
		end 'isExportOther'
	end 'parseExport'

	// --- Typealias parsing ---

	// Parse: typealias Name = int(LOWER to UPPER) | float(LOWER to UPPER) | bool | ...
	// Registers primitive-backed typealiases in the project's type registry.
	// Computes optimal IR type from the range bounds (e.g. int(0 to u32.max) → u32).
	function parseTopLevelTypealias() throws ParserError
		expect(TokenKind.typealias)
		let nameToken = consume()

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'noEquals'
			skipToNextLine()
			return
		end 'noEquals'
		expect(TokenKind.equals)

		let baseToken = cursor.current()

		var resolvedStdType = StdType.i64
		var sawValidBase = false

		if baseToken.kind == TokenKind.bool 'isBool'
			// bool typealiases map to i1 at the Std level.
			resolvedStdType = StdType.i1
			sawValidBase = true
		end 'isBool'

		if baseToken.kind == TokenKind.int or baseToken.kind == TokenKind.float or baseToken.kind == TokenKind.byte 'isNumeric'
			let isFloat = baseToken.kind == TokenKind.float
			let isByte = baseToken.kind == TokenKind.byte
			try cursor.advance()  // skip 'int', 'float', or 'byte'

			let parenToken = cursor.current()
			if parenToken.kind != TokenKind.leftParen 'noParen'
				var example = "int(0 to 100)"
				if isFloat 'floatEx'
					example = "float(f64.min to f64.max)"
				end 'floatEx' else if isByte 'byteEx'
					example = "byte(0 to u8.max)"
				end 'byteEx'
				reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "typealias '{nameToken.value}' requires range bounds, e.g. {example}", line: baseToken.line, column: baseToken.column, filePath: filePath)
				skipToNextLine()
				return
			end 'noParen'
			expect(TokenKind.leftParen)

			let lowerBound = try parseTypeBound()
			try cursor.advance()  // past last-consumed of lowerBound

			if cursor.current().kind == TokenKind.to 'hasTo'
				try cursor.advance()  // past `to` onto upperBound's first token
			end 'hasTo'

			let upperBound = try parseTypeBound()

			if isFloat 'computeFloat'
				resolvedStdType = StdType.f64
			end 'computeFloat' else 'computeInt'
				// `byte(lo to hi)` is just an unsigned integer alias; let
				// computeOptimalIntType pick the narrowest width (u8 for 0..255).
				resolvedStdType = computeOptimalIntType(lower: lowerBound, upper: upperBound)
				try project.typealiasRanges.insert(nameToken.value, value: TypealiasRange.create(lowerBound, upper: upperBound)) otherwise ignore
			end 'computeInt'
			sawValidBase = true
		end 'isNumeric'

		if not sawValidBase 'unsupported'
			skipToNextLine()
			return
		end 'unsupported'

		try project.typealiases.insert(nameToken.value, value: resolvedStdType) otherwise 'dupAlias'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate typealias '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupAlias'
		skipToNextLine()
	end 'parseTopLevelTypealias'

	// --- Type declaration parsing ---

	// Parse: type Name ... end 'Name'
	// Collects fields, registers the struct type, and parses methods as qualified functions.
	function parseTypeDecl(module MaxonModule) throws ParserError
		expect(TokenKind.type)
		let typeNameToken = consume()
		let typeName = typeNameToken.value
		currentTypeName = typeName
		logTrace(LogCategory.parser, message: () gives "parser: type '{typeName}'")
		skipNewlines()

		// First pass: collect fields, skip over method bodies
		var fields = StructFieldArray.create()
		var fieldOffset = 0 as FieldOffset
		let savedPos = cursor.index()

		while true 'scanFields'
			let memberToken = cursor.current()
			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if memberToken.kind == TokenKind.export 'skipExport'
				try cursor.advance()
			end 'skipExport'
			let kindToken = cursor.current()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'isField'
				try cursor.advance()
				let fieldNameToken = consume()
				let fieldTypeToken = consume()
				fields.push(StructField.create(fieldNameToken.value, fieldType: internMaxonType(project, name: fieldTypeToken.value), offset: fieldOffset))
				fieldOffset = fieldOffset + 8
				skipNewlines()
			end 'isField' else if kindToken.kind == TokenKind.static or kindToken.kind == TokenKind.function 'skipMethod'
				// Skip the entire method body including its 'end' token
				skipToNextLine()
				skipNewlines()
				try skipMethodBody()
				skipNewlines()
			end 'skipMethod' else 'skipOther'
				skipToNextLine()
				skipNewlines()
			end 'skipOther'
		end 'scanFields'

		// Register the struct type before parsing method bodies (needed for Self{...} resolution)
		let structType = StructType.create(typeName, fields: fields, byteSize: fieldOffset)
		try project.structTypes.insert(typeName, value: structType) otherwise 'dupType'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate type '{typeName}'", line: typeNameToken.line, column: typeNameToken.column, filePath: filePath)
		end 'dupType'

		// Second pass: parse methods (rewind to saved position)
		try cursor.seek(savedPos) otherwise panic("Parser.parseTypeDecl: rewind seek({savedPos}) out of bounds")
		while true 'typeBody'
			let memberToken = cursor.current()
			let typeBodyPrevPos = cursor.index()
			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if memberToken.kind == TokenKind.export 'skipExport2'
				try cursor.advance()
			end 'skipExport2'
			let kindToken = cursor.current()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'skipField'
				skipToNextLine()
				skipNewlines()
			end 'skipField' else if kindToken.kind == TokenKind.static 'isStatic'
				try cursor.advance()
				if cursor.current().kind == TokenKind.function 'isStaticFunc'
					try parseFunctionLike(module, typeName: typeName, isInstance: false, fields: fields)
				end 'isStaticFunc' else 'notFunc'
					skipToNextLine()
				end 'notFunc'
				skipNewlines()
			end 'isStatic' else if kindToken.kind == TokenKind.function 'isMethod'
				try parseFunctionLike(module, typeName: typeName, isInstance: true, fields: fields)
				skipNewlines()
			end 'isMethod' else 'skipMember'
				skipToNextLine()
				skipNewlines()
			end 'skipMember'
			// Guard against an inner parse that failed to advance pos. Without
			// this, a bad method declaration can leave the loop stuck at the
			// same token forever — a non-terminating compile is the worst
			// possible failure mode for the spec-test runner, which has no
			// in-process timeout on compilation.
			if cursor.index() <= typeBodyPrevPos 'stuck'
				try cursor.seek(typeBodyPrevPos + 1) otherwise panic("Parser.parseTypeDecl: typeBody-stuck seek({typeBodyPrevPos + 1}) out of bounds")
			end 'stuck'
		end 'typeBody'

		currentTypeName = ""
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.
	end 'parseTypeDecl'

	// Write modified field values back to the struct pointer before returning.
	function emitFieldWritebacks(module MaxonModule, block IrBlock, nameToken Token, fields StructFieldArray)
		let selfSlot = lookupVariable("__self", token: nameToken)
		let selfLoadName = freshSynthName()
		module.appendOp(block, op: MaxonOp.varLoad(selfLoadName, slotId: selfSlot, slotType: internMaxonType(project, name: currentTypeName), range: SourceRange.none()))

		for field in fields 'eachField'
			if let fieldSlot = try scope.lookup(field.name) 'hasField'
				let fieldValName = freshSynthName()
				module.appendOp(block, op: MaxonOp.varLoad(fieldValName, slotId: fieldSlot, slotType: field.fieldType, range: SourceRange.none()))
				module.appendOp(block, op: MaxonOp.fieldStore(selfLoadName, offset: field.offset, value: fieldValName, range: SourceRange.none()))
			end 'hasField'
		end 'eachField'
	end 'emitFieldWritebacks'

	// Skip over a method body in the first pass of type parsing.
	// Scans token-by-token counting nested block-opening keywords (if/while/
	// for/match/else) to find the matching `end` for this method. For-loop
	// header advances each iteration; body updates depth and breaks when the
	// method's own `end` is reached so try skipEndAndLabel() can consume it.
	function skipMethodBody() throws ParserError
		var depth = 1
		for token in cursor 'skip'
			if token.kind == TokenKind.end 'isEnd'
				depth = depth - 1
				if depth == 0 'atMethodEnd'
					try skipEndAndLabel()
					return
				end 'atMethodEnd'
			end 'isEnd' else if token.kind == TokenKind.if or token.kind == TokenKind.while or token.kind == TokenKind.for or token.kind == TokenKind.match or token.kind == TokenKind.else 'opensBlock'
				depth = depth + 1
			end 'opensBlock'
		end 'skip'
	end 'skipMethodBody'

	// Parse a type bound: a number literal, negative literal, or T.min/T.max.
	// Mutates pos and returns just BoundValue.
	// entry: cursor AT first token of the bound (minus, intLit, or identifier).
	// exit:  cursor AT last-consumed token of the bound.
	function parseTypeBound() returns BoundValue throws ParserError
		let token = cursor.current()

		if token.kind == TokenKind.minus 'isNeg'
			let numToken = try cursor.peek(1)
			let value = try parseInt(numToken.value) otherwise 'negOverflow'
				reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(numToken.value)}' is outside the range of int", line: numToken.line, column: numToken.column, filePath: filePath)
				try cursor.advance()  // onto intLit
				return 0
			end 'negOverflow'
			try cursor.advance()  // onto intLit
			return 0 - value
		end 'isNeg'

		if token.kind == TokenKind.intLiteral 'isLit'
			let value = try parseInt(token.value) otherwise 'litOverflow'
				reportLiteralOverflow(TokenKind.intLiteral, token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int")
				return 0
			end 'litOverflow'
			return value
		end 'isLit'

		let afterIdent = try cursor.peek(1)
		if token.kind == TokenKind.identifier and afterIdent.kind == TokenKind.dot 'maybeTypeBound'
			let fieldToken = try cursor.peek(2)
			if fieldToken.kind == TokenKind.identifier 'hasField'
				let bound = resolveTypeBound(token.value, field: fieldToken.value)
				try cursor.advance()  // past ident onto '.'
				try cursor.advance()  // past '.' onto fieldIdent
				return bound
			end 'hasField'
		end 'maybeTypeBound'

		return 0
	end 'parseTypeBound'

	// --- Return statement ---

	// entry: cursor AT `return`.
	// exit:  cursor AT last-consumed token (`return` for void-return; last
	//        token of the return expression otherwise).
	function parseReturnStatement(module MaxonModule, block IrBlock) throws ParserError
		let returnToken = cursor.current()
		let nextTok = try cursor.peek(1) otherwise 'noNext'
			emitImplicitReturn(module, block: block)
			return
		end 'noNext'
		if nextTok.kind == TokenKind.newline or nextTok.kind == TokenKind.end 'bareReturn'
			emitImplicitReturn(module, block: block)
			return
		end 'bareReturn'

		try cursor.advance()  // past `return` onto expr first token
		let resultExpr = try parseExpression(module, block: block)
		let lastExprToken = cursor.current()
		module.setTerminator(block, op: MaxonOp.ret(exprName(resultExpr), range: SourceRange.between(returnToken, last: lastExprToken)))
	end 'parseReturnStatement'

	// Emits MaxonOp.panic with a location-prefixed message for the stack trace.
	// entry: cursor AT `panic`.
	// exit:  cursor AT `)`.
	function parsePanicStatement(module MaxonModule, block IrBlock) throws ParserError
		let panicToken = cursor.current()
		try cursor.advance()  // past 'panic' onto '('
		try cursor.advance()  // past '(' onto msg
		let msgToken = cursor.current()
		try cursor.advance()  // past msg onto ')'
		let rparenToken = cursor.current()

		let fileName = filePath.filename()
		let fullMsg = "panic at {fileName}:{panicToken.line}: {msgToken.value}"
		module.appendOp(block, op: MaxonOp.panic(fullMsg, range: SourceRange.between(panicToken, last: rparenToken)))
	end 'parsePanicStatement'

	// --- If statement ---

	// Parse: if <condition> 'label' ... end 'label' [else 'label' ... end 'label']
	// Returns the merge block to continue emitting into.
	// entry: cursor AT `if`.
	// exit:  cursor AT last-consumed (the final `end` or label).
	function parseIfStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let ifToken = cursor.current()
		try cursor.advance()  // past `if` onto condition

		// Parse condition expression
		let condResult = try parseExpression(module, block: block)
		// parseExpression exits AT last-consumed of condition.
		try cursor.advance()  // past condition onto optional label OR newline

		let userLabel = try parseOptionalBlockLabel("if")
		// parseOptionalBlockLabel consumes through newlines (old contract); leaves
		// cursor at first token of the body.

		let ifFilePath = filePath.toString()
		var thenBlock = module.addBlockAt(func, label: userLabel, filePath: ifFilePath, firstLine: ifToken.line)
		let thenBlockId = thenBlock.id
		let baseLabel = "{userLabel}_{thenBlockId}"
		thenBlock.label = baseLabel

		let thenExit = try parseScopedStatements(module, func: func, block: thenBlock)
		// parseScopedStatements exits with cursor AT `end` (the body's terminator).

		try skipEndAndLabel()
		// cursor now AT `end` or label. Advance past into whitespace.
		try cursor.advance()
		skipNewlines()

		if cursor.current().kind == TokenKind.else 'hasElse'
			let elseToken = cursor.current()
			try cursor.advance()  // past `else`

			var elseLabel = "{baseLabel}.else"

			if cursor.current().kind == TokenKind.if 'isElseIf'
				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				let elseBlockId = elseBlock.id
				// Recursive call: exits AT final `end`/label of the nested if.
				let elseIfExit = try parseIfStatement(module, func: func, block: elseBlock)
				return finalizeIfElseById(module, func: func, condBlock: block, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseIfExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'isElseIf' else 'plainElse'
				if cursor.current().kind == TokenKind.stringLiteral 'hasElseLabel'
					elseLabel = "{cursor.current().value}_{func.nextBlockId}"
					try cursor.advance()
					expectNewlineAfterLabel()
				end 'hasElseLabel' else 'noElseLabel'
					skipNewlines()
				end 'noElseLabel'

				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				let elseBlockId = elseBlock.id
				let elseExit = try parseScopedStatements(module, func: func, block: elseBlock)
				try skipEndAndLabel()
				// cursor AT final `end` / label — exit AT last-consumed.
				return finalizeIfElseById(module, func: func, condBlock: block, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'plainElse'
		end 'hasElse'

		// No else clause. Above we advanced past the then-block's end/label and
		// ran skipNewlines to see if an `else` followed. Since there wasn't
		// one, we've already moved past last-consumed; retreat so exit is AT
		// last-consumed.
		try cursor.retreat() otherwise panic("Parser.parseIfStatement: retreat from post-then-block position failed at index {cursor.index()}")
		let afterBlock = module.addBlockAt(func, label: "{baseLabel}.after", filePath: ifFilePath, firstLine: cursor.current().line)
		branchIfNeeded(module, block: thenExit, target: afterBlock.id)
		module.setTerminator(block, op: MaxonOp.condBr(exprName(condResult), thenTarget: thenBlockId, elseTarget: afterBlock.id, range: SourceRange.none()))
		return afterBlock
	end 'parseIfStatement'

	// --- While statement ---

	// Parse: while <condition> 'label' ... end 'label'
	// Returns the exit block to continue emitting into.
	// entry: cursor AT `while`.
	// exit:  cursor AT the final `end` token (or its label).
	function parseWhileStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let whileToken = cursor.current()
		try cursor.advance()  // past `while` onto condition

		// Create cond block first (we need it to parse the condition into).
		// All three loop blocks (header, body, exit) open at the `while` token —
		// coverage-wise the whole construct is one statement, and the exit block
		// is reached right after the condition fails at that same line.
		let whileFilePath = filePath.toString()
		var condBlock = module.addBlockAt(func, label: "cond", filePath: whileFilePath, firstLine: whileToken.line)
		let condBlockId = condBlock.id

		// Branch from entry block to cond block
		module.setTerminator(block, op: MaxonOp.br(condBlockId, range: SourceRange.none()))

		// Parse condition in condBlock
		let condResult = try parseExpression(module, block: condBlock)
		try cursor.advance()  // past last-consumed of condition

		// Read the user's block label and derive unique labels
		let userLabel = try parseOptionalBlockLabel("loop")

		// Derive base label: userLabel_<blockId>
		let baseLabel = "{userLabel}_{condBlockId}"

		// Rename condBlock to baseLabel.header
		condBlock.label = "{baseLabel}.header"

		// Create body and exit blocks with derived labels
		var bodyBlock = module.addBlockAt(func, label: baseLabel, filePath: whileFilePath, firstLine: whileToken.line)
		let bodyBlockId = bodyBlock.id
		let exitBlock = module.addBlockAt(func, label: "{baseLabel}.exit", filePath: whileFilePath, firstLine: whileToken.line)
		let exitBlockId = exitBlock.id

		// condBlock terminator: if true -> bodyBlock, if false -> exitBlock
		module.setTerminator(condBlock, op: MaxonOp.condBr(exprName(condResult), thenTarget: bodyBlockId, elseTarget: exitBlockId, range: SourceRange.none()))

		// Push loop context for break/continue
		loopStack.push(LoopContext.create(userLabel, headerBlockId: condBlockId, exitBlockId: exitBlockId))

		// Parse body in bodyBlock
		let bodyExit = try parseScopedStatements(module, func: func, block: bodyBlock)

		// Pop loop context
		try loopStack.pop() otherwise ignore

		// Loop back to cond block if body doesn't terminate
		branchIfNeeded(module, block: bodyExit, target: condBlockId)

		// Skip 'end' and optional label string
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.

		return exitBlock
	end 'parseWhileStatement'

	// --- Discard assignment ---

	// Parse: _ = expression (discard function result)
	// Uses parserNextSlot as a unique suffix since it increments with each variable
	// entry: cursor AT `_`.
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseDiscardAssignment(module MaxonModule, block IrBlock) throws ParserError
		try cursor.advance()  // past '_' onto '='
		try cursor.advance()  // past '=' onto RHS first token
		let exprResult = try parseExpression(module, block: block)
		let discardName = "__discard_{scope.nextSlot}"
		let slot = defineVariableWithType(discardName, varType: exprType(exprResult))
		module.appendOp(block, op: MaxonOp.varDecl(slot, value: exprName(exprResult), slotType: exprType(exprResult), range: SourceRange.none()))
	end 'parseDiscardAssignment'

	// --- Variable assignment ---

	// Parse: identifier = expression (variable reassignment)
	// entry: cursor AT the identifier (LHS).
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseVarAssignment(module MaxonModule, block IrBlock) throws ParserError
		let nameToken = cursor.current()
		try cursor.advance()  // past name onto '='
		try cursor.advance()  // past '=' onto RHS
		let exprResult = try parseExpression(module, block: block)
		let lastExprToken = cursor.current()
		let stmtRange = SourceRange.between(nameToken, last: lastExprToken)
		let slot = lookupVariable(nameToken.value, token: nameToken)
		if scope.isSelfField(nameToken.value) 'selfFieldWrite'
			let info = scope.getInfo(nameToken.value)
			let selfSlot = lookupVariable("__self", token: nameToken)
			let selfLoadName = freshSynthName()
			// Implicit self-load and field-store share the statement's range —
			// the user wrote `field = value`, not a separate self-load op.
			module.appendOp(block, op: MaxonOp.varLoad(selfLoadName, slotId: selfSlot, slotType: internMaxonType(project, name: currentTypeName), range: stmtRange))
			module.appendOp(block, op: MaxonOp.fieldStore(selfLoadName, offset: info.fieldOffset, value: exprName(exprResult), range: stmtRange))
		end 'selfFieldWrite' else 'localWrite'
			module.appendOp(block, op: MaxonOp.varStore(slot, value: exprName(exprResult), range: stmtRange))
		end 'localWrite'
	end 'parseVarAssignment'

	// --- Variable declaration ---

	// entry: cursor AT `var` or `let`.
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseVarDecl(module MaxonModule, block IrBlock) throws ParserError
		let kwToken = cursor.current()
		let isLet = kwToken.kind == TokenKind.let
		try cursor.advance()  // past 'var'/'let' onto name

		let nameToken = cursor.current()
		try cursor.advance()  // past name onto '=' (or next)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			let tokStr = tokenValueToString(equalsToken.value)
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokStr}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			_ = defineVariableWithType(nameToken.value, varType: MaxonType.integer)
			synchronize()
			return
		end 'notEquals'

		try cursor.advance()  // past '=' onto RHS first token
		let exprResult = try parseExpression(module, block: block)

		if isLet and exprIsStringConst(exprResult) 'registerStringConst'
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(exprStringConstValue(exprResult))) otherwise 'dupConst3'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'dupConst3'
			_ = defineVariableWithType(nameToken.value, varType: exprType(exprResult))
			return
		end 'registerStringConst'

		let lastExprToken = cursor.current()
		let slot = defineVariableWithType(nameToken.value, varType: exprType(exprResult))
		module.appendOp(block, op: MaxonOp.varDecl(slot, value: exprName(exprResult), slotType: exprType(exprResult), range: SourceRange.between(kwToken, last: lastExprToken)))
	end 'parseVarDecl'

	// --- Print statement ---

	// entry: cursor AT `print`.
	// exit:  cursor AT `)`.
	function parsePrintStatement(module MaxonModule, block IrBlock) throws ParserError
		try cursor.advance()  // past 'print' onto '('
		try cursor.advance()  // past '(' onto string
		let strToken = cursor.current()
		try cursor.advance()  // past string onto ')'
		try parseStringInterpolation(module, block: block, str: strToken.value)
	end 'parsePrintStatement'

	// --- String Interpolation ---

	function parseStringInterpolation(module MaxonModule, block IrBlock, str String) throws ParserError
		let strBytes = str.toByteArray()
		var buf = ByteArray.create()
		var i = 0
		let len = strBytes.count()

		while i < len 'scan'
			let ch = try strBytes.get(i) otherwise panic("parseStringInterpolation: loop guard i < len just succeeded but strBytes.get({i}) failed (len={len})")

			// Escape sequences
			if ch == '\\' 'backslash'
				if i + 1 < len 'hasNext'
					let next = try strBytes.get(i + 1) otherwise panic("parseStringInterpolation: i + 1 < len just succeeded but strBytes.get({i + 1}) failed (len={len})")
					if next == 'n' 'escN'
						buf.push(10)
						i = i + 2
						continue
					end 'escN'
					if next == 't' 'escT'
						buf.push(9)
						i = i + 2
						continue
					end 'escT'
					if next == '\\' 'escBS'
						buf.push(92)
						i = i + 2
						continue
					end 'escBS'
					if next == '"' 'escDQ'
						buf.push(34)
						i = i + 2
						continue
					end 'escDQ'
				end 'hasNext'
				buf.push(ch)
				i = i + 1
				continue
			end 'backslash'

			// Interpolation: { ... }
			if ch == '{' 'openBrace'
				// Flush literal buffer
				if not buf.isEmpty() 'flushBuf'
					module.appendOp(block, op: MaxonOp.printLiteral(String.from(buf), range: SourceRange.none()))
					buf = ByteArray.create()
				end 'flushBuf'

				// Extract expression between braces
				i = i + 1
				let exprStart = i
				var braceDepth = 1

				while i < len and braceDepth > 0 'findClose'
					let bc = try strBytes.get(i) otherwise panic("parseStringInterpolation: loop guard i < len just succeeded but strBytes.get({i}) failed (len={len})")
					if bc == '{' 'nested'
						braceDepth = braceDepth + 1
					end 'nested'
					if bc == '}' 'close'
						braceDepth = braceDepth - 1
					end 'close'
					if braceDepth > 0 'notDone'
						i = i + 1
					end 'notDone'
				end 'findClose'

				// Tokenize and parse the expression between braces using a sub-parser
				let exprStr = String.from(strBytes.slice(exprStart, endIndex: i))
				let exprTokens = tokenize(exprStr)
				var subParser = try Parser.create(project, tokens: exprTokens, filePath: filePath, namespace: namespace)
				subParser.scope = scope
				let exprResult = try subParser.parseExpression(module, block: block)
				module.appendOp(block, op: MaxonOp.printInt(exprName(exprResult), range: SourceRange.none()))

				i = i + 1  // skip closing brace
				continue
			end 'openBrace'

			buf.push(ch)
			i = i + 1
		end 'scan'

		// Flush remaining literal buffer
		if not buf.isEmpty() 'flushRemaining'
			module.appendOp(block, op: MaxonOp.printLiteral(String.from(buf), range: SourceRange.none()))
		end 'flushRemaining'
	end 'parseStringInterpolation'

	// --- Expression Parsing ---

	// Pratt expression parser: single loop handles all binary precedence levels.
	function parseExpression(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		return try parseExpressionBP(module, block: block, minBP: 0)
	end 'parseExpression'

	// entry: cursor AT first operand's first token.
	// exit:  cursor AT last-consumed token of the rightmost accepted operand.
	function parseExpressionBP(module MaxonModule, block IrBlock, minBP BindingPower) returns ExprResult throws ParserError
		var left = try parseUnary(module, block: block)
		// left leaves cursor AT last-consumed of unary.

		while true 'prattLoop'
			// Peek ahead for a candidate operator token. cursor is AT last-
			// consumed of the previous operand.
			let opCandidate = try cursor.peek(1) otherwise break
			let bp = try infixBindingPower(opCandidate.kind) otherwise 0
			if bp == 0 'notOp'
				break
			end 'notOp'
			if bp <= minBP 'tooLow'
				break
			end 'tooLow'

			try cursor.advance() otherwise break  // onto operator
			let opToken = cursor.current()
			try cursor.advance() otherwise break  // past operator onto right-operand's first token

			let leftName = exprName(left)
			let opRange = SourceRange.ofToken(opToken)

			// Compile-time string constant folding for ==
			if opToken.kind == TokenKind.equalsEquals 'checkStrFold'
				if exprIsStringConst(left) 'leftIsStr'
					let right = try parsePrimary(module, block: block)
					var foldedLeft = 1
					if exprStringConstValue(left) != exprStringConstValue(right) 'strNeq'
						foldedLeft = 0
					end 'strNeq'
					let leftLitName = emitLiteral(module, block: block, value: foldedLeft, valueType: MaxonType.integer)
					let rightLitName = emitLiteral(module, block: block, value: 1, valueType: MaxonType.integer)
					let resultName = freshSynthName()
					module.appendOp(block, op: MaxonOp.cmp(resultName, left: leftLitName, right: rightLitName, predicate: CmpPredicate.eq, operandType: MaxonType.integer, range: opRange))
					left = ExprResult.direct(resultName, valueType: MaxonType.integer)
					continue
				end 'leftIsStr'
			end 'checkStrFold'

			// Reference identity: is / is not
			if opToken.kind == TokenKind.is 'isRefEq'
				var negate = false
				if cursor.current().kind == TokenKind.not 'isNot'
					negate = true
					try cursor.advance() otherwise break  // past `not` onto right-operand's first token
				end 'isNot'
				let right = try parseExpressionBP(module, block: block, minBP: bp)
				if not maxonTypeIsRef(project, t: exprType(left)) or not maxonTypeIsRef(project, t: exprType(right)) 'notRef'
					reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "'is' requires reference types (structs), not primitive values", line: opToken.line, column: opToken.column, filePath: filePath)
				end 'notRef'
				let resultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.refEq(resultName, left: leftName, right: exprName(right), negate: negate, range: opRange))
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
				continue
			end 'isRefEq'

			// Parse right operand with higher minimum binding power for left-associativity
			let right = try parseExpressionBP(module, block: block, minBP: bp)

			// Dispatch == and != to .equals() call for reference types (content comparison)
			if (opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals) and maxonTypeIsRef(project, t: exprType(left)) and maxonTypeIsRef(project, t: exprType(right)) 'refEquals'
				let equalsResultName = freshSynthName()
				var equalsArgs = ByteArrayArray.create()
				equalsArgs.push(leftName)
				equalsArgs.push(exprName(right))
				module.appendOp(block, op: MaxonOp.call(equalsResultName, callee: "equals".toByteArray(), args: equalsArgs, range: opRange))
				if opToken.kind == TokenKind.bangEquals 'neq'
					let notResultName = freshSynthName()
					module.appendOp(block, op: MaxonOp.unop(notResultName, operand: equalsResultName, opKind: UnaryOpKind.bitNot, operandType: MaxonType.integer, range: opRange))
					left = ExprResult.direct(notResultName, valueType: MaxonType.integer)
				end 'neq' else 'eq'
					left = ExprResult.direct(equalsResultName, valueType: MaxonType.integer)
				end 'eq'
				continue
			end 'refEquals'

			let resultName = freshSynthName()
			// Pick an advisory operandType from whichever operand carries the
			// most specific source-level type. lowerMaxonToStd sees the
			// fully-resolved operand StdTypes and inserts int↔float promotions
			// and picks the concrete opcodes.
			let operandType = binOpOperandType(exprType(left), rightType: exprType(right), kind: opToken.kind)
			try emitBinaryOp(module, block: block, kind: opToken.kind, resultName: resultName, leftName: leftName, rightName: exprName(right), operandType: operandType, range: opRange) otherwise ignore

			// Comparison ops produce int (bool); arithmetic inherits the
			// operand's source-level type so chained expressions stay
			// typed consistently through TypeResolution.
			if opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals or opToken.kind == TokenKind.lessThan or opToken.kind == TokenKind.lessEquals or opToken.kind == TokenKind.greaterThan or opToken.kind == TokenKind.greaterEquals 'isCmp'
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
			end 'isCmp' else 'notCmp'
				left = ExprResult.direct(resultName, valueType: operandType)
			end 'notCmp'
		end 'prattLoop'

		return left
	end 'parseExpressionBP'

	// --- Binary op emission ---

	// Choose the advisory operandType for a binary op. Bitwise ops are
	// integer-only; for everything else we prefer float > named > integer so
	// mixed expressions like `foo + 1.0` retain the `float` type. The actual
	// dispatch happens in lowerMaxonToStd after type resolution.
	function binOpOperandType(leftType MaxonType, rightType MaxonType, kind TokenKind) returns MaxonType
		if kind == TokenKind.or or kind == TokenKind.xor or kind == TokenKind.and or kind == TokenKind.shl or kind == TokenKind.shr or kind == TokenKind.mod 'intOnly'
			return MaxonType.integer
		end 'intOnly'
		if maxonTypeIsFloat(leftType) or maxonTypeIsFloat(rightType) 'anyFloat'
			return MaxonType.float
		end 'anyFloat'
		if isNamedMaxonType(leftType) 'leftNamed'
			return leftType
		end 'leftNamed'
		if isNamedMaxonType(rightType) 'rightNamed'
			return rightType
		end 'rightNamed'
		return MaxonType.integer
	end 'binOpOperandType'

	function isNamedMaxonType(t MaxonType) returns bool
		return match t 'check'
			named gives true
			integer gives false
			float gives false
			boolean gives false
		end 'check'
	end 'isNamedMaxonType'

	function emitBinaryOp(module MaxonModule, block IrBlock, kind TokenKind, resultName ByteArray, leftName ByteArray, rightName ByteArray, operandType MaxonType, range SourceRange = SourceRange.none()) throws ParserError
		let intType = MaxonType.integer
		let hlOp = match kind 'emit'
			or gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitOr, operandType: intType, range: range)
			xor gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitXor, operandType: intType, range: range)
			and gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitAnd, operandType: intType, range: range)
			shl gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shl, operandType: intType, range: range)
			shr gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shr, operandType: intType, range: range)
			equalsEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.eq, operandType: operandType, range: range)
			bangEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ne, operandType: operandType, range: range)
			lessThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.lt, operandType: operandType, range: range)
			lessEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.le, operandType: operandType, range: range)
			greaterThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.gt, operandType: operandType, range: range)
			greaterEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ge, operandType: operandType, range: range)
			plus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.add, operandType: operandType, range: range)
			minus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.sub, operandType: operandType, range: range)
			star gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mul, operandType: operandType, range: range)
			slash gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.div, operandType: operandType, range: range)
			mod gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mod, operandType: intType, range: range)
			default throws ParserError.unhandledToken
		end 'emit'
		module.appendOp(block, op: hlOp)
	end 'emitBinaryOp'

	// --- Unary parsing ---

	// Unary: -primary | not primary | primary
	function parseUnary(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let token = cursor.current()

		if token.kind == TokenKind.minus 'isNeg'
			let opRange = SourceRange.ofToken(token)
			expect(TokenKind.minus)
			let operand = try parsePrimary(module, block: block)
			let operandType = exprType(operand)
			if maxonTypeIsFloat(operandType) 'floatNeg'
				// Float negation: emit 0.0 - operand. The parser emits directly in
				// terms of MaxonType.float here because the source-level float
				// literal is unambiguous.
				// The synthetic `0.0` literal has no source origin; the binop itself
				// ranges over the `-` operator token that triggered the lowering.
				let zeroName = freshSynthName()
				module.appendOp(block, op: MaxonOp.literal(zeroName, value: 0, valueType: MaxonType.float, range: SourceRange.none()))
				let resultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.binop(resultName, left: zeroName, right: exprName(operand), opKind: BinOpKind.sub, operandType: MaxonType.float, range: opRange))
				return try parseAsCasts(module, block: block, expr: ExprResult.direct(resultName, valueType: MaxonType.float))
			end 'floatNeg'
			// For named or integer operands, emit the integer unary-neg op and
			// let lowerMaxonToStd pick the concrete StdType.
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.neg, operandType: operandType, range: opRange))
			return try parseAsCasts(module, block: block, expr: ExprResult.direct(resultName, valueType: operandType))
		end 'isNeg' else if token.kind == TokenKind.not 'isNot'
			let notRange = SourceRange.ofToken(token)
			expect(TokenKind.not)
			let operand = try parseUnary(module, block: block)
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.bitNot, operandType: MaxonType.integer, range: notRange))
			return ExprResult.direct(resultName, valueType: MaxonType.integer)
		end 'isNot'

		return try parseAsCasts(module, block: block, expr: try parsePostfix(module, block: block, expr: try parsePrimary(module, block: block)))
	end 'parseUnary'

	// --- Cast expression parsing ---

	// Parse zero or more `as Type` casts following an expression. Casts bind
	// tighter than any binary operator, so we apply them as a postfix chain
	// before returning to the Pratt loop. Each cast emits a maxon.convert op
	// whose fromType/toType drive width selection during lowering. Cast
	// validity (widening rules, narrowing rejection) is checked by the
	// TypeResolution pass after all named types have been resolved.
	// entry: cursor AT last-consumed of the incoming expression.
	// exit:  cursor AT the final type-name token (or same as entry if no cast).
	function parseAsCasts(module MaxonModule, block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr
		while true 'castLoop'
			let asCandidate = try cursor.peek(1) otherwise break
			if asCandidate.kind != TokenKind.as 'notAs'
				break
			end 'notAs'
			try cursor.advance() otherwise break  // onto 'as'
			let asToken = cursor.current()
			try cursor.advance() otherwise break  // past 'as' onto type token
			let targetMaxonType = parseCastTargetType()
			// parseCastTargetType leaves cursor AT the type-name token.
			let targetLastToken = cursor.current()
			let fromMaxonType = exprType(result)
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.convert(resultName, operand: exprName(result), fromType: fromMaxonType, toType: targetMaxonType, implicit: false, range: SourceRange.between(asToken, last: targetLastToken)))
			result = ExprResult.direct(resultName, valueType: targetMaxonType)
		end 'castLoop'
		return result
	end 'parseAsCasts'

	// Parse the type appearing after `as`. Accepts the bare primitive
	// keywords (`int`, `float`, `bool`, `byte`) and registered typealias
	// identifiers — the former resolve to MaxonType primitives, the latter
	// stay as MaxonType.named so the typealias registry drives lowering.
	// exit: cursor AT the type-name token (not advanced past it).
	function parseCastTargetType() returns MaxonType
		let typeToken = cursor.current()
		if typeToken.kind == TokenKind.int 'isInt'
			return MaxonType.integer
		end 'isInt'
		if typeToken.kind == TokenKind.float 'isFloat'
			return MaxonType.float
		end 'isFloat'
		if typeToken.kind == TokenKind.bool 'isBool'
			return MaxonType.boolean
		end 'isBool'
		if typeToken.kind == TokenKind.byte 'isByte'
			return internMaxonType(project, name: "byte")
		end 'isByte'
		if typeToken.kind == TokenKind.identifier 'isIdent'
			return internMaxonType(project, name: typeToken.value)
		end 'isIdent'
		reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected type name after 'as'", line: typeToken.line, column: typeToken.column, filePath: filePath)
		return MaxonType.integer
	end 'parseCastTargetType'

	// --- Postfix expression chain ---

	// entry: cursor AT last-consumed of the primary expression.
	// exit:  cursor AT last-consumed of the postfix chain (`)` for method call
	//        or field-name token for field access). If no chain, cursor AT
	//        last-consumed of the primary (same as entry).
	function parsePostfix(module MaxonModule, block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr

		// Peek ahead for `.`. If so, consume and parse a chain segment.
		while true 'postfixLoop'
			let nextTok = try cursor.peek(1) otherwise break
			if nextTok.kind != TokenKind.dot 'notDot'
				break
			end 'notDot'
			if not maxonTypeIsRef(project, t: exprType(result)) 'notRef'
				break
			end 'notRef'

			try cursor.advance() otherwise break  // move onto '.'
			try cursor.advance() otherwise break  // past '.' onto member name
			let memberToken = cursor.current()
			let memberName = memberToken.value

			let structTypeName = maxonTypeStructName(project, t: exprType(result))
			let structType = try project.structTypes.get(structTypeName) otherwise break

			let receiverName = exprName(result)

			let afterMember = try cursor.peek(1) otherwise 'noMore'
				// No more tokens — treat as field access, exit AT memberToken.
				var fieldOffsetEof = 0
				var fieldFoundEof = false
				var fieldTypeEof = MaxonType.integer
				for field in structType.fields 'findFieldEof'
					if field.name == memberName 'matchEof'
						fieldOffsetEof = field.offset
						fieldFoundEof = true
						fieldTypeEof = field.fieldType
						break
					end 'matchEof'
				end 'findFieldEof'
				if not fieldFoundEof 'fieldNotFoundEof'
					break
				end 'fieldNotFoundEof'
				let fieldLoadNameEof = freshSynthName()
				module.appendOp(block, op: MaxonOp.fieldLoad(fieldLoadNameEof, structName: receiverName, offset: fieldOffsetEof, range: SourceRange.ofToken(memberToken)))
				result = ExprResult.direct(fieldLoadNameEof, valueType: fieldTypeEof)
				break
			end 'noMore'

			if afterMember.kind == TokenKind.leftParen 'isMethodCall'
				let calleeName = "{structTypeName}.{memberName}"
				try cursor.advance() otherwise break  // past memberName onto `(`
				try cursor.advance() otherwise break  // past `(` onto first arg (or `)`)
				let argNames = try parseCallArgs(module, block: block, calleeName: calleeName, paramStartIndex: 1)
				// parseCallArgs exits AT `)`.
				let rparenToken = cursor.current()
				var fullArgNames = ByteArrayArray.create()
				fullArgNames.push(receiverName)
				for argName in argNames 'addArgs'
					fullArgNames.push(argName)
				end 'addArgs'
				result = emitCallAndResult(module, block: block, calleeName: calleeName, args: fullArgNames, range: SourceRange.between(memberToken, last: rparenToken))
				// Cursor AT `)`. Loop continues to check next for `.`.
				continue
			end 'isMethodCall'

			// Field access: .field — cursor AT memberToken.
			var fieldOffset = 0
			var fieldFound = false
			var fieldType = MaxonType.integer
			for field in structType.fields 'findField'
				if field.name == memberName 'match'
					fieldOffset = field.offset
					fieldFound = true
					fieldType = field.fieldType
					break
				end 'match'
			end 'findField'
			if not fieldFound 'fieldNotFound'
				break
			end 'fieldNotFound'
			let fieldLoadName = freshSynthName()
			module.appendOp(block, op: MaxonOp.fieldLoad(fieldLoadName, structName: receiverName, offset: fieldOffset, range: SourceRange.ofToken(memberToken)))
			result = ExprResult.direct(fieldLoadName, valueType: fieldType)
			// Cursor AT memberToken. Loop continues to peek next.
		end 'postfixLoop'

		return result
	end 'parsePostfix'

	// --- Primary expression parsing ---

	// entry: cursor AT the first identifier token.
	// exit:  cursor AT the last-consumed token (final `)`, `}`, field-name,
	//        or the identifier itself for a bare variable read).
	function parseIdentifierExpr(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		// Exhausted cursor means "bare identifier with nothing after it": the
		// EOF sentinel token doesn't match any of the kind== checks below, so
		// control falls through to the bare-variable-read tail.
		let peekToken = try cursor.peek(1) otherwise Token.eof()

		// Type.staticMethod(args)
		if peekToken.kind == TokenKind.dot and project.structTypes.contains(token.value) 'maybeStaticCall'
			let memberToken = try cursor.peek(2)
			let afterMember = try cursor.peek(3)
			if memberToken.kind == TokenKind.identifier and afterMember.kind == TokenKind.leftParen 'isStaticCall'
				let calleeName = "{token.value}.{memberToken.value}"
				expect(TokenKind.identifier)
				expect(TokenKind.dot)
				expect(TokenKind.identifier)
				expect(TokenKind.leftParen)
				// parseCallArgs exits AT `)` (new contract).
				let argNames = try parseCallArgs(module, block: block, calleeName: calleeName, paramStartIndex: 0)
				let rparenToken = cursor.current()
				return emitCallAndResult(module, block: block, calleeName: calleeName, args: argNames, range: SourceRange.between(token, last: rparenToken))
			end 'isStaticCall'
		end 'maybeStaticCall'

		if peekToken.kind == TokenKind.leftParen 'isCall'
			expect(TokenKind.identifier)
			expect(TokenKind.leftParen)
			if token.value == "trunc" 'isTruncParse'
				// parseExpression exits AT last-consumed of the expression; after
				// it, advance once so we land on `)` to be the trunc's exit pos.
				let truncArgResult = try parseExpression(module, block: block)
				try cursor.advance()
				let truncRparenToken = cursor.current()
				let truncResultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.convert(truncResultName, operand: exprName(truncArgResult), fromType: exprType(truncArgResult), toType: MaxonType.integer, implicit: true, range: SourceRange.between(token, last: truncRparenToken)))
				return ExprResult.direct(truncResultName, valueType: MaxonType.integer)
			end 'isTruncParse'

			let calleeName = resolveCallTarget(token.value)
			var argNames = try parseCallArgs(module, block: block, calleeName: calleeName, paramStartIndex: 0)
			let rparenToken = cursor.current()
			return emitCallAndResult(module, block: block, calleeName: calleeName, args: argNames, range: SourceRange.between(token, last: rparenToken))
		end 'isCall'

		// Sized type bound: u64.max, i32.min, etc.
		if peekToken.kind == TokenKind.dot 'maybeTypeBound'
			let fieldToken = try cursor.peek(2)
			if fieldToken.kind == TokenKind.identifier and (fieldToken.value == "min" or fieldToken.value == "max") and (token.value == "u8" or token.value == "u16" or token.value == "u32" or token.value == "u64" or token.value == "i8" or token.value == "i16" or token.value == "i32" or token.value == "i64") 'isTypeBound'
				let bound = resolveTypeBound(token.value, field: fieldToken.value)
				expect(TokenKind.identifier)
				expect(TokenKind.dot)
				// Stay AT fieldToken (the `min`/`max` identifier). Don't advance past it.
				let boundName = emitLiteral(module, block: block, value: bound, valueType: MaxonType.integer, range: SourceRange.between(token, last: fieldToken))
				return ExprResult.direct(boundName, valueType: MaxonType.integer)
			end 'isTypeBound'
		end 'maybeTypeBound'

		// Struct construction: TypeName{field: value, ...}
		if peekToken.kind == TokenKind.leftBrace and project.structTypes.contains(token.value) 'isStructLiteral'
			return try parseStructLiteral(module, block: block, typeName: token.value, typeToken: token)
		end 'isStructLiteral'

		// Ranged primitive construction: TypeName{expression}
		if peekToken.kind == TokenKind.leftBrace 'isTypedConstruct'
			try cursor.advance()  // skip type name
			try cursor.advance()  // skip '{'
			let innerResult = try parseExpression(module, block: block)
			// advance past last-consumed of inner expression, landing on '}'
			try cursor.advance()
			return innerResult
		end 'isTypedConstruct'

		if project.topLevelConstants.contains(token.value) 'isConst'
			return resolveConstant(module, block: block, name: token.value)
		end 'isConst'

		let slot = lookupVariable(token.value, token: token)
		let name = freshSynthName()
		let varType = scope.getType(token.value)
		let tokRange = SourceRange.ofToken(token)
		if scope.isSelfField(token.value) 'selfFieldRead'
			let info = scope.getInfo(token.value)
			let selfSlot = lookupVariable("__self", token: token)
			let selfLoadName = freshSynthName()
			module.appendOp(block, op: MaxonOp.varLoad(selfLoadName, slotId: selfSlot, slotType: internMaxonType(project, name: currentTypeName), range: tokRange))
			module.appendOp(block, op: MaxonOp.fieldLoad(name, structName: selfLoadName, offset: info.fieldOffset, range: tokRange))
		end 'selfFieldRead' else 'localRead'
			module.appendOp(block, op: MaxonOp.varLoad(name, slotId: slot, slotType: varType, range: tokRange))
		end 'localRead'
		// Stay AT the identifier token. Don't advance past it.
		return ExprResult.direct(name, valueType: varType)
	end 'parseIdentifierExpr'

	// Resolve a bare function identifier to its qualified callee name. Prefers
	// a function in the current file's namespace, then the stdlib namespace,
	// then falls back to the file-local qualification so diagnostics point
	// at the expected name even if the function does not exist.
	function resolveCallTarget(bareName String) returns String
		if bareName == "main" 'isMain'
			return bareName
		end 'isMain'
		let localName = qualifyName(namespace, name: bareName)
		if project.funcReturnTypes.contains(localName) 'isLocal'
			return localName
		end 'isLocal'
		let stdlibName = qualifyName("stdlib", name: bareName)
		if project.funcReturnTypes.contains(stdlibName) 'isStdlib'
			return stdlibName
		end 'isStdlib'
		return localName
	end 'resolveCallTarget'

	// Parse call arguments, validating named args for 2nd+ arguments.
	// When calleeName resolves to a registered function signature, the first
	// argument may be positional (mapped to paramStartIndex) and subsequent
	// arguments are reordered by name so IR parameter order matches the
	// callee's declaration. Missing arguments with integer defaults are filled
	// in automatically. When no signature is registered (stdlib calls before
	// cache warm-up, interface calls, etc.) the legacy positional-order path
	// is used.
	// paramStartIndex is the index of the first user-facing parameter — 0 for
	// free functions, 1 for method calls where the caller prepends the
	// receiver to argIds after parseCallArgs returns.
	function parseCallArgs(module MaxonModule, block IrBlock, calleeName String = "", paramStartIndex ParsedInt = 0) returns ByteArrayArray throws ParserError
		let hasSignature = not calleeName.isEmpty() and project.funcSignatures.contains(calleeName)
		if not hasSignature 'noSignature'
			return try parseCallArgsLegacy(module, block: block)
		end 'noSignature'
		let signature = try project.funcSignatures.get(calleeName) otherwise panic("signature contains but get failed")
		return try parseCallArgsWithSignature(module, block: block, signature: signature, paramStartIndex: paramStartIndex)
	end 'parseCallArgs'

	// Legacy path used when we don't know the signature (stdlib, interface,
	// or calls whose callee resolution depends on receiver-type inference).
	// Accepts any well-formed named-or-positional argument list and emits the
	// arguments in source order.
	// entry: cursor AT first-arg-first-token OR AT `)` if no args.
	// exit:  cursor AT `)`.
	function parseCallArgsLegacy(module MaxonModule, block IrBlock) returns ByteArrayArray throws ParserError
		var args = ByteArrayArray.create()
		var argIndex = 0
		if cursor.current().kind != TokenKind.rightParen 'hasArgs'
			while true 'argLoop'
				_ = try consumeArgLabel(requireNamed: argIndex >= 1)
				// parseExpression exits AT last-consumed of the arg expression;
				// advance once so cursor lands past it (commas are skipped by
				// the lexer, so the next token is either a label / value /  `)`).
				let argResult = try parseExpression(module, block: block)
				try cursor.advance()
				args.push(exprName(argResult))
				argIndex = argIndex + 1
				if cursor.current().kind == TokenKind.rightParen 'endArgs'
					break
				end 'endArgs'
			end 'argLoop'
		end 'hasArgs'
		return args
	end 'parseCallArgsLegacy'

	// Signature-aware path: slot each argument into the position named by its
	// label, report E3003 for unknown labels, and fill missing arguments with
	// their integer literal defaults. The first argument may be positional —
	// it is assigned to the first user-facing parameter slot.
	function parseCallArgsWithSignature(module MaxonModule, block IrBlock, signature FuncSignature, paramStartIndex ParsedInt) returns ByteArrayArray throws ParserError
		let userParamCount = signature.paramNames.count() - paramStartIndex
		var slotNames = ByteArrayArray.create()
		var slotFilled = BoolArray.create()
		for _ in 0 upto userParamCount 'initSlots'
			slotNames.push(ByteArray.create())
			slotFilled.push(false)
		end 'initSlots'

		var argIndex = 0
		if cursor.current().kind != TokenKind.rightParen 'hasArgs'
			while true 'argLoop'
				let labelToken = try consumeArgLabel(requireNamed: argIndex >= 1)
				var targetIndex = argIndex
				var labelResolved = true
				if labelToken.hasValue 'hasLabel'
					if let resolved = try resolveParamIndex(signature, name: labelToken.token.value, paramStartIndex: paramStartIndex, nameToken: labelToken.token) 'gotIndex'
						targetIndex = resolved
					end 'gotIndex' else 'noMatch'
						labelResolved = false
					end 'noMatch'
				end 'hasLabel'
				let argResult = try parseExpression(module, block: block)
				// parseExpression leaves cursor AT last-consumed; advance once to
				// move past it (commas are skipped by lexer).
				try cursor.advance()
				if labelResolved and targetIndex < userParamCount 'recordArg'
					slotNames.set(targetIndex, value: exprName(argResult))
					slotFilled.set(targetIndex, value: true)
				end 'recordArg'
				argIndex = argIndex + 1
				if cursor.current().kind == TokenKind.rightParen 'endArgs'
					break
				end 'endArgs'
			end 'argLoop'
		end 'hasArgs'

		fillArgDefaultsFromSignature(module, block: block, signature: signature, paramStartIndex: paramStartIndex, slotNames: slotNames, slotFilled: slotFilled, userParamCount: userParamCount)
		return slotNames
	end 'parseCallArgsWithSignature'

	// Consume and validate an optional `name:` label on the next argument.
	// When requireNamed is true and no label is present, reports E3005. When
	// a label is present (regardless of requireNamed), consumes both tokens
	// and returns them; otherwise returns an empty OptionalToken.
	function consumeArgLabel(requireNamed bool) returns OptionalToken throws ParserError
		let maybeLabel = cursor.current()
		let afterLabel = try cursor.peek(1)
		let isNamed = maybeLabel.kind == TokenKind.identifier and afterLabel.kind == TokenKind.colon
		if requireNamed and not isNamed 'notNamed'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: maybeLabel.line, column: maybeLabel.column, filePath: filePath)
		end 'notNamed'
		if not isNamed 'noLabel'
			return OptionalToken.empty()
		end 'noLabel'
		let nameToken = consume()
		expect(TokenKind.colon)
		return OptionalToken.some(nameToken)
	end 'consumeArgLabel'

	// Fill in any unfilled argument slots from the signature's default values.
	// Missing required arguments leave the slot at 0 — downstream semantic
	// checks will report them; stopping here would hide later errors from the
	// user and slow down iteration.
	function fillArgDefaultsFromSignature(module MaxonModule, block IrBlock, signature FuncSignature, paramStartIndex ParsedInt, slotNames ByteArrayArray, slotFilled BoolArray, userParamCount ParsedInt)
		for userIdx in 0 upto userParamCount 'fillDefaults'
			let isFilled = try slotFilled.get(userIdx) otherwise panic("slotFilled out of bounds in fillDefaults")
			if isFilled 'alreadySet'
				continue
			end 'alreadySet'
			let paramIdx = userIdx + paramStartIndex
			let paramDefault = try signature.paramDefaults.get(paramIdx) otherwise panic("paramDefaults out of bounds in fillDefaults")
			let defaultValue = paramDefaultAsIntLiteral(paramDefault)
			if defaultValue.hasValue 'hasDefault'
				let defaultName = emitLiteral(module, block: block, value: defaultValue.value, valueType: MaxonType.integer)
				slotNames.set(userIdx, value: defaultName)
				slotFilled.set(userIdx, value: true)
			end 'hasDefault'
		end 'fillDefaults'
	end 'fillArgDefaultsFromSignature'

	// Resolve a named argument label to its parameter index in the signature.
	// paramStartIndex is the index of the first user-facing parameter — the
	// implicit __self slot is invisible to callers so its name is not
	// considered a valid label. Throws ParamLookupError.unknownName after
	// reporting the compile error so the caller can skip the argument cleanly.
	function resolveParamIndex(signature FuncSignature, name String, paramStartIndex ParsedInt, nameToken Token) returns ParsedInt throws ParamLookupError
		var i = paramStartIndex
		while i < signature.paramNames.count() 'scan'
			let candidate = try signature.paramNames.get(i) otherwise panic("paramNames index out of bounds")
			if candidate == name 'found'
				return i - paramStartIndex
			end 'found'
			i = i + 1
		end 'scan'
		reportCompileError(project, code: ErrorCode.semanticUndefinedVariable, message: "unknown parameter name: '{name}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		throw ParamLookupError.unknownName(name)
	end 'resolveParamIndex'

	// Emit a function call and return the appropriate ExprResult based on return type.
	// `range` covers the call-site span (the callee name through the closing `)`);
	// caller captures it before parsing arguments and passes it in.
	function emitCallAndResult(module MaxonModule, block IrBlock, calleeName String, args ByteArrayArray, range SourceRange = SourceRange.none()) returns ExprResult
		let callName = freshSynthName()
		module.appendOp(block, op: MaxonOp.call(callName, callee: calleeName.toByteArray(), args: args, range: range))
		let calleeReturnType = try project.funcReturnTypes.get(calleeName) otherwise MaxonReturnType.void
		let calleeValueType = match calleeReturnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		if maxonReturnTypeIsVoid(calleeReturnType) 'isVoidReturn'
			return ExprResult.direct(callName, valueType: MaxonType.integer)
		end 'isVoidReturn'
		// Carry the callee's declared return MaxonType through; lowerMaxonToStd
		// picks the register class after TypeResolution has validated the name.
		return ExprResult.direct(callName, valueType: calleeValueType)
	end 'emitCallAndResult'

	// Resolve an instance method name by finding the struct type of the variable.
	function resolveInstanceMethod(varName String, methodName String) returns String
		let structType = getVariableStructType(varName)
		if structType.isEmpty() 'noType'
			return methodName
		end 'noType'
		return "{structType}.{methodName}"
	end 'resolveInstanceMethod'

	// entry: cursor AT type-name identifier (if not typeNameConsumed) OR AT `{`.
	// exit:  cursor AT `}`.
	function parseStructLiteral(module MaxonModule, block IrBlock, typeName String, typeToken Token, typeNameConsumed bool = false) returns ExprResult throws ParserError
		if not typeNameConsumed 'consumeTypeName'
			try cursor.advance()  // past type-name onto `{`
		end 'consumeTypeName'
		// cursor AT `{`. Advance past into body.
		try cursor.advance()
		skipNewlines()

		let structType = try project.structTypes.get(typeName) otherwise 'noType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown struct type '{typeName}'", line: typeToken.line, column: typeToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'noType'

		let sizeName = emitLiteral(module, block: block, value: structType.byteSize, valueType: MaxonType.integer)
		let ptrName = freshSynthName()
		module.appendOp(block, op: MaxonOp.structAlloc(ptrName, byteSize: sizeName, range: SourceRange.ofToken(typeToken)))

		// Parse field: value pairs and store each field
		while cursor.current().kind != TokenKind.rightBrace 'fields'
			let fieldNameToken = cursor.current()
			try cursor.advance()  // past fieldName onto ':'
			try cursor.advance()  // past ':' onto RHS
			let fieldValue = try parseExpression(module, block: block)
			// parseExpression exits AT last-consumed of RHS.
			let fieldLastToken = cursor.current()
			try cursor.advance()  // past RHS onto newline / next field / `}`

			var fieldFound = false
			for field in structType.fields 'findField'
				if field.name == fieldNameToken.value 'match'
					module.appendOp(block, op: MaxonOp.fieldStore(ptrName, offset: field.offset, value: exprName(fieldValue), range: SourceRange.between(fieldNameToken, last: fieldLastToken)))
					fieldFound = true
					break
				end 'match'
			end 'findField'
			if not fieldFound 'unknown'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown field '{fieldNameToken.value}' in type '{typeName}'", line: fieldNameToken.line, column: fieldNameToken.column, filePath: filePath)
			end 'unknown'

			skipNewlines()
		end 'fields'
		// cursor AT `}`. Stay AT it (new contract).
		return ExprResult.direct(ptrName, valueType: internMaxonType(project, name: typeName))
	end 'parseStructLiteral'

	function parsePrimaryMatch(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		// New contract: every primary leaf exits AT its last-consumed token.
		match token.kind 'primary'
			intLiteral then return try parseIntLiteral(module, block: block, token: token)
			floatLiteral then return try parseFloatLiteral(module, block: block, token: token)
			identifier then return try parseIdentifierExpr(module, block: block, token: token)
			doubleStringLiteral then return parseStringLiteral(token)
			true then return parseBoolLiteral(module, block: block, value: 1)
			false then return parseBoolLiteral(module, block: block, value: 0)
			leftParen then return try parseParenExpr(module, block: block)
			selfType then return try parseSelfExpr(module, block: block)
			default throws ParserError.unhandledToken
		end 'primary'
	end 'parsePrimaryMatch'

	// entry: cursor AT `Self`.
	// exit:  cursor AT `}` (for Self{...}) or AT `Self` on error paths.
	function parseSelfExpr(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let selfToken = cursor.current()
		if currentTypeName.isEmpty() 'notInType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'Self' can only be used inside a type declaration", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'notInType'
		let nextTok = try cursor.peek(1) otherwise 'noNext'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '\{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'noNext'
		if nextTok.kind == TokenKind.leftBrace 'isStructLiteral'
			try cursor.advance()  // past Self onto `{`
			return try parseStructLiteral(module, block: block, typeName: currentTypeName, typeToken: selfToken, typeNameConsumed: true)
		end 'isStructLiteral'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '\{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'parseSelfExpr'

	function parsePrimary(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let token = cursor.current()
		let result = try parsePrimaryMatch(module, block: block, token: token) otherwise return raiseUnexpectedToken(module, block: block, token: token)
		return result
	end 'parsePrimary'

	// Expression-position parse failure: the next token doesn't start any known
	// primary. Report the diagnostic (for batch compile output), emit a
	// `MaxonOp.error` that anchors the failed span in the IR (for the LSP),
	// skip to the end of the line to avoid cascading errors, and return a
	// dummy ExprResult so the caller's type shape stays intact.
	function raiseUnexpectedToken(module MaxonModule, block IrBlock, token Token) returns ExprResult
		let message = "Expected expression but got '{tokenValueToString(token.value)}'"
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: message, line: token.line, column: token.column, filePath: filePath)
		module.appendOp(block, op: MaxonOp.error(MaxonErrorKind.expectedExpression, message: message, range: SourceRange.ofToken(token)))
		for tok in cursor 'skip'
			if tok.kind == TokenKind.newline 'atEnd'
				break
			end 'atEnd'
		end 'skip'
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'raiseUnexpectedToken'

	// exit: cursor AT the intLiteral token (not advanced past it).
	function parseIntLiteral(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		let value = try parseInt(token.value) otherwise 'overflow'
			reportLiteralOverflow(TokenKind.intLiteral, token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'overflow'
		let name = emitLiteral(module, block: block, value: value, valueType: MaxonType.integer, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.integer)
	end 'parseIntLiteral'

	// exit: cursor AT the floatLiteral token (not advanced past it).
	function parseFloatLiteral(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		let rawBits = try parseFloatBits(token.value) otherwise 'overflow'
			reportLiteralOverflow(TokenKind.floatLiteral, token: token, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.float)
		end 'overflow'
		let name = emitLiteral(module, block: block, value: rawBits, valueType: MaxonType.float, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.float)
	end 'parseFloatLiteral'

	// exit: cursor AT the doubleStringLiteral token (not advanced past it).
	function parseStringLiteral(token Token) returns ExprResult
		// String literals don't emit an op in the Maxon IR today (they're
		// constant-folded through `stringConst`), so there's no range to
		// attach. When string literals acquire a backing op, the range
		// comes from `SourceRange.ofToken(token)`.
		let name = freshSynthName()
		return ExprResult.stringConst(name, value: token.value)
	end 'parseStringLiteral'

	// exit: cursor AT the 'true' or 'false' keyword token (not advanced past it).
	function parseBoolLiteral(module MaxonModule, block IrBlock, value ParsedInt) returns ExprResult
		let tok = cursor.current()
		let name = emitLiteral(module, block: block, value: value, valueType: MaxonType.boolean, range: SourceRange.ofToken(tok))
		return ExprResult.direct(name, valueType: MaxonType.boolean)
	end 'parseBoolLiteral'

	// entry: cursor AT `(`.
	// exit:  cursor AT `)`.
	function parseParenExpr(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		expect(TokenKind.leftParen)
		let inner = try parseExpression(module, block: block)
		// parseExpression exits AT last-consumed of inner; advance to land on `)`.
		try cursor.advance()
		if cursor.current().kind != TokenKind.rightParen 'noClose'
			let t = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected ')' but got '{tokenValueToString(t.value)}'", line: t.line, column: t.column, filePath: filePath)
		end 'noClose'
		return inner
	end 'parseParenExpr'

end 'Parser'

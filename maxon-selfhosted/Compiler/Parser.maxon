// Recursive descent parser.
// Consumes tokens and emits Maxon ops into an MaxonModule with block-based CFG.
//
// ===== Helper contract =====
//
//   entry: cursor AT the opening token of the construct this helper parses
//          (e.g. `return`, `let`, `function`, `(`, or the first operand token).
//   exit:  cursor AT the LAST token the helper consumed. The caller — typically
//          a `for token in cursor` dispatch loop — advances past that last
//          token on the next iteration's header step.
//
// Corollary: helpers do NOT call `try cursor.advance()` or `expect()` on the token they
// want the caller to see as "last-consumed." The helper's final action is an
// `at(kind)` assertion (no advance), a recursive call to a helper that itself
// ends AT its last-consumed token, or a loop whose body leaves the cursor in
// the right place.
//
// ===== End-of-file semantics =====
//
// There is no `TokenKind.eof` sentinel. The cursor signals exhaustion by
// throwing `IterationError.exhausted` from `try cursor.advance()` / `peek(n)`. A
// `for token in cursor` loop terminates naturally when the cursor runs out.
//
// Unclosed constructs (missing `end`, `)`, `}`, truncated expression) are
// parse errors, not silent terminations. Helpers that expect a closing
// terminator check for it explicitly and report `unexpected end of input`
// with the opener's source range when the cursor exhausts before they find it.
//
// ===== Panics vs diagnostics =====
//
// The parser NEVER calls `panic()` on input-driven failures. Malformed or
// incomplete input produces a diagnostic (via `reportCompileError`) or a
// `ParserError` throw that the caller converts to one. Panics are reserved
// for internal-invariant failures — loop guards that just succeeded yet a
// subsequent `get()` failed, map `contains()` returning true yet `get()`
// failing, etc. Those are parser bugs, not user errors.

export typealias BoolArray = Array with bool

typealias TokenIter = ArrayIterator with Token

export type Parser
	var project Project
	// Original token array kept for absolute-index lookups (e.g. "previous
	// token"). The cursor drives consumption; this array stays fixed.
	var tokens TokenArray
	var cursor TokenIter
	var filePath FilePath
	// Module namespace supplied by the caller — used to qualify declarations
	// and resolve unqualified calls within this module.
	var namespace String
	// Current type name when parsing inside a type declaration (for Self resolution)
	var currentTypeName String
	var scope Scope
	// Context stacks for break/continue and match
	var loopStack LoopContextArray
	var matchStack MatchContextArray
	// Set when an unexpected statement token aborts the enclosing function body,
	// mirroring the C# bootstrap compiler's throw-to-top-level recovery. Suppresses
	// cascading E3013 (missing-return) and out-of-place `end` consumption.
	var abortBody bool
	// Per-function unused-parameter tracking. paramLocations records each
	// parameter's declaration site; referencedVars records every name read by
	// identifier/assignment/dot-call paths in the body. Both are reset at the
	// top of parseFunction and consulted by checkUnusedParameters.
	var paramLocations ParamLocationArray
	var referencedVars ReferencedVarSet
	// Per-function counter for minting synthetic intermediate names (`$t0`,
	// `$t1`, …). Reset to 0 at the top of each function parse. Each synthetic
	// name is the ASCII byte sequence of `$t` + the integer, wrapped in a
	// ByteArray so it flows as a zero-copy name slice through the Maxon IR.
	// SSA numbering at the Std level is assigned later (in LowerMaxonToStd).
	var synthNameCounter ParsedInt
	// Grow-on-demand cache of synth-name ByteArrays, indexed by the counter
	// value. Entries 0..K are populated lazily as freshSynthName is called;
	// subsequent functions within the same Parser reuse the hot entries
	// without re-allocating. Sub-parsers for string interpolation get their
	// own small cache — lifetime matches the Parser instance.
	var synthNameCache ByteArrayArray
	// Tracks the block expression-level emission is currently writing into,
	// and the function that owns it. Bool short-circuit emission for `and`/`or`
	// switches blocks mid-expression: the cond_br lands in the entry block,
	// the rhs evaluates in a fresh side block, and we resume in a fresh merge
	// block. Statement-level callers that emit further ops after parseExpression
	// must read currentBlock to find the block control flow actually landed on.
	var currentBlock IrBlock
	var currentFunc IrFunction

	export static function create(project Project, tokens TokenArray, filePath FilePath, namespace String) returns Parser throws ParserError
		// Empty token array (empty or whitespace-only source) is a legitimate
		// input — caller must handle by throwing ParserError.unexpectedEof so
		// empty-file handling is explicit rather than a silent empty module.
		let cursor = try tokens.cursor() otherwise throw ParserError.unexpectedEof
		// Placeholder func/block — every parseFunction call rebinds these
		// before any expression is parsed.
		let placeholderFunc = IrFunction.create("", maxonReturnType: MaxonReturnType.void, paramCount: 0, maxonParamTypes: MaxonTypeArray.create(), returnLine: 0)
		let placeholderBlock = IrBlock.create(BlockId{0}, label: "")
		return Self{project: project, tokens: tokens, cursor: cursor, filePath: filePath, namespace: namespace, currentTypeName: "", scope: Scope.create(), loopStack: LoopContextArray.create(), matchStack: MatchContextArray.create(), abortBody: false, paramLocations: ParamLocationArray.create(), referencedVars: ReferencedVarSet.create(), synthNameCounter: 0, synthNameCache: ByteArrayArray.create(), currentBlock: placeholderBlock, currentFunc: placeholderFunc}
	end 'create'

	export function parseModule() returns MaxonModule throws ParserError
		logDebug(LogCategory.parser, message: () gives "parser: module={filePath}")

		var module = MaxonModule.create()

		skipNewlines()

		// Dispatch-loop Pattern D: iterate over the cursor. Each helper exits
		// AT its last-consumed token; the for-header then advances onto the
		// next top-level opener (or the loop terminates on cursor exhaustion).
		for token in cursor 'parseLoop'
			let prevPos = cursor.index()

			try 'dispatch'
				match token.kind 'kind'
					function then parseFunction(module, typeName: "", isInstance: false, fields: StructFieldArray.create())
					type then parseTypeDecl(module)
					let then parseTopLevelLet()
					var then parseTopLevelVar(typeName: "")
					typealias then parseTopLevelTypealias()
					export then parseExport()
					newline then continue
					default throws ParserError.unhandledToken
				end 'kind'
			end 'dispatch' otherwise(e) 'propagate'
				match e 'kind'
					unhandledToken then return reportUnexpectedTopLevel(token, module: module)
					typeError then throw ParserError.typeError
					overflow then throw ParserError.overflow
					unexpectedEof then throw ParserError.unexpectedEof
				end 'kind'
			end 'propagate'

			if cursor.index() <= prevPos 'stuck'
				try cursor.seek(prevPos + 1) otherwise panic("Parser.parseModule: stuck-guard seek({prevPos + 1}) out of bounds")
			end 'stuck'

			// abortBody (from synchronizeToTopLevel) leaves cursor AT next
			// top-level opener. For-header's auto-advance would skip it, so
			// retreat to compensate.
			if abortBody 'aborted'
				abortBody = false
				// synchronizeToTopLevel either parked us AT a top-level opener
				// (function/type/etc) or ran to exhaustion. If at an opener,
				// retreat so for-header advances onto it for re-dispatch.
				// Otherwise, break out of the loop entirely.
				let curKind = cursor.current().kind
				let atTopLevel = curKind == TokenKind.function or curKind == TokenKind.type or curKind == TokenKind.union or curKind == TokenKind.enum or curKind == TokenKind.export or curKind == TokenKind.let or curKind == TokenKind.var or curKind == TokenKind.typealias
				if atTopLevel 'redispatch'
					try cursor.retreat() otherwise panic("Parser.parseModule: retreat from top-level re-dispatch position failed at index {cursor.index()}")
				end 'redispatch' else 'noMore'
					break
				end 'noMore'
			end 'aborted'
		end 'parseLoop'

		// Invariant: every block we emit must have committed to a terminator
		// (a real op, dead, or fallthrough). A lingering Terminator.unset
		// means the parser left a block in an intermediate state — a bug
		// that would otherwise surface as mysterious failures deep in the
		// pipeline. Skip the check on error paths: reported errors may
		// legitimately leave blocks unfinished (e.g. missing-return aborts
		// emission).
		if project.diagnostics.count() == 0 'validate'
			for block in module.blocks 'eachBlock'
				block.assertTerminated()
			end 'eachBlock'
		end 'validate'

		return module
	end 'parseModule'

	// Reject declarations whose name starts with `__`. That prefix is reserved
	// for compiler-internal symbols (runtime intrinsics, builtin types like
	// __ManagedMemory). stdlib/Builtins.maxon is the sole exemption — it's the
	// type-system bridge that exposes those internal names. Call this at every
	// site that introduces a NEW binding (function/type/typealias/field/param/
	// let/var/enum-case/match-binding). Pure references to existing __ names
	// are fine.
	function checkReservedDeclName(nameToken Token)
		if namespace == "stdlib" and filePath.filename() == "Builtins.maxon" 'isBuiltins'
			return
		end 'isBuiltins'
		if not nameToken.value.startsWith("__") 'notReserved'
			return
		end 'notReserved'
		reportCompileError(project, code: ErrorCode.parserReservedIdentifier, message: "identifier '{nameToken.value}' is reserved: declarations starting with '__' are reserved for compiler internals", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'checkReservedDeclName'

	// --- Function parsing ---

	// Parse a parenthesized parameter list of the form `name Type, name Type, ...`
	// with optional default values `name Type = literal`.
	// Appends each parameter to the symbol table and to paramTypes, and updates
	// paramCount. Also fills paramNames and paramDefaults (parallel arrays) for
	// the call-site reordering pass. Caller is responsible for the leading `(`
	// and trailing `)`.
	function parseFunctionParameters(paramCount ParsedInt, paramTypes MaxonTypeArray, paramNames StringArray, paramDefaults ParamDefaultArray) throws ParserError
		if cursor.current().kind == TokenKind.rightParen 'noParams'
			return
		end 'noParams'

		while true 'paramLoop'
			let paramNameToken = try consume()
			checkReservedDeclName(paramNameToken)
			let paramTypeToken = try consume()

			let paramMaxonType = internMaxonType(project, name: paramTypeToken.value)

			// Define the parameter as a variable so it's accessible in the body
			_ = defineVariableWithType(paramNameToken.value, varType: paramMaxonType)
			paramLocations.push(ParamLocation.create(paramNameToken.value, line: paramNameToken.line, column: paramNameToken.column))
			paramTypes.push(paramMaxonType)
			paramNames.push(paramNameToken.value)
			paramDefaults.push(try parseOptionalParamDefault())
			paramCount = paramCount + 1

			if cursor.current().kind == TokenKind.rightParen 'endParams'
				break
			end 'endParams'
		end 'paramLoop'
	end 'parseFunctionParameters'

	// Parse an optional `= <literal>` default value for a parameter. Only
	// integer literals (optionally prefixed with `-`) are supported — the C#
	// bootstrap captures tokens and re-evaluates arbitrary expressions, but the
	// self-hosted parser needs only the literal form the current specs use.
	function parseOptionalParamDefault() returns ParamDefault throws ParserError
		if cursor.current().kind != TokenKind.equals 'noDefault'
			return ParamDefault.none
		end 'noDefault'
		try expect(TokenKind.equals)
		var negate = false
		if cursor.current().kind == TokenKind.minus 'negative'
			negate = true
			try expect(TokenKind.minus)
		end 'negative'
		let litToken = try consume()
		if litToken.kind != TokenKind.intLiteral 'notInt'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "parameter default value must be an integer literal", line: litToken.line, column: litToken.column, filePath: filePath)
			return ParamDefault.none
		end 'notInt'
		var value = try parseInt(litToken.value) otherwise 'overflow'
			try reportLiteralOverflow(TokenKind.intLiteral, token: litToken, message: "Integer literal '{tokenValueToString(litToken.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ParamDefault.none
		end 'overflow'
		if negate 'applyNeg'
			value = 0 - value
		end 'applyNeg'
		return ParamDefault.intLiteral(value)
	end 'parseOptionalParamDefault'

	// Skip an optional `throws ErrorType` clause.
	function skipThrowsClause() throws ParserError
		if cursor.current().kind == TokenKind.throws 'hasThrows'
			try expect(TokenKind.throws)
			try expect(TokenKind.identifier)
		end 'hasThrows'
	end 'skipThrowsClause'

	// Parse an optional `returns Type` clause. Returns MaxonReturnType.void if
	// the clause is absent. When isMethod is true and the return type is
	// `Self`, resolves to the enclosing type (typeName). For plain functions,
	// `Self` is consumed via the normal identifier path.
	function parseOptionalReturnType(isMethod bool, typeName String) returns MaxonReturnType throws ParserError
		if cursor.current().kind != TokenKind.returns 'noReturns'
			return MaxonReturnType.void
		end 'noReturns'
		try expect(TokenKind.returns)
		if isMethod 'methodReturns'
			let typeToken = cursor.current()
			if typeToken.kind == TokenKind.selfType 'isSelfReturn'
				try expect(TokenKind.selfType)
				return MaxonReturnType.value(internMaxonType(project, name: typeName))
			end 'isSelfReturn'
		end 'methodReturns'
		let typeToken = try consume()
		return MaxonReturnType.value(internMaxonType(project, name: typeToken.value))
	end 'parseOptionalReturnType'

	// Unified parser for both free functions and methods (static or instance).
	// When typeName is empty, parses a free function. When typeName is non-empty,
	// parses a method on that type; isInstance controls whether an implicit
	// `__self` parameter and field-load prologue / writeback epilogue are added.
	function parseFunction(module MaxonModule, typeName String, isInstance bool, fields StructFieldArray) throws ParserError
		let isMethod = not typeName.isEmpty()

		try expect(TokenKind.function)
		resetSymbolTable()
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		// Derive the qualified name used for symbol registration and logging.
		var qualifiedName = ""
		if isMethod 'methodName'
			qualifiedName = "{typeName}.{nameToken.value}"
			logTrace(LogCategory.parser, message: () gives "parser: method '{qualifiedName}'")
		end 'methodName' else 'freeName'
			if nameToken.value == "main" 'isMain'
				qualifiedName = nameToken.value
			end 'isMain' else 'qualifyNonMain'
				qualifiedName = qualifyName(namespace, name: nameToken.value)
			end 'qualifyNonMain'
			logTrace(LogCategory.parser, message: () gives "parser: function '{nameToken.value}'")
		end 'freeName'

		try expect(TokenKind.leftParen)

		var paramCount = 0
		var paramTypes = MaxonTypeArray.create()
		var paramNames = StringArray.create()
		var paramDefaults = ParamDefaultArray.create()

		// Instance methods get an implicit self pointer parameter, registered
		// before explicit parameters so the parameter order matches the
		// calling convention. Self is a named MaxonType matching the
		// enclosing type; lowerMaxonToStd resolves it to i64 (pointer width).
		if isInstance 'addSelfParam'
			_ = defineVariableWithType("__self", varType: internMaxonType(project, name: typeName))
			paramTypes.push(internMaxonType(project, name: typeName))
			paramNames.push("__self")
			paramDefaults.push(ParamDefault.none)
			paramCount = paramCount + 1
		end 'addSelfParam'

		try parseFunctionParameters(paramCount, paramTypes: paramTypes, paramNames: paramNames, paramDefaults: paramDefaults)
		try expect(TokenKind.rightParen)

		let returnType_ = try parseOptionalReturnType(isMethod: isMethod, typeName: typeName)
		// Capture the void-ness up front so we can release the `returnType_`
		// borrow before calling into parseStatements (which mutates self.cursor).
		let returnIsVoid = maxonReturnTypeIsVoid(returnType_)

		try skipThrowsClause()

		skipNewlines()

		var func = IrFunction.create(qualifiedName, maxonReturnType: returnType_, paramCount: paramCount, maxonParamTypes: paramTypes, returnLine: 0)
		// Carry the source-file namespace forward so LowerMaxonToStd can
		// resolve `CallContext.free` callees against `{namespace}.callee`
		// even when the function's own name is bare (e.g. main entrypoint).
		func.namespace = namespace
		// Register return type so callers can determine result kind. Display
		// the bare name for free functions and the qualified name for methods
		// in duplicate diagnostics.
		var funcIsDuplicate = false
		try project.funcReturnTypes.insert(qualifiedName, value: returnType_) otherwise 'dupFunc'
			funcIsDuplicate = true
			if isMethod 'methodDisplay'
				reportDuplicateFunction(qualifiedName, nameToken: nameToken)
			end 'methodDisplay' else 'freeDisplay'
				reportDuplicateFunction(nameToken.value, nameToken: nameToken)
			end 'freeDisplay'
		end 'dupFunc'
		// Register signature for call-site named-arg reordering and defaults.
		// Skip on duplicate — funcReturnTypes.insert already reported it and
		// the first signature entry wins. Also seed the method-name index so
		// DFE can dispatch dynamic methodCalls in O(matches) instead of
		// scanning the full function table.
		if not funcIsDuplicate 'registerSignature'
			try project.funcSignatures.insert(qualifiedName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise panic("funcSignatures.insert: duplicate for '{qualifiedName}' but funcReturnTypes reported none")
			project.methodNameIndex.record(qualifiedName)
		end 'registerSignature'
		var block = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: nameToken.line)
		// Seed the parser's current-function/block tracker — expression-level
		// short-circuit emission appends new blocks to currentFunc and updates
		// currentBlock so subsequent emissions land in the right place.
		currentFunc = func
		currentBlock = block

		// For instance methods, register each field as a self-field alias.
		// Reads/writes lower directly to fieldLoad/fieldStore through __self,
		// not to a local slot — so a nested call that mutates self.field sees
		// the new value on return (and the caller sees callee's mutations).
		if isInstance 'emitFieldAccess'
			for field in fields 'eachField'
				_ = scope.declareSelfField(field.name, varType: field.fieldType, offset: field.offset)
			end 'eachField'
		end 'emitFieldAccess'

		// Parse body
		var bodyReturns = false
		block = try parseStatements(module, func: func, block: block, lastWasReturn: bodyReturns)

		// Body aborted on an unexpected statement token — the parser has already
		// synchronized past this function. Suppress the missing-return cascade and
		// don't attempt to consume a closing `end`: it belongs to a top-level
		// construct that the outer loop will re-dispatch. The partial function
		// body is dropped: an error was already reported so no binary will be
		// produced, and registering it risks downstream passes tripping over
		// unterminated blocks.
		if abortBody 'aborted'
			// Keep abortBody=true so parseModule's compensating-advance logic
			// knows cursor is already parked at the next top-level opener.
			return
		end 'aborted'

		checkUnusedParameters()

		// Functions with a declared return type must terminate on every path —
		// report E3013 rather than silently falling through to an implicit 0.
		// Dead blocks are unreachable (isTerminated returns true) so they
		// trigger neither the implicit return nor the missing-return error.
		// Self-fields are aliased directly to __self so there is no writeback
		// phase: every field mutation already went through fieldStore.
		if not block.isTerminated() 'needsImplicitRet'
			if returnIsVoid 'emitVoid'
				emitImplicitReturn(module, block: block)
			end 'emitVoid' else 'reportMissing'
				reportCompileError(project, code: ErrorCode.semanticMissingReturn, message: "missing return statement: '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'reportMissing'
		end 'needsImplicitRet'

		// Hand the parser's per-function scope state off to the IrFunction so
		// it persists for downstream consumers. Today this is inspection-only;
		// later commits add the name-resolution query on top.
		func.scope = scope
		module.functions.push(func)

		// Skip 'end' and optional label string
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.
	end 'parseFunction'

	// --- Statement parsing ---

	// Record a statement's starting line against the block it will append to.
	// Looks up the flat blockRef within the current function's block set and
	// delegates to recordBlockLine for the de-dup-against-last append. When
	// the block is a detached dead sink (not in func.blockRefs) the findBlockRef
	// lookup throws and we silently drop the record — unreachable statements
	// don't contribute to coverage.
	function recordStmtLine(module MaxonModule, func IrFunction, block IrBlock, line LineNumber)
		let blockRef = try module.findBlockRef(func, block: block) otherwise return
		recordBlockLine(module.blockSourceInfo, blockRef: blockRef, line: line)
	end 'recordStmtLine'

	// Parse statements until 'end' is reached. Returns the current block.
	// Sets lastWasReturn to true if the last statement was a return.
	function parseStatements(module MaxonModule, func IrFunction, block IrBlock, lastWasReturn bool) returns IrBlock throws ParserError
		lastWasReturn = false

		// Dispatch-loop Pattern D: iterate over the cursor. Each helper exits
		// AT its last-consumed token; the for-header advances onto the next
		// statement's opener (or `end`, or terminates on cursor exhaustion).
		for stmtToken in cursor 'body'
			let stmtPrevPos = cursor.index()
			if stmtToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if stmtToken.kind == TokenKind.newline 'isBlank'
				continue
			end 'isBlank'

			lastWasReturn = false

			// Keep the parser's currentBlock tracker pointed at the block
			// statement-level helpers should emit into. Expression-internal
			// short-circuit emission may move it forward; we re-seed before
			// each statement so the new block is the entry block for that
			// statement's emissions.
			currentBlock = block
			recordStmtLine(module, func: func, block: block, line: stmtToken.line)

			if stmtToken.kind == TokenKind.return 'isReturn'
				if func.returnLine == 0 'noRetLine'
					func.returnLine = stmtToken.line
				end 'noRetLine'
				try parseReturnStatement(module, block: block)
				lastWasReturn = true
			end 'isReturn' else if stmtToken.kind == TokenKind.var or stmtToken.kind == TokenKind.let 'isVarDecl'
				try parseVarDecl(module, block: block)
				block = currentBlock
			end 'isVarDecl' else if stmtToken.kind == TokenKind.print 'isPrint'
				try parsePrintStatement(module, block: block)
				block = currentBlock
			end 'isPrint' else if stmtToken.kind == TokenKind.panic 'isPanic'
				try parsePanicStatement(module, block: block)
				lastWasReturn = true
			end 'isPanic' else if stmtToken.kind == TokenKind.if 'isIf'
				block = try parseIfStatement(module, func: func, block: block)
			end 'isIf' else if stmtToken.kind == TokenKind.while 'isWhile'
				block = try parseWhileStatement(module, func: func, block: block)
			end 'isWhile' else if stmtToken.kind == TokenKind.break 'isBreak'
				block = parseBreakStatement(module, func: func, block: block)
				lastWasReturn = true
			end 'isBreak' else if stmtToken.kind == TokenKind.continue 'isContinue'
				block = parseContinueStatement(module, func: func, block: block)
				lastWasReturn = true
			end 'isContinue' else if stmtToken.kind == TokenKind.identifier 'isIdent'
				try parseIdentifierStatement(module, block: block)
				block = currentBlock
			end 'isIdent' else if stmtToken.kind == TokenKind.self 'isSelfStmt'
				try parseSelfStatement(module, block: block)
				block = currentBlock
			end 'isSelfStmt' else 'unexpectedToken'
				reportUnexpectedToken()
			end 'unexpectedToken'

			// abortBody (from reportUnexpectedToken) means synchronizeToTopLevel
			// already parked cursor at next top-level opener; break so the
			// outer parseFunction can re-dispatch it.
			if abortBody 'aborted'
				break
			end 'aborted'

			// Stuck-guard: if cursor didn't advance, force advance to prevent
			// infinite loops on malformed input.
			if cursor.index() <= stmtPrevPos 'stmtStuck'
				try cursor.seek(stmtPrevPos + 1) otherwise panic("Parser.parseStatements: stmt-stuck seek({stmtPrevPos + 1}) out of bounds")
			end 'stmtStuck'
		end 'body'

		return block
	end 'parseStatements'

	// --- Identifier statement dispatch ---

	// Dispatches an identifier at statement level: assignment, function call, or error.
	function parseIdentifierStatement(module MaxonModule, block IrBlock) throws ParserError
		let peekToken = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
		if cursor.current().value == "_" and peekToken.kind == TokenKind.equals 'isDiscard'
			try parseDiscardAssignment(module, block: block)
			return
		end 'isDiscard' else if peekToken.kind == TokenKind.equals 'isAssign'
			try parseVarAssignment(module, block: block)
			return
		end 'isAssign' else if peekToken.kind == TokenKind.leftParen 'isCall'
			// Statement-level function call — parse as expression, discard result
			_ = try parseExpression(module, block: block)
			return
		end 'isCall' else if peekToken.kind == TokenKind.dot 'maybeDotCall'
			// Distinguish `TypeName.field = expr` (qualified-global store) from
			// other dot expressions (method calls, field access). The
			// qualified-store form is exactly identifier-dot-identifier-equals
			// AND the qualified name resolves to a known global var. Anything
			// else falls through to expression parsing so method chains and
			// field reads keep their existing handling.
			let afterDot = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
			let afterField = try cursor.peek(3) otherwise throw ParserError.unexpectedEof
			if afterDot.kind == TokenKind.identifier and afterField.kind == TokenKind.equals 'maybeQualified'
				let qualifiedName = "{cursor.current().value}.{afterDot.value}"
				if project.globalVars.contains(qualifiedName) 'isGlobalStore'
					try parseGlobalAssignment(module, block: block, qualifiedName: qualifiedName)
					return
				end 'isGlobalStore'
			end 'maybeQualified'
			// Dot call: variable.method(args) or Type.staticMethod(args) or field access
			_ = try parseExpression(module, block: block)
			return
		end 'maybeDotCall'

		reportUnexpectedToken()
	end 'parseIdentifierStatement'

	// Parse a statement starting with `self`: either `self.field = expr` (field
	// assignment) or any other `self.…` expression (method call, field read used
	// for its side effect). Cursor is AT `self` on entry.
	function parseSelfStatement(module MaxonModule, block IrBlock) throws ParserError
		let selfToken = cursor.current()
		if reportSelfOutsideType(selfToken) 'notInType'
			return
		end 'notInType'

		let dot1 = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
		if dot1.kind != TokenKind.dot 'notDot'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '.' after 'self'", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return
		end 'notDot'

		let fieldTok = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
		let afterField = try cursor.peek(3) otherwise throw ParserError.unexpectedEof

		if fieldTok.kind == TokenKind.identifier and afterField.kind == TokenKind.equals 'isSelfFieldAssign'
			let fieldName = fieldTok.value
			if not scope.isSelfField(fieldName) 'badField'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown field '{fieldName}' in type '{currentTypeName}'", line: fieldTok.line, column: fieldTok.column, filePath: filePath)
				return
			end 'badField'

			// peeks above proved the self-dot-identifier-equals shape.
			try expect(TokenKind.self)
			try expect(TokenKind.dot)
			try expect(TokenKind.identifier)
			try expect(TokenKind.equals)

			currentBlock = block
			let exprResult = try parseExpression(module, block: block)
			var emitBlock = currentBlock
			let stmtRange = SourceRange.between(selfToken, last: cursor.current())
			emitSelfFieldStore(module, block: emitBlock, fieldName: fieldName, valueName: exprName(exprResult), range: stmtRange)
			return
		end 'isSelfFieldAssign'

		_ = try parseExpression(module, block: block)
	end 'parseSelfStatement'

	// Parse `TypeName.fieldName = <expr>` for a registered static-field global.
	// Caller has verified the qualified name is in project.globalVars.
	function parseGlobalAssignment(module MaxonModule, block IrBlock, qualifiedName String) throws ParserError
		let nameToken = cursor.current()
		// Caller has proven identifier-dot-identifier-equals via peeks.
		try expect(TokenKind.identifier)
		try expect(TokenKind.dot)
		try expect(TokenKind.identifier)
		try expect(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(module, block: block)
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: cursor.current())
		emitGlobalStore(module, block: emitBlock, qualifiedName: qualifiedName, valueName: exprName(exprResult), range: stmtRange)
	end 'parseGlobalAssignment'

	// Look up a registered global by its qualified name. Caller is expected to
	// have already proved containment via `project.globalVars.contains(name)`;
	// the failure path is a programmer-error panic with the call-site label.
	function lookupGlobalVar(qualifiedName String, callSite String) returns GlobalVarInfo
		return try project.globalVars.get(qualifiedName) otherwise panic("{callSite}: globalVars.contains('{qualifiedName}') succeeded but get failed")
	end 'lookupGlobalVar'

	// Emit a maxon.global_load op and return the synth result name. Used by both
	// the bare-identifier and qualified-field read paths in parseIdentifierExpr.
	function emitGlobalLoad(module MaxonModule, block IrBlock, qualifiedName String, slotType MaxonType, range SourceRange) returns ByteArray
		let resultName = freshSynthName()
		module.appendOp(block, op: MaxonOp.globalLoad(resultName, name: qualifiedName, slotType: slotType, range: range))
		return resultName
	end 'emitGlobalLoad'

	// Emit a maxon.global_store op for the given qualified name and value.
	function emitGlobalStore(module MaxonModule, block IrBlock, qualifiedName String, valueName ByteArray, range SourceRange)
		let info = lookupGlobalVar(qualifiedName, callSite: "emitGlobalStore")
		module.appendOp(block, op: MaxonOp.globalStore(qualifiedName, value: valueName, slotType: info.slotType, range: range))
	end 'emitGlobalStore'

	// Reports an unexpected statement-level token and aborts the enclosing function
	// body. Mirrors the C# bootstrap's throw-to-top-level behavior: one error is
	// reported and recovery skips to the next top-level declaration. Continuing
	// inside the body would consume a stray `end 'label'` meant for an outer
	// construct and cascade into E3013 (missing return) at the real `end`.
	function reportUnexpectedToken()
		let stmtToken = cursor.current()
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token: '{tokenValueToString(stmtToken.value)}'", line: stmtToken.line, column: stmtToken.column, filePath: filePath)
		abortBody = true
		synchronizeToTopLevel()
	end 'reportUnexpectedToken'

	function reportUnexpectedTopLevel(token Token, module MaxonModule) returns MaxonModule
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected function declaration, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		return module
	end 'reportUnexpectedTopLevel'

	// Reports a duplicate top-level constant declaration at the given name token.
	function reportDuplicateConstant(nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateConstant'

	// Reports a duplicate function/method declaration. Callers pass the display
	// name separately because free functions use the bare name while methods
	// use the type-qualified name.
	function reportDuplicateFunction(displayName String, nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate function '{displayName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateFunction'

	// Reports a literal-overflow error at `token` with the fully-formatted
	// `message` and then consumes the literal token so parsing can continue
	// without cascading errors. Callers pass the pre-formatted message so each
	// site can keep its exact wording (int vs float, with/without range suffix).
	function reportLiteralOverflow(tokenKind TokenKind, token Token, message String) throws ParserError
		reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: message, line: token.line, column: token.column, filePath: filePath)
		try expect(tokenKind)
	end 'reportLiteralOverflow'

	// --- Top-level let ---

	// Parse top-level `let NAME = <expr>` — stores as compile-time constant.
	// Supports string literals and constant integer expressions.
	function parseTopLevelLet() throws ParserError
		try expect(TokenKind.let)

		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			synchronize()
			return
		end 'notEquals'

		try expect(TokenKind.equals)
		let valueToken = cursor.current()
		if valueToken.kind == TokenKind.doubleStringLiteral 'isString'
			try expect(TokenKind.doubleStringLiteral)
			// Interpolations have no compile-time meaning at top level —
			// the operand names they'd reference don't exist yet. Reject
			// explicitly rather than silently dropping the interpolation.
			if cursor.current().kind == TokenKind.stringInterpStart 'hasInterp'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "top-level let does not support string interpolation", line: valueToken.line, column: valueToken.column, filePath: filePath)
				synchronize()
				return
			end 'hasInterp'
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(valueToken.value)) otherwise 'dupConst1'
				reportDuplicateConstant(nameToken)
			end 'dupConst1'
			logTrace(LogCategory.parser, message: () gives "parser: const string '{nameToken.value}'")
			return
		end 'isString'

		// Single-quote strings are not valid top-level constants
		if valueToken.kind == TokenKind.stringLiteral 'isSingleQuoteString'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected constant expression, got '{valueToken.value}'", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'isSingleQuoteString'

		// Try to evaluate a compile-time integer constant expression
		let constValue = try evalConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Top-level let only supports string literals and constant integer expressions", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.intValue(constValue)) otherwise 'dupConst2'
			reportDuplicateConstant(nameToken)
		end 'dupConst2'
		logTrace(LogCategory.parser, message: () gives "parser: const int '{nameToken.value}' = {constValue}")
	end 'parseTopLevelLet'

	// Parse a mutable global declaration:
	//   `var NAME = <const-int-expr>`            (top-level)
	//   `static var NAME = <const-int-expr>`     (inside a type)
	// Stores a `GlobalVarInfo` keyed by the qualified name (`NAME` at the top
	// level, `TypeName.NAME` for a static field) so call sites can resolve the
	// name to a writable .data slot. Initial value must be a compile-time
	// constant integer or boolean literal; non-const initializers report a
	// diagnostic and synchronize without registering the global, so unresolved
	// reads downstream surface as the more familiar "Undefined variable" error.
	function parseTopLevelVar(typeName String) throws ParserError
		try expect(TokenKind.var)

		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			synchronize()
			return
		end 'notEquals'
		try expect(TokenKind.equals)

		let valueToken = cursor.current()
		let inferredType = inferGlobalVarType(valueToken)
		let constValue = try evalConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Top-level var only supports constant integer expressions", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		let qualifiedName = qualifyName(typeName, name: nameToken.value)

		let info = GlobalVarInfo.create(qualifiedName, slotType: inferredType, initialValue: constValue, mutable: true)
		try project.globalVars.insert(qualifiedName, value: info) otherwise 'dupGlobal'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate global '{qualifiedName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupGlobal'
		logTrace(LogCategory.parser, message: () gives "parser: global var '{qualifiedName}' = {constValue}")
	end 'parseTopLevelVar'

	// Pick the slot type for a global from the first token of its initializer.
	// `true`/`false` give boolean; everything else lands as integer (the existing
	// constant-expression path only yields ints today, so non-bool initializers
	// reuse the integer slot encoding without further inspection).
	function inferGlobalVarType(initToken Token) returns MaxonType
		if initToken.kind == TokenKind.true or initToken.kind == TokenKind.false 'isBool'
			return MaxonType.boolean
		end 'isBool'
		return MaxonType.integer
	end 'inferGlobalVarType'

	// Parse `static let NAME = <const-int-expr>` inside a type. The value is
	// inlined at every use site as a compile-time constant — no runtime
	// storage. The qualified name (`TypeName.NAME`) is registered in the
	// project's topLevelConstants map so qualified expression resolution can
	// substitute the integer value directly.
	function parseTopLevelStaticLet(typeName String) throws ParserError
		try expect(TokenKind.let)
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			synchronize()
			return
		end 'notEquals'
		try expect(TokenKind.equals)

		let valueToken = cursor.current()
		let constValue = try evalConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Static let only supports constant integer expressions", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		let qualifiedName = "{typeName}.{nameToken.value}"
		try project.topLevelConstants.insert(qualifiedName, value: ConstantValue.intValue(constValue)) otherwise 'dupStaticLet'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate static let '{qualifiedName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupStaticLet'
		logTrace(LogCategory.parser, message: () gives "parser: static let '{qualifiedName}' = {constValue}")
	end 'parseTopLevelStaticLet'

	// Evaluate a compile-time integer constant expression.
	// Supports: integer literals, hex literals, `not <expr>`, `-<expr>`,
	// references to previously declared `let` integer constants, and
	// `+`/`-` between operands of any of the above.
	function evalConstExpr() returns ParsedInt throws ParserError
		let lhs = try evalConstAtom()
		return try evalConstAddTail(lhs)
	end 'evalConstExpr'

	function evalConstAddTail(lhs ParsedInt) returns ParsedInt throws ParserError
		var acc = lhs
		while true 'tail'
			if tokenIs(TokenKind.plus) 'isPlus'
				let rhs = try evalConstAtom()
				acc = acc + rhs
			end 'isPlus' else if tokenIs(TokenKind.minus) 'isMinus'
				let rhs = try evalConstAtom()
				acc = acc - rhs
			end 'isMinus' else 'done'
				break
			end 'done'
		end 'tail'
		return acc
	end 'evalConstAddTail'

	function evalConstAtom() returns ParsedInt throws ParserError
		if tokenIs(TokenKind.not) 'isNot'
			return not try evalConstAtom()
		end 'isNot'

		if tokenIs(TokenKind.minus) 'isNeg'
			return 0 - try evalConstAtom()
		end 'isNeg'

		let token = cursor.current()

		if tokenIs(TokenKind.intLiteral) 'isInt'
			return try parseInt(token.value)
		end 'isInt'

		if tokenIs(TokenKind.true) 'isTrue'
			return 1
		end 'isTrue'

		if tokenIs(TokenKind.false) 'isFalse'
			return 0
		end 'isFalse'

		if token.kind == TokenKind.identifier 'isIdent'
			let constVal = try project.topLevelConstants.get(token.value) otherwise throw ParserError.unhandledToken
			let isInt = match constVal 'isIntKind'
				intValue gives true
				stringValue gives false
			end 'isIntKind'
			if not isInt 'notInt'
				throw ParserError.unhandledToken
			end 'notInt'
			_ = try consume()
			return match constVal 'unwrap'
				intValue(v) gives v
				default panic("evalConstAtom: impossible stringValue arm — isInt guard above guarantees intValue")
			end 'unwrap'
		end 'isIdent'

		throw ParserError.unhandledToken
	end 'evalConstAtom'

	// --- Export dispatch ---

	// entry: cursor AT `export`.
	// exit:  for function/type re-dispatch, leaves cursor AT `function`/`type`
	//        so main loop re-dispatches. for typealias, after typealias body.
	function parseExport() throws ParserError
		try expect(TokenKind.export)  // caller has dispatched on 'export'

		if cursor.current().kind == TokenKind.function 'isExportFunc'
			return
		end 'isExportFunc' else if cursor.current().kind == TokenKind.typealias 'isExportTypealias'
			try parseTopLevelTypealias()
		end 'isExportTypealias' else if cursor.current().kind == TokenKind.type 'isExportType'
			return
		end 'isExportType' else 'isExportOther'
			skipToNextLine()
		end 'isExportOther'
	end 'parseExport'

	// --- Typealias parsing ---

	// Parse: typealias Name = int(LOWER to UPPER) | float(LOWER to UPPER) | bool | ...
	// Registers primitive-backed typealiases in the project's type registry.
	// Computes optimal IR type from the range bounds (e.g. int(0 to u32.max) → u32).
	function parseTopLevelTypealias() throws ParserError
		try expect(TokenKind.typealias)
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'noEquals'
			skipToNextLine()
			return
		end 'noEquals'
		try expect(TokenKind.equals)

		let baseToken = cursor.current()

		var resolvedStdType = StdType.i64
		var sawValidBase = false

		if baseToken.kind == TokenKind.bool 'isBool'
			// bool typealiases map to i1 at the Std level.
			resolvedStdType = StdType.i1
			sawValidBase = true
		end 'isBool'

		// Track an optional integer range so we can register it after the main
		// typealias insert succeeds. Float aliases and bare `bool` leave the
		// range empty.
		var hasRange = false
		var rangeLower = 0 as BoundValue
		var rangeUpper = 0 as BoundValue
		if baseToken.kind == TokenKind.int or baseToken.kind == TokenKind.float or baseToken.kind == TokenKind.byte 'isNumeric'
			let isFloat = baseToken.kind == TokenKind.float
			let isByte = baseToken.kind == TokenKind.byte
			try expect(baseToken.kind)

			let parenToken = cursor.current()
			if parenToken.kind != TokenKind.leftParen 'noParen'
				var example = "int(0 to 100)"
				if isFloat 'floatEx'
					example = "float(f64.min to f64.max)"
				end 'floatEx' else if isByte 'byteEx'
					example = "byte(0 to u8.max)"
				end 'byteEx'
				reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "typealias '{nameToken.value}' requires range bounds, e.g. {example}", line: baseToken.line, column: baseToken.column, filePath: filePath)
				skipToNextLine()
				return
			end 'noParen'

			try expect(TokenKind.leftParen)

			let lowerBound = try parseTypeBound()
			try advance()  // past last-consumed of lowerBound

			if cursor.current().kind == TokenKind.to 'hasTo'
				try expect(TokenKind.to)
			end 'hasTo'

			let upperBound = try parseTypeBound()

			if isFloat 'computeFloat'
				resolvedStdType = StdType.f64
			end 'computeFloat' else 'computeInt'
				// `byte(lo to hi)` is just an unsigned integer alias; let
				// computeOptimalIntType pick the narrowest width (u8 for 0..255).
				resolvedStdType = computeOptimalIntType(lower: lowerBound, upper: upperBound)
				hasRange = true
				rangeLower = lowerBound
				rangeUpper = upperBound
			end 'computeInt'
			sawValidBase = true
		end 'isNumeric'

		if not sawValidBase 'unsupported'
			skipToNextLine()
			return
		end 'unsupported'

		// Register the alias first so the range entry only lands when this is
		// the first definition — duplicates report the canonical error here and
		// leave both maps pointing at the original.
		var aliasIsDuplicate = false
		try project.typealiases.insert(nameToken.value, value: resolvedStdType) otherwise 'dupAlias'
			aliasIsDuplicate = true
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate typealias '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupAlias'
		if not aliasIsDuplicate and hasRange 'recordRange'
			try project.typealiasRanges.insert(nameToken.value, value: TypealiasRange.create(rangeLower, upper: rangeUpper)) otherwise panic("typealiasRanges.insert: '{nameToken.value}' duplicate but typealiases.insert accepted it")
		end 'recordRange'
		skipToNextLine()
	end 'parseTopLevelTypealias'

	// --- Type declaration parsing ---

	// Replay-loop dispatch: seek-and-parse a single type-body member. The
	// caller (parseTypeDecl) has already advanced past any `export` modifier;
	// each per-member helper consumes its own opening keyword.
	function dispatchTypeMember(module MaxonModule, kind MemberKind, typeName String, fields StructFieldArray) throws ParserError
		if isInstanceMethodKind(kind) 'inst'
			try parseFunction(module, typeName: typeName, isInstance: true, fields: fields)
			return
		end 'inst'
		if isStaticMethodKind(kind) 'sm'
			try parseStaticMethod(module, typeName: typeName, fields: fields)
			return
		end 'sm'
		if isStaticVarKind(kind) 'sv'
			try parseStaticVar(typeName: typeName)
			return
		end 'sv'
		if isStaticLetKind(kind) 'sl'
			try parseStaticLet(typeName: typeName)
			return
		end 'sl'
	end 'dispatchTypeMember'

	function isInstanceMethodKind(kind MemberKind) returns bool
		return match kind 'check'
			instanceMethod gives true
			staticMethod gives false
			staticVar gives false
			staticLet gives false
		end 'check'
	end 'isInstanceMethodKind'

	function isStaticMethodKind(kind MemberKind) returns bool
		return match kind 'check'
			staticMethod gives true
			instanceMethod gives false
			staticVar gives false
			staticLet gives false
		end 'check'
	end 'isStaticMethodKind'

	function isStaticVarKind(kind MemberKind) returns bool
		return match kind 'check'
			staticVar gives true
			instanceMethod gives false
			staticMethod gives false
			staticLet gives false
		end 'check'
	end 'isStaticVarKind'

	function isStaticLetKind(kind MemberKind) returns bool
		return match kind 'check'
			staticLet gives true
			instanceMethod gives false
			staticMethod gives false
			staticVar gives false
		end 'check'
	end 'isStaticLetKind'

	function parseStaticMethod(module MaxonModule, typeName String, fields StructFieldArray) throws ParserError
		try expect(TokenKind.static)
		try parseFunction(module, typeName: typeName, isInstance: false, fields: fields)
	end 'parseStaticMethod'

	function parseStaticVar(typeName String) throws ParserError
		try expect(TokenKind.static)
		try parseTopLevelVar(typeName: typeName)
	end 'parseStaticVar'

	function parseStaticLet(typeName String) throws ParserError
		try expect(TokenKind.static)
		try parseTopLevelStaticLet(typeName: typeName)
	end 'parseStaticLet'

	// Parse: type Name ... end 'Name'
	//
	// Single linear walk over the body that:
	//   - collects fields directly (cheap, single-line),
	//   - bookmarks every static var/let, static function, and instance
	//     function for replay AFTER the StructType is registered,
	//   - never re-walks tokens it has already classified.
	// The bookmark-replay step is required (not just a perf optimization)
	// because method-body parsing calls `lookupFieldTypeForChain` /
	// `lookupMethodReturnTypeForChain`, which probe `project.structTypes`
	// for the enclosing type — so the type must be registered before any
	// method body is parsed. The bookmarks let pass 2 seek directly to
	// each member's first token without re-skipping fields or other
	// methods' bodies.
	function parseTypeDecl(module MaxonModule) throws ParserError
		try expect(TokenKind.type)
		let typeNameToken = try consume()
		checkReservedDeclName(typeNameToken)
		let typeName = typeNameToken.value
		currentTypeName = typeName
		logTrace(LogCategory.parser, message: () gives "parser: type '{typeName}'")
		skipNewlines()

		var fields = StructFieldArray.create()
		var fieldOffset = 0 as FieldOffset
		var bookmarks = MemberBookmarkArray.create()

		while true 'scanFields'
			let memberToken = cursor.current()
			let scanFieldsPrevPos = cursor.index()
			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			// Capture the bookmark anchor BEFORE consuming the optional
			// `export` modifier so pass 2's seek lands on the same token
			// pass 1 saw — the per-member helpers already know how to skip
			// `export` themselves.
			let memberStart = cursor.index()
			if memberToken.kind == TokenKind.export 'skipExport'
				try expect(TokenKind.export)
			end 'skipExport'
			let kindToken = cursor.current()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'isField'
				try expect(kindToken.kind)
				let fieldNameToken = try consume()
				checkReservedDeclName(fieldNameToken)
				let fieldTypeToken = try consume()
				fields.push(StructField.create(fieldNameToken.value, fieldType: internMaxonType(project, name: fieldTypeToken.value), offset: fieldOffset))
				fieldOffset = fieldOffset + 8
				skipNewlines()
			end 'isField' else if kindToken.kind == TokenKind.static 'isStaticMember'
				// `static var`/`static let` are top-level value declarations
				// (single-line); `static function` is a method body whose
				// matching `end` we walk past via skipMethodBody.
				let afterStatic = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
				if afterStatic.kind == TokenKind.var 'isStaticVar'
					bookmarks.push(MemberBookmark.create(memberStart, kind: MemberKind.staticVar))
					skipToNextLine()
					skipNewlines()
				end 'isStaticVar' else if afterStatic.kind == TokenKind.let 'isStaticLet'
					bookmarks.push(MemberBookmark.create(memberStart, kind: MemberKind.staticLet))
					skipToNextLine()
					skipNewlines()
				end 'isStaticLet' else 'isStaticMethod'
					bookmarks.push(MemberBookmark.create(memberStart, kind: MemberKind.staticMethod))
					skipToNextLine()
					skipNewlines()
					try skipMethodBody()
					skipNewlines()
				end 'isStaticMethod'
			end 'isStaticMember' else if kindToken.kind == TokenKind.function 'isInstanceMethod'
				bookmarks.push(MemberBookmark.create(memberStart, kind: MemberKind.instanceMethod))
				skipToNextLine()
				skipNewlines()
				try skipMethodBody()
				skipNewlines()
			end 'isInstanceMethod' else 'skipOther'
				skipToNextLine()
				skipNewlines()
			end 'skipOther'

			// Stuck-guard: if no helper made forward progress this iteration,
			// force-advance so a malformed type body cannot infinite-loop the
			// compile. A non-terminating compile is the worst possible failure
			// mode for the spec-test runner, which has no in-process timeout.
			if cursor.index() <= scanFieldsPrevPos 'stuckScan'
				try cursor.seek(scanFieldsPrevPos + 1) otherwise break
			end 'stuckScan'
		end 'scanFields'

		// `cursor` now sits on the type's terminal `end` — capture so we
		// can restore it after the bookmark replay below.
		let typeEndPos = cursor.index()

		// Register the struct type. Method bodies parsed below probe this
		// via lookupFieldTypeForChain / lookupMethodReturnTypeForChain, so
		// it must exist before any method body runs.
		let structType = StructType.create(typeName, fields: fields, byteSize: fieldOffset)
		try project.structTypes.insert(typeName, value: structType) otherwise 'dupType'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate type '{typeName}'", line: typeNameToken.line, column: typeNameToken.column, filePath: filePath)
		end 'dupType'

		// Replay bookmarks: seek to each member's start and parse it. Every
		// per-member helper consumes the optional `export` modifier and the
		// `static`/`function`/`var`/`let` keyword as part of its own
		// dispatch, so we don't need to re-eat those here.
		for bookmark in bookmarks 'replay'
			try cursor.seek(bookmark.startIndex) otherwise panic("Parser.parseTypeDecl: bookmark seek({bookmark.startIndex}) out of bounds")
			if cursor.current().kind == TokenKind.export 'skipReplayExport'
				try expect(TokenKind.export)
			end 'skipReplayExport'
			try dispatchTypeMember(module, kind: bookmark.kind, typeName: typeName, fields: fields)
		end 'replay'

		// Reposition on the type's terminal `end` for skipEndAndLabel.
		try cursor.seek(typeEndPos) otherwise panic("Parser.parseTypeDecl: typeEnd seek({typeEndPos}) out of bounds")
		currentTypeName = ""
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.
	end 'parseTypeDecl'

	// Write modified field values back to the struct pointer before returning.
	function emitFieldWritebacks(module MaxonModule, block IrBlock, nameToken Token, fields StructFieldArray)
		let selfLoadName = emitSelfLoad(module, block: block, token: nameToken, range: SourceRange.none())

		for field in fields 'eachField'
			if let fieldSlot = try scope.lookup(field.name) 'hasField'
				let fieldValName = freshSynthName()
				module.appendOp(block, op: MaxonOp.varLoad(fieldValName, slotId: fieldSlot, slotType: field.fieldType, range: SourceRange.none()))
				module.appendOp(block, op: MaxonOp.fieldStore(selfLoadName, fieldName: field.name.toByteArray(), value: fieldValName, range: SourceRange.none()))
			end 'hasField'
		end 'eachField'
	end 'emitFieldWritebacks'

	// Skip over a method body in the first pass of type parsing.
	// Scans token-by-token counting nested block-opening keywords (if/while/
	// for/match/else) to find the matching `end` for this method. For-loop
	// header advances each iteration; body updates depth and breaks when the
	// method's own `end` is reached so try skipEndAndLabel() can consume it.
	function skipMethodBody() throws ParserError
		var depth = 1
		for token in cursor 'skip'
			if token.kind == TokenKind.end 'isEnd'
				depth = depth - 1
				if depth == 0 'atMethodEnd'
					try skipEndAndLabel()
					return
				end 'atMethodEnd'
			end 'isEnd' else if token.kind == TokenKind.if or token.kind == TokenKind.while or token.kind == TokenKind.for or token.kind == TokenKind.match or token.kind == TokenKind.else 'opensBlock'
				depth = depth + 1
			end 'opensBlock'
		end 'skip'
	end 'skipMethodBody'

	// Parse a type bound: a number literal, negative literal, or T.min/T.max.
	// Mutates pos and returns just BoundValue.
	// entry: cursor AT first token of the bound (minus, intLit, or identifier).
	// exit:  cursor AT last-consumed token of the bound.
	function parseTypeBound() returns BoundValue throws ParserError
		let token = cursor.current()

		if token.kind == TokenKind.minus 'isNeg'
			let numToken = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
			let value = try parseInt(numToken.value) otherwise 'negOverflow'
				reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(numToken.value)}' is outside the range of int", line: numToken.line, column: numToken.column, filePath: filePath)
				try expect(TokenKind.minus)
				return 0
			end 'negOverflow'
			try expect(TokenKind.minus)
			return 0 - value
		end 'isNeg'

		if token.kind == TokenKind.intLiteral 'isLit'
			let value = try parseInt(token.value) otherwise 'litOverflow'
				try reportLiteralOverflow(TokenKind.intLiteral, token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int")
				return 0
			end 'litOverflow'
			return value
		end 'isLit'

		let afterIdent = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
		if token.kind == TokenKind.identifier and afterIdent.kind == TokenKind.dot 'maybeTypeBound'
			let fieldToken = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
			if fieldToken.kind == TokenKind.identifier 'hasField'
				let bound = resolveTypeBound(token.value, field: fieldToken.value)
				try expect(TokenKind.identifier)
				try expect(TokenKind.dot)
				return bound
			end 'hasField'
		end 'maybeTypeBound'

		return 0
	end 'parseTypeBound'

	// --- Return statement ---

	// entry: cursor AT `return`.
	// exit:  cursor AT last-consumed token (`return` for void-return; last
	//        token of the return expression otherwise).
	function parseReturnStatement(module MaxonModule, block IrBlock) throws ParserError
		let returnToken = cursor.current()
		let nextTok = try cursor.peek(1) otherwise 'noNext'
			emitImplicitReturn(module, block: block)
			return
		end 'noNext'
		if nextTok.kind == TokenKind.newline or nextTok.kind == TokenKind.end 'bareReturn'
			emitImplicitReturn(module, block: block)
			return
		end 'bareReturn'

		try expect(TokenKind.return)
		currentBlock = block
		let resultExpr = try parseExpression(module, block: block)
		let lastExprToken = cursor.current()
		// currentBlock holds the block control-flow landed on after the
		// expression — if the rhs of a bool `and`/`or` triggered short-circuit
		// emission, that's a merge block, not the original `block`.
		module.setTerminator(currentBlock, op: MaxonOp.ret(exprName(resultExpr), range: SourceRange.between(returnToken, last: lastExprToken)))
	end 'parseReturnStatement'

	// Emits MaxonOp.panic with a location-prefixed message for the stack trace.
	// entry: cursor AT `panic`.
	// exit:  cursor AT `)`.
	function parsePanicStatement(module MaxonModule, block IrBlock) throws ParserError
		let panicToken = cursor.current()
		try expect(TokenKind.panic)  // caller has already dispatched on 'panic'
		try expect(TokenKind.leftParen)
		let msgToken = cursor.current()
		try expect(TokenKind.doubleStringLiteral)
		// Runtime panic interpolation isn't implemented in the self-hosted
		// compiler yet. Report an error rather than silently dropping the
		// interpolation (which would print the pre-`{` fragment only).
		if cursor.current().kind == TokenKind.stringInterpStart 'hasInterp'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "panic interpolation is not supported in the self-hosted compiler", line: msgToken.line, column: msgToken.column, filePath: filePath)
			synchronize()
			return
		end 'hasInterp'
		let rparenToken = cursor.current()

		let fileName = filePath.filename()
		let fullMsg = "panic at {fileName}:{panicToken.line}: {msgToken.value}"
		module.appendOp(block, op: MaxonOp.panic(fullMsg, range: SourceRange.between(panicToken, last: rparenToken)))
	end 'parsePanicStatement'

	// --- If statement ---

	// Parse: if <condition> 'label' ... end 'label' [else 'label' ... end 'label']
	// Returns the merge block to continue emitting into.
	// entry: cursor AT `if`.
	// exit:  cursor AT last-consumed (the final `end` or label).
	function parseIfStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let ifToken = cursor.current()
		try expect(TokenKind.if)

		// Seed currentBlock so a bool short-circuit in the condition appends to
		// the right place; recover the post-condition block afterwards because
		// short-circuit may have advanced control flow to a merge block.
		currentBlock = block
		let condResult = try parseExpression(module, block: block)
		let condBlock = currentBlock
		// parseExpression exits AT last-consumed of condition.
		try advance()  // past condition onto optional label OR newline

		let userLabel = try parseOptionalBlockLabel("if")
		// parseOptionalBlockLabel consumes through newlines (old contract); leaves
		// cursor at first token of the body.

		let ifFilePath = filePath.toString()
		var thenBlock = module.addBlockAt(func, label: userLabel, filePath: ifFilePath, firstLine: ifToken.line)
		let thenBlockId = thenBlock.id
		let baseLabel = "{userLabel}_{thenBlockId}"
		thenBlock.label = baseLabel

		let thenExit = try parseScopedStatements(module, func: func, block: thenBlock)
		// parseScopedStatements exits with cursor AT `end` (the body's terminator).

		try skipEndAndLabel()
		// cursor now AT `end` or label. Advance past into whitespace.
		try advance()
		skipNewlines()

		if cursor.current().kind == TokenKind.else 'hasElse'
			let elseToken = cursor.current()
			try expect(TokenKind.else)

			var elseLabel = "{baseLabel}.else"

			if cursor.current().kind == TokenKind.if 'isElseIf'
				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				// Capture the id BEFORE the recursive parse — parseIfStatement may
				// add more blocks, which can invalidate the `elseBlock` struct
				// reference under the IR's block-array growth semantics.
				let elseBlockId = elseBlock.id
				let elseIfExit = try parseIfStatement(module, func: func, block: elseBlock)
				return finalizeIfElseById(module, func: func, condBlock: condBlock, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseIfExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'isElseIf' else 'plainElse'
				if cursor.current().kind == TokenKind.stringLiteral 'hasElseLabel'
					elseLabel = "{cursor.current().value}_{func.nextBlockId}"
					try expect(TokenKind.stringLiteral)
					expectNewlineAfterLabel()
				end 'hasElseLabel' else 'noElseLabel'
					skipNewlines()
				end 'noElseLabel'

				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				// Capture id before parseScopedStatements — subsequent block adds
				// may invalidate the `elseBlock` struct reference.
				let elseBlockId = elseBlock.id
				let elseExit = try parseScopedStatements(module, func: func, block: elseBlock)
				try skipEndAndLabel()
				// cursor AT final `end` / label — exit AT last-consumed.
				return finalizeIfElseById(module, func: func, condBlock: condBlock, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'plainElse'
		end 'hasElse'

		// No else clause. Above we advanced past the then-block's end/label and
		// ran skipNewlines to see if an `else` followed. Since there wasn't
		// one, we've already moved past last-consumed; retreat so exit is AT
		// last-consumed.
		try cursor.retreat() otherwise panic("Parser.parseIfStatement: retreat from post-then-block position failed at index {cursor.index()}")
		let afterBlock = module.addBlockAt(func, label: "{baseLabel}.after", filePath: ifFilePath, firstLine: cursor.current().line)
		branchIfNeeded(module, block: thenExit, target: afterBlock.id)
		module.setTerminator(condBlock, op: MaxonOp.condBr(exprName(condResult), thenTarget: thenBlockId, elseTarget: afterBlock.id, range: SourceRange.none()))
		return afterBlock
	end 'parseIfStatement'

	// --- While statement ---

	// Parse: while <condition> 'label' ... end 'label'
	// Returns the exit block to continue emitting into.
	// entry: cursor AT `while`.
	// exit:  cursor AT the final `end` token (or its label).
	function parseWhileStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let whileToken = cursor.current()
		try expect(TokenKind.while)

		// Create cond block first (we need it to parse the condition into).
		// All three loop blocks (header, body, exit) open at the `while` token —
		// coverage-wise the whole construct is one statement, and the exit block
		// is reached right after the condition fails at that same line.
		let whileFilePath = filePath.toString()
		var condBlock = module.addBlockAt(func, label: "cond", filePath: whileFilePath, firstLine: whileToken.line)
		let condBlockId = condBlock.id

		// Branch from entry block to cond block
		module.setTerminator(block, op: MaxonOp.br(condBlockId, range: SourceRange.none()))

		// Parse condition in condBlock. Bool short-circuit may move control
		// flow off condBlock to a fresh merge block — capture it.
		currentBlock = condBlock
		let condResult = try parseExpression(module, block: condBlock)
		let condExitBlock = currentBlock
		try advance()  // past last-consumed of condition

		// Read the user's block label and derive unique labels
		let userLabel = try parseOptionalBlockLabel("loop")

		// Derive base label: userLabel_<blockId>
		let baseLabel = "{userLabel}_{condBlockId}"

		// Rename condBlock to baseLabel.header
		condBlock.label = "{baseLabel}.header"

		// Create body and exit blocks with derived labels
		var bodyBlock = module.addBlockAt(func, label: baseLabel, filePath: whileFilePath, firstLine: whileToken.line)
		let bodyBlockId = bodyBlock.id
		let exitBlock = module.addBlockAt(func, label: "{baseLabel}.exit", filePath: whileFilePath, firstLine: whileToken.line)
		let exitBlockId = exitBlock.id

		// condBlock terminator: if true -> bodyBlock, if false -> exitBlock.
		// When the condition triggered short-circuit emission, the cond_br
		// belongs on the merge block where the bool value materialized, not
		// the original condBlock.
		module.setTerminator(condExitBlock, op: MaxonOp.condBr(exprName(condResult), thenTarget: bodyBlockId, elseTarget: exitBlockId, range: SourceRange.none()))

		// Push loop context for break/continue
		loopStack.push(LoopContext.create(userLabel, headerBlockId: condBlockId, exitBlockId: exitBlockId))

		// Parse body in bodyBlock
		let bodyExit = try parseScopedStatements(module, func: func, block: bodyBlock)

		// Pop the loop context we pushed above. The stack can't be empty here —
		// we own both the matching push and the intermediate parse call.
		try loopStack.pop() otherwise panic("loopStack.pop: stack unexpectedly empty after while-body parse")

		// Loop back to cond block if body doesn't terminate
		branchIfNeeded(module, block: bodyExit, target: condBlockId)

		// Skip 'end' and optional label string
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.

		return exitBlock
	end 'parseWhileStatement'

	// --- Break / continue statements ---

	// Parse: break [label]  or  continue [label]
	// Emits an unconditional branch to the loop exit or header block, then
	// returns a fresh detached block so later statements are unreachable.
	// entry: cursor AT `break` or `continue`.
	// exit:  cursor AT the keyword (unlabeled) or AT the label string (labeled).
	function parseBreakStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock
		let breakToken = cursor.current()
		if loopStack.count() == 0 'notInLoop'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'break' can only be used inside a loop", line: breakToken.line, column: breakToken.column, filePath: filePath)
			return block
		end 'notInLoop'

		let targetId = resolveLoopTarget(useExit: true)
		module.setTerminator(block, op: MaxonOp.br(targetId, range: SourceRange.none()))
		return newDetachedBlock(func)
	end 'parseBreakStatement'

	function parseContinueStatement(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock
		let continueToken = cursor.current()
		if loopStack.count() == 0 'notInLoop'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'continue' can only be used inside a loop", line: continueToken.line, column: continueToken.column, filePath: filePath)
			return block
		end 'notInLoop'

		let targetId = resolveLoopTarget(useExit: false)
		module.setTerminator(block, op: MaxonOp.br(targetId, range: SourceRange.none()))
		return newDetachedBlock(func)
	end 'parseContinueStatement'

	// Resolve the jump target for break (useExit=true) or continue (useExit=false),
	// consuming an optional label token when present.
	// entry: cursor AT `break` or `continue`.
	// exit:  cursor AT the keyword (unlabeled) or AT the label string (labeled).
	function resolveLoopTarget(useExit bool) returns BlockId
		let innermostCtx = try loopStack.get(loopStack.count() - 1) otherwise panic("resolveLoopTarget: empty loopStack")
		let target = innermostCtx.exitBlockId if useExit else innermostCtx.headerBlockId

		let nextTok = try cursor.peek(1) otherwise 'noNext'
			return target
		end 'noNext'
		if nextTok.kind != TokenKind.stringLiteral 'noLabel'
			return target
		end 'noLabel'

		try cursor.advance() otherwise panic("resolveLoopTarget: advance past keyword failed")
		let labelToken = cursor.current()

		for i in 0 upto loopStack.count() 'search'
			let ctx = try loopStack.get(loopStack.count() - 1 - i) otherwise panic("resolveLoopTarget: loop index out of bounds")
			if ctx.sourceLabel == labelToken.value 'found'
				return ctx.exitBlockId if useExit else ctx.headerBlockId
			end 'found'
		end 'search'

		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "No enclosing loop with label '{labelToken.value}'", line: labelToken.line, column: labelToken.column, filePath: filePath)
		return target
	end 'resolveLoopTarget'

	// --- Discard assignment ---

	// Parse: _ = expression (discard function result)
	// Uses parserNextSlot as a unique suffix since it increments with each variable
	// entry: cursor AT `_`.
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseDiscardAssignment(module MaxonModule, block IrBlock) throws ParserError
		// Dispatched on identifier `_` followed by `=`; both positions proven.
		try expect(TokenKind.identifier)
		try expect(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(module, block: block)
		// Emit into the block control flow landed on — bool short-circuit may
		// have moved it off `block` to a merge block.
		var emitBlock = currentBlock
		let discardName = "__discard_{scope.nextSlot}"
		let slot = defineVariableWithType(discardName, varType: exprType(exprResult))
		module.appendOp(emitBlock, op: MaxonOp.varDecl(slot, value: exprName(exprResult), slotType: exprType(exprResult), range: SourceRange.none()))
	end 'parseDiscardAssignment'

	// --- Variable assignment ---

	// Parse: identifier = expression (variable reassignment)
	// entry: cursor AT the identifier (LHS).
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseVarAssignment(module MaxonModule, block IrBlock) throws ParserError
		let nameToken = cursor.current()
		// Dispatched on `identifier` followed by `=`; advance through both.
		try expect(TokenKind.identifier)
		try expect(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(module, block: block)
		// Emit into the block control flow landed on — bool short-circuit may
		// have moved it off `block` to a merge block.
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: cursor.current())
		// A bare identifier on the LHS may name a top-level `var`. Locals
		// shadow globals, so we check the scope first; only if no local binding
		// exists do we treat it as a global store.
		if not scope.contains(nameToken.value) and project.globalVars.contains(nameToken.value) 'globalWrite'
			emitGlobalStore(module, block: emitBlock, qualifiedName: nameToken.value, valueName: exprName(exprResult), range: stmtRange)
			return
		end 'globalWrite'
		let slot = lookupVariable(nameToken.value, token: nameToken)
		if scope.isSelfField(nameToken.value) 'selfFieldWrite'
			// Implicit self-load and field-store share the statement's range —
			// the user wrote `field = value`, not a separate self-load op.
			emitSelfFieldStore(module, block: emitBlock, fieldName: nameToken.value, valueName: exprName(exprResult), range: stmtRange)
		end 'selfFieldWrite' else 'localWrite'
			module.appendOp(emitBlock, op: MaxonOp.varStore(slot, value: exprName(exprResult), range: stmtRange))
		end 'localWrite'
	end 'parseVarAssignment'

	// --- Variable declaration ---

	// entry: cursor AT `var` or `let`.
	// exit:  cursor AT last-consumed of the RHS expression.
	function parseVarDecl(module MaxonModule, block IrBlock) throws ParserError
		let kwToken = cursor.current()
		let isLet = kwToken.kind == TokenKind.let
		// Caller dispatched on `var`/`let`; consume the keyword.
		if isLet 'letKw'
			try expect(TokenKind.let)
		end 'letKw' else 'varKw'
			try expect(TokenKind.var)
		end 'varKw'

		let nameToken = cursor.current()
		try expect(TokenKind.identifier)
		checkReservedDeclName(nameToken)

		let equalsToken = cursor.current()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			let tokStr = tokenValueToString(equalsToken.value)
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokStr}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			_ = defineVariableWithType(nameToken.value, varType: MaxonType.integer)
			synchronize()
			return
		end 'notEquals'

		try expect(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(module, block: block)
		// Emit the varDecl into the block control flow landed on — bool
		// short-circuit may have moved it off `block` to a merge block.
		var emitBlock = currentBlock

		if isLet and exprIsStringConst(exprResult) 'registerStringConst'
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(exprStringConstValue(exprResult))) otherwise 'dupConst3'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'dupConst3'
			_ = defineVariableWithType(nameToken.value, varType: exprType(exprResult))
			return
		end 'registerStringConst'

		let lastExprToken = cursor.current()
		let slot = defineVariableWithType(nameToken.value, varType: exprType(exprResult))
		module.appendOp(emitBlock, op: MaxonOp.varDecl(slot, value: exprName(exprResult), slotType: exprType(exprResult), range: SourceRange.between(kwToken, last: lastExprToken)))
	end 'parseVarDecl'

	// --- Print statement ---

	// entry: cursor AT `print`.
	// exit:  cursor AT `)`.
	//
	// The lexer splits double-quoted strings into a stream of
	//   doubleStringLiteral (fragment) [stringInterpStart <expr tokens> stringInterpEnd doubleStringLiteral (fragment)]*
	// so we consume each segment from the main cursor: fragments become
	// printLiteral ops (with escape decoding), and each bracketed expression
	// parses as a normal expression whose value is emitted as printInt.
	function parsePrintStatement(module MaxonModule, block IrBlock) throws ParserError
		try expect(TokenKind.print)  // caller has already dispatched on 'print'
		try expect(TokenKind.leftParen)
		let strToken = cursor.current()
		try expect(TokenKind.doubleStringLiteral)
		try emitFragmentLiteral(module, block: block, fragment: strToken.value)
		while cursor.current().kind == TokenKind.stringInterpStart 'interp'
			try expect(TokenKind.stringInterpStart)
			currentBlock = block
			let exprResult = try parseExpression(module, block: block)
			// parseExpression exits AT last-consumed of the interpolation
			// expression; advance onto the closing marker so `expect` consumes it.
			try advance()
			try expect(TokenKind.stringInterpEnd)
			module.appendOp(block, op: MaxonOp.printInt(exprName(exprResult), range: SourceRange.none()))
			let nextFrag = cursor.current()
			assertFragmentAfterInterpEnd(callerName: "parsePrintStatement", token: nextFrag)
			try expect(TokenKind.doubleStringLiteral)
			try emitFragmentLiteral(module, block: block, fragment: nextFrag.value)
		end 'interp'
	end 'parsePrintStatement'

	// Lexer invariant: every stringInterpEnd is followed by a doubleStringLiteral
	// fragment (possibly empty when the interpolation is adjacent to the closing
	// `"`). Anything else means the lexer broke its contract — panic with caller
	// context so the bug shows where it surfaced.
	function assertFragmentAfterInterpEnd(callerName String, token Token)
		if token.kind != TokenKind.doubleStringLiteral 'noFrag'
			panic("{callerName}: expected doubleStringLiteral fragment after stringInterpEnd, got {token.kind.name}")
		end 'noFrag'
	end 'assertFragmentAfterInterpEnd'

	// Decode escape sequences (`\n`, `\t`, `\\`, `\"`) in a string fragment and
	// emit a printLiteral op. Empty fragments produce no op — the lexer emits a
	// zero-width doubleStringLiteral whenever an interpolation butts up against
	// the opening `"` or closing `"`, and we want the IR to reflect only the
	// non-empty literal runs.
	function emitFragmentLiteral(module MaxonModule, block IrBlock, fragment String) throws ParserError
		let fragBytes = fragment.toByteArray()
		let fragLen = fragBytes.count()
		if fragLen == 0 'empty'
			return
		end 'empty'
		var buf = ByteArray.create()
		var i = 0
		while i < fragLen 'decode'
			let ch = try fragBytes.get(i) otherwise panic("emitFragmentLiteral: loop guard i < fragLen just succeeded but get({i}) failed (fragLen={fragLen})")
			if ch == '\\' and i + 1 < fragLen 'escape'
				let next = try fragBytes.get(i + 1) otherwise panic("emitFragmentLiteral: i + 1 < fragLen just succeeded but get({i + 1}) failed (fragLen={fragLen})")
				if next == 'n' 'escN'
					buf.push(10)
					i = i + 2
					continue
				end 'escN'
				if next == 't' 'escT'
					buf.push(9)
					i = i + 2
					continue
				end 'escT'
				if next == '\\' 'escBS'
					buf.push(92)
					i = i + 2
					continue
				end 'escBS'
				if next == '"' 'escDQ'
					buf.push(34)
					i = i + 2
					continue
				end 'escDQ'
			end 'escape'
			buf.push(ch)
			i = i + 1
		end 'decode'
		if not buf.isEmpty() 'flush'
			module.appendOp(block, op: MaxonOp.printLiteral(String.from(buf), range: SourceRange.none()))
		end 'flush'
	end 'emitFragmentLiteral'

	// --- Expression Parsing ---

	// Pratt expression parser: single loop handles all binary precedence levels.
	function parseExpression(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		return try parseExpressionBP(module, block: block, minBP: 0)
	end 'parseExpression'

	// entry: cursor AT first operand's first token.
	// exit:  cursor AT last-consumed token of the rightmost accepted operand.
	function parseExpressionBP(module MaxonModule, block IrBlock, minBP BindingPower) returns ExprResult throws ParserError
		// blk tracks the block this loop is currently emitting into. Bool
		// short-circuit emission moves it to a fresh merge block; subsequent
		// operands and the binop itself land in that merge block, not the
		// block we entered on.
		var blk = block
		currentBlock = blk
		var left = try parseUnary(module, block: blk)
		blk = currentBlock
		// left leaves cursor AT last-consumed of unary.

		while true 'prattLoop'
			// Peek ahead for a candidate operator token. cursor is AT last-
			// consumed of the previous operand.
			let opToken = try cursor.peek(1) otherwise break
			let bp = try infixBindingPower(opToken.kind) otherwise 0
			if bp == 0 'notOp'
				break
			end 'notOp'
			if bp <= minBP 'tooLow'
				break
			end 'tooLow'

			// expect-consume to leave cursor on the RHS first token. Trailing
			// operator at EOF (`1 +<eof>`) reports via expect.
			try advance()
			try expect(opToken.kind)

			let leftName = exprName(left)
			let opRange = SourceRange.ofToken(opToken)

			// Bool short-circuit for `and`/`or`. Skips emission of the rhs when
			// the lhs already determines the result. Integer `and`/`or` are
			// bitwise — both sides are always evaluated, so this branch only
			// fires when the lhs's type is bool.
			if (opToken.kind == TokenKind.and or opToken.kind == TokenKind.or) and maxonTypeIsBool(exprType(left)) 'shortCircuit'
				let mergeName = try emitShortCircuit(module, entryBlock: blk, leftName: leftName, opToken: opToken, rhsMinBP: bp)
				blk = currentBlock
				left = ExprResult.direct(mergeName, valueType: MaxonType.boolean)
				continue
			end 'shortCircuit'

			// Compile-time string constant folding for ==
			if opToken.kind == TokenKind.equalsEquals 'checkStrFold'
				if exprIsStringConst(left) 'leftIsStr'
					currentBlock = blk
					let right = try parsePrimary(module, block: blk)
					blk = currentBlock
					var foldedLeft = 1
					if exprStringConstValue(left) != exprStringConstValue(right) 'strNeq'
						foldedLeft = 0
					end 'strNeq'
					let leftLitName = emitLiteral(module, block: blk, value: foldedLeft, valueType: MaxonType.integer)
					let rightLitName = emitLiteral(module, block: blk, value: 1, valueType: MaxonType.integer)
					let resultName = freshSynthName()
					module.appendOp(blk, op: MaxonOp.cmp(resultName, left: leftLitName, right: rightLitName, predicate: CmpPredicate.eq, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: opRange))
					left = ExprResult.direct(resultName, valueType: MaxonType.integer)
					continue
				end 'leftIsStr'
			end 'checkStrFold'

			// Reference identity: is / is not
			if opToken.kind == TokenKind.is 'isRefEq'
				var negate = false
				if cursor.current().kind == TokenKind.not 'isNot'
					negate = true
					try expect(TokenKind.not)
				end 'isNot'
				currentBlock = blk
				let right = try parseExpressionBP(module, block: blk, minBP: bp)
				blk = currentBlock
				if not maxonTypeIsRef(project, t: exprType(left)) or not maxonTypeIsRef(project, t: exprType(right)) 'notRef'
					reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "'is' requires reference types (structs), not primitive values", line: opToken.line, column: opToken.column, filePath: filePath)
				end 'notRef'
				let resultName = freshSynthName()
				module.appendOp(blk, op: MaxonOp.refEq(resultName, left: leftName, right: exprName(right), negate: negate, range: opRange))
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
				continue
			end 'isRefEq'

			// Parse right operand with higher minimum binding power for left-associativity
			currentBlock = blk
			let right = try parseExpressionBP(module, block: blk, minBP: bp)
			blk = currentBlock

			// Dispatch == and != to .equals() call for reference types (content comparison)
			if (opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals) and maxonTypeIsRef(project, t: exprType(left)) and maxonTypeIsRef(project, t: exprType(right)) 'refEquals'
				let equalsResultName = freshSynthName()
				var equalsArgs = ByteArrayArray.create()
				equalsArgs.push(exprName(right))
				let equalsLabels = StringArray.create()
				var equalsArgTypes = MaxonTypeArray.create()
				equalsArgTypes.push(exprType(right))
				var equalsArgRanges = SourceRangeArray.create()
				equalsArgRanges.push(opRange)
				module.appendOp(blk, op: MaxonOp.methodCall(equalsResultName, receiver: leftName, methodName: project.calleeNames.intern("equals"), args: equalsArgs, argLabels: equalsLabels, argTypes: equalsArgTypes, argRanges: equalsArgRanges, range: opRange))
				if opToken.kind == TokenKind.bangEquals 'neq'
					let notResultName = freshSynthName()
					module.appendOp(blk, op: MaxonOp.unop(notResultName, operand: equalsResultName, opKind: UnaryOpKind.bitNot, operandType: MaxonType.integer, range: opRange))
					left = ExprResult.direct(notResultName, valueType: MaxonType.integer)
				end 'neq' else 'eq'
					left = ExprResult.direct(equalsResultName, valueType: MaxonType.integer)
				end 'eq'
				continue
			end 'refEquals'

			let resultName = freshSynthName()
			// Pick an advisory operandType from whichever operand carries the
			// most specific source-level type. lowerMaxonToStd sees the
			// fully-resolved operand StdTypes and inserts int↔float promotions
			// and picks the concrete opcodes. Left/right MaxonTypes are recorded
			// separately on the cmp op so TypeResolution can diagnose E3005.
			let leftExprType = exprType(left)
			let rightExprType = exprType(right)
			let operandType = binOpOperandType(leftExprType, rightType: rightExprType, kind: opToken.kind)
			emitBinaryOp(module, block: blk, kind: opToken.kind, resultName: resultName, leftName: leftName, rightName: exprName(right), leftType: leftExprType, rightType: rightExprType, operandType: operandType, range: opRange)

			// Comparison ops produce int (bool); arithmetic inherits the
			// operand's source-level type so chained expressions stay
			// typed consistently through TypeResolution.
			if opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals or opToken.kind == TokenKind.lessThan or opToken.kind == TokenKind.lessEquals or opToken.kind == TokenKind.greaterThan or opToken.kind == TokenKind.greaterEquals 'isCmp'
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
			end 'isCmp' else 'notCmp'
				left = ExprResult.direct(resultName, valueType: operandType)
			end 'notCmp'
		end 'prattLoop'

		// Publish the block control flow exited on so callers (statement-level
		// helpers, recursive parseExpressionBP frames) emit subsequent ops in
		// the right place even when bool short-circuit moved us forward.
		currentBlock = blk
		return left
	end 'parseExpressionBP'

	// --- Binary op emission ---

	// Choose the advisory operandType for a binary op. Bitwise ops are
	// integer-only; for everything else we prefer float > named > integer so
	// mixed expressions like `foo + 1.0` retain the `float` type. The actual
	// dispatch happens in lowerMaxonToStd after type resolution.
	function binOpOperandType(leftType MaxonType, rightType MaxonType, kind TokenKind) returns MaxonType
		if kind == TokenKind.or or kind == TokenKind.xor or kind == TokenKind.and or kind == TokenKind.shl or kind == TokenKind.shr or kind == TokenKind.mod 'intOnly'
			return MaxonType.integer
		end 'intOnly'
		if maxonTypeIsFloat(leftType) or maxonTypeIsFloat(rightType) 'anyFloat'
			return MaxonType.float
		end 'anyFloat'
		if isNamedMaxonType(leftType) 'leftNamed'
			return leftType
		end 'leftNamed'
		if isNamedMaxonType(rightType) 'rightNamed'
			return rightType
		end 'rightNamed'
		return MaxonType.integer
	end 'binOpOperandType'

	function isNamedMaxonType(t MaxonType) returns bool
		return match t 'check'
			named gives true
			integer gives false
			float gives false
			boolean gives false
			string gives false
		end 'check'
	end 'isNamedMaxonType'

	// Lower a bool `and`/`or` to short-circuit IR. Allocates a varSlot seeded
	// with the short-circuit value (false for `and`, true for `or`), branches
	// on the lhs to either skip the rhs (preserving the seed) or evaluate the
	// rhs and overwrite the slot, then merges. Returns the synthesized result
	// name; updates currentBlock to the merge block. Block layout is always
	// [entry, rhs..., merge] to match the cond_br convention (jcc-to-else +
	// fall-through-to-then). For `or` the lhs is negated so the "then" branch
	// is always the rhs path.
	function emitShortCircuit(module MaxonModule, entryBlock IrBlock, leftName ByteArray, opToken Token, rhsMinBP BindingPower) returns ByteArray throws ParserError
		let isOr = opToken.kind == TokenKind.or
		var label = "shortAnd"
		var opName = "and"
		var seedValue = 0
		if isOr 'isOrLabel'
			label = "shortOr"
			opName = "or"
			seedValue = 1
		end 'isOrLabel'
		let opRange = SourceRange.ofToken(opToken)
		let opLine = opToken.line

		// Allocate the slot via the parser scope so subsequent varLoad/varStore
		// ops resolve correctly through the existing slot machinery.
		let slot = scope.declare("__{label}_{currentFunc.nextBlockId}", varType: MaxonType.boolean, mutable: true)

		// Seed with the short-circuit value: `and` seeds false, `or` seeds true.
		let seedName = emitLiteral(module, block: entryBlock, value: seedValue, valueType: MaxonType.boolean)
		module.appendOp(entryBlock, op: MaxonOp.varDecl(slot, value: seedName, slotType: MaxonType.boolean, range: opRange))

		// For `or`, negate the lhs so we can use the same [rhs(then), merge(else)]
		// layout as `and`: take the rhs path when the negated value is true.
		var branchCondName = leftName
		if isOr 'negateLhs'
			let negatedName = freshSynthName()
			let oneName = emitLiteral(module, block: entryBlock, value: 1, valueType: MaxonType.integer)
			module.appendOp(entryBlock, op: MaxonOp.binop(negatedName, left: leftName, right: oneName, opKind: BinOpKind.bitXor, operandType: MaxonType.integer, range: opRange))
			branchCondName = negatedName
		end 'negateLhs'

		// rhs block sits immediately after the entry block. Allocate it
		// before parsing the rhs so its label is fixed; the merge block is
		// allocated AFTER the rhs parse so any nested short-circuit blocks
		// added during rhs parsing slot in between rhs and merge.
		let rhsLabel = "{label}.rhs"
		var rhsBlock = module.addBlockAt(currentFunc, label: rhsLabel, filePath: filePath.toString(), firstLine: opLine)
		let rhsBlockId = rhsBlock.id

		currentBlock = rhsBlock
		let rhsResult = try parseExpressionBP(module, block: rhsBlock, minBP: rhsMinBP)
		var rhsExitBlock = currentBlock
		if not maxonTypeIsBool(exprType(rhsResult)) 'rhsTypeMismatch'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "operator '{opName}' requires both operands to be the same type (both bool or both int)", line: opLine, column: opToken.column, filePath: filePath)
		end 'rhsTypeMismatch'

		module.appendOp(rhsExitBlock, op: MaxonOp.varStore(slot, value: exprName(rhsResult), range: opRange))

		let mergeLabel = "{label}.merge"
		var mergeBlock = module.addBlockAt(currentFunc, label: mergeLabel, filePath: filePath.toString(), firstLine: opLine)
		let mergeBlockId = mergeBlock.id

		module.setTerminator(entryBlock, op: MaxonOp.condBr(branchCondName, thenTarget: rhsBlockId, elseTarget: mergeBlockId, range: opRange))
		module.setTerminator(rhsExitBlock, op: MaxonOp.br(mergeBlockId, range: opRange))

		currentBlock = mergeBlock
		let resultName = freshSynthName()
		module.appendOp(mergeBlock, op: MaxonOp.varLoad(resultName, slotId: slot, slotType: MaxonType.boolean, range: opRange))
		return resultName
	end 'emitShortCircuit'

	// Caller guarantees `kind` is one of the infix operators for which
	// `infixBindingPower` returns a nonzero value (and `is` is intercepted by
	// the pratt loop before reaching here). Any other kind is a dispatch bug —
	// we panic rather than throw, so tests expose it as a compiler invariant
	// violation instead of a recoverable parse error.
	function emitBinaryOp(module MaxonModule, block IrBlock, kind TokenKind, resultName ByteArray, leftName ByteArray, rightName ByteArray, leftType MaxonType, rightType MaxonType, operandType MaxonType, range SourceRange = SourceRange.none())
		let intType = MaxonType.integer
		let hlOp = match kind 'emit'
			or gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitOr, operandType: intType, range: range)
			xor gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitXor, operandType: intType, range: range)
			and gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitAnd, operandType: intType, range: range)
			shl gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shl, operandType: intType, range: range)
			shr gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shr, operandType: intType, range: range)
			equalsEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.eq, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			bangEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ne, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			lessThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.lt, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			lessEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.le, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			greaterThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.gt, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			greaterEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ge, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			plus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.add, operandType: operandType, range: range)
			minus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.sub, operandType: operandType, range: range)
			star gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mul, operandType: operandType, range: range)
			slash gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.div, operandType: operandType, range: range)
			mod gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mod, operandType: intType, range: range)
			default panic("emitBinaryOp: unexpected token kind {kind.name} — pratt loop should have filtered via infixBindingPower")
		end 'emit'
		module.appendOp(block, op: hlOp)
	end 'emitBinaryOp'

	// --- Unary parsing ---

	// Unary: -primary | not primary | primary
	function parseUnary(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let token = cursor.current()

		if token.kind == TokenKind.minus 'isNeg'
			let opRange = SourceRange.ofToken(token)
			try expect(TokenKind.minus)
			let operand = try parsePrimary(module, block: block)
			let operandType = exprType(operand)
			if maxonTypeIsFloat(operandType) 'floatNeg'
				// Float negation: emit 0.0 - operand. The parser emits directly in
				// terms of MaxonType.float here because the source-level float
				// literal is unambiguous.
				// The synthetic `0.0` literal has no source origin; the binop itself
				// ranges over the `-` operator token that triggered the lowering.
				let zeroName = freshSynthName()
				module.appendOp(block, op: MaxonOp.literal(zeroName, value: 0, valueType: MaxonType.float, range: SourceRange.none()))
				let resultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.binop(resultName, left: zeroName, right: exprName(operand), opKind: BinOpKind.sub, operandType: MaxonType.float, range: opRange))
				return try parseAsCasts(module, block: block, expr: ExprResult.direct(resultName, valueType: MaxonType.float))
			end 'floatNeg'
			// For named or integer operands, emit the integer unary-neg op and
			// let lowerMaxonToStd pick the concrete StdType.
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.neg, operandType: operandType, range: opRange))
			return try parseAsCasts(module, block: block, expr: ExprResult.direct(resultName, valueType: operandType))
		end 'isNeg' else if token.kind == TokenKind.not 'isNot'
			let notRange = SourceRange.ofToken(token)
			try expect(TokenKind.not)
			let operand = try parseUnary(module, block: block)
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.bitNot, operandType: MaxonType.integer, range: notRange))
			return ExprResult.direct(resultName, valueType: MaxonType.integer)
		end 'isNot'

		return try parseAsCasts(module, block: block, expr: try parsePostfix(module, block: block, expr: try parsePrimary(module, block: block)))
	end 'parseUnary'

	// --- Cast expression parsing ---

	// Parse zero or more `as Type` casts following an expression. Casts bind
	// tighter than any binary operator, so we apply them as a postfix chain
	// before returning to the Pratt loop. Each cast emits a maxon.convert op
	// whose fromType/toType drive width selection during lowering. Cast
	// validity (widening rules, narrowing rejection) is checked by the
	// TypeResolution pass after all named types have been resolved.
	// entry: cursor AT last-consumed of the incoming expression.
	// exit:  cursor AT the final type-name token (or same as entry if no cast).
	function parseAsCasts(module MaxonModule, block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr
		while true 'castLoop'
			let asCandidate = try cursor.peek(1) otherwise break
			if asCandidate.kind != TokenKind.as 'notAs'
				break
			end 'notAs'
			// asCandidate (from peek) IS `as`; advance onto it, then expect-
			// consume to leave cursor on the type token. Missing type after
			// `as` at EOF reports via expect.
			let asToken = asCandidate
			try advance()
			try expect(TokenKind.as)
			let targetMaxonType = parseCastTargetType()
			// parseCastTargetType leaves cursor AT the type-name token.
			let targetLastToken = cursor.current()
			let fromMaxonType = exprType(result)
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.convert(resultName, operand: exprName(result), fromType: fromMaxonType, toType: targetMaxonType, implicit: false, range: SourceRange.between(asToken, last: targetLastToken)))
			result = ExprResult.direct(resultName, valueType: targetMaxonType)
		end 'castLoop'
		return result
	end 'parseAsCasts'

	// Parse the type appearing after `as`. Accepts the bare primitive
	// keywords (`int`, `float`, `bool`, `byte`) and registered typealias
	// identifiers — the former resolve to MaxonType primitives, the latter
	// stay as MaxonType.named so the typealias registry drives lowering.
	// exit: cursor AT the type-name token (not advanced past it).
	function parseCastTargetType() returns MaxonType
		let typeToken = cursor.current()
		if typeToken.kind == TokenKind.int 'isInt'
			return MaxonType.integer
		end 'isInt'
		if typeToken.kind == TokenKind.float 'isFloat'
			return MaxonType.float
		end 'isFloat'
		if typeToken.kind == TokenKind.bool 'isBool'
			return MaxonType.boolean
		end 'isBool'
		if typeToken.kind == TokenKind.byte 'isByte'
			return internMaxonType(project, name: "byte")
		end 'isByte'
		if typeToken.kind == TokenKind.identifier 'isIdent'
			return internMaxonType(project, name: typeToken.value)
		end 'isIdent'
		reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected type name after 'as'", line: typeToken.line, column: typeToken.column, filePath: filePath)
		return MaxonType.integer
	end 'parseCastTargetType'

	// --- Postfix expression chain ---

	// entry: cursor AT last-consumed of the primary expression.
	// exit:  cursor AT last-consumed of the postfix chain (`)` for method call
	//        or field-name token for field access). If no chain, cursor AT
	//        last-consumed of the primary (same as entry).
	//
	// Chain continuation is now purely token-driven: as long as the next
	// token is `.`, we emit the next chain segment without consulting the
	// receiver's struct type. Lowering performs the receiver-type lookup
	// when it sees the resulting fieldLoad / methodCall ops.
	function parsePostfix(module MaxonModule, block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr

		// Peek ahead for `.`. If so, consume and parse a chain segment.
		while true 'postfixLoop'
			let nextTok = try cursor.peek(1) otherwise break
			if nextTok.kind != TokenKind.dot 'notDot'
				break
			end 'notDot'

			// nextTok (from peek) IS `.`; advance onto it, then expect-consume
			// to leave cursor on the member name. Missing member name at EOF
			// reports via expect.
			try advance()
			try expect(TokenKind.dot)
			let memberToken = cursor.current()
			let memberName = memberToken.value
			let memberNameBytes = memberName.toByteArray()

			let receiverName = exprName(result)
			let receiverType = exprType(result)

			let afterMember = try cursor.peek(1) otherwise 'noMore'
				let fieldLoadNameEof = freshSynthName()
				module.appendOp(block, op: MaxonOp.fieldLoad(fieldLoadNameEof, receiver: receiverName, fieldName: memberNameBytes, range: SourceRange.ofToken(memberToken)))
				let fieldTypeEof = lookupFieldTypeForChain(receiverType, fieldName: memberName)
				result = ExprResult.direct(fieldLoadNameEof, valueType: fieldTypeEof)
				break
			end 'noMore'

			if afterMember.kind == TokenKind.leftParen 'isMethodCall'
				try expect(TokenKind.identifier)
				try expect(TokenKind.leftParen)
				let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(module, block: block)
				// parseCallArgsRaw exits AT `)`.
				let rparenToken = cursor.current()
				let methodResultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.methodCall(methodResultName, receiver: receiverName, methodName: memberNameBytes, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(memberToken, last: rparenToken)))
				let methodReturnType = lookupMethodReturnTypeForChain(receiverType, methodName: memberName)
				result = ExprResult.direct(methodResultName, valueType: methodReturnType)
				// Cursor AT `)`. Loop continues to check next for `.`.
				continue
			end 'isMethodCall'

			let fieldLoadName = freshSynthName()
			module.appendOp(block, op: MaxonOp.fieldLoad(fieldLoadName, receiver: receiverName, fieldName: memberNameBytes, range: SourceRange.ofToken(memberToken)))
			let fieldType = lookupFieldTypeForChain(receiverType, fieldName: memberName)
			result = ExprResult.direct(fieldLoadName, valueType: fieldType)
			// Cursor AT memberToken. Loop continues to peek next.
		end 'postfixLoop'

		return result
	end 'parsePostfix'

	// Look up the type of a field on the receiver's struct type. Used for
	// parser-time type-flow propagation in postfix chains; lowering re-runs
	// the same lookup when emitting field-load Std ops. Returns
	// `MaxonType.integer` as a placeholder when the receiver isn't a known
	// struct or the field doesn't exist — lowering will surface a real
	// diagnostic.
	function lookupFieldTypeForChain(receiverType MaxonType, fieldName String) returns MaxonType
		let structName = maxonTypeStructName(project, t: receiverType)
		if structName.isEmpty() 'noStruct'
			return MaxonType.integer
		end 'noStruct'
		// structTypes / fieldByName / fields are sparse during parse; absent entries fall back to the
		// MaxonType.integer placeholder (lowering re-checks and produces real diagnostics).
		let structType = try project.structTypes.get(structName) otherwise return MaxonType.integer
		let fieldIdx = try structType.fieldByName.get(fieldName) otherwise return MaxonType.integer
		let field = try structType.fields.get(fieldIdx) otherwise return MaxonType.integer
		return field.fieldType
	end 'lookupFieldTypeForChain'

	// Look up the return type of `{receiverType}.methodName` for postfix
	// type propagation. Same placeholder fallback as field lookup.
	function lookupMethodReturnTypeForChain(receiverType MaxonType, methodName String) returns MaxonType
		let structName = maxonTypeStructName(project, t: receiverType)
		if structName.isEmpty() 'noStruct'
			return MaxonType.integer
		end 'noStruct'
		let qualifiedCallee = "{structName}.{methodName}"
		let returnType = try project.funcReturnTypes.get(qualifiedCallee) otherwise MaxonReturnType.void
		return match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
	end 'lookupMethodReturnTypeForChain'

	// --- Primary expression parsing ---

	// entry: cursor AT the first identifier token.
	// exit:  cursor AT the last-consumed token (final `)`, `}`, field-name,
	//        or the identifier itself for a bare variable read).
	function parseIdentifierExpr(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		// Exhausted cursor means "bare identifier with nothing after it": the
		// EOF sentinel token doesn't match any of the kind== checks below, so
		// control falls through to the bare-variable-read tail.
		let peekToken = try cursor.peek(1) otherwise Token.eof()

		// Ident.Ident(args) — disambiguated using local-scope membership only:
		//   - `c.method(...)` where `c` is a known local var: emit methodCall
		//     and let lowering resolve `{receiverType}.method` from the value-
		//     type map.
		//   - `Type.method(...)` otherwise: emit a qualified call; lowering
		//     uses the callee verbatim.
		// We deliberately do NOT consult `project.structTypes` here — the
		// scope check is purely function-local and doesn't reach into
		// cross-declaration registries.
		if peekToken.kind == TokenKind.dot 'maybeDotCall'
			let memberToken = try cursor.peek(2) otherwise Token.eof()
			let afterMember = try cursor.peek(3) otherwise Token.eof()
			if memberToken.kind == TokenKind.identifier and afterMember.kind == TokenKind.leftParen 'isDotCall'
				let memberNameBytes = memberToken.value.toByteArray()
				if scope.contains(token.value) 'isMethodOnLocal'
					// Method call on a local-scope value receiver. The
					// receiver may be a true local (var/let), a parameter, or
					// a self-field alias inside an instance method — branch on
					// `isSelfField` so the receiver load op carries the type
					// from the right source.
					let receiverVarType = scope.getType(token.value)
					let receiverLoadName = freshSynthName()
					if scope.isSelfField(token.value) 'selfFieldReceiver'
						module.appendOp(block, op: MaxonOp.selfFieldLoad(receiverLoadName, fieldName: token.value.toByteArray(), range: SourceRange.ofToken(token)))
					end 'selfFieldReceiver' else 'localReceiver'
						let receiverSlot = lookupVariable(token.value, token: token)
						module.appendOp(block, op: MaxonOp.varLoad(receiverLoadName, slotId: receiverSlot, slotType: receiverVarType, range: SourceRange.ofToken(token)))
					end 'localReceiver'
					try expect(TokenKind.identifier)
					try expect(TokenKind.dot)
					try expect(TokenKind.identifier)
					try expect(TokenKind.leftParen)
					let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(module, block: block)
					let rparenToken = cursor.current()
					let methodResultName = freshSynthName()
					module.appendOp(block, op: MaxonOp.methodCall(methodResultName, receiver: receiverLoadName, methodName: memberNameBytes, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(token, last: rparenToken)))
					let methodReturnType = lookupMethodReturnTypeForChain(receiverVarType, methodName: memberToken.value)
					return ExprResult.direct(methodResultName, valueType: methodReturnType)
				end 'isMethodOnLocal'
				// Qualified static call: Type.method(...) — lowering resolves verbatim.
				let calleeName = "{token.value}.{memberToken.value}"
				try expect(TokenKind.identifier)
				try expect(TokenKind.dot)
				try expect(TokenKind.identifier)
				try expect(TokenKind.leftParen)
				let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(module, block: block)
				let rparenToken = cursor.current()
				return emitCallAndResult(module, block: block, calleeName: calleeName, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.between(token, last: rparenToken))
			end 'isDotCall'
		end 'maybeDotCall'

		// Qualified static-field read: TypeName.field, when the qualified name
		// resolves to a registered static var (.data slot) or static let
		// (compile-time constant). Methods take precedence above; this branch
		// only fires when the next token after `.field` is NOT `(`.
		if peekToken.kind == TokenKind.dot 'maybeQualifiedRead'
			let memberToken = try cursor.peek(2) otherwise Token.eof()
			let afterMember = try cursor.peek(3) otherwise Token.eof()
			if memberToken.kind == TokenKind.identifier and afterMember.kind != TokenKind.leftParen 'isFieldRead'
				let qualifiedName = "{token.value}.{memberToken.value}"
				if project.globalVars.contains(qualifiedName) 'isGlobalRead'
					let info = lookupGlobalVar(qualifiedName, callSite: "parseIdentifierExpr.qualifiedRead")
					// Advance to the field-name token, then stay AT it per the
					// "exit AT last-consumed" primary-expression contract.
					try expect(TokenKind.identifier)
					try expect(TokenKind.dot)
					let resultName = emitGlobalLoad(module, block: block, qualifiedName: qualifiedName, slotType: info.slotType, range: SourceRange.between(token, last: memberToken))
					return ExprResult.direct(resultName, valueType: info.slotType)
				end 'isGlobalRead'
				if project.topLevelConstants.contains(qualifiedName) 'isStaticLet'
					try expect(TokenKind.identifier)
					try expect(TokenKind.dot)
					return resolveConstant(module, block: block, name: qualifiedName)
				end 'isStaticLet'
			end 'isFieldRead'
		end 'maybeQualifiedRead'

		if peekToken.kind == TokenKind.leftParen 'isCall'
			try expect(TokenKind.identifier)
			try expect(TokenKind.leftParen)
			if token.value == "trunc" 'isTruncParse'
				// parseExpression exits AT last-consumed of the expression; after
				// it, advance once so we land on `)` to be the trunc's exit pos.
				let truncArgResult = try parseExpression(module, block: block)
				try advance()
				let truncRparenToken = cursor.current()
				let truncResultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.convert(truncResultName, operand: exprName(truncArgResult), fromType: exprType(truncArgResult), toType: MaxonType.integer, implicit: true, range: SourceRange.between(token, last: truncRparenToken)))
				return ExprResult.direct(truncResultName, valueType: MaxonType.integer)
			end 'isTruncParse'

			if token.value == "sqrt" 'isSqrtParse'
				let sqrtArgResult = try parseExpression(module, block: block)
				// parseExpression exits AT last-consumed of the arg; advance once
				// so the cursor lands on `)` per the primary-expression exit
				// contract (caller's dispatch loop will advance past `)`).
				try advance()
				let sqrtRparenToken = cursor.current()
				let sqrtRange = SourceRange.between(token, last: sqrtRparenToken)
				// sqrt is a pure-float intrinsic. Emit an implicit convert-to-float
				// unconditionally; `lowerConvert` aliases it at zero cost when the
				// operand is already float (same-family case).
				let promotedName = freshSynthName()
				module.appendOp(block, op: MaxonOp.convert(promotedName, operand: exprName(sqrtArgResult), fromType: exprType(sqrtArgResult), toType: MaxonType.float, implicit: true, range: sqrtRange))
				let sqrtResultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.sqrt(sqrtResultName, operand: promotedName, range: sqrtRange))
				return ExprResult.direct(sqrtResultName, valueType: MaxonType.float)
			end 'isSqrtParse'

			// Bare callee — emit a name-symbolic call. CallContext tells lowering
			// how to qualify (sibling-method probe inside a type body, then free
			// resolution via currentNamespace + stdlib fallback). Lowering also
			// detects __self instance-method calls and prepends the receiver.
			let bareCallee = token.value
			let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(module, block: block)
			let rparenToken = cursor.current()
			var ctx = CallContext.free
			if not currentTypeName.isEmpty() 'inMethod'
				ctx = CallContext.sibling(currentTypeName)
			end 'inMethod'
			return emitCallAndResult(module, block: block, calleeName: bareCallee, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: ctx, range: SourceRange.between(token, last: rparenToken))
		end 'isCall'

		// Sized type bound: u64.max, i32.min, etc.
		if peekToken.kind == TokenKind.dot 'maybeTypeBound'
			let fieldToken = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
			if fieldToken.kind == TokenKind.identifier and (fieldToken.value == "min" or fieldToken.value == "max") and (token.value == "u8" or token.value == "u16" or token.value == "u32" or token.value == "u64" or token.value == "i8" or token.value == "i16" or token.value == "i32" or token.value == "i64") 'isTypeBound'
				let bound = resolveTypeBound(token.value, field: fieldToken.value)
				try expect(TokenKind.identifier)
				try expect(TokenKind.dot)
				// Stay AT fieldToken (the `min`/`max` identifier). Don't advance past it.
				let boundName = emitLiteral(module, block: block, value: bound, valueType: MaxonType.integer, range: SourceRange.between(token, last: fieldToken))
				return ExprResult.direct(boundName, valueType: MaxonType.integer)
			end 'isTypeBound'
		end 'maybeTypeBound'

		// Struct construction: TypeName{field: value, ...}
		if peekToken.kind == TokenKind.leftBrace and project.structTypes.contains(token.value) 'isStructLiteral'
			return try parseStructLiteral(module, block: block, typeName: token.value, typeToken: token)
		end 'isStructLiteral'

		// Ranged primitive construction: TypeName{expression}
		if peekToken.kind == TokenKind.leftBrace 'isTypedConstruct'
			try expect(TokenKind.identifier)
			try expect(TokenKind.leftBrace)
			let innerResult = try parseExpression(module, block: block)
			// advance past last-consumed of inner expression, landing on '}'
			try advance()
			return innerResult
		end 'isTypedConstruct'

		if project.topLevelConstants.contains(token.value) 'isConst'
			return resolveConstant(module, block: block, name: token.value)
		end 'isConst'

		// Bare identifier may name a top-level `var`. Locals shadow globals:
		// only resolve to a global when the name is unbound in the local scope.
		if not scope.contains(token.value) and project.globalVars.contains(token.value) 'isGlobalRead'
			let info = lookupGlobalVar(token.value, callSite: "parseIdentifierExpr.bareRead")
			let resultName = emitGlobalLoad(module, block: block, qualifiedName: token.value, slotType: info.slotType, range: SourceRange.ofToken(token))
			return ExprResult.direct(resultName, valueType: info.slotType)
		end 'isGlobalRead'

		let slot = lookupVariable(token.value, token: token)
		let name = freshSynthName()
		let varType = scope.getType(token.value)
		let tokRange = SourceRange.ofToken(token)
		if scope.isSelfField(token.value) 'selfFieldRead'
			module.appendOp(block, op: MaxonOp.selfFieldLoad(name, fieldName: token.value.toByteArray(), range: tokRange))
		end 'selfFieldRead' else 'localRead'
			module.appendOp(block, op: MaxonOp.varLoad(name, slotId: slot, slotType: varType, range: tokRange))
		end 'localRead'
		// Stay AT the identifier token. Don't advance past it.
		return ExprResult.direct(name, valueType: varType)
	end 'parseIdentifierExpr'

	// Parse call arguments, validating named args for 2nd+ arguments.
	// When calleeName resolves to a registered function signature, the first
	// argument may be positional (mapped to paramStartIndex) and subsequent
	// arguments are reordered by name so IR parameter order matches the
	// callee's declaration. Missing arguments with integer defaults are filled
	// in automatically. When no signature is registered (stdlib calls before
	// cache warm-up, interface calls, etc.) the legacy positional-order path
	// is used.
	// Parser-only path: walk the argument list and collect parallel arrays
	// of value names + source labels. No signature lookup, no slot fill, no
	// default insertion — those happen in LowerMaxonToStd's slotArgsForCall.
	// Each arg's label is "" when the arg was positional, or the source-level
	// `name:` label otherwise. Replaces the parser-time signature-driven
	// slotting that lived in parseCallArgsWithSignature.
	// entry: cursor AT first-arg-first-token OR AT `)` if no args.
	// exit:  cursor AT `)`.
	function parseCallArgsRaw(module MaxonModule, block IrBlock) returns (ByteArrayArray, StringArray, MaxonTypeArray, SourceRangeArray) throws ParserError
		var args = ByteArrayArray.create()
		var labels = StringArray.create()
		var argTypes = MaxonTypeArray.create()
		var argRanges = SourceRangeArray.create()
		var argIndex = 0
		if cursor.current().kind != TokenKind.rightParen 'hasArgs'
			while true 'argLoop'
				let labelOpt = try consumeArgLabel(requireNamed: argIndex >= 1)
				var labelStr = ""
				if labelOpt.hasValue 'hasLabel'
					labelStr = labelOpt.token.value
				end 'hasLabel'
				let argFirstToken = cursor.current()
				let argResult = try parseExpression(module, block: block)
				let argLastToken = cursor.current()
				// parseExpression exits AT last-consumed; advance to next.
				try advance()
				args.push(exprName(argResult))
				labels.push(labelStr)
				argTypes.push(exprType(argResult))
				argRanges.push(SourceRange.between(argFirstToken, last: argLastToken))
				argIndex = argIndex + 1
				if cursor.current().kind == TokenKind.rightParen 'endArgs'
					break
				end 'endArgs'
			end 'argLoop'
		end 'hasArgs'
		return (args, labels, argTypes, argRanges)
	end 'parseCallArgsRaw'

	// Consume and validate an optional `name:` label on the next argument.
	// When requireNamed is true and no label is present, reports E3005. When
	// a label is present (regardless of requireNamed), consumes both tokens
	// and returns them; otherwise returns an empty OptionalToken.
	function consumeArgLabel(requireNamed bool) returns OptionalToken throws ParserError
		let maybeLabel = cursor.current()
		let afterLabel = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
		let isNamed = maybeLabel.kind == TokenKind.identifier and afterLabel.kind == TokenKind.colon
		if requireNamed and not isNamed 'notNamed'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: maybeLabel.line, column: maybeLabel.column, filePath: filePath)
		end 'notNamed'
		if not isNamed 'noLabel'
			return OptionalToken.empty()
		end 'noLabel'
		let nameToken = try consume()
		try expect(TokenKind.colon)
		return OptionalToken.some(nameToken)
	end 'consumeArgLabel'

	// Emit a function call op. The parser does NOT do callee dispatch or
	// signature-driven arg slotting — those happen in LowerMaxonToStd —
	// but it DOES read the resolved callee's declared return type so that
	// the ExprResult's valueType propagates a real `MaxonType.named(...)`
	// to downstream type-flow consumers (var slot inference, postfix
	// chain typing). The lookup is a bare dictionary read and does not
	// constitute cross-method resolution.
	// `range` covers the call-site span (the callee name through the closing
	// `)`); caller captures it before parsing arguments and passes it in.
	// `callContext` tells lowering how to qualify the bare callee name:
	// CallContext.qualified for already-qualified names, .sibling(typeName)
	// for bare names inside a method body, .free for everything else.
	function emitCallAndResult(module MaxonModule, block IrBlock, calleeName String, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, callContext CallContext, range SourceRange = SourceRange.none()) returns ExprResult
		let callName = freshSynthName()
		module.appendOp(block, op: MaxonOp.call(callName, callee: project.calleeNames.intern(calleeName), callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: range))
		let resolvedCallee = qualifyCalleeForType(calleeName, callContext: callContext)
		let returnType = try project.funcReturnTypes.get(resolvedCallee) otherwise MaxonReturnType.void
		let resultType = match returnType 'unwrap'
			void gives MaxonType.integer
			value(inner) gives inner
		end 'unwrap'
		return ExprResult.direct(callName, valueType: resultType)
	end 'emitCallAndResult'

	// Mirror of LowerMaxonToStd's call-resolution path for the parser's local
	// use — only consulted to recover the callee's return type for
	// ExprResult type-flow. Lowering re-runs the same probe order at the
	// lowering boundary; keeping the two in sync is cheaper than threading
	// the resolved name back from lowering for parse-time type inference.
	// Delegates to the shared `qualifyCalleeForContext` so all three
	// consumers (parser, DFE, lowering) cannot drift.
	function qualifyCalleeForType(bare String, callContext CallContext) returns String
		return qualifyCalleeForContext(project, bare: bare, callContext: callContext, currentNamespace: namespace)
	end 'qualifyCalleeForType'

	// entry: cursor AT type-name identifier (if not typeNameConsumed) OR AT `{`.
	// exit:  cursor AT `}`.
	//
	// Parser does NOT consult `project.structTypes` — it emits a structAlloc
	// op carrying the type name and per-field fieldStore ops carrying the
	// field name. Lowering looks up the byte size, validates field names,
	// and computes offsets.
	function parseStructLiteral(module MaxonModule, block IrBlock, typeName String, typeToken Token, typeNameConsumed bool = false) returns ExprResult throws ParserError
		if not typeNameConsumed 'consumeTypeName'
			try expect(TokenKind.identifier)
		end 'consumeTypeName'
		try expect(TokenKind.leftBrace)
		skipNewlines()

		let typeNameBytes = typeName.toByteArray()
		let ptrName = freshSynthName()
		module.appendOp(block, op: MaxonOp.structAlloc(ptrName, structName: typeNameBytes, range: SourceRange.ofToken(typeToken)))

		// Parse field: value pairs and emit one fieldStore per field.
		while cursor.current().kind != TokenKind.rightBrace 'fields'
			let fieldNameToken = cursor.current()
			try expect(TokenKind.identifier)
			try expect(TokenKind.colon)
			let fieldValue = try parseExpression(module, block: block)
			// parseExpression exits AT last-consumed of RHS.
			let fieldLastToken = cursor.current()
			try advance()  // past RHS onto newline / next field / `}`

			module.appendOp(block, op: MaxonOp.fieldStore(ptrName, fieldName: fieldNameToken.value.toByteArray(), value: exprName(fieldValue), range: SourceRange.between(fieldNameToken, last: fieldLastToken)))

			skipNewlines()
		end 'fields'
		// cursor AT `}`. Stay AT it (new contract).
		return ExprResult.direct(ptrName, valueType: internMaxonType(project, name: typeName))
	end 'parseStructLiteral'

	function parsePrimaryMatch(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		// New contract: every primary leaf exits AT its last-consumed token.
		match token.kind 'primary'
			intLiteral then return try parseIntLiteral(module, block: block, token: token)
			floatLiteral then return try parseFloatLiteral(module, block: block, token: token)
			identifier then return try parseIdentifierExpr(module, block: block, token: token)
			doubleStringLiteral then return try parseStringLiteral(token)
			true then return parseBoolLiteral(module, block: block, value: 1)
			false then return parseBoolLiteral(module, block: block, value: 0)
			leftParen then return try parseParenExpr(module, block: block)
			selfType then return try parseSelfExpr(module, block: block)
			self then return try parseSelfInstanceExpr(module, block: block)
			default throws ParserError.unhandledToken
		end 'primary'
	end 'parsePrimaryMatch'

	// entry: cursor AT `Self`.
	// exit:  cursor AT `}` (for Self{...}) or AT `Self` on error paths.
	function parseSelfExpr(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let selfToken = cursor.current()
		if currentTypeName.isEmpty() 'notInType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'Self' can only be used inside a type declaration", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'notInType'
		let nextTok = try cursor.peek(1) otherwise 'noNext'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '\{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'noNext'
		if nextTok.kind == TokenKind.leftBrace 'isStructLiteral'
			try expect(TokenKind.selfType)
			return try parseStructLiteral(module, block: block, typeName: currentTypeName, typeToken: selfToken, typeNameConsumed: true)
		end 'isStructLiteral'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '\{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'parseSelfExpr'

	// entry: cursor AT `self`.
	// exit:  cursor AT last-consumed of the expression (the `self` token itself
	//        if used bare, but in practice always followed by `.field` via
	//        parsePostfix which advances further).
	function parseSelfInstanceExpr(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let selfToken = cursor.current()
		if reportSelfOutsideType(selfToken) 'notInType'
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'notInType'
		let selfLoadName = emitSelfLoad(module, block: block, token: selfToken, range: SourceRange.ofToken(selfToken))
		return ExprResult.direct(selfLoadName, valueType: internMaxonType(project, name: currentTypeName))
	end 'parseSelfInstanceExpr'

	function parsePrimary(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		let token = cursor.current()
		let result = try parsePrimaryMatch(module, block: block, token: token) otherwise return raiseUnexpectedToken(module, block: block, token: token)
		return result
	end 'parsePrimary'

	// Expression-position parse failure: the next token doesn't start any known
	// primary. Report the diagnostic (for batch compile output), emit a
	// `MaxonOp.error` that anchors the failed span in the IR (for the LSP),
	// skip to the end of the line to avoid cascading errors, and return a
	// dummy ExprResult so the caller's type shape stays intact.
	function raiseUnexpectedToken(module MaxonModule, block IrBlock, token Token) returns ExprResult
		let message = "Expected expression but got '{tokenValueToString(token.value)}'"
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: message, line: token.line, column: token.column, filePath: filePath)
		module.appendOp(block, op: MaxonOp.error(MaxonErrorKind.expectedExpression, message: message, range: SourceRange.ofToken(token)))
		for tok in cursor 'skip'
			if tok.kind == TokenKind.newline 'atEnd'
				break
			end 'atEnd'
		end 'skip'
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'raiseUnexpectedToken'

	// exit: cursor AT the intLiteral token (not advanced past it).
	function parseIntLiteral(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		let value = try parseInt(token.value) otherwise 'overflow'
			try reportLiteralOverflow(TokenKind.intLiteral, token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'overflow'
		let name = emitLiteral(module, block: block, value: value, valueType: MaxonType.integer, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.integer)
	end 'parseIntLiteral'

	// exit: cursor AT the floatLiteral token (not advanced past it).
	function parseFloatLiteral(module MaxonModule, block IrBlock, token Token) returns ExprResult throws ParserError
		let rawBits = try parseFloatBits(token.value) otherwise 'overflow'
			try reportLiteralOverflow(TokenKind.floatLiteral, token: token, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.float)
		end 'overflow'
		let name = emitLiteral(module, block: block, value: rawBits, valueType: MaxonType.float, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.float)
	end 'parseFloatLiteral'

	// exit: cursor AT the doubleStringLiteral token (not advanced past it)
	//       for simple strings, or AT the final fragment (after consuming all
	//       interpolation tokens) for interpolated ones. Interpolated strings
	//       in expression position aren't representable as stringConst — we
	//       report an error and return a dummy value so parsing continues.
	function parseStringLiteral(token Token) returns ExprResult throws ParserError
		// String literals don't emit an op in the Maxon IR today (they're
		// constant-folded through `stringConst`), so there's no range to
		// attach. When string literals acquire a backing op, the range
		// comes from `SourceRange.ofToken(token)`.
		let peek = try cursor.peek(1) otherwise Token.eof()
		if peek.kind == TokenKind.stringInterpStart 'hasInterp'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "string interpolation is only supported inside print()", line: token.line, column: token.column, filePath: filePath)
			// Consume the rest of the composite string so we exit AT the
			// last fragment — the Pratt loop's advance lands cleanly on the
			// next real token.
			try skipInterpolatedRemainder()
			let dummy = freshSynthName()
			return ExprResult.stringConst(dummy, value: "")
		end 'hasInterp'
		let name = freshSynthName()
		return ExprResult.stringConst(name, value: token.value)
	end 'parseStringLiteral'

	// Consume tokens from a composite interpolated string (after the initial
	// doubleStringLiteral has been seen via peek) until cursor lands AT the
	// final fragment. Used by error-recovery paths that reject interpolations
	// but still need to advance past them so surrounding parsing stays sane.
	// entry: cursor AT a doubleStringLiteral whose peek(1) is stringInterpStart.
	// exit:  cursor AT the final doubleStringLiteral fragment.
	function skipInterpolatedRemainder() throws ParserError
		// Advance past the opening fragment.
		try expect(TokenKind.doubleStringLiteral)
		while cursor.current().kind == TokenKind.stringInterpStart 'interp'
			// Walk through the interpolation-expression tokens until stringInterpEnd.
			try expect(TokenKind.stringInterpStart)
			while cursor.current().kind != TokenKind.stringInterpEnd 'skipExpr'
				try advance()
			end 'skipExpr'
			try expect(TokenKind.stringInterpEnd)
			assertFragmentAfterInterpEnd(callerName: "skipInterpolatedRemainder", token: cursor.current())
			// Advance past the fragment only if another interpolation follows;
			// otherwise leave cursor AT it per the exit contract.
			let followerPeek = try cursor.peek(1) otherwise Token.eof()
			if followerPeek.kind != TokenKind.stringInterpStart 'done'
				return
			end 'done'
			try expect(TokenKind.doubleStringLiteral)
		end 'interp'
	end 'skipInterpolatedRemainder'

	// exit: cursor AT the 'true' or 'false' keyword token (not advanced past it).
	function parseBoolLiteral(module MaxonModule, block IrBlock, value ParsedInt) returns ExprResult
		let tok = cursor.current()
		let name = emitLiteral(module, block: block, value: value, valueType: MaxonType.boolean, range: SourceRange.ofToken(tok))
		return ExprResult.direct(name, valueType: MaxonType.boolean)
	end 'parseBoolLiteral'

	// entry: cursor AT `(`.
	// exit:  cursor AT `)`.
	function parseParenExpr(module MaxonModule, block IrBlock) returns ExprResult throws ParserError
		try expect(TokenKind.leftParen)
		let inner = try parseExpression(module, block: block)
		// parseExpression exits AT last-consumed of inner; advance to land on `)`.
		try advance()
		if cursor.current().kind != TokenKind.rightParen 'noClose'
			let t = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected ')' but got '{tokenValueToString(t.value)}'", line: t.line, column: t.column, filePath: filePath)
		end 'noClose'
		return inner
	end 'parseParenExpr'

	// Return the current token and advance past it. If the consumed token was
	// the last in the stream, cursor stays at last-valid — consistent with
	// the exit-AT-last-consumed contract at helper boundaries.
	function consume() returns Token throws ParserError
		let token = cursor.current()
		try cursor.advance() otherwise throw ParserError.unexpectedEof
		return token
	end 'consume'

	function advance() throws ParserError
		try cursor.advance() otherwise throw ParserError.unexpectedEof
	end 'advance'

	// Verify the current token is `kind` and advance past it. Advancing off the
	// end of the stream throws ParserError.unexpectedEof so callers don't have
	// to rescue a silent success separately — anything that still needs work
	// after `expect` can rely on a valid next token. Wrong-kind reports
	// parserExpectedToken and returns without advancing.
	function expect(kind TokenKind) throws ParserError
		if cursor.current().kind != kind 'matched'
			let token = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected {kind.name} but got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
			return
		end 'matched'

		try cursor.advance() otherwise throw ParserError.unexpectedEof
	end 'expect'

	// If the current token matches `kind`, consume it (advancing past it,
	// silently tolerating EOF) and return true. Otherwise leave the cursor in
	// place and return false. Combines the common "check then advance" pattern
	// without the redundant re-check that `expect` does when the kind is known.
	function tokenIs(kind TokenKind) returns bool
		if cursor.current().kind != kind 'noMatch'
			return false
		end 'noMatch'
		try cursor.advance() otherwise return true
		return true
	end 'tokenIs'

	function skipNewlines()
		// Iterate until we land on a non-newline. The for-header's implicit
		// advance eats each newline; the body breaks on the first other kind,
		// leaving cursor AT that non-newline token.
		for token in cursor 'skip'
			if token.kind != TokenKind.newline 'notNewline'
				break
			end 'notNewline'
		end 'skip'
	end 'skipNewlines'

	function expectNewlineAfterLabel()
		if cursor.current().kind != TokenKind.newline 'noNewline'
			let token = cursor.current()
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected newline after block label, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		end 'noNewline'
		skipNewlines()
	end 'expectNewlineAfterLabel'

	// Parse an optional block label of the form `'label'` after control-flow
	// keywords like `if` or `while`. Returns the label string if present,
	// otherwise the provided default. Consumes the trailing newline in both cases.
	function parseOptionalBlockLabel(defaultLabel String) returns String throws ParserError
		if cursor.current().kind == TokenKind.stringLiteral 'hasLabel'
			let label = cursor.current().value
			try cursor.advance() otherwise 'eof'
				reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "unexpected end of input after block label '{label}'", line: cursor.current().line, column: cursor.current().column, filePath: filePath)
				throw ParserError.unexpectedEof
			end 'eof'
			expectNewlineAfterLabel()
			return label
		end 'hasLabel'
		skipNewlines()
		return defaultLabel
	end 'parseOptionalBlockLabel'

	// entry: cursor AT `end`.
	// exit:  cursor AT `end` (if no label) OR AT the label string literal.
	function skipEndAndLabel() throws ParserError
		// Assertion: caller should have placed cursor at `end`.
		if cursor.current().kind != TokenKind.end 'notEnd'
			let t = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected 'end' but got '{tokenValueToString(t.value)}'", line: t.line, column: t.column, filePath: filePath)
			return
		end 'notEnd'
		let nextTok = try cursor.peek(1) otherwise return
		if nextTok.kind == TokenKind.stringLiteral 'hasLabel'
			try cursor.advance() otherwise 'eof'
				reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "unexpected end of input after 'end'", line: cursor.current().line, column: cursor.current().column, filePath: filePath)
				throw ParserError.unexpectedEof
			end 'eof'
		end 'hasLabel'
	end 'skipEndAndLabel'

	function skipToNextLine()
		// Iterate until we land on a newline (or exhaust at EOF). Body breaks
		// the moment we see one, leaving cursor AT the newline.
		for token in cursor 'skip'
			if token.kind == TokenKind.newline 'atEnd'
				return
			end 'atEnd'
		end 'skip'
	end 'skipToNextLine'

	// Error recovery: skip to next statement boundary.
	// Always advances at least 1 token to prevent infinite loops. Swallows
	// exhaustion because we're already in an error-recovery state.
	function synchronize()
		try cursor.advance() otherwise return
		for token in cursor 'sync'
			if token.kind == TokenKind.end 'atBoundary'
				return
			end 'atBoundary'
			if token.kind == TokenKind.newline 'atNewline'
				// Leave cursor AT newline (new contract — the statement's
				// last-consumed token, from the parser's POV). The dispatch
				// loop's compensating advance past this will land on the next
				// statement's opener.
				return
			end 'atNewline'
		end 'sync'
	end 'synchronize'

	// Synchronize to the next top-level declaration after an error.
	function synchronizeToTopLevel()
		for token in cursor 'sync'
			if token.kind == TokenKind.function or token.kind == TokenKind.type or token.kind == TokenKind.union or token.kind == TokenKind.enum or token.kind == TokenKind.export or token.kind == TokenKind.let or token.kind == TokenKind.var or token.kind == TokenKind.typealias 'atTopLevel'
				return
			end 'atTopLevel'
		end 'sync'
	end 'synchronizeToTopLevel'

	// --- Emission helpers ---

	// Mint a fresh synthetic intermediate name. Used for every op result that
	// doesn't directly correspond to a source-level variable (e.g. the result
	// of `a + b`). The `$t` prefix keeps these names disjoint from any
	// lexer-emitted identifier. Counter resets per function in resetSymbolTable.
	//
	// synthNameCache is keyed by counter value and grown on demand — the first
	// time we mint `$tN`, we allocate the ByteArray and push it at index N;
	// subsequent functions in the same Parser reuse the same entry without
	// re-allocating. Since synthNameCounter resets per function, entries
	// 0..K stay hot across the whole parse.
	function freshSynthName() returns ByteArray
		let n = synthNameCounter
		synthNameCounter = synthNameCounter + 1
		if n < synthNameCache.count() 'cached'
			return try synthNameCache.get(n) otherwise panic("freshSynthName: count() said {synthNameCache.count()} > {n} but get failed")
		end 'cached'
		// Cache miss: this is the first time the counter has reached n. By
		// construction n == synthNameCache.count(), so pushing appends at
		// exactly the right index.
		let name = "$t{n}".toByteArray()
		synthNameCache.push(name)
		return name
	end 'freshSynthName'

	// When the literal has an originating source token (int/float/bool
	// literal, type-bound constant like `u64.max`), callers pass its range
	// so hover/rename can map back to the source. Compiler-synthesized
	// literals (zero for implicit return, struct-byte-size, default arg
	// fallback) pass `SourceRange.none()` because they have no source origin.
	function emitLiteral(module MaxonModule, block IrBlock, value ParsedInt, valueType MaxonType, range SourceRange = SourceRange.none()) returns ByteArray
		let name = freshSynthName()
		module.appendOp(block, op: MaxonOp.literal(name, value: value, valueType: valueType, range: range))
		return name
	end 'emitLiteral'

	function emitImplicitReturn(module MaxonModule, block IrBlock)
		let zeroName = emitLiteral(module, block: block, value: 0, valueType: MaxonType.integer)
		module.setTerminator(block, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	end 'emitImplicitReturn'

	// Emit a varLoad for the implicit `__self` slot and return the fresh name
	// that holds the struct pointer. Caller must ensure we are inside an
	// instance method — in a static context lookupVariable("__self", …) will
	// report "Undefined variable '__self'".
	function emitSelfLoad(module MaxonModule, block IrBlock, token Token, range SourceRange) returns ByteArray
		let selfSlot = lookupVariable("__self", token: token)
		let selfLoadName = freshSynthName()
		module.appendOp(block, op: MaxonOp.varLoad(selfLoadName, slotId: selfSlot, slotType: internMaxonType(project, name: currentTypeName), range: range))
		return selfLoadName
	end 'emitSelfLoad'

	// Emit `self.<fieldName> = <valueName>` — load self then store the value at
	// the resolved field offset. Shared by implicit (`field = v`) and explicit
	// (`self.field = v`) field-assign parse paths; both reuse the same range
	// for the self-load and the store to keep debug info attached to the full
	// statement rather than to a synthetic receiver.
	function emitSelfFieldStore(module MaxonModule, block IrBlock, fieldName String, valueName ByteArray, range SourceRange)
		module.appendOp(block, op: MaxonOp.selfFieldStore(fieldName: fieldName.toByteArray(), value: valueName, range: range))
	end 'emitSelfFieldStore'

	// Diagnose bare `self` outside any type body. Returns true when we are
	// NOT inside a type (caller should return early). Keeps the error message
	// consistent between statement- and expression-context `self`.
	function reportSelfOutsideType(token Token) returns bool
		if currentTypeName.isEmpty() 'notInType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'self' can only be used inside an instance method", line: token.line, column: token.column, filePath: filePath)
			return true
		end 'notInType'
		return false
	end 'reportSelfOutsideType'

	// Finalize an if/else by emitting the condBr and returning either a
	// detached block (both branches terminated) or a new merge block.
	// Uses captured block IDs to avoid stale references from nested parsing.
	// `mergeLine` is the source line for the synthetic merge block — typically
	// the line just past the if's closing `end`, i.e. where post-if statements
	// will land.
	function finalizeIfElseById(module MaxonModule, func IrFunction, condBlock IrBlock, condName ByteArray, thenBlockId BlockId, thenExit IrBlock, elseBlockId BlockId, elseExit IrBlock, baseLabel String, mergeLine LineNumber) returns IrBlock
		module.setTerminator(condBlock, op: MaxonOp.condBr(condName, thenTarget: thenBlockId, elseTarget: elseBlockId, range: SourceRange.none()))
		// isTerminated covers both real terminators and dead blocks, so
		// a branch whose arm ends in a fully-terminated nested if/else
		// contributes no live path to the merge.
		if thenExit.isTerminated() and elseExit.isTerminated() 'bothTerminated'
			return newDetachedBlock(func)
		end 'bothTerminated'
		let mergeBlock = module.addBlockAt(func, label: "{baseLabel}.merge", filePath: filePath.toString(), firstLine: mergeLine)
		branchIfNeeded(module, block: thenExit, target: mergeBlock.id)
		branchIfNeeded(module, block: elseExit, target: mergeBlock.id)
		return mergeBlock
	end 'finalizeIfElseById'

	function branchIfNeeded(module MaxonModule, block IrBlock, target BlockId)
		// Dead blocks are already terminated (unreachably), so isTerminated
		// is enough — leaving them without an op keeps them absent from the CFG.
		if not block.isTerminated() 'needsBranch'
			module.setTerminator(block, op: MaxonOp.br(target, range: SourceRange.none()))
		end 'needsBranch'
	end 'branchIfNeeded'

	// --- Symbol table helpers ---

	function resetSymbolTable()
		scope.reset()
		paramLocations = ParamLocationArray.create()
		referencedVars = ReferencedVarSet.create()
		synthNameCounter = 0
	end 'resetSymbolTable'

	// Emit E3012 for the first parameter whose name never appeared on a read
	// path in the body, matching the C# compiler's throw-on-first behavior.
	// Reporting every unused parameter would add noise that isn't in the spec.
	// `_` is the discard convention and is skipped. Local `var`/`let` bindings
	// are not yet tracked in self-hosted.
	function checkUnusedParameters()
		for param in paramLocations 'eachParam'
			if param.name == "_" 'isDiscard'
				continue
			end 'isDiscard'
			if not referencedVars.contains(param.name) 'unused'
				reportCompileError(project, code: ErrorCode.semanticUnusedVariable, message: "unused variable: '{param.name}'", line: param.line, column: param.column, filePath: filePath)
				return
			end 'unused'
		end 'eachParam'
	end 'checkUnusedParameters'

	// Declare a variable carrying the given source-level MaxonType. Slot
	// width is NOT picked here — lowerMaxonToStd resolves MaxonType via the
	// typealias registry after TypeResolution has run.
	function defineVariableWithType(name String, varType MaxonType) returns VarSlot
		return scope.declare(name, varType: varType, mutable: true)
	end 'defineVariableWithType'

	function getVariableStructType(name String) returns String
		if not scope.contains(name) 'notFound'
			return ""
		end 'notFound'
		return maxonTypeStructName(project, t: scope.getType(name))
	end 'getVariableStructType'

	function lookupVariable(name String, token Token) returns VarSlot
		if let slot = try scope.lookup(name) 'found'
			referencedVars.insert(element: name)
			return slot
		end 'found'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Undefined variable '{tokenValueToString(name)}'", line: token.line, column: token.column, filePath: filePath)
		return 0
	end 'lookupVariable'

	function resolveConstant(module MaxonModule, block IrBlock, name String) returns ExprResult
		let constVal = try project.topLevelConstants.get(name) otherwise return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)

		match constVal 'dispatch'
			stringValue(v) then return ExprResult.stringConst(freshSynthName(), value: v)
			intValue(v) then return ExprResult.direct(emitLiteral(module, block: block, value: v, valueType: MaxonType.integer), valueType: MaxonType.integer)
		end 'dispatch'
	end 'resolveConstant'

	function parseScopedStatements(module MaxonModule, func IrFunction, block IrBlock) returns IrBlock throws ParserError
		scope.pushScope()
		var lastWasReturn = false
		let exitBlock = try parseStatements(module, func: func, block: block, lastWasReturn: lastWasReturn)
		scope.popScope()
		return exitBlock
	end 'parseScopedStatements'
end 'Parser'

// --- Standalone pure functions ---

// --- MaxonType predicates for parser use ---
// Named types are "unresolved" at parse time: whether they're struct/enum/
// typealias is a property of the registries maintained alongside the parse,
// so helpers consult Project to answer concrete questions.

function maxonTypeIsFloat(t MaxonType) returns bool
	return match t 'check'
		float gives true
		integer gives false
		boolean gives false
		named gives false
		string gives false
	end 'check'
end 'maxonTypeIsFloat'

function maxonTypeIsBool(t MaxonType) returns bool
	return match t 'check'
		boolean gives true
		integer gives false
		float gives false
		named gives false
		string gives false
	end 'check'
end 'maxonTypeIsBool'

// A named type is a "reference" (heap-allocated struct/enum/function) when
// the project knows about it in the corresponding registry. For named types
// that aren't yet registered (forward references across files), we
// conservatively return false; the TypeResolution pass catches truly-unknown
// names after all files have been parsed.
function maxonTypeIsRef(project Project, t MaxonType) returns bool
	let nameStr = t.nameOrEmpty(project)
	return not nameStr.isEmpty() and project.structTypes.contains(nameStr)
end 'maxonTypeIsRef'

// Return the underlying struct-type name for a named MaxonType, or "" when
// the type is not currently registered as a struct. Exported because the
// Maxon→Std lowering pass uses it to resolve receiver types for fieldLoad,
// fieldStore, and methodCall ops the parser now leaves name-symbolic.
export function maxonTypeStructName(project Project, t MaxonType) returns String
	let nameStr = t.nameOrEmpty(project)
	if nameStr.isEmpty() 'noName'
		return ""
	end 'noName'
	if project.structTypes.contains(nameStr) 'isStruct'
		return nameStr
	end 'isStruct'
	return ""
end 'maxonTypeStructName'

// Create a block that is not added to the function's block list.
// Used as a sink for dead code after fully-terminated if/else branches.
// Terminator.dead marks it unreachable so later checks can distinguish
// it from a real block that simply has not had its terminator set yet.
function newDetachedBlock(func IrFunction) returns IrBlock
	let id = func.nextBlockId
	func.nextBlockId = func.nextBlockId + 1
	var block = IrBlock.create(id, label: "dead")
	block.terminator = Terminator.dead
	return block
end 'newDetachedBlock'

function tokenValueToString(value String) returns String
	if value.isEmpty() 'empty'
		return "(empty)"
	end 'empty'
	return value
end 'tokenValueToString'

// Qualify a function name with namespace: "ns.name".
// Returns the raw name if namespace is empty. Exported because the Maxon→Std
// lowering pass also walks the funcReturnTypes registry to resolve the
// callee names that the parser now leaves unqualified.
export function qualifyName(ns String, name String) returns String
	if ns.isEmpty() 'noNs'
		return name
	end 'noNs'
	return "{ns}.{name}"
end 'qualifyName'

// --- Pratt parser binding power ---

typealias BindingPower = int(0 to 14)

// Throws for non-operator tokens; the call site uses `otherwise 0` to stop the Pratt loop.
function infixBindingPower(kind TokenKind) returns BindingPower throws ParserError
	return match kind 'bp'
		or gives 2
		xor gives 4
		and gives 6
		shl gives 8
		shr gives 8
		equalsEquals gives 10
		bangEquals gives 10
		is gives 10
		lessThan gives 10
		lessEquals gives 10
		greaterThan gives 10
		greaterEquals gives 10
		plus gives 12
		minus gives 12
		star gives 14
		slash gives 14
		mod gives 14
		default throws ParserError.unhandledToken
	end 'bp'
end 'infixBindingPower'

// --- Type bound parsing helpers ---

typealias BoundValue = int(i64.min to i64.max)

let typeBoundsTable = [
	"u8.min": 0, "u8.max": 255, "u16.min": 0, "u16.max": 65535, "u32.min": 0, "u32.max": 4294967295, "u64.min": 0, "u64.max": -1,
	"i8.min": -128, "i8.max": 127, "i16.min": -32768, "i16.max": 32767, "i32.min": -2147483648, "i32.max": 2147483647, "i64.min": -9223372036854775808, "i64.max": 9223372036854775807
]

function resolveTypeBound(typeName String, field String) returns BoundValue
	let key = "{typeName}.{field}"
	// Sentinel: 0 means "not a known type-qualified bound"; callers treat 0 as "fall through to literal parsing".
	return try typeBoundsTable.get(key) otherwise 0
end 'resolveTypeBound'

// Pick the narrowest StdType that can hold a typealias's range of values.
// Negative lower bounds fall through to signed i64 because signed narrow
// widths aren't yet used at the Std level.
function computeOptimalIntType(lower BoundValue, upper BoundValue) returns StdType
	if lower >= 0 'unsigned'
		if upper < 0 'wrappedU64'
			return StdType.u64
		end 'wrappedU64'
		if upper <= u8.max 'u8'
			return StdType.u8
		end 'u8'
		if upper <= u16.max 'u16'
			return StdType.u16
		end 'u16'
		if upper <= u32.max 'u32'
			return StdType.u32
		end 'u32'
		return StdType.u64
	end 'unsigned'
	return StdType.i64
end 'computeOptimalIntType'

// --- ExprResult enum ---

// Result of parsing an expression. The parser only ever tracks the
// source-level MaxonType on the value; int-vs-float dispatch and width
// selection happen in lowerMaxonToStd, not here.
//
// The `name` field carries a `ByteArray` — either a zero-copy slice over the
// lexer's source buffer (for a user-written variable) or a synthetic name
// (`$tN`) minted by the parser for an intermediate. SSA numbering is assigned
// only when the Maxon dialect is lowered to Std.
export union ExprResult
	// Computed value — already emitted as an op
	direct(name ByteArray, valueType MaxonType)
	// Compile-time string constant — for constant folding of == on strings
	stringConst(name ByteArray, value String)
end 'ExprResult'

// --- ExprResult helpers ---

function exprName(expr ExprResult) returns ByteArray
	return match expr 'getName'
		direct(name, _) gives name
		stringConst(name, _) gives name
	end 'getName'
end 'exprName'

function exprType(expr ExprResult) returns MaxonType
	return match expr 'getType'
		direct(_, valueType) gives valueType
		stringConst gives MaxonType.string
	end 'getType'
end 'exprType'

function exprIsStringConst(expr ExprResult) returns bool
	return match expr 'check'
		stringConst gives true
		direct gives false
	end 'check'
end 'exprIsStringConst'

function exprStringConstValue(expr ExprResult) returns String
	return match expr 'getValue'
		stringConst(_, value) gives value
		direct gives ""
	end 'getValue'
end 'exprStringConstValue'

// --- Context stacks for loops and match ---

type LoopContext
	export var sourceLabel String
	export var headerBlockId BlockId
	export var exitBlockId BlockId

	export static function create(sourceLabel String, headerBlockId BlockId, exitBlockId BlockId) returns LoopContext
		return Self{sourceLabel: sourceLabel, headerBlockId: headerBlockId, exitBlockId: exitBlockId}
	end 'create'
end 'LoopContext'

typealias LoopContextArray = Array with LoopContext

type MatchContext
	export var sourceLabel String
	export var mergeBlockId BlockId

	export static function create(sourceLabel String, mergeBlockId BlockId) returns MatchContext
		return Self{sourceLabel: sourceLabel, mergeBlockId: mergeBlockId}
	end 'create'
end 'MatchContext'

typealias MatchContextArray = Array with MatchContext

// Member-bookmark records produced by `parseTypeDecl`'s single-pass scan
// over the type body. Each bookmark captures the token index where a
// non-field member begins (with optional `export` still pending) plus the
// member's kind, so the replay loop can dispatch to the right per-member
// parse helper after the StructType is registered.
union MemberKind
	instanceMethod
	staticMethod
	staticVar
	staticLet
end 'MemberKind'

type MemberBookmark
	export let startIndex Index
	export let kind MemberKind

	export static function create(startIndex Index, kind MemberKind) returns MemberBookmark
		return Self{startIndex: startIndex, kind: kind}
	end 'create'
end 'MemberBookmark'

typealias MemberBookmarkArray = Array with MemberBookmark

// Tracks the source location of a parameter so CheckUnusedVariables can pin
// an E3012 error back to the declaration site rather than the function header.
type ParamLocation
	export let name String
	export let line ErrorLineNumber
	export let column ErrorColumnNumber

	export static function create(name String, line ErrorLineNumber, column ErrorColumnNumber) returns ParamLocation
		return Self{name: name, line: line, column: column}
	end 'create'
end 'ParamLocation'

typealias ParamLocationArray = Array with ParamLocation
typealias ReferencedVarSet = Set with String

// Optional Token wrapper returned by consumeArgLabel. Maxon has no built-in
// optional type, so a small struct with a presence flag keeps the call-site
// unwrap obvious (hasValue/token) without resorting to sentinel tokens.
type OptionalToken
	export let hasValue bool
	export let token Token

	export static function some(token Token) returns OptionalToken
		return Self{hasValue: true, token: token}
	end 'some'

	export static function empty() returns OptionalToken
		return Self{hasValue: false, token: Token.eof()}
	end 'empty'
end 'OptionalToken'

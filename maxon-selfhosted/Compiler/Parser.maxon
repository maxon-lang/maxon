// Recursive descent parser.
// Consumes tokens and emits Maxon dialect ops with funcBegin/funcEnd markers.

export typealias MaxonOpArray = Array with MaxonOp
export typealias ValueId = int(0 to u64.max)
export typealias VarSlot = int(0 to u64.max)
export typealias ParsedInt = int(i64.min to i64.max)
typealias TokenIndex = int(0 to u64.max)
export typealias VarSlotArray = Array with VarSlot
export typealias BoolArray = Array with bool
export typealias ByteArrayArray = Array with ByteArray

type ParseFunctionResult
    export var ops MaxonOpArray
    export var nextPos TokenIndex
end 'ParseFunctionResult'

function tokenValueToString(value ByteArray) returns String
    let len = value.count()
    if len == 0 'empty'
        return "(empty)"
    end 'empty'
    return String.from(value)
end 'tokenValueToString'

function resetSymbolTable(project Project)
    project.parserVarNames = ByteArrayArray{}
    project.parserVarSlots = VarSlotArray{}
    project.parserVarIsFloat = BoolArray{}
    project.parserNextSlot = 0
end 'resetSymbolTable'

function defineVariable(project Project, name ByteArray, isFloat bool) returns VarSlot
    let slot = project.parserNextSlot
    project.parserVarNames.push(name)
    project.parserVarSlots.push(slot)
    project.parserVarIsFloat.push(isFloat)
    project.parserNextSlot = project.parserNextSlot + 1
    return slot
end 'defineVariable'

function lookupVariable(project Project, name ByteArray, token Token, filePath String) returns VarSlot throws CompileError
    var i = project.parserVarNames.count() - 1
    while i >= 0 'lookup'
        let vn = try project.parserVarNames.get(i) otherwise ByteArray{}
        if bytesEqual(vn, b: name) 'found'
            return try project.parserVarSlots.get(i) otherwise 0
        end 'found'
        i = i - 1
    end 'lookup'
    try raiseCompileError(ErrorCode.semanticUndefinedVariable, message: "Undefined variable '{tokenValueToString(name)}'", line: token.line, column: token.column, filePath: filePath)
    return 0
end 'lookupVariable'

// Look up a compile-time string constant. Returns empty ByteArray if not found.
function lookupStringConst(project Project, name ByteArray) returns ByteArray
    var i = 0
    while i < project.stringConstNames.count() 'lookup'
        let cn = try project.stringConstNames.get(i) otherwise ByteArray{}
        if bytesEqual(cn, b: name) 'found'
            return try project.stringConstValues.get(i) otherwise ByteArray{}
        end 'found'
        i = i + 1
    end 'lookup'
    var empty = ByteArray{}
    return empty
end 'lookupStringConst'

function isVariableFloat(project Project, name ByteArray) returns bool
    var i = project.parserVarNames.count() - 1
    while i >= 0 'lookup'
        let vn = try project.parserVarNames.get(i) otherwise ByteArray{}
        if bytesEqual(vn, b: name) 'found'
            return try project.parserVarIsFloat.get(i) otherwise false
        end 'found'
        i = i - 1
    end 'lookup'
    return false
end 'isVariableFloat'

export function parse(project Project, tokens TokenArray, filePath String) returns MaxonOpArray throws CompileError
    logDebug(LogCategory.parser, message: "Starting parser")
    var pos = 0
    var allOps = MaxonOpArray{}

    pos = skipNewlines(tokens, startPos: pos)

    while pos < tokens.count() 'parseLoop'
        let token = tokenAt(tokens, pos: pos)
        if token.kind == TokenKind.eof 'isEof'
            break
        end 'isEof'
        if token.kind == TokenKind.function 'isFunction'
            let result = try parseFunction(project, tokens: tokens, startPos: pos, filePath: filePath)
            allOps.append(result.ops)
            pos = result.nextPos
        end 'isFunction' else 'notFunction'
            if token.kind == TokenKind.let 'isTopLet'
                pos = try parseTopLevelLet(project, tokens: tokens, startPos: pos, filePath: filePath)
            end 'isTopLet' else 'notTopLet'
                pos = pos + 1
            end 'notTopLet'
        end 'notFunction'
        pos = skipNewlines(tokens, startPos: pos)
    end 'parseLoop'

    logDebug(LogCategory.parser, message: "Parser complete: {allOps.count()} ops")
    return allOps
end 'parse'

// --- Function parsing ---

function parseFunction(project Project, tokens TokenArray, startPos TokenIndex, filePath String) returns ParseFunctionResult throws CompileError
    var pos = startPos
    pos = pos + 1  // skip 'function'

    let nameToken = tokenAt(tokens, pos: pos)
    logTrace(LogCategory.parser, message: "Parsing function '{String.from(nameToken.value)}'")
    pos = pos + 1

    // Expect '(' ')'
    pos = pos + 1  // skip '('
    pos = pos + 1  // skip ')'

    // Parse 'returns' type
    var returnTypeName = ByteArray{}
    let nextToken = tokenAt(tokens, pos: pos)
    if nextToken.kind == TokenKind.returns 'hasReturns'
        pos = pos + 1  // skip 'returns'
        let typeToken = tokenAt(tokens, pos: pos)
        returnTypeName = typeToken.value
        pos = pos + 1  // skip type name
    end 'hasReturns'

    // Skip newlines
    pos = skipNewlines(tokens, startPos: pos)

    // Parse body statements into ops
    var ops = MaxonOpArray{}
    resetValueIds(project)
    resetSymbolTable(project)

    ops.push(MaxonOp.funcBegin(nameToken.value, returnTypeName))

    pos = try parseStatements(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)


    ops.push(MaxonOp.funcEnd)

    // Skip 'end' and optional label string
    pos = pos + 1  // skip 'end'
    let afterEnd = tokenAt(tokens, pos: pos)
    if afterEnd.kind == TokenKind.stringLiteral 'hasLabel'
        pos = pos + 1  // skip label
    end 'hasLabel'

    return {ops: ops, nextPos: pos}
end 'parseFunction'

// --- Statement parsing ---

// Parse statements until 'end' is reached. Returns the position at the 'end' token.
function parseStatements(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns TokenIndex throws CompileError
    var pos = startPos
    while pos < tokens.count() 'body'
        let stmtToken = tokenAt(tokens, pos: pos)
        if stmtToken.kind == TokenKind.end 'isEnd'
            break
        end 'isEnd'
        if stmtToken.kind == TokenKind.return 'isReturn'
            pos = try parseReturnStatement(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        end 'isReturn' else 'notReturn'
            if stmtToken.kind == TokenKind.var or stmtToken.kind == TokenKind.let 'isVarDecl'
                pos = try parseVarDecl(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
            end 'isVarDecl' else 'notVarDecl'
                if stmtToken.kind == TokenKind.print 'isPrint'
                    pos = try parsePrintStatement(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
                end 'isPrint' else 'notPrint'
                    if stmtToken.kind == TokenKind.if 'isIf'
                        pos = try parseIfStatement(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
                    end 'isIf' else 'notIf'
                        try raiseCompileError(ErrorCode.parserExpectedToken, message: "Unexpected token '{tokenValueToString(stmtToken.value)}' in statement position", line: stmtToken.line, column: stmtToken.column, filePath: filePath)
                    end 'notIf'
                end 'notPrint'
            end 'notVarDecl'
        end 'notReturn'
        pos = skipNewlines(tokens, startPos: pos)
    end 'body'
    return pos
end 'parseStatements'

// Parse top-level `let NAME = "value"` — stores as compile-time string constant.
function parseTopLevelLet(project Project, tokens TokenArray, startPos TokenIndex, filePath String) returns TokenIndex throws CompileError
    var pos = startPos + 1  // skip 'let'
    let nameToken = tokenAt(tokens, pos: pos)
    pos = pos + 1  // skip name
    let equalsToken = tokenAt(tokens, pos: pos)
    if equalsToken.kind != TokenKind.equals 'notEquals'
        try raiseCompileError(ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
    end 'notEquals'
    pos = pos + 1  // skip '='
    let valueToken = tokenAt(tokens, pos: pos)
    if valueToken.kind != TokenKind.doubleStringLiteral 'notString'
        try raiseCompileError(ErrorCode.parserExpectedToken, message: "Top-level let only supports string literals", line: valueToken.line, column: valueToken.column, filePath: filePath)
    end 'notString'
    pos = pos + 1  // skip string value
    project.stringConstNames.push(nameToken.value)
    project.stringConstValues.push(valueToken.value)
    logTrace(LogCategory.parser, message: "Registered top-level string constant '{String.from(nameToken.value)}'")
    return pos
end 'parseTopLevelLet'

function parseReturnStatement(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns TokenIndex throws CompileError
    var pos = startPos + 1  // skip 'return'
    let resultId = try parseExpression(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
    pos = resultId.nextPos
    ops.push(MaxonOp.returnOp(resultId.valueId))
    return pos
end 'parseReturnStatement'

// Parse: if <condition> 'label' ... end 'label' [else 'label' ... end 'label']
function parseIfStatement(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns TokenIndex throws CompileError
    var pos = startPos + 1  // skip 'if'

    // Parse condition expression
    let condResult = try parseExpression(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
    pos = condResult.nextPos

    // Skip block label after condition
    let thenLabelToken = tokenAt(tokens, pos: pos)
    if thenLabelToken.kind == TokenKind.stringLiteral 'hasThenLabel'
        pos = pos + 1
    end 'hasThenLabel'
    pos = skipNewlines(tokens, startPos: pos)

    // Generate unique labels for the branches
    let thenLabel = nextLabelName(project, prefix: b"then")
    let elseLabel = nextLabelName(project, prefix: b"else")
    let mergeLabel = nextLabelName(project, prefix: b"merge")

    // Emit conditional branch
    ops.push(MaxonOp.condBr(condResult.valueId, thenLabel, elseLabel))

    // Emit then block
    ops.push(MaxonOp.label(thenLabel))
    pos = try parseStatements(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)

    let lastThenOp = try ops.get(ops.count() - 1) otherwise MaxonOp.funcEnd
    let thenReturns = isReturnOp(lastThenOp)

    if not thenReturns 'thenNeedsMerge'
        ops.push(MaxonOp.br(mergeLabel))
    end 'thenNeedsMerge'

    // Skip 'end' and label
    pos = pos + 1  // skip 'end'
    let afterThenEnd = tokenAt(tokens, pos: pos)
    if afterThenEnd.kind == TokenKind.stringLiteral 'hasThenEndLabel'
        pos = pos + 1
    end 'hasThenEndLabel'
    pos = skipNewlines(tokens, startPos: pos)

    // Check for else
    let maybeElse = tokenAt(tokens, pos: pos)
    var hasElse = false
    var elseReturns = false
    if maybeElse.kind == TokenKind.else 'isElse'
        hasElse = true
        pos = pos + 1  // skip 'else'
        // Skip else block label
        let elseLabelToken = tokenAt(tokens, pos: pos)
        if elseLabelToken.kind == TokenKind.stringLiteral 'hasElseLabel'
            pos = pos + 1
        end 'hasElseLabel'
        pos = skipNewlines(tokens, startPos: pos)

        // Emit else block
        ops.push(MaxonOp.label(elseLabel))
        pos = try parseStatements(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)

        let lastElseOp = try ops.get(ops.count() - 1) otherwise MaxonOp.funcEnd
        elseReturns = isReturnOp(lastElseOp)

        if not elseReturns 'elseNeedsMerge'
            ops.push(MaxonOp.br(mergeLabel))
        end 'elseNeedsMerge'

        // Skip 'end' and label
        pos = pos + 1  // skip 'end'
        let afterElseEnd = tokenAt(tokens, pos: pos)
        if afterElseEnd.kind == TokenKind.stringLiteral 'hasElseEndLabel'
            pos = pos + 1
        end 'hasElseEndLabel'
    end 'isElse'

    if not hasElse 'noElseBlock'
        // No else: else label jumps straight to merge
        ops.push(MaxonOp.label(elseLabel))
    end 'noElseBlock'

    // Emit merge label if either branch needs it
    if not (thenReturns and elseReturns) 'needsMerge'
        ops.push(MaxonOp.label(mergeLabel))
    end 'needsMerge'

    return pos
end 'parseIfStatement'

function isReturnOp(op MaxonOp) returns bool
    match op 'check'
        returnOp(retValId) then return true
        literal(resultId, value) then return false
        floatLiteral(resultId, rawBits) then return false
        varDecl(slotId, valueId) then return false
        varLoad(resultId, slotId) then return false
        add(resultId, leftId, rightId) then return false
        sub(resultId, leftId, rightId) then return false
        mul(resultId, leftId, rightId) then return false
        cmpEq(resultId, leftId, rightId) then return false
        cmpNe(resultId, leftId, rightId) then return false
        cmpLt(resultId, leftId, rightId) then return false
        cmpLe(resultId, leftId, rightId) then return false
        cmpGt(resultId, leftId, rightId) then return false
        cmpGe(resultId, leftId, rightId) then return false
        floatCmpEq(resultId, leftId, rightId) then return false
        condBr(condId, tl, el) then return false
        br(targetLabel) then return false
        label(name) then return false
        printLiteral(data) then return false
        printInt(valueId) then return false
        funcBegin(name, returnType) then return false
        funcEnd then return false
        call(resultId, callee) then return false
    end 'check'
end 'isReturnOp'

function nextLabelName(project Project, prefix ByteBuffer) returns ByteArray
    let id = project.nextLabelId_
    project.nextLabelId_ = project.nextLabelId_ + 1
    var buf = ByteArray{}
    // "__label_"
    buf.push(95)
    buf.push(95)
    buf.push(108)
    buf.push(97)
    buf.push(98)
    buf.push(101)
    buf.push(108)
    buf.push(95)
    appendBytes(buf, src: prefix)
    buf.push(95)
    appendIntBytes(buf, n: id)
    return buf
end 'nextLabelName'

function appendBytes(dst ByteArray, src ByteBuffer)
    var i = 0
    while i < src.count() 'copy'
        dst.push(try src.get(i) otherwise 0)
        i = i + 1
    end 'copy'
end 'appendBytes'

function appendIntBytes(dst ByteArray, n ParsedInt)
    if n == 0 'zero'
        dst.push(48)
        return
    end 'zero'
    // Compute digits in reverse, then append in order
    var digits = ByteArray{}
    var remaining = n
    while remaining > 0 'digitLoop'
        digits.push(48 + (remaining mod 10))
        remaining = remaining / 10
    end 'digitLoop'
    var i = digits.count() - 1
    while i >= 0 'reverse'
        dst.push(try digits.get(i) otherwise 48)
        i = i - 1
    end 'reverse'
end 'appendIntBytes'

function parseVarDecl(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns TokenIndex throws CompileError
    var pos = startPos + 1  // skip 'var'/'let'
    let nameToken = tokenAt(tokens, pos: pos)
    pos = pos + 1  // skip name
    let equalsToken = tokenAt(tokens, pos: pos)
    if equalsToken.kind != TokenKind.equals 'notEquals'
        let tokStr = tokenValueToString(equalsToken.value)
        try raiseCompileError(ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokStr}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
    end 'notEquals'
    pos = pos + 1  // skip '='
    let exprResult = try parseExpression(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
    pos = exprResult.nextPos
    let slot = defineVariable(project, name: nameToken.value, isFloat: exprResult.isFloat)
    ops.push(MaxonOp.varDecl(slot, exprResult.valueId))
    return pos
end 'parseVarDecl'

function parsePrintStatement(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns TokenIndex throws CompileError
    var pos = startPos + 1  // skip 'print'
    pos = pos + 1  // skip '('
    let strToken = tokenAt(tokens, pos: pos)
    pos = pos + 1  // skip string
    pos = pos + 1  // skip ')'

    // Parse the double-quoted string for interpolation segments
    try parseStringInterpolation(project, str: strToken.value, ops: ops, filePath: filePath)

    return pos
end 'parsePrintStatement'

// --- String Interpolation ---

function parseStringInterpolation(project Project, str ByteArray, ops MaxonOpArray, filePath String) throws CompileError
    var buf = ByteArray{}
    var i = 0
    let len = str.count()

    while i < len 'scan'
        let ch = try str.get(i) otherwise 0

        // Escape sequences
        if ch == 92 'backslash'
            if i + 1 < len 'hasNext'
                let next = try str.get(i + 1) otherwise 0
                if next == 110 'escN'
                    buf.push(10)
                    i = i + 2
                    continue
                end 'escN'
                if next == 116 'escT'
                    buf.push(9)
                    i = i + 2
                    continue
                end 'escT'
                if next == 92 'escBS'
                    buf.push(92)
                    i = i + 2
                    continue
                end 'escBS'
                if next == 34 'escDQ'
                    buf.push(34)
                    i = i + 2
                    continue
                end 'escDQ'
            end 'hasNext'
            buf.push(ch)
            i = i + 1
            continue
        end 'backslash'

        // Interpolation: { ... }
        if ch == 123 'openBrace'
            // Flush literal buffer
            if not buf.isEmpty() 'flushBuf'
                ops.push(MaxonOp.printLiteral(buf))
                buf = ByteArray{}
            end 'flushBuf'

            // Extract expression between braces
            i = i + 1
            let exprStart = i
            var braceDepth = 1
            while i < len and braceDepth > 0 'findClose'
                let bc = try str.get(i) otherwise 0
                if bc == 123 'nested'
                    braceDepth = braceDepth + 1
                end 'nested'
                if bc == 125 'close'
                    braceDepth = braceDepth - 1
                end 'close'
                if braceDepth > 0 'notDone'
                    i = i + 1
                end 'notDone'
            end 'findClose'

            // Tokenize and parse the expression between braces
            let exprBytes = sliceBytes(str, startPos: exprStart, endPos: i)
            let exprTokens = tokenize(exprBytes)
            let exprResult = try parseExpression(project, tokens: exprTokens, startPos: 0, ops: ops, filePath: filePath)
            ops.push(MaxonOp.printInt(exprResult.valueId))

            i = i + 1  // skip closing brace
            continue
        end 'openBrace'

        buf.push(ch)
        i = i + 1
    end 'scan'

    // Flush remaining literal buffer
    if not buf.isEmpty() 'flushRemaining'
        ops.push(MaxonOp.printLiteral(buf))
    end 'flushRemaining'
end 'parseStringInterpolation'

// --- Expression Parsing ---

// Result of parsing an expression: the value ID and next token position
export type ExprResult
    export var valueId ValueId
    export var nextPos TokenIndex
    export var isFloat bool
    // For compile-time string constant folding
    export var isStringConst bool
    export var stringConstValue ByteArray
end 'ExprResult'

function parseExpression(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns ExprResult throws CompileError
    return try parseComparison(project, tokens: tokens, startPos: startPos, ops: ops, filePath: filePath)
end 'parseExpression'

// Comparison: addSub (== | != | < | <= | > | >=) addSub
function parseComparison(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns ExprResult throws CompileError
    var result = try parseAddSub(project, tokens: tokens, startPos: startPos, ops: ops, filePath: filePath)
    var pos = result.nextPos
    var leftId = result.valueId
    var leftIsFloat = result.isFloat

    let opToken = tokenAt(tokens, pos: pos)
    if opToken.kind == TokenKind.equalsEquals 'isEqEq'
        pos = pos + 1
        // Compile-time string constant folding: both sides must be string constants
        if result.isStringConst 'leftIsStr'
            let right = try parsePrimary(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
            pos = right.nextPos
            // Emit an integer comparison that produces the folded result.
            // true: emit `1 == 1`, false: emit `0 == 1`
            var foldedLeft = 1
            if not bytesEqual(result.stringConstValue, b: right.stringConstValue) 'strNeq'
                foldedLeft = 0
            end 'strNeq'
            let leftLitId = nextValueId(project)
            ops.push(MaxonOp.literal(leftLitId, foldedLeft))
            let rightLitId = nextValueId(project)
            ops.push(MaxonOp.literal(rightLitId, 1))
            let resultId = nextValueId(project)
            ops.push(MaxonOp.cmpEq(resultId, leftLitId, rightLitId))
            return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
        end 'leftIsStr'
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        if leftIsFloat or right.isFloat 'floatCmp'
            ops.push(MaxonOp.floatCmpEq(resultId, leftId, right.valueId))
        end 'floatCmp' else 'intCmp'
            ops.push(MaxonOp.cmpEq(resultId, leftId, right.valueId))
        end 'intCmp'
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isEqEq'
    if opToken.kind == TokenKind.bangEquals 'isNeq'
        pos = pos + 1
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        ops.push(MaxonOp.cmpNe(resultId, leftId, right.valueId))
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isNeq'
    if opToken.kind == TokenKind.lessThan 'isLt'
        pos = pos + 1
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        ops.push(MaxonOp.cmpLt(resultId, leftId, right.valueId))
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isLt'
    if opToken.kind == TokenKind.lessEquals 'isLe'
        pos = pos + 1
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        ops.push(MaxonOp.cmpLe(resultId, leftId, right.valueId))
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isLe'
    if opToken.kind == TokenKind.greaterThan 'isGt'
        pos = pos + 1
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        ops.push(MaxonOp.cmpGt(resultId, leftId, right.valueId))
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isGt'
    if opToken.kind == TokenKind.greaterEquals 'isGe'
        pos = pos + 1
        let right = try parseAddSub(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
        pos = right.nextPos
        let resultId = nextValueId(project)
        ops.push(MaxonOp.cmpGe(resultId, leftId, right.valueId))
        return {valueId: resultId, nextPos: pos, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isGe'

    return {valueId: leftId, nextPos: pos, isFloat: leftIsFloat, isStringConst: false, stringConstValue: ByteArray{}}
end 'parseComparison'

function parseAddSub(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns ExprResult throws CompileError
    var result = try parseMulDiv(project, tokens: tokens, startPos: startPos, ops: ops, filePath: filePath)
    var pos = result.nextPos
    var leftId = result.valueId
    var leftIsFloat = result.isFloat

    while pos < tokens.count() 'addSubLoop'
        let opToken = tokenAt(tokens, pos: pos)
        if opToken.kind == TokenKind.plus 'isAdd'
            pos = pos + 1
            let right = try parseMulDiv(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
            pos = right.nextPos
            let resultId = nextValueId(project)
            ops.push(MaxonOp.add(resultId, leftId, right.valueId))
            leftId = resultId
        end 'isAdd' else 'notAdd'
            if opToken.kind == TokenKind.minus 'isSub'
                pos = pos + 1
                let right = try parseMulDiv(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
                pos = right.nextPos
                let resultId = nextValueId(project)
                ops.push(MaxonOp.sub(resultId, leftId, right.valueId))
                leftId = resultId
            end 'isSub' else 'notSub'
                break 'addSubLoop'
            end 'notSub'
        end 'notAdd'
    end 'addSubLoop'

    return {valueId: leftId, nextPos: pos, isFloat: leftIsFloat, isStringConst: false, stringConstValue: ByteArray{}}
end 'parseAddSub'

function parseMulDiv(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns ExprResult throws CompileError
    var result = try parsePrimary(project, tokens: tokens, startPos: startPos, ops: ops, filePath: filePath)
    var pos = result.nextPos
    var leftId = result.valueId
    var leftIsFloat = result.isFloat

    while pos < tokens.count() 'mulLoop'
        let opToken = tokenAt(tokens, pos: pos)
        if opToken.kind == TokenKind.star 'isMul'
            pos = pos + 1
            let right = try parsePrimary(project, tokens: tokens, startPos: pos, ops: ops, filePath: filePath)
            pos = right.nextPos
            let resultId = nextValueId(project)
            ops.push(MaxonOp.mul(resultId, leftId, right.valueId))
            leftId = resultId
        end 'isMul' else 'notMul'
            break 'mulLoop'
        end 'notMul'
    end 'mulLoop'

    return {valueId: leftId, nextPos: pos, isFloat: leftIsFloat, isStringConst: false, stringConstValue: ByteArray{}}
end 'parseMulDiv'

function parsePrimary(project Project, tokens TokenArray, startPos TokenIndex, ops MaxonOpArray, filePath String) returns ExprResult throws CompileError
    let token = tokenAt(tokens, pos: startPos)

    if token.kind == TokenKind.intLiteral 'isInt'
        let value = parseInt(token.value)
        let id = nextValueId(project)
        ops.push(MaxonOp.literal(id, value))
        return {valueId: id, nextPos: startPos + 1, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isInt'

    if token.kind == TokenKind.floatLiteral 'isFloat'
        let rawBits = parseFloatBits(token.value)
        let id = nextValueId(project)
        ops.push(MaxonOp.floatLiteral(id, rawBits))
        return {valueId: id, nextPos: startPos + 1, isFloat: true, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isFloat'

    if token.kind == TokenKind.identifier 'isIdent'
        let peekToken = tokenAt(tokens, pos: startPos + 1)
        if peekToken.kind == TokenKind.leftParen 'isCall'
            let callId = nextValueId(project)
            ops.push(MaxonOp.call(callId, token.value))
            return {valueId: callId, nextPos: startPos + 3, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
        end 'isCall'
        // Check for compile-time string constant before variable lookup
        let strConst = lookupStringConst(project, name: token.value)
        if not strConst.isEmpty() 'isStrConst'
            let id = nextValueId(project)
            return {valueId: id, nextPos: startPos + 1, isFloat: false, isStringConst: true, stringConstValue: strConst}
        end 'isStrConst'
        let slot = try lookupVariable(project, name: token.value, token: token, filePath: filePath)
        let id = nextValueId(project)
        ops.push(MaxonOp.varLoad(id, slot))
        let varIsFloat = isVariableFloat(project, name: token.value)
        return {valueId: id, nextPos: startPos + 1, isFloat: varIsFloat, isStringConst: false, stringConstValue: ByteArray{}}
    end 'isIdent'

    // String literal in expression position — treated as compile-time constant
    if token.kind == TokenKind.doubleStringLiteral 'isStrLit'
        let id = nextValueId(project)
        return {valueId: id, nextPos: startPos + 1, isFloat: false, isStringConst: true, stringConstValue: token.value}
    end 'isStrLit'

    if token.kind == TokenKind.leftParen 'isParen'
        let inner = try parseExpression(project, tokens: tokens, startPos: startPos + 1, ops: ops, filePath: filePath)
        return {valueId: inner.valueId, nextPos: inner.nextPos + 1, isFloat: inner.isFloat, isStringConst: inner.isStringConst, stringConstValue: inner.stringConstValue}
    end 'isParen'

    // Fallback: return 0
    let id = nextValueId(project)
    ops.push(MaxonOp.literal(id, 0))
    return {valueId: id, nextPos: startPos + 1, isFloat: false, isStringConst: false, stringConstValue: ByteArray{}}
end 'parsePrimary'

// --- Helpers ---

function skipNewlines(tokens TokenArray, startPos TokenIndex) returns TokenIndex
    var pos = startPos
    while pos < tokens.count() 'skip'
        let token = tokenAt(tokens, pos: pos)
        if token.kind == TokenKind.newline 'isNewline'
            pos = pos + 1
        end 'isNewline' else 'notNewline'
            return pos
        end 'notNewline'
    end 'skip'
    return pos
end 'skipNewlines'

function tokenAt(tokens TokenArray, pos TokenIndex) returns Token
    return try tokens.get(pos) otherwise Token{kind: TokenKind.eof, value: ByteArray{}, line: 0, column: 0}
end 'tokenAt'

// Convert a decimal float string (e.g. "3.14") to IEEE 754 double raw bits.
// Uses integer-only arithmetic: parses into integer/fraction parts,
// then constructs the IEEE 754 representation manually.
function parseFloatBits(s ByteArray) returns ParsedInt
    // Parse integer and fractional parts as integers
    var intPart = 0
    var fracPart = 0
    var fracDigits = 0
    var pastDot = false

    var pi = 0
    while pi < s.count() 'parse'
        let b = try s.get(pi) otherwise 0
        if b == 46 'isDot'
            pastDot = true
        end 'isDot' else 'notDot'
            if b >= 48 and b <= 57 'isDigit'
                if pastDot 'frac'
                    fracPart = fracPart * 10 + (b - 48)
                    fracDigits = fracDigits + 1
                end 'frac' else 'int'
                    intPart = intPart * 10 + (b - 48)
                end 'int'
            end 'isDigit'
        end 'notDot'
        pi = pi + 1
    end 'parse'

    // Compute fracDivisor = 10^fracDigits
    var fracDivisor = 1
    var fd = 0
    while fd < fracDigits 'powLoop'
        fracDivisor = fracDivisor * 10
        fd = fd + 1
    end 'powLoop'

    // Build the mantissa by scaling: value = intPart + fracPart/fracDivisor
    // We need to find exponent and 52-bit mantissa for IEEE 754 double.

    // Find the binary exponent: how many times we can halve or double intPart
    // Strategy: scale the value into [1.0, 2.0) by tracking the exponent
    // Represent value as (intPart * fracDivisor + fracPart) / fracDivisor

    var numerator = intPart * fracDivisor + fracPart
    var denominator = fracDivisor

    // Handle zero
    if numerator == 0 'isZero'
        return 0
    end 'isZero'

    // Find exponent: normalize so that 1 <= numerator/denominator < 2
    // i.e., denominator <= numerator < 2*denominator
    var exponent = 0
    while numerator >= 2 * denominator 'shiftDown'
        denominator = denominator * 2
        exponent = exponent + 1
    end 'shiftDown'
    while numerator < denominator 'shiftUp'
        numerator = numerator * 2
        exponent = exponent - 1
    end 'shiftUp'

    // Now 1.0 <= numerator/denominator < 2.0
    // Extract 52 bits of mantissa (implicit leading 1 is not stored)
    // mantissa = ((numerator/denominator - 1) * 2^52)
    numerator = numerator - denominator
    var mantissa = 0
    var bit = 51
    while bit >= 0 'mantissaBits'
        numerator = numerator * 2
        if numerator >= denominator 'hasBit'
            mantissa = mantissa + (1 shl bit)
            numerator = numerator - denominator
        end 'hasBit'
        bit = bit - 1
    end 'mantissaBits'

    // IEEE 754 double: sign(1) | exponent+1023(11) | mantissa(52)
    let biasedExp = exponent + 1023
    return (biasedExp shl 52) + mantissa
end 'parseFloatBits'

function parseInt(s ByteArray) returns ParsedInt
    var result = 0
    var pi = 0
    while pi < s.count() 'digits'
        let b = try s.get(pi) otherwise 0
        if b >= 48 and b <= 57 'digit'
            result = result * 10 + (b - 48)
        end 'digit'
        pi = pi + 1
    end 'digits'
    return result
end 'parseInt'

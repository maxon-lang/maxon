// Recursive descent parser.
// Consumes tokens and emits Maxon ops into an MlirModule with block-based CFG.

export typealias ValueId = int(0 to u64.max)
export typealias VarSlot = int(0 to u64.max)
export typealias ParsedInt = int(i64.min to i64.max)
export typealias VarSlotArray = Array with VarSlot
export typealias BoolArray = Array with bool
export typealias ByteArrayArray = Array with ByteArray
// Scope depth tracking for block scoping (if/while bodies).
// Records the symbol table size when entering a scope so variables can be removed on exit.
export typealias ScopeDepth = int(0 to u64.max)
export typealias ScopeDepthArray = Array with ScopeDepth

typealias TokenIndex = int(0 to u64.max)

enum ParserError
	unhandledToken
	typeError
	overflow
end 'ParserError'

// --- Standalone pure functions ---

function tokenAt(tokens TokenArray, pos TokenIndex) returns Token
	return try tokens.get(pos) otherwise Token.eof()
end 'tokenAt'

// --- Block-based emission helpers ---

function emitOp(module MlirModule, block MlirBlock, op MaxonOp)
	appendMaxonOp(module, block: block, op: op)
end 'emitOp'

function finalizeBlock(module MlirModule, block MlirBlock, terminator MaxonOp)
	setMaxonTerminator(module, block: block, op: terminator)
end 'finalizeBlock'

function newBlock(module MlirModule, func MlirFunction, label String) returns MlirBlock
	return addBlock(module, func: func, label: label)
end 'newBlock'

// Create a block that is not added to the function's block list.
// Used as a sink for dead code after fully-terminated if/else branches.
function newDetachedBlock(func MlirFunction) returns MlirBlock
	let id = func.nextBlockId
	func.nextBlockId = func.nextBlockId + 1
	return createMlirBlock(id, label: "dead")
end 'newDetachedBlock'

// --- Pure number parsing ---

// Convert a decimal float string (e.g. "3.14", "1.5e2", "2.0e-3") to IEEE 754 double raw bits.
// Throws ParserError.overflow if the value exceeds float64 range.
function parseFloatBits(s String) returns ParsedInt throws ParserError
	let bytes = s.toByteArray()
	var intPart = 0
	var fracPart = 0
	var fracDigits = 0
	var pastDot = false
	var sciExp = 0
	var sciExpNeg = false
	var inExponent = false
	var intDigits = 0
	var hasNonZeroDigit = false

	var pi = 0
	while pi < bytes.count() 'parse'
		let b = try bytes.get(pi) otherwise 0

		if b == '_' 'skipUnderscore'
			pi = pi + 1
			continue
		end 'skipUnderscore'

		if inExponent 'expPart'
			if b >= '0' and b <= '9' 'expDigit'
				sciExp = sciExp * 10 + (b - '0')
				if sciExp > 100000 'capExp'
					sciExp = 100000
				end 'capExp'
			end 'expDigit'
		end 'expPart' else 'mantissaPart'
			if b == 'e' or b == 'E' 'startExp'
				inExponent = true
				if pi + 1 < bytes.count() 'peekSign'
					let signByte = try bytes.get(pi + 1) otherwise 0
					if signByte == '-' 'negSign'
						sciExpNeg = true
						pi = pi + 1
					end 'negSign' else if signByte == '+' 'posSign'
						pi = pi + 1
					end 'posSign'
				end 'peekSign'
			end 'startExp' else 'notExp'
				if b == '.' 'isDot'
					pastDot = true
				end 'isDot' else 'notDot'
					if b >= '0' and b <= '9' 'isDigit'
						if b != '0' 'nonZero'
							hasNonZeroDigit = true
						end 'nonZero'
						if pastDot 'frac'
							fracPart = fracPart * 10 + (b - '0')
							fracDigits = fracDigits + 1
						end 'frac' else 'int'
							intPart = intPart * 10 + (b - '0')
							intDigits = intDigits + 1
						end 'int'
					end 'isDigit'
				end 'notDot'
			end 'notExp'
		end 'mantissaPart'
		pi = pi + 1
	end 'parse'

	// float64 max is ~1.8e308; effective magnitude ~ 10^(intDigits - 1 + sciExp).
	if hasNonZeroDigit and not sciExpNeg 'checkOverflow'
		let effectiveExp = intDigits - 1 + sciExp
		if effectiveExp > 308 'overflow'
			throw ParserError.overflow
		end 'overflow'
	end 'checkOverflow'

	// Compute fracDivisor = 10^fracDigits
	var fracDivisor = 1
	for _ in 0 upto fracDigits 'powLoop'
		fracDivisor = fracDivisor * 10
	end 'powLoop'

	var numerator = intPart * fracDivisor + fracPart
	var denominator = fracDivisor

	if sciExp > 0 'applySciExp'
		if sciExpNeg 'divByTen'
			for _ in 0 upto sciExp 'divLoop'
				denominator = denominator * 10
			end 'divLoop'
		end 'divByTen' else 'mulByTen'
			for _ in 0 upto sciExp 'mulLoop'
				numerator = numerator * 10
			end 'mulLoop'
		end 'mulByTen'
	end 'applySciExp'

	if numerator == 0 'isZero'
		return 0
	end 'isZero'

	var exponent = 0
	while numerator >= 2 * denominator 'shiftDown'
		denominator = denominator * 2
		exponent = exponent + 1
	end 'shiftDown'
	while numerator < denominator 'shiftUp'
		numerator = numerator * 2
		exponent = exponent - 1
	end 'shiftUp'

	numerator = numerator - denominator
	var mantissa = 0
	var bit = 51
	while bit >= 0 'mantissaBits'
		numerator = numerator * 2
		if numerator >= denominator 'hasBit'
			mantissa = mantissa + (1 shl bit)
			numerator = numerator - denominator
		end 'hasBit'
		bit = bit - 1
	end 'mantissaBits'

	// IEEE 754 double layout: sign(1) | exponent+1023(11) | mantissa(52)
	let biasedExp = exponent + 1023
	return(biasedExp shl 52) + mantissa
end 'parseFloatBits'

// Parse an integer literal. Throws ParserError.overflow if the value exceeds i64 range.
// Handles decimal, hex (0x), binary (0b), and octal (0o) prefixes.
function parseInt(s String) returns ParsedInt throws ParserError
	let bytes = s.toByteArray()
	let sLen = bytes.count()

	if sLen < 1 'empty'
		return 0
	end 'empty'

	if sLen >= 2 'checkPrefix'
		let first = try bytes.get(0) otherwise 0
		let second = try bytes.get(1) otherwise 0

		if first == '0' and(second == 'x' or second == 'X') 'isHex'
			return try parseHexInt(bytes, startIndex: 2)
		end 'isHex' else if first == '0' and(second == 'b' or second == 'B') 'isBin'
			return try parseBinaryInt(bytes, startIndex: 2)
		end 'isBin' else if first == '0' and(second == 'o' or second == 'O') 'isOct'
			return try parseOctalInt(bytes, startIndex: 2)
		end 'isOct'
	end 'checkPrefix'

	var result = 0
	var digitCount = 0
	var leadingZeros = true
	for pi in 0 upto sLen 'digits'
		let b = try bytes.get(pi) otherwise 0
		if b >= '0' and b <= '9' 'digit'
			result = result * 10 + (b - '0')
			if not leadingZeros or b != '0' 'significant'
				leadingZeros = false
				digitCount = digitCount + 1
			end 'significant'
		end 'digit'
	end 'digits'

	// >19 significant digits always overflows i64
	if digitCount > 19 'tooMany'
		throw ParserError.overflow
	end 'tooMany'

	// Exactly 19 digits: compare digit-by-digit against "9223372036854775807"
	if digitCount == 19 'checkMax'
		let maxStr = b"9223372036854775807"
		var mi = 0
		var pastLeading = false
		for pi in 0 upto sLen 'cmp'
			let b = try bytes.get(pi) otherwise 0
			if b == '_' 'skipUs'
				continue
			end 'skipUs'
			if not pastLeading and b == '0' 'skipLz'
				continue
			end 'skipLz'
			if b >= '0' and b <= '9' 'cmpDigit'
				pastLeading = true
				let maxByte = try maxStr.get(mi) otherwise 0
				if b > maxByte 'bigger'
					throw ParserError.overflow
				end 'bigger' else if b < maxByte 'smaller'
					return result
				end 'smaller'
				mi = mi + 1
			end 'cmpDigit'
		end 'cmp'
	end 'checkMax'

	return result
end 'parseInt'

// Parse a hex integer literal. Throws ParserError.overflow if more than 16 significant hex digits.
function parseHexInt(s ByteArray, startIndex CharOffset) returns ParsedInt throws ParserError
	var result = 0
	var digitCount = 0
	var leadingZeros = true
	for pi in startIndex upto s.count() 'hexDigits'
		let b = try s.get(pi) otherwise 0
		if b >= '0' and b <= '9' 'decDigit'
			result = result * 16 + (b - '0')
			if not leadingZeros or b != '0' 'sigDec'
				leadingZeros = false
				digitCount = digitCount + 1
			end 'sigDec'
		end 'decDigit' else if b >= 'a' and b <= 'f' 'lowerHex'
			result = result * 16 + (b - 'a' + 10)
			leadingZeros = false
			digitCount = digitCount + 1
		end 'lowerHex' else if b >= 'A' and b <= 'F' 'upperHex'
			result = result * 16 + (b - 'A' + 10)
			leadingZeros = false
			digitCount = digitCount + 1
		end 'upperHex'
	end 'hexDigits'
	if digitCount > 16 'overflow'
		throw ParserError.overflow
	end 'overflow'
	return result
end 'parseHexInt'

// Throws ParserError.overflow if more than 64 significant binary digits.
function parseBinaryInt(s ByteArray, startIndex CharOffset) returns ParsedInt throws ParserError
	var result = 0
	var digitCount = 0
	var leadingZeros = true
	for pi in startIndex upto s.count() 'binDigits'
		let b = try s.get(pi) otherwise 0
		if b == '0' 'zeroBit'
			result = result * 2
			if not leadingZeros 'sigZero'
				digitCount = digitCount + 1
			end 'sigZero'
		end 'zeroBit' else if b == '1' 'oneBit'
			result = result * 2 + 1
			leadingZeros = false
			digitCount = digitCount + 1
		end 'oneBit'
	end 'binDigits'
	if digitCount > 64 'overflow'
		throw ParserError.overflow
	end 'overflow'
	return result
end 'parseBinaryInt'

// Throws ParserError.overflow if more than 21 significant octal digits,
// or exactly 21 with a leading digit > 1 (exceeds 64 bits).
function parseOctalInt(s ByteArray, startIndex CharOffset) returns ParsedInt throws ParserError
	var result = 0
	var digitCount = 0
	var leadingZeros = true
	var firstSignificantDigit = 0
	for pi in startIndex upto s.count() 'octDigits'
		let b = try s.get(pi) otherwise 0
		if b >= '0' and b <= '7' 'octDigit'
			result = result * 8 + (b - '0')
			if not leadingZeros or b != '0' 'significant'
				if leadingZeros 'firstSig'
					firstSignificantDigit = b - '0'
				end 'firstSig'
				leadingZeros = false
				digitCount = digitCount + 1
			end 'significant'
		end 'octDigit'
	end 'octDigits'
	// 64 bits = 21 octal digits max, but first digit can be at most 1 (0o1777...7)
	if digitCount > 21 or(digitCount == 21 and firstSignificantDigit > 1) 'overflow'
		throw ParserError.overflow
	end 'overflow'
	return result
end 'parseOctalInt'

function tokenValueToString(value String) returns String
	if value.isEmpty() 'empty'
		return "(empty)"
	end 'empty'
	return value
end 'tokenValueToString'

// Derive a namespace from the file path.
// For .test files, uses the spec category name (part before first dot in stem).
// For .maxon files, uses the filename stem.
function deriveNamespace(filePath FilePath) returns String
	let stem = filePath.stem()
	// For spec test fragments (.test files), use the part before the first dot
	// e.g. "panic.in-function" -> "panic"
	let ext = filePath.fileExtension()
	if ext == ".test" 'isTest'
		let stemBytes = stem.toByteArray()
		let dotByte = 0x2E
		for i in 0 upto stemBytes.count() 'findDot'
			let b = try stemBytes.get(i) otherwise 0
			if b == dotByte 'isDot'
				return String.from(stemBytes.slice(0, endIndex: i))
			end 'isDot'
		end 'findDot'
	end 'isTest'
	return stem
end 'deriveNamespace'

// Qualify a function name with namespace: "ns.name".
// Returns the raw name if namespace is empty.
function qualifyName(ns String, name String) returns String
	if ns.isEmpty() 'noNs'
		return name
	end 'noNs'
	return "{ns}.{name}"
end 'qualifyName'

// --- Pratt parser binding power ---

typealias BindingPower = int(0 to 14)

// Throws for non-operator tokens; the call site uses `otherwise 0` to stop the Pratt loop.
function infixBindingPower(kind TokenKind) returns BindingPower throws ParserError
	return match kind 'bp'
		or gives 2
		xor gives 4
		and gives 6
		shl gives 8
		shr gives 8
		equalsEquals gives 10
		bangEquals gives 10
		is gives 10
		lessThan gives 10
		lessEquals gives 10
		greaterThan gives 10
		greaterEquals gives 10
		plus gives 12
		minus gives 12
		star gives 14
		slash gives 14
		mod gives 14
		default throws ParserError.unhandledToken
	end 'bp'
end 'infixBindingPower'

// --- Type bound parsing helpers ---

typealias BoundValue = int(i64.min to i64.max)

let typeBoundsTable = [
	"u8.min": 0, "u8.max": 255, "u16.min": 0, "u16.max": 65535, "u32.min": 0, "u32.max": 4294967295, "u64.min": 0, "u64.max": -1,
	"i8.min": -128, "i8.max": 127, "i16.min": -32768, "i16.max": 32767, "i32.min": -2147483648, "i32.max": 2147483647, "i64.min": -9223372036854775808, "i64.max": 9223372036854775807
]

function resolveTypeBound(typeName String, field String) returns BoundValue
	let key = "{typeName}.{field}"
	return try typeBoundsTable.get(key) otherwise 0
end 'resolveTypeBound'

function computeOptimalIntType(lower BoundValue, upper BoundValue) returns String
	if lower >= 0 'unsigned'
		// If upper is negative, it wrapped (e.g. u64.max = -1), so it must be u64
		if upper < 0 'wrappedU64'
			return "u64"
		end 'wrappedU64'
		if upper <= u8.max 'u8'
			return "u8"
		end 'u8'
		if upper <= u16.max 'u16'
			return "u16"
		end 'u16'
		if upper <= u32.max 'u32'
			return "u32"
		end 'u32'
		return "u64"
	end 'unsigned'
	return "i64"
end 'computeOptimalIntType'

// --- ExprResult type ---

// Result of parsing an expression: the value ID and metadata.
// pos is tracked on the Parser, so no nextPos field.
type ExprResult
	export var valueId ValueId
	export var isFloat bool
	export var isRefType bool
	// For compile-time string constant folding
	export var isStringConst bool
	export var stringConstValue String
	// Struct type name for ref-type results (empty for non-struct)
	export var structTypeName String

	static function create(valueId ValueId) returns ExprResult
		return Self{valueId: valueId, isFloat: false, isRefType: false, isStringConst: false, stringConstValue: "", structTypeName: ""}
	end 'create'

	static function createFloat(valueId ValueId) returns ExprResult
		return Self{valueId: valueId, isFloat: true, isRefType: false, isStringConst: false, stringConstValue: "", structTypeName: ""}
	end 'createFloat'

	static function createFull(valueId ValueId, isFloat bool, isRefType bool, isStringConst bool, stringConstValue String) returns ExprResult
		return Self{valueId: valueId, isFloat: isFloat, isRefType: isRefType, isStringConst: isStringConst, stringConstValue: stringConstValue, structTypeName: ""}
	end 'createFull'

	static function createStruct(valueId ValueId, structTypeName String) returns ExprResult
		return Self{valueId: valueId, isFloat: false, isRefType: true, isStringConst: false, stringConstValue: "", structTypeName: structTypeName}
	end 'createStruct'
end 'ExprResult'

// --- Parser type ---

type Parser
	var project Project
	var tokens TokenArray
	var pos TokenIndex
	var filePath FilePath
	// Current type name when parsing inside a type declaration (for Self resolution)
	var currentTypeName String

	static function create(project Project, tokens TokenArray, filePath FilePath) returns Parser
		return Self{project: project, tokens: tokens, pos: 0, filePath: filePath, currentTypeName: ""}
	end 'create'

	// --- Token navigation helpers ---

	function peek() returns Token
		return tokenAt(tokens, pos: pos)
	end 'peek'

	function peekAt(offset TokenIndex) returns Token
		return tokenAt(tokens, pos: pos + offset)
	end 'peekAt'

	function advance()
		pos = pos + 1
	end 'advance'

	function consume() returns Token
		let token = tokenAt(tokens, pos: pos)
		pos = pos + 1
		return token
	end 'consume'

	function at(kind TokenKind) returns bool
		return peek().kind == kind
	end 'at'

	function expect(kind TokenKind)
		if at(kind) 'matched'
			advance()
			return
		end 'matched'
		let token = peek()
		reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected {kind.name} but got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
	end 'expect'

	function skipNewlines()
		while pos < tokens.count() 'skip'
			if at(TokenKind.newline) 'isNewline'
				advance()
			end 'isNewline' else 'notNewline'
				return
			end 'notNewline'
		end 'skip'
	end 'skipNewlines'

	function expectNewlineAfterLabel()
		if not at(TokenKind.newline) 'noNewline'
			let token = peek()
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected newline after block label, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		end 'noNewline'
		skipNewlines()
	end 'expectNewlineAfterLabel'

	function skipEndAndLabel()
		expect(TokenKind.end)
		if at(TokenKind.stringLiteral) 'hasLabel'
			advance()
		end 'hasLabel'
	end 'skipEndAndLabel'

	function skipToNextLine()
		while pos < tokens.count() 'skip'
			if at(TokenKind.newline) or at(TokenKind.eof) 'atEnd'
				return
			end 'atEnd'
			advance()
		end 'skip'
	end 'skipToNextLine'

	// Error recovery: skip to next statement boundary.
	// Always advances at least 1 token to prevent infinite loops.
	function synchronize()
		if pos < tokens.count() 'advanceOne'
			advance()
		end 'advanceOne'
		while pos < tokens.count() 'sync'
			if at(TokenKind.end) or at(TokenKind.eof) 'atBoundary'
				return
			end 'atBoundary'
			if at(TokenKind.newline) 'atNewline'
				advance()
				return
			end 'atNewline'
			advance()
		end 'sync'
	end 'synchronize'

	// --- Emission helpers ---

	function emitLiteral(module MlirModule, block MlirBlock, value ParsedInt, isFloat bool) returns ValueId
		let id = nextValueId(project)
		emitOp(module, block: block, op: MaxonOp.literal(id, value: value, isFloat: isFloat))
		return id
	end 'emitLiteral'

	function emitImplicitReturn(module MlirModule, block MlirBlock)
		let zeroId = emitLiteral(module, block: block, value: 0, isFloat: false)
		finalizeBlock(module, block: block, terminator: MaxonOp.ret(zeroId))
	end 'emitImplicitReturn'

	// Finalize an if/else by emitting the condBr and returning either a
	// detached block (both branches terminated) or a new merge block.
	// Uses captured block IDs to avoid stale references from nested parsing.
	function finalizeIfElseById(module MlirModule, func MlirFunction, condBlock MlirBlock, condValueId ValueId, thenBlockId BlockId, thenExit MlirBlock, elseBlockId BlockId, elseExit MlirBlock, baseLabel String) returns MlirBlock
		finalizeBlock(module, block: condBlock, terminator: MaxonOp.condBr(condValueId, thenTarget: thenBlockId, elseTarget: elseBlockId))
		if thenExit.hasTerminator and elseExit.hasTerminator 'bothTerminated'
			return newDetachedBlock(func)
		end 'bothTerminated'
		let mergeBlock = newBlock(module, func: func, label: "{baseLabel}.merge")
		branchIfNeeded(module, block: thenExit, target: mergeBlock.id)
		branchIfNeeded(module, block: elseExit, target: mergeBlock.id)
		return mergeBlock
	end 'finalizeIfElseById'

	function branchIfNeeded(module MlirModule, block MlirBlock, target BlockId)
		if not block.hasTerminator 'needsBranch'
			finalizeBlock(module, block: block, terminator: MaxonOp.br(target))
		end 'needsBranch'
	end 'branchIfNeeded'

	// --- Symbol table helpers ---

	function resetSymbolTable()
		project.parserVarNames = StringArray.create()
		project.parserVarSlots = VarSlotArray.create()
		project.parserVarIsFloat = BoolArray.create()
		project.parserVarIsRefType = BoolArray.create()
		project.parserVarStructType = StringArray.create()
		project.parserScopeStack = ScopeDepthArray.create()
		project.parserNextSlot = 0
	end 'resetSymbolTable'

	function pushScope()
		project.parserScopeStack.push(project.parserVarNames.count())
	end 'pushScope'

	function popScope()
		let savedSize = try project.parserScopeStack.pop() otherwise 0

		// Remove variables added since the scope was pushed
		while project.parserVarNames.count() > savedSize 'trim'
			try project.parserVarNames.pop() otherwise ""
			try project.parserVarSlots.pop() otherwise 0
			try project.parserVarIsFloat.pop() otherwise false
			try project.parserVarIsRefType.pop() otherwise false
			try project.parserVarStructType.pop() otherwise ""
		end 'trim'
	end 'popScope'

	function defineVariable(name String, isFloat bool, isRefType bool, structTypeName String = "") returns VarSlot
		let slot = project.parserNextSlot
		project.parserVarNames.push(name)
		project.parserVarSlots.push(slot)
		project.parserVarIsFloat.push(isFloat)
		project.parserVarIsRefType.push(isRefType)
		project.parserVarStructType.push(structTypeName)
		project.parserNextSlot = project.parserNextSlot + 1
		return slot
	end 'defineVariable'

	function getVariableStructType(name String) returns String
		let idx = findVariableIndex(name)
		if idx >= 0 'found'
			return try project.parserVarStructType.get(idx) otherwise ""
		end 'found'
		return ""
	end 'getVariableStructType'

	function findVariableIndex(name String) returns ParsedInt
		var i = project.parserVarNames.count() - 1
		while i >= 0 'lookup'
			let vn = try project.parserVarNames.get(i) otherwise ""
			if vn == name 'found'
				return i
			end 'found'
			i = i - 1
		end 'lookup'
		return -1
	end 'findVariableIndex'

	function lookupVariable(name String, token Token) returns VarSlot
		let idx = findVariableIndex(name)
		if idx >= 0 'found'
			return try project.parserVarSlots.get(idx) otherwise panic("unreachable: variable index validated")
		end 'found'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Undefined variable '{tokenValueToString(name)}'", line: token.line, column: token.column, filePath: filePath)
		return 0
	end 'lookupVariable'

	function resolveConstant(module MlirModule, block MlirBlock, name String) returns ExprResult
		let constVal = try project.topLevelConstants.get(name) otherwise 'notFound'
			return ExprResult.create(0)
		end 'notFound'

		expect(TokenKind.identifier)

		let isString = match constVal 'checkKind'
			stringValue gives true
			intValue gives false
		end 'checkKind'

		if isString 'str'
			let strVal = match constVal 'getStr'
				stringValue(v) gives v
				intValue gives ""
			end 'getStr'
			let id = nextValueId(project)
			return ExprResult.createFull(id, isFloat: false, isRefType: false, isStringConst: true, stringConstValue: strVal)
		end 'str'

		let intVal = match constVal 'getInt'
			intValue(v) gives v
			stringValue gives 0
		end 'getInt'
		let constId = emitLiteral(module, block: block, value: intVal, isFloat: false)
		return ExprResult.create(constId)
	end 'resolveConstant'

	function isVariableFloat(name String) returns bool
		let idx = findVariableIndex(name)
		if idx >= 0 'found'
			return try project.parserVarIsFloat.get(idx) otherwise false
		end 'found'
		return false
	end 'isVariableFloat'

	function isVariableRefType(name String) returns bool
		let idx = findVariableIndex(name)
		if idx >= 0 'found'
			return try project.parserVarIsRefType.get(idx) otherwise false
		end 'found'
		return false
	end 'isVariableRefType'

	// --- Scoped statement parsing ---

	function parseScopedStatements(module MlirModule, func MlirFunction, block MlirBlock) returns MlirBlock
		pushScope()
		var lastWasReturn = false
		let exitBlock = parseStatements(module, func: func, block: block, lastWasReturn: lastWasReturn)
		popScope()
		return exitBlock
	end 'parseScopedStatements'

	// --- Top-level parsing ---

	export function parseModule() returns MlirModule
		logDebug(LogCategory.parser, message: () gives "Starting parser")

		var module = createMlirModule()
		skipNewlines()

		while pos < tokens.count() 'parseLoop'
			let token = peek()
			let prevPos = pos

			if token.kind == TokenKind.eof 'isEof'
				break
			end 'isEof' else if token.kind == TokenKind.function 'isFunc'
				parseFunction(module)
			end 'isFunc' else if token.kind == TokenKind.type 'isType'
				parseTypeDecl(module)
			end 'isType' else if token.kind == TokenKind.let 'isLet'
				parseTopLevelLet()
			end 'isLet' else if token.kind == TokenKind.typealias 'isTypealias'
				parseTopLevelTypealias()
			end 'isTypealias' else if token.kind == TokenKind.export 'isExport'
				parseExport()
			end 'isExport'

			if pos <= prevPos 'stuck'
				pos = prevPos + 1
			end 'stuck'

			skipNewlines()
		end 'parseLoop'

		return module
	end 'parseModule'

	// --- Function parsing ---

	function parseFunction(module MlirModule)
		expect(TokenKind.function)

		let nameToken = consume()
		logTrace(LogCategory.parser, message: () gives "Parsing function '{nameToken.value}'")

		expect(TokenKind.leftParen)

		// Create function early so we can set paramCount, but defer symbol table setup
		resetValueIds(project)
		resetSymbolTable()

		var paramCount = 0
		var paramTypes = StdTypeArray.create()
		if not at(TokenKind.rightParen) 'hasParams'
			// Parse parameters: name Type, name Type, ...
			while pos < tokens.count() 'paramLoop'
				let paramNameToken = consume()
				let paramTypeToken = consume()

				// Resolve the parameter type to detect floats
				let resolvedType = resolveTypeName(project, name: paramTypeToken.value)
				let paramIsFloat = resolvedType == "f64"

				// Define the parameter as a variable so it's accessible in the body
				_ = defineVariable(paramNameToken.value, isFloat: paramIsFloat, isRefType: false)
				paramTypes.push(resolvedTypeToStdType(resolvedType))
				paramCount = paramCount + 1

				if at(TokenKind.rightParen) 'endParams'
					break
				end 'endParams'
			end 'paramLoop'
		end 'hasParams'
		expect(TokenKind.rightParen)

		// Parse 'returns' type
		var returnTypeName = ""
		if at(TokenKind.returns) 'hasReturns'
			expect(TokenKind.returns)
			let typeToken = consume()
			returnTypeName = typeToken.value
		end 'hasReturns'

		// Handle optional 'throws' clause by skipping it
		if at(TokenKind.throws) 'hasThrows'
			expect(TokenKind.throws)
			expect(TokenKind.identifier)
		end 'hasThrows'

		skipNewlines()

		// Create function and entry block — qualify name with file-based namespace (except main)
		var funcName = nameToken.value.clone()
		if funcName != "main" 'qualifyNonMain'
			let ns = deriveNamespace(filePath)
			funcName = qualifyName(ns, name: funcName)
		end 'qualifyNonMain'
		var func = createMlirFunction(funcName, returnType: returnTypeName, paramCount: paramCount, paramTypes: paramTypes, returnLine: 0)
		// Register return type so callers can determine if result is float
		try project.funcReturnTypes.insert(funcName, value: returnTypeName) otherwise 'dupFunc'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate function '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupFunc'
		var block = newBlock(module, func: func, label: "entry")

		// Parse function body
		var bodyReturns = false
		block = parseStatements(module, func: func, block: block, lastWasReturn: bodyReturns)

		// Implicit void return if body did not end with a return
		if not block.hasTerminator 'needsImplicitRet'
			emitImplicitReturn(module, block: block)
		end 'needsImplicitRet'

		module.functions.push(func)

		// Skip 'end' and optional label string
		skipEndAndLabel()
	end 'parseFunction'

	// --- Statement parsing ---

	// Parse statements until 'end' is reached. Returns the current block.
	// Sets lastWasReturn to true if the last statement was a return.
	function parseStatements(module MlirModule, func MlirFunction, block MlirBlock, lastWasReturn bool) returns MlirBlock
		lastWasReturn = false

		while pos < tokens.count() 'body'
			let stmtToken = peek()
			if stmtToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'

			lastWasReturn = false

			if stmtToken.kind == TokenKind.return 'isReturn'
				if func.returnLine == 0 'noRetLine'
					func.returnLine = stmtToken.line
				end 'noRetLine'
				parseReturnStatement(module, block: block)
				lastWasReturn = true
			end 'isReturn' else if stmtToken.kind == TokenKind.var or stmtToken.kind == TokenKind.let 'isVarDecl'
				parseVarDecl(module, block: block)
			end 'isVarDecl' else if stmtToken.kind == TokenKind.print 'isPrint'
				parsePrintStatement(module, block: block)
			end 'isPrint' else if stmtToken.kind == TokenKind.panic 'isPanic'
				parsePanicStatement(module, block: block)
				lastWasReturn = true
			end 'isPanic' else if stmtToken.kind == TokenKind.if 'isIf'
				block = parseIfStatement(module, func: func, block: block)
			end 'isIf' else if stmtToken.kind == TokenKind.while 'isWhile'
				block = parseWhileStatement(module, func: func, block: block)
			end 'isWhile' else if stmtToken.kind == TokenKind.identifier 'isIdent'
				parseIdentifierStatement(module, block: block)
			end 'isIdent' else 'unexpectedToken'
				reportUnexpectedToken()
			end 'unexpectedToken'

			skipNewlines()
		end 'body'

		return block
	end 'parseStatements'

	// --- Identifier statement dispatch ---

	// Dispatches an identifier at statement level: assignment, function call, or error.
	function parseIdentifierStatement(module MlirModule, block MlirBlock)
		let peekToken = peekAt(1)
		if peek().value == "_" and peekToken.kind == TokenKind.equals 'isDiscard'
			parseDiscardAssignment(module, block: block)
			return
		end 'isDiscard' else if peekToken.kind == TokenKind.equals 'isAssign'
			parseVarAssignment(module, block: block)
			return
		end 'isAssign' else if peekToken.kind == TokenKind.leftParen 'isCall'
			// Statement-level function call — parse as expression, discard result
			_ = parseExpression(module, block: block)
			return
		end 'isCall' else if peekToken.kind == TokenKind.identifier 'maybeDotCall'
			// Dot call: variable.method(args) or Type.staticMethod(args)
			let peekToken2 = peekAt(2)
			if peekToken2.kind == TokenKind.leftParen 'isDotCall'
				_ = parseExpression(module, block: block)
				return
			end 'isDotCall'
		end 'maybeDotCall'

		reportUnexpectedToken()
	end 'parseIdentifierStatement'

	// Reports an unexpected token error and synchronizes to the next statement.
	function reportUnexpectedToken()
		let stmtToken = peek()
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token: '{tokenValueToString(stmtToken.value)}'", line: stmtToken.line, column: stmtToken.column, filePath: filePath)
		synchronize()
	end 'reportUnexpectedToken'

	// --- Top-level let ---

	// Parse top-level `let NAME = <expr>` — stores as compile-time constant.
	// Supports string literals and constant integer expressions.
	function parseTopLevelLet()
		expect(TokenKind.let)

		let nameToken = consume()

		let equalsToken = peek()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokenValueToString(equalsToken.value)}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			synchronize()
			return
		end 'notEquals'

		expect(TokenKind.equals)
		let valueToken = peek()
		if valueToken.kind == TokenKind.doubleStringLiteral 'isString'
			expect(TokenKind.doubleStringLiteral)
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(valueToken.value)) otherwise 'dupConst1'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'dupConst1'
			logTrace(LogCategory.parser, message: () gives "Registered top-level string constant '{nameToken.value}'")
			return
		end 'isString'

		// Try to evaluate a compile-time integer constant expression
		let constValue = try evalConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Top-level let only supports string literals and constant integer expressions", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.intValue(constValue)) otherwise 'dupConst2'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupConst2'
		logTrace(LogCategory.parser, message: () gives "Registered top-level integer constant '{nameToken.value}' = {constValue}")
	end 'parseTopLevelLet'

	// Evaluate a compile-time integer constant expression.
	// Supports: integer literals, hex literals, `not <expr>`, `-<expr>`.
	function evalConstExpr() returns ParsedInt throws ParserError
		let token = peek()

		if token.kind == TokenKind.not 'isNot'
			expect(TokenKind.not)
			return not try evalConstExpr()
		end 'isNot'

		if token.kind == TokenKind.minus 'isNeg'
			expect(TokenKind.minus)
			return 0 - try evalConstExpr()
		end 'isNeg'

		if token.kind == TokenKind.intLiteral 'isInt'
			let intVal = try parseInt(token.value)
			expect(TokenKind.intLiteral)
			return intVal
		end 'isInt'

		throw ParserError.unhandledToken
	end 'evalConstExpr'

	// --- Export dispatch ---

	function parseExport()
		expect(TokenKind.export)

		if at(TokenKind.function) 'isExportFunc'
			// Leave pos at 'function' — the main loop will re-dispatch on it next iteration
			return
		end 'isExportFunc' else if at(TokenKind.typealias) 'isExportTypealias'
			parseTopLevelTypealias()
		end 'isExportTypealias' else if at(TokenKind.type) 'isExportType'
			// Leave pos at 'type' — the main loop will re-dispatch
			return
		end 'isExportType' else 'isExportOther'
			// Skip export var/let/other declarations
			skipToNextLine()
		end 'isExportOther'
	end 'parseExport'

	// --- Typealias parsing ---

	// Parse: typealias Name = int(LOWER to UPPER) | float(LOWER to UPPER) | bool | ...
	// Registers primitive-backed typealiases in the project's type registry.
	// Computes optimal MLIR type from the range bounds (e.g. int(0 to u32.max) → u32).
	function parseTopLevelTypealias()
		expect(TokenKind.typealias)
		let nameToken = consume()

		let equalsToken = peek()
		if equalsToken.kind != TokenKind.equals 'noEquals'
			skipToNextLine()
			return
		end 'noEquals'
		expect(TokenKind.equals)

		let baseToken = peek()

		var mlirType = ""

		if baseToken.kind == TokenKind.bool 'isBool'
			mlirType = "i1"
		end 'isBool'

		if baseToken.kind == TokenKind.int or baseToken.kind == TokenKind.float 'isNumeric'
			let isFloat = baseToken.kind == TokenKind.float
			advance()  // skip 'int' or 'float'

			let parenToken = peek()
			if parenToken.kind != TokenKind.leftParen 'noParen'
				var example = "int(0 to 100)"
				if isFloat 'floatEx'
					example = "float(f64.min to f64.max)"
				end 'floatEx'
				reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "typealias '{nameToken.value}' requires range bounds, e.g. {example}", line: baseToken.line, column: baseToken.column, filePath: FilePath from "")
				skipToNextLine()
				return
			end 'noParen'
			expect(TokenKind.leftParen)

			let lowerBound = parseTypeBound()

			if at(TokenKind.to) 'hasTo'
				expect(TokenKind.to)
			end 'hasTo'

			let upperBound = parseTypeBound()

			if isFloat 'computeFloat'
				mlirType = "f64"
			end 'computeFloat' else 'computeInt'
				mlirType = computeOptimalIntType(lower: lowerBound, upper: upperBound)
				try project.typealiasRanges.insert(nameToken.value, value: TypealiasRange.create(lowerBound, upper: upperBound)) otherwise ignore
			end 'computeInt'
		end 'isNumeric'

		if mlirType == "" 'unsupported'
			skipToNextLine()
			return
		end 'unsupported'

		try project.typealiases.insert(nameToken.value, value: mlirType) otherwise 'dupAlias'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate typealias '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupAlias'
		skipToNextLine()
	end 'parseTopLevelTypealias'

	// --- Type declaration parsing ---

	// Parse: type Name ... end 'Name'
	// Collects fields, registers the struct type, and parses methods as qualified functions.
	function parseTypeDecl(module MlirModule)
		expect(TokenKind.type)
		let typeNameToken = consume()
		let typeName = typeNameToken.value
		currentTypeName = typeName
		skipNewlines()

		// First pass: collect fields, skip over method bodies
		var fields = StructFieldArray.create()
		var fieldOffset = 0 as FieldOffset
		let savedPos = pos

		while pos < tokens.count() 'scanFields'
			let memberToken = peek()
			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if memberToken.kind == TokenKind.export 'skipExport'
				advance()
			end 'skipExport'
			let kindToken = peek()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'isField'
				advance()
				let fieldNameToken = consume()
				let fieldTypeToken = consume()
				fields.push(StructField.create(fieldNameToken.value, typeName: fieldTypeToken.value, offset: fieldOffset))
				fieldOffset = fieldOffset + 8
				skipNewlines()
			end 'isField' else if kindToken.kind == TokenKind.static or kindToken.kind == TokenKind.function 'skipMethod'
				// Skip the entire method body including its 'end' token
				skipToNextLine()
				skipNewlines()
				skipMethodBody()
				skipNewlines()
			end 'skipMethod' else 'skipOther'
				skipToNextLine()
				skipNewlines()
			end 'skipOther'
		end 'scanFields'

		// Register the struct type before parsing method bodies (needed for Self{...} resolution)
		let structType = StructType.create(typeName, fields: fields, byteSize: fieldOffset)
		try project.structTypes.insert(typeName, value: structType) otherwise 'dupType'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate type '{typeName}'", line: typeNameToken.line, column: typeNameToken.column, filePath: filePath)
		end 'dupType'

		// Second pass: parse methods (rewind to saved position)
		pos = savedPos
		while pos < tokens.count() 'typeBody'
			let memberToken = peek()
			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'
			if memberToken.kind == TokenKind.export 'skipExport2'
				advance()
			end 'skipExport2'
			let kindToken = peek()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'skipField'
				skipToNextLine()
				skipNewlines()
			end 'skipField' else if kindToken.kind == TokenKind.static 'isStatic'
				advance()
				if at(TokenKind.function) 'isStaticFunc'
					parseStaticMethod(module, typeName: typeName, fields: fields)
				end 'isStaticFunc' else 'notFunc'
					skipToNextLine()
				end 'notFunc'
				skipNewlines()
			end 'isStatic' else if kindToken.kind == TokenKind.function 'isMethod'
				parseInstanceMethod(module, typeName: typeName, fields: fields)
				skipNewlines()
			end 'isMethod' else 'skipMember'
				skipToNextLine()
				skipNewlines()
			end 'skipMember'
		end 'typeBody'

		currentTypeName = ""
		skipEndAndLabel()
	end 'parseTypeDecl'

	function parseStaticMethod(module MlirModule, typeName String, fields StructFieldArray)
		parseMethodFunctionImpl(module, typeName: typeName, selfMode: 0, fields: fields)
	end 'parseStaticMethod'

	function parseInstanceMethod(module MlirModule, typeName String, fields StructFieldArray)
		parseMethodFunctionImpl(module, typeName: typeName, selfMode: 1, fields: fields)
	end 'parseInstanceMethod'

	// Parse a method inside a type declaration as a standalone qualified function.
	// selfMode: 0 = static (no self), 1 = instance (add self param and field access)
	function parseMethodFunctionImpl(module MlirModule, typeName String, selfMode ParsedInt, fields StructFieldArray)
		expect(TokenKind.function)
		let nameToken = consume()
		let qualifiedName = "{typeName}.{nameToken.value}"
		logTrace(LogCategory.parser, message: () gives "Parsing method '{qualifiedName}'")

		expect(TokenKind.leftParen)

		resetValueIds(project)
		resetSymbolTable()

		var paramCount = 0
		var paramTypes = StdTypeArray.create()

		// Instance methods get an implicit self pointer parameter
		if selfMode == 1 'addSelfParam'
			_ = defineVariable("__self", isFloat: false, isRefType: true, structTypeName: typeName)
			paramTypes.push(StdType.i64)
			paramCount = paramCount + 1
		end 'addSelfParam'

		// Parse explicit parameters: name Type [, name Type]*
		// Commas are silently skipped by the lexer.
		if not at(TokenKind.rightParen) 'hasParams'
			while pos < tokens.count() 'paramLoop'
				let paramNameToken = consume()
				let paramTypeToken = consume()
				let resolvedType = resolveTypeName(project, name: paramTypeToken.value)
				let paramIsFloat = resolvedType == "f64"
				_ = defineVariable(paramNameToken.value, isFloat: paramIsFloat, isRefType: false)
				paramTypes.push(resolvedTypeToStdType(resolvedType))
				paramCount = paramCount + 1
				if at(TokenKind.rightParen) 'endParams'
					break
				end 'endParams'
			end 'paramLoop'
		end 'hasParams'
		expect(TokenKind.rightParen)

		// Parse 'returns' type — handle Self as the type name
		var returnTypeName = ""
		if at(TokenKind.returns) 'hasReturns'
			expect(TokenKind.returns)
			let typeToken = peek()
			if typeToken.kind == TokenKind.selfType 'isSelfReturn'
				returnTypeName = typeName
				advance()
			end 'isSelfReturn' else 'normalReturn'
				returnTypeName = consume().value
			end 'normalReturn'
		end 'hasReturns'

		// Handle optional 'throws' clause
		if at(TokenKind.throws) 'hasThrows'
			expect(TokenKind.throws)
			expect(TokenKind.identifier)
		end 'hasThrows'

		skipNewlines()

		// Create function
		var func = createMlirFunction(qualifiedName, returnType: returnTypeName, paramCount: paramCount, paramTypes: paramTypes, returnLine: 0)
		try project.funcReturnTypes.insert(qualifiedName, value: returnTypeName) otherwise 'dupFunc'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate function '{qualifiedName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'dupFunc'
		var block = newBlock(module, func: func, label: "entry")

		// For instance methods, emit field loads from the self pointer
		if selfMode == 1 'emitFieldAccess'
			let selfSlot = lookupVariable("__self", token: nameToken)
			let selfLoadId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.varLoad(selfLoadId, slotId: selfSlot))

			for field in fields 'eachField'
				let fieldLoadId = nextValueId(project)
				emitOp(module, block: block, op: MaxonOp.fieldLoad(fieldLoadId, structId: selfLoadId, offset: field.offset))
				let fieldResolvedType = resolveTypeName(project, name: field.typeName)
				let fieldIsFloat = fieldResolvedType == "f64"
				let fieldIsRef = project.structTypes.contains(field.typeName)
				var fieldStructType = ""
				if fieldIsRef 'hasStructType'
					fieldStructType = field.typeName
				end 'hasStructType'
				let fieldSlot = defineVariable(field.name, isFloat: fieldIsFloat, isRefType: fieldIsRef, structTypeName: fieldStructType)
				emitOp(module, block: block, op: MaxonOp.varDecl(fieldSlot, valueId: fieldLoadId))
			end 'eachField'
		end 'emitFieldAccess'

		// Parse body
		var bodyReturns = false
		block = parseStatements(module, func: func, block: block, lastWasReturn: bodyReturns)

		// For instance methods that modify fields, write fields back to struct before return
		if selfMode == 1 'instanceReturn'
			if block.hasTerminator 'instanceTerminated'
				// Already terminated
			end 'instanceTerminated' else 'instanceNeedsReturn'
				emitFieldWritebacks(module, block: block, nameToken: nameToken, fields: fields)
				emitImplicitReturn(module, block: block)
			end 'instanceNeedsReturn'
		end 'instanceReturn' else 'staticReturn'
			if block.hasTerminator 'staticTerminated'
				// Already returned
			end 'staticTerminated' else 'staticNeedsReturn'
				emitImplicitReturn(module, block: block)
			end 'staticNeedsReturn'
		end 'staticReturn'

		module.functions.push(func)
		skipEndAndLabel()
	end 'parseMethodFunctionImpl'

	// Write modified field values back to the struct pointer before returning.
	function emitFieldWritebacks(module MlirModule, block MlirBlock, nameToken Token, fields StructFieldArray)
		let selfSlot = lookupVariable("__self", token: nameToken)
		let selfLoadId = nextValueId(project)
		emitOp(module, block: block, op: MaxonOp.varLoad(selfLoadId, slotId: selfSlot))

		for field in fields 'eachField'
			let fieldIdx = findVariableIndex(field.name)
			if fieldIdx >= 0 'hasField'
				let fieldSlot = try project.parserVarSlots.get(fieldIdx) otherwise panic("unreachable: field index validated")
				let fieldValId = nextValueId(project)
				emitOp(module, block: block, op: MaxonOp.varLoad(fieldValId, slotId: fieldSlot))
				emitOp(module, block: block, op: MaxonOp.fieldStore(selfLoadId, offset: field.offset, valueId: fieldValId))
			end 'hasField'
		end 'eachField'
	end 'emitFieldWritebacks'

	// Skip over a method body in the first pass of type parsing.
	// Scans token-by-token counting end tokens to find the matching end for this function.
	function skipMethodBody()
		var depth = 1
		while pos < tokens.count() and depth > 0 'skip'
			let token = peek()
			if token.kind == TokenKind.eof 'isEof'
				break
			end 'isEof'
			if token.kind == TokenKind.end 'isEnd'
				depth = depth - 1
				if depth == 0 'atMethodEnd'
					skipEndAndLabel()
					return
				end 'atMethodEnd'
			end 'isEnd' else if token.kind == TokenKind.if or token.kind == TokenKind.while or token.kind == TokenKind.for or token.kind == TokenKind.match or token.kind == TokenKind.else 'opensBlock'
				depth = depth + 1
			end 'opensBlock'
			advance()
		end 'skip'
	end 'skipMethodBody'

	// Parse a type bound: a number literal, negative literal, or T.min/T.max.
	// The lexer doesn't emit '.' tokens, so "u32.max" is tokenized as two
	// identifiers: "u32" and "max" (with '.' silently skipped).
	// Mutates pos and returns just BoundValue.
	function parseTypeBound() returns BoundValue
		let token = peek()

		// Negative literal: - NUMBER
		if token.kind == TokenKind.minus 'isNeg'
			let numToken = peekAt(1)
			let value = try parseInt(numToken.value) otherwise 'negOverflow'
				reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(numToken.value)}' is outside the range of int", line: numToken.line, column: numToken.column, filePath: filePath)
				expect(TokenKind.minus)
				expect(TokenKind.intLiteral)
				return 0
			end 'negOverflow'
			expect(TokenKind.minus)
			expect(TokenKind.intLiteral)
			return 0 - value
		end 'isNeg'

		// Number literal
		if token.kind == TokenKind.intLiteral 'isLit'
			let value = try parseInt(token.value) otherwise 'litOverflow'
				reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int", line: token.line, column: token.column, filePath: filePath)
				expect(TokenKind.intLiteral)
				return 0
			end 'litOverflow'
			expect(TokenKind.intLiteral)
			return value
		end 'isLit'

		// T.min or T.max — lexed as two identifiers (T and min/max)
		let fieldToken = peekAt(1)
		if fieldToken.kind == TokenKind.identifier 'hasField'
			let bound = resolveTypeBound(token.value, field: fieldToken.value)
			expect(TokenKind.identifier)
			expect(TokenKind.identifier)
			return bound
		end 'hasField'

		advance()
		return 0
	end 'parseTypeBound'

	// --- Return statement ---

	function parseReturnStatement(module MlirModule, block MlirBlock)
		expect(TokenKind.return)

		// Bare 'return' without expression (void return)
		let nextTok = peek()
		if nextTok.kind == TokenKind.newline or nextTok.kind == TokenKind.end or nextTok.kind == TokenKind.eof 'bareReturn'
			emitImplicitReturn(module, block: block)
			return
		end 'bareReturn'

		let resultId = parseExpression(module, block: block)

		finalizeBlock(module, block: block, terminator: MaxonOp.ret(resultId.valueId))
	end 'parseReturnStatement'

	// Emits MaxonOp.panic with a location-prefixed message for the stack trace.
	function parsePanicStatement(module MlirModule, block MlirBlock)
		let panicToken = consume()
		advance()  // '('
		let msgToken = consume()
		advance()  // ')'

		// Prefix with source location so the panic message includes file:line
		let fileName = filePath.filename()
		let fullMsg = "panic at {fileName}:{panicToken.line}: {msgToken.value}"

		let panicId = nextValueId(project)
		appendMaxonOp(module, block: block, op: MaxonOp.panic(fullMsg, panicId: panicId))
	end 'parsePanicStatement'

	// --- If statement ---

	// Parse: if <condition> 'label' ... end 'label' [else 'label' ... end 'label']
	// Returns the merge block to continue emitting into.
	function parseIfStatement(module MlirModule, func MlirFunction, block MlirBlock) returns MlirBlock
		expect(TokenKind.if)

		// Parse condition expression (emits ops to current block)
		let condResult = parseExpression(module, block: block)

		// Capture the user's block label for deriving block names
		var userLabel = "if"
		if at(TokenKind.stringLiteral) 'hasThenLabel'
			userLabel = peek().value
			advance()
			expectNewlineAfterLabel()
		end 'hasThenLabel' else 'noLabel'
			skipNewlines()
		end 'noLabel'

		// Create then block — its ID provides a unique suffix for all derived labels
		var thenBlock = newBlock(module, func: func, label: userLabel)
		let thenBlockId = thenBlock.id
		let baseLabel = "{userLabel}_{thenBlockId}"
		thenBlock.label = baseLabel

		// Parse then block body
		let thenExit = parseScopedStatements(module, func: func, block: thenBlock)

		// Skip 'end' and label
		skipEndAndLabel()
		skipNewlines()

		// Check for else clause
		if at(TokenKind.else) 'hasElse'
			expect(TokenKind.else)

			// Derive else label from the base label
			var elseLabel = "{baseLabel}.else"

			// Check for 'else if' chain
			if at(TokenKind.if) 'isElseIf'
				var elseBlock = newBlock(module, func: func, label: elseLabel)
				let elseBlockId = elseBlock.id
				let elseIfExit = parseIfStatement(module, func: func, block: elseBlock)
				return finalizeIfElseById(module, func: func, condBlock: block, condValueId: condResult.valueId, thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseIfExit, baseLabel: baseLabel)
			end 'isElseIf' else 'plainElse'
				// Capture the else block label if present, otherwise use derived name
				if at(TokenKind.stringLiteral) 'hasElseLabel'
					elseLabel = "{peek().value}_{func.nextBlockId}"
					advance()
					expectNewlineAfterLabel()
				end 'hasElseLabel' else 'noElseLabel'
					skipNewlines()
				end 'noElseLabel'

				var elseBlock = newBlock(module, func: func, label: elseLabel)
				let elseBlockId = elseBlock.id
				let elseExit = parseScopedStatements(module, func: func, block: elseBlock)
				skipEndAndLabel()
				return finalizeIfElseById(module, func: func, condBlock: block, condValueId: condResult.valueId, thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseExit, baseLabel: baseLabel)
			end 'plainElse'
		end 'hasElse'

		// No else clause: false branch goes directly to after block
		let afterBlock = newBlock(module, func: func, label: "{baseLabel}.after")
		branchIfNeeded(module, block: thenExit, target: afterBlock.id)
		finalizeBlock(module, block: block, terminator: MaxonOp.condBr(condResult.valueId, thenTarget: thenBlockId, elseTarget: afterBlock.id))
		return afterBlock
	end 'parseIfStatement'

	// --- While statement ---

	// Parse: while <condition> 'label' ... end 'label'
	// Returns the exit block to continue emitting into.
	function parseWhileStatement(module MlirModule, func MlirFunction, block MlirBlock) returns MlirBlock
		expect(TokenKind.while)

		// Create cond block first (we need it to parse the condition into)
		var condBlock = newBlock(module, func: func, label: "cond")
		let condBlockId = condBlock.id

		// Branch from entry block to cond block
		finalizeBlock(module, block: block, terminator: MaxonOp.br(condBlockId))

		// Parse condition in condBlock
		let condResult = parseExpression(module, block: condBlock)

		// Read the user's block label and derive unique labels
		var userLabel = "loop"
		if at(TokenKind.stringLiteral) 'hasWhileLabel'
			userLabel = peek().value
			advance()
			expectNewlineAfterLabel()
		end 'hasWhileLabel' else 'noWhileLabel'
			skipNewlines()
		end 'noWhileLabel'

		// Derive base label: userLabel_<blockId>
		let baseLabel = "{userLabel}_{condBlockId}"

		// Rename condBlock to baseLabel.header
		condBlock.label = "{baseLabel}.header"

		// Create body and exit blocks with derived labels
		var bodyBlock = newBlock(module, func: func, label: baseLabel)
		let bodyBlockId = bodyBlock.id
		let exitBlock = newBlock(module, func: func, label: "{baseLabel}.exit")
		let exitBlockId = exitBlock.id

		// condBlock terminator: if true -> bodyBlock, if false -> exitBlock
		finalizeBlock(module, block: condBlock, terminator: MaxonOp.condBr(condResult.valueId, thenTarget: bodyBlockId, elseTarget: exitBlockId))

		// Parse body in bodyBlock
		let bodyExit = parseScopedStatements(module, func: func, block: bodyBlock)

		// Loop back to cond block if body doesn't terminate
		branchIfNeeded(module, block: bodyExit, target: condBlockId)

		// Skip 'end' and optional label string
		skipEndAndLabel()

		return exitBlock
	end 'parseWhileStatement'

	// --- Discard assignment ---

	// Parse: _ = expression (discard function result)
	// Uses parserNextSlot as a unique suffix since it increments with each variable
	function parseDiscardAssignment(module MlirModule, block MlirBlock)
		advance()  // skip '_'
		expect(TokenKind.equals)

		let exprResult = parseExpression(module, block: block)

		let discardName = "__discard_{project.parserNextSlot}"
		let slot = defineVariable(discardName, isFloat: exprResult.isFloat, isRefType: exprResult.isRefType)
		emitOp(module, block: block, op: MaxonOp.varDecl(slot, valueId: exprResult.valueId))
	end 'parseDiscardAssignment'

	// --- Variable assignment ---

	// Parse: identifier = expression (variable reassignment)
	function parseVarAssignment(module MlirModule, block MlirBlock)
		let nameToken = consume()
		expect(TokenKind.equals)

		let exprResult = parseExpression(module, block: block)

		let slot = lookupVariable(nameToken.value, token: nameToken)
		emitOp(module, block: block, op: MaxonOp.varStore(slot, valueId: exprResult.valueId))
	end 'parseVarAssignment'

	// --- Variable declaration ---

	function parseVarDecl(module MlirModule, block MlirBlock)
		let isLet = peek().kind == TokenKind.let
		advance()  // skip 'var'/'let'

		let nameToken = consume()

		let equalsToken = peek()
		if equalsToken.kind != TokenKind.equals 'notEquals'
			let tokStr = tokenValueToString(equalsToken.value)
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected '=' but got '{tokStr}'", line: equalsToken.line, column: equalsToken.column, filePath: filePath)
			// Define the variable as a placeholder to prevent cascading "undefined variable" errors
			_ = defineVariable(nameToken.value, isFloat: false, isRefType: false)
			synchronize()
			return
		end 'notEquals'

		expect(TokenKind.equals)
		let exprResult = parseExpression(module, block: block)

		// Register let-bound string literals as compile-time string constants
		// so later comparisons like `inner == "hello"` can be folded.
		// Skip runtime storage since the value is resolved at compile time.
		if isLet and exprResult.isStringConst 'registerStringConst'
			try project.topLevelConstants.insert(nameToken.value, value: ConstantValue.stringValue(exprResult.stringConstValue)) otherwise 'dupConst3'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'dupConst3'
			_ = defineVariable(nameToken.value, isFloat: exprResult.isFloat, isRefType: exprResult.isRefType, structTypeName: exprResult.structTypeName)
			return
		end 'registerStringConst'

		let slot = defineVariable(nameToken.value, isFloat: exprResult.isFloat, isRefType: exprResult.isRefType, structTypeName: exprResult.structTypeName)
		emitOp(module, block: block, op: MaxonOp.varDecl(slot, valueId: exprResult.valueId))
	end 'parseVarDecl'

	// --- Print statement ---

	function parsePrintStatement(module MlirModule, block MlirBlock)
		expect(TokenKind.print)
		expect(TokenKind.leftParen)
		let strToken = consume()
		expect(TokenKind.rightParen)

		// Parse the double-quoted string for interpolation segments
		parseStringInterpolation(module, block: block, str: strToken.value)
	end 'parsePrintStatement'

	// --- String Interpolation ---

	function parseStringInterpolation(module MlirModule, block MlirBlock, str String)
		let strBytes = str.toByteArray()
		var buf = ByteArray.create()
		var i = 0
		let len = strBytes.count()

		while i < len 'scan'
			let ch = try strBytes.get(i) otherwise 0

			// Escape sequences
			if ch == '\\' 'backslash'
				if i + 1 < len 'hasNext'
					let next = try strBytes.get(i + 1) otherwise 0
					if next == 'n' 'escN'
						buf.push(10)
						i = i + 2
						continue
					end 'escN'
					if next == 't' 'escT'
						buf.push(9)
						i = i + 2
						continue
					end 'escT'
					if next == '\\' 'escBS'
						buf.push(92)
						i = i + 2
						continue
					end 'escBS'
					if next == '"' 'escDQ'
						buf.push(34)
						i = i + 2
						continue
					end 'escDQ'
				end 'hasNext'
				buf.push(ch)
				i = i + 1
				continue
			end 'backslash'

			// Interpolation: { ... }
			if ch == '{' 'openBrace'
				// Flush literal buffer
				if not buf.isEmpty() 'flushBuf'
					emitOp(module, block: block, op: MaxonOp.printLiteral(String.from(buf)))
					buf = ByteArray.create()
				end 'flushBuf'

				// Extract expression between braces
				i = i + 1
				let exprStart = i
				var braceDepth = 1

				while i < len and braceDepth > 0 'findClose'
					let bc = try strBytes.get(i) otherwise 0
					if bc == '{' 'nested'
						braceDepth = braceDepth + 1
					end 'nested'
					if bc == '}' 'close'
						braceDepth = braceDepth - 1
					end 'close'
					if braceDepth > 0 'notDone'
						i = i + 1
					end 'notDone'
				end 'findClose'

				// Tokenize and parse the expression between braces using a sub-parser
				let exprStr = String.from(strBytes.slice(exprStart, endIndex: i))
				let exprTokens = tokenize(exprStr)
				let subParser = Parser.create(project, tokens: exprTokens, filePath: filePath)
				let exprResult = subParser.parseExpression(module, block: block)
				emitOp(module, block: block, op: MaxonOp.printInt(exprResult.valueId))

				i = i + 1  // skip closing brace
				continue
			end 'openBrace'

			buf.push(ch)
			i = i + 1
		end 'scan'

		// Flush remaining literal buffer
		if not buf.isEmpty() 'flushRemaining'
			emitOp(module, block: block, op: MaxonOp.printLiteral(String.from(buf)))
		end 'flushRemaining'
	end 'parseStringInterpolation'

	// --- Expression Parsing ---

	// Pratt expression parser: single loop handles all binary precedence levels.
	function parseExpression(module MlirModule, block MlirBlock) returns ExprResult
		return parseExpressionBP(module, block: block, minBP: 0)
	end 'parseExpression'

	function parseExpressionBP(module MlirModule, block MlirBlock, minBP BindingPower) returns ExprResult
		let left = parseUnary(module, block: block)
		var leftId = left.valueId
		var leftIsFloat = left.isFloat
		var leftIsRefType = left.isRefType
		var leftIsStringConst = left.isStringConst
		var leftStringConstValue = left.stringConstValue.clone()
		var leftStructTypeName = left.structTypeName.clone()

		while pos < tokens.count() 'prattLoop'
			let opToken = peek()
			let bp = try infixBindingPower(opToken.kind) otherwise 0
			if bp == 0 'notOp'
				break
			end 'notOp'
			if bp <= minBP 'tooLow'
				break
			end 'tooLow'

			advance()  // skip operator

			// Compile-time string constant folding for ==
			if opToken.kind == TokenKind.equalsEquals 'checkStrFold'
				if leftIsStringConst 'leftIsStr'
					let right = parsePrimary(module, block: block)
					var foldedLeft = 1
					if leftStringConstValue != right.stringConstValue 'strNeq'
						foldedLeft = 0
					end 'strNeq'
					let leftLitId = emitLiteral(module, block: block, value: foldedLeft, isFloat: false)
					let rightLitId = emitLiteral(module, block: block, value: 1, isFloat: false)
					let resultId = nextValueId(project)
					emitOp(module, block: block, op: MaxonOp.cmp(resultId, leftId: leftLitId, rightId: rightLitId, predicate: CmpPredicate.eq, isFloat: false))
					leftId = resultId
					leftIsFloat = false
					leftIsRefType = false
					leftIsStringConst = false
					leftStringConstValue = ""
					leftStructTypeName = ""
					continue
				end 'leftIsStr'
			end 'checkStrFold'

			// Reference identity: is / is not
			if opToken.kind == TokenKind.is 'isRefEq'
				var negate = false
				if at(TokenKind.not) 'isNot'
					negate = true
					expect(TokenKind.not)
				end 'isNot'
				let right = parseExpressionBP(module, block: block, minBP: bp)
				if not leftIsRefType or not right.isRefType 'notRef'
					reportCompileError(project, code: ErrorCode.semanticIsRequiresRefType, message: "'is' requires reference types (structs), not primitive values", line: opToken.line, column: opToken.column, filePath: filePath)
				end 'notRef'
				let resultId = nextValueId(project)
				emitOp(module, block: block, op: MaxonOp.refEq(resultId, leftId: leftId, rightId: right.valueId, negate: negate))
				leftId = resultId
				leftIsFloat = false
				leftIsRefType = false
				leftIsStringConst = false
				leftStringConstValue = ""
				leftStructTypeName = ""
				continue
			end 'isRefEq'

			// Parse right operand with higher minimum binding power for left-associativity
			let right = parseExpressionBP(module, block: block, minBP: bp)

			// Dispatch == and != to .equals() call for reference types (content comparison)
			if(opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals) and leftIsRefType and right.isRefType 'refEquals'
				let equalsResultId = nextValueId(project)
				var equalsArgIds = ValueIdArray.create()
				equalsArgIds.push(leftId)
				equalsArgIds.push(right.valueId)
				// TODO: use actual type name once type tracking is available (e.g., "String.equals")
				emitOp(module, block: block, op: MaxonOp.call(equalsResultId, callee: "equals", argIds: equalsArgIds))
				if opToken.kind == TokenKind.bangEquals 'neq'
					// != is !equals(): invert with bitNot
					let notResultId = nextValueId(project)
					emitOp(module, block: block, op: MaxonOp.unop(notResultId, operandId: equalsResultId, opKind: UnaryOpKind.bitNot, isFloat: false))
					leftId = notResultId
				end 'neq' else 'eq'
					leftId = equalsResultId
				end 'eq'
				leftIsFloat = false
				leftIsRefType = false
				leftIsStringConst = false
				leftStringConstValue = ""
				leftStructTypeName = ""
				continue
			end 'refEquals'

			let resultId = nextValueId(project)
			let eitherIsFloat = leftIsFloat or right.isFloat
			try emitBinaryOp(module, block: block, kind: opToken.kind, resultId: resultId, leftId: leftId, rightId: right.valueId, leftIsFloat: leftIsFloat, rightIsFloat: right.isFloat) otherwise ignore
			leftId = resultId
			// Comparison ops produce int (bool), arithmetic on floats produces float
			if opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals or opToken.kind == TokenKind.lessThan or opToken.kind == TokenKind.lessEquals or opToken.kind == TokenKind.greaterThan or opToken.kind == TokenKind.greaterEquals 'isCmp'
				leftIsFloat = false
			end 'isCmp' else 'notCmp'
				leftIsFloat = eitherIsFloat
			end 'notCmp'
			leftIsRefType = false
			leftIsStringConst = false
			leftStringConstValue = ""
			leftStructTypeName = ""
		end 'prattLoop'

		var result = ExprResult.createFull(leftId, isFloat: leftIsFloat, isRefType: leftIsRefType, isStringConst: leftIsStringConst, stringConstValue: leftStringConstValue)
		result.structTypeName = leftStructTypeName
		return result
	end 'parseExpressionBP'

	// --- Binary op emission ---

	function emitBinaryOp(module MlirModule, block MlirBlock, kind TokenKind, resultId ValueId, leftId ValueId, rightId ValueId, leftIsFloat bool, rightIsFloat bool) throws ParserError
		let isFloat = leftIsFloat or rightIsFloat
		// Promote int operand to float when mixing int and float in arithmetic/comparison
		var actualLeftId = leftId
		var actualRightId = rightId
		if isFloat and not leftIsFloat 'promoteLeft'
			let promId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.intToFloat(promId, operandId: leftId))
			actualLeftId = promId
		end 'promoteLeft'
		if isFloat and not rightIsFloat 'promoteRight'
			let promId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.intToFloat(promId, operandId: rightId))
			actualRightId = promId
		end 'promoteRight'
		let hlOp = match kind 'emit'
			or gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.bitOr, isFloat: false)
			xor gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.bitXor, isFloat: false)
			and gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.bitAnd, isFloat: false)
			shl gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.shl, isFloat: false)
			shr gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.shr, isFloat: false)
			equalsEquals gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.eq, isFloat: isFloat)
			bangEquals gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.ne, isFloat: isFloat)
			lessThan gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.lt, isFloat: isFloat)
			lessEquals gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.le, isFloat: isFloat)
			greaterThan gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.gt, isFloat: isFloat)
			greaterEquals gives MaxonOp.cmp(resultId, leftId: actualLeftId, rightId: actualRightId, predicate: CmpPredicate.ge, isFloat: isFloat)
			plus gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.add, isFloat: isFloat)
			minus gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.sub, isFloat: isFloat)
			star gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.mul, isFloat: isFloat)
			slash gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.div, isFloat: isFloat)
			mod gives MaxonOp.binop(resultId, leftId: actualLeftId, rightId: actualRightId, opKind: BinOpKind.mod, isFloat: false)
			default throws ParserError.unhandledToken
		end 'emit'
		emitOp(module, block: block, op: hlOp)
	end 'emitBinaryOp'

	// --- Unary parsing ---

	// Unary: -primary | not primary | primary
	function parseUnary(module MlirModule, block MlirBlock) returns ExprResult
		let token = peek()

		if token.kind == TokenKind.minus 'isNeg'
			expect(TokenKind.minus)
			let operand = parsePrimary(module, block: block)
			if operand.isFloat 'floatNeg'
				// Float negation: emit 0.0 - operand
				let zeroId = nextValueId(project)
				emitOp(module, block: block, op: MaxonOp.literal(zeroId, value: 0, isFloat: true))
				let resultId = nextValueId(project)
				emitOp(module, block: block, op: MaxonOp.binop(resultId, leftId: zeroId, rightId: operand.valueId, opKind: BinOpKind.sub, isFloat: true))
				return ExprResult.createFull(resultId, isFloat: true, isRefType: false, isStringConst: false, stringConstValue: "")
			end 'floatNeg'
			let resultId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.unop(resultId, operandId: operand.valueId, opKind: UnaryOpKind.neg, isFloat: false))
			return ExprResult.createFull(resultId, isFloat: false, isRefType: false, isStringConst: false, stringConstValue: "")
		end 'isNeg' else if token.kind == TokenKind.not 'isNot'
			expect(TokenKind.not)
			let operand = parseUnary(module, block: block)
			let resultId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.unop(resultId, operandId: operand.valueId, opKind: UnaryOpKind.bitNot, isFloat: false))
			return ExprResult.createFull(resultId, isFloat: false, isRefType: false, isStringConst: false, stringConstValue: "")
		end 'isNot'

		return parsePrimary(module, block: block)
	end 'parseUnary'

	// --- Primary expression parsing ---

	function parseIdentifierExpr(module MlirModule, block MlirBlock, token Token) returns ExprResult throws ParserError
		let peekToken = peekAt(1)

		// Dot notation: Type.method(args) or variable.method(args)
		// The lexer skips '.', so these appear as two consecutive identifiers.
		if peekToken.kind == TokenKind.identifier 'maybeDot'
			let peekToken2 = peekAt(2)

			// Type.staticMethod(args) — first identifier is a known struct type
			if project.structTypes.contains(token.value) and peekToken2.kind == TokenKind.leftParen 'isStaticCall'
				let calleeName = "{token.value}.{peekToken.value}"
				expect(TokenKind.identifier)
				expect(TokenKind.identifier)
				expect(TokenKind.leftParen)
				let argIds = parseCallArgs(module, block: block)
				expect(TokenKind.rightParen)
				return emitCallAndResult(module, block: block, calleeName: calleeName, argIds: argIds)
			end 'isStaticCall'

			// variable.method(args) or variable.field — first identifier is a variable
			let varIdx = findVariableIndex(token.value)
			if varIdx >= 0 'isVarAccess'
				let varIsRef = try project.parserVarIsRefType.get(varIdx) otherwise false

				if varIsRef 'isRefVar'
					let varSlot = try project.parserVarSlots.get(varIdx) otherwise panic("unreachable: variable index validated")
					let selfId = nextValueId(project)
					emitOp(module, block: block, op: MaxonOp.varLoad(selfId, slotId: varSlot))

					if peekToken2.kind == TokenKind.leftParen 'isMethodCall'
						let methodName = peekToken.value
						let calleeName = resolveInstanceMethod(token.value, methodName: methodName)
						expect(TokenKind.identifier)
						expect(TokenKind.identifier)
						expect(TokenKind.leftParen)
						let argIds = parseCallArgs(module, block: block)
						expect(TokenKind.rightParen)

						var fullArgIds = ValueIdArray.create()
						fullArgIds.push(selfId)
						for argId in argIds 'addArgs'
							fullArgIds.push(argId)
						end 'addArgs'

						return emitCallAndResult(module, block: block, calleeName: calleeName, argIds: fullArgIds)
					end 'isMethodCall'

					// Field access — peekToken2 is not '('
					let structTypeName = getVariableStructType(token.value)
					let structType = try project.structTypes.get(structTypeName) otherwise 'noStructType'
						throw ParserError.unhandledToken
					end 'noStructType'

					let fieldName = peekToken.value
					var fieldOffset = 0
					var fieldFound = false
					var fieldIsFloat = false
					var fieldIsRef = false
					var fieldStructType = ""

					for field in structType.fields 'findField'
						if field.name == fieldName 'match'
							fieldOffset = field.offset
							fieldFound = true
							let fieldResolvedType = resolveTypeName(project, name: field.typeName)
							fieldIsFloat = fieldResolvedType == "f64"
							fieldIsRef = project.structTypes.contains(field.typeName)
							if fieldIsRef 'hasFieldStructType'
								fieldStructType = field.typeName
							end 'hasFieldStructType'
							break
						end 'match'
					end 'findField'

					if not fieldFound 'fieldNotFound'
						throw ParserError.unhandledToken
					end 'fieldNotFound'

					let fieldLoadId = nextValueId(project)
					emitOp(module, block: block, op: MaxonOp.fieldLoad(fieldLoadId, structId: selfId, offset: fieldOffset))
					expect(TokenKind.identifier)
					expect(TokenKind.identifier)

					var result = ExprResult.createFull(fieldLoadId, isFloat: fieldIsFloat, isRefType: fieldIsRef, isStringConst: false, stringConstValue: "")
					result.structTypeName = fieldStructType
					return result
				end 'isRefVar'
			end 'isVarAccess'
		end 'maybeDot'

		if peekToken.kind == TokenKind.leftParen 'isCall'
			expect(TokenKind.identifier)
			expect(TokenKind.leftParen)
			var argIds = ValueIdArray.create()
			var lastArgIsFloat = false

			// Parse arguments until ')'
			if not at(TokenKind.rightParen) 'hasArgs'
				while pos < tokens.count() 'argLoop'
					// Skip labeled argument names (e.g., "b:" in "b: 2")
					let maybeLabel = peek()
					let afterLabel = peekAt(1)
					if maybeLabel.kind == TokenKind.identifier and afterLabel.kind == TokenKind.colon 'isLabel'
						expect(TokenKind.identifier)
						expect(TokenKind.colon)
					end 'isLabel'

					let argResult = parseExpression(module, block: block)
					argIds.push(argResult.valueId)
					lastArgIsFloat = argResult.isFloat

					if at(TokenKind.rightParen) 'endArgs'
						break
					end 'endArgs'
				end 'argLoop'
			end 'hasArgs'
			expect(TokenKind.rightParen)

			// trunc() converts a float to int via cvttsd2si, or is a no-op on integers
			if token.value == "trunc" 'isTrunc'
				let truncArgId = try argIds.get(0) otherwise 0
				if lastArgIsFloat 'isFloat'
					let truncResultId = nextValueId(project)
					emitOp(module, block: block, op: MaxonOp.truncFloat(truncResultId, operandId: truncArgId))
					return ExprResult.create(truncResultId)
				end 'isFloat'
				// Integer argument — trunc is a no-op
				return ExprResult.create(truncArgId)
			end 'isTrunc'

			// Qualify call target with file-based namespace (except main)
			var calleeName = token.value
			if calleeName != "main" 'qualifyCall'
				let callNs = deriveNamespace(filePath)
				calleeName = qualifyName(callNs, name: calleeName)
			end 'qualifyCall'
			let callId = nextValueId(project)
			emitOp(module, block: block, op: MaxonOp.call(callId, callee: calleeName, argIds: argIds))
			// Check if the callee returns a float type
			let calleeReturnType = try project.funcReturnTypes.get(calleeName) otherwise ""
			let resolvedReturnType = resolveTypeName(project, name: calleeReturnType)
			let callReturnsFloat = resolvedReturnType == "f64"
			if callReturnsFloat 'isFloatReturn'
				return ExprResult.createFloat(callId)
			end 'isFloatReturn'
			return ExprResult.create(callId)
		end 'isCall'

		// Sized type bound as expression: u64.max, i32.min, etc.
		// The lexer skips '.', so "u64.max" arrives as two consecutive identifiers.
		if peekToken.kind == TokenKind.identifier and(peekToken.value == "min" or peekToken.value == "max") and(token.value == "u8" or token.value == "u16" or token.value == "u32" or token.value == "u64" or token.value == "i8" or token.value == "i16" or token.value == "i32" or token.value == "i64") 'isTypeBound'
			let bound = resolveTypeBound(token.value, field: peekToken.value)
			expect(TokenKind.identifier)
			expect(TokenKind.identifier)
			let boundId = emitLiteral(module, block: block, value: bound, isFloat: false)
			return ExprResult.create(boundId)
		end 'isTypeBound'

		// Struct construction: TypeName{field: value, ...}
		if peekToken.kind == TokenKind.leftBrace and project.structTypes.contains(token.value) 'isStructLiteral'
			return parseStructLiteral(module, block: block, typeName: token.value, typeToken: token)
		end 'isStructLiteral'

		// Ranged primitive construction: TypeName{expression}
		if peekToken.kind == TokenKind.leftBrace 'isTypedConstruct'
			advance()  // skip type name
			advance()  // skip '{'
			let innerResult = parseExpression(module, block: block)
			advance()  // skip '}'
			return innerResult
		end 'isTypedConstruct'

		// Check for compile-time constant before variable lookup
		if project.topLevelConstants.contains(token.value) 'isConst'
			return resolveConstant(module, block: block, name: token.value)
		end 'isConst'

		let slot = lookupVariable(token.value, token: token)
		let id = nextValueId(project)
		emitOp(module, block: block, op: MaxonOp.varLoad(id, slotId: slot))
		let varIsFloat = isVariableFloat(token.value)
		let varIsRef = isVariableRefType(token.value)
		expect(TokenKind.identifier)
		return ExprResult.createFull(id, isFloat: varIsFloat, isRefType: varIsRef, isStringConst: false, stringConstValue: "")
	end 'parseIdentifierExpr'

	// Parse call arguments, validating named args for 2nd+ arguments.
	// firstNamedIndex: index of the first arg that must be named (0 = all must be named, 1 = 2nd+ must be named)
	function parseCallArgs(module MlirModule, block MlirBlock, firstNamedIndex ParsedInt = 1) returns ValueIdArray
		var argIds = ValueIdArray.create()
		var argIndex = 0
		if not at(TokenKind.rightParen) 'hasArgs'
			while pos < tokens.count() 'argLoop'
				let maybeLabel = peek()
				let afterLabel = peekAt(1)

				if argIndex >= firstNamedIndex 'checkNamed'
					// This argument must be named
					if maybeLabel.kind == TokenKind.identifier and afterLabel.kind == TokenKind.colon 'isNamed'
						expect(TokenKind.identifier)
						expect(TokenKind.colon)
					end 'isNamed' else 'notNamed'
						reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: maybeLabel.line, column: maybeLabel.column, filePath: filePath)
					end 'notNamed'
				end 'checkNamed' else 'positionalArg'
					// Positional argument — may optionally have a label
					if maybeLabel.kind == TokenKind.identifier and afterLabel.kind == TokenKind.colon 'isLabel'
						expect(TokenKind.identifier)
						expect(TokenKind.colon)
					end 'isLabel'
				end 'positionalArg'

				let argResult = parseExpression(module, block: block)
				argIds.push(argResult.valueId)
				argIndex = argIndex + 1

				if at(TokenKind.rightParen) 'endArgs'
					break
				end 'endArgs'
			end 'argLoop'
		end 'hasArgs'
		return argIds
	end 'parseCallArgs'

	// Emit a function call and return the appropriate ExprResult based on return type.
	function emitCallAndResult(module MlirModule, block MlirBlock, calleeName String, argIds ValueIdArray) returns ExprResult
		let callId = nextValueId(project)
		emitOp(module, block: block, op: MaxonOp.call(callId, callee: calleeName, argIds: argIds))
		let calleeReturnType = try project.funcReturnTypes.get(calleeName) otherwise ""
		let resolvedReturnType = resolveTypeName(project, name: calleeReturnType)
		if resolvedReturnType == "f64" 'isFloatReturn'
			return ExprResult.createFloat(callId)
		end 'isFloatReturn'
		// Check if the return type is a struct (ref type)
		if project.structTypes.contains(calleeReturnType) 'isRefReturn'
			return ExprResult.createStruct(callId, structTypeName: calleeReturnType)
		end 'isRefReturn'
		return ExprResult.create(callId)
	end 'emitCallAndResult'

	// Resolve an instance method name by finding the struct type of the variable.
	function resolveInstanceMethod(varName String, methodName String) returns String
		let structType = getVariableStructType(varName)
		if structType.isEmpty() 'noType'
			return methodName
		end 'noType'
		return "{structType}.{methodName}"
	end 'resolveInstanceMethod'

	// Parse struct literal: TypeName{field: value, field: value, ...}
	// Allocates heap memory and stores each field value at its offset.
	// When called from parseIdentifierExpr, the type name identifier has not been consumed.
	// When called from parseSelfExpr, the Self token has already been consumed.
	// skipTypeName: 0 = consume type name identifier first, 1 = already consumed (called from parseSelfExpr)
	function parseStructLiteral(module MlirModule, block MlirBlock, typeName String, typeToken Token, skipTypeName ParsedInt = 0) returns ExprResult
		if skipTypeName == 0 'consumeTypeName'
			expect(TokenKind.identifier)
		end 'consumeTypeName'
		expect(TokenKind.leftBrace)
		skipNewlines()

		let structType = try project.structTypes.get(typeName) otherwise 'noType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown struct type '{typeName}'", line: typeToken.line, column: typeToken.column, filePath: filePath)
			return ExprResult.create(0)
		end 'noType'

		// Allocate heap memory for the struct
		let sizeId = emitLiteral(module, block: block, value: structType.byteSize, isFloat: false)
		let ptrId = nextValueId(project)
		emitOp(module, block: block, op: MaxonOp.structAlloc(ptrId, byteSize: sizeId))

		// Parse field: value pairs and store each field
		while not at(TokenKind.rightBrace) 'fields'
			let fieldNameToken = consume()
			expect(TokenKind.colon)
			let fieldValue = parseExpression(module, block: block)

			// Find the field offset
			var fieldFound = false
			for field in structType.fields 'findField'
				if field.name == fieldNameToken.value 'match'
					emitOp(module, block: block, op: MaxonOp.fieldStore(ptrId, offset: field.offset, valueId: fieldValue.valueId))
					fieldFound = true
					break
				end 'match'
			end 'findField'
			if not fieldFound 'unknown'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Unknown field '{fieldNameToken.value}' in type '{typeName}'", line: fieldNameToken.line, column: fieldNameToken.column, filePath: filePath)
			end 'unknown'

			skipNewlines()
		end 'fields'
		expect(TokenKind.rightBrace)

		return ExprResult.createStruct(ptrId, structTypeName: typeName)
	end 'parseStructLiteral'

	function parsePrimaryMatch(module MlirModule, block MlirBlock, token Token) returns ExprResult throws ParserError
		match token.kind 'primary'
			intLiteral then return parseIntLiteral(module, block: block, token: token)
			floatLiteral then return parseFloatLiteral(module, block: block, token: token)
			identifier then return try parseIdentifierExpr(module, block: block, token: token)
			doubleStringLiteral then return parseStringLiteral(token)
			true then return parseBoolLiteral(module, block: block, value: 1)
			false then return parseBoolLiteral(module, block: block, value: 0)
			leftParen then return parseParenExpr(module, block: block)
			selfType then return parseSelfExpr(module, block: block)
			default throws ParserError.unhandledToken
		end 'primary'
	end 'parsePrimaryMatch'

	// Parse Self{field: value, ...} inside a type declaration.
	function parseSelfExpr(module MlirModule, block MlirBlock) returns ExprResult
		let selfToken = consume()
		if currentTypeName.isEmpty() 'notInType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'Self' can only be used inside a type declaration", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.create(0)
		end 'notInType'
		if at(TokenKind.leftBrace) 'isStructLiteral'
			return parseStructLiteral(module, block: block, typeName: currentTypeName, typeToken: selfToken, skipTypeName: 1)
		end 'isStructLiteral'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
		return ExprResult.create(0)
	end 'parseSelfExpr'

	function parsePrimary(module MlirModule, block MlirBlock) returns ExprResult
		let token = peek()
		let result = try parsePrimaryMatch(module, block: block, token: token) otherwise 'unhandled'
			return raiseUnexpectedToken(token)
		end 'unhandled'
		return result
	end 'parsePrimary'

	function raiseUnexpectedToken(token Token) returns ExprResult
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected expression but got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		// Skip to end of line to prevent cascading errors
		while not at(TokenKind.newline) and not at(TokenKind.eof) 'skip'
			advance()
		end 'skip'
		return ExprResult.create(0)
	end 'raiseUnexpectedToken'

	function parseIntLiteral(module MlirModule, block MlirBlock, token Token) returns ExprResult
		let value = try parseInt(token.value) otherwise 'overflow'
			reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)", line: token.line, column: token.column, filePath: filePath)
			expect(TokenKind.intLiteral)
			return ExprResult.create(0)
		end 'overflow'
		let id = emitLiteral(module, block: block, value: value, isFloat: false)
		expect(TokenKind.intLiteral)
		return ExprResult.create(id)
	end 'parseIntLiteral'

	function parseFloatLiteral(module MlirModule, block MlirBlock, token Token) returns ExprResult
		let rawBits = try parseFloatBits(token.value) otherwise 'overflow'
			reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float", line: token.line, column: token.column, filePath: filePath)
			expect(TokenKind.floatLiteral)
			return ExprResult.createFloat(0)
		end 'overflow'
		let id = emitLiteral(module, block: block, value: rawBits, isFloat: true)
		expect(TokenKind.floatLiteral)
		return ExprResult.createFloat(id)
	end 'parseFloatLiteral'

	function parseStringLiteral(token Token) returns ExprResult
		let id = nextValueId(project)
		expect(TokenKind.doubleStringLiteral)
		return ExprResult.createFull(id, isFloat: false, isRefType: false, isStringConst: true, stringConstValue: token.value)
	end 'parseStringLiteral'

	function parseBoolLiteral(module MlirModule, block MlirBlock, value ParsedInt) returns ExprResult
		let id = emitLiteral(module, block: block, value: value, isFloat: false)
		advance()  // skip 'true' or 'false'
		return ExprResult.create(id)
	end 'parseBoolLiteral'

	function parseParenExpr(module MlirModule, block MlirBlock) returns ExprResult
		expect(TokenKind.leftParen)
		let inner = parseExpression(module, block: block)
		expect(TokenKind.rightParen)
		return inner
	end 'parseParenExpr'

end 'Parser'

// --- Public API wrapper ---

export function parse(project Project, tokens TokenArray, filePath FilePath) returns MlirModule
	let parser = Parser.create(project, tokens: tokens, filePath: filePath)
	return parser.parseModule()
end 'parse'

// Recursive descent parser.
// Consumes tokens and emits Maxon ops into an MaxonModule with block-based CFG.
//
// ===== Helper contract (stream-style) =====
//
//   entry: cursor AT the construct's first token.
//   exit:  cursor AT the first token AFTER the construct (or at exhaustion).
//
// Token primitives:
//   at(K) / atOffset(K, n)  peek the cursor (no advance)
//   accept(K)               if at(K): advance, return true; else false
//   consume()               advance past current, return the Token  ← default verb
//   eat(K)                  advance past, asserting kind (panic on mismatch)
//   expect(K)               validate user input (diagnose + synchronize on mismatch)
//
// Use `consume()` when you've classified the token and want to step past it.
// `eat(K)` is for pure separators where the token's value doesn't matter.
// `expect(K)` is the only one that produces a diagnostic on mismatch.
//
// Never call `cursor.advance()` directly. A bare advance is "I'm leaving this
// token without looking" — but if we're advancing, either we've already
// classified it (use consume/eat) or we're reading it now (use consume).
// The lone exceptions are `synchronize` during error recovery and the dispatch
// loops' stuck-guard — both deliberately blind skips.
//
// ===== End-of-file semantics =====
//
// The lexer appends a `TokenKind.eof` sentinel as the last token of the
// stream. After consuming all user-visible tokens, `cursor.current()` still
// returns a valid Token (the EOF sentinel) with empty `value`, line/column
// pointing one past the last lexed character. This lets diagnostic helpers
// emit "got '<token>'" messages without a special EOF branch — the empty
// value renders as `''` and matches the C# bootstrap's phrasing.
//
// Helpers that consume a token via `cursor.advance()` past the EOF sentinel
// throw `IterationError.exhausted`; the parser's `consume()` wrapper catches
// that and reports `Unexpected end of input, expected <X>`.
//
// Unclosed constructs (missing `end`, `)`, `}`, truncated expression) are
// parse errors, not silent terminations. Helpers that expect a closing
// terminator check for it explicitly and report `unexpected end of input`
// with the opener's source range when the cursor exhausts before they find it.
//
// ===== Panics vs diagnostics =====
//
// The parser NEVER calls `panic()` on input-driven failures. Malformed or
// incomplete input produces a diagnostic (via `reportCompileError`) or a
// `ParserError` throw that the caller converts to one. Panics are reserved
// for internal-invariant failures — loop guards that just succeeded yet a
// subsequent `get()` failed, map `contains()` returning true yet `get()`
// failing, etc. Those are parser bugs, not user errors.

export typealias BoolArray = Array with bool
// Phase 9 Stage 5 (struct-backing): per-function let bindings whose
// initializer is a known struct-backed enum-case literal. Keyed on the
// let's bare local name; value is the qualified `EnumName.caseName` of
// the case. Reset by `resetSymbolTable` between functions.
export typealias StructBackedEnumCaseBindingMap = Map with(String, String)

typealias TokenIter = ArrayIterator with Token

// Number of `.field` segments on a field-assignment LHS (`a.b.c = …` has
// depth 2). No concrete upper bound — bounded only by source-program size.
typealias FieldChainDepth = int(0 to u64.max)
typealias ChainPeekOffset = int(0 to u64.max)

// `\xNN` / `\uNNNN` decoding: a single nibble (0..15) and a BMP codepoint.
typealias HexNibble = int(0 to 15)
typealias UnicodeCodepoint = int(0 to 0x10FFFF)

// Recursion depth budget for the parser-time producer-type scan that chases
// varLoad→varDecl→call chains so `var m = MapInit()` resolves to `Map<...>`
// when the parser needs to qualify a method call on `m`.
typealias ScanDepth = int(0 to 8)

// Stage E (closures): one entry per distinct outer-scope name captured by
// a closure body. The parser appends to `closureCaptures` in first-reference
// order so `index` doubles as the env-array slot at lowering time. Capture
// is by reference: lowering emits a stackAddr of the outer slot into env[i],
// and the lifted body's `closureEnvLoad` reads through env[i] to recover
// the live value at call time.
export type CaptureInfo
	export var name String
	export var captureType MaxonType
	export var index ParsedInt

	export static function create(name String, captureType MaxonType, index ParsedInt) returns CaptureInfo
		return Self{name: name, captureType: captureType, index: index}
	end 'create'
end 'CaptureInfo'

export typealias CaptureInfoArray = Array with CaptureInfo

export type Parser
	var project Project
	// Original token array kept for absolute-index lookups (e.g. "previous
	// token"). The cursor drives consumption; this array stays fixed.
	var tokens TokenArray
	var cursor TokenIter
	var filePath FilePath
	// Module namespace supplied by the caller — used to qualify declarations
	// and resolve unqualified calls within this module.
	var namespace String
	// Current type name when parsing inside a type declaration (for Self resolution)
	var currentTypeName String
	// Phase 11.0: bare names of the in-scope type parameters declared by the
	// enclosing `type X uses A, B` (or `extension`/`function`) header. Set on
	// type-body entry, cleared on type-body exit. `parseTypeRef` consults
	// this list before its single-token type lookup so a bare identifier
	// matching one of the entries lowers to `MaxonType.typeParameter(id)`
	// instead of falling through to `internMaxonType` (which would treat the
	// name as a regular `MaxonType.named`).
	var currentTypeParams StringArray
	// Phase 11.7: bare-name conformance list for the enclosing `type` body's
	// `implements` clause. Set on type-body entry, cleared on body exit.
	// `checkUnusedParameters` consults it to suppress E3012 on parameters of
	// methods that satisfy an interface's required signature — those parameter
	// names are dictated by the interface and may legitimately go unread in a
	// stub or no-op implementation.
	var currentTypeConformances ConformanceArray
	// Visibility tier of the type currently being parsed. Set by `parseTypeDecl`
	// at body-entry, cleared at body-exit. Static decls and instance methods
	// inside the body inherit this — `module type T { static var f = 0 }`
	// makes `T.f` module-scoped without a per-member modifier.
	var currentTypeVisibility Visibility
	// Visibility tier of the enum currently being parsed. Set by `parseEnumDecl`
	// at body-entry, cleared at body-exit. Per-case top-level constants and
	// the auto-injected typealias for the enum inherit this.
	var currentEnumVisibility Visibility
	var scope Scope
	// Context stacks for break/continue and match
	var loopStack LoopContextArray
	var matchStack MatchContextArray
	// Set when an unexpected statement token aborts the enclosing function body,
	// mirroring the C# bootstrap compiler's throw-to-top-level recovery. Suppresses
	// cascading E3013 (missing-return) and out-of-place `end` consumption.
	var abortBody bool
	// Per-function unused-parameter and unused-local tracking. paramLocations
	// records each parameter's declaration site; localVarLocations records
	// each `let`/`var` declaration's site; referencedVars records every name
	// read by identifier/assignment/dot-call paths in the body. All three are
	// reset at the top of parseFunction and consulted by checkUnusedParameters.
	var paramLocations ParamLocationArray
	var localVarLocations ParamLocationArray
	var referencedVars ReferencedVarSet
	// Per-function counter for minting synthetic intermediate names (`$t0`,
	// `$t1`, …). Reset to 0 at the top of each function parse. Each synthetic
	// name is the ASCII byte sequence of `$t` + the integer, wrapped in a
	// ByteArray so it flows as a zero-copy name slice through the Maxon IR.
	// SSA numbering at the Std level is assigned later (in LowerMaxonToStd).
	var synthNameCounter ParsedInt
	// Grow-on-demand cache of synth-name ByteArrays, indexed by the counter
	// value. Entries 0..K are populated lazily as freshSynthName is called;
	// subsequent functions within the same Parser reuse the hot entries
	// without re-allocating. Sub-parsers for string interpolation get their
	// own small cache — lifetime matches the Parser instance.
	var synthNameCache ByteArrayArray
	// Tracks the block expression-level emission is currently writing into,
	// and the function that owns it. Bool short-circuit emission for `and`/`or`
	// switches blocks mid-expression: the cond_br lands in the entry block,
	// the rhs evaluates in a fresh side block, and we resume in a fresh merge
	// block. Statement-level callers that emit further ops after parseExpression
	// must read currentBlock to find the block control flow actually landed on.
	var currentBlock IrBlock
	var currentFunc IrFunction
	// The Maxon module being populated. Initialized empty in `create()` and
	// returned by `parseModule()`. Lifetime spans this Parser instance — every
	// helper that emits ops writes into this single module, so it lives as a
	// field rather than being threaded through every signature.
	var module MaxonModule
	// User-facing description of the next token's expected role, set by
	// the caller of consume()/advance() before invoking. On EOF, the
	// helper emits "Unexpected end of input, expected <consumeExpectedDisplay>"
	// instead of a generic message — gives parity with C#'s "expected X"
	// suffix without threading the kind through every call site.
	var consumeExpectedDisplay String
	// True while parsing an arm body inside a match statement. Suppresses the
	// Pratt parser's consumption of `and` when followed by `fallthrough` so
	// the match-arm helper can see and process the fallthrough marker.
	// Saved/restored by callers so nested matches behave correctly.
	var inMatchArmBody bool
	// Stage E (closures): set true while parsing a closure body. Toggles the
	// capture-detection branches in `emitSelfLoad` and the bare-name read
	// path so outer-scope references emit `closureEnvLoad` ops instead of
	// crashing with "Undefined variable" against the lifted function's
	// fresh scope. parseClosure saves/restores both this and `closureCaptures`.
	var inClosure bool
	// Suppress parseTypeRef's `with` consumption when inside a function
	// parameter list. The C# bootstrap does not parse generic-instance
	// inline (`Base with Args`) outside typealias-RHS / conformance
	// contexts, so a parameter named `with` (e.g. `replace(old String, with String)`
	// in stdlib's String.maxon) doesn't get gobbled as a generic-instance
	// arg of the previous param's type. Saved/restored across nested
	// function declarations.
	var inFunctionParam bool
	// True while parsing the source expression of a `for X in <expr> to/upto <expr>`
	// header. Suppresses the Pratt parser's range-as-binary-op consumption of
	// `to`/`upto` so the for-in parser sees those tokens and uses its
	// fast-path while-loop desugaring. parseParenExpr saves/clears this so a
	// parenthesized sub-expression (e.g. `for x in (1 upto 4).createIterator() 'l'`)
	// still gets a first-class Range/OpenRange value.
	var inForInHeader bool
	// Stage E (closures): the outer function's scope at the moment we
	// entered a closure body. Used to discriminate capture references
	// (declared in the enclosing scope) from genuine undefined names.
	// `closureCaptures` accumulates a CaptureInfo per distinct outer name
	// referenced in the body so parseClosure can mint a paired
	// `closureCreate` op carrying the names + types in env-array order.
	var closureOuterScope Scope
	var closureCaptures CaptureInfoArray

	// Lazily allocated synthetic `__module_init_<n>` function for this file.
	// Holds the IR for materializing every top-level array-literal initializer
	// in the source. The first `let xs = [...]` / `var xs = [...]` at module
	// scope creates the function and its single entry block; subsequent literals
	// emit into the same block. `moduleInitName` is empty when the function has
	// not been allocated yet — a fresh-Parser sentinel keyed off Optional<T>'s
	// absence is unavailable for IrFunction in the current type system, so the
	// pair (name == "", entry block index) carries the same intent.
	var moduleInitName String
	// Captured at allocation time. `moduleInitFunc` is the IrFunction the
	// parser passes to `module.addBlockAt`; `moduleInitBlock` is the entry
	// block where every array-literal init's ops are appended. Both are valid
	// only when `moduleInitName != ""`. The same struct identity flows back
	// into `finalizeModuleInit` so the closing `ret` lands in the right block.
	var moduleInitFunc IrFunction
	var moduleInitBlock IrBlock
	// Synthetic-name counter dedicated to `__module_init_<n>`. The shared
	// `synthNameCounter` resets between user functions (see resetSymbolTable),
	// so a second top-level array literal parsed after an intervening user
	// function would otherwise re-use names from the first literal and crash
	// the producer-type map. We snapshot/restore around each
	// `parseTopLevelArrayLiteralDecl` call so this counter advances
	// monotonically across every literal in the file regardless of how many
	// user functions sit between them.
	var moduleInitSynthCounter ParsedInt
	// E3062 (unused typealias) tracking. `localTypealiases` records every
	// file-private `typealias Name = ...` parsed in this file with its source
	// location; `usedTypeAliases` accumulates every type-name token that
	// resolved through a type-reference site. After parseModule finishes,
	// `checkUnusedTypeAliases` reports any local alias that wasn't referenced.
	// Implicit-inferred uses from bare `[...]` array literals don't count —
	// only literal `Name`-token references do, matching the C# bootstrap.
	var localTypealiases LocalTypealiasArray
	var usedTypeAliases ReferencedVarSet
	// Phase 9 Stage 5 (struct-backing): per-function let bindings whose
	// initializer is a known struct-backed enum-case literal. The map keyed
	// on the let's bare name; value is the qualified `EnumName.caseName`.
	// `parseVarDecl` records the entry when the initializer's tokens are
	// `EnumName.caseName` and `caseHasStructBacking` returns true; the
	// identifier-read path consults it to fold `local.rawValue.field`
	// chains to the leaf constant the same way direct
	// `EnumName.caseName.field` chains do. Cleared by `resetSymbolTable` so
	// a fresh function starts with no stale bindings.
	var letStructBackedEnumCases StructBackedEnumCaseBindingMap

	export static function create(project Project, tokens TokenArray, filePath FilePath, namespace String) returns Parser throws ParserError
		// Empty token array (empty or whitespace-only source) is a legitimate
		// input — caller must handle by throwing ParserError.unexpectedEof so
		// empty-file handling is explicit rather than a silent empty module.
		let cursor = try tokens.cursor() otherwise throw ParserError.unexpectedEof
		// Placeholder func/block — every parseFunction call rebinds these
		// before any expression is parsed.
		let placeholderFunc = IrFunction.create("", maxonReturnType: MaxonReturnType.void, paramCount: 0, maxonParamTypes: MaxonTypeArray.create(), returnLine: 0)
		let placeholderBlock = IrBlock.create(0, label: "")
		return Self{project: project, tokens: tokens, cursor: cursor, filePath: filePath, namespace: namespace, currentTypeName: "", currentTypeParams: StringArray.create(), currentTypeConformances: ConformanceArray.create(), currentTypeVisibility: Visibility.file, currentEnumVisibility: Visibility.file, scope: Scope.create(), loopStack: LoopContextArray.create(), matchStack: MatchContextArray.create(), abortBody: false, paramLocations: ParamLocationArray.create(), localVarLocations: ParamLocationArray.create(), referencedVars: ReferencedVarSet.create(), synthNameCounter: 0, synthNameCache: ByteArrayArray.create(), currentBlock: placeholderBlock, currentFunc: placeholderFunc, module: MaxonModule.create(), consumeExpectedDisplay: "more input", inMatchArmBody: false, inClosure: false, inFunctionParam: false, inForInHeader: false, closureOuterScope: Scope.create(), closureCaptures: CaptureInfoArray.create(), moduleInitName: "", moduleInitFunc: placeholderFunc, moduleInitBlock: placeholderBlock, moduleInitSynthCounter: 0, localTypealiases: LocalTypealiasArray.create(), usedTypeAliases: ReferencedVarSet.create(), letStructBackedEnumCases: StructBackedEnumCaseBindingMap.create()}
	end 'create'

	export function parseModule() returns MaxonModule throws ParserError
		logDebug(LogCategory.parser, message: () gives "parser: module={filePath}")

		// Stream-style dispatch: each helper exits past its last-consumed token.
		// Use skipOptionalNewlines (vs skipNewlines) since trailing newlines at
		// EOF are normal at top level — they're just blank lines after the last
		// declaration, not a missing-content error.
		while skipOptionalNewlines() 'parseLoop'
			let prevPos = cursor.index()
			let diagCountBefore = project.diagnostics.count()
			let token = cursor.current()

			try 'dispatch'
				dispatchTopLevel()
			end 'dispatch' otherwise(e) 'propagate'
				match e 'kind'
					unhandledToken then return handleTopLevelUnhandledToken(token, diagCountBefore: diagCountBefore)
					typeError then throw ParserError.typeError
					overflow then throw ParserError.overflow
					unexpectedEof then throw ParserError.unexpectedEof
				end 'kind'
			end 'propagate'

			if abortBody 'aborted'
				abortBody = false
				// synchronizeToTopLevel parked cursor AT next top-level opener (or ran out).
				if cursor.index() >= tokens.count() 'noMore'
					break
				end 'noMore'
				if not isAtTopLevelOpener() 'noOpener'
					break
				end 'noOpener'
				// Fall through — next iteration re-dispatches the opener.
			end 'aborted'

			// Stuck-guard: dispatch failed to advance. Force progress by one token.
			if cursor.index() <= prevPos 'stuck'
				try cursor.advance() otherwise break
			end 'stuck'
		end 'parseLoop'

		// Close out the synthetic `__module_init_<n>` function (if any) with
		// a void `ret` so its entry block is properly terminated before the
		// MaxonModule is handed off.
		finalizeModuleInit()

		checkUnusedTypeAliases()

		// Propagate char-byte provenance through each function's varDecl /
		// varLoad chains. The literal-emission site populated
		// `project.charByteLiterals` for raw literal value names; this walk
		// extends the set so a `let c = 'A'` binding also marks every
		// subsequent `varLoad` of `c` as char-byte. Consumers (overload
		// resolution in MaxonDialect, interpolation lowering in
		// LowerMaxonToStd) read the project-level set at their site and
		// don't need a separate per-function pass.
		propagateCharByteThroughVarChains(project, module: module)

		return module
	end 'parseModule'

	// E3062: every file-private `typealias` recorded in this Parser must be
	// referenced explicitly somewhere in the file. Implicit uses inferred from
	// a bare `[...]` array literal don't count — the alias must appear by name
	// at a type position (parseTypeRef) or wherever else `usedTypeAliases`
	// gets populated. Mirrors maxon-sharp's `CheckUnusedTypeAliases`.
	//
	// Suppression: the bootstrap's `PreScanTypeAliasesOnly` short-circuits
	// further parsing of any file whose pre-scan emitted a diagnostic, so
	// `CheckUnusedTypeAliases` never runs there. The self-hosted parser keeps
	// going after a typealias error to maximise per-file recovery, which would
	// double-report the same alias as both E3061 (or E3060 etc.) and E3062.
	// Skip the unused-check when the file already has a typealias-related
	// diagnostic so the wording stays in sync with the bootstrap.
	function checkUnusedTypeAliases()
		if fileHasTypealiasDiagnostic() 'alreadyReported'
			return
		end 'alreadyReported'
		for entry in localTypealiases 'eachAlias'
			if not usedTypeAliases.contains(entry.name) 'isUnused'
				reportCompileError(project, code: ErrorCode.semanticUnusedTypeAlias, message: "unused typealias: '{entry.name}'", line: entry.line, column: entry.column, filePath: filePath)
			end 'isUnused'
		end 'eachAlias'
	end 'checkUnusedTypeAliases'

	// True when `project.diagnostics` already contains an E3061 (duplicate
	// typealias) entry for this file. The cascade gate in reportCompileError
	// covers lex/parser/IR errors but doesn't suppress 3xxx-after-3xxx; this
	// helper plugs the typealias-specific gap.
	function fileHasTypealiasDiagnostic() returns bool
		let myPath = filePath.toString()
		for d in project.diagnostics 'eachDiag'
			if d.code.rawValue == ErrorCode.semanticDuplicateTypeAlias.rawValue and d.filePath.toString() == myPath 'isMatch'
				return true
			end 'isMatch'
		end 'eachDiag'
		return false
	end 'fileHasTypealiasDiagnostic'

	// Reject declarations whose name starts with `__`, and reject `self` as a
	// binding name. The `__` prefix is reserved for compiler-internal symbols
	// (runtime intrinsics, builtin types like __ManagedMemory);
	// stdlib/Builtins.maxon is the sole exemption — it's the type-system
	// bridge that exposes those internal names. `self` is the implicit
	// instance receiver and binding it would silently shadow the receiver.
	// Call this at every site that introduces a NEW binding
	// (function/type/typealias/field/param/let/var/match-binding). Pure
	// references to existing __ names are fine.
	function checkReservedDeclName(nameToken Token)
		if namespace == "stdlib" and filePath.filename() == "Builtins.maxon" 'isBuiltins'
			return
		end 'isBuiltins'
		if namespace == "stdlib" and filePath.filename() == "Internals.maxon" 'isInternals'
			return
		end 'isInternals'
		if filePath.filename() == "stdlib-bootstrap.maxon" 'isBootstrap'
			return
		end 'isBootstrap'
		if nameToken.value == "self" 'selfReserved'
			reportCompileError(project, code: ErrorCode.parserReservedIdentifier, message: "identifier 'self' is reserved: it is the implicit instance receiver and cannot be bound by user code", line: nameToken.line, column: nameToken.column, filePath: filePath)
			return
		end 'selfReserved'
		if not nameToken.value.startsWith("__") 'notReserved'
			return
		end 'notReserved'
		reportCompileError(project, code: ErrorCode.parserReservedIdentifier, message: "identifier '{nameToken.value}' is reserved: declarations starting with '__' are reserved for compiler internals", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'checkReservedDeclName'

	// --- Function parsing ---

	// Parse a single type reference. Recognizes either:
	//   - a single type-name token (identifier or primitive keyword), OR
	//   - a function type `(T1, T2) returns R` (parameter parens, optional
	//     `returns` clause; missing `returns` ⇒ void return).
	// Used by parameter-type and interface-method parameter-type sites so
	// `function apply(f (Integer) returns Integer, x Integer) ...` parses.
	// On a missing/malformed type token the helper reports E2003 and
	// synchronizes the cursor — callers that already have their own
	// recovery path (parseFunctionParameters' `synchronize() + return`)
	// preserve that behaviour by checking `at(TokenKind.rightParen)` after
	// the call and bailing.
	//
	// Commas inside the function-type parameter list are skipped at the
	// lexer (see actionTable's skipOther), so the inner `parseTypeRef` calls
	// see a flat run of types between the parens.
	function parseTypeRef() returns MaxonType throws ParserError
		// Paren-prefixed type: either a function type `(T1, T2) returns R`
		// or a tuple type `(T1, T2, ...)` (2+ elements, no `returns`).
		// Empty `()` and single-element `(T)` followed by `returns` are
		// always function types; `()` alone is a void→void function type.
		if at(TokenKind.leftParen) 'isParen'
			try eat(TokenKind.leftParen)
			var innerTypes = MaxonTypeArray.create()
			while not at(TokenKind.rightParen) 'paramTypes'
				let inner = try parseTypeRef()
				innerTypes.push(inner)
				if at(TokenKind.rightParen) 'doneParams'
					break
				end 'doneParams'
				try expect(TokenKind.comma)
			end 'paramTypes'
			try eat(TokenKind.rightParen)
			// `returns` always means function type. Otherwise: 2+ inner
			// types means tuple; 0 or 1 stays a function type (void-arg
			// returning void / single-arg returning void). This matches
			// the C# bootstrap's disambiguation rule.
			if at(TokenKind.returns) 'hasReturn'
				try eat(TokenKind.returns)
				let retInner = try parseTypeRef()
				let fnReturn = MaxonReturnType.value(retInner)
				let id = internFunctionType(project, paramTypes: innerTypes, returnType: fnReturn)
				return MaxonType.function(id)
			end 'hasReturn'
			if innerTypes.count() >= 2 'isTuple'
				let baseName = "__Tuple{innerTypes.count()}"
				let baseId = project.typeNames.intern(baseName)
				let giid = project.genericInstances.intern(baseId, args: innerTypes)
				return MaxonType.genericInstance(giid)
			end 'isTuple'
			let fnReturn = MaxonReturnType.void
			let id = internFunctionType(project, paramTypes: innerTypes, returnType: fnReturn)
			return MaxonType.function(id)
		end 'isParen'

		// Phase 11.0 step 3b: bare `Self` in any type position resolves to the
		// enclosing type's name. The lexer emits `Self` as a dedicated
		// `selfType` keyword token, so `isTypeNameToken` (identifier/primitive
		// only) doesn't accept it — handle it here before the generic single-
		// token path. Outside a type/extension body the keyword is meaningless;
		// report a clean diagnostic and synchronize.
		let maybeSelf = cursor.current()
		if maybeSelf.kind == TokenKind.selfType 'isSelfType'
			if currentTypeName.isEmpty() 'noCtx'
				reportCompileError(project, code: ErrorCode.parserExpectedType, message: "'Self' is only valid inside a type or extension body", line: maybeSelf.line, column: maybeSelf.column, filePath: filePath)
				synchronize()
				return MaxonType.unresolved
			end 'noCtx'
			try eat(TokenKind.selfType)
			return internMaxonType(project, name: currentTypeName)
		end 'isSelfType'

		// Single-token type — identical to the legacy parameter-type path.
		let typeToken = try consumeExpecting("type name")
		if not isTypeNameToken(typeToken) 'badType'
			reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Expected type name", line: typeToken.line, column: typeToken.column, filePath: filePath)
			synchronize()
			// Return a placeholder — the caller's synchronize check will
			// drop this value before it reaches downstream consumers.
			return MaxonType.unresolved
		end 'badType'

		// Phase 11.0: a bare identifier matching one of the in-scope type
		// parameters lowers to `MaxonType.typeParameter(id)`. The lookup
		// table is empty outside generic type bodies, so non-generic code
		// pays only the .count() check. We don't apply this rule to keyword
		// tokens (Self, primitive type names) since those have their own
		// resolution paths.
		if typeToken.kind == TokenKind.identifier and isTypeParameterName(typeToken.value) 'isTypeParam'
			let pid = project.typeParameters.intern(currentTypeName, paramName: typeToken.value)
			return MaxonType.typeParameter(pid)
		end 'isTypeParam'

		// E3062 use-tracking: every parseTypeRef site that consumes a real
		// identifier counts as a use of any same-named local typealias. Only
		// identifier tokens get tracked — keyword type names (`int`, `bool`,
		// `String`) cannot be aliases anyway.
		if typeToken.kind == TokenKind.identifier 'trackUse'
			usedTypeAliases.insert(element: typeToken.value)
		end 'trackUse'

		// Phase 9 Stage 4: accept dotted type names like `Shape.unionCases`
		// for the union-cases companion enum. The companion is registered as
		// a typealias under the dotted name, so the regular `internMaxonType`
		// path resolves it once we glue the segments back together. Only
		// applied when the dotted name is a known type/alias/enum —
		// otherwise we leave the `.` for the surrounding caller (typealias
		// args, type-resolution placeholders) to handle.
		if typeToken.kind == TokenKind.identifier and at(TokenKind.dot) 'maybeDottedType'
			let dotPeek = try cursor.peek(1) otherwise Token.eof()
			if dotPeek.kind == TokenKind.identifier 'haveDottedMember'
				let dottedName = "{typeToken.value}.{dotPeek.value}"
				if project.unresolvedTypealiases.contains(dottedName) or project.typealiases.contains(dottedName) or project.unresolvedEnums.contains(dottedName) or project.enumTypes.contains(dottedName) 'isDottedType'
					try eat(TokenKind.dot)
					_ = try consume()
					usedTypeAliases.insert(element: dottedName)
					return internMaxonType(project, name: dottedName)
				end 'isDottedType'
			end 'haveDottedMember'
		end 'maybeDottedType'

		// Phase 11.0: extend `Base with Args`. After consuming the base name,
		// peek for `with`; if present, parse a comma-separated arg list (or a
		// single arg) and intern through the genericInstance registry. The
		// `Base` half of `Base with X` always resolves through the regular
		// type-name interner — generic-instance rewriting only kicks in once
		// `with` is observed. Inside a function param list, `with` after a
		// type name is the next param's name (matching C# behavior — generic
		// instances only land in typealias RHS / conformance contexts).
		if at(TokenKind.with) and not inFunctionParam 'isGenericInstance'
			try eat(TokenKind.with)
			var args = MaxonTypeArray.create()
			if accept(TokenKind.leftParen) 'parenList'
				while not at(TokenKind.rightParen) 'argLoop'
					let inner = try parseTypeRef()
					args.push(inner)
					if at(TokenKind.rightParen) 'doneArgs'
						break
					end 'doneArgs'
					try expect(TokenKind.comma)
				end 'argLoop'
				try expect(TokenKind.rightParen)
			end 'parenList' else 'singleArg'
				let inner = try parseTypeRef()
				args.push(inner)
			end 'singleArg'
			let baseId = project.typeNames.intern(typeToken.value)
			let giid = project.genericInstances.intern(baseId, args: args)
			return MaxonType.genericInstance(giid)
		end 'isGenericInstance'

		return internMaxonType(project, name: typeToken.value)
	end 'parseTypeRef'

	// Phase 11.0: True iff `name` is one of the in-scope type-parameter bare
	// names (collected from a `uses` clause on the enclosing type/extension).
	// `currentTypeParams` is empty outside generic bodies, so the loop
	// short-circuits to false in non-generic code.
	function isTypeParameterName(name String) returns bool
		for i in 0 upto currentTypeParams.count() 'scan'
			let p = try currentTypeParams.get(i) otherwise return false
			if p == name 'hit'
				return true
			end 'hit'
		end 'scan'
		return false
	end 'isTypeParameterName'

	// Parse a parenthesized parameter list of the form `name Type, name Type, ...`
	// with optional default values `name Type = literal`.
	// Appends each parameter to the symbol table and to paramTypes, and updates
	// paramCount. Also fills paramNames and paramDefaults (parallel arrays) for
	// the call-site reordering pass. Caller is responsible for the leading `(`
	// and trailing `)`.
	function parseFunctionParameters(paramCount ParsedInt, paramTypes MaxonTypeArray, paramNames StringArray, paramDefaults ParamDefaultArray) throws ParserError
		if cursor.current().kind == TokenKind.rightParen 'noParams'
			return
		end 'noParams'

		let savedInFunctionParam = inFunctionParam
		inFunctionParam = true
		try parseFunctionParametersInner(paramCount, paramTypes: paramTypes, paramNames: paramNames, paramDefaults: paramDefaults) otherwise(e) 'restoreOnErr'
			inFunctionParam = savedInFunctionParam
			throw e
		end 'restoreOnErr'
		inFunctionParam = savedInFunctionParam
	end 'parseFunctionParameters'

	function parseFunctionParametersInner(paramCount ParsedInt, paramTypes MaxonTypeArray, paramNames StringArray, paramDefaults ParamDefaultArray) throws ParserError
		while true 'paramLoop'
			let paramNameToken = try consumeExpecting("identifier")
			if not tokenIsIdentifierLike(paramNameToken) 'badName'
				reportTokenMismatch(paramNameToken, expectedDisplay: "identifier")
				synchronize()
				return
			end 'badName'

			checkReservedDeclName(paramNameToken)

			// `parseTypeRef` handles both the legacy single-token type and
			// function-type parameter shapes (`f (Integer) returns Integer`).
			// On a malformed type it reports E2003 and synchronizes — the
			// `at(rightParen)` test below short-circuits the loop in that
			// case so we don't push half-consumed state.
			let paramMaxonType = try parseTypeRef()
			if at(TokenKind.rightParen) and isUnresolvedMaxonType(paramMaxonType) 'recovered'
				return
			end 'recovered'

			// Define the parameter as a variable so it's accessible in the body
			_ = defineVariableWithType(paramNameToken.value, varType: paramMaxonType)
			paramLocations.push(ParamLocation.create(paramNameToken.value, line: paramNameToken.line, column: paramNameToken.column))
			paramTypes.push(paramMaxonType)
			paramNames.push(paramNameToken.value)
			paramDefaults.push(try parseOptionalParamDefault())
			paramCount = paramCount + 1
			// Stage E (closures): a function-typed parameter `f (T) returns R`
			// expands at the ABI level to a (fn-pointer, env-pointer) pair.
			// Allocate the hidden env slot in the parser's scope here — that
			// way the slot-id counter and any follow-on `defineVariableWithType`
			// (later params, locals in the body) automatically pick up the
			// +1 offset. The env slot has a reserved `__env_<paramName>`
			// name that user code can't shadow (`__`-prefix is rejected by
			// `checkReservedDeclName`). The matching paramTypes / paramNames
			// entry is appended later by parseFunction's caller-side
			// expansion step so the user-facing FuncSignature stays at the
			// declared param count.
			if isFunctionMaxonType(paramMaxonType) 'expandEnv'
				let envName = "__env_{paramNameToken.value}"
				_ = scope.declare(envName, varType: MaxonType.integer, mutable: true)
			end 'expandEnv'
			// C1.d: an interface-typed param ABI-expands to (value,
			// witness). Reserve a hidden slot for the witness here so
			// the next param (or local) lands at slot+2, keeping
			// VarSlot ids contiguous with `abiParamTypes` indexing.
			if interfaceTypeIsFat(paramMaxonType) 'expandWitness'
				let witnessName = "__witness_{paramNameToken.value}"
				_ = scope.declare(witnessName, varType: MaxonType.integer, mutable: true)
			end 'expandWitness'

			if cursor.current().kind == TokenKind.rightParen 'endParams'
				break
			end 'endParams'
			try expect(TokenKind.comma)
		end 'paramLoop'
	end 'parseFunctionParametersInner'

	// Parse an optional `= <literal>` default value for a parameter. Only
	// integer literals (optionally prefixed with `-`) are supported — the C#
	// bootstrap captures tokens and re-evaluates arbitrary expressions, but the
	// self-hosted parser needs only the literal form the current specs use.
	function parseOptionalParamDefault() returns ParamDefault throws ParserError
		if not at(TokenKind.equals) 'noDefault'
			return ParamDefault.none
		end 'noDefault'

		try eat(TokenKind.equals)

		let negate = accept(TokenKind.minus)

		let litToken = try consume()
		if litToken.kind != TokenKind.intLiteral 'notInt'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "parameter default value must be an integer literal", line: litToken.line, column: litToken.column, filePath: filePath)
			return ParamDefault.none
		end 'notInt'

		var value = try parseInt(litToken.value) otherwise 'overflow'
			reportLiteralOverflow(token: litToken, message: "Integer literal '{tokenValueToString(litToken.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ParamDefault.none
		end 'overflow'

		if negate 'applyNeg'
			value = 0 - value
		end 'applyNeg'

		return ParamDefault.intLiteral(value)
	end 'parseOptionalParamDefault'

	// Parse an optional `throws ErrorType` clause. Returns
	// `ThrowsClause.throwing(name)` when the clause is present and
	// `ThrowsClause.none` when absent. Phase 1c records this on
	// `IrFunction.throwsTypeName`; Phase 4 consumes it for error-flag ABI
	// lowering.
	function parseThrowsClause() returns ThrowsClause throws ParserError
		if not accept(TokenKind.throws) 'noThrows'
			return ThrowsClause.none
		end 'noThrows'
		let nameToken = try consumeExpecting("error type name")
		return ThrowsClause.throwing(nameToken.value)
	end 'parseThrowsClause'

	// Phase 11.0: parse an optional `where T is Trait1 [and Trait2]* [, T2 is
	// Trait3 ...]*` clause. Conjunction is expanded at parse time so the
	// returned array stores one (paramName, requiredTraitName) entry per
	// requirement. Bare-name capture only — Phase 11 step 5 resolves trait
	// names against the interface registries.
	//
	// Grammar:
	//     whereClause = 'where' constraint (',' constraint)*
	//     constraint  = IDENT 'is' IDENT ('and' IDENT)*
	//
	// `is` is a TokenKind keyword in expression contexts (reference identity),
	// but the where-clause grammar disambiguates positionally: the cursor only
	// reaches this slot when the parent decl-header parser explicitly invokes
	// `parseWhereClause`. Multiple constraints (one per type-parameter) are
	// separated by commas; conjunctions on a single parameter use `and`.
	function parseWhereClause() returns WhereClauseArray throws ParserError
		var clauses = WhereClauseArray.create()
		if not accept(TokenKind.where) 'noWhere'
			return clauses
		end 'noWhere'
		while at(TokenKind.identifier) 'paramLoop'
			let paramToken = try consume()
			// `is` is a TokenKind keyword. Use accept (not at-then-eat) so a
			// missing `is` reports through the regular tokenMismatch path
			// rather than infinite-looping on a malformed clause.
			if not accept(TokenKind.is) 'missingIs'
				let stray = cursor.current()
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "expected 'is' after type-parameter name in where clause, got '{tokenValueToString(stray.value)}'", line: stray.line, column: stray.column, filePath: filePath)
				return clauses
			end 'missingIs'
			// First trait name is mandatory; subsequent `and`-joined names
			// are optional. Each (paramName, traitName) pair becomes its own
			// WhereClause entry — the conjunction is flat at the AST level.
			var firstTrait = true
			while firstTrait or accept(TokenKind.and) 'traitLoop'
				firstTrait = false
				let traitToken = try consumeExpecting("trait name")
				clauses.push(WhereClause.create(paramToken.value, requiredTraitName: traitToken.value))
			end 'traitLoop'
			if not accept(TokenKind.comma) 'noMoreClauses'
				break
			end 'noMoreClauses'
		end 'paramLoop'
		return clauses
	end 'parseWhereClause'

	// Parse an optional `implements I1, I2 with X, I3 with (X, Y)` clause on a
	// `type` or `enum` declaration. Returns an empty array when the keyword
	// isn't present. Commas come through as real `TokenKind.comma` tokens; the
	// loop consumes one per conformance separator. Bare-name capture only —
	// Phase 3 of the interfaces plan resolves these against
	// `project.unresolvedInterfaces` and validates the type-parameter arity.
	//
	// Grammar:
	//     implementsClause = 'implements' conformance (',' conformance)*
	//     conformance      = IDENT ('with' withArgs)?
	//     withArgs         = IDENT | '(' IDENT (',' IDENT)* ')'
	//
	// The case `Iterator with RangeBound, BidirectionalIterator` parses as two
	// conformances (`Iterator with RangeBound` and `BidirectionalIterator`):
	// the bare-identifier `with` form takes exactly one type argument; the
	// next identifier opens the next conformance.
	//
	// `parenForm` on each `Conformance` records whether the `with(...)` arg
	// list used parens. TypeResolution uses this to collapse a parenthesized
	// multi-arg list against a single-`uses` interface into one `__TupleN`
	// generic-instance (mirrors maxon-sharp's `ParseWithTypeArgs`
	// `expectedCount == 1` branch).
	function parseImplementsClause() returns ConformanceArray throws ParserError
		var list = ConformanceArray.create()
		if not accept(TokenKind.implements) 'noImpl'
			return list
		end 'noImpl'

		// At least one conformance is required after `implements`. Subsequent
		// conformances are signalled by a comma followed by another
		// identifier in the next slot.
		while at(TokenKind.identifier) 'list'
			let nameToken = try consumeExpecting("interface name")
			var withArgs = StringArray.create()
			var parenForm = false
			if accept(TokenKind.with) 'hasWith'
				if accept(TokenKind.leftParen) 'parenList'
					parenForm = true
					while at(TokenKind.identifier) 'argLoop'
						let argToken = try consumeExpecting("type parameter name")
						withArgs.push(argToken.value)
						if at(TokenKind.rightParen) 'doneArgs'
							break
						end 'doneArgs'
						try expect(TokenKind.comma)
					end 'argLoop'
					try expect(TokenKind.rightParen)
				end 'parenList' else 'singleArg'
					let argToken = try consumeExpecting("type parameter name")
					withArgs.push(argToken.value)
				end 'singleArg'
			end 'hasWith'
			list.push(Conformance.create(nameToken.value, withArgs: withArgs, parenForm: parenForm, line: nameToken.line, column: nameToken.column))
			if not accept(TokenKind.comma) 'noMoreConf'
				break
			end 'noMoreConf'
		end 'list'

		return list
	end 'parseImplementsClause'

	// Parse an optional `returns Type` clause. Returns MaxonReturnType.void if
	// the clause is absent. The return-type slot routes through `parseTypeRef`,
	// which is the canonical entry that handles `Self`, generic instances
	// (`Base with X`), type-parameter names, and function types uniformly.
	// `Self` resolves against `currentTypeName` inside parseTypeRef.
	function parseOptionalReturnType() returns MaxonReturnType throws ParserError
		if not at(TokenKind.returns) 'noReturns'
			return MaxonReturnType.void
		end 'noReturns'

		try eat(TokenKind.returns)
		let returnType = try parseTypeRef()
		return MaxonReturnType.value(returnType)
	end 'parseOptionalReturnType'

	// Unified parser for both free functions and methods (static or instance).
	// When typeName is empty, parses a free function. When typeName is non-empty,
	// parses a method on that type; isInstance controls whether an implicit
	// `__self` parameter and field-load prologue / writeback epilogue are added.
	// entry: cursor AT the token AFTER `function` — the function-name identifier.
	// Caller (dispatchTopLevel / dispatchTypeMember / parseStaticMethod) has
	// already consumed the `function` keyword. `visibility` reflects either an
	// explicit `export` / `module` modifier or the inherited tier of the
	// enclosing type / enum (so `module type T { static function f() ... }`
	// makes `T.f` module-scoped without the user repeating the modifier).
	function parseFunction(typeName String, isInstance bool, fields StructFieldArray, visibility Visibility) throws ParserError
		let isMethod = not typeName.isEmpty()

		resetSymbolTable()
		let nameToken = try consumeExpecting("identifier")
		checkReservedDeclName(nameToken)

		// Derive the qualified name used for symbol registration and logging.
		var qualifiedName = ""
		if isMethod 'methodName'
			qualifiedName = "{typeName}.{nameToken.value}"
			logTrace(LogCategory.parser, message: () gives "parser: method '{qualifiedName}'")
		end 'methodName' else 'freeName'
			if nameToken.value == "main" 'isMain'
				qualifiedName = nameToken.value
			end 'isMain' else 'qualifyNonMain'
				qualifiedName = qualifyName(namespace, name: nameToken.value)
			end 'qualifyNonMain'
			logTrace(LogCategory.parser, message: () gives "parser: function '{nameToken.value}'")
		end 'freeName'

		try expect(TokenKind.leftParen)

		var paramCount = 0
		var paramTypes = MaxonTypeArray.create()
		var paramNames = StringArray.create()
		var paramDefaults = ParamDefaultArray.create()

		// Instance methods get an implicit self pointer parameter, registered
		// before explicit parameters so the parameter order matches the
		// calling convention. Self is a named MaxonType matching the
		// enclosing type; lowerMaxonToStd resolves it to i64 (pointer width).
		if isInstance 'addSelfParam'
			let selfMaxonType = internMaxonType(project, name: typeName)
			_ = defineVariableWithType("__self", varType: selfMaxonType)
			paramTypes.push(selfMaxonType)
			paramNames.push("__self")
			paramDefaults.push(ParamDefault.none)
			paramCount = paramCount + 1
			// C1.d: when the implicit `__self` is interface-typed (an extension
			// method declared on an interface), the ABI expands to (value,
			// witness). Reserve a hidden scope slot for the witness right after
			// `__self` so subsequent param/local slot ids stay aligned with the
			// expanded `abiParamTypes` indexing — without this, the first
			// user-visible param shadows the witness slot and the body reads
			// the witness pointer when it intends to read its first argument.
			if interfaceTypeIsFat(selfMaxonType) 'expandSelfWitness'
				_ = scope.declare("__witness___self", varType: MaxonType.integer, mutable: true)
			end 'expandSelfWitness'
		end 'addSelfParam'

		try parseFunctionParameters(paramCount, paramTypes: paramTypes, paramNames: paramNames, paramDefaults: paramDefaults)
		try expect(TokenKind.rightParen)
		// Stage E (closures): build the ABI-level paramTypes array by
		// inserting an i64 env-pointer slot after every function-typed
		// param. `paramTypes` / `paramNames` / `paramDefaults` stay at
		// the user-facing count so FuncSignature drives slot-fill +
		// default insertion against the declared shape; `abiParamTypes`
		// lands on `IrFunction.maxonParamTypes` and gives Std lowering
		// the expanded ABI shape. parseFunctionParameters already
		// allocated the env slot in `scope`, so slot ids here naturally
		// align with `abiParamTypes` indexing.
		var abiParamTypes = MaxonTypeArray.create()
		for i in 0 upto paramTypes.count() 'expandAbi'
			let pt = try paramTypes.get(i) otherwise panic("parseFunction: paramTypes.get OOB at {i} during ABI expansion")
			abiParamTypes.push(pt)
			if isFunctionMaxonType(pt) 'addEnv'
				abiParamTypes.push(MaxonType.integer)
			end 'addEnv'
			// C1.d: an interface-typed param is a fat pointer (value,
			// witness) — append the witness slot after the value slot so
			// the Std-level paramCount and ABI vector both grow in
			// lockstep. The matching parser scope slot for the witness is
			// declared in parseFunctionParameters via a synthetic
			// `__witness_<paramName>` so the witness slot has a stable
			// VarSlot id that lowering can resolve via interfaceWitnessSlots.
			if interfaceTypeIsFat(pt) 'addWitnessSlot'
				abiParamTypes.push(MaxonType.integer)
			end 'addWitnessSlot'
		end 'expandAbi'
		let abiParamCount = abiParamTypes.count() as ParamCount

		let returnType = try parseOptionalReturnType()
		// Capture the void-ness up front so we can release the `returnType`
		// borrow before calling into parseStatements (which mutates self.cursor).
		let returnIsVoid = maxonReturnTypeIsVoid(returnType)

		let throwsTypeName = try parseThrowsClause()

		// Phase 11.0: optional function-level `where T is Trait` clause. We
		// parse and discard for now — function-level constraint enforcement
		// is Phase 11 step 5's job and Array.maxon doesn't carry any
		// function-level `where` clauses (its `where`s all live on
		// `extension` declarations). Parsing here keeps any future
		// generic-function header round-tripping through this path without a
		// special-case parser branch.
		_ = try parseWhereClause()

		// Tolerate EOF here so a truncated source (e.g. `function main()` with no
		// body) reaches the missing-`end` diagnostic via skipEndAndLabel below
		// instead of throwing through to queryParseOps' generic EOF fallback.
		_ = skipOptionalNewlines()

		var func = IrFunction.create(qualifiedName, maxonReturnType: returnType, paramCount: abiParamCount, maxonParamTypes: abiParamTypes, returnLine: 0, throwsTypeName: throwsTypeName)
		// Carry the source-file namespace forward so LowerMaxonToStd can
		// resolve `CallContext.free` callees against `{namespace}.callee`
		// even when the function's own name is bare (e.g. main entrypoint).
		func.namespace = namespace
		// Stamp visibility + declaring file so cross-file call resolution
		// can filter via `isVisibleFrom` against the reader's path.
		func.visibility = visibility
		func.sourceFilePath = filePath
		// Record the name token position for function-level diagnostics
		// (e.g. E3054 main-cannot-throw) that need the declaration site.
		func.nameLine = nameToken.line
		func.nameColumn = nameToken.column
		// Register return type so callers can determine result kind. Display
		// the bare name for free functions and the qualified name for methods
		// in duplicate diagnostics.
		//
		// Minimal first-param overload support: when the bare qualified name
		// is already taken, attempt to mangle both functions by their first
		// non-self parameter type. If the suffixes differ the two functions
		// coexist under mangled names and the bare name is recorded in
		// `project.overloadedNames` so call-site resolution can disambiguate.
		// Same suffixes still report E2001 — that's a real duplicate.
		var funcIsDuplicate = false
		var registrationName = qualifiedName
		try project.funcReturnTypes.insert(qualifiedName, value: returnType) otherwise 'dupFunc'
			let resolution = tryRegisterOverload(qualifiedName, paramTypes: paramTypes, paramNames: paramNames, hasSelf: isInstance, returnType: returnType)
			if resolution.isOverload 'isOverload'
				registrationName = resolution.mangledName
			end 'isOverload' else 'realDup'
				funcIsDuplicate = true
				if isMethod 'methodDisplay'
					reportDuplicateFunction(qualifiedName, nameToken: nameToken)
				end 'methodDisplay' else 'freeDisplay'
					reportDuplicateFunction(nameToken.value, nameToken: nameToken)
				end 'freeDisplay'
			end 'realDup'
		end 'dupFunc'
		// Stamp the (possibly-mangled) registration name onto the IrFunction
		// so downstream passes (LowerMaxonToStd, codegen) emit the function
		// under the same key the call-site lookup hits.
		func.name = registrationName
		// Register signature for call-site named-arg reordering and defaults.
		// Skip on duplicate — funcReturnTypes.insert already reported it and
		// the first signature entry wins. Also seed the method-name index so
		// DFE can dispatch dynamic methodCalls in O(matches) instead of
		// scanning the full function table. Also stamp the function-visibility
		// sidecar so call-site qualification can filter cross-namespace
		// candidates by the reader's path.
		if not funcIsDuplicate 'registerSignature'
			try project.funcSignatures.insert(registrationName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise panic("funcSignatures.insert: duplicate for '{registrationName}' but funcReturnTypes reported none")
			project.methodNameIndex.record(registrationName)
			try project.funcVisibilities.insert(registrationName, value: FuncVisibilityInfo.create(visibility, sourceFilePath: filePath)) otherwise ignore
			// Register the throws-clause type name (empty string = non-throwing).
			try project.funcThrowsTypes.insert(registrationName, value: throwsTypeName) otherwise ignore
		end 'registerSignature'
		var block = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: nameToken.line)
		// Seed the parser's current-function/block tracker — expression-level
		// short-circuit emission appends new blocks to currentFunc and updates
		// currentBlock so subsequent emissions land in the right place.
		currentFunc = func
		currentBlock = block

		// For instance methods, register each field as a self-field alias.
		// Reads/writes lower directly to fieldLoad/fieldStore through __self,
		// not to a local slot — so a nested call that mutates self.field sees
		// the new value on return (and the caller sees callee's mutations).
		if isInstance 'emitFieldAccess'
			for field in fields 'eachField'
				_ = scope.declareSelfField(field.name, varType: field.fieldType, offset: field.offset)
			end 'eachField'
		end 'emitFieldAccess'

		// Parse body
		var bodyReturns = false
		block = try parseStatements(func, block: block, lastWasReturn: bodyReturns)

		// Body aborted on an unexpected statement token — the parser has already
		// synchronized past this function. Suppress the missing-return cascade and
		// don't attempt to consume a closing `end`: it belongs to a top-level
		// construct that the outer loop will re-dispatch. The partial function
		// body is dropped: an error was already reported so no binary will be
		// produced, and registering it risks downstream passes tripping over
		// unterminated blocks.
		if abortBody 'aborted'
			// Keep abortBody=true so parseModule's compensating-advance logic
			// knows cursor is already parked at the next top-level opener.
			return
		end 'aborted'

		// Capture the body's line range so the deferred unused-var consumer
		// can decide whether a primary diagnostic landed inside this function.
		// `previousToken()` points at the last consumed body token (typically
		// the trailing newline before `end`), so its line is a tight upper
		// bound. `nameToken.line` is the lower bound — params declared on the
		// header line still fall inside this range.
		checkUnusedParameters(methodName: nameToken.value, isMethod: isMethod, startLine: nameToken.line, endLine: previousToken().line)

		// Functions with a declared return type must terminate on every path —
		// report E3013 rather than silently falling through to an implicit 0.
		// Skip 'end' and optional label string FIRST so a truncated function
		// body surfaces "Expected 'end'" before the inline missing-return
		// check. The first-error gate at reportCompileError then suppresses
		// the missing-return as a cascade artifact, matching C#'s "first
		// parse error wins" output.
		try skipEndAndLabel()

		// Dead blocks are unreachable (isTerminated returns true) so they
		// trigger neither the implicit return nor the missing-return error.
		// Self-fields are aliased directly to __self so there is no writeback
		// phase: every field mutation already went through fieldStore.
		if not block.isTerminated() 'needsImplicitRet'
			if returnIsVoid 'emitVoid'
				emitImplicitReturn(block)
			end 'emitVoid' else 'reportMissing'
				reportCompileError(project, code: ErrorCode.semanticMissingReturn, message: "missing return statement: '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'reportMissing'
		end 'needsImplicitRet'

		// Hand the parser's per-function scope state off to the IrFunction so
		// it persists for downstream consumers. Today this is inspection-only;
		// later commits add the name-resolution query on top.
		func.scope = scope
		module.functions.push(func)
		// cursor AT end/label — exit AT last-consumed.
	end 'parseFunction'

	// --- Statement parsing ---

	// Record a statement's starting line against the block it will append to.
	// Looks up the flat blockRef within the current function's block set and
	// delegates to recordBlockLine for the de-dup-against-last append. When
	// the block is a detached dead sink (not in func.blockRefs) the findBlockRef
	// lookup throws and we silently drop the record — unreachable statements
	// don't contribute to coverage.
	function recordStmtLine(func IrFunction, block IrBlock, line LineNumber)
		let blockRef = try module.findBlockRef(func, block: block) otherwise return
		recordBlockLine(module.blockSourceInfo, blockRef: blockRef, line: line)
	end 'recordStmtLine'

	// Parse statements until 'end' is reached. Returns the current block.
	// Sets lastWasReturn to true if the last statement was a return.
	function parseStatements(func IrFunction, block IrBlock, lastWasReturn bool) returns IrBlock throws ParserError
		lastWasReturn = false

		// Stream-style dispatch: each helper exits past its last-consumed token.
		while skipOptionalNewlines() 'body'
			let stmtPrevPos = cursor.index()
			let stmtToken = cursor.current()
			if stmtToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'

			lastWasReturn = false

			// Keep the parser's currentBlock tracker pointed at the block
			// statement-level helpers should emit into. Expression-internal
			// short-circuit emission may move it forward; we re-seed before
			// each statement so the new block is the entry block for that
			// statement's emissions.
			currentBlock = block
			recordStmtLine(func, block: block, line: stmtToken.line)

			if stmtToken.kind == TokenKind.return 'isReturn'
				if func.returnLine == 0 'noRetLine'
					func.returnLine = stmtToken.line
				end 'noRetLine'
				try parseReturnStatement(block)
				lastWasReturn = true
			end 'isReturn' else if stmtToken.kind == TokenKind.var or stmtToken.kind == TokenKind.let 'isVarDecl'
				try parseVarDecl(block)
				block = currentBlock
			end 'isVarDecl' else if stmtToken.kind == TokenKind.panic 'isPanic'
				try parsePanicStatement(block)
				lastWasReturn = true
			end 'isPanic' else if stmtToken.kind == TokenKind.throw 'isThrow'
				try parseThrowStatement(block)
				lastWasReturn = true
			end 'isThrow' else if stmtToken.kind == TokenKind.try 'isTryStmt'
				// Statement-form `try EXPR [otherwise FALLBACK]` — reuse the
				// expression-level parser and discard its result. The success
				// path leaves currentBlock pointing at the continue/merge
				// block, so flow continues from there. lastWasReturn stays
				// false because the success path always falls through.
				_ = try parseTryExpression(block, isStatementContext: true)
				block = currentBlock
			end 'isTryStmt' else if stmtToken.kind == TokenKind.if 'isIf'
				block = try parseIfStatement(func, block: block)
			end 'isIf' else if stmtToken.kind == TokenKind.while 'isWhile'
				block = try parseWhileStatement(func, block: block)
			end 'isWhile' else if stmtToken.kind == TokenKind.for 'isFor'
				block = try parseForStatement(func, block: block)
			end 'isFor' else if stmtToken.kind == TokenKind.match 'isMatchStmt'
				block = try parseMatchStatement(block)
			end 'isMatchStmt' else if stmtToken.kind == TokenKind.break 'isBreak'
				block = try parseBreakStatement(func, block: block)
				lastWasReturn = true
			end 'isBreak' else if stmtToken.kind == TokenKind.continue 'isContinue'
				block = try parseContinueStatement(func, block: block)
				lastWasReturn = true
			end 'isContinue' else if stmtToken.kind == TokenKind.identifier 'isIdent'
				try parseIdentifierStatement(block)
				block = currentBlock
			end 'isIdent' else if stmtToken.kind == TokenKind.self 'isSelfStmt'
				try parseSelfStatement(block)
				block = currentBlock
			end 'isSelfStmt' else 'unexpectedToken'
				reportUnexpectedToken()
			end 'unexpectedToken'

			// abortBody (from reportUnexpectedToken) means synchronizeToTopLevel
			// already parked cursor at next top-level opener; break so the
			// outer parseFunction can re-dispatch it.
			if abortBody 'aborted'
				break
			end 'aborted'

			// Stuck-guard: if cursor didn't advance, force advance to prevent
			// infinite loops on malformed input.
			if cursor.index() <= stmtPrevPos 'stmtStuck'
				try cursor.advance() otherwise break
			end 'stmtStuck'
		end 'body'

		return block
	end 'parseStatements'

	// --- Identifier statement dispatch ---

	// Dispatches an identifier at statement level: assignment, function call, or error.
	function parseIdentifierStatement(block IrBlock) throws ParserError
		let peekToken = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
		if cursor.current().value == "_" and peekToken.kind == TokenKind.equals 'isDiscard'
			try parseDiscardAssignment(block)
			return
		end 'isDiscard' else if peekToken.kind == TokenKind.equals 'isAssign'
			try parseVarAssignment(block)
			return
		end 'isAssign' else if peekToken.kind == TokenKind.leftParen 'isCall'
			// Statement-level function call — parse as expression, discard result
			_ = try parseExpression(block)
			return
		end 'isCall' else if peekToken.kind == TokenKind.dot 'maybeDotCall'
			// Distinguish field-assignment shapes from expression-path uses
			// (method calls, field reads):
			//   localVar.field(.field)* = expr → fieldStore on the loaded local
			//                                     (zero-or-more chained loads)
			//   TypeName.field = expr          → qualified-global store (TypeResolution
			//                                     rewrites to globalStore once
			//                                     `project.topLevelVars` is populated)
			//   anything else with a dot       → method call / field read on the
			//                                     expression path
			// The local-var case must come first so a local `newState` shadows
			// any global / type with the same leading name.
			let chainLen = chainedFieldAssignDepth()
			if chainLen >= 1 'isFieldAssign'
				let receiverName = cursor.current().value
				if scope.contains(receiverName) 'leadingIsLocal'
					try parseLocalFieldAssignment(block, chainLen: chainLen)
					return
				end 'leadingIsLocal'
				if chainLen == 1 'singleDot'
					let afterDot = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
					let qualifiedName = "{receiverName}.{afterDot.value}"
					try parseGlobalAssignment(block, qualifiedName: qualifiedName)
					return
				end 'singleDot'
				// `globalVar.field1.field2(.fieldN)* = expr` where `globalVar`
				// is a registered top-level var holding a struct. Mirrors
				// parseLocalFieldAssignment but seeds the chain from an
				// unresolvedRead — TypeResolution rewrites that to a globalLoad
				// once the project's topLevelVars registry is populated.
				try parseGlobalChainedFieldAssignment(block, chainLen: chainLen)
				return
			end 'isFieldAssign'
			// Dot call: variable.method(args) or Type.staticMethod(args) or field access
			_ = try parseExpression(block)
			return
		end 'maybeDotCall'

		reportUnexpectedToken()
	end 'parseIdentifierStatement'

	// Parse a statement starting with `self`: either `self.field = expr` (field
	// assignment) or any other `self.…` expression (method call, field read used
	// for its side effect). Cursor is AT `self` on entry.
	function parseSelfStatement(block IrBlock) throws ParserError
		let selfToken = cursor.current()
		if reportSelfOutsideType(selfToken) 'notInType'
			return
		end 'notInType'

		if not atOffset(TokenKind.dot, offset: 1) 'notDot'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '.' after 'self'", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return
		end 'notDot'

		let fieldTok = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
		let afterField = try cursor.peek(3) otherwise throw ParserError.unexpectedEof

		if fieldTok.kind == TokenKind.identifier and afterField.kind == TokenKind.equals 'isSelfFieldAssign'
			let fieldName = fieldTok.value
			// Field-existence validation is deferred to TypeResolution so the
			// parser stays pure-record. TypeResolution walks every
			// selfFieldStore op against the now-fully-resolved struct layout
			// and surfaces the "Unknown field" diagnostic at the recorded
			// source range when a field doesn't exist on the enclosing type.

			// peeks above proved the self-dot-identifier-equals shape.
			try eat(TokenKind.self)
			try eat(TokenKind.dot)
			try eat(TokenKind.identifier)
			try eat(TokenKind.equals)

			currentBlock = block
			let exprResult = try parseExpression(block)
			var emitBlock = currentBlock
			let stmtRange = SourceRange.between(selfToken, last: previousToken())
			emitSelfFieldStore(emitBlock, fieldName: fieldName, valueName: exprName(exprResult), range: stmtRange)
			return
		end 'isSelfFieldAssign'

		_ = try parseExpression(block)
	end 'parseSelfStatement'

	// Returns the number of `.identifier` segments after the leading
	// identifier when the cursor sits at an `identifier(.identifier)+ =`
	// pattern. Returns 0 if the pattern does not match. The leading-
	// identifier-is-local check is the caller's responsibility — that
	// distinction decides between a local-var fieldStore and a qualified-
	// global store.
	function chainedFieldAssignDepth() returns FieldChainDepth
		var depth = 0 as FieldChainDepth
		var offset = 1 as ChainPeekOffset
		while true 'count'
			let dotTok = try cursor.peek(offset) otherwise return 0 as FieldChainDepth
			if dotTok.kind != TokenKind.dot 'notDot'
				break
			end 'notDot'
			let fieldTok = try cursor.peek(offset + 1) otherwise return 0 as FieldChainDepth
			// Phase 15e: `t.0 = 20` is a tuple-positional store; accept both
			// identifier and intLiteral here so the dispatch below routes
			// `t.0 = ...` through parseLocalFieldAssignment.
			if fieldTok.kind != TokenKind.identifier and fieldTok.kind != TokenKind.intLiteral 'notId'
				return 0 as FieldChainDepth
			end 'notId'
			depth = depth + 1
			offset = offset + 2
		end 'count'
		if depth == 0 'noDots'
			return 0 as FieldChainDepth
		end 'noDots'
		let trailing = try cursor.peek(offset) otherwise return 0 as FieldChainDepth
		if trailing.kind != TokenKind.equals 'notAssign'
			return 0 as FieldChainDepth
		end 'notAssign'
		return depth
	end 'chainedFieldAssignDepth'

	// Parse `localVar.field1(.fieldN)* = <expr>` where `localVar` is in
	// scope. Lowers to: varLoad(localVar) → fieldLoad(field1) → … →
	// fieldStore(lastField, value: rhs). Each intermediate fieldLoad's
	// result becomes the receiver of the next op, so a `.value =` write
	// flows down the same load path a read would synthesize. The single-
	// field case (`x.f = …`, chainLen == 1) emits varLoad + fieldStore
	// with no intermediate loads. TypeResolution / lowering perform the
	// per-field validation (existence, mutability) on each emitted op.
	function parseLocalFieldAssignment(block IrBlock, chainLen FieldChainDepth) throws ParserError
		let nameToken = try consume()
		let slot = lookupVariable(nameToken.value, token: nameToken)
		let nameRange = SourceRange.ofToken(nameToken)
		var receiverName = freshSynthName()
		module.appendOp(block, op: MaxonOp.varLoad(receiverName, slotId: slot, slotType: MaxonType.unresolved, range: nameRange))

		// Walk the first chainLen-1 dots as field reads to materialize the
		// innermost struct receiver, leaving the final dot for the store.
		for _ in 0 upto chainLen - 1 'eachLoad'
			try eat(TokenKind.dot)
			let fieldTok = try consume()
			let nextReceiver = freshSynthName()
			let loadRange = SourceRange.ofToken(fieldTok)
			module.appendOp(block, op: MaxonOp.fieldLoad(nextReceiver, receiver: receiverName, fieldName: computeFieldNameForMemberToken(fieldTok).toByteArray(), range: loadRange))
			receiverName = nextReceiver
		end 'eachLoad'

		try eat(TokenKind.dot)
		let lastFieldTok = try consume()
		try eat(TokenKind.equals)

		currentBlock = block
		let exprResult = try parseExpression(block)
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: previousToken())
		module.appendOp(emitBlock, op: MaxonOp.fieldStore(receiverName, fieldName: computeFieldNameForMemberToken(lastFieldTok).toByteArray(), value: exprName(exprResult), isInit: false, range: stmtRange))
	end 'parseLocalFieldAssignment'

	// Parse `globalVar.field1.field2(.fieldN)* = <expr>` where `globalVar`
	// is a (yet-to-be-resolved) top-level var. Lowers to: unresolvedRead
	// globalVar → fieldLoad field1 → … → fieldStore lastField. The leading
	// unresolvedRead is rewritten to globalLoad by TypeResolution once
	// `project.topLevelVars` is fully populated; if the receiver doesn't
	// resolve, the same pass surfaces the standard "Undefined variable"
	// diagnostic against that op. `chainLen` is the number of dot-segments
	// after the leading global (≥2 — chainLen == 1 goes through
	// parseGlobalAssignment, which emits a single qualifiedName
	// unresolvedAssign).
	function parseGlobalChainedFieldAssignment(block IrBlock, chainLen FieldChainDepth) throws ParserError
		let nameToken = try consume()
		let nameRange = SourceRange.ofToken(nameToken)
		var receiverName = freshSynthName()
		module.appendOp(block, op: MaxonOp.unresolvedRead(receiverName, name: nameToken.value, range: nameRange))

		// Walk the first chainLen-1 dots as field reads to materialize the
		// innermost struct receiver, leaving the final dot for the store.
		for _ in 0 upto chainLen - 1 'eachLoad'
			try eat(TokenKind.dot)
			let fieldTok = try consume()
			let nextReceiver = freshSynthName()
			let loadRange = SourceRange.ofToken(fieldTok)
			module.appendOp(block, op: MaxonOp.fieldLoad(nextReceiver, receiver: receiverName, fieldName: computeFieldNameForMemberToken(fieldTok).toByteArray(), range: loadRange))
			receiverName = nextReceiver
		end 'eachLoad'

		try eat(TokenKind.dot)
		let lastFieldTok = try consume()
		try eat(TokenKind.equals)

		currentBlock = block
		let exprResult = try parseExpression(block)
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: previousToken())
		module.appendOp(emitBlock, op: MaxonOp.fieldStore(receiverName, fieldName: computeFieldNameForMemberToken(lastFieldTok).toByteArray(), value: exprName(exprResult), isInit: false, range: stmtRange))
	end 'parseGlobalChainedFieldAssignment'

	// Parse `TypeName.fieldName = <expr>`. The store target is emitted as
	// an `unresolvedAssign` op carrying the qualified name; TypeResolution
	// rewrites it to `globalStore` once `project.topLevelVars` is known to be
	// fully populated. Caller has proven identifier-dot-identifier-equals
	// via peeks.
	function parseGlobalAssignment(block IrBlock, qualifiedName String) throws ParserError
		let nameToken = cursor.current()
		try eat(TokenKind.identifier)
		try eat(TokenKind.dot)
		try eat(TokenKind.identifier)
		try eat(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(block)
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: previousToken())
		module.appendOp(emitBlock, op: MaxonOp.unresolvedAssign(qualifiedName, value: exprName(exprResult), range: stmtRange))
	end 'parseGlobalAssignment'

	// Reports an unexpected statement-level token and aborts the enclosing function
	// body. Mirrors the C# bootstrap's throw-to-top-level behavior: one error is
	// reported and recovery skips to the next top-level declaration. Continuing
	// inside the body would consume a stray `end 'label'` meant for an outer
	// construct and cascade into E3013 (missing return) at the real `end`.
	function reportUnexpectedToken()
		let stmtToken = cursor.current()
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token: '{tokenValueToString(stmtToken.value)}'", line: stmtToken.line, column: stmtToken.column, filePath: filePath)
		abortBody = true
		synchronizeToTopLevel()
	end 'reportUnexpectedToken'

	function reportUnexpectedTopLevel(token Token) returns MaxonModule
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected function declaration, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		return module
	end 'reportUnexpectedTopLevel'

	// Called from parseModule's propagate handler for ParserError.unhandledToken.
	// If no diagnostics were added during the dispatch, emits the generic
	// "Expected function declaration" error. If diagnostics were already added
	// (e.g. E3059 thrown from a void-try-in-assignment check), skips the
	// redundant error — the real one was already recorded.
	function handleTopLevelUnhandledToken(token Token, diagCountBefore ElementCount) returns MaxonModule
		if project.diagnostics.count() == diagCountBefore 'noDiag'
			return reportUnexpectedTopLevel(token)
		end 'noDiag'
		return module
	end 'handleTopLevelUnhandledToken'

	// Reports a duplicate top-level constant declaration at the given name token.
	function reportDuplicateConstant(nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateConstant'

	// Reports a duplicate function/method declaration. Callers pass the display
	// name separately because free functions use the bare name while methods
	// use the type-qualified name.
	function reportDuplicateFunction(displayName String, nameToken Token)
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate function '{displayName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
	end 'reportDuplicateFunction'

	// Try to register the current function as a first-param overload of an
	// already-registered function with the same qualified name. Called from
	// parseFunction's collision branch (when funcReturnTypes.insert reported
	// a duplicate). Returns:
	//   - isOverload=true,  mangledName=<new function's mangled name> — the
	//     existing function has been re-keyed under its own mangled form,
	//     `overloadedNames` has been updated, and the caller should register
	//     the new function under `mangledName`.
	//   - isOverload=false, mangledName="" — the two signatures share the
	//     same first-param suffix (a real duplicate). The caller emits E2001.
	//
	// `paramTypes` is the new function's full param list including __self
	// when isInstance; `hasSelf` controls the slot-0 skip when computing the
	// first-param suffix.
	function tryRegisterOverload(qualifiedName String, paramTypes MaxonTypeArray, paramNames StringArray, hasSelf bool, returnType MaxonReturnType) returns OverloadResolution
		var newSuffix = mangleSuffixForFirstParam(project, paramTypes: paramTypes, hasSelf: hasSelf)
		// Existing function's first-param type comes from its registered
		// FuncSignature. If we don't find one, we can't compute its suffix
		// and must fall back to the duplicate diagnostic.
		let existingSig = try project.funcSignatures.get(qualifiedName) otherwise return OverloadResolution.duplicate()
		let existingHasSelf = signatureFirstParamIsSelf(existingSig)
		var existingSuffix = mangleSuffixForFirstParam(project, paramTypes: existingSig.paramTypes, hasSelf: existingHasSelf)
		// Type-only suffix collides → fall back to name-based suffix. This
		// is the path the spec's `slice(start, endIndex)` vs `slice(start,
		// length)` case takes — same `$Integer$Integer` types, different
		// param names, distinguished at call sites by labels. If the
		// name-based suffix also collides, the two are a real duplicate.
		if existingSuffix == newSuffix 'sameTypeSuffix'
			let nameNew = mangleSuffixForParamNames(paramNames, hasSelf: hasSelf)
			let nameExisting = mangleSuffixForParamNames(existingSig.paramNames, hasSelf: existingHasSelf)
			if nameNew == nameExisting 'sameNameSuffix'
				return OverloadResolution.duplicate()
			end 'sameNameSuffix'
			newSuffix = nameNew
			existingSuffix = nameExisting
		end 'sameTypeSuffix'
		let existingMangled = "{qualifiedName}{existingSuffix}"
		let newMangled = "{qualifiedName}{newSuffix}"
		// Re-key the existing entry under its mangled form. We compute the
		// re-keyed values BEFORE removing so a missing intermediate (e.g. a
		// stdlib-restored function with no funcVisibilities entry) doesn't
		// strand the bare name.
		rekeyExistingFunction(qualifiedName, mangledName: existingMangled)
		// Register the bare-name overload bucket. Both names go in so a
		// future third overload can extend the same bucket.
		var bucket = try project.overloadedNames.get(qualifiedName) otherwise QualifiedNameArray.create()
		if bucket.count() == 0 'fresh'
			bucket.push(existingMangled)
		end 'fresh'
		bucket.push(newMangled)
		project.overloadedNames.upsert(qualifiedName, value: bucket)
		// Insert the new function's funcReturnTypes entry under its mangled
		// name; the caller handles funcSignatures / funcVisibilities /
		// funcThrowsTypes / methodNameIndex inserts under `registrationName`.
		try project.funcReturnTypes.insert(newMangled, value: returnType) otherwise panic("tryRegisterOverload: funcReturnTypes.insert collision on freshly-mangled name '{newMangled}'")
		return OverloadResolution.overload(newMangled)
	end 'tryRegisterOverload'

	// Re-key an existing funcReturnTypes / funcSignatures / funcVisibilities /
	// funcThrowsTypes / IrFunction.name entry from `bareName` to `mangledName`.
	// methodNameIndex receives an additional bucket entry for `mangledName`;
	// the stale `bareName` entry is left in place because the bucket is an
	// Array (no remove API) — call-site lookups filter out stale entries
	// when funcReturnTypes.contains returns false.
	function rekeyExistingFunction(bareName String, mangledName String)
		if let rt = try project.funcReturnTypes.get(bareName) 'haveRt'
			try project.funcReturnTypes.insert(mangledName, value: rt) otherwise ignore
			_ = project.funcReturnTypes.remove(bareName)
		end 'haveRt'
		if let sig = try project.funcSignatures.get(bareName) 'haveSig'
			try project.funcSignatures.insert(mangledName, value: sig) otherwise ignore
			_ = project.funcSignatures.remove(bareName)
		end 'haveSig'
		if let vis = try project.funcVisibilities.get(bareName) 'haveVis'
			try project.funcVisibilities.insert(mangledName, value: vis) otherwise ignore
			_ = project.funcVisibilities.remove(bareName)
		end 'haveVis'
		if let th = try project.funcThrowsTypes.get(bareName) 'haveTh'
			try project.funcThrowsTypes.insert(mangledName, value: th) otherwise ignore
			_ = project.funcThrowsTypes.remove(bareName)
		end 'haveTh'
		project.methodNameIndex.record(mangledName)
		// Walk the current module's functions for an IrFunction whose .name
		// matches the bare key and rewrite it. Cross-file overloads aren't
		// supported in this minimal pass — the existing function is expected
		// to live in the same module being parsed (Array.maxon's two
		// `contains` overloads sit in one extension block, satisfying this).
		for i in 0 upto module.functions.count() 'eachFunc'
			var f = try module.functions.get(i) otherwise continue
			if f.name == bareName 'match'
				f.name = mangledName
				try module.functions.set(i, value: f) otherwise ignore
				return
			end 'match'
		end 'eachFunc'
	end 'rekeyExistingFunction'

	// Reports a literal-overflow error at `token` with the fully-formatted
	// `message`. Callers are responsible for any cursor advancement appropriate
	// to their context; pass the pre-formatted message so each site can keep
	// its exact wording (int vs float, with/without range suffix).
	function reportLiteralOverflow(token Token, message String)
		reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: message, line: token.line, column: token.column, filePath: filePath)
	end 'reportLiteralOverflow'

	// --- Top-level let / var ---

	// Parse a top-level binding:
	//   `let NAME = <expr>`                      (top-level)
	//   `var NAME = <expr>`                      (top-level)
	//   `static var NAME = <expr>`               (inside a type)
	// Captures the initializer as a structural `UnresolvedConstExpr` arena
	// tree and registers an `UnresolvedTopLevelDecl` entry; the
	// `resolveAllTopLevelDecls` pass in TypeResolution.maxon drains the
	// entry into `topLevelConstants` (immutable lets) or `topLevelVars`
	// (mutable vars) once enums and typealiases have themselves been
	// resolved, so identifier / enum-case / `as`-cast references fold
	// without parser-time peeks into project state.
	//
	// `let` and `var` accept the same initializer shapes — the only
	// effect of `mutable` is which destination the resolved value lands
	// in, and (downstream) whether reassignment to the binding is
	// rejected with E2013.
	//
	// `typeName` qualifies the binding with its enclosing type for static
	// fields (`Counter.count`); it's empty for top-level decls.
	//
	// entry: cursor AT the token AFTER `let` / `var` — the binding name.
	// Caller (dispatchTopLevel / parseStaticVar) has already consumed the
	// keyword.
	function parseTopLevelDecl(typeName String, mutable bool, visibility Visibility) throws ParserError
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		try expect(TokenKind.equals)

		let valueToken = cursor.current()
		let qualifiedName = qualifyName(typeName, name: nameToken.value)

		// String literal initializer (`let GREETING = "hello"`,
		// `var msg = "hi"`). Captured as a `stringLit` arena node.
		if valueToken.kind == TokenKind.stringLiteral 'isString'
			try parseTopLevelStringDecl(nameToken, qualifiedName: qualifiedName, valueToken: valueToken, mutable: mutable, visibility: visibility)
			return
		end 'isString'

		// Single-quote strings are never valid as top-level initializers.
		if valueToken.kind == TokenKind.charLiteral 'isSingleQuoteString'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected constant expression, got '{valueToken.value}'", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'isSingleQuoteString'

		if rejectCallInitializer(valueToken) 'wasCall'
			return
		end 'wasCall'

		// `NAME = TypeName.method(...)` — runtime-init struct factory call.
		// Materialize the call in a synthetic `__module_init_<n>` function
		// (lazily allocated on first use) and reserve a writable .data slot
		// for the call result, mirroring the array-literal path. `mrt_start`
		// invokes every `__module_init_<n>` before `main`, so the slot holds
		// the factory result by the time user code reads it. Both `let` and
		// `var` accept this shape — the entry lands in `topLevelVars` so
		// cross-file `shared.field` reads resolve through `globalLoad` /
		// `globalStore` just like simple `export var counter = 10` does.
		if isRuntimeInitInitializer(valueToken) 'isMethodCall'
			try parseTopLevelRuntimeInitDecl(nameToken, qualifiedName: qualifiedName, mutable: mutable, visibility: visibility)
			return
		end 'isMethodCall'

		// `NAME = TypeName{field: ..., ...}` — deferred struct-literal
		// initializer. The self-hosted compiler doesn't yet evaluate struct
		// literals at compile time; we recognize the shape and skip past
		// the matching `}`, registering a placeholder so the binding exists
		// for name resolution. The static `let`s in `stdlib/CharacterSet`
		// (e.g. `static let cachedWhitespaces = CharacterSet{...}`) hit
		// this path. The unresolved value is harmless as long as nothing
		// reachable from `main` reads it; DCE drops unreferenced static
		// lets along with their owning type's unused methods.
		if isStructLiteralInitializer(valueToken) 'isStructLit'
			try skipPastStructLiteralInitializer()
			skipToNextLine()
			let placeholder = TopLevelConstant.create(ConstantValue.intValue(0), visibility: visibility, sourceFilePath: filePath)
			try project.topLevelConstants.insert(qualifiedName, value: placeholder) otherwise ignore
			logTrace(LogCategory.parser, message: () gives "parser: deferred struct-literal decl '{qualifiedName}' (no init emitted)")
			return
		end 'isStructLit'

		// `let xs = [1, 2, 3]` / `var xs = [...]` — array-literal initializer.
		// Materialize the literal at runtime in a synthetic per-file
		// `__module_init_<n>` function (lazily allocated on first use), and
		// reserve a writable .data slot for the array reference. `mrt_start`
		// invokes every `__module_init_<n>` before `main` so the slot holds
		// the literal's pointer by the time user code reads it.
		if valueToken.kind == TokenKind.leftBracket 'isArrayLit'
			try parseTopLevelArrayLiteralDecl(nameToken, qualifiedName: qualifiedName, mutable: mutable, visibility: visibility)
			return
		end 'isArrayLit'

		// Capture the initializer as a structural tree. Identifier
		// references become `nameRef` nodes resolved later by
		// `resolveAllTopLevelDecls`.
		let exprId = try parseConstExpr() otherwise 'notConst'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Top-level initializer must be a compile-time constant (int / float / bool / string / enum case / `as`-cast / let-ref)", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'notConst'

		registerUnresolvedTopLevelDecl(nameToken, qualifiedName: qualifiedName, rootExprId: exprId, mutable: mutable, visibility: visibility)
	end 'parseTopLevelDecl'

	// Handle the `<name> = "<string>"` shape. Lifted out so the EOF /
	// interpolation handling stays self-contained.
	function parseTopLevelStringDecl(nameToken Token, qualifiedName String, valueToken Token, mutable bool, visibility Visibility) throws ParserError
		// Step past the string literal. Tolerate EOF because `<name> = ""`
		// at end-of-file is a complete declaration.
		try cursor.advance() otherwise 'eofAfterString'
			logTrace(LogCategory.parser, message: () gives "parser: top-level string const at EOF")
		end 'eofAfterString'
		// Interpolations have no compile-time meaning at top level — the
		// operand names they'd reference don't exist yet. Reject
		// explicitly rather than silently dropping the interpolation.
		if at(TokenKind.stringInterpStart) 'hasInterp'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "top-level decl does not support string interpolation", line: valueToken.line, column: valueToken.column, filePath: filePath)
			synchronize()
			return
		end 'hasInterp'
		let strId = project.strings.intern(valueToken.value)
		let exprId = appendConstExpr(UnresolvedConstExpr.stringLit(strId))
		registerUnresolvedTopLevelDecl(nameToken, qualifiedName: qualifiedName, rootExprId: exprId, mutable: mutable, visibility: visibility)
		logTrace(LogCategory.parser, message: () gives "parser: const string '{qualifiedName}'")
	end 'parseTopLevelStringDecl'

	// Lazily allocate this file's synthetic `__module_init_<n>` function on
	// first use. Subsequent top-level array-literal decls in the same file
	// reuse the cached function and append into the same entry block.
	//
	// The init function is a 0-param void-returning IrFunction registered in
	// `project.moduleInitFuncs` (file-discovery order) and stamped onto
	// `project.livenessRoots` so DFE keeps it (and everything it transitively
	// calls — `__ManagedMemory.create`, `T.init`, etc.). `mrt_start` invokes
	// every entry in order before calling `main`;
	// the patch is applied during `augmentWithRuntime` after the runtime+user
	// modules have merged.
	function getOrCreateModuleInit() returns String
		if moduleInitName != "" 'cached'
			return moduleInitName
		end 'cached'
		let suffix = project.moduleInitFuncs.count() as ParsedInt
		let name = "__module_init_{suffix}"
		var func = IrFunction.create(name, maxonReturnType: MaxonReturnType.void, paramCount: 0, maxonParamTypes: MaxonTypeArray.create(), returnLine: 0)
		// Inits run from `mrt_start`, so they need `global` visibility — file
		// would force visibility filtering against the runtime's empty path.
		func.namespace = namespace
		func.visibility = Visibility.global
		func.sourceFilePath = filePath
		let block = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: 1)
		module.functions.push(func)
		project.moduleInitFuncs.push(name)
		project.livenessRoots.push(name)
		moduleInitName = name
		moduleInitFunc = func
		moduleInitBlock = block
		return name
	end 'getOrCreateModuleInit'

	// Top-level `let xs = [1, 2, 3]` / `var xs = [1, 2, 3]`. The literal's
	// `__ManagedMemory.create` + per-element `set` + `T.init(mm)` sequence is
	// emitted into the file's `__module_init_<n>` entry block, and the result
	// is stored into a writable .data slot via `globalStore`. The slot starts
	// life as 8 zero bytes (added by `registerGlobalVarsForDataSection`); the
	// init overwrites it with the array reference at startup time.
	//
	// Both `let` and `var` follow this path. The slot lives in
	// `topLevelVars` either way, but `let`-bound names are also recorded in
	// `project.immutableArrayLitNames` so `rewriteUnresolvedAssign` can keep
	// firing E2013 on subsequent source-level reassignments.
	//
	// Lifetime note: the array's refcount lands at 1 after `T.init`, ownership
	// transfers into the slot via `globalStore`, and there is no scope-end
	// drop in `__module_init_<n>` — so the array silently leaks at process
	// exit. The C# bootstrap has a separate `__maxon_global_cleanup` pass
	// which the self-hosted compiler does not yet emit; the affected spec
	// tests don't observe clean shutdown.
	function parseTopLevelArrayLiteralDecl(nameToken Token, qualifiedName String, mutable bool, visibility Visibility) throws ParserError
		let firstToken = cursor.current()
		let result = try parseInModuleInitContext(parseArrayLiteral: true)
		finalizeTopLevelInitDecl(nameToken, qualifiedName: qualifiedName, mutable: mutable, visibility: visibility, result: result, firstToken: firstToken, kindLabel: "array literal")
	end 'parseTopLevelArrayLiteralDecl'

	// Top-level `let/var <name> = TypeName.method(...)`. Parses the full call
	// expression (which may include named/positional arguments and nested
	// expressions) inside the file's lazy `__module_init_<n>` function and
	// reserves a writable .data slot for the call result so cross-file reads
	// of `<name>.field` resolve through `globalLoad` / `globalStore` the same
	// way as a plain `export var counter = 10`.
	function parseTopLevelRuntimeInitDecl(nameToken Token, qualifiedName String, mutable bool, visibility Visibility) throws ParserError
		let firstToken = cursor.current()
		let result = try parseInModuleInitContext(parseArrayLiteral: false)
		finalizeTopLevelInitDecl(nameToken, qualifiedName: qualifiedName, mutable: mutable, visibility: visibility, result: result, firstToken: firstToken, kindLabel: "runtime-init")
	end 'parseTopLevelRuntimeInitDecl'

	// Parse an initializer expression into the file's `__module_init_<n>`
	// block. Allocates the init function on first call, then swaps
	// `synthNameCounter` and `currentFunc` so synthesized value names land in
	// the init function's namespace — the `arrayLiteralProducers` map keys
	// off `currentFunc.name`, so without the swap a literal here would miss
	// the TypeResolution read site. Restores both on the way out.
	function parseInModuleInitContext(parseArrayLiteral bool) returns ExprResult throws ParserError
		_ = getOrCreateModuleInit()
		let savedSynth = synthNameCounter
		synthNameCounter = moduleInitSynthCounter
		let savedFunc = currentFunc
		currentFunc = moduleInitFunc
		var result = ExprResult.direct(ByteArray.create(), valueType: MaxonType.unresolved)
		if parseArrayLiteral 'kind'
			result = try parseArrayLiteralExpr(moduleInitBlock)
		end 'kind' else 'general'
			result = try parseExpression(moduleInitBlock)
		end 'general'
		currentFunc = savedFunc
		moduleInitSynthCounter = synthNameCounter
		synthNameCounter = savedSynth
		return result
	end 'parseInModuleInitContext'

	// Common tail for both top-level init paths: emit the `globalStore`,
	// register the `topLevelVars` entry, and gate `let`-bound names through
	// `immutableArrayLitNames` so `rewriteUnresolvedAssign` can keep firing
	// E2013 on subsequent source-level reassignments.
	//
	// Slot type is `MaxonType.unresolved` at parse time; TypeResolution's
	// `fillUnresolvedTypes` pass rewrites the globalStore op once the
	// initializer's result type is known and a follow-up walk backfills
	// `topLevelVars[name].slotType` so user reads carry the concrete type.
	//
	// Lifetime note: ownership transfers from the init's local refcount into
	// the slot via `globalStore` and there is no scope-end drop in
	// `__module_init_<n>` — heap-allocated initializers silently leak at
	// process exit. The C# bootstrap has a separate `__maxon_global_cleanup`
	// pass which the self-hosted compiler does not yet emit; the affected
	// spec tests don't observe clean shutdown.
	function finalizeTopLevelInitDecl(nameToken Token, qualifiedName String, mutable bool, visibility Visibility, result ExprResult, firstToken Token, kindLabel String)
		let initRange = SourceRange.between(firstToken, last: previousToken())

		if project.topLevelConstants.contains(qualifiedName) or project.topLevelVars.contains(qualifiedName) 'dupResolved'
			reportDuplicateConstant(nameToken)
			return
		end 'dupResolved'

		module.appendOp(moduleInitBlock, op: MaxonOp.globalStore(qualifiedName, value: exprName(result), slotType: exprType(result), range: initRange))

		let info = TopLevelVarInfo.create(qualifiedName, slotType: exprType(result), initialValue: 0 as IntConstant, visibility: visibility, sourceFilePath: filePath)
		try project.topLevelVars.insert(qualifiedName, value: info) otherwise 'dupVar'
			reportDuplicateConstant(nameToken)
		end 'dupVar'

		if not mutable 'isLet'
			project.immutableArrayLitNames.push(qualifiedName)
		end 'isLet'

		logTrace(LogCategory.parser, message: () gives "parser: top-level {kindLabel} '{qualifiedName}' → {moduleInitName}")
	end 'finalizeTopLevelInitDecl'

	// Close out this file's synthetic `__module_init_<n>` function once the
	// top-level parse loop terminates. A null-op when the parser never saw a
	// top-level array literal — `moduleInitName` stays "" and there is no
	// dangling unterminated block.
	function finalizeModuleInit()
		if moduleInitName == "" 'noInit'
			return
		end 'noInit'
		// Void return: emit a constant-zero literal (mirrors emitImplicitReturn).
		// Same synth-counter swap as the literal-emit path: the zero literal
		// would otherwise collide with names already minted in this init.
		let savedSynth = synthNameCounter
		synthNameCounter = moduleInitSynthCounter
		let zeroName = emitLiteral(moduleInitBlock, value: 0, valueType: MaxonType.integer)
		moduleInitSynthCounter = synthNameCounter
		synthNameCounter = savedSynth
		module.setTerminator(moduleInitBlock, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	end 'finalizeModuleInit'

	// Phase 11.x: parse a field default-value expression (`var f T = expr`)
	// into a synthetic helper function. The helper is registered as
	// `<TypeName>.__field_init_<fieldName>` so `enclosingTypeName` resolves
	// it back to the enclosing struct — this in turn makes
	// `functionIsGenericForLowering` / `functionHasWhereClausesForLowering`
	// see the enclosing generic params and inject the same implicit
	// layout / witness trailing slots the rest of the type's methods get.
	//
	// The cursor must be positioned at the first token of the default
	// expression on entry; exits with the cursor on the token AFTER the
	// expression (typically the trailing newline).
	function parseFieldDefaultInitHelper(typeName String, fieldName String, fieldType MaxonType, fieldLine LineNumber) throws ParserError
		let helperName = "{typeName}.__field_init_{fieldName}"
		let returnType = MaxonReturnType.value(fieldType)
		var helperFunc = IrFunction.create(helperName, maxonReturnType: returnType, paramCount: 0, maxonParamTypes: MaxonTypeArray.create(), returnLine: fieldLine)
		helperFunc.namespace = namespace
		// Stay file-private — these helpers are only ever called from
		// struct-literal lowerings inside the declaring file's compilation
		// unit. Cross-file users of the struct go through their own copy of
		// the lowerer, which synthesizes a parallel call.
		helperFunc.visibility = Visibility.file
		helperFunc.sourceFilePath = filePath
		helperFunc.nameLine = fieldLine
		helperFunc.nameColumn = 1
		let helperBlock = module.addBlockAt(helperFunc, label: "entry", filePath: filePath.toString(), firstLine: fieldLine)

		// Swap parser state into the helper. The synth-name counter is
		// per-function so we save and restore it the same way
		// `parseInModuleInitContext` does — without this, names minted by
		// the default-expression parse would collide with the outer
		// function (which currently doesn't exist, but the same counter
		// gets reused by subsequent helpers in the same type body).
		let savedFunc = currentFunc
		let savedBlock = currentBlock
		let savedSynth = synthNameCounter
		currentFunc = helperFunc
		currentBlock = helperBlock
		synthNameCounter = 0

		let result = try parseExpression(helperBlock)
		let retName = exprName(result)
		module.setTerminator(helperBlock, op: MaxonOp.ret(retName, range: SourceRange.none()))

		currentFunc = savedFunc
		currentBlock = savedBlock
		synthNameCounter = savedSynth

		// Register the helper. Skip funcReturnTypes / funcSignatures
		// registration when a duplicate exists (shouldn't happen — the
		// `<TypeName>.__field_init_<fieldName>` key is unique by
		// construction — but the insert API is contract-checked).
		try project.funcReturnTypes.insert(helperName, value: returnType) otherwise ignore
		try project.funcSignatures.insert(helperName, value: FuncSignature.create(StringArray.create(), paramTypes: MaxonTypeArray.create(), paramDefaults: ParamDefaultArray.create())) otherwise ignore
		try project.funcVisibilities.insert(helperName, value: FuncVisibilityInfo.create(Visibility.file, sourceFilePath: filePath)) otherwise ignore
		try project.funcThrowsTypes.insert(helperName, value: ThrowsClause.none) otherwise ignore
		// Stage K.4: no livenessRoot push. Every `Self{}` literal that
		// omits a defaulted field emits a `MaxonOp.call(__field_init_<name>)`
		// op in `parseStructLiteral`, so the regular DFE call-edge walk
		// reaches the helper when the struct is actually constructed. If no
		// user code constructs the struct, the helper is correctly dead.
		module.functions.push(helperFunc)
	end 'parseFieldDefaultInitHelper'

	// Infer the declared type of a shorthand `var f = <literal>` field from
	// the literal's lead-token kind. The valid lead tokens are int/float/
	// string/char/bool literals plus a leading `-` for negative numerics.
	// Enum-case shorthand (`var f = Color.red`) needs cross-decl lookup to
	// resolve `Color` to its enum type, so it lands as `unresolved` and
	// TypeResolution finishes the job. Anything else is a programming
	// error in the shorthand — the full `var f T = expr` form should be
	// used for non-literal defaults.
	function inferShorthandFieldType(leadToken Token, fieldNameToken Token) returns MaxonType
		// Negative numeric literal: peek past the unary `-` to the digit
		// token so the kind check sees the literal, not the operator.
		let litKind = inferShorthandLitKind(leadToken)
		if litKind == TokenKind.intLiteral 'isInt'
			return MaxonType.integer
		end 'isInt'
		if litKind == TokenKind.floatLiteral 'isFloat'
			return MaxonType.float
		end 'isFloat'
		if litKind == TokenKind.true or litKind == TokenKind.false 'isBool'
			return MaxonType.boolean
		end 'isBool'
		if litKind == TokenKind.stringLiteral 'isStr'
			return MaxonType.string
		end 'isStr'
		// Character literals fit in an int slot; TypeResolution refines to
		// the declared Codepoint typealias if the user later annotates one.
		if litKind == TokenKind.charLiteral 'isChar'
			return MaxonType.integer
		end 'isChar'
		// Identifier-led shorthand (enum case like `Color.red`) — defer to
		// TypeResolution, which can see the enum declaration and pin the
		// type once cross-decl info is available.
		if litKind == TokenKind.identifier 'isIdent'
			return MaxonType.unresolved
		end 'isIdent'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "field '{fieldNameToken.value}' shorthand default must be a literal (int, float, bool, string, char, or enum case); use full form 'var {fieldNameToken.value} Type = expr' for arbitrary expressions", line: leadToken.line, column: leadToken.column, filePath: filePath)
		return MaxonType.unresolved
	end 'inferShorthandFieldType'

	function inferShorthandLitKind(leadToken Token) returns TokenKind
		if leadToken.kind != TokenKind.minus 'notNeg'
			return leadToken.kind
		end 'notNeg'
		let next = try cursor.peek(1) otherwise return leadToken.kind
		return next.kind
	end 'inferShorthandLitKind'

	// True when the initializer is shaped like `Identifier . identifier (`
	// (a deferred struct-factory call, e.g. `Outer.create(...)`) OR like
	// `Identifier from <literal>` (`FilePath from "test.txt"` — sugar for
	// `Identifier.init(literal)` against an InitableFromStringLiteral /
	// InitableFromCharLiteral conformer). Both shapes lower into a runtime
	// call materialized inside the file's `__module_init_<n>` function;
	// recognizing the shapes here keeps the trailing `(...)` / literal from
	// destabilizing the const-expression dispatcher.
	function isRuntimeInitInitializer(valueToken Token) returns bool
		if valueToken.kind != TokenKind.identifier 'notIdent'
			return false
		end 'notIdent'
		let nextTok = try cursor.peek(1) otherwise Token.eof()
		if nextTok.kind == TokenKind.from 'isFromLiteral'
			let litTok = try cursor.peek(2) otherwise Token.eof()
			return litTok.kind == TokenKind.stringLiteral or litTok.kind == TokenKind.charLiteral
		end 'isFromLiteral'
		let memberTok = try cursor.peek(2) otherwise Token.eof()
		let parenTok = try cursor.peek(3) otherwise Token.eof()
		return nextTok.kind == TokenKind.dot and memberTok.kind == TokenKind.identifier and parenTok.kind == TokenKind.leftParen
	end 'isRuntimeInitInitializer'

	// `let NAME = TypeName{field: ..., ...}` — deferred struct-literal
	// initializer. The self-hosted compiler doesn't yet evaluate struct
	// literals at compile time; we recognize the shape (`Identifier {`)
	// and skip past the matching closing brace.
	function isStructLiteralInitializer(valueToken Token) returns bool
		if valueToken.kind != TokenKind.identifier 'notIdent'
			return false
		end 'notIdent'
		let braceTok = try cursor.peek(1) otherwise Token.eof()
		return braceTok.kind == TokenKind.leftBrace
	end 'isStructLiteralInitializer'

	// Skip past the entire `TypeName{...}` initializer — including any
	// nested braces inside the field initializers. Stops just past the
	// matching `}`. The cursor is left at the next token (typically the
	// trailing newline).
	function skipPastStructLiteralInitializer() throws ParserError
		try cursor.advance() otherwise return  // past TypeName
		try eat(TokenKind.leftBrace)
		var depth = 1
		while depth > 0 'scan'
			let t = cursor.current()
			if t.kind == TokenKind.eof 'eof'
				return
			end 'eof'
			if t.kind == TokenKind.leftBrace 'open'
				depth = depth + 1
			end 'open' else if t.kind == TokenKind.rightBrace 'close'
				depth = depth - 1
			end 'close'
			try cursor.advance() otherwise return
		end 'scan'
	end 'skipPastStructLiteralInitializer'

	// Append a node to the project-wide expression arena and return its
	// arena id. Callers use the returned id when building parent nodes
	// (e.g. `add(left: leftId, right: rightId)`).
	function appendConstExpr(node UnresolvedConstExpr) returns UnresolvedConstExprId
		let id = project.unresolvedConstExprs.count()
		project.unresolvedConstExprs.push(node)
		return id
	end 'appendConstExpr'

	// Catch `let NAME = call()` / `var NAME = call()` at the top level and
	// surface the dedicated E2045 diagnostic before parseConstExpr would
	// reject the open-paren with a generic "could not parse" message. Returns
	// `true` when a call was rejected (caller has already been synchronized);
	// `false` to let normal parsing continue.
	function rejectCallInitializer(valueToken Token) returns bool
		if valueToken.kind != TokenKind.identifier 'notIdent'
			return false
		end 'notIdent'
		let afterIdent = try cursor.peek(1) otherwise Token.eof()
		if afterIdent.kind != TokenKind.leftParen 'notCall'
			return false
		end 'notCall'
		reportCompileError(project, code: ErrorCode.parserNonConstantInitializer, message: "Function calls are not allowed in global variable initializers; '{valueToken.value}()' is not a constant expression", line: valueToken.line, column: valueToken.column, filePath: filePath)
		synchronize()
		return true
	end 'rejectCallInitializer'

	// Register a captured top-level decl (let or var). Reports E2001
	// (duplicate) when `qualifiedName` collides with another pending decl,
	// an already-resolved constant, an already-resolved var, or a
	// stdlib-cached constant. The duplicate-check set is the union of all
	// destinations the resolver might land in.
	function registerUnresolvedTopLevelDecl(nameToken Token, qualifiedName String, rootExprId UnresolvedConstExprId, mutable bool, visibility Visibility)
		if project.topLevelConstants.contains(qualifiedName) or project.topLevelVars.contains(qualifiedName) 'dupResolved'
			reportDuplicateConstant(nameToken)
			return
		end 'dupResolved'
		let entry = UnresolvedTopLevelDecl.create(qualifiedName, rootExprId: rootExprId, mutable: mutable, visibility: visibility, line: nameToken.line, column: nameToken.column, filePath: filePath)
		try project.unresolvedTopLevelDecls.insert(qualifiedName, value: entry) otherwise 'dupPending'
			reportDuplicateConstant(nameToken)
		end 'dupPending'
		logTrace(LogCategory.parser, message: () gives "parser: deferred top-level decl '{qualifiedName}' rootExprId={rootExprId} mutable={mutable} visibility={visibility.name}")
	end 'registerUnresolvedTopLevelDecl'

	// Parse `static let NAME = <const-int-expr>` inside a type. The value is
	// inlined at every use site as a compile-time constant — no runtime
	// storage. The qualified name (`TypeName.NAME`) is registered in the
	// project's topLevelConstants map so qualified expression resolution can
	// substitute the integer value directly.
	// Build `UnresolvedConstExpr` nodes in `project.unresolvedConstExprs`
	// without folding the expression at parse time. Identifier references
	// are captured as `nameRef(name)` regardless of whether the name is
	// currently resolvable — the TypeResolution pass walks the
	// arena with cycle detection and emits E2012 for cyclic references.
	//
	// Grammar (precedence high → low): integer literals, hex literals,
	// `true`/`false`, identifier references, `not <expr>`, `-<expr>`,
	// `*`, `+` / `-`, comparison (`==` `!=` `<` `<=` `>` `>=`), `and`,
	// `xor`, `or`. This mirrors the runtime expression precedence so a
	// `let` written with the runtime grammar parses identically here.
	// Token shapes outside this grammar throw `ParserError.unhandledToken`,
	// surfacing as the existing E2010 diagnostic.
	function parseConstExpr() returns UnresolvedConstExprId throws ParserError
		return try parseConstOr()
	end 'parseConstExpr'

	function parseConstOr() returns UnresolvedConstExprId throws ParserError
		var acc = try parseConstXor()
		while accept(TokenKind.or) 'tail'
			let rhs = try parseConstXor()
			acc = appendConstExpr(UnresolvedConstExpr.logicalOr(left: acc, right: rhs))
		end 'tail'
		return acc
	end 'parseConstOr'

	function parseConstXor() returns UnresolvedConstExprId throws ParserError
		var acc = try parseConstAnd()
		while accept(TokenKind.xor) 'tail'
			let rhs = try parseConstAnd()
			acc = appendConstExpr(UnresolvedConstExpr.logicalXor(left: acc, right: rhs))
		end 'tail'
		return acc
	end 'parseConstXor'

	function parseConstAnd() returns UnresolvedConstExprId throws ParserError
		var acc = try parseConstCompare()
		while accept(TokenKind.and) 'tail'
			let rhs = try parseConstCompare()
			acc = appendConstExpr(UnresolvedConstExpr.logicalAnd(left: acc, right: rhs))
		end 'tail'
		return acc
	end 'parseConstAnd'

	// Comparison is non-associative — only one `cmp` may appear per
	// expression, mirroring how the C# bootstrap rejects chained
	// comparisons. Folds to `intValue(0)` / `intValue(1)` at evaluate time.
	function parseConstCompare() returns UnresolvedConstExprId throws ParserError
		let lhs = try parseConstAdd()

		let opKind = cursor.current().kind
		if not isConstCompareToken(opKind) 'noOp'
			return lhs
		end 'noOp'

		try eat(opKind)
		let rhs = try parseConstAdd()
		return appendConstExpr(buildConstCompareNode(opKind, left: lhs, right: rhs))
	end 'parseConstCompare'

	function isConstCompareToken(kind TokenKind) returns bool
		return kind == TokenKind.equalsEquals or kind == TokenKind.bangEquals or kind == TokenKind.lessThan or kind == TokenKind.lessEquals or kind == TokenKind.greaterThan or kind == TokenKind.greaterEquals
	end 'isConstCompareToken'

	// Caller (parseConstCompare) guarantees `kind` passed isConstCompareToken;
	// any other token is a dispatch bug, so panic surfaces it as a compiler
	// invariant violation rather than a recoverable parse error.
	function buildConstCompareNode(kind TokenKind, left UnresolvedConstExprId, right UnresolvedConstExprId) returns UnresolvedConstExpr
		return match kind 'mk'
			equalsEquals gives UnresolvedConstExpr.compareEq(left: left, right: right)
			bangEquals gives UnresolvedConstExpr.compareNeq(left: left, right: right)
			lessThan gives UnresolvedConstExpr.compareLt(left: left, right: right)
			lessEquals gives UnresolvedConstExpr.compareLte(left: left, right: right)
			greaterThan gives UnresolvedConstExpr.compareGt(left: left, right: right)
			greaterEquals gives UnresolvedConstExpr.compareGte(left: left, right: right)
			default panic("buildConstCompareNode: unexpected token kind {kind.name} — caller must filter via isConstCompareToken")
		end 'mk'
	end 'buildConstCompareNode'

	function parseConstAdd() returns UnresolvedConstExprId throws ParserError
		var acc = try parseConstMul()
		while true 'tail'
			if accept(TokenKind.plus) 'isPlus'
				let rhs = try parseConstMul()
				acc = appendConstExpr(UnresolvedConstExpr.add(left: acc, right: rhs))
			end 'isPlus' else if accept(TokenKind.minus) 'isMinus'
				let rhs = try parseConstMul()
				acc = appendConstExpr(UnresolvedConstExpr.sub(left: acc, right: rhs))
			end 'isMinus' else 'done'
				break
			end 'done'
		end 'tail'
		return acc
	end 'parseConstAdd'

	// Multiplication binds tighter than `+`/`-`, matching the runtime
	// expression parser's precedence. Only `*` is captured here; `/` and
	// `mod` aren't needed by any current top-level let initializer and
	// would require introducing float / divide-by-zero handling at fold
	// time.
	function parseConstMul() returns UnresolvedConstExprId throws ParserError
		var acc = try parseConstAtom()
		while true 'tail'
			if accept(TokenKind.star) 'isStar'
				let rhs = try parseConstAtom()
				acc = appendConstExpr(UnresolvedConstExpr.mul(left: acc, right: rhs))
			end 'isStar' else 'done'
				break
			end 'done'
		end 'tail'
		return acc
	end 'parseConstMul'

	function parseConstAtom() returns UnresolvedConstExprId throws ParserError
		let baseId = try parseConstUnary()
		return try parseConstAsCastTail(baseId)
	end 'parseConstAtom'

	// Apply zero or more `as TypeName` casts to a base const expression.
	// Each cast wraps the prior id in an `asCast` node carrying the target
	// type name; the resolver folds these against the project's typealias /
	// ranged-type registry once typealiases have been drained.
	function parseConstAsCastTail(baseId UnresolvedConstExprId) returns UnresolvedConstExprId throws ParserError
		var acc = baseId
		while accept(TokenKind.as) 'tail'
			let typeName = try consumeConstCastTargetName()
			acc = appendConstExpr(UnresolvedConstExpr.asCast(operand: acc, typeName: typeName))
		end 'tail'
		return acc
	end 'parseConstAsCastTail'

	// Read the type-name identifier that follows `as`. Built-in primitive
	// keywords are accepted as identity casts (no value change at fold time);
	// identifiers are returned verbatim and resolved by the const evaluator
	// against `project.typealiases` / `project.typealiasRanges`.
	function consumeConstCastTargetName() returns String throws ParserError
		let token = cursor.current()
		if token.kind == TokenKind.identifier 'isIdent'
			_ = try consume()
			// E3062: top-level `42 as SmallInt` is a use of `SmallInt`, same
			// as the in-function `parseCastTargetType` path.
			usedTypeAliases.insert(element: token.value)
			return token.value
		end 'isIdent'
		throw ParserError.unhandledToken
	end 'consumeConstCastTargetName'

	function parseConstUnary() returns UnresolvedConstExprId throws ParserError
		if accept(TokenKind.not) 'isNot'
			let inner = try parseConstAtom()
			return appendConstExpr(UnresolvedConstExpr.notOp(operand: inner))
		end 'isNot'

		if accept(TokenKind.minus) 'isNeg'
			let inner = try parseConstAtom()
			return appendConstExpr(UnresolvedConstExpr.negate(operand: inner))
		end 'isNeg'

		return try parseConstPrimary()
	end 'parseConstUnary'

	function parseConstPrimary() returns UnresolvedConstExprId throws ParserError
		let token = cursor.current()

		if accept(TokenKind.intLiteral) 'isInt'
			let v = try parseInt(token.value)
			return appendConstExpr(UnresolvedConstExpr.intLit(value: v))
		end 'isInt'

		if accept(TokenKind.floatLiteral) 'isFloat'
			let bits = try parseFloatBits(token.value) otherwise 'overflow'
				reportLiteralOverflow(token: token, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float")
				throw ParserError.unhandledToken
			end 'overflow'
			return appendConstExpr(UnresolvedConstExpr.floatLit(bits: bits))
		end 'isFloat'

		if accept(TokenKind.true) 'isTrue'
			return appendConstExpr(UnresolvedConstExpr.boolLit(value: true))
		end 'isTrue'

		if accept(TokenKind.false) 'isFalse'
			return appendConstExpr(UnresolvedConstExpr.boolLit(value: false))
		end 'isFalse'

		if accept(TokenKind.leftParen) 'isParen'
			let inner = try parseConstExpr()
			try expect(TokenKind.rightParen)
			return inner
		end 'isParen'

		if token.kind == TokenKind.identifier 'isIdent'
			let next = try cursor.peek(1) otherwise Token.eof()
			// Function calls in const initializers are not constant; let the
			// caller surface E2045 with the right message.
			if next.kind == TokenKind.leftParen 'isCall'
				throw ParserError.unhandledToken
			end 'isCall'
			// `Name.member` — could be `EnumName.caseName` or a sized-type
			// bound (`u64.max` / `i32.min`). Capture both structurally.
			if next.kind == TokenKind.dot 'isDotted'
				let memberToken = try cursor.peek(2) otherwise Token.eof()
				if memberToken.kind == TokenKind.identifier 'memberIsIdent'
					if isSizedTypeName(token.value) and (memberToken.value == "min" or memberToken.value == "max") 'isTypeBound'
						_ = try consume()
						try eat(TokenKind.dot)
						_ = try consume()
						let bound = resolveTypeBound(token.value, field: memberToken.value)
						return appendConstExpr(UnresolvedConstExpr.intLit(value: bound))
					end 'isTypeBound'
					_ = try consume()
					try eat(TokenKind.dot)
					_ = try consume()
					return appendConstExpr(UnresolvedConstExpr.enumCase(enumName: token.value, caseName: memberToken.value))
				end 'memberIsIdent'
			end 'isDotted'
			_ = try consume()
			return appendConstExpr(UnresolvedConstExpr.nameRef(name: token.value))
		end 'isIdent'

		throw ParserError.unhandledToken
	end 'parseConstPrimary'

	// Parse a struct literal in const-expression context — either the
	// `StructType{field: value, ...}` brace form or the
	// `StructType.create([fieldLabel:] value, ...)` constructor form. The
	// leading identifier (the struct type name) is consumed inside this
	// helper. Returns the arena id of the synthesized `structLit` node, or
	// throws on a malformed sub-expression. Caller guarantees `cursor` is
	// already positioned at the `StructType` identifier.
	//
	// Positional args in the `.create(...)` form are mapped to field names
	// via the struct's declared field order (looked up through
	// `unresolvedStructTypes`). The number of positional args must not
	// exceed the declared field count; named args bind to their label
	// verbatim. We don't enforce coverage / duplicates here — TypeResolution
	// already validates struct-field completeness on the resolved tree.
	function parseConstStructLiteralRoot() returns UnresolvedConstExprId throws ParserError
		let typeNameToken = try consume()
		if typeNameToken.kind != TokenKind.identifier 'badTypeName'
			reportTokenMismatch(typeNameToken, expectedDisplay: "struct type name")
			throw ParserError.unhandledToken
		end 'badTypeName'
		let structTypeName = typeNameToken.value

		var fieldNames = StringArray.create()
		var fieldExprs = UnresolvedConstExprIdArray.create()

		if accept(TokenKind.leftBrace) 'isBraceForm'
			try parseConstStructLiteralBraceBody(fieldNamesOut: fieldNames, fieldExprsOut: fieldExprs)
		end 'isBraceForm' else if accept(TokenKind.dot) 'isDotForm'
			let methodToken = try consumeExpecting("identifier")
			if methodToken.value != "create" 'notCreate'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "enum struct backing: only '{structTypeName}.create(...)' factory call is supported, got '{structTypeName}.{methodToken.value}'", line: methodToken.line, column: methodToken.column, filePath: filePath)
				throw ParserError.unhandledToken
			end 'notCreate'
			try expect(TokenKind.leftParen)
			try parseConstStructLiteralCreateBody(structTypeName: structTypeName, fieldNamesOut: fieldNames, fieldExprsOut: fieldExprs)
		end 'isDotForm' else 'badForm'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "enum struct backing: expected '\{' or '.create(' after '{structTypeName}'", line: typeNameToken.line, column: typeNameToken.column, filePath: filePath)
			throw ParserError.unhandledToken
		end 'badForm'

		return appendConstExpr(UnresolvedConstExpr.structLit(structTypeName: structTypeName, fieldNames: fieldNames, fieldExprs: fieldExprs))
	end 'parseConstStructLiteralRoot'

	// Parse the body of `{field: value, ...}` after the `{` has been
	// consumed, populating the parallel `fieldNames` / `fieldExprs` arrays.
	function parseConstStructLiteralBraceBody(fieldNamesOut StringArray, fieldExprsOut UnresolvedConstExprIdArray) throws ParserError
		try skipNewlines()
		while not at(TokenKind.rightBrace) 'fields'
			let fieldNameToken = try consumeExpecting("identifier")
			try expect(TokenKind.colon)
			let valueId = try parseConstStructFieldValue()
			fieldNamesOut.push(fieldNameToken.value)
			fieldExprsOut.push(valueId)
			_ = accept(TokenKind.comma)
			try skipNewlines()
		end 'fields'
		try expect(TokenKind.rightBrace)
	end 'parseConstStructLiteralBraceBody'

	// Parse the body of `.create(arg, ...)` after the `(` has been consumed.
	// Each arg is either `label: value` (named) or just `value` (positional);
	// positional args are bound to field names from the struct's declared
	// field order via `unresolvedStructTypes` lookup. The struct's `.create`
	// signature is assumed to mirror its field order — the standard pattern
	// generated by the language idiom and seen across the spec fragments.
	function parseConstStructLiteralCreateBody(structTypeName String, fieldNamesOut StringArray, fieldExprsOut UnresolvedConstExprIdArray) throws ParserError
		try skipNewlines()
		var positionalIndex = 0
		while not at(TokenKind.rightParen) 'args'
			let fieldNameToken = cursor.current()
			let afterName = try cursor.peek(1) otherwise Token.eof()
			var resolvedFieldName = ""
			if fieldNameToken.kind == TokenKind.identifier and afterName.kind == TokenKind.colon 'isNamed'
				_ = try consume()
				try expect(TokenKind.colon)
				resolvedFieldName = fieldNameToken.value
			end 'isNamed' else 'isPositional'
				resolvedFieldName = try lookupStructFieldNameByIndex(structTypeName: structTypeName, index: positionalIndex) otherwise 'unknownField'
					let posToken = cursor.current()
					reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "enum struct backing: positional arg #{positionalIndex} cannot be resolved against struct '{structTypeName}' (declare named: 'fieldName: value')", line: posToken.line, column: posToken.column, filePath: filePath)
					throw ParserError.unhandledToken
				end 'unknownField'
			end 'isPositional'
			let valueId = try parseConstStructFieldValue()
			fieldNamesOut.push(resolvedFieldName)
			fieldExprsOut.push(valueId)
			positionalIndex = positionalIndex + 1
			_ = accept(TokenKind.comma)
			try skipNewlines()
		end 'args'
		try expect(TokenKind.rightParen)
	end 'parseConstStructLiteralCreateBody'

	// Parse one field-value expression inside a struct backing literal. A
	// nested struct (`StructType{...}` or `StructType.create(...)`) is
	// captured as another arena `structLit` entry; anything else flows
	// through `parseConstExpr` so int / float / bool / nameRef / enum-case /
	// arithmetic-fold cases share their existing implementations.
	function parseConstStructFieldValue() returns UnresolvedConstExprId throws ParserError
		let token = cursor.current()
		if token.kind == TokenKind.identifier 'isIdent'
			let next = try cursor.peek(1) otherwise Token.eof()
			if next.kind == TokenKind.leftBrace 'isBraceLit'
				return try parseConstStructLiteralRoot()
			end 'isBraceLit'
			if next.kind == TokenKind.dot 'isDotted'
				let memberToken = try cursor.peek(2) otherwise Token.eof()
				let afterMember = try cursor.peek(3) otherwise Token.eof()
				if memberToken.kind == TokenKind.identifier and memberToken.value == "create" and afterMember.kind == TokenKind.leftParen 'isCreateCall'
					return try parseConstStructLiteralRoot()
				end 'isCreateCall'
				// Otherwise fall through — parseConstExpr handles
				// `EnumName.caseName` via parseConstPrimary's enum-case arm.
			end 'isDotted'
		end 'isIdent'
		return try parseConstExpr()
	end 'parseConstStructFieldValue'

	// Look up the i-th declared field name on `structTypeName`. Throws
	// `StructFieldProbeError.notFound` when the struct isn't registered yet
	// (forward reference) or when the index is out of range. Callers handle
	// the throw by emitting an E2003 / E3032-adjacent diagnostic.
	function lookupStructFieldNameByIndex(structTypeName String, index UnresolvedConstExprId) returns String throws StructFieldProbeError
		let unresolved = try project.unresolvedStructTypes.get(structTypeName) otherwise throw StructFieldProbeError.notFound
		if index >= unresolved.fields.count() 'outOfRange'
			throw StructFieldProbeError.notFound
		end 'outOfRange'
		let structFieldEntry = try unresolved.fields.get(index) otherwise throw StructFieldProbeError.notFound
		return structFieldEntry.name
	end 'lookupStructFieldNameByIndex'

	// Phase 9 Stage 5 (struct-backing): true when `EnumName.caseName` carries
	// a `= StructType{...}` / `= StructType.create(...)` backing literal.
	// Drives parser-side compile-time resolution of `EnumName.caseName.field`
	// chains and `local.rawValue.field` chains where `local` is bound to the
	// case. Looks up `unresolvedEnums` (parse-time) and `enumTypes` (resolved)
	// — only one will be populated at any given parser observation, but the
	// helper handles both for forward / cross-file safety.
	function caseHasStructBacking(enumName String, caseName String) returns bool
		if let unresolvedEnum = try project.unresolvedEnums.get(enumName) 'inUnresolved'
			for c in unresolvedEnum.cases 'scan'
				if c.name == caseName 'hit'
					return not c.backingStructName.isEmpty()
				end 'hit'
			end 'scan'
		end 'inUnresolved'
		if let resolvedEnum = try project.enumTypes.get(enumName) 'inResolved'
			for c in resolvedEnum.cases 'scan2'
				if c.name == caseName 'hit2'
					return not c.backingStructName.isEmpty()
				end 'hit2'
			end 'scan2'
		end 'inResolved'
		return false
	end 'caseHasStructBacking'

	// Phase 9 Stage 5 (struct-backing): non-consuming peek for the
	// `EnumName.caseName` shape at the cursor's current position. Returns
	// the qualified `EnumName.caseName` string when the prefix is a known
	// struct-backed enum AND the named case carries a backing literal.
	// Throws `EnumCaseProbeError.notFound` otherwise — callers handle the
	// miss with `try … otherwise ignore` (parse-time probe; no diagnostic).
	// Used by `parseVarDecl` so a `let op = TestOp.mul` records `op` as
	// an alias for `TestOp.mul` without consuming any tokens — the actual
	// expression parse runs immediately after this peek and emits the
	// regular IR.
	function peekStructBackedEnumCaseQualifiedName() returns String throws EnumCaseProbeError
		let prefixToken = cursor.current()
		if prefixToken.kind != TokenKind.identifier 'notIdent'
			throw EnumCaseProbeError.notFound
		end 'notIdent'
		let dotToken = try cursor.peek(1) otherwise Token.eof()
		if dotToken.kind != TokenKind.dot 'noDot'
			throw EnumCaseProbeError.notFound
		end 'noDot'
		let memberToken = try cursor.peek(2) otherwise Token.eof()
		if memberToken.kind != TokenKind.identifier 'noMember'
			throw EnumCaseProbeError.notFound
		end 'noMember'
		// Reject deeper postfix chains: `EnumName.case.field` shouldn't be
		// recorded as a simple alias — the chain itself folds via the
		// direct-access path in `parseIdentifierExpr`. We only want bare
		// `let op = EnumName.case` here.
		let afterMember = try cursor.peek(3) otherwise Token.eof()
		if afterMember.kind == TokenKind.dot 'hasChain'
			throw EnumCaseProbeError.notFound
		end 'hasChain'
		if not caseHasStructBacking(enumName: prefixToken.value, caseName: memberToken.value) 'noBacking'
			throw EnumCaseProbeError.notFound
		end 'noBacking'
		return "{prefixToken.value}.{memberToken.value}"
	end 'peekStructBackedEnumCaseQualifiedName'

	// Companion lookup returning the per-case struct-backing arena id when
	// the case is struct-backed. Throws `EnumCaseProbeError.notFound` when
	// no matching backed case exists — id 0 IS a valid arena entry, so we
	// can't fold "missing" into a sentinel here. Callers should normally
	// guard with `caseHasStructBacking` first, in which case `otherwise
	// panic` is appropriate.
	function lookupCaseStructBackingExprId(enumName String, caseName String) returns UnresolvedConstExprId throws EnumCaseProbeError
		if let unresolvedEnum = try project.unresolvedEnums.get(enumName) 'inUnresolved'
			for c in unresolvedEnum.cases 'scan'
				if c.name == caseName 'hit'
					if c.backingStructName.isEmpty() 'noBacking'
						throw EnumCaseProbeError.notFound
					end 'noBacking'
					return c.backingStructExprId
				end 'hit'
			end 'scan'
		end 'inUnresolved'
		if let resolvedEnum = try project.enumTypes.get(enumName) 'inResolved'
			for c in resolvedEnum.cases 'scan2'
				if c.name == caseName 'hit2'
					if c.backingStructName.isEmpty() 'noBacking2'
						throw EnumCaseProbeError.notFound
					end 'noBacking2'
					return c.backingStructExprId
				end 'hit2'
			end 'scan2'
		end 'inResolved'
		throw EnumCaseProbeError.notFound
	end 'lookupCaseStructBackingExprId'

	// Phase 9 Stage 5: descend a `structLit` arena tree, following
	// `fieldChain` field names, and return the resulting ConstantValue. The
	// chain is consumed left-to-right; once a leaf (`intLit`, `floatLit`,
	// `boolLit`, `enumCase`) is reached, the remaining chain must be empty
	// (no further `.field`) — non-empty surfaces as a parse-time error at
	// the caller. Returns ConstantValue.intValue(0) plus `found = false` on
	// any unresolved field reference.
	// Walk a struct-backing arena tree following `fieldChain`. Returns a
	// `StructBackingFoldResult` carrying the leaf constant on success; the
	// `notFound` shape signals "couldn't fold" (chain reached a non-struct
	// mid-descent, field name doesn't exist on the current `structLit`, or
	// the leaf isn't a scalar literal). `.ordinal` / `.rawValue` on an
	// `enumCase` leaf is a no-op alias to the case's folded integer —
	// matches the existing bare-enum `.ordinal` accessor semantics.
	function resolveStructBackingFieldChain(rootExprId UnresolvedConstExprId, fieldChain StringArray) returns StructBackingFoldResult
		var currentExprId = rootExprId
		var idx = 0
		while idx < fieldChain.count() 'descend'
			let fieldName = try fieldChain.get(idx) otherwise return StructBackingFoldResult.notFound()
			if isEnumCaseLeaf(currentExprId) and isEnumOrdinalLikeAccessor(fieldName) and idx == fieldChain.count() - 1 'enumCaseOrdinalLeaf'
				return evaluateStructBackingLeaf(currentExprId)
			end 'enumCaseOrdinalLeaf'
			let descendResult = descendStructBackingLevel(currentExprId, fieldName: fieldName)
			if not descendResult.found 'noField'
				return StructBackingFoldResult.notFound()
			end 'noField'
			currentExprId = descendResult.exprId
			idx = idx + 1
		end 'descend'
		return evaluateStructBackingLeaf(currentExprId)
	end 'resolveStructBackingFieldChain'

	function isEnumCaseLeaf(exprId UnresolvedConstExprId) returns bool
		let node = try project.unresolvedConstExprs.get(exprId) otherwise return false
		return isStructBackingLeafEnumKindCheck(node)
	end 'isEnumCaseLeaf'

	function isStructBackingLeafEnumKindCheck(node UnresolvedConstExpr) returns bool
		match node 'k'
			enumCase then return true
			boolLit then return false
			floatLit then return false
			intLit then return false
			stringLit then return false
			structLit then return false
			asCast then return false
			nameRef then return false
			negate then return false
			notOp then return false
			add then return false
			sub then return false
			mul then return false
			compareEq then return false
			compareNeq then return false
			compareLt then return false
			compareLte then return false
			compareGt then return false
			compareGte then return false
			logicalAnd then return false
			logicalXor then return false
			logicalOr then return false
		end 'k'
	end 'isStructBackingLeafEnumKindCheck'

	function isEnumOrdinalLikeAccessor(name String) returns bool
		return name == "ordinal" or name == "rawValue"
	end 'isEnumOrdinalLikeAccessor'

	// Look up `fieldName` inside the `structLit` arena node at `exprId` and
	// return the named field's sub-expression id. `found = false` when the
	// node is not a struct literal, the field name isn't declared on it, or
	// the arena lookup fails. We use an explicit `found` flag instead of a
	// 0 sentinel because arena id 0 IS a valid entry — the first int literal
	// pushed gets id 0, and the first user-pushed entry depends on whether
	// stdlib added any const exprs before user code.
	function descendStructBackingLevel(exprId UnresolvedConstExprId, fieldName String) returns StructBackingDescendResult
		let node = try project.unresolvedConstExprs.get(exprId) otherwise return StructBackingDescendResult.none()
		return structLitFieldExprId(node, fieldName: fieldName)
	end 'descendStructBackingLevel'

	// Pattern-match a single arena node looking for the `structLit` arm; if
	// found, walk its field arrays for `fieldName` and return the matched
	// sub-expr id. All non-`structLit` arms return `none()`. The match must
	// enumerate every arm because the language requires exhaustive matches
	// on enums.
	function structLitFieldExprId(node UnresolvedConstExpr, fieldName String) returns StructBackingDescendResult
		match node 'matchNode'
			structLit(_, fieldNames, fieldExprs) then return findStructLitFieldExprIdInArrays(fieldNames, fieldExprs: fieldExprs, fieldName: fieldName)
			boolLit then return StructBackingDescendResult.none()
			floatLit then return StructBackingDescendResult.none()
			enumCase then return StructBackingDescendResult.none()
			asCast then return StructBackingDescendResult.none()
			intLit then return StructBackingDescendResult.none()
			stringLit then return StructBackingDescendResult.none()
			nameRef then return StructBackingDescendResult.none()
			negate then return StructBackingDescendResult.none()
			notOp then return StructBackingDescendResult.none()
			add then return StructBackingDescendResult.none()
			sub then return StructBackingDescendResult.none()
			mul then return StructBackingDescendResult.none()
			compareEq then return StructBackingDescendResult.none()
			compareNeq then return StructBackingDescendResult.none()
			compareLt then return StructBackingDescendResult.none()
			compareLte then return StructBackingDescendResult.none()
			compareGt then return StructBackingDescendResult.none()
			compareGte then return StructBackingDescendResult.none()
			logicalAnd then return StructBackingDescendResult.none()
			logicalXor then return StructBackingDescendResult.none()
			logicalOr then return StructBackingDescendResult.none()
		end 'matchNode'
	end 'structLitFieldExprId'

	function findStructLitFieldExprIdInArrays(fieldNames StringArray, fieldExprs UnresolvedConstExprIdArray, fieldName String) returns StructBackingDescendResult
		for i in 0 upto fieldNames.count() 'eachField'
			let nm = try fieldNames.get(i) otherwise continue
			if nm == fieldName 'matched'
				let resolvedId = try fieldExprs.get(i) otherwise return StructBackingDescendResult.none()
				return StructBackingDescendResult.hit(resolvedId)
			end 'matched'
		end 'eachField'
		return StructBackingDescendResult.none()
	end 'findStructLitFieldExprIdInArrays'

	// Evaluate a struct-backing arena node that is expected to be a scalar
	// leaf (int / float / bool / enumCase). Nested struct literals reached at
	// this position are not foldable through `.field` access alone (caller's
	// fieldChain has been fully consumed) — surface as notFound so the
	// caller emits a diagnostic. Unsupported arms (`nameRef`, `negate`,
	// arithmetic ops, …) similarly surface as notFound; the parser only
	// stores leaves the struct-backing surface accepts, so reaching them
	// here would indicate a forward reference or `parseConstExpr` returning
	// a richer expression than this fold path knows how to descend.
	function evaluateStructBackingLeaf(exprId UnresolvedConstExprId) returns StructBackingFoldResult
		let node = try project.unresolvedConstExprs.get(exprId) otherwise return StructBackingFoldResult.notFound()
		match node 'leaf'
			intLit(value) then return StructBackingFoldResult.intHit(value)
			boolLit(value) then return structBackingFoldFromBool(value)
			floatLit(bits) then return StructBackingFoldResult.floatHit(bits)
			enumCase(enumName, caseName) then return evaluateStructBackingEnumCaseLeaf(enumName, caseName: caseName)
			structLit then return StructBackingFoldResult.notFound()
			asCast then return StructBackingFoldResult.notFound()
			stringLit then return StructBackingFoldResult.notFound()
			nameRef then return StructBackingFoldResult.notFound()
			negate then return StructBackingFoldResult.notFound()
			notOp then return StructBackingFoldResult.notFound()
			add then return StructBackingFoldResult.notFound()
			sub then return StructBackingFoldResult.notFound()
			mul then return StructBackingFoldResult.notFound()
			compareEq then return StructBackingFoldResult.notFound()
			compareNeq then return StructBackingFoldResult.notFound()
			compareLt then return StructBackingFoldResult.notFound()
			compareLte then return StructBackingFoldResult.notFound()
			compareGt then return StructBackingFoldResult.notFound()
			compareGte then return StructBackingFoldResult.notFound()
			logicalAnd then return StructBackingFoldResult.notFound()
			logicalXor then return StructBackingFoldResult.notFound()
			logicalOr then return StructBackingFoldResult.notFound()
		end 'leaf'
	end 'evaluateStructBackingLeaf'

	function structBackingFoldFromBool(value bool) returns StructBackingFoldResult
		if value 'asTrue'
			return StructBackingFoldResult.intHit(1)
		end 'asTrue'
		return StructBackingFoldResult.intHit(0)
	end 'structBackingFoldFromBool'

	function evaluateStructBackingEnumCaseLeaf(enumName String, caseName String) returns StructBackingFoldResult
		let qualified = "{enumName}.{caseName}"
		if let entry = try project.topLevelConstants.get(qualified) 'found'
			return match entry.value 'cv'
				intValue(v) gives StructBackingFoldResult.intHit(v)
				floatValue(bits) gives StructBackingFoldResult.floatHit(bits)
				stringValue gives StructBackingFoldResult.notFound()
			end 'cv'
		end 'found'
		return StructBackingFoldResult.notFound()
	end 'evaluateStructBackingEnumCaseLeaf'

	// Phase 9 Stage 5: consume the `.field[.field]*` tail of a struct-backing
	// access chain after `EnumName.caseName` (or `local.rawValue`) has been
	// recognized. Caller has already validated `cursor` is positioned at the
	// first `.` and the case carries a `structLit` arena entry at
	// `rootExprId`. Emits a `MaxonOp.literal` for the folded leaf constant.
	// The caller's responsibility for `prefixToken` / `memberToken` is purely
	// diagnostic-source-range plumbing.
	function parseStructBackingAccessChain(rootExprId UnresolvedConstExprId, prefixToken Token, memberToken Token, block IrBlock) returns ExprResult throws ParserError
		// Consume `.caseName` so cursor lands on the first chain `.fieldName`.
		try eat(TokenKind.dot)
		_ = try consume()
		// Collect the trailing `.field` chain into a StringArray. `.rawValue`
		// on a struct-backed enum is reinterpreted as "the struct itself" —
		// we silently drop it from the lookup chain so `op.rawValue.value`
		// folds the same way as `Op.case.value` would on a union.
		var fieldChain = StringArray.create()
		var lastFieldToken = memberToken
		while at(TokenKind.dot) 'chain'
			let chainDot = try cursor.peek(0) otherwise Token.eof()
			if chainDot.kind != TokenKind.dot 'sanity'
				break
			end 'sanity'
			let chainFieldToken = try cursor.peek(1) otherwise Token.eof()
			if chainFieldToken.kind != TokenKind.identifier 'noChainField'
				break
			end 'noChainField'
			try eat(TokenKind.dot)
			_ = try consume()
			lastFieldToken = chainFieldToken
			// `.rawValue` is the "open the struct" accessor — never appears
			// as a field on the user-declared struct. Skip it so subsequent
			// `.realField` accesses lookup against the struct's own fields.
			if chainFieldToken.value == "rawValue" 'skipRaw'
				continue
			end 'skipRaw'
			fieldChain.push(chainFieldToken.value)
		end 'chain'
		usedTypeAliases.insert(element: prefixToken.value)
		let foldResult = resolveStructBackingFieldChain(rootExprId: rootExprId, fieldChain: fieldChain)
		if not foldResult.found 'foldFailed'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "enum struct backing: could not resolve field chain on '{prefixToken.value}.{memberToken.value}' — verify field names match the struct's declared layout", line: lastFieldToken.line, column: lastFieldToken.column, filePath: filePath)
			let placeholderName = emitLiteral(block, value: 0, valueType: MaxonType.integer, range: SourceRange.between(prefixToken, last: lastFieldToken))
			return ExprResult.direct(placeholderName, valueType: MaxonType.integer)
		end 'foldFailed'
		// Float vs int leaves emit different valueTypes so downstream
		// producer-type tracking sees the right answer for chained reads
		// (`op.rawValue.float.fineFactor` would propagate as float through
		// the resulting literal).
		if foldResult.isFloat 'isFloatLeaf'
			let litName = emitLiteral(block, value: foldResult.floatBits, valueType: MaxonType.float, range: SourceRange.between(prefixToken, last: lastFieldToken))
			return ExprResult.direct(litName, valueType: MaxonType.float)
		end 'isFloatLeaf'
		let litName = emitLiteral(block, value: foldResult.intValue, valueType: MaxonType.integer, range: SourceRange.between(prefixToken, last: lastFieldToken))
		return ExprResult.direct(litName, valueType: MaxonType.integer)
	end 'parseStructBackingAccessChain'

	// --- Export dispatch ---

	// True when `kind` opens a top-level declaration — used by error-recovery
	// paths (synchronizeToTopLevel, abortBody re-dispatch) to anchor on the
	// next plausible declaration. Includes `union`/`enum` which aren't yet
	// dispatched, but are reserved as recovery anchors so a stray top-level
	// `union`/`enum` resyncs cleanly once support lands.
	function isTopLevelOpener(kind TokenKind) returns bool
		return kind == TokenKind.function or kind == TokenKind.type or kind == TokenKind.union or kind == TokenKind.enum or kind == TokenKind.interface or kind == TokenKind.extension or kind == TokenKind.let or kind == TokenKind.var or kind == TokenKind.typealias
	end 'isTopLevelOpener'

	// Convenience: is cursor positioned at a token that opens a top-level
	// declaration (or `export` modifier)?
	function isAtTopLevelOpener() returns bool
		let k = cursor.current().kind
		return isTopLevelOpener(k) or k == TokenKind.export
	end 'isAtTopLevelOpener'

	// Single source of truth for top-level keyword → parser routing. Consumes
	// the opening keyword (and any leading `export` modifier), then dispatches
	// to the appropriate per-declaration parser. Throws
	// `ParserError.unhandledToken` for plain top-level garbage so parseModule
	// can report it at source position; `export <garbage>` gets the gentler
	// skip-to-next-line recovery so a single bad export doesn't wedge parsing.
	// Adding a new top-level keyword — and hence a new declaration that may
	// carry an `export` modifier — only requires extending the inner match.
	function dispatchTopLevel() throws ParserError
		let visibility = consumeVisibilityModifier()
		let isExport = visibility == Visibility.global

		try 'dispatchInner'
			dispatchInner(visibility: visibility)
		end 'dispatchInner' otherwise(e) 'maybeRecover'
			if isExport 'exportRecovery'
				// `export <garbage>` — report the bad token then skip to the
				// next line. Without the report, malformed exports vanished
				// silently. Other error kinds keep their fast-unwind path.
				match e 'kind'
					unhandledToken then reportBadExportAndSkip()
					typeError then throw ParserError.typeError
					overflow then throw ParserError.overflow
					unexpectedEof then throw ParserError.unexpectedEof
				end 'kind'
			end 'exportRecovery' else 'rethrow'
				throw e
			end 'rethrow'
		end 'maybeRecover'
	end 'dispatchTopLevel'

	// Consume an optional `export` keyword or contextual `module`
	// identifier, returning the resulting visibility tier. `module` is a
	// contextual keyword (the lexer emits it as an identifier) — it's
	// only recognized when followed by a decl-opener token, so user code
	// can still bind `module` as a parameter or local variable name.
	// `export module` (or `module export`) is rejected at parse time so
	// the user gets a focused diagnostic instead of a follow-on parse
	// error on the next token.
	function consumeVisibilityModifier() returns Visibility
		let exportToken = cursor.current()
		if accept(TokenKind.export) 'isExport'
			if tryConsumeContextualModule() 'doubleModifier'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'export' and 'module' cannot be combined", line: exportToken.line, column: exportToken.column, filePath: filePath)
			end 'doubleModifier'
			return Visibility.global
		end 'isExport'
		let moduleToken = cursor.current()
		if tryConsumeContextualModule() 'isModuleScoped'
			// Reject `module export <decl>` symmetrically.
			if accept(TokenKind.export) 'doubleModifierAfter'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'export' and 'module' cannot be combined", line: moduleToken.line, column: moduleToken.column, filePath: filePath)
				return Visibility.global
			end 'doubleModifierAfter'
			return Visibility.module
		end 'isModuleScoped'
		return Visibility.file
	end 'consumeVisibilityModifier'

	// Consume the contextual `module` identifier when it precedes a
	// decl-opener token. Returns true on success (cursor now points at
	// the decl-opener), false otherwise (cursor unchanged).
	function tryConsumeContextualModule() returns bool
		let token = cursor.current()
		if token.kind != TokenKind.identifier or token.value != "module" 'notModule'
			return false
		end 'notModule'
		let next = try cursor.peek(1) otherwise Token.eof()
		if not isTopLevelOpener(next.kind) 'notDeclOpener'
			return false
		end 'notDeclOpener'
		try cursor.advance() otherwise return false
		return true
	end 'tryConsumeContextualModule'

	function reportBadExportAndSkip()
		let badTok = cursor.current()
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected declaration after 'export', got '{tokenValueToString(badTok.value)}'", line: badTok.line, column: badTok.column, filePath: filePath)
		skipToNextLine()
	end 'reportBadExportAndSkip'

	function dispatchInner(visibility Visibility) throws ParserError
		let token = try consume()

		match token.kind 'k'
			function then try parseFunction("", isInstance: false, fields: StructFieldArray.create(), visibility: visibility)
			type then try parseTypeDecl(visibility)
			enum then try parseEnumDecl(visibility)
			union then try parseUnionDecl(visibility)
			interface then try parseInterfaceDecl(visibility)
			extension then try parseExtension(visibility)
			let then try parseTopLevelDecl(typeName: "", mutable: false, visibility: visibility)
			var then try parseTopLevelDecl(typeName: "", mutable: true, visibility: visibility)
			typealias then try parseTopLevelTypealias(visibility)
			default throws ParserError.unhandledToken
		end 'k'
	end 'dispatchInner'

	// --- Typealias parsing ---

	// Parse: typealias Name = int(LOWER to UPPER) | float(LOWER to UPPER) | bool | ...
	// Captures the right-hand side as an UnresolvedTypeExpr and records it in
	// project.unresolvedTypealiases. Actual conversion to StdType + range
	// registration happens later in the TypeResolution pass, so we don't have
	// to know whether the RHS depends on another alias here.
	// entry: cursor AT the token AFTER `typealias` — the alias name identifier.
	// Caller (dispatchTopLevel) has already consumed the `typealias` keyword.
	function parseTopLevelTypealias(visibility Visibility) throws ParserError
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		try expect(TokenKind.equals)

		let expr = try parseTypealiasRhs(nameToken) otherwise return

		// Duplicate detection runs against both unresolved and resolved
		// registries — the latter catches duplicates that survive a stdlib
		// pre-seed where some aliases are already in `typealiases` before the
		// parser starts.
		//
		// Visibility-aware semantics:
		//   - Two file-private aliases in *different* files don't conflict —
		//     each is scoped to its declaring file. Mirrors the C# bootstrap's
		//     per-file `_localTypeAliases` semantics. The global registry
		//     keeps only the first-parsed entry; cross-file references to a
		//     file-private alias would resolve to whichever was parsed first,
		//     which by definition isn't a supported lookup (file-private
		//     aliases are not visible across files).
		//   - File-private vs. exported (any order) is a *shadowing error*.
		//     An export must not be hidden by a same-named file-private, and
		//     a file-private must not silently override an export.
		//   - Two exported aliases (or any combination touching `module`/
		//     `global` visibility) is a duplicate error.
		//   - Same file, same name is always a duplicate error regardless of
		//     visibility.
		let isFilePrivate = visibility == Visibility.file
		var existingVisibility = Visibility.global
		var existingFilePath = filePath
		var hasExisting = false
		if let existing = try project.unresolvedTypealiases.get(nameToken.value) 'haveExisting'
			hasExisting = true
			existingVisibility = existing.visibility
			existingFilePath = existing.filePath
		end 'haveExisting'
		// Same probe against the resolved-typealiases sidecar. Stdlib aliases
		// that survived a cache restore land in `typealiases` with one or
		// more (visibility, sourceFilePath) entries in `typealiasVisibilities`
		// (one per declaring file — the same name may be declared file-
		// private in multiple stdlib files). Iterate every entry and report
		// the first conflict; missing entries default to `(global, stdlib-
		// bootstrap path)` per Project.maxon.
		let existingIsFilePrivate = hasExisting and existingVisibility == Visibility.file
		let existingFromOtherFile = hasExisting and not (existingFilePath.toString() == filePath.toString())
		let bootstrapPath = try FilePath.from("stdlib-bootstrap.maxon") otherwise filePath

		// Stage K.X.A: Classify the relationship with each existing entry.
		// A duplicate only fires when both this and the existing decl are
		// simultaneously observable from each other's file (same file, or
		// both non-file-private). Cross-file invisibility silences the
		// check entirely — no separate "shadows" path.
		var collides = false
		if project.typealiases.contains(nameToken.value) 'haveResolved'
			var infos = TypealiasVisibilityInfoArray.create()
			if let storedInfos = try project.typealiasVisibilities.get(nameToken.value) 'haveInfos'
				for info in storedInfos 'eachInfo'
					infos.push(info)
				end 'eachInfo'
			end 'haveInfos'
			if infos.count() == 0 'noSidecar'
				infos.push(TypealiasVisibilityInfo.create(Visibility.global, sourceFilePath: bootstrapPath))
			end 'noSidecar'
			for info in infos 'classifyEach'
				let resolvedIsFilePrivate = info.visibility == Visibility.file
				let resolvedFromOtherFile = not (info.sourceFilePath.toString() == filePath.toString())
				if not resolvedFromOtherFile 'sameFile'
					collides = true
					continue
				end 'sameFile'
				let existingInvisibleHere = resolvedIsFilePrivate
				let thisInvisibleThere = isFilePrivate
				if existingInvisibleHere or thisInvisibleThere 'oneIsInvisible'
					continue
				end 'oneIsInvisible'
				collides = true
			end 'classifyEach'
		end 'haveResolved'
		if not collides and hasExisting 'checkUnresolved'
			if not existingFromOtherFile 'sameFile'
				collides = true
			end 'sameFile' else 'differentFiles'
				let existingInvisibleHere = existingIsFilePrivate
				let thisInvisibleThere = isFilePrivate
				if not existingInvisibleHere and not thisInvisibleThere 'bothObservable'
					collides = true
				end 'bothObservable'
			end 'differentFiles'
		end 'checkUnresolved'

		if collides 'duplicate'
			reportCompileError(project, code: ErrorCode.semanticDuplicateTypeAlias, message: "Duplicate typealias '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			skipToNextLine()
			return
		end 'duplicate'

		// First-parsed entry wins on cross-file file-private collisions; the
		// existing entry stays canonical in the global map.
		if not hasExisting 'firstEntry'
			project.unresolvedTypealiases.upsert(nameToken.value, value: UnresolvedTypealias.create(nameToken.value, expr: expr, visibility: visibility, line: nameToken.line, column: nameToken.column, filePath: filePath))
		end 'firstEntry'
		// File-private aliases participate in the unused-typealias check.
		// Exported / module-visible aliases skip it because cross-file uses
		// aren't visible to a single Parser instance. A typealias whose RHS
		// failed range validation also skips the check — the E3005 already
		// raised is the user-visible diagnostic; cascading E3062 would
		// distract.
		if visibility == Visibility.file and not isInvalidTypealiasExpr(expr) 'isLocal'
			localTypealiases.push(LocalTypealias.create(nameToken.value, line: nameToken.line, column: nameToken.column))
		end 'isLocal'
		skipToNextLine()
	end 'parseTopLevelTypealias'

	// Phase 11.0 step 2: shared RHS parser used by both top-level and
	// inner-body typealias declarations. Returns the captured expression
	// on success. Throws `ParserError.unhandledToken` after emitting a
	// diagnostic and calling `skipToNextLine` — callers `try ... otherwise`
	// to bail out of the enclosing typealias declaration. The token cursor
	// is positioned just past the RHS on success and somewhere on the next
	// line on failure. `nameToken` is used only for diagnostic anchoring —
	// the helper does not consume the alias name itself.
	function parseTypealiasRhs(nameToken Token) returns UnresolvedTypeExpr throws ParserError
		let baseToken = cursor.current()

		// `expr` is the captured RHS; `sawValidBase` tracks whether we saw
		// something we know how to capture. Recognized RHS forms are `bool`,
		// `int(L to U)`, `byte(L to U)`, `float(L to U)`, a bare identifier
		// (`typealias A = B`), and a generic instance (`Base with(A,B)` or
		// `Base with X`). The resolver pass takes the captured form and
		// computes the eventual StdType (or, for genericAlias, MaxonType).
		var expr = UnresolvedTypeExpr.boolPrim
		var sawValidBase = false

		if baseToken.kind == TokenKind.bool 'isBool'
			expr = UnresolvedTypeExpr.boolPrim
			sawValidBase = true
		end 'isBool'

		// Tuple-type RHS: `typealias Entry = (Key, Value)` desugars to a
		// generic instance of a synthetic `__TupleN` base struct. The
		// arity decides the base (`__Tuple2` for 2 elements, `__Tuple3`
		// for 3); each element must be a bare identifier (a type-param
		// in the enclosing scope, or a type name resolvable later). The
		// generic-alias resolver path then folds this into a real
		// `MaxonType.genericInstance`. Mirrors the C# bootstrap's tuple
		// typealias handling.
		if not sawValidBase and baseToken.kind == TokenKind.leftParen 'isTuple'
			try eat(TokenKind.leftParen)
			var elemNames = StringArray.create()
			while not at(TokenKind.rightParen) 'tupleLoop'
				let elemTok = cursor.current()
				if not isTypeNameToken(elemTok) 'badElem'
					reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}' tuple element must be a type name, got '{tokenValueToString(elemTok.value)}'", line: elemTok.line, column: elemTok.column, filePath: filePath)
					skipToNextLine()
					throw ParserError.unhandledToken
				end 'badElem'
				_ = try consume()
				usedTypeAliases.insert(element: elemTok.value)
				elemNames.push(elemTok.value)
				if at(TokenKind.rightParen) 'doneTuple'
					break
				end 'doneTuple'
				try expect(TokenKind.comma)
			end 'tupleLoop'
			try expect(TokenKind.rightParen)
			if elemNames.count() < 2 'badArity'
				reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}' tuple must have at least 2 elements", line: baseToken.line, column: baseToken.column, filePath: filePath)
				throw ParserError.unhandledToken
			end 'badArity'
			let baseName = "__Tuple{elemNames.count()}"
			expr = UnresolvedTypeExpr.genericAlias(baseName, args: elemNames)
			sawValidBase = true
		end 'isTuple'

		if baseToken.kind == TokenKind.int or baseToken.kind == TokenKind.float 'isNumeric'
			let isFloat = baseToken.kind == TokenKind.float
			try eat(baseToken.kind)

			if not at(TokenKind.leftParen) 'noParen'
				var example = "int(0 to 100)"
				if isFloat 'floatEx'
					example = "float(f64.min to f64.max)"
				end 'floatEx'
				reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "typealias '{nameToken.value}' requires range bounds, e.g. {example}", line: baseToken.line, column: baseToken.column, filePath: filePath)
				skipToNextLine()
				throw ParserError.unhandledToken
			end 'noParen'

			try eat(TokenKind.leftParen)

			let parsed = try parseRangedPrimitiveBounds(baseToken, isFloat: isFloat)
			expr = parsed
			sawValidBase = true
		end 'isNumeric'

		// Bare sized-type shorthand `typealias Integer = i64` is rejected with
		// E2003, mirroring the C# bootstrap. Without this branch the bare-
		// identifier RHS path below would accept `i64` and the resolver later
		// would complain about an unknown type.
		if not sawValidBase and baseToken.kind == TokenKind.identifier and isSizedTypeName(baseToken.value) 'isBareSized'
			let nextTok = try cursor.peek(1) otherwise Token.eof()
			if nextTok.kind != TokenKind.dot 'notMinMax'
				reportCompileError(project, code: ErrorCode.parserExpectedType, message: "Bare sized type '{baseToken.value}' is not allowed. Use explicit range syntax, e.g. 'int({baseToken.value}.min to {baseToken.value}.max)'", line: baseToken.line, column: baseToken.column, filePath: filePath)
				skipToNextLine()
				throw ParserError.unhandledToken
			end 'notMinMax'
		end 'isBareSized'

		// Bare identifier RHS: `typealias A = B` aliases an existing named
		// type. The resolver picks up the chain in a later iteration once
		// the target alias is itself resolved, so source-text order doesn't
		// matter — `A` can be declared before or after `B`.
		//
		// Phase 11.0 step 2: generalized `typealias Foo = Base with(Args...)`.
		// Any base name is accepted; resolution into a `MaxonType.genericInstance`
		// is the resolver pass's job (TypeResolution.resolveAllGenericTypealiases).
		// The legacy `__ManagedMemory → i64` typealias-table seeding is preserved
		// as a side effect when the LHS is `__ManagedMemory`, so existing single-
		// arg `__ManagedMemory with X` aliases continue to resolve through the
		// StdType-typed `project.typealiases` map until step 5 swaps them over.
		if not sawValidBase and baseToken.kind == TokenKind.identifier 'isAliasName'
			let targetToken = try consume()
			// E3062: `typealias B = A` and `typealias E = Base with(A,B)` both
			// reference the named base/args explicitly.
			usedTypeAliases.insert(element: targetToken.value)
			if at(TokenKind.with) 'hasWith'
				try eat(TokenKind.with)
				var argNames = StringArray.create()
				// Phase 13 (sized typealiases): `typealias Vec1 = Vector with 1 Int`
				// — an int literal in the first positional slot encodes a
				// compile-time size. Captured to produce `sizedGenericAlias`;
				// distinct N produce distinct gids during resolution.
				var sizeLiteral = 0 as IntConstant
				var sawSize = false
				if at(TokenKind.intLiteral) 'isSizedHead'
					let sizeToken = try consume()
					let parsedSize = try parseInt(sizeToken.value) otherwise 'overflow'
						reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "typealias '{nameToken.value}': size literal '{tokenValueToString(sizeToken.value)}' exceeds int range", line: sizeToken.line, column: sizeToken.column, filePath: filePath)
						skipToNextLine()
						throw ParserError.unhandledToken
					end 'overflow'
					if parsedSize <= 0 'nonPositive'
						reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}': sized-typealias size must be positive, got {parsedSize}", line: sizeToken.line, column: sizeToken.column, filePath: filePath)
						skipToNextLine()
						throw ParserError.unhandledToken
					end 'nonPositive'
					sizeLiteral = parsedSize
					sawSize = true
				end 'isSizedHead'
				if accept(TokenKind.leftParen) 'parenList'
					while not at(TokenKind.rightParen) 'argLoop'
						let argToken = cursor.current()
						if not isTypeNameToken(argToken) 'badArg'
							reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}': expected type-name argument in 'with(...)', got '{tokenValueToString(argToken.value)}'", line: argToken.line, column: argToken.column, filePath: filePath)
							skipToNextLine()
							throw ParserError.unhandledToken
						end 'badArg'
						_ = try consume()
						usedTypeAliases.insert(element: argToken.value)
						argNames.push(argToken.value)
						if at(TokenKind.rightParen) 'doneAliasArgs'
							break
						end 'doneAliasArgs'
						try expect(TokenKind.comma)
					end 'argLoop'
					try expect(TokenKind.rightParen)
				end 'parenList' else 'bareArgs'
					// Bare (no-paren) `with` arg form. The first identifier is
					// mandatory; subsequent comma-separated identifiers are
					// captured greedily so a multi-`uses` target like
					// `typealias WithIterSelf = WithIterIterator with Iter, Element`
					// produces both `Iter` and `Element` as separate args.
					// Mirrors maxon-sharp `ParseWithTypeArgs`'s no-paren branch
					// (greedy comma consumption up to expectedCount; we don't
					// know expectedCount at parse time and stop on the first
					// non-identifier token, which is functionally equivalent
					// for the legal forms).
					var firstBareArg = true
					while firstBareArg or accept(TokenKind.comma) 'bareLoop'
						let argToken = cursor.current()
						if not isTypeNameToken(argToken) 'badBare'
							if firstBareArg 'mustHaveOne'
								reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}': '{targetToken.value} with' requires a type-name argument, got '{tokenValueToString(argToken.value)}'", line: argToken.line, column: argToken.column, filePath: filePath)
								skipToNextLine()
								throw ParserError.unhandledToken
							end 'mustHaveOne'
							// A consumed comma followed by a non-type-name
							// is malformed source (`with A, ,` or `with A, end`).
							// Report and stop — the comma has already been
							// consumed, so silently bailing would mis-position
							// the recovery cursor.
							reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}': expected type-name argument after ',' in '{targetToken.value} with', got '{tokenValueToString(argToken.value)}'", line: argToken.line, column: argToken.column, filePath: filePath)
							skipToNextLine()
							throw ParserError.unhandledToken
						end 'badBare'
						_ = try consume()
						usedTypeAliases.insert(element: argToken.value)
						argNames.push(argToken.value)
						firstBareArg = false
					end 'bareLoop'
				end 'bareArgs'

				if targetToken.value == "__ManagedMemory" 'isMmWith'
					// Preserve the legacy seeding so `__ManagedMemory` resolves
					// through the StdType typealias machinery. Phase 11.0 step 8a
					// ALSO captures the generic-alias form so per-instance type
					// flow (inner-alias substitution at methodCall sites) sees
					// the real `genericInstance(__ManagedMemory, [Element])`
					// rather than a bare named placeholder.
					try project.typealiases.insert("__ManagedMemory", value: StdType.i64) otherwise ignore
				end 'isMmWith'
				if sawSize 'sized'
					expr = UnresolvedTypeExpr.sizedGenericAlias(targetToken.value, size: sizeLiteral, args: argNames)
				end 'sized' else 'unsized'
					expr = UnresolvedTypeExpr.genericAlias(targetToken.value, args: argNames)
				end 'unsized'
				sawValidBase = true
			end 'hasWith' else 'noWith'
				expr = UnresolvedTypeExpr.aliasName(targetToken.value)
				sawValidBase = true
			end 'noWith'
		end 'isAliasName'

		if not sawValidBase 'unsupported'
			reportCompileError(project, code: ErrorCode.parserExpectedType, message: "typealias '{nameToken.value}' RHS must be 'bool', a ranged primitive (int(...)/float(...)), or another type name; got '{tokenValueToString(baseToken.value)}'", line: baseToken.line, column: baseToken.column, filePath: filePath)
			skipToNextLine()
			throw ParserError.unhandledToken
		end 'unsupported'

		return expr
	end 'parseTypealiasRhs'

	// Phase 11.0 step 2: parse a `typealias Name = ...` declaration that
	// appears inside a `type Body ... end` block. Cursor is AT the alias
	// name identifier (caller already consumed `typealias`). Records the
	// alias in `innerAliases` so the resolver pass can promote it once the
	// surrounding type is being lowered. Inner aliases are scoped to the
	// enclosing type — they are not added to `project.unresolvedTypealiases`.
	function parseInnerTypealias(typeName String, innerAliases InnerAliasMap) throws ParserError
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		try expect(TokenKind.equals)

		let expr = try parseTypealiasRhs(nameToken) otherwise return

		// Duplicate detection within the same type body. The map key is the
		// bare alias name — collisions across types are fine (alias names
		// are scoped to the type that declares them).
		if innerAliases.contains(nameToken.value) 'duplicate'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate inner typealias '{nameToken.value}' in type '{typeName}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			skipToNextLine()
			return
		end 'duplicate'

		innerAliases.upsert(nameToken.value, value: expr)
		skipToNextLine()
	end 'parseInnerTypealias'

	// --- Type declaration parsing ---

	// Parse: type Name ... end 'Name'
	//
	// Single linear walk over the body. Fields (var/let one-liners) by
	// convention come first; methods follow. We collect both as we go and
	// deposit an UnresolvedStructType at the end — the TypeResolution pass
	// drains it into project.structTypes. The parser does no cross-declaration
	// lookup; field-type validation and named-id resolution are the resolver's
	// job. Method bodies receive the fields array directly so they can register
	// self-field aliases without consulting any registry.
	//
	// entry: cursor AT the token AFTER `type` — the type-name identifier.
	// Caller (dispatchTopLevel) has already consumed the `type` keyword.
	function parseTypeDecl(visibility Visibility) throws ParserError
		let typeNameToken = try consume()
		checkReservedDeclName(typeNameToken)

		currentTypeName = typeNameToken.value
		// Stash the type's visibility so static fields, static methods, and
		// instance methods inside the body inherit it without the user
		// repeating the modifier on every member. Cleared below at end of
		// body so a sibling type at file scope starts fresh.
		currentTypeVisibility = visibility

		logTrace(LogCategory.parser, message: () gives "parser: type '{currentTypeName}'")

		// Phase 11.0: capture `uses T1, T2` (mirrors `parseInterfaceDecl`).
		// Commas are stripped at the lexer; the loop stops at the next
		// non-identifier token (`implements`, `where`, newline, function...).
		// Each name is also interned into `project.typeParameters` so a later
		// pass can resolve `MaxonType.typeParameter(id)` references back to
		// their constraint set. Bound into `currentTypeParams` for the body
		// so `parseTypeRef` can recognize them.
		var usesParams = StringArray.create()
		if accept(TokenKind.uses) 'hasUses'
			while at(TokenKind.identifier) 'usesLoop'
				let paramToken = try consume()
				usesParams.push(paramToken.value)
				_ = project.typeParameters.intern(currentTypeName, paramName: paramToken.value)
				if not accept(TokenKind.comma) 'doneUses'
					break
				end 'doneUses'
			end 'usesLoop'
			// Persist source-declaration order so getParamNames returns
			// the right pairing even when the registry's id-order gets
			// scrambled by out-of-order intern calls during cache restore.
			var paramCopy = StringArray.create()
			for n in usesParams 'copyUsesParams'
				paramCopy.push(n)
			end 'copyUsesParams'
			project.typeParameters.recordParamOrder(currentTypeName, paramOrder: paramCopy)
		end 'hasUses'
		currentTypeParams = usesParams

		// Phase 1b: capture `implements I1, I2 with X, ...` as metadata. No
		// validation here — Phase 3 resolves and checks the conformance set.
		let conformances = try parseImplementsClause()
		currentTypeConformances = conformances

		// Phase 11.0: capture `where T is Trait1 and Trait2, ...`. Each
		// constraint is also recorded against `project.typeParameters` so
		// later phases can resolve constraint sets without re-walking the
		// `whereClauses` array.
		var whereClauses = try parseWhereClause()
		// Phase 11.1 (step 5): stamp the declaring-type name onto every
		// where-clause entry so later substitution / constraint-checking can
		// disambiguate which type-parameter scope `wc.paramName` belongs to
		// (the `(declaringTypeName, paramName)` tuple is the type-param id key).
		for i in 0 upto whereClauses.count() 'recordConstraint'
			let wc = try whereClauses.get(i) otherwise panic("parseTypeDecl: whereClauses.get OOB at {i}")
			let pid = project.typeParameters.intern(currentTypeName, paramName: wc.paramName)
			project.typeParameters.addConstraint(pid, traitName: wc.requiredTraitName)
			let scoped = WhereClause.createScoped(wc.paramName, requiredTraitName: wc.requiredTraitName, declaringTypeName: currentTypeName)
			try whereClauses.set(i, value: scoped) otherwise panic("parseTypeDecl: whereClauses.set OOB at {i}")
		end 'recordConstraint'

		try skipNewlines()

		var fields = StructFieldArray.create()
		// Field offsets and struct byteSize are computed by the
		// `layoutAllStructs` pass in TypeResolution, after typealiases
		// have been resolved (so narrow-int enums can pick the right
		// per-field width). The parser stamps `offset: 0` /
		// `offsetResolved: false` placeholders; the pass overwrites both.
		// Phase 11.0 step 2: per-type table of `typealias Foo = ...` decls
		// that appear inside this body. Step 5+ consumes the table during
		// substitution; this step only stores them.
		var innerAliases = InnerAliasMap.create()

		while true 'body'
			let bodyPrevPos = cursor.index()
			let memberToken = cursor.current()

			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'

			// Field/method-level visibility modifiers. The `export` keyword
			// on a `var`/`let` field marks it as externally accessible
			// (`v.field` outside the type's own methods); without it the
			// field is private and external access raises E3014. The
			// contextual `module` modifier is parsed but treated as
			// advisory (visibility tier inheritance via the enclosing
			// type's modifier).
			var isExportedField = accept(TokenKind.export)
			let maybeMod = cursor.current()
			if maybeMod.kind == TokenKind.identifier and maybeMod.value == "module" 'maybeModuleField'
				let nextField = try cursor.peek(1) otherwise Token.eof()
				if nextField.kind == TokenKind.var or nextField.kind == TokenKind.let or nextField.kind == TokenKind.static or nextField.kind == TokenKind.function or nextField.kind == TokenKind.typealias 'isModuleField'
					try cursor.advance() otherwise break
					// `module var` makes the field accessible from any file
					// in the same module — the visibility check at field
					// load/store sites doesn't currently distinguish module-
					// scoped from fully-exported, so treat both as
					// externally-accessible (suppresses E3014). A future
					// cross-module visibility refinement would split the
					// flag back out.
					isExportedField = true
				end 'isModuleField'
			end 'maybeModuleField'

			let kindToken = cursor.current()
			if kindToken.kind == TokenKind.var or kindToken.kind == TokenKind.let 'isField'
				let isMutableField = kindToken.kind == TokenKind.var
				try eat(kindToken.kind)
				let fieldNameToken = try consume()
				checkReservedDeclName(fieldNameToken)
				// Shorthand `var f = literal` infers the type from the
				// literal's lead-token kind; the full form `var f T = expr`
				// parses the type explicitly and accepts any expression as
				// default. Both produce a synthetic helper function
				// `<TypeName>.__field_init_<fieldName>` so downstream
				// struct-literal lowerings can call it for any `Self{...}`
				// that omits the field.
				var fieldType = MaxonType.unresolved
				var hasFieldDefault = false
				if at(TokenKind.equals) 'shorthandForm'
					try eat(TokenKind.equals)
					fieldType = inferShorthandFieldType(cursor.current(), fieldNameToken: fieldNameToken)
					try parseFieldDefaultInitHelper(typeName: currentTypeName, fieldName: fieldNameToken.value, fieldType: fieldType, fieldLine: fieldNameToken.line)
					hasFieldDefault = true
				end 'shorthandForm' else 'typedForm'
					// Phase 11.0 step 3c: route field types through `parseTypeRef`
					// so `Self`, in-scope type parameters (`Element`), generic
					// instances (`__ManagedMemory with Element`), and function
					// types are all handled uniformly.
					fieldType = try parseTypeRef()
					if at(TokenKind.equals) 'hasDefault'
						try eat(TokenKind.equals)
						try parseFieldDefaultInitHelper(typeName: currentTypeName, fieldName: fieldNameToken.value, fieldType: fieldType, fieldLine: fieldNameToken.line)
						hasFieldDefault = true
					end 'hasDefault'
				end 'typedForm'
				// Offset is a placeholder; `layoutAllStructs` in TypeResolution
				// stamps the real offset (and flips `offsetResolved`) once
				// `field.fieldType` has been resolved against typealiases.
				fields.push(StructField.create(fieldNameToken.value, fieldType: fieldType, offset: 0, isMutable: isMutableField, hasDefault: hasFieldDefault, offsetResolved: false, isExported: isExportedField))
				try skipNewlines()
			end 'isField' else if kindToken.kind == TokenKind.typealias 'isInnerAlias'
				try eat(TokenKind.typealias)
				try parseInnerTypealias(currentTypeName, innerAliases: innerAliases)
				try skipNewlines()
			end 'isInnerAlias' else if kindToken.kind == TokenKind.static 'isStatic'
				try eat(TokenKind.static)
				let afterStatic = cursor.current()
				// Static decls (vars, lets, methods) inherit the enclosing
				// type's visibility so `T.field` is reachable exactly where
				// `T` is reachable.
				if afterStatic.kind == TokenKind.var 'sVar'
					try eat(TokenKind.var)
					try parseTopLevelDecl(typeName: currentTypeName, mutable: true, visibility: currentTypeVisibility)
				end 'sVar' else if afterStatic.kind == TokenKind.let 'sLet'
					try eat(TokenKind.let)
					try parseTopLevelDecl(typeName: currentTypeName, mutable: false, visibility: currentTypeVisibility)
				end 'sLet' else 'sFn'
					try eat(TokenKind.function)
					try parseFunction(currentTypeName, isInstance: false, fields: fields, visibility: currentTypeVisibility)
				end 'sFn'
				try skipNewlines()
			end 'isStatic' else if kindToken.kind == TokenKind.function 'isMethod'
				try eat(TokenKind.function)
				try parseFunction(currentTypeName, isInstance: true, fields: fields, visibility: currentTypeVisibility)
				try skipNewlines()
			end 'isMethod' else 'unknown'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token in type body: '{tokenValueToString(kindToken.value)}' (expected 'var', 'let', 'static', 'function', or 'typealias')", line: kindToken.line, column: kindToken.column, filePath: filePath)
				skipToNextLine()
				try skipNewlines()
			end 'unknown'

			// Stuck-guard: malformed type body must not infinite-loop the compile.
			if cursor.index() <= bodyPrevPos 'stuck'
				try cursor.advance() otherwise break
			end 'stuck'
		end 'body'

		// byteSize is a placeholder; `layoutAllStructs` in TypeResolution
		// overwrites it once every field's width is known.
		let unresolved = UnresolvedStructType.create(currentTypeName, fields: fields, byteSize: 0, visibility: visibility, line: typeNameToken.line, column: typeNameToken.column, filePath: filePath, implementedInterfaces: conformances, typeParams: usesParams, whereClauses: whereClauses, innerAliases: innerAliases)
		try project.unresolvedStructTypes.insert(currentTypeName, value: unresolved) otherwise 'dupType'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate type '{currentTypeName}'", line: typeNameToken.line, column: typeNameToken.column, filePath: filePath)
		end 'dupType'

		// Maintain the `structInnerAliasNames` reverse index alongside
		// every write into a struct's `innerAliases` map. Even on the
		// duplicate-type-error path above, the user's body still
		// registered these names — the original struct's body already
		// declared them, so reporting them as known suppresses cascading
		// E3009s for the same name.
		for (aliasName, _) in innerAliases 'recordAliasNames'
			project.structInnerAliasNames.insert(aliasName)
		end 'recordAliasNames'

		// Eager BuiltinArrayLiteral / BuiltinDictionaryLiteral discovery.
		// Walking conformances at type-registration time means each static
		// cache is populated by the time stdlib parsing finishes — which is
		// critical because user code's array/map literals trigger after stdlib's
		// `unresolvedStructTypes` has been drained by `resolveAllStructTypes`.
		// User types may also declare conformance to either protocol without
		// conflict — stdlib's `Array`/`Map` is registered first (each cache-set
		// short-circuits on a non-empty prior) and remains the canonical
		// desugaring target; user implementations are valid declarations but
		// don't displace the stdlib entry.
		for conf in conformances 'discoverBuiltins'
			if conf.interfaceName == "BuiltinArrayLiteral" 'isBal'
				if getCachedBuiltinArrayLiteralTypeName().isEmpty() 'firstImpl'
					setCachedBuiltinArrayLiteralTypeName(currentTypeName)
				end 'firstImpl'
			end 'isBal' else if conf.interfaceName == "BuiltinDictionaryLiteral" 'isBdl'
				if getCachedBuiltinDictionaryLiteralTypeName().isEmpty() 'firstImpl'
					setCachedBuiltinDictionaryLiteralTypeName(currentTypeName)
				end 'firstImpl'
			end 'isBdl'
		end 'discoverBuiltins'

		currentTypeName = ""
		currentTypeVisibility = Visibility.file
		// Phase 11.0: clear the in-scope type-param list so a sibling type at
		// file scope starts fresh. parseTypeRef checks for emptiness via
		// .count() so an empty StringArray is the correct sentinel.
		currentTypeParams = StringArray.create()
		currentTypeConformances = ConformanceArray.create()
		try skipEndAndLabel()
	end 'parseTypeDecl'

	// --- Enum declaration parsing ---
	//
	// Parse: enum Name [<cases and methods>] end 'Name'
	//
	// Each case becomes a top-level integer (or float) constant under the
	// `EnumName.caseName` qualified name, so subsequent `EnumName.caseName`
	// references resolve through the existing `unresolvedRead → literal`
	// rewrite path. The enum itself is registered as a typealias to int (or
	// f64 when float-backed) so parameters/return types/var declarations of
	// the enum type lower to a primitive width without further machinery.
	//
	// Methods: an enum may contain `function name(...)` declarations whose
	// bodies see the enum as the implicit `self` receiver type. They lower
	// like ordinary instance methods (the calling convention treats the
	// receiver as a same-width primitive in the first-arg slot).
	//
	// entry: cursor AT the token AFTER `enum` — the enum-name identifier.
	// Caller (dispatchTopLevel) has already consumed the `enum` keyword.
	function parseEnumDecl(visibility Visibility) throws ParserError
		let enumNameToken = try consume()
		checkReservedDeclName(enumNameToken)

		currentTypeName = enumNameToken.value
		// Stash the enum's visibility so per-case `TopLevelConstant`s, the
		// auto-injected typealias, and any methods declared in the body
		// inherit the same tier without the user repeating the modifier.
		currentEnumVisibility = visibility
		logTrace(LogCategory.parser, message: () gives "parser: enum '{currentTypeName}'")

		// Phase 1b: capture `implements I1, I2, ...` as metadata. The clause
		// follows the enum name (and precedes any newlines / cases), mirroring
		// the placement on `type` declarations. Phase 3 will validate.
		let conformances = try parseImplementsClause()

		// Pre-register an empty enum so method bodies parsed below can resolve
		// `match self` against the enum's named MaxonType. The full case list
		// is patched in once the body has been walked.
		let preRegisterEntry = UnresolvedEnumType.create(currentTypeName, cases: EnumCaseArray.create(), isFloatBacked: false, visibility: visibility, line: enumNameToken.line, column: enumNameToken.column, filePath: filePath, implementedInterfaces: conformances)
		try project.unresolvedEnums.insert(currentTypeName, value: preRegisterEntry) otherwise 'dupEnumPre'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate enum '{currentTypeName}'", line: enumNameToken.line, column: enumNameToken.column, filePath: filePath)
			currentTypeName = ""
			synchronize()
			return
		end 'dupEnumPre'

		try skipNewlines()

		var cases = EnumCaseArray.create()
		var caseNames = ReferencedVarSet.create()
		// Backing kind ('none' / 'int' / 'float' / 'string' / 'char') is
		// lazily fixed by the first explicit raw value. Float / string /
		// char backings are mutually exclusive with each other and with
		// per-case `= int` values; mixing kinds raises E3032.
		var hasExplicitBacking = false
		var isFloatBacked = false
		var isStringBacked = false
		var isCharBacked = false
		// Phase 9 Stage 5 (struct-backing): when a case carries
		// `= StructType{...}`, the struct type fixes the backing for every
		// case in the enum. Empty means no struct backing has been seen yet;
		// the first such case populates this, and subsequent cases must
		// match (E3032 on mismatch).
		var enumStructBackingTypeName = ""
		var nextOrdinal = 0 as IntConstant
		// Methods are emitted inline as the body is walked. The pre-registered
		// (empty-cases) UnresolvedEnumType above lets a method's `match self`
		// resolve `EnumName` as an enum even before the full case list lands.

		while true 'body'
			let bodyPrevPos = cursor.index()
			let memberToken = cursor.current()

			// `end` terminates the enum body when it is followed by the
			// block's `'Label'` literal; otherwise it is a keyword-named case
			// (covered by the `keyword-as-case-name` spec).
			if memberToken.kind == TokenKind.end and lookaheadIsBlockEnd() 'isEnd'
				break
			end 'isEnd'

			// Disambiguate `function` as method-keyword vs `function` as a
			// keyword-named enum case. Method form is always followed by an
			// identifier (the method name); case form is followed by either a
			// newline, an `=` (for an explicit raw value), or end-of-block.
			// An optional leading `export` is accepted so stdlib enum bodies
			// that explicitly spell out the visibility — `export function f`
			// — parse the same as the unprefixed form; enum methods inherit
			// the enclosing enum's visibility.
			var methodTokenOffset = 0 as ChainPeekOffset
			if memberToken.kind == TokenKind.export 'sawExport'
				methodTokenOffset = 1 as ChainPeekOffset
			end 'sawExport'
			let leadingFunc = try cursor.peek(methodTokenOffset) otherwise Token.eof()
			if leadingFunc.kind == TokenKind.function and lookaheadIsMethodSignatureAtOffset(methodTokenOffset) 'isMethod'
				if methodTokenOffset == 1 'eatExport'
					try eat(TokenKind.export)
				end 'eatExport'
				try eat(TokenKind.function)
				try parseEnumMethod(currentTypeName)
				try skipNewlines()
				if cursor.index() <= bodyPrevPos 'methodStuck'
					try cursor.advance() otherwise break
				end 'methodStuck'
				continue
			end 'isMethod'

			// A case name. Identifier or any keyword token (the enum spec
			// permits keyword tokens like `function`/`return`/`end`/`if` as
			// case names — the lexer emits them as their keyword TokenKind,
			// but `.value` carries the raw spelling).
			let caseToken = try consume()
			let caseName = caseToken.value
			checkReservedDeclName(caseToken)

			// Duplicate-case detection (E3030).
			let isDuplicateCase = caseNames.contains(caseName)
			if isDuplicateCase 'duplicateCase'
				reportCompileError(project, code: ErrorCode.semanticEnumDuplicateCase, message: "duplicate enum case: '{caseName}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
			end 'duplicateCase' else 'recordCase'
				caseNames.insert(element: caseName)
			end 'recordCase'

			var rawValue = nextOrdinal
			var rawIsFloat = false
			var caseBackingTypeName = ""
			var caseBackingExprId = 0 as UnresolvedConstExprId
			// Decoded text of a `caseName = "literal"` / `caseName = 'literal'`
			// raw value. Empty for cases that omit `=` or carry a numeric /
			// struct backing. Interpolation lowering reads this directly to
			// emit the user-visible rendering; `.rawValue` / `.fromName`
			// look it up the same way.
			var rawStringValue = ""

			if accept(TokenKind.equals) 'hasRawValue'
				let valueToken = cursor.current()
				// Negative numeric raw value: a unary `-` followed by an int
				// or float literal. The lexer emits `-` as its own token, so
				// peel it off, parse the magnitude, then negate. Mirrors how
				// negation handles a leading-minus in expression position.
				var rawSign = 1 as ParsedInt
				if valueToken.kind == TokenKind.minus 'hasMinus'
					try eat(TokenKind.minus)
					rawSign = -1 as ParsedInt
				end 'hasMinus'
				let magToken = cursor.current()
				if magToken.kind == TokenKind.intLiteral 'isInt'
					try eat(TokenKind.intLiteral)
					let mag = parseRawValueForEnum(magToken, kindLabel: "Integer", isFloat: false)
					let parsed = (mag * rawSign) as ParsedInt
					rawValue = parsed
					rawIsFloat = false
					if hasExplicitBacking and isFloatBacked 'mismatch'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected float, got int'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'mismatch'
					if not enumStructBackingTypeName.isEmpty() 'structVsIntMix'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got int'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'structVsIntMix'
					hasExplicitBacking = true
					nextOrdinal = parsed + 1
				end 'isInt' else if magToken.kind == TokenKind.floatLiteral 'isFloat'
					try eat(TokenKind.floatLiteral)
					var bits = parseRawValueForEnum(magToken, kindLabel: "Float", isFloat: true)
					if rawSign < 0 'negateFloat'
						// IEEE 754 sign bit is the MSB; XOR-toggle to negate.
						bits = (bits xor (1 shl 63)) as ParsedInt
					end 'negateFloat'
					rawValue = bits
					rawIsFloat = true
					if hasExplicitBacking and not isFloatBacked 'intMismatch'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected int, got float'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'intMismatch'
					if not enumStructBackingTypeName.isEmpty() 'structVsFloatMix'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got float'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'structVsFloatMix'
					hasExplicitBacking = true
					isFloatBacked = true
				end 'isFloat' else if magToken.kind == TokenKind.identifier and rawSign > 0 'isStructBacking'
					// Phase 9 Stage 5: `caseName = StructType{...}` /
					// `caseName = StructType.create(...)` — capture the per-case
					// struct backing literal. The struct type is fixed by the
					// first such case; subsequent cases must use the same type.
					// The cases keep their auto-assigned ordinal as the rawValue
					// (the runtime representation is the ordinal i64).
					let structTypeNameForCase = magToken.value
					if not enumStructBackingTypeName.isEmpty() and structTypeNameForCase != enumStructBackingTypeName 'wrongStructType'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got {structTypeNameForCase}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'wrongStructType'
					if hasExplicitBacking 'numericVsStruct'
						var priorBacking = "int"
						if isFloatBacked 'asFloat'
							priorBacking = "float"
						end 'asFloat'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {priorBacking}, got {structTypeNameForCase}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'numericVsStruct'
					let exprId = try parseConstStructLiteralRoot()
					caseBackingTypeName = structTypeNameForCase
					caseBackingExprId = exprId
					if enumStructBackingTypeName.isEmpty() 'firstStruct'
						enumStructBackingTypeName = structTypeNameForCase
					end 'firstStruct'
					rawValue = nextOrdinal
					rawIsFloat = false
					nextOrdinal = nextOrdinal + 1
				end 'isStructBacking' else if magToken.kind == TokenKind.stringLiteral and rawSign > 0 'isStringLit'
					// Phase 9 (string-backed enums): `caseName = "literal"`.
					// Runtime representation stays as the auto-incrementing
					// ordinal so `match` / equality / hashing all compile to
					// integer ops; the decoded string is stashed on the case
					// and used by interpolation, `.rawValue`, and `.fromName`.
					validateEscapes(magToken, kind: "string literal")
					try eat(TokenKind.stringLiteral)
					let decodedBytes = decodeStringEscapes(magToken.value)
					let decodedString = String.from(decodedBytes)
					if hasExplicitBacking and not isStringBacked 'stringMismatch'
						var priorBacking = "int"
						if isFloatBacked 'asFloat'
							priorBacking = "float"
						end 'asFloat'
						if isCharBacked 'asChar'
							priorBacking = "char"
						end 'asChar'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {priorBacking}, got string'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'stringMismatch'
					if not enumStructBackingTypeName.isEmpty() 'structVsStringMix'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got string'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'structVsStringMix'
					hasExplicitBacking = true
					isStringBacked = true
					rawValue = nextOrdinal
					rawIsFloat = false
					rawStringValue = decodedString
					nextOrdinal = nextOrdinal + 1
				end 'isStringLit' else if magToken.kind == TokenKind.charLiteral and rawSign > 0 'isCharLit'
					// Phase 9 (char-backed enums): `caseName = 'A'` /
					// `caseName = 'é'` (latin small e with acute).
					// Same shape as string-backed — runtime rep is the
					// ordinal; the decoded codepoint bytes drive
					// interpolation + lookup.
					validateEscapes(magToken, kind: "character literal")
					try eat(TokenKind.charLiteral)
					let decodedBytes = decodeStringEscapes(magToken.value)
					let decodedString = String.from(decodedBytes)
					if hasExplicitBacking and not isCharBacked 'charMismatch'
						var priorBacking = "int"
						if isFloatBacked 'asFloat'
							priorBacking = "float"
						end 'asFloat'
						if isStringBacked 'asString'
							priorBacking = "string"
						end 'asString'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {priorBacking}, got char'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'charMismatch'
					if not enumStructBackingTypeName.isEmpty() 'structVsCharMix'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got char'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'structVsCharMix'
					hasExplicitBacking = true
					isCharBacked = true
					rawValue = nextOrdinal
					rawIsFloat = false
					rawStringValue = decodedString
					nextOrdinal = nextOrdinal + 1
				end 'isCharLit' else 'badRawValue'
					reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "enum raw value must be an int, float, string, or character literal, got '{tokenValueToString(magToken.value)}'", line: magToken.line, column: magToken.column, filePath: filePath)
					try cursor.advance() otherwise break
				end 'badRawValue'
			end 'hasRawValue' else 'noRaw'
				if hasExplicitBacking and isFloatBacked 'floatRequiresExplicit'
					reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "float-backed enum case '{caseName}' requires an explicit raw value", line: caseToken.line, column: caseToken.column, filePath: filePath)
				end 'floatRequiresExplicit'
				if isStringBacked 'stringRequiresExplicit'
					reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected string, got int'", line: caseToken.line, column: caseToken.column, filePath: filePath)
				end 'stringRequiresExplicit'
				if isCharBacked 'charRequiresExplicit'
					reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected char, got int'", line: caseToken.line, column: caseToken.column, filePath: filePath)
				end 'charRequiresExplicit'
				if not enumStructBackingTypeName.isEmpty() 'structRequiresExplicit'
					reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {enumStructBackingTypeName}, got int'", line: caseToken.line, column: caseToken.column, filePath: filePath)
				end 'structRequiresExplicit'
				rawValue = nextOrdinal
				rawIsFloat = false
				nextOrdinal = nextOrdinal + 1
			end 'noRaw'

			// Duplicate-raw-value detection (E3031). Compares stored bit
			// payloads: int-backed cases use the integer value directly,
			// float-backed cases compare on IEEE-754 bits (which is exactly
			// the duplicate semantics — `1.1 == 1.1` shares bits). String /
			// char backings compare on the decoded text — the runtime
			// rawValue is the ordinal (always unique) so the int field can't
			// detect duplicate spellings. The diagnostic shows the raw bit
			// pattern for floats and the literal text for string/char; the
			// spec only requires the literal to appear in the message.
			let dupOnString = isStringBacked or isCharBacked
			for existing in cases 'checkDup'
				let isDupHit = (dupOnString and not rawStringValue.isEmpty() and existing.rawStringValue == rawStringValue) or (not dupOnString and existing.rawValue == rawValue)
				if isDupHit 'isDup'
					let dupShown = rawStringValue if dupOnString else "{rawValue}"
					reportCompileError(project, code: ErrorCode.semanticEnumDuplicateRawValue, message: "duplicate raw value: '{dupShown}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					break
				end 'isDup'
			end 'checkDup'

			// Skip the push for duplicate-case names so EnumType.create's
			// downstream unique-name invariant holds even when E3030 has
			// already been reported. The diagnostic above is the user-facing
			// signal; suppressing the second EnumCase entry keeps the IR
			// well-formed for the subsequent passes that walk this enum.
			if isDuplicateCase 'skipDup'
				try skipNewlines()
				continue
			end 'skipDup'

			let ordinalSlot = cases.count() as CaseOrdinal
			cases.push(EnumCase.create(caseName, ordinal: ordinalSlot, rawValue: rawValue, line: caseToken.line, column: caseToken.column, backingStructName: caseBackingTypeName, backingStructExprId: caseBackingExprId, rawStringValue: rawStringValue))

			// Register the case as a top-level constant so the existing
			// `unresolvedRead → literal` rewrite resolves `EnumName.case`.
			// Cases inherit the enum's visibility tier so cross-file reads
			// of `Direction.north` succeed exactly when the enum itself is
			// reachable from the reading file.
			let qualifiedName = "{currentTypeName}.{caseName}"
			var constValue = ConstantValue.intValue(rawValue)
			if rawIsFloat 'isFloatConst'
				constValue = ConstantValue.floatValue(rawValue)
			end 'isFloatConst'
			let caseEntry = TopLevelConstant.create(constValue, visibility: currentEnumVisibility, sourceFilePath: filePath)
			try project.topLevelConstants.insert(qualifiedName, value: caseEntry) otherwise ignore

			try skipNewlines()

			if cursor.index() <= bodyPrevPos 'caseStuck'
				try cursor.advance() otherwise break
			end 'caseStuck'
		end 'body'

		// Register the enum as a typealias so parameter / return / var
		// declarations of the enum type resolve via the typealias machinery.
		// Float-backed enums alias to f64; int-backed alias to int(lo to hi)
		// where `lo` widens to the smallest negative raw value so that
		// `computeOptimalIntType` picks a signed narrow StdType for enums
		// with negative raw values.
		var enumTypeExpr = UnresolvedTypeExpr.rangedInt(enumIntLowerBound(cases), upper: enumIntUpperBound(cases))
		if isFloatBacked 'asFloatExpr'
			enumTypeExpr = UnresolvedTypeExpr.rangedFloat(f64MinBits(), upper: f64MaxBits())
		end 'asFloatExpr'
		if not project.typealiases.contains(currentTypeName) and not project.unresolvedTypealiases.contains(currentTypeName) 'registerAlias'
			project.unresolvedTypealiases.upsert(currentTypeName, value: UnresolvedTypealias.create(currentTypeName, expr: enumTypeExpr, visibility: visibility, line: enumNameToken.line, column: enumNameToken.column, filePath: filePath))
		end 'registerAlias'

		// Patch the pre-registered placeholder with the full case list. The
		// duplicate-name diagnostic was already issued above when we tried to
		// insert the placeholder, so this upsert is unconditional.
		let unresolvedEnum = UnresolvedEnumType.create(currentTypeName, cases: cases, isFloatBacked: isFloatBacked, visibility: visibility, line: enumNameToken.line, column: enumNameToken.column, filePath: filePath, implementedInterfaces: conformances, isStringBacked: isStringBacked, isCharBacked: isCharBacked)
		project.unresolvedEnums.upsert(currentTypeName, value: unresolvedEnum)

		// Phase 9 Stage 5: synthesize the per-enum `.fromRawValue` /
		// `.fromName` lookup helpers. The parser-side call-site rewrite
		// (in parseIdentifierExpr's static-call arm) targets these names
		// directly, so they must exist before any call sites get parsed
		// — but bodies emitted here go through the regular call-resolution
		// pipeline along with every other user-written function. Struct-
		// backed enums skip the `.fromRawValue` synthesis: the raw value
		// is a struct literal, not an int, so the lookup form
		// `EnumName.fromRawValue(intLit)` is rejected per
		// `enum-struct-backing.md`'s `error.struct-backing-fromRawValue`
		// test (E3034 unknown enum case). `.fromName` stays synthesized so
		// the user-facing `Name → Case` mapping still works on struct-
		// backed enums (the spec doesn't forbid it).
		// String / char backings keep the runtime rawValue at the ordinal
		// so the synthesized `int(ordinal) -> EnumName` lookup we use for
		// int-backed enums would always succeed but for the wrong reason.
		// `.fromRawValue("Active")` is a separate user-facing surface — to
		// be added when a spec demands it — so skip the helper for now in
		// the same way struct-backed enums skip it.
		let skipFromRawHelper = (not enumStructBackingTypeName.isEmpty()) or isStringBacked or isCharBacked
		synthesizeEnumLookupHelpers(enumName: currentTypeName, cases: cases, isFloatBacked: isFloatBacked, visibility: visibility, line: enumNameToken.line, column: enumNameToken.column, skipFromRawValue: skipFromRawHelper)

		currentTypeName = ""
		currentEnumVisibility = Visibility.file
		try skipEndAndLabel()
	end 'parseEnumDecl'

	// --- Union declaration parsing (Phase 9 Stage 2) ---
	//
	// Parse: union Name [implements I1, I2]
	//            caseName                          # bare case (no payload)
	//            caseName(field1 T1, field2 T2)    # payload case
	//            function method() ...             # method
	//        end 'Name'
	//
	// Unions share `project.unresolvedEnums` storage with enums (the
	// `isUnion` flag distinguishes them); resolution machinery is identical
	// except for the typealias-injection step. A union value is a heap
	// pointer with distinct type identity — `internMaxonType` returns
	// `MaxonType.named(unionName)` and lowering keeps it 8 bytes wide. No
	// ranged-int alias is registered.
	//
	// Bare cases register a `TopLevelConstant` keyed `UnionName.caseName`
	// so existing `Type.case` reads work unchanged. Payload cases skip the
	// constant registration and synthesise a constructor function
	// (`__construct_{UnionName}_{caseName}`) so `Type.case(args)` lowers
	// through TypeResolution's normal call path.
	function parseUnionDecl(visibility Visibility) throws ParserError
		let unionNameToken = try consume()
		checkReservedDeclName(unionNameToken)

		currentTypeName = unionNameToken.value
		currentEnumVisibility = visibility
		logTrace(LogCategory.parser, message: () gives "parser: union '{currentTypeName}'")

		let conformances = try parseImplementsClause()

		// Pre-register with an empty case list so method bodies parsed below
		// resolve `match self` against the union's named MaxonType. Patched
		// once the body has been walked.
		let preRegisterEntry = UnresolvedEnumType.create(currentTypeName, cases: EnumCaseArray.create(), isFloatBacked: false, visibility: visibility, line: unionNameToken.line, column: unionNameToken.column, filePath: filePath, implementedInterfaces: conformances, isUnion: true)
		try project.unresolvedEnums.insert(currentTypeName, value: preRegisterEntry) otherwise 'dupUnionPre'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate union '{currentTypeName}'", line: unionNameToken.line, column: unionNameToken.column, filePath: filePath)
			currentTypeName = ""
			synchronize()
			return
		end 'dupUnionPre'

		try skipNewlines()

		var cases = EnumCaseArray.create()
		var caseNames = ReferencedVarSet.create()
		// Phase 9 Stage 5 (struct-backing): the first case carrying
		// `= StructType{...}` fixes the union's backing struct type. Later
		// cases must use the same type — mismatch raises E3032.
		var unionStructBackingTypeName = ""

		while true 'body'
			let bodyPrevPos = cursor.index()
			let memberToken = cursor.current()

			if memberToken.kind == TokenKind.end and lookaheadIsBlockEnd() 'isEnd'
				break
			end 'isEnd'

			// `function` as method-keyword vs `function` as a keyword-named
			// union case mirrors the enum rule: method form is always followed
			// by an identifier (the method name); case form is followed by `(`
			// or a newline / block end. An optional `export` prefix on the
			// method is accepted (and discarded) so stdlib union bodies that
			// spell out the visibility — `export function displayName(...)` —
			// parse the same way as the unprefixed form; union methods
			// inherit the enclosing union's visibility, so a leading `export`
			// here is redundant rather than wrong.
			var methodTokenOffset = 0 as ChainPeekOffset
			if memberToken.kind == TokenKind.export 'sawExport'
				methodTokenOffset = 1 as ChainPeekOffset
			end 'sawExport'
			let leadingFunc = try cursor.peek(methodTokenOffset) otherwise Token.eof()
			if leadingFunc.kind == TokenKind.function and lookaheadIsMethodSignatureAtOffset(methodTokenOffset) 'isMethod'
				if methodTokenOffset == 1 'eatExport'
					try eat(TokenKind.export)
				end 'eatExport'
				try eat(TokenKind.function)
				try parseEnumMethod(currentTypeName)
				try skipNewlines()
				if cursor.index() <= bodyPrevPos 'methodStuck'
					try cursor.advance() otherwise break
				end 'methodStuck'
				continue
			end 'isMethod'

			let caseToken = try consume()
			let caseName = caseToken.value
			checkReservedDeclName(caseToken)

			let isDuplicateCase = caseNames.contains(caseName)
			if isDuplicateCase 'duplicateCase'
				reportCompileError(project, code: ErrorCode.semanticEnumDuplicateCase, message: "duplicate union case: '{caseName}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
			end 'duplicateCase' else 'recordCase'
				caseNames.insert(element: caseName)
			end 'recordCase'

			var payloadFields = EnumPayloadFieldArray.create()
			if accept(TokenKind.leftParen) 'hasPayload'
				try parseUnionCasePayload(payloadFields)
			end 'hasPayload'

			// Phase 9 Stage 5 (struct-backing): optional
			// `= StructType{...}` / `= StructType.create(...)` after the
			// optional payload list. Cross-case consistency is required: every
			// case must use the same struct type.
			var caseBackingTypeName = ""
			var caseBackingExprId = 0 as UnresolvedConstExprId
			if accept(TokenKind.equals) 'hasBacking'
				let valueToken = cursor.current()
				if valueToken.kind != TokenKind.identifier 'badBacking'
					reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "union case backing must be 'StructType\{...\}' or 'StructType.create(...)', got '{tokenValueToString(valueToken.value)}'", line: valueToken.line, column: valueToken.column, filePath: filePath)
					try cursor.advance() otherwise break
				end 'badBacking' else 'isStructBacking'
					let structTypeNameForCase = valueToken.value
					if not unionStructBackingTypeName.isEmpty() and structTypeNameForCase != unionStructBackingTypeName 'wrongStructType'
						reportCompileError(project, code: ErrorCode.semanticEnumRawValueTypeMismatch, message: "raw value type mismatch: 'expected {unionStructBackingTypeName}, got {structTypeNameForCase}'", line: caseToken.line, column: caseToken.column, filePath: filePath)
					end 'wrongStructType'
					let exprId = try parseConstStructLiteralRoot()
					caseBackingTypeName = structTypeNameForCase
					caseBackingExprId = exprId
					if unionStructBackingTypeName.isEmpty() 'firstStruct'
						unionStructBackingTypeName = structTypeNameForCase
					end 'firstStruct'
				end 'isStructBacking'
			end 'hasBacking'

			if isDuplicateCase 'skipDup'
				try skipNewlines()
				continue
			end 'skipDup'

			let ordinalSlot = cases.count() as CaseOrdinal
			cases.push(EnumCase.create(caseName, ordinal: ordinalSlot, rawValue: ordinalSlot as IntConstant, line: caseToken.line, column: caseToken.column, payloadFields: payloadFields, backingStructName: caseBackingTypeName, backingStructExprId: caseBackingExprId))

			// Phase 9 Stage 3: every union case — bare or payload-bearing —
			// is heap-boxed so all values of the union type share a uniform
			// `i64 tag + maxArity*8 payload` shape. The match-side tag
			// dispatch then unconditionally loads the tag from offset 0
			// without needing to distinguish bare vs payload cases at
			// lowering time. Bare cases get a no-arg constructor
			// `__construct_Union_Bare()` returning the boxed union value.
			synthesizeUnionConstructor(unionName: currentTypeName, caseName: caseName, payloadFields: payloadFields, line: caseToken.line, column: caseToken.column, visibility: visibility)

			try skipNewlines()

			if cursor.index() <= bodyPrevPos 'caseStuck'
				try cursor.advance() otherwise break
			end 'caseStuck'
		end 'body'

		// Patch the pre-registered placeholder with the full case list. Union
		// names do NOT get an int/float-ranged typealias — `internMaxonType`
		// hands out `MaxonType.named(currentTypeName)` and lowering treats
		// the value as an 8-byte heap pointer. The duplicate-name diagnostic
		// was already issued above when the placeholder insert failed.
		let unresolvedUnion = UnresolvedEnumType.create(currentTypeName, cases: cases, isFloatBacked: false, visibility: visibility, line: unionNameToken.line, column: unionNameToken.column, filePath: filePath, implementedInterfaces: conformances, isUnion: true)
		project.unresolvedEnums.upsert(currentTypeName, value: unresolvedUnion)

		// Phase 9 Stage 4: synthesize the `.unionCases` companion bare-enum
		// per `specs/union-cases.md`. One bare case per variant of the
		// union, ordinals matching the parent union's tag values. The
		// companion has its own MaxonType identity + typealias + per-case
		// TopLevelConstant entries, so `Shape.unionCases.circle` resolves
		// through the same plumbing as `Color.red` — and `.allCases` /
		// `.allCaseNames` reuse the Stage 1 emitters automatically. Only
		// emitted when the union has at least one payload-bearing case;
		// plain enums already expose `.allCases` directly.
		registerUnionCasesCompanion(unionName: currentTypeName, cases: cases, visibility: visibility, line: unionNameToken.line, column: unionNameToken.column)

		currentTypeName = ""
		currentEnumVisibility = Visibility.file
		try skipEndAndLabel()
	end 'parseUnionDecl'

	// Phase 9 Stage 4: register the `<UnionName>.unionCases` companion enum.
	// One bare case per variant of the parent union; ordinals match the
	// parent's tag values; rawValue defaults to ordinal so `.rawValue` and
	// `.fromRawValue` round-trip cleanly. Skipped when no case carries a
	// payload — plain enums already provide the same surface natively, and
	// the spec only mandates the companion for unions with associated values.
	function registerUnionCasesCompanion(unionName String, cases EnumCaseArray, visibility Visibility, line LineNumber, column ColumnNumber)
		var hasPayload = false
		for c in cases 'scanPayload'
			if c.payloadFields.count() > 0 'isPayloadCase'
				hasPayload = true
				break
			end 'isPayloadCase'
		end 'scanPayload'
		if not hasPayload 'noCompanion'
			return
		end 'noCompanion'
		let companionName = "{unionName}.unionCases"
		// Avoid duplicate registration when a union is re-parsed (e.g. fragment
		// regeneration with `--update-required`).
		if project.unresolvedEnums.contains(companionName) or project.enumTypes.contains(companionName) 'alreadyRegistered'
			return
		end 'alreadyRegistered'
		var companionCases = EnumCaseArray.create()
		for i in 0 upto cases.count() 'eachCase'
			let c = try cases.get(i) otherwise panic("registerUnionCasesCompanion: cases.get OOB at {i}")
			// Mirror the parent case's ordinal so `.rawValue` agrees with the
			// union's tag value (the natural pairing for de/serialization).
			companionCases.push(EnumCase.create(c.name, ordinal: c.ordinal, rawValue: c.ordinal as IntConstant, line: c.line, column: c.column, payloadFields: EnumPayloadFieldArray.create()))
		end 'eachCase'
		let companionUnresolved = UnresolvedEnumType.create(companionName, cases: companionCases, isFloatBacked: false, visibility: visibility, line: line, column: column, filePath: filePath, implementedInterfaces: ConformanceArray.create(), isUnion: false)
		try project.unresolvedEnums.insert(companionName, value: companionUnresolved) otherwise ignore
		// Register each case as a top-level integer constant so the lookup
		// path in `parseIdentifierExpr` finds `Shape.unionCases.circle`.
		for i in 0 upto companionCases.count() 'eachConst'
			let c = try companionCases.get(i) otherwise panic("registerUnionCasesCompanion: companionCases.get OOB at {i}")
			let qualifiedName = "{companionName}.{c.name}"
			let caseEntry = TopLevelConstant.create(ConstantValue.intValue(c.rawValue), visibility: visibility, sourceFilePath: filePath)
			try project.topLevelConstants.insert(qualifiedName, value: caseEntry) otherwise ignore
		end 'eachConst'
		// Register a typealias `companionName → int(0 to N)` so a value of
		// the companion enum can flow through let/var/param slots the same
		// way bare enum values do.
		let aliasExpr = UnresolvedTypeExpr.rangedInt(0, upper: enumIntUpperBound(companionCases))
		if not project.typealiases.contains(companionName) and not project.unresolvedTypealiases.contains(companionName) 'registerAlias'
			project.unresolvedTypealiases.upsert(companionName, value: UnresolvedTypealias.create(companionName, expr: aliasExpr, visibility: visibility, line: line, column: column, filePath: filePath))
		end 'registerAlias'

		// Phase 9 Stage 5: the companion is itself a bare enum, so it gets
		// the same `.fromRawValue` / `.fromName` lookup helpers a
		// standalone enum would. `Shape.unionCases.fromRawValue(0)` then
		// dispatches through `__enum_Shape.unionCases_fromRawValue`.
		synthesizeEnumLookupHelpers(enumName: companionName, cases: companionCases, isFloatBacked: false, visibility: visibility, line: line, column: column)
	end 'registerUnionCasesCompanion'

	// Parse the parenthesized payload-field list for a union case after the
	// opening `(` has been consumed. Each field is `name Type`, separated by
	// commas. On a malformed entry we synchronize past the `)` so the outer
	// case loop can advance to the next case without losing state.
	function parseUnionCasePayload(payloadFields EnumPayloadFieldArray) throws ParserError
		if at(TokenKind.rightParen) 'emptyPayload'
			try eat(TokenKind.rightParen)
			return
		end 'emptyPayload'

		while true 'fieldLoop'
			let fieldNameToken = try consumeExpecting("identifier")
			if not tokenIsIdentifierLike(fieldNameToken) 'badName'
				reportTokenMismatch(fieldNameToken, expectedDisplay: "identifier")
				synchronize()
				return
			end 'badName'

			checkReservedDeclName(fieldNameToken)

			let fieldType = try parseTypeRef()
			if at(TokenKind.rightParen) and isUnresolvedMaxonType(fieldType) 'recovered'
				try eat(TokenKind.rightParen)
				return
			end 'recovered'

			payloadFields.push(EnumPayloadField.create(fieldNameToken.value, fieldType: fieldType))

			if at(TokenKind.rightParen) 'doneList'
				try eat(TokenKind.rightParen)
				return
			end 'doneList'
			try expect(TokenKind.comma)
		end 'fieldLoop'
	end 'parseUnionCasePayload'

	// Register a synthetic constructor function for a payload union case.
	// Each `caseName(field1 T1, field2 T2)` payload variant gets a function
	// `__construct_{UnionName}_{caseName}(field1 T1, field2 T2) returns {UnionName}`
	// so `EnumName.caseName(args)` resolves through TypeResolution's call
	// path. Stage 2 leaves the body as a single `MaxonOp.error` placeholder
	// — Stage 3 will emit the actual alloc + per-field store sequence.
	function synthesizeUnionConstructor(unionName String, caseName String, payloadFields EnumPayloadFieldArray, line LineNumber, column ColumnNumber, visibility Visibility)
		let funcName = unionConstructorSymbolName(unionName, caseName: caseName)
		if project.funcReturnTypes.contains(funcName) 'alreadyRegistered'
			// Duplicate-case detection already reported E3030 — the parser
			// suppresses the second case push but may still reach this
			// synthesis path. Skip silently rather than overwriting.
			return
		end 'alreadyRegistered'

		var paramNames = StringArray.create()
		var paramTypes = MaxonTypeArray.create()
		var paramDefaults = ParamDefaultArray.create()
		for i in 0 upto payloadFields.count() 'eachField'
			let field = try payloadFields.get(i) otherwise panic("synthesizeUnionConstructor: payloadFields.get OOB at {i}")
			paramNames.push(field.name)
			paramTypes.push(field.fieldType)
			paramDefaults.push(ParamDefault.none)
		end 'eachField'

		let returnMaxonType = internMaxonType(project, name: unionName)
		let returnType = MaxonReturnType.value(returnMaxonType)

		// Register signature + return type so call-site argument reordering
		// and named-arg defaults pick the synthetic function up exactly like
		// a user-written `static function`.
		try project.funcReturnTypes.insert(funcName, value: returnType) otherwise panic("synthesizeUnionConstructor: funcReturnTypes collision on '{funcName}'")
		try project.funcSignatures.insert(funcName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise panic("synthesizeUnionConstructor: funcSignatures collision on '{funcName}'")
		project.methodNameIndex.record(funcName)
		try project.funcVisibilities.insert(funcName, value: FuncVisibilityInfo.create(visibility, sourceFilePath: filePath)) otherwise ignore
		try project.funcThrowsTypes.insert(funcName, value: ThrowsClause.none) otherwise ignore

		// Build the synthetic body: declare a slot per payload field,
		// `varLoad` each (so the resulting name is bound for the
		// `enumConstruct` operand list), `enumConstruct` the union value,
		// and return it. Slot indices match the param positions by
		// construction — `func.scope` starts empty and `declare` hands out
		// slots in declaration order, so slot 0 = first param, etc.
		// Mirrors how a user-written `function name(args) ...` body
		// observes its parameters.
		var func = IrFunction.create(funcName, maxonReturnType: returnType, paramCount: paramTypes.count() as ParamCount, maxonParamTypes: paramTypes, returnLine: line, throwsTypeName: ThrowsClause.none)
		func.namespace = namespace
		func.visibility = visibility
		func.sourceFilePath = filePath
		func.nameLine = line
		func.nameColumn = column
		var bodyBlock = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: line)
		var payloadValueNames = ByteArrayArray.create()
		for i in 0 upto payloadFields.count() 'eachField'
			let field = try payloadFields.get(i) otherwise panic("synthesizeUnionConstructor: payloadFields.get OOB at {i}")
			let slot = func.scope.declare(field.name, varType: field.fieldType, mutable: false)
			let loadedName = "__ctor_arg_{i}".toByteArray()
			module.appendOp(bodyBlock, op: MaxonOp.varLoad(loadedName, slotId: slot, slotType: field.fieldType, range: SourceRange.none()))
			payloadValueNames.push(loadedName)
		end 'eachField'
		let resultName = "__ctor_result".toByteArray()
		module.appendOp(bodyBlock, op: MaxonOp.enumConstruct(resultName, enumName: unionName, caseName: caseName, payloadValues: payloadValueNames, range: SourceRange.none()))
		module.setTerminator(bodyBlock, op: MaxonOp.ret(resultName, range: SourceRange.none()))
		module.functions.push(func)
	end 'synthesizeUnionConstructor'

	// Phase 9 Stage 5: returns true when `enumName` resolves to a union
	// type (one with any case carrying associated values). The parser
	// uses this to decide whether `<Name>.fromRawValue(...)` and
	// `<Name>.fromName(...)` calls should be redirected to a synthesized
	// lookup helper. Pure unions (associated-value cases) are excluded
	// because their `.fromRawValue` is explicitly rejected by the spec
	// (E3034 from TypeResolution) and their `.fromName` needs a
	// payload-routing path not yet synthesized. The `.unionCases`
	// companion enums are bare enums (their cases have no payload fields),
	// so they take the regular helper path.
	function enumIsAssociatedValueUnion(enumName String) returns bool
		if let resolved = try project.enumTypes.get(enumName) 'isResolved'
			return resolved.isUnion
		end 'isResolved'
		if let unresolved = try project.unresolvedEnums.get(enumName) 'isUnresolved'
			return unresolved.isUnion
		end 'isUnresolved'
		return false
	end 'enumIsAssociatedValueUnion'

	// Phase 9 Stage 5: true when at least one case on `enumName` carries a
	// `= StructType{...}` / `= StructType.create(...)` backing literal. Used
	// to suppress `.fromRawValue(...)` rewrite (the struct rawValue can't
	// be reconstructed from an int) per `error.struct-backing-fromRawValue`.
	function enumIsStructBacked(enumName String) returns bool
		if let resolved = try project.enumTypes.get(enumName) 'isResolved'
			for c in resolved.cases 'scan'
				if not c.backingStructName.isEmpty() 'hit'
					return true
				end 'hit'
			end 'scan'
		end 'isResolved'
		if let unresolved = try project.unresolvedEnums.get(enumName) 'isUnresolved'
			for c in unresolved.cases 'scan2'
				if not c.backingStructName.isEmpty() 'hit2'
					return true
				end 'hit2'
			end 'scan2'
		end 'isUnresolved'
		return false
	end 'enumIsStructBacked'

	// Phase 9 Stage 5: synthesize the `__enum_<EnumName>_fromRawValue(raw)`
	// and `__enum_<EnumName>_fromName(name)` lookup helpers for a bare-enum
	// type (or a union's `.unionCases` companion, which is itself a bare
	// enum). Both helpers throw the enum's own type on a miss — `try /
	// otherwise` doesn't bind the error value in any of today's specs, so
	// reusing the enum as the throws type avoids inventing a dedicated
	// `__EnumLookupFailure` enum and keeps lowering's `errorReturn(0, flag)`
	// shape unchanged.
	//
	// `fromRawValue` compares the receiver against each case's rawValue and
	// returns the matched rawValue. For float-backed enums the comparisons
	// use f64-eq; the return slot also lowers as f64. `fromName` compares
	// against the case-name strings via `String.equals(...)`.
	//
	// Skipped for unions with associated values — the spec rejects
	// `Union.fromRawValue(...)` outright (E3034), and `Union.fromName(...)`
	// for associated-value unions needs a heap-allocating construction path
	// that mirrors `synthesizeUnionConstructor` plus payload-arg routing.
	// That richer form is deferred until a downstream spec demands it; the
	// 3 enum-full `fromName-associated-*` fragments stay non-whitelisted
	// for the same reason.
	function synthesizeEnumLookupHelpers(enumName String, cases EnumCaseArray, isFloatBacked bool, visibility Visibility, line LineNumber, column ColumnNumber, skipFromRawValue bool = false)
		if cases.count() == 0 'noCases'
			// Degenerate enum: skip helper synthesis. The empty-case enum is
			// already an E3030 / E2004 violation surfaced upstream; emitting
			// helpers here would create a one-block function with a single
			// `throw` and no return, which Verifier flags as unreachable.
			return
		end 'noCases'
		if not skipFromRawValue 'emitFromRaw'
			synthesizeEnumFromRawValueHelper(enumName, cases: cases, isFloatBacked: isFloatBacked, visibility: visibility, line: line, column: column)
		end 'emitFromRaw'
		synthesizeEnumFromNameHelper(enumName, cases: cases, isFloatBacked: isFloatBacked, visibility: visibility, line: line, column: column)
	end 'synthesizeEnumLookupHelpers'

	// Synthesize `__enum_<EnumName>_fromRawValue(raw <RawType>) returns
	// <EnumName> throws <EnumName>`. The body is a linear chain of cmp +
	// condBr blocks, one per case. On a hit, return the matched rawValue
	// (which for bare enums IS the runtime representation). On full
	// fall-through, throw the enum's first case as a sentinel.
	function synthesizeEnumFromRawValueHelper(enumName String, cases EnumCaseArray, isFloatBacked bool, visibility Visibility, line LineNumber, column ColumnNumber)
		let funcName = enumFromRawValueSymbolName(enumName)
		if project.funcReturnTypes.contains(funcName) 'alreadyRegistered'
			return
		end 'alreadyRegistered'

		let rawType = MaxonType.float if isFloatBacked else MaxonType.integer
		let enumMaxonType = internMaxonType(project, name: enumName)
		var paramNames = StringArray.create()
		paramNames.push("raw")
		var paramTypes = MaxonTypeArray.create()
		paramTypes.push(rawType)
		var paramDefaults = ParamDefaultArray.create()
		paramDefaults.push(ParamDefault.none)

		let returnType = MaxonReturnType.value(enumMaxonType)
		let throwsClause = ThrowsClause.throwing(enumName)

		try project.funcReturnTypes.insert(funcName, value: returnType) otherwise panic("synthesizeEnumFromRawValueHelper: funcReturnTypes collision on '{funcName}'")
		try project.funcSignatures.insert(funcName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise panic("synthesizeEnumFromRawValueHelper: funcSignatures collision on '{funcName}'")
		project.methodNameIndex.record(funcName)
		try project.funcVisibilities.insert(funcName, value: FuncVisibilityInfo.create(visibility, sourceFilePath: filePath)) otherwise ignore
		try project.funcThrowsTypes.insert(funcName, value: throwsClause) otherwise ignore

		var func = IrFunction.create(funcName, maxonReturnType: returnType, paramCount: 1 as ParamCount, maxonParamTypes: paramTypes, returnLine: line, throwsTypeName: throwsClause)
		func.namespace = namespace
		func.visibility = visibility
		func.sourceFilePath = filePath
		func.nameLine = line
		func.nameColumn = column

		// Swap in a clean synth-counter so names minted for this helper
		// don't collide with the caller's parser state. The helper has no
		// user-written body so the saved counter restores back to the
		// caller's stream unchanged.
		let savedFunc = currentFunc
		let savedBlock = currentBlock
		let savedSynth = synthNameCounter
		currentFunc = func
		synthNameCounter = 0

		// Declare the `raw` parameter as the function's first slot. The
		// `varLoad` that follows reads its value into an SSA name we can
		// compare against each case's raw value.
		let rawSlot = func.scope.declare("raw", varType: rawType, mutable: false)
		var entryBlock = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: line)
		currentBlock = entryBlock
		let rawName = freshSynthName()
		module.appendOp(entryBlock, op: MaxonOp.varLoad(rawName, slotId: rawSlot, slotType: rawType, range: SourceRange.none()))

		// Chain of comparisons: for each case, emit a cmp + condBr to the
		// per-case return block, threading the else-target through the next
		// check block. The final miss falls through to a throw block.
		// The throw-on-miss block is created once and shared by every
		// per-case `else` target on the last iteration. The remaining
		// non-last iterations branch into a fresh `check_{i+1}` block.
		var throwBlock = module.addBlockAt(func, label: "no_match_throw", filePath: filePath.toString(), firstLine: line)
		var currentCheck = entryBlock
		let caseCount = cases.count()
		for i in 0 upto caseCount 'eachCase'
			let c = try cases.get(i) otherwise panic("synthesizeEnumFromRawValueHelper: cases.get OOB at {i}")
			var returnBlock = module.addBlockAt(func, label: "case_{i}_return", filePath: filePath.toString(), firstLine: line)
			let isLast = i == caseCount - 1
			// Pre-allocate the next-check block for non-last iterations. On the
			// last iteration the miss falls into `throwBlock` directly, so no
			// further check block is needed.
			var nextCheck = currentCheck
			if not isLast 'allocNext'
				nextCheck = module.addBlockAt(func, label: "check_{i + 1}", filePath: filePath.toString(), firstLine: line)
			end 'allocNext'

			// cmp raw == case.rawValue
			let litValueType = MaxonType.float if isFloatBacked else MaxonType.integer
			let litName = freshSynthName()
			module.appendOp(currentCheck, op: MaxonOp.literal(litName, value: c.rawValue, valueType: litValueType, range: SourceRange.none()))
			let cmpName = freshSynthName()
			module.appendOp(currentCheck, op: MaxonOp.cmp(cmpName, left: rawName, right: litName, predicate: CmpPredicate.eq, leftType: rawType, rightType: rawType, operandType: rawType, range: SourceRange.none()))
			let elseTarget = throwBlock.id if isLast else nextCheck.id
			module.setTerminator(currentCheck, op: MaxonOp.condBr(cmpName, thenTarget: returnBlock.id, elseTarget: elseTarget, range: SourceRange.none()))

			// Per-case return body: emit the case's rawValue and return it.
			currentBlock = returnBlock
			let resultLitName = freshSynthName()
			module.appendOp(returnBlock, op: MaxonOp.literal(resultLitName, value: c.rawValue, valueType: litValueType, range: SourceRange.none()))
			module.setTerminator(returnBlock, op: MaxonOp.ret(resultLitName, range: SourceRange.none()))

			currentCheck = nextCheck
		end 'eachCase'

		// Final miss: throw the enum's first case as a sentinel value. The
		// throws ABI carries (value: 0, flag: ordinal+1); callers' `try /
		// otherwise` only inspect the flag's nonzeroness in today's specs,
		// so the variant choice is purely a placeholder. Using the first
		// case (ordinal 0) keeps the flag a stable `1` across every helper.
		let firstCase = try cases.get(0) otherwise panic("synthesizeEnumFromRawValueHelper: cases.get(0) failed despite count check")
		// Empty payload-value name: `fromRawValue` is only synthesized for
		// bare-case enums (Phase 9 Stage 5 gates struct-backed / union enums
		// out), so the throw never needs to carry a union pointer.
		module.setTerminator(throwBlock, op: MaxonOp.throw(enumName, variantName: firstCase.name, payloadValueName: ByteArray.create(), range: SourceRange.none()))

		// Stage K.4: no livenessRoot push. `EnumName.fromRawValue(...)`
		// user calls are rewritten to `call __enum_<EnumName>_fromRawValue`
		// ops via `enumFromRawValueSymbolName` (MaxonDialect.maxon), so
		// the DFE call-edge walk reaches the helper when needed.
		module.functions.push(func)

		currentFunc = savedFunc
		currentBlock = savedBlock
		synthNameCounter = savedSynth
	end 'synthesizeEnumFromRawValueHelper'

	// Synthesize `__enum_<EnumName>_fromName(name String) returns <EnumName>
	// throws <EnumName>`. Body shape mirrors `fromRawValue` but the
	// per-case comparison is `name.equals("<caseName>")` (a methodCall the
	// String extension intercepts at lowering) instead of a primitive cmp.
	// Returns the case's rawValue on a hit.
	function synthesizeEnumFromNameHelper(enumName String, cases EnumCaseArray, isFloatBacked bool, visibility Visibility, line LineNumber, column ColumnNumber)
		let funcName = enumFromNameSymbolName(enumName)
		if project.funcReturnTypes.contains(funcName) 'alreadyRegistered'
			return
		end 'alreadyRegistered'

		let stringMaxonType = MaxonType.named(project.typeNames.intern("String"))
		let enumMaxonType = internMaxonType(project, name: enumName)
		var paramNames = StringArray.create()
		paramNames.push("name")
		var paramTypes = MaxonTypeArray.create()
		paramTypes.push(stringMaxonType)
		var paramDefaults = ParamDefaultArray.create()
		paramDefaults.push(ParamDefault.none)

		let returnType = MaxonReturnType.value(enumMaxonType)
		let throwsClause = ThrowsClause.throwing(enumName)

		try project.funcReturnTypes.insert(funcName, value: returnType) otherwise panic("synthesizeEnumFromNameHelper: funcReturnTypes collision on '{funcName}'")
		try project.funcSignatures.insert(funcName, value: FuncSignature.create(paramNames, paramTypes: paramTypes, paramDefaults: paramDefaults)) otherwise panic("synthesizeEnumFromNameHelper: funcSignatures collision on '{funcName}'")
		project.methodNameIndex.record(funcName)
		try project.funcVisibilities.insert(funcName, value: FuncVisibilityInfo.create(visibility, sourceFilePath: filePath)) otherwise ignore
		try project.funcThrowsTypes.insert(funcName, value: throwsClause) otherwise ignore

		var func = IrFunction.create(funcName, maxonReturnType: returnType, paramCount: 1 as ParamCount, maxonParamTypes: paramTypes, returnLine: line, throwsTypeName: throwsClause)
		func.namespace = namespace
		func.visibility = visibility
		func.sourceFilePath = filePath
		func.nameLine = line
		func.nameColumn = column

		let savedFunc = currentFunc
		let savedBlock = currentBlock
		let savedSynth = synthNameCounter
		currentFunc = func
		synthNameCounter = 0

		let nameSlot = func.scope.declare("name", varType: stringMaxonType, mutable: false)
		var entryBlock = module.addBlockAt(func, label: "entry", filePath: filePath.toString(), firstLine: line)
		currentBlock = entryBlock
		let receiverName = freshSynthName()
		module.appendOp(entryBlock, op: MaxonOp.varLoad(receiverName, slotId: nameSlot, slotType: stringMaxonType, range: SourceRange.none()))

		let litValueType = MaxonType.float if isFloatBacked else MaxonType.integer
		// Shared throw-on-miss block — see the fromRawValue helper for the
		// rationale on a single shared sink.
		var throwBlock = module.addBlockAt(func, label: "no_match_throw", filePath: filePath.toString(), firstLine: line)
		var currentCheck = entryBlock
		let caseCount = cases.count()
		for i in 0 upto caseCount 'eachCase'
			let c = try cases.get(i) otherwise panic("synthesizeEnumFromNameHelper: cases.get OOB at {i}")
			var returnBlock = module.addBlockAt(func, label: "case_{i}_return", filePath: filePath.toString(), firstLine: line)
			let isLast = i == caseCount - 1
			var nextCheck = currentCheck
			if not isLast 'allocNext'
				nextCheck = module.addBlockAt(func, label: "check_{i + 1}", filePath: filePath.toString(), firstLine: line)
			end 'allocNext'

			// Build a string literal for the case name and call
			// `name.equals(<caseName>)`. The methodCall result type is
			// pinned by TypeResolution from the receiver's String type.
			let caseNameStringId = project.strings.intern(c.name)
			let caseNameLitName = freshSynthName()
			module.appendOp(currentCheck, op: MaxonOp.stringConst(caseNameLitName, stringId: caseNameStringId, range: SourceRange.none()))
			var equalsArgs = ByteArrayArray.create()
			equalsArgs.push(caseNameLitName)
			var equalsArgLabels = StringArray.create()
			equalsArgLabels.push("")
			var equalsArgTypes = MaxonTypeArray.create()
			equalsArgTypes.push(stringMaxonType)
			var equalsArgRanges = SourceRangeArray.create()
			equalsArgRanges.push(SourceRange.none())
			let cmpName = freshSynthName()
			module.appendOp(currentCheck, op: MaxonOp.methodCall(cmpName, receiver: receiverName, methodName: "equals".toByteArray(), args: equalsArgs, argLabels: equalsArgLabels, argTypes: equalsArgTypes, argRanges: equalsArgRanges, range: SourceRange.none()))
			let elseTarget = throwBlock.id if isLast else nextCheck.id
			module.setTerminator(currentCheck, op: MaxonOp.condBr(cmpName, thenTarget: returnBlock.id, elseTarget: elseTarget, range: SourceRange.none()))

			currentBlock = returnBlock
			let resultLitName = freshSynthName()
			module.appendOp(returnBlock, op: MaxonOp.literal(resultLitName, value: c.rawValue, valueType: litValueType, range: SourceRange.none()))
			module.setTerminator(returnBlock, op: MaxonOp.ret(resultLitName, range: SourceRange.none()))

			currentCheck = nextCheck
		end 'eachCase'

		let firstCase = try cases.get(0) otherwise panic("synthesizeEnumFromNameHelper: cases.get(0) failed despite count check")
		// Empty payload-value name: `fromName` is only synthesized for
		// bare-case enums; the throw carries no union pointer.
		module.setTerminator(throwBlock, op: MaxonOp.throw(enumName, variantName: firstCase.name, payloadValueName: ByteArray.create(), range: SourceRange.none()))

		// Stage K.4: no livenessRoot push. `EnumName.fromName(...)` user
		// calls are rewritten to `call __enum_<EnumName>_fromName` ops via
		// `enumFromNameSymbolName` (MaxonDialect.maxon), so the DFE
		// call-edge walk reaches the helper when needed.
		module.functions.push(func)

		currentFunc = savedFunc
		currentBlock = savedBlock
		synthNameCounter = savedSynth
	end 'synthesizeEnumFromNameHelper'

	// --- Interface declaration parsing ---
	//
	// Parse: interface Name [extends Parent1, Parent2] [uses Elem1, Elem2]
	//            function name(params) [returns Type] [throws ErrorType]
	//            ...
	//        end 'Name'
	//
	// Interface bodies are signature-only: each method line is one statement
	// with no body and no trailing `end 'name'`. The parser captures the
	// declaration as an `UnresolvedInterfaceType` and deposits it in
	// `project.unresolvedInterfaces`. Phase 3 of the interfaces plan drains
	// the map into a resolved registry once method-signature types resolve.
	//
	// entry: cursor AT the token AFTER `interface` — the interface-name identifier.
	// Caller (dispatchInner) has already consumed the `interface` keyword.
	function parseInterfaceDecl(visibility Visibility) throws ParserError
		let nameToken = try consume()
		checkReservedDeclName(nameToken)

		logTrace(LogCategory.parser, message: () gives "parser: interface '{nameToken.value}'")

		// Commas are skipped at the lexer (see actionTable's skipOther) so the
		// extends/uses lists land as plain runs of identifiers. The loop stops
		// when the next token isn't another identifier — which lands us at
		// `uses`, `function`, `end`, or a newline. Bare-name capture mirrors
		// stdlib/Interfaces.maxon's `extends Iterator` / `uses Element, Iter`.
		var extendsNames = StringArray.create()
		if accept(TokenKind.extends) 'hasExtends'
			while at(TokenKind.identifier) 'extLoop'
				let parentToken = try consume()
				extendsNames.push(parentToken.value)
				if not accept(TokenKind.comma) 'doneExtends'
					break
				end 'doneExtends'
			end 'extLoop'
		end 'hasExtends'

		var usesParams = StringArray.create()
		if accept(TokenKind.uses) 'hasUses'
			while at(TokenKind.identifier) 'usesLoop'
				let paramToken = try consume()
				usesParams.push(paramToken.value)
				if not accept(TokenKind.comma) 'doneIfaceUses'
					break
				end 'doneIfaceUses'
			end 'usesLoop'
		end 'hasUses'

		// Inheritance of `uses` parameters from `extends` parents is
		// performed by `TypeResolution.inheritInterfaceUsesParams`, which
		// runs after every interface (including cross-file ones) has been
		// recorded — the parser only sees its own file, so the lookup
		// would be best-effort against `unresolvedInterfaces` here.

		try skipNewlines()

		var methods = InterfaceMethodSigArray.create()

		// Phase 9.7: stamp the interface name as the current type so
		// `Self` inside method signatures (`function clone() returns Self`,
		// `function equals(other Self) returns bool`) resolves to the
		// interface's own type slot. Saved/restored so a nested decl (none
		// today, but future-proof) doesn't lose the outer context.
		let savedTypeName = currentTypeName
		currentTypeName = nameToken.value

		while true 'body'
			let bodyPrevPos = cursor.index()
			let memberToken = cursor.current()

			if memberToken.kind == TokenKind.end and lookaheadIsBlockEnd() 'isEnd'
				break
			end 'isEnd'

			// Visibility modifiers on interface members are accepted and
			// ignored — interface methods are public requirements regardless.
			if memberToken.kind == TokenKind.export 'isExport'
				try eat(TokenKind.export)
				try skipNewlines()
				continue
			end 'isExport'

			// Skip nested typealias declarations inside interfaces (e.g.
			// `typealias ElementArray = Array with Element`). They contribute
			// to associated-type resolution rather than method requirements.
			if memberToken.kind == TokenKind.typealias 'isAlias'
				skipToNextLine()
				try skipNewlines()
				continue
			end 'isAlias'

			// `static function` is allowed before the method name to mark
			// factory-style interface requirements (e.g. BuiltinStringLiteral.init).
			var isStaticMethod = false
			if memberToken.kind == TokenKind.static 'isStatic'
				try eat(TokenKind.static)
				isStaticMethod = true
			end 'isStatic'

			let methodToken = cursor.current()
			if methodToken.kind == TokenKind.function 'isMethod'
				try eat(TokenKind.function)
				let sig = try parseInterfaceMethodSig(isStatic: isStaticMethod)
				methods.push(sig)
				try skipNewlines()
			end 'isMethod' else 'unknown'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token in interface body: '{tokenValueToString(methodToken.value)}' (expected 'function' or 'end')", line: methodToken.line, column: methodToken.column, filePath: filePath)
				skipToNextLine()
				try skipNewlines()
			end 'unknown'

			if cursor.index() <= bodyPrevPos 'stuck'
				try cursor.advance() otherwise break
			end 'stuck'
		end 'body'

		currentTypeName = savedTypeName

		if project.unresolvedInterfaces.contains(nameToken.value) 'duplicate'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate interface '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
		end 'duplicate' else 'register'
			let unresolved = UnresolvedInterfaceType.create(nameToken.value, extendsNames: extendsNames, usesParams: usesParams, methods: methods, visibility: visibility, line: nameToken.line, column: nameToken.column, filePath: filePath)
			project.unresolvedInterfaces.upsert(nameToken.value, value: unresolved)
		end 'register'

		try skipEndAndLabel()
	end 'parseInterfaceDecl'

	// Parse one interface method signature: `name(param Type, ...) [returns Type] [throws ErrorType]`.
	// No method body, no `end 'name'` — the signature is a single line. Param
	// types and the return type are interned through `internMaxonType`; the
	// throws-clause type is captured as the bare error-enum name (empty when
	// absent) so Phase 3 can resolve it once `unresolvedInterfaces` drains.
	// entry: cursor AT the method-name identifier (caller ate `function`).
	// exit:  cursor on the first token AFTER the signature (the trailing newline).
	function parseInterfaceMethodSig(isStatic bool) returns InterfaceMethodSig throws ParserError
		let nameToken = try consumeExpecting("identifier")
		checkReservedDeclName(nameToken)

		try expect(TokenKind.leftParen)

		var paramNames = StringArray.create()
		var paramTypes = MaxonTypeArray.create()
		// Suppress generic-instance consumption inside the param list — see
		// parseFunctionParameters for rationale.
		let savedInFunctionParam = inFunctionParam
		inFunctionParam = true

		// Parameter pairs are `name Type` separated by commas. Stop when the
		// next token is the closing `)`.
		while not at(TokenKind.rightParen) 'paramLoop'
			let paramNameToken = try consumeExpecting("identifier")
			if not tokenIsIdentifierLike(paramNameToken) 'badName'
				reportTokenMismatch(paramNameToken, expectedDisplay: "identifier")
				synchronize()
				return InterfaceMethodSig.create(nameToken.value, paramNames: paramNames, paramTypes: paramTypes, returnType: MaxonReturnType.void, throwsTypeName: ThrowsClause.none, isStatic: isStatic, line: nameToken.line, column: nameToken.column)
			end 'badName'
			checkReservedDeclName(paramNameToken)
			// Function-typed interface params must work too. Return-type
			// parsing (below) stays single-token for now — Stage A's tests
			// don't exercise function-typed interface return positions.
			let paramType = try parseTypeRef()
			if at(TokenKind.rightParen) and isUnresolvedMaxonType(paramType) 'recovered'
				return InterfaceMethodSig.create(nameToken.value, paramNames: paramNames, paramTypes: paramTypes, returnType: MaxonReturnType.void, throwsTypeName: ThrowsClause.none, isStatic: isStatic, line: nameToken.line, column: nameToken.column)
			end 'recovered'
			paramNames.push(paramNameToken.value)
			paramTypes.push(paramType)
			if at(TokenKind.rightParen) 'doneIfaceParams'
				break
			end 'doneIfaceParams'
			try expect(TokenKind.comma)
		end 'paramLoop'

		try expect(TokenKind.rightParen)
		inFunctionParam = savedInFunctionParam

		var returnType = MaxonReturnType.void
		if accept(TokenKind.returns) 'hasReturn'
			// Use parseTypeRef so `Self` resolves through the enclosing
			// interface's `currentTypeName` and so any same-named local
			// typealias gets tracked for E3062 (unused) — both behaviors
			// were missing when this site read a single token directly.
			returnType = MaxonReturnType.value(try parseTypeRef())
		end 'hasReturn'

		let throwsName = try parseThrowsClause()

		return InterfaceMethodSig.create(nameToken.value, paramNames: paramNames, paramTypes: paramTypes, returnType: returnType, throwsTypeName: throwsName, isStatic: isStatic, line: nameToken.line, column: nameToken.column)
	end 'parseInterfaceMethodSig'

	// Phase 11.0 step 4: real parser for `extension TargetType ... end`.
	// Methods declared inside the body are registered as qualified
	// `TargetType.methodName` callees on `project` at parse time (via the
	// shared `parseFunction` path). The per-extension metadata —
	// type-parameter rebinding, added conformances, where-clauses — is
	// captured into `project.unresolvedExtensions` for later resolution.
	//
	// Grammar (matches stdlib/Array.maxon):
	//     extension Target [uses T1, T2] [implements I1, I2] [where T is Trait1 and Trait2]
	//         [export] [static] function ... end
	//         ...
	//     end 'Target'
	//
	// entry: cursor AT the token AFTER `extension` (the target-type name).
	// Caller (dispatchInner) has already consumed the `extension` keyword.
	// J.4b: peek the upcoming `function` body's method-name token without
	// consuming it. parseFunction will consume the identifier itself; we
	// just snapshot the bare name so the outer extension can record the
	// `<targetType>.<methodName>` mapping. Returns "" on a malformed
	// extension body so the caller can skip the registration silently.
	function peekIdentifierForExtensionMethod() returns String
		let tok = cursor.current()
		if tok.kind == TokenKind.identifier 'isIdent'
			return tok.value
		end 'isIdent'
		return ""
	end 'peekIdentifierForExtensionMethod'

	function parseExtension(visibility Visibility) throws ParserError
		let targetNameToken = try consumeExpecting("type name")
		let targetTypeName = targetNameToken.value

		// Optional `uses T1, T2` rebinds the target type's parameter names
		// for the body of this extension. When absent, we inherit the
		// target's `uses` parameters verbatim by looking the target up in
		// `unresolvedStructTypes` (works in-file because Maxon parses
		// declarations top-down, and stdlib/Array.maxon places its
		// extensions after the `type Array uses Element` declaration).
		var targetTypeParams = StringArray.create()
		if accept(TokenKind.uses) 'hasUses'
			while at(TokenKind.identifier) 'usesLoop'
				let paramToken = try consume()
				targetTypeParams.push(paramToken.value)
				_ = project.typeParameters.intern(targetTypeName, paramName: paramToken.value)
				if not accept(TokenKind.comma) 'doneExtUses'
					break
				end 'doneExtUses'
			end 'usesLoop'
		end 'hasUses' else 'inheritParams'
			// Target hasn't been parsed yet (cross-file extension or
			// out-of-order declaration) → leave `targetTypeParams` empty
			// so step 5 can diagnose at resolution time. Otherwise inherit
			// the target's `uses` parameter names verbatim. Extension targets
			// can be either struct types (`extension Array`) or interfaces
			// (`extension HasItems where Element is Equatable`); both kinds
			// declare `uses` parameters that the body needs in scope.
			if let target = try project.unresolvedStructTypes.get(targetTypeName) 'haveTarget'
				for i in 0 upto target.typeParams.count() 'copyParams'
					let p = try target.typeParams.get(i) otherwise panic("parseExtension: typeParams.get OOB at {i}")
					targetTypeParams.push(p)
				end 'copyParams'
			end 'haveTarget' else 'tryInterface'
				if let ifaceTarget = try project.unresolvedInterfaces.get(targetTypeName) 'haveIface'
					for i in 0 upto ifaceTarget.usesParams.count() 'copyIfaceParams'
						let p = try ifaceTarget.usesParams.get(i) otherwise panic("parseExtension: usesParams.get OOB at {i}")
						targetTypeParams.push(p)
						_ = project.typeParameters.intern(targetTypeName, paramName: p)
					end 'copyIfaceParams'
				end 'haveIface'
			end 'tryInterface'
		end 'inheritParams'

		// Push the parser's type-context stack so method bodies can resolve
		// `Self`, the target type's parameters (`Element`), and field
		// references (handled below via the `fields` argument to
		// `parseFunction`).
		let savedTypeName = currentTypeName
		let savedTypeParams = currentTypeParams
		let savedTypeVisibility = currentTypeVisibility
		currentTypeName = targetTypeName
		currentTypeParams = targetTypeParams
		currentTypeVisibility = visibility

		// Optional `implements I1, I2 [with(...)]` clause for added
		// conformances. Step 5 validates these against the target type
		// once the where-clause is satisfied for an observed instantiation.
		let addedConformances = try parseImplementsClause()

		// Optional `where T is Trait1 and Trait2 [, T2 is Trait3 ...]`
		// clause for a *conditional* extension. Unlike a type declaration's
		// own where-clause, an extension's constraints don't restrict the
		// base type itself — `Array with Integer` is still well-formed when
		// `Integer` isn't `Equatable`; only the methods added by
		// `extension Array where Element is Equatable` become unavailable.
		// So we must NOT call `project.typeParameters.addConstraint` here:
		// doing so would make `validateConstraintsFor` fire E3017 on every
		// `Array with X` instantiation. The constraints stay attached to the
		// UnresolvedExtension and drive conditional dispatch at lowering.
		var whereClauses = try parseWhereClause()
		for i in 0 upto whereClauses.count() 'stampDeclaringType'
			let wc = try whereClauses.get(i) otherwise panic("parseExtension: whereClauses.get OOB at {i}")
			let scoped = WhereClause.createScoped(wc.paramName, requiredTraitName: wc.requiredTraitName, declaringTypeName: targetTypeName)
			try whereClauses.set(i, value: scoped) otherwise panic("parseExtension: whereClauses.set OOB at {i}")
		end 'stampDeclaringType'

		try skipNewlines()

		// Resolve the target type's field list so instance methods inside
		// the extension can resolve bare identifiers as `self.field`. When
		// the target hasn't been parsed yet, fall through with an empty
		// list; bare-field references will fail to resolve and surface as
		// regular undefined-identifier diagnostics.
		var fields = StructFieldArray.create()
		if let targetForFields = try project.unresolvedStructTypes.get(targetTypeName) 'haveTargetFields'
			for f in targetForFields.fields 'copyFields'
				fields.push(f)
			end 'copyFields'
		end 'haveTargetFields'

		// Inner `typealias` declarations (e.g. `typealias ElementArray =
		// Array with Element` inside an extension body) parse through the
		// same inner-typealias entry as a type declaration's body. They
		// land on a per-call local map; step 5+ folds the entries into the
		// target struct's `innerAliases` during resolution.
		var extInnerAliases = InnerAliasMap.create()

		// J.4b: collect the qualified names of methods parsed inside this
		// extension body. parseFunction registers each method's identifier
		// token; we peek at it before consuming so the captured names are
		// the same `<targetType>.<methodName>` keys used in funcSignatures
		// / funcReturnTypes. After the body loop, we walk this list and
		// stamp the extension's whereClauses into
		// `project.extensionMethodWhereClauses` for the E4006 lookup.
		var extensionMethodNames = StringArray.create()

		while true 'body'
			let bodyPrevPos = cursor.index()
			let memberToken = cursor.current()

			if memberToken.kind == TokenKind.end 'isEnd'
				break
			end 'isEnd'

			// Visibility prefix on extension methods is allowed — the
			// extension's own visibility tier is the inherited default,
			// so the `export` token is consumed but ignored (mirrors the
			// type-body dispatch at parseTypeDecl).
			_ = accept(TokenKind.export)

			let kindToken = cursor.current()
			if kindToken.kind == TokenKind.typealias 'isInnerAlias'
				try eat(TokenKind.typealias)
				try parseInnerTypealias(targetTypeName, innerAliases: extInnerAliases)
				try skipNewlines()
			end 'isInnerAlias' else if kindToken.kind == TokenKind.static 'isStatic'
				try eat(TokenKind.static)
				try eat(TokenKind.function)
				let methodName = peekIdentifierForExtensionMethod()
				try parseFunction(targetTypeName, isInstance: false, fields: fields, visibility: currentTypeVisibility)
				if not methodName.isEmpty() 'recordStatic'
					extensionMethodNames.push("{targetTypeName}.{methodName}")
				end 'recordStatic'
				try skipNewlines()
			end 'isStatic' else if kindToken.kind == TokenKind.function 'isFn'
				try eat(TokenKind.function)
				let methodName = peekIdentifierForExtensionMethod()
				try parseFunction(targetTypeName, isInstance: true, fields: fields, visibility: currentTypeVisibility)
				if not methodName.isEmpty() 'recordFn'
					extensionMethodNames.push("{targetTypeName}.{methodName}")
				end 'recordFn'
				try skipNewlines()
			end 'isFn' else 'unknown'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token in extension body: '{tokenValueToString(kindToken.value)}' (expected 'function', 'static', or 'typealias')", line: kindToken.line, column: kindToken.column, filePath: filePath)
				skipToNextLine()
				try skipNewlines()
			end 'unknown'

			// Stuck-guard: malformed extension body must not infinite-loop.
			if cursor.index() <= bodyPrevPos 'stuck'
				try cursor.advance() otherwise break
			end 'stuck'
		end 'body'

		// Restore the parser's type-context stack before returning.
		currentTypeName = savedTypeName
		currentTypeParams = savedTypeParams
		currentTypeVisibility = savedTypeVisibility

		// Record the extension metadata for step 5+'s where-clause and
		// conditional-conformance resolution. Methods themselves are
		// already in `project.funcSignatures` etc. via the parseFunction
		// calls above, qualified as `targetTypeName.methodName`.
		let unresolvedExt = UnresolvedExtension.create(targetTypeName, targetTypeParams: targetTypeParams, addedConformances: addedConformances, whereClauses: whereClauses, visibility: visibility, line: targetNameToken.line, column: targetNameToken.column, filePath: filePath)
		project.unresolvedExtensions.push(unresolvedExt)

		// J.4b: stamp each method declared inside this extension body with
		// the extension's whereClauses so resolveMethodCallSite can issue
		// E4006 for un-satisfied conditional availability without rescanning
		// the unresolvedExtensions list at every call site.
		for methodKey in extensionMethodNames 'recordWhere'
			try project.extensionMethodWhereClauses.insert(methodKey, value: whereClauses) otherwise ignore
		end 'recordWhere'

		// Phase 11.0 step 8a: merge inner-typealias entries declared inside
		// the extension body into the target's UnresolvedStructType so the
		// post-parse resolver promotes them through the same path as the
		// type's own inner aliases. Skip silently when the target was
		// already drained or never declared in this project — the original
		// extension methods will surface that error on their own.
		if extInnerAliases.count() > 0 'mergeInner'
			mergeExtensionInnerAliases(targetTypeName, extInnerAliases: extInnerAliases)
		end 'mergeInner'

		try skipEndAndLabel()
	end 'parseExtension'

	// Phase 11.0 step 8a helper: lift the mutating-call out of `parseExtension`
	// so the `try ... otherwise return` form skips silently when the target
	// type isn't declared yet (or was already drained).
	//
	// Targets fall into two buckets: `extension SomeStruct` writes into the
	// struct's `innerAliases`; `extension SomeInterface` writes into the
	// interface's. Without the interface branch, the parser would silently
	// drop the alias for interface targets, breaking method bodies that
	// reference it. The "neither bucket has the target" path stays silent —
	// the extension's methods themselves will surface the missing-target
	// diagnostic.
	function mergeExtensionInnerAliases(targetTypeName String, extInnerAliases InnerAliasMap)
		if var target = try project.unresolvedStructTypes.get(targetTypeName) 'structTarget'
			for (aliasName, aliasExpr) in extInnerAliases 'eachAlias'
				if not target.innerAliases.contains(aliasName) 'novel'
					target.innerAliases.upsert(aliasName, value: aliasExpr)
				end 'novel'
				// Record the reverse-index entry regardless of whether
				// this extension introduced it or the struct already had
				// it — Set.insert is idempotent and the "novel" check
				// above only gates the per-struct map write.
				project.structInnerAliasNames.insert(aliasName)
			end 'eachAlias'
			project.unresolvedStructTypes.upsert(targetTypeName, value: target)
			return
		end 'structTarget'

		if var iface = try project.unresolvedInterfaces.get(targetTypeName) 'ifaceTarget'
			for (aliasName, aliasExpr) in extInnerAliases 'eachIfaceAlias'
				if not iface.innerAliases.contains(aliasName) 'novelIface'
					iface.innerAliases.upsert(aliasName, value: aliasExpr)
				end 'novelIface'
			end 'eachIfaceAlias'
			project.unresolvedInterfaces.upsert(targetTypeName, value: iface)
			return
		end 'ifaceTarget'
	end 'mergeExtensionInnerAliases'

	// True when the cursor is positioned on `end` *followed by* the
	// `'Label'` literal that closes a block (or end-of-input). Used by
	// parseEnumDecl and the match parsers to distinguish the block
	// terminator from a keyword-named enum case (see `keyword-as-case-name`
	// spec). Treats EOF as a block end so callers don't spin past the input.
	function lookaheadIsBlockEnd() returns bool
		let next = try cursor.peek(1) otherwise return true
		return next.kind == TokenKind.charLiteral
	end 'lookaheadIsBlockEnd'

	// True when the cursor is positioned on a match block's terminating
	// `end '<label>'`.
	function isMatchArmsEnd() returns bool
		if not at(TokenKind.end) 'notEnd'
			return false
		end 'notEnd'
		return lookaheadIsBlockEnd()
	end 'isMatchArmsEnd'

	// True when the cursor is positioned on `function` *followed by* an
	// identifier-and-`(` shape — i.e. a method signature. Used by parseEnumDecl
	// to distinguish method declarations from `function` used as a
	// keyword-named enum case.
	function lookaheadIsMethodSignature() returns bool
		return lookaheadIsMethodSignatureAtOffset(0 as ChainPeekOffset)
	end 'lookaheadIsMethodSignature'

	// Same as `lookaheadIsMethodSignature` but with `function` expected at
	// `cursor + funcOffset`. Lets enum/union body dispatch peek past an
	// optional leading `export` modifier (offset 1) before deciding between
	// method-vs-case.
	function lookaheadIsMethodSignatureAtOffset(funcOffset ChainPeekOffset) returns bool
		let nameToken = try cursor.peek(funcOffset + 1) otherwise return false
		if nameToken.kind != TokenKind.identifier 'noName'
			return false
		end 'noName'
		let afterName = try cursor.peek(funcOffset + 2) otherwise return false
		return afterName.kind == TokenKind.leftParen
	end 'lookaheadIsMethodSignatureAtOffset'

	// Parse a method on the enclosing enum. Models the enum as a "type" for
	// parsing purposes — the method gets an implicit `__self` parameter typed
	// to the enum, and registers under `{enumName}.{methodName}` so dot-call
	// dispatch finds it. The empty fields array tells parseFunction not to
	// set up self-field aliases — enums have no fields. Method visibility
	// inherits from `currentEnumVisibility` so cross-file method calls match
	// whatever the enum-decl declared.
	function parseEnumMethod(enumName String) throws ParserError
		try parseFunction(enumName, isInstance: true, fields: StructFieldArray.create(), visibility: currentEnumVisibility)
	end 'parseEnumMethod'

	// Read the next int / float literal for an enum raw value, recovering
	// gracefully on overflow so the enclosing case-collection loop keeps
	// walking the rest of the body. Float values are returned as raw IEEE-754
	// bits, so both forms share a single IntConstant return slot.
	function parseRawValueForEnum(token Token, kindLabel String, isFloat bool) returns IntConstant
		var parsed = 0 as IntConstant
		if isFloat 'isFloatLit'
			parsed = try parseFloatBits(token.value) otherwise 'overflow'
				reportLiteralOverflow(token: token, message: "{kindLabel} literal '{tokenValueToString(token.value)}' is outside the range of {kindLabel}")
				return 0
			end 'overflow'
		end 'isFloatLit' else 'isIntLit'
			parsed = try parseInt(token.value) otherwise 'overflow'
				reportLiteralOverflow(token: token, message: "{kindLabel} literal '{tokenValueToString(token.value)}' is outside the range of {kindLabel}")
				return 0
			end 'overflow'
		end 'isIntLit'
		return parsed
	end 'parseRawValueForEnum'

	// IEEE-754 max/min finite double as i64 bit patterns. Used as the synthetic
	// float range for a float-backed enum's typealias entry. The min pattern
	// is the max pattern with the sign bit set (0xFFEFFFFFFFFFFFFF), which —
	// reinterpreted as a signed i64 — is -4503599627370497.
	function f64MaxBits() returns IntConstant
		// 0x7FEFFFFFFFFFFFFF — largest finite positive double.
		return 9218868437227405311
	end 'f64MaxBits'

	function f64MinBits() returns IntConstant
		// 0xFFEFFFFFFFFFFFFF as a signed i64 — most-negative finite double.
		return 0 - 4503599627370497
	end 'f64MinBits'

	// Pick an upper bound for an int-backed enum's typealias range from the
	// largest raw value seen. Empty enums fall through with `0`; the typealias
	// range becomes `0 to 0` and any access is rejected, which matches the
	// "empty enum has no valid value" semantics.
	function enumIntUpperBound(cases EnumCaseArray) returns RangeBound
		var upper = 0 as RangeBound
		for c in cases 'scan'
			if c.rawValue > upper 'newMax'
				upper = c.rawValue
			end 'newMax'
		end 'scan'
		return upper
	end 'enumIntUpperBound'

	// Pick a lower bound for an int-backed enum's typealias range from the
	// smallest raw value seen. Returns 0 unless at least one case carries a
	// negative raw value — keeping legacy unsigned-enum range shapes
	// (`int(0 to N)`) intact while letting signed enums widen the range to
	// include negatives so `computeOptimalIntType` picks the signed StdType.
	function enumIntLowerBound(cases EnumCaseArray) returns RangeBound
		var lower = 0 as RangeBound
		for c in cases 'scan'
			if c.rawValue < lower 'newMin'
				lower = c.rawValue
			end 'newMin'
		end 'scan'
		return lower
	end 'enumIntLowerBound'

	// Write modified field values back to the struct pointer before returning.
	function emitFieldWritebacks(block IrBlock, nameToken Token, fields StructFieldArray)
		let selfLoadName = emitSelfLoad(block, token: nameToken, range: SourceRange.none())

		for field in fields 'eachField'
			if let fieldSlot = try scope.lookup(field.name) 'hasField'
				let fieldValName = freshSynthName()
				module.appendOp(block, op: MaxonOp.varLoad(fieldValName, slotId: fieldSlot, slotType: field.fieldType, range: SourceRange.none()))
				module.appendOp(block, op: MaxonOp.fieldStore(selfLoadName, fieldName: field.name.toByteArray(), value: fieldValName, isInit: true, range: SourceRange.none()))
			end 'hasField'
		end 'eachField'
	end 'emitFieldWritebacks'

	// Parse an int range bound: a number literal, negative literal, or T.min/T.max.
	// Returns the bound value plus the type-qualifier name when the bound was
	// `T.min`/`T.max` (empty string when it was a literal). Callers compare
	// qualifiers to detect mismatched type bounds (E3005).
	// entry: cursor AT first token of the bound (minus, intLit, or identifier).
	// exit:  cursor AT last-consumed token of the bound.
	function parseIntRangeBound() returns BoundResult throws ParserError
		if accept(TokenKind.minus) 'isNeg'
			let numToken = try consume()
			let value = try parseInt(numToken.value) otherwise 'negOverflow'
				reportCompileError(project, code: ErrorCode.parserLiteralOverflow, message: "Integer literal '{tokenValueToString(numToken.value)}' is outside the range of int", line: numToken.line, column: numToken.column, filePath: filePath)
				return BoundResult.create(0, qualifier: "")
			end 'negOverflow'
			return BoundResult.create(0 - value, qualifier: "")
		end 'isNeg'

		if at(TokenKind.intLiteral) 'isLit'
			let token = try consume()
			let value = try parseInt(token.value) otherwise 'litOverflow'
				reportLiteralOverflow(token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int")
				return BoundResult.create(0, qualifier: "")
			end 'litOverflow'
			return BoundResult.create(value, qualifier: "")
		end 'isLit'

		if at(TokenKind.identifier) and atOffset(TokenKind.dot, offset: 1) 'maybeTypeBound'
			let fieldToken = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
			if fieldToken.kind == TokenKind.identifier 'hasField'
				let typeNameToken = try consume()
				try eat(TokenKind.dot)
				let fieldNameToken = try consume()
				return BoundResult.create(resolveTypeBound(typeNameToken.value, field: fieldNameToken.value), qualifier: typeNameToken.value)
			end 'hasField'
		end 'maybeTypeBound'

		return BoundResult.create(0, qualifier: "")
	end 'parseIntRangeBound'

	// Parse a float range bound: float literal, negative float literal, or
	// T.min/T.max (where T is f32 or f64). Returns the IEEE-754 double bit
	// pattern as i64, plus the qualifier. Integer literals are accepted and
	// converted (so `float(0 to 100.0)` works).
	function parseFloatRangeBound() returns BoundResult throws ParserError
		if accept(TokenKind.minus) 'isNeg'
			let numToken = try consume()
			let bits = try parseFloatBoundBits(numToken, negate: true) otherwise 'negOverflow'
				return BoundResult.create(0, qualifier: "")
			end 'negOverflow'
			return BoundResult.create(bits, qualifier: "")
		end 'isNeg'

		if at(TokenKind.floatLiteral) or at(TokenKind.intLiteral) 'isLit'
			let token = try consume()
			let bits = try parseFloatBoundBits(token, negate: false) otherwise 'litOverflow'
				return BoundResult.create(0, qualifier: "")
			end 'litOverflow'
			return BoundResult.create(bits, qualifier: "")
		end 'isLit'

		if at(TokenKind.identifier) and atOffset(TokenKind.dot, offset: 1) 'maybeTypeBound'
			let fieldToken = try cursor.peek(2) otherwise throw ParserError.unexpectedEof
			if fieldToken.kind == TokenKind.identifier 'hasField'
				let typeNameToken = try consume()
				try eat(TokenKind.dot)
				let fieldNameToken = try consume()
				return BoundResult.create(resolveFloatTypeBound(typeNameToken.value, field: fieldNameToken.value), qualifier: typeNameToken.value)
			end 'hasField'
		end 'maybeTypeBound'

		return BoundResult.create(0, qualifier: "")
	end 'parseFloatRangeBound'

	// Parse a number-literal token as a float and return its IEEE-754 i64
	// bit pattern. Accepts both intLiteral and floatLiteral tokens. `negate`
	// applies a unary-minus to the parsed value before reinterpreting.
	function parseFloatBoundBits(token Token, negate bool) returns IntConstant throws ParserError
		if token.kind == TokenKind.floatLiteral 'isFloat'
			let bits = try parseFloatBits(token.value) otherwise 'overflow'
				reportLiteralOverflow(token: token, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float")
				throw ParserError.overflow
			end 'overflow'
			if negate 'doNegate'
				return negateFloatBits(bits)
			end 'doNegate'
			return bits
		end 'isFloat'
		// Integer literal — re-interpret as float by parsing the integer and
		// converting via IEEE-754 round-to-nearest. Only powers-of-two and
		// small integers occur in practice (range-bound literals like 0, 100).
		let intValue = try parseInt(token.value) otherwise 'intOverflow'
			reportLiteralOverflow(token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int")
			throw ParserError.overflow
		end 'intOverflow'
		let signed = intValue if not negate else 0 - intValue
		return floatBitsFromInt(signed)
	end 'parseFloatBoundBits'

	// Parse the inside of `int(...)` or `float(...)` after the opening paren
	// is consumed. Validates ranges and returns the appropriate
	// UnresolvedTypeExpr arm. Reports E3005 on bound mismatches and replaces
	// the alias's RHS with `invalid` so downstream resolution proceeds without
	// cascading.
	function parseRangedPrimitiveBounds(baseToken Token, isFloat bool) returns UnresolvedTypeExpr throws ParserError
		var lowerBound = BoundResult.create(0, qualifier: "")
		var upperBound = BoundResult.create(0, qualifier: "")
		if isFloat 'parseFloat'
			lowerBound = try parseFloatRangeBound()
		end 'parseFloat' else 'parseInt'
			lowerBound = try parseIntRangeBound()
		end 'parseInt'

		var upperInclusive = true
		if accept(TokenKind.to) 'isTo'
			upperInclusive = true
		end 'isTo' else if accept(TokenKind.upto) 'isUpto'
			upperInclusive = false
		end 'isUpto' else 'badSep'
			let cur = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected 'to' or 'upto' in range", line: cur.line, column: cur.column, filePath: filePath)
			skipToNextLine()
			throw ParserError.unhandledToken
		end 'badSep'

		if isFloat 'parseFloatU'
			upperBound = try parseFloatRangeBound()
		end 'parseFloatU' else 'parseIntU'
			upperBound = try parseIntRangeBound()
		end 'parseIntU'

		try expect(TokenKind.rightParen)

		// Mismatched type qualifiers — both sides explicitly named a type
		// and they disagree. Reports against the upper-bound column for
		// stable diagnostic anchoring (matches the C# bootstrap).
		if lowerBound.qualifier != "" and upperBound.qualifier != "" and lowerBound.qualifier != upperBound.qualifier 'mismatched'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Mismatched type bounds: '{lowerBound.qualifier}.min' and '{upperBound.qualifier}.max' must reference the same type", line: baseToken.line, column: baseToken.column + 4, filePath: filePath)
			return UnresolvedTypeExpr.invalid
		end 'mismatched'

		// A negative lower paired with `u64.max` upper would need a 65-bit
		// type to represent — the i64 storage wraps `u64.max` to -1 and
		// silently collapses the range. Reject before the order check so the
		// user sees the unrepresentable-range diagnostic, not "Invalid range".
		if not isFloat and lowerBound.value < 0 and upperBound.qualifier == "u64" 'unrepresentable'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Integer range cannot span both negative values and above i64.max: 'int({lowerBound.value} to u64.max)' is not representable in 64 bits; use 'i64.min to i64.max' or '0 to u64.max' instead", line: baseToken.line, column: baseToken.column, filePath: filePath)
			return UnresolvedTypeExpr.invalid
		end 'unrepresentable'

		// Range ordering. For ints, treat non-negative lower as unsigned for
		// the comparison so `0 to u64.max` (where u64.max wraps to -1 signed)
		// is valid.
		var invalidRange = false
		if isFloat 'orderFloat'
			invalidRange = floatBitsGreater(lowerBound.value, b: upperBound.value) or (lowerBound.value == upperBound.value and not upperInclusive)
		end 'orderFloat' else 'orderInt'
			invalidRange = isInvalidIntRange(lowerBound.value, upper: upperBound.value, upperInclusive: upperInclusive)
		end 'orderInt'

		if invalidRange 'badOrder'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Invalid range: lower bound {lowerBound.value} must be less than upper bound {upperBound.value}", line: baseToken.line, column: baseToken.column, filePath: filePath)
			return UnresolvedTypeExpr.invalid
		end 'badOrder'

		// Normalize `upto N` to inclusive `to N - 1` for ints so downstream
		// passes only ever see one bound shape.
		var normalizedUpper = upperBound.value
		if not upperInclusive and not isFloat 'normalizeUpto'
			normalizedUpper = upperBound.value - 1
		end 'normalizeUpto'

		if isFloat 'returnFloat'
			return UnresolvedTypeExpr.rangedFloat(lowerBound.value, upper: normalizedUpper)
		end 'returnFloat'
		return UnresolvedTypeExpr.rangedInt(lowerBound.value, upper: normalizedUpper)
	end 'parseRangedPrimitiveBounds'

	// --- Return statement ---

	function parseReturnStatement(block IrBlock) throws ParserError
		// Pre-flight: if `return` is followed by EOF or by newline/`end`, emit
		// implicit return and stop. We still consume `return` itself — at EOF
		// the consume's advance throws after returning the token; we swallow
		// it because the work for this statement is done.
		let nextTok = try cursor.peek(1) otherwise 'noNext'
			emitImplicitReturn(block)
			try cursor.advance() otherwise return
			return
		end 'noNext'
		let returnToken = try consume()
		if nextTok.kind == TokenKind.newline or nextTok.kind == TokenKind.end or nextTok.kind == TokenKind.eof 'bareReturn'
			emitImplicitReturn(block)
			return
		end 'bareReturn'

		currentBlock = block
		let resultExpr = try parseExpression(block)
		let lastExprToken = previousToken()
		// currentBlock holds the block control-flow landed on after the
		// expression — if the rhs of a bool `and`/`or` triggered short-circuit
		// emission, that's a merge block, not the original `block`.
		// `parseStringLiteral`'s fast path returns a `stringConst` ExprResult
		// without emitting a backing op; the ret below would reference an
		// unbound name (E3013 in lowering).
		let materializedResult = materializeStringConstIfNeeded(currentBlock, expr: resultExpr, range: SourceRange.between(returnToken, last: lastExprToken))
		module.setTerminator(currentBlock, op: MaxonOp.ret(exprName(materializedResult), range: SourceRange.between(returnToken, last: lastExprToken)))
	end 'parseReturnStatement'

	// Emits MaxonOp.panic with a location-prefixed message for the stack trace.
	function parsePanicStatement(block IrBlock) throws ParserError
		let panicToken = try consume()  // caller has already dispatched on 'panic'
		try expect(TokenKind.leftParen)
		let msgToken = try consume()
		if msgToken.kind != TokenKind.stringLiteral 'notString'
			reportTokenMismatch(msgToken, expectedDisplay: tokenKindDisplay(TokenKind.stringLiteral))
			synchronize()
			return
		end 'notString'
		// Runtime panic interpolation isn't implemented in the self-hosted
		// compiler yet. Report an error rather than silently dropping the
		// interpolation (which would print the pre-`{` fragment only).
		if at(TokenKind.stringInterpStart) 'hasInterp'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "panic interpolation is not supported in the self-hosted compiler", line: msgToken.line, column: msgToken.column, filePath: filePath)
			synchronize()
			return
		end 'hasInterp'
		let rparenToken = cursor.current()
		try expect(TokenKind.rightParen)

		let fileName = filePath.filename()
		let fullMsg = "panic at {fileName}:{panicToken.line}: {msgToken.value}"
		let stringId = project.strings.intern(fullMsg)
		module.appendOp(block, op: MaxonOp.panic(stringId, range: SourceRange.between(panicToken, last: rparenToken)))
	end 'parsePanicStatement'

	// Parse: throw EnumName.variantName [(arg, ...)]
	// Lowering: emit MaxonOp.throw, which lowers to a single
	// `StdCallOp.errorReturn` op that places the variant ordinal+1 in the
	// secondary error register (RDX/X1) alongside a default primary value
	// — the multi-value-return error ABI. The thrown variant ordinal is
	// recovered at lowering time by walking
	// project.unresolvedEnums / project.enumTypes — the parser stays
	// agnostic of cross-declaration registries. `throw` is a block
	// terminator: setTerminator places it as the block's tail op so the
	// caller marks `lastWasReturn = true` and stops emitting into this
	// block.
	//
	// Phase 9 Stage 5c: `throw EnumName.case(args)` on an associated-value
	// union error enum lowers to a call to the synthesized
	// `__construct_EnumName_case` constructor followed by a throw that
	// threads the constructor result through the multi-value-return value
	// slot. The flag remains `ordinal + 1`; the value slot's meaning flips
	// from "default placeholder" to "union pointer" at the caller's
	// `try ... otherwise (e)` site.
	function parseThrowStatement(block IrBlock) throws ParserError
		let throwToken = try consume()  // caller has already dispatched on 'throw'
		let typeNameToken = try consumeExpecting("error type name")
		try expect(TokenKind.dot)
		let variantToken = try consumeExpecting("error variant name")
		if at(TokenKind.leftParen) 'hasPayload'
			let ctorCall = try emitUnionThrowConstruction(block, typeNameToken: typeNameToken, variantToken: variantToken)
			module.setTerminator(block, op: MaxonOp.throw(typeNameToken.value, variantName: variantToken.value, payloadValueName: ctorCall.resultName, range: SourceRange.between(throwToken, last: ctorCall.lastToken)))
			return
		end 'hasPayload'
		module.setTerminator(block, op: MaxonOp.throw(typeNameToken.value, variantName: variantToken.value, payloadValueName: ByteArray.create(), range: SourceRange.between(throwToken, last: variantToken)))
	end 'parseThrowStatement'

	// Phase 9 Stage 5c: emit the constructor call for `throw EnumName.case(args)`
	// and return both the SSA name binding the constructed union pointer and
	// the closing paren token (for caller's source-range diagnostics).
	// Caller has already consumed `EnumName.case` and is positioned at `(`.
	// Calls `parseCallArgsRaw` to parse the argument list, then routes through
	// `emitCallAndResult` against the synthesized `__construct_EnumName_case`
	// symbol — exactly the same lowering path `EnumName.case(args)` takes as
	// a value expression. The throw op consumes this result through its
	// `payloadValueName` slot.
	function emitUnionThrowConstruction(block IrBlock, typeNameToken Token, variantToken Token) returns ThrowConstructionResult throws ParserError
		let lparen = cursor.current()
		// Consume the `(` so parseCallArgsRaw enters with cursor on the
		// first arg's first token (mirroring every other Foo.bar(args) site).
		try eat(TokenKind.leftParen)
		let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
		let rparenToken = previousToken()
		// Route through the synthesized constructor symbol so TypeResolution
		// arity-checks and arg-reorders against the registered signature.
		// `emitCallAndResult` emits a regular `MaxonOp.call`, returns the
		// fresh result name, and leaves `currentBlock` unchanged.
		let ctorName = unionConstructorSymbolName(typeNameToken.value, caseName: variantToken.value)
		let result = emitCallAndResult(calleeName: ctorName, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.between(lparen, last: rparenToken))
		return ThrowConstructionResult.create(resultName: exprName(result), lastToken: rparenToken)
	end 'emitUnionThrowConstruction'

	// --- If statement ---

	// Parse: if <condition> 'label' ... end 'label' [else 'label' ... end 'label']
	// Returns the merge block to continue emitting into.
	function parseIfStatement(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let ifToken = try consume()

		// `if let X = try CALL`, `if var X = try CALL`, and `if try CALL`:
		// dispatch to the binding/error form. Parses the try, branches on
		// the error flag, and threads the success-side binding into the
		// then-block scope.
		if at(TokenKind.let) or at(TokenKind.var) or at(TokenKind.try) 'isIfTry'
			return try parseIfTryStatement(func, block: block, ifToken: ifToken)
		end 'isIfTry'

		// Seed currentBlock so a bool short-circuit in the condition appends to
		// the right place; recover the post-condition block afterwards because
		// short-circuit may have advanced control flow to a merge block.
		currentBlock = block
		let condResult = try parseExpression(block)
		let condBlock = currentBlock

		// `if` requires a block label (matches C# bootstrap). Without one,
		// downstream `end 'label'` matching can't be enforced.
		if not at(TokenKind.charLiteral) 'noLabel'
			reportTokenMismatch(cursor.current(), expectedDisplay: "characterliteral")
			synchronize()
			return condBlock
		end 'noLabel'
		let userLabel = try parseOptionalBlockLabel("if")

		let ifFilePath = filePath.toString()
		var thenBlock = module.addBlockAt(func, label: userLabel, filePath: ifFilePath, firstLine: ifToken.line)
		let thenBlockId = thenBlock.id
		let baseLabel = "{userLabel}_{thenBlockId}"
		thenBlock.label = baseLabel

		let thenExit = try parseScopedStatements(func, block: thenBlock)

		try skipEndAndLabel()
		// EOF here is fine — `if ... end` with nothing after just ends the construct.
		_ = skipOptionalNewlines()

		if at(TokenKind.else) 'hasElse'
			let elseToken = try consume()

			var elseLabel = "{baseLabel}.else"

			if at(TokenKind.if) 'isElseIf'
				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				// Capture the id BEFORE the recursive parse — parseIfStatement may
				// add more blocks, which can invalidate the `elseBlock` struct
				// reference under the IR's block-array growth semantics.
				let elseBlockId = elseBlock.id
				let elseIfExit = try parseIfStatement(func, block: elseBlock)
				return finalizeIfElseById(func, condBlock: condBlock, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseIfExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'isElseIf' else 'plainElse'
				if at(TokenKind.charLiteral) 'hasElseLabel'
					let elseLabelToken = try consume()
					elseLabel = "{elseLabelToken.value}_{func.nextBlockId}"
					try expectNewlineAfterLabel()
				end 'hasElseLabel' else 'noElseLabel'
					try skipNewlines()
				end 'noElseLabel'

				var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
				// Capture id before parseScopedStatements — subsequent block adds
				// may invalidate the `elseBlock` struct reference.
				let elseBlockId = elseBlock.id
				let elseExit = try parseScopedStatements(func, block: elseBlock)
				try skipEndAndLabel()
				return finalizeIfElseById(func, condBlock: condBlock, condName: exprName(condResult), thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
			end 'plainElse'
		end 'hasElse'

		// No else clause. We're already past the then-block's end/label.
		let afterBlock = module.addBlockAt(func, label: "{baseLabel}.after", filePath: ifFilePath, firstLine: cursor.current().line)
		branchIfNeeded(thenExit, target: afterBlock.id)
		module.setTerminator(condBlock, op: MaxonOp.condBr(exprName(condResult), thenTarget: thenBlockId, elseTarget: afterBlock.id, range: SourceRange.none()))
		return afterBlock
	end 'parseIfStatement'

	// Parse `if let X = try CALL 'lab' ... end 'lab'` and friends. Three forms:
	//   `if let X = try CALL 'lab' ... end 'lab' [else 'el' ... end 'el']`
	//   `if var X = try CALL 'lab' ... end 'lab' [else 'el' ... end 'el']`
	//   `if try CALL 'lab' ... end 'lab' [else 'el' ... end 'el']`
	// On try-success, the bound name (let/var form) is the call result and the
	// then-block runs. On try-error, the else block runs (or the if is skipped
	// when no else is present). The error flag is the condition.
	// entry: cursor AT `let`, `var`, or `try` (caller has already eaten `if`).
	function parseIfTryStatement(func IrFunction, block IrBlock, ifToken Token) returns IrBlock throws ParserError
		var bindingName = ""
		var bindingMutable = false
		if at(TokenKind.let) or at(TokenKind.var) 'isBinding'
			bindingMutable = at(TokenKind.var)
			_ = try consume()
			let nameTok = try consumeExpecting("identifier")
			if not tokenIsIdentifierLike(nameTok) 'badName'
				reportTokenMismatch(nameTok, expectedDisplay: "identifier")
				synchronize()
				return block
			end 'badName'
			checkReservedDeclName(nameTok)
			bindingName = nameTok.value
			try expect(TokenKind.equals)
		end 'isBinding'

		// Now parse the `try CALL` part. We re-use parseTryExpression's
		// internal mechanics by inlining the rewrite-call path: parse the
		// inner call, rewrite to tryCall/tryMethodCall, and produce the
		// error-flag name + result name.
		let tryToken = try consumeExpecting("try")
		if tryToken.kind != TokenKind.try 'noTry'
			reportTokenMismatch(tryToken, expectedDisplay: "'try'")
			synchronize()
			return block
		end 'noTry'

		currentBlock = block
		let opCountBefore = module.ops.count()
		let inner = try parseUnary(block)
		let innerName = exprName(inner)
		var callReturnType = exprType(inner)
		var condBlock = currentBlock
		let opCountAfter = module.ops.count()

		let errorFlagName = freshSynthName()
		var rewrote = false
		var calleeThrowsTypeName = ThrowsClause.none
		if opCountAfter > opCountBefore 'haveLast'
			let lastIdx = opCountAfter - 1
			let lastOp = try module.ops.get(lastIdx) otherwise panic("parseIfTryStatement: ops.get OOB")
			rewrote = tryRewriteCallToTryCall(opIdx: lastIdx, op: lastOp, errorFlagName: errorFlagName, tryRange: SourceRange.ofToken(tryToken))
			if not rewrote 'tryMethod'
				rewrote = tryRewriteMethodCallToTryMethodCall(opIdx: lastIdx, op: lastOp, errorFlagName: errorFlagName, tryRange: SourceRange.ofToken(tryToken))
			end 'tryMethod'
			if rewrote 'resolveThrows'
				// Cache the callee's throws clause so an `else (e) 'label'`
				// binding (added below) can pick the right type for the error
				// slot, parallel to parseTryFallbackDispatch's binding path.
				let rewrittenOp = try module.ops.get(lastIdx) otherwise panic("parseIfTryStatement: re-read OOB after rewrite")
				let qualifiedCallee = qualifiedCalleeFromTryCall(rewrittenOp, opIdx: lastIdx)
				calleeThrowsTypeName = try project.funcThrowsTypes.get(qualifiedCallee) otherwise ThrowsClause.none
			end 'resolveThrows'
		end 'haveLast'
		if not rewrote 'noRewrite'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'if let/var/try' requires a throwing call expression after 'try'", line: tryToken.line, column: tryToken.column, filePath: filePath)
			synchronize()
			return block
		end 'noRewrite'

		// cmp flag != 0 → error path; flag == 0 → success path.
		let zeroName = emitLiteral(condBlock, value: 0, valueType: MaxonType.integer)
		let condName = freshSynthName()
		module.appendOp(condBlock, op: MaxonOp.cmp(condName, left: errorFlagName, right: zeroName, predicate: CmpPredicate.eq, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: SourceRange.ofToken(tryToken)))

		// `if` requires a block label.
		if not at(TokenKind.charLiteral) 'noLabel'
			reportTokenMismatch(cursor.current(), expectedDisplay: "characterliteral")
			synchronize()
			return condBlock
		end 'noLabel'
		let userLabel = try parseOptionalBlockLabel("if")

		let ifFilePath = filePath.toString()
		var thenBlock = module.addBlockAt(func, label: userLabel, filePath: ifFilePath, firstLine: ifToken.line)
		let thenBlockId = thenBlock.id
		let baseLabel = "{userLabel}_{thenBlockId}"
		thenBlock.label = baseLabel

		// In the then-block, declare the binding (if any) and seed it with
		// the call result so user body code can reference it. Mutability
		// follows the let/var form.
		if not bindingName.isEmpty() 'declareBinding'
			let bindingSlot = scope.declare(bindingName, varType: callReturnType, mutable: bindingMutable)
			module.appendOp(thenBlock, op: MaxonOp.varDecl(bindingSlot, value: innerName, slotType: callReturnType, range: SourceRange.ofToken(tryToken)))
		end 'declareBinding'

		let thenExit = try parseScopedStatements(func, block: thenBlock)

		try skipEndAndLabel()
		_ = skipOptionalNewlines()

		if at(TokenKind.else) 'hasElse'
			let elseToken = try consume()
			// Optional error binding: `else (e) 'label'` exposes the typed
			// error value to the else block's body, mirroring the
			// `otherwise (e) 'label'` form in parseTryFallbackDispatch.
			var elseBindingName = ""
			var hasElseBinding = false
			if at(TokenKind.leftParen) 'hasErrorBinding'
				try eat(TokenKind.leftParen)
				let bindingToken = try consume()
				if not tokenIsIdentifierLike(bindingToken) 'badBindingName'
					reportTokenMismatch(bindingToken, expectedDisplay: "identifier")
					synchronize()
					return condBlock
				end 'badBindingName'
				try eat(TokenKind.rightParen)
				elseBindingName = bindingToken.value
				hasElseBinding = true
			end 'hasErrorBinding'
			var elseLabel = "{baseLabel}.else"
			if at(TokenKind.charLiteral) 'hasElseLabel'
				let elseLabelToken = try consume()
				elseLabel = "{elseLabelToken.value}_{func.nextBlockId}"
				try expectNewlineAfterLabel()
			end 'hasElseLabel' else 'noElseLabel'
				try skipNewlines()
			end 'noElseLabel'

			var elseBlock = module.addBlockAt(func, label: elseLabel, filePath: ifFilePath, firstLine: elseToken.line)
			let elseBlockId = elseBlock.id
			// Bind the error value in the else block when `(e)` was present.
			// Choose the slot type the same way parseTryFallbackDispatch does:
			// bare-enum throws → `flag - 1` recovers the ordinal (integer slot);
			// associated-value union → the flag value IS the union pointer.
			if hasElseBinding 'declareErrorBinding'
				var bindingType = MaxonType.integer
				var throwsIsUnion = false
				if let throwsName = try throwsClauseName(calleeThrowsTypeName) 'haveThrowsName'
					bindingType = internMaxonType(project, name: throwsName)
					throwsIsUnion = enumIsAssociatedValueUnion(throwsName)
				end 'haveThrowsName'
				scope.pushScope()
				let bindingSlot = scope.declare(elseBindingName, varType: bindingType, mutable: false)
				var bindingValueName = ByteArray.create()
				if throwsIsUnion 'isUnion'
					bindingValueName = errorFlagName
				end 'isUnion' else 'isBare'
					let oneName = emitLiteral(elseBlock, value: 1, valueType: MaxonType.integer)
					let enumOrdinalName = freshSynthName()
					module.appendOp(elseBlock, op: MaxonOp.binop(enumOrdinalName, left: errorFlagName, right: oneName, opKind: BinOpKind.sub, operandType: MaxonType.integer, range: SourceRange.ofToken(elseToken)))
					bindingValueName = enumOrdinalName
				end 'isBare'
				module.appendOp(elseBlock, op: MaxonOp.varDecl(bindingSlot, value: bindingValueName, slotType: bindingType, range: SourceRange.ofToken(elseToken)))
			end 'declareErrorBinding'
			let elseExit = try parseScopedStatements(func, block: elseBlock)
			if hasElseBinding 'popBindingScope'
				scope.popScope()
			end 'popBindingScope'
			try skipEndAndLabel()
			return finalizeIfElseById(func, condBlock: condBlock, condName: condName, thenBlockId: thenBlockId, thenExit: thenExit, elseBlockId: elseBlockId, elseExit: elseExit, baseLabel: baseLabel, mergeLine: cursor.current().line)
		end 'hasElse'

		// No else clause.
		let afterBlock = module.addBlockAt(func, label: "{baseLabel}.after", filePath: ifFilePath, firstLine: cursor.current().line)
		branchIfNeeded(thenExit, target: afterBlock.id)
		module.setTerminator(condBlock, op: MaxonOp.condBr(condName, thenTarget: thenBlockId, elseTarget: afterBlock.id, range: SourceRange.none()))
		return afterBlock
	end 'parseIfTryStatement'

	// --- While statement ---

	// Parse: while <condition> 'label' ... end 'label'
	// Returns the exit block to continue emitting into.
	function parseWhileStatement(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let whileToken = try consume()

		// Create cond block first (we need it to parse the condition into).
		// All three loop blocks (header, body, exit) open at the `while` token —
		// coverage-wise the whole construct is one statement, and the exit block
		// is reached right after the condition fails at that same line.
		let whileFilePath = filePath.toString()
		var condBlock = module.addBlockAt(func, label: "cond", filePath: whileFilePath, firstLine: whileToken.line)
		let condBlockId = condBlock.id

		// Branch from entry block to cond block
		module.setTerminator(block, op: MaxonOp.br(condBlockId, range: SourceRange.none()))

		// Parse condition in condBlock. Bool short-circuit may move control
		// flow off condBlock to a fresh merge block — capture it.
		currentBlock = condBlock
		let condResult = try parseExpression(condBlock)
		let condExitBlock = currentBlock

		// while loops require a block label (matches C# bootstrap). Without
		// one, downstream break/continue have nothing to target.
		if not at(TokenKind.charLiteral) 'noLabel'
			let tok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected loop label after while condition", line: tok.line, column: tok.column, filePath: filePath)
			synchronize()
			return condExitBlock
		end 'noLabel'
		let userLabel = try parseOptionalBlockLabel("loop")

		// Derive base label: userLabel_<blockId>
		let baseLabel = "{userLabel}_{condBlockId}"

		// Rename condBlock to baseLabel.header
		condBlock.label = "{baseLabel}.header"

		// Create body and exit blocks with derived labels
		var bodyBlock = module.addBlockAt(func, label: baseLabel, filePath: whileFilePath, firstLine: whileToken.line)
		let bodyBlockId = bodyBlock.id
		let exitBlock = module.addBlockAt(func, label: "{baseLabel}.exit", filePath: whileFilePath, firstLine: whileToken.line)
		let exitBlockId = exitBlock.id

		// condBlock terminator: if true -> bodyBlock, if false -> exitBlock.
		// When the condition triggered short-circuit emission, the cond_br
		// belongs on the merge block where the bool value materialized, not
		// the original condBlock.
		module.setTerminator(condExitBlock, op: MaxonOp.condBr(exprName(condResult), thenTarget: bodyBlockId, elseTarget: exitBlockId, range: SourceRange.none()))

		// Push loop context for break/continue
		loopStack.push(LoopContext.create(userLabel, headerBlockId: condBlockId, exitBlockId: exitBlockId, continueBlockId: condBlockId))

		// Parse body in bodyBlock
		let bodyExit = try parseScopedStatements(func, block: bodyBlock)

		// Pop the loop context we pushed above. The stack can't be empty here —
		// we own both the matching push and the intermediate parse call.
		try loopStack.pop() otherwise panic("loopStack.pop: stack unexpectedly empty after while-body parse")

		// Loop back to cond block if body doesn't terminate
		branchIfNeeded(bodyExit, target: condBlockId)

		// Skip 'end' and optional label string
		try skipEndAndLabel()
		// cursor AT end/label — exit AT last-consumed.

		return exitBlock
	end 'parseWhileStatement'

	// --- Match (statement and expression) ---
	//
	// Both forms desugar to a chain of `cmp + condBr` blocks:
	//   ENTRY: br ARM0
	//   ARM0:  cmp scrutinee == case0; condBr ARM0_BODY ARM1
	//   ARM1:  cmp scrutinee == case1; condBr ARM1_BODY ARM2
	//   ...
	//   ARMN:  cmp scrutinee == caseN; condBr ARMN_BODY MERGE
	//   ARM*_BODY: <arm body>; br MERGE  (statement form)
	//   ARM*_BODY: <arm value emit>; varStore result; br MERGE  (expression form)
	//   MERGE: ...continued...                       (statement form)
	//   MERGE: result = varLoad slot; ...            (expression form)
	//
	// Statement arms use `then`, expression arms use `gives`. Both consume a
	// single expression following the keyword (statement arms permit any
	// statement-shape expression — return / break / continue still flow
	// through the expression parser today). The parser does NO case-name
	// resolution: it emits each arm's dispatch as a `MaxonOp.enumMatchArm`
	// terminator carrying the case name verbatim. TypeResolution looks up
	// the scrutinee's enum and resolves the case to its raw value once the
	// producer-type map is built.

	// Parse the prelude common to both match forms: `match <expr> '<label>'`
	// followed by newlines. Returns the scrutinee value/type, the synthesized
	// `baseLabel` used to derive arm/merge block names, and the freshly-added
	// merge block. On a missing label the caller-supplied error path runs and
	// the result's `failed` flag is set.
	function parseMatchHeader() returns MatchHeader throws ParserError
		try eat(TokenKind.match)
		// Phase 9 Stage 4: probe for a bare-identifier scrutinee BEFORE
		// `parseExpression` consumes the token. When the scrutinee is a bare
		// identifier referring to a mutable scope local, payload bindings
		// inherit that mutability — they can be assigned to via
		// `enumPayloadStore`. For anything more complex (struct fields,
		// computed expressions, immutable locals) bindings stay read-only
		// and assignment-to-binding fires E2013.
		var scrutineeMutable = false
		let cur = cursor.current()
		let nxt = try cursor.peek(1) otherwise Token.eof()
		if cur.kind == TokenKind.identifier and nxt.kind == TokenKind.charLiteral and scope.contains(cur.value) 'isBareLocal'
			let info = scope.getInfo(cur.value)
			scrutineeMutable = info.mutable
		end 'isBareLocal'
		let scrutineeResult = try parseExpression(currentBlock)
		if not at(TokenKind.charLiteral) 'noLabel'
			let tok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserMatchMissingBlockId, message: "missing block identifier", line: tok.line, column: tok.column, filePath: filePath)
			return MatchHeader.failed()
		end 'noLabel'
		// Consume the label and skip any trailing newlines without enforcing one
		// — match defers diagnostics to the arm-parsing loop so a truncated
		// `match X 'L'` reports "Expected pattern value" rather than the more
		// generic "Expected newline after block label" if-and-friends emit.
		let labelToken = try consume()
		let userLabel = labelToken.value
		_ = skipOptionalNewlines()
		let baseLabel = "{userLabel}_{currentFunc.nextBlockId}"
		let mergeBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.merge", filePath: filePath.toString(), firstLine: cursor.current().line)
		return MatchHeader.create(scrutineeName: exprName(scrutineeResult), scrutineeType: exprType(scrutineeResult), userLabel: userLabel, baseLabel: baseLabel, mergeBlock: mergeBlock, scrutineeMutable: scrutineeMutable)
	end 'parseMatchHeader'

	// Consume `'label'` after `end`, validating it matches the expected label.
	// Emits E2043 (block-id mismatch) when present-but-different. The shared
	// `skipEndAndLabel` accepts any label silently — match needs the stricter
	// match-up check both forms expose to the user.
	function consumeMatchEndLabel(expectedLabel String) throws ParserError
		if not at(TokenKind.end) 'notEnd'
			reportTokenMismatch(cursor.current(), expectedDisplay: "'end'")
			synchronize()
			return
		end 'notEnd'
		let endToken = try consume()
		if at(TokenKind.charLiteral) 'hasLabel'
			let labelToken = try consume()
			if labelToken.value != expectedLabel 'mismatch'
				reportCompileError(project, code: ErrorCode.parserMatchMismatchedBlockId, message: "block identifier mismatch: expected '{expectedLabel}', got '{tokenValueToString(labelToken.value)}'", line: endToken.line, column: endToken.column, filePath: filePath)
			end 'mismatch'
		end 'hasLabel'
	end 'consumeMatchEndLabel'

	// Decode a single-byte character literal to its byte value. Multi-byte
	// char literals (escaped Unicode, multi-codepoint forms) are rejected
	// because match arms compare against the scrutinee's single-byte
	// integer representation. Reports E3005-style with a clear message;
	// returns 0 as a fallback so downstream wiring stays well-formed.
	function decodeCharLiteralToByte(charToken Token) returns ParsedInt
		let decoded = decodeStringEscapes(charToken.value)
		if decoded.count() != 1 'badLen'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "multi-byte character literal '{tokenValueToString(charToken.value)}' is not allowed in a match pattern; use a single-byte char or an integer literal", line: charToken.line, column: charToken.column, filePath: filePath)
			return 0
		end 'badLen'
		let byteVal = try decoded.get(0) otherwise panic("decodeCharLiteralToByte: count==1 but get(0) failed")
		return byteVal as ParsedInt
	end 'decodeCharLiteralToByte'

	// Parse one pattern token: an integer literal (with optional leading `-`),
	// the `default` keyword, an identifier (treated as an enum case name), a
	// range form `X to|upto Y` on integer literals (with `min` / `max`
	// sentinels for open-ended bounds). Returns the spec; reports
	// overflow/error and returns a fallback default when the token can't
	// be classified. Caller handles `or` chaining and duplicate detection.
	function parseOneMatchPattern() returns MatchPatternSpec throws ParserError
		if at(TokenKind.default) 'isDefault'
			let tok = try consume()
			return MatchPatternSpec.defaultPattern(tok)
		end 'isDefault'

		let firstToken = cursor.current()

		// `min to|upto X` — open-ended lower bound on a range pattern. The
		// lexer emits `min` as an identifier; check the value rather than
		// a dedicated TokenKind so the keyword stays contextual.
		if firstToken.kind == TokenKind.identifier and firstToken.value == "min" and isFollowedByRangeKeyword(offset: 1 as ElementCount) 'minRange'
			try cursor.advance() otherwise throw ParserError.unexpectedEof
			return try parseRangePattern(loValue: 0, loDisplay: "min", loToken: firstToken, hasMinSentinel: true)
		end 'minRange'

		var negate = false
		if at(TokenKind.minus) 'isNegated'
			negate = true
			try cursor.advance() otherwise throw ParserError.unexpectedEof
		end 'isNegated'

		if at(TokenKind.intLiteral) 'isInt'
			let litToken = try consume()
			var value = try parseInt(litToken.value) otherwise 'overflow'
				reportLiteralOverflow(token: litToken, message: "Integer literal '{tokenValueToString(litToken.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
				return MatchPatternSpec.defaultPattern(litToken)
			end 'overflow'
			if negate 'applyNeg'
				value = 0 - value
			end 'applyNeg'
			// Range pattern: `INT to|upto (INT | max)`. Lookahead on the
			// next token; if it isn't `to` / `upto` this stays a bare int
			// literal.
			if at(TokenKind.to) or at(TokenKind.upto) 'isRange'
				return try parseRangePattern(loValue: value, loDisplay: "{value}", loToken: litToken, hasMinSentinel: false)
			end 'isRange'
			return MatchPatternSpec.intLiteral(litToken, value: value, displayName: "{value}")
		end 'isInt'

		// Character literal patterns lower to integer comparisons against the
		// scrutinee's byte value. Match machinery treats them as plain
		// integer-valued patterns — multi-byte literals (which would
		// require Character-struct equality, not byte equality) are
		// rejected as out-of-scope for match arms today.
		if at(TokenKind.charLiteral) 'isChar'
			let charToken = try consume()
			let value = decodeCharLiteralToByte(charToken)
			let displayName = "'{tokenValueToString(charToken.value)}'"
			if at(TokenKind.to) or at(TokenKind.upto) 'isRange'
				return try parseRangePattern(loValue: value, loDisplay: displayName, loToken: charToken, hasMinSentinel: false)
			end 'isRange'
			return MatchPatternSpec.intLiteral(charToken, value: value, displayName: displayName)
		end 'isChar'

		// Anything else is treated as an enum case name. The lexer emits the
		// case identifier as either `TokenKind.identifier` or — when the
		// case name is spelled with a keyword (the keyword-as-case-name
		// spec) — as the keyword's own TokenKind. We let any non-empty
		// token value through and defer enum-case resolution to
		// TypeResolution. If the scrutinee turns out to be non-enum, TR
		// rewrites the op to a `br` and reports E3005.
		if firstToken.value.isEmpty() 'noValue'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected pattern value, got '{tokenValueToString(firstToken.value)}'", line: firstToken.line, column: firstToken.column, filePath: filePath)
			return MatchPatternSpec.defaultPattern(firstToken)
		end 'noValue'
		let caseToken = try consume()
		// Reject qualified case names (E3075): `Color.red` in a match arm
		// is a style error — the scrutinee already pins the enum, so the
		// bare `red` suffices. We bail out of the entire match via
		// ParserError.typeError after the first emit so the user sees one
		// canonical diagnostic per match instead of N (one per qualified
		// arm), matching the bootstrap compiler's fail-fast behavior.
		if at(TokenKind.dot) 'isQualified'
			let nextTok = try cursor.peek(1) otherwise return MatchPatternSpec.enumCase(caseToken, caseName: caseToken.value)
			if nextTok.kind == TokenKind.identifier 'bareCase'
				try cursor.advance() otherwise return MatchPatternSpec.enumCase(caseToken, caseName: caseToken.value)
				let qualifiedTok = try consume()
				reportCompileError(project, code: ErrorCode.semanticMatchQualifiedCaseName, message: "use '{qualifiedTok.value}' instead of '{caseToken.value}.{qualifiedTok.value}' in match", line: caseToken.line, column: caseToken.column, filePath: filePath)
				throw ParserError.typeError
			end 'bareCase'
		end 'isQualified'
		// Enum-case range: `caseName to|upto caseName`. We resolve both
		// case ordinals here against `unresolvedEnums` / `enumTypes` (the
		// parser already knows the scrutinee's enum from the first arm's
		// caseName, but range patterns can appear before any bare-case arm).
		// On miss the case-name lookup fails; we emit a fallback bare-case
		// pattern so TypeResolution can surface the proper diagnostic.
		if at(TokenKind.to) or at(TokenKind.upto) 'isEnumRange'
			return try parseEnumRangePattern(loCaseName: caseToken.value, loToken: caseToken)
		end 'isEnumRange'
		// Phase 9 Stage 2: payload-binding pattern `caseName(x, _, var y)`.
		// We parse the binding list here so the resulting MatchPatternSpec
		// carries the destructure plan; arity / all-discard validation
		// runs against the case's payload arity. The lookup uses the same
		// best-effort scan as `parseEnumRangePattern` — when the case is
		// unknown at parse time, TypeResolution fires E3005 / unknown-case
		// once the scrutinee's type is known.
		if at(TokenKind.leftParen) 'isPayloadPattern'
			return try parseCaseBindingPattern(caseToken)
		end 'isPayloadPattern'
		return MatchPatternSpec.enumCase(caseToken, caseName: caseToken.value)
	end 'parseOneMatchPattern'

	// Parse a payload-binding pattern `caseName(b1, b2, ...)` after the
	// caseName token has already been consumed. The cursor sits on the
	// opening `(`. Each binding is `identifier`, `_`, or `var identifier`.
	// Arity is validated against any union case the parser already knows
	// about (best-effort — TR finishes the job for unknown cases).
	function parseCaseBindingPattern(caseToken Token) returns MatchPatternSpec throws ParserError
		try eat(TokenKind.leftParen)
		var bindings = MatchPatternBindingArray.create()
		var bindingNames = ByteArrayArray.create()
		var allDiscard = true

		if not at(TokenKind.rightParen) 'hasBindings'
			while true 'bindingLoop'
				var isVar = false
				if at(TokenKind.var) 'consumeVar'
					try eat(TokenKind.var)
					isVar = true
				end 'consumeVar'

				let bindingToken = try consume()
				let isDiscard = bindingToken.value == "_"
				let bindingName = "" if isDiscard else bindingToken.value
				bindings.push(MatchPatternBinding.create(bindingName, isDiscard: isDiscard, isVar: isVar, line: bindingToken.line, column: bindingToken.column))
				bindingNames.push(bindingName.toByteArray())
				if not isDiscard 'realBinding'
					allDiscard = false
				end 'realBinding'

				if at(TokenKind.rightParen) 'doneList'
					break
				end 'doneList'
				try expect(TokenKind.comma)
			end 'bindingLoop'
		end 'hasBindings'
		try eat(TokenKind.rightParen)

		// Arity validation against the owning union case is deferred to
		// TypeResolution — the parser can't see cross-file enum
		// declarations, and TR's match-arm walk knows the resolved
		// scrutinee type so it can produce the canonical E3035 with the
		// correct enum-case binding.

		// E3081: an all-discard pattern (`case(_, _)`) provides no usable
		// bindings; the bare-case form covers the same source intent more
		// clearly. Only fires when at least one binding was present —
		// `case()` with zero parens is already arity-checked above.
		if bindings.count() > 0 and allDiscard 'allDiscarded'
			reportCompileError(project, code: ErrorCode.semanticMatchDiscardedBindings, message: "all bindings in pattern '{caseToken.value}(...)' are discards; use the bare case name instead", line: caseToken.line, column: caseToken.column, filePath: filePath)
		end 'allDiscarded'

		return MatchPatternSpec.enumCaseWithBindings(caseToken, caseName: caseToken.value, bindings: bindings, bindingNames: bindingNames)
	end 'parseCaseBindingPattern'

	// Parse `caseName to|upto (caseName | max)`. Resolves both case
	// ordinals against the enum registry so the range op carries integer
	// bounds for lowering. On an unknown case name returns the bare-case
	// fallback so TypeResolution can produce the canonical diagnostic.
	function parseEnumRangePattern(loCaseName String, loToken Token) returns MatchPatternSpec throws ParserError
		let rangeTok = try consume()
		let isUpto = rangeTok.kind == TokenKind.upto
		let rangeKeyword = "upto" if isUpto else "to"

		let upperTok = cursor.current()
		var hasMaxSentinel = false
		var hiCaseName = ""
		var hiDisplay = ""
		if upperTok.kind == TokenKind.identifier and upperTok.value == "max" 'maxSentinel'
			try cursor.advance() otherwise throw ParserError.unexpectedEof
			hasMaxSentinel = true
			hiDisplay = "max"
		end 'maxSentinel' else 'caseUpper'
			if upperTok.value.isEmpty() 'noUpper'
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected upper-bound case name after '{rangeKeyword}', got '{tokenValueToString(upperTok.value)}'", line: upperTok.line, column: upperTok.column, filePath: filePath)
				return MatchPatternSpec.enumCase(loToken, caseName: loCaseName)
			end 'noUpper'
			let hiToken = try consume()
			hiCaseName = hiToken.value
			hiDisplay = hiCaseName
		end 'caseUpper'

		let displayName = "{loCaseName} {rangeKeyword} {hiDisplay}"

		// Look up both case ordinals. The first match (resolved or unresolved)
		// wins — same lookup strategy as `enumScrutineeDisplayNameFromCase`.
		var loOrdinal = -1
		var hiOrdinal = -1
		var foundEnum = false
		var ownerEnumName = ""
		for (name, enumType) in project.enumTypes 'searchResolved'
			if enumType.caseByName.contains(loCaseName) and (hasMaxSentinel or enumType.caseByName.contains(hiCaseName)) 'isHit'
				loOrdinal = (try enumType.caseByName.get(loCaseName) otherwise -1) as int
				if hasMaxSentinel 'maxHi'
					hiOrdinal = enumType.cases.count() as int - 1
				end 'maxHi' else 'lookupHi'
					hiOrdinal = (try enumType.caseByName.get(hiCaseName) otherwise -1) as int
				end 'lookupHi'
				ownerEnumName = name
				foundEnum = true
				break
			end 'isHit'
		end 'searchResolved'
		if not foundEnum 'tryUnresolved'
			for (name, enumType) in project.unresolvedEnums 'searchUnresolved'
				var foundLo = -1
				var foundHi = -1
				for i in 0 upto enumType.cases.count() 'cases'
					let c = try enumType.cases.get(i) otherwise panic("parseEnumRangePattern: cases OOB at {i}")
					if c.name == loCaseName 'loHit'
						foundLo = i as int
					end 'loHit'
					if not hasMaxSentinel and c.name == hiCaseName 'hiHit'
						foundHi = i as int
					end 'hiHit'
				end 'cases'
				if foundLo >= 0 and (hasMaxSentinel or foundHi >= 0) 'matchedEnum'
					loOrdinal = foundLo
					hiOrdinal = (enumType.cases.count() as int - 1) if hasMaxSentinel else foundHi
					ownerEnumName = name
					foundEnum = true
					break
				end 'matchedEnum'
			end 'searchUnresolved'
		end 'tryUnresolved'

		if not foundEnum 'unknownCase'
			// Defer to TypeResolution: emit a fallback bare-case arm. TR
			// will report E3005 / unknown-case when it resolves the
			// scrutinee.
			return MatchPatternSpec.enumCase(loToken, caseName: loCaseName)
		end 'unknownCase'

		// Single-value rejection: `red to red` or `red upto green` where
		// green is the next ordinal. Mirrors the integer-range check.
		let isToSame = not isUpto and hiOrdinal == loOrdinal
		let isUptoAdjacent = isUpto and hiOrdinal == loOrdinal + 1
		if isToSame or isUptoAdjacent 'singleValue'
			reportCompileError(project, code: ErrorCode.parserMatchDuplicatePattern, message: "range pattern '{displayName}' covers a single value; use the bare value instead", line: loToken.line, column: loToken.column, filePath: filePath)
		end 'singleValue'

		return MatchPatternSpec.enumRange(loToken, loOrdinal: loOrdinal as ParsedInt, hiOrdinal: hiOrdinal as ParsedInt, isUpto: isUpto, hasMaxSentinel: hasMaxSentinel, displayName: displayName, enumOwnerName: ownerEnumName)
	end 'parseEnumRangePattern'

	// True when `cursor.peek(offset)` is the `to` or `upto` keyword. Used
	// by the `min` lookahead — without this gate, a bare `min` identifier
	// elsewhere (e.g. a top-level constant named `min`) would be
	// misinterpreted as a range-pattern sentinel.
	function isFollowedByRangeKeyword(offset ElementCount) returns bool
		let tok = try cursor.peek(offset) otherwise return false
		return tok.kind == TokenKind.to or tok.kind == TokenKind.upto
	end 'isFollowedByRangeKeyword'

	// Parse the `to|upto (INT | char | max)` tail of a range pattern.
	// Caller has already consumed the lower bound (an int literal, a char
	// literal, or the `min` keyword) and provides its computed `loValue`
	// and source-form `loDisplay`. The cursor sits on `to` / `upto`. Emits
	// E2027 on a single-value range (`X to X`, `X upto X+1`) and returns
	// a fallback int literal so downstream arm wiring stays well-formed.
	function parseRangePattern(loValue ParsedInt, loDisplay String, loToken Token, hasMinSentinel bool) returns MatchPatternSpec throws ParserError
		let rangeTok = try consume()
		let isUpto = rangeTok.kind == TokenKind.upto
		let rangeKeyword = "upto" if isUpto else "to"

		// Open upper bound: `X to|upto max`. `max` is a contextual keyword
		// (an identifier whose spelling matches "max").
		let upperTok = cursor.current()
		if upperTok.kind == TokenKind.identifier and upperTok.value == "max" 'maxSentinel'
			try cursor.advance() otherwise throw ParserError.unexpectedEof
			let displayName = "{loDisplay} {rangeKeyword} max"
			return MatchPatternSpec.rangeLiteral(loToken, loValue: loValue, hiValue: 0, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: true, displayName: displayName)
		end 'maxSentinel'

		// Character literal upper bound: decode the literal bytes
		// identically to `decodeCharLiteralToByte` on the lower bound.
		var hiValue = 0 as ParsedInt
		var hiDisplay = ""
		if upperTok.kind == TokenKind.charLiteral 'isCharUpper'
			let hiToken = try consume()
			hiValue = decodeCharLiteralToByte(hiToken)
			hiDisplay = "'{tokenValueToString(hiToken.value)}'"
		end 'isCharUpper' else 'isIntUpper'
			var negateUpper = false
			if at(TokenKind.minus) 'isNegUpper'
				negateUpper = true
				try cursor.advance() otherwise throw ParserError.unexpectedEof
			end 'isNegUpper'

			if not at(TokenKind.intLiteral) 'noUpperLit'
				let badTok = cursor.current()
				reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected upper-bound integer literal (or 'max') after '{rangeKeyword}', got '{tokenValueToString(badTok.value)}'", line: badTok.line, column: badTok.column, filePath: filePath)
				return MatchPatternSpec.intLiteral(loToken, value: loValue, displayName: loDisplay)
			end 'noUpperLit'
			let hiToken = try consume()
			hiValue = try parseInt(hiToken.value) otherwise 'overflow'
				reportLiteralOverflow(token: hiToken, message: "Integer literal '{tokenValueToString(hiToken.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
				return MatchPatternSpec.intLiteral(loToken, value: loValue, displayName: loDisplay)
			end 'overflow'
			if negateUpper 'applyNegU'
				hiValue = 0 - hiValue
			end 'applyNegU'
			hiDisplay = "{hiValue}"
		end 'isIntUpper'
		let displayName = "{loDisplay} {rangeKeyword} {hiDisplay}"

		// Single-value range rejection (E2027). `X to X` covers exactly one
		// value; `X upto X+1` covers exactly one value too. Open-bound forms
		// are skipped — a `min`/`max` sentinel always spans more than one
		// value. Don't reject on `X upto X` (empty range) — that's a
		// distinct degenerate case the spec doesn't currently call out;
		// downstream lowering still produces a never-true cmp so behaviour
		// is harmless even if odd-looking.
		if not hasMinSentinel 'checkSingleValue'
			let isToSame = not isUpto and hiValue == loValue
			let isUptoAdjacent = isUpto and hiValue == loValue + 1
			if isToSame or isUptoAdjacent 'singleValue'
				reportCompileError(project, code: ErrorCode.parserMatchDuplicatePattern, message: "range pattern '{displayName}' covers a single value; use the bare value instead", line: loToken.line, column: loToken.column, filePath: filePath)
			end 'singleValue'
		end 'checkSingleValue'

		return MatchPatternSpec.rangeLiteral(loToken, loValue: loValue, hiValue: hiValue, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: false, displayName: displayName)
	end 'parseRangePattern'

	// Parse one arm's pattern list (either a single `default`, a single enum
	// case identifier, or one or more integer literals separated by `or`).
	// Returns the list along with whether it is a default arm. Tracks duplicate
	// patterns via `seenKeys` and reports E2027 on collision.
	function parseMatchArmPatterns(seenKeys ReferencedVarSet, defaultSeen bool) returns MatchPatternList throws ParserError
		var patterns = MatchPatternSpecArray.create()
		while true 'collect'
			let firstLine = cursor.current().line
			let firstCol = cursor.current().column
			let pattern = try parseOneMatchPattern()

			if pattern.isDefault() 'isDefault'
				patterns.push(pattern)
				return MatchPatternList.create(patterns: patterns)
			end 'isDefault'

			if defaultSeen 'afterDefault'
				reportCompileError(project, code: ErrorCode.parserMatchDefaultNotLast, message: "'default' case must be the last case in match", line: firstLine, column: firstCol, filePath: filePath)
			end 'afterDefault'
			let isPlainEnumCase = match pattern.kind 'k'
				enumCase gives true
				defaultArm gives false
				intLiteral gives false
				rangeLiteral gives false
			end 'k'
			// Detect overlap-via-range before the generic-duplicate path
			// so the diagnostic uses the "overlapping pattern" wording
			// expected by enum-match-exhaustive. A prior range arm
			// inserted every case name it covered into `seenKeys`.
			if isPlainEnumCase and seenKeys.contains(pattern.caseName) 'overlapsRange'
				reportCompileError(project, code: ErrorCode.parserMatchDuplicatePattern, message: "overlapping pattern in match: '{pattern.caseName}' is already covered", line: firstLine, column: firstCol, filePath: filePath)
			end 'overlapsRange' else 'normalDupCheck'
				if seenKeys.contains(pattern.displayName) 'isDup'
					reportCompileError(project, code: ErrorCode.parserMatchDuplicatePattern, message: "duplicate pattern in match: '{pattern.displayName}'", line: firstLine, column: firstCol, filePath: filePath)
				end 'isDup' else 'recordKey'
					seenKeys.insert(element: pattern.displayName)
					if isPlainEnumCase 'addCaseName'
						seenKeys.insert(element: pattern.caseName)
					end 'addCaseName'
				end 'recordKey'
			end 'normalDupCheck'
			patterns.push(pattern)

			if not at(TokenKind.or) 'noOr'
				return MatchPatternList.create(patterns: patterns)
			end 'noOr'
			try cursor.advance() otherwise throw ParserError.unexpectedEof
		end 'collect'
		return MatchPatternList.create(patterns: patterns)
	end 'parseMatchArmPatterns'

	// Look up the enum-type name that owns `caseName`. Walks both the
	// resolved registry and the parser-time unresolved entries because
	// match arms may reference an enum declared in the same file before
	// TypeResolution has promoted it. Returns "<unknown>" when no enum
	// claims the case (which only happens when the user typed a typo'd
	// case name — TR will surface the real diagnostic).
	function enumScrutineeDisplayNameFromCase(caseName String) returns String
		for (name, enumType) in project.enumTypes 'searchResolved'
			if enumType.caseByName.contains(caseName) 'isMatch'
				return name
			end 'isMatch'
		end 'searchResolved'
		for (name, enumType) in project.unresolvedEnums 'searchUnresolved'
			for c in enumType.cases 'cases'
				if c.name == caseName 'isMatch'
					return name
				end 'isMatch'
			end 'cases'
		end 'searchUnresolved'
		return "<unknown>"
	end 'enumScrutineeDisplayNameFromCase'

	// Type-driven enum-scrutinee predicate, used to gate E2046 (`default`
	// without `throws`/`panic`). Returns true only when the scrutinee's
	// `MaxonType` is statically known to be a non-enum primitive at parse
	// time — `bool` / `int` / `float` / `String` / known struct names.
	// When the scrutinee type is `unresolved` (the common case for local
	// variable references whose types haven't propagated yet) we defer to
	// pattern-shape inference, which the caller combines with this result.
	function matchScrutineeIsKnownNonEnum(t MaxonType) returns bool
		return match t 'check'
			boolean gives true
			integer gives true
			float gives true
			string gives true
			function gives true
			named(id) gives namedTypeIsKnownNonEnum(project.typeNames.get(id))
			unresolved gives false
			typeParameter gives false
			genericInstance gives true
			interface gives true
			constInt gives false
		end 'check'
	end 'matchScrutineeIsKnownNonEnum'

	// Companion to `matchScrutineeIsKnownNonEnum`: a `named` reference is
	// non-enum iff it resolves to a registered struct/typealias and not an
	// enum. Returns false when the name is unknown (could be an unresolved
	// enum we haven't seen yet — caller treats this as ambiguous).
	function namedTypeIsKnownNonEnum(name String) returns bool
		if name.isEmpty() 'noName'
			return false
		end 'noName'
		if project.enumTypes.contains(name) or project.unresolvedEnums.contains(name) 'isEnum'
			return false
		end 'isEnum'
		if project.structTypes.contains(name) or project.unresolvedStructTypes.contains(name) 'isStruct'
			return true
		end 'isStruct'
		if project.typealiases.contains(name) or project.unresolvedTypealiases.contains(name) 'isAlias'
			return true
		end 'isAlias'
		return false
	end 'namedTypeIsKnownNonEnum'

	// Match-expression arms forbid `and fallthrough`. The Pratt parser stops
	// at the boundary because of the `inMatchArmBody` gate, but we still need
	// to surface E2001 (unexpected `and`) at the leftover token. Caller has
	// already finished parsing the arm's expression; on entry the cursor sits
	// on `and` if a fallthrough was present.
	function rejectFallthroughInMatchExpression()
		if at(TokenKind.and) and atOffset(TokenKind.fallthrough, offset: 1) 'badFt'
			let andToken = cursor.current()
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "unexpected token: 'and'", line: andToken.line, column: andToken.column, filePath: filePath)
		end 'badFt'
	end 'rejectFallthroughInMatchExpression'

	// Enforce E2026 — every enum case must be covered when matching on an
	// enum without a `default` arm. The caller passes the scrutinee's enum
	// name when its `MaxonType` resolves to a known enum at parse time;
	// otherwise we fall back to searching enum registries for `lastEnumCaseName`.
	// The type-driven path is required once stdlib enums are restored from
	// cache because case names like `notFound` appear in multiple enums
	// (StringError, FileError, ...) and a pure case-name search returns the
	// first one that hits — misrouting the diagnostic when a user enum reuses
	// the same case name.
	function validateEnumExhaustiveness(hasEnumArm bool, hasDefault bool, lastEnumCaseName String, scrutineeEnumName String, seenKeys ReferencedVarSet, errorLine LineNumber, errorColumn ColumnNumber)
		if not hasEnumArm 'noEnum'
			return
		end 'noEnum'
		if hasDefault 'hasDefault'
			return
		end 'hasDefault'
		var enumName = scrutineeEnumName
		if enumName.isEmpty() 'fallbackToCaseSearch'
			enumName = enumScrutineeDisplayNameFromCase(lastEnumCaseName)
		end 'fallbackToCaseSearch'
		var missing = ""
		if let resolvedEnum = try project.enumTypes.get(enumName) 'isResolved'
			missing = enumMissingCases(resolvedEnum.cases, seenKeys: seenKeys)
		end 'isResolved' else 'tryUnresolved'
			if let unresolvedEnum = try project.unresolvedEnums.get(enumName) 'isUnresolved'
				missing = enumMissingCases(unresolvedEnum.cases, seenKeys: seenKeys)
			end 'isUnresolved'
		end 'tryUnresolved'
		if missing.isEmpty() 'allCovered'
			return
		end 'allCovered'
		reportCompileError(project, code: ErrorCode.parserMatchNotExhaustive, message: "match on enum '{enumName}' is not exhaustive, missing: {missing}", line: errorLine, column: errorColumn, filePath: filePath)
	end 'validateEnumExhaustiveness'

	// Return the scrutinee's enum name when its MaxonType resolves to a
	// known enum at parse time. Empty string for unresolved types or non-enum
	// types so the caller can fall back to case-name search.
	function enumScrutineeDisplayNameFromType(t MaxonType) returns String
		let name = t.nameOrEmpty(project)
		if name.isEmpty() 'noName'
			return ""
		end 'noName'
		if project.enumTypes.contains(name) or project.unresolvedEnums.contains(name) 'isEnum'
			return name
		end 'isEnum'
		return ""
	end 'enumScrutineeDisplayNameFromType'

	// Resolve `enumName.ordinal` to a case name. Throws
	// `EnumCaseProbeError.notFound` when the enum isn't registered or the
	// ordinal is out of range — the parser has already emitted a fallback
	// at that point, or TR will surface the canonical diagnostic.
	function enumCaseNameAtOrdinal(enumName String, ordinal ParsedInt) returns String throws EnumCaseProbeError
		if let resolvedEnum = try project.enumTypes.get(enumName) 'isResolved'
			if ordinal >= 0 and ordinal < resolvedEnum.cases.count() 'inRange'
				let c = try resolvedEnum.cases.get(ordinal as ElementCount) otherwise panic("enumCaseNameAtOrdinal: in-range ordinal {ordinal} but cases.get failed for enum '{enumName}'")
				return c.name
			end 'inRange'
		end 'isResolved'
		if let unresolvedEnum = try project.unresolvedEnums.get(enumName) 'isUnresolved'
			if ordinal >= 0 and ordinal < unresolvedEnum.cases.count() 'inRange2'
				let c = try unresolvedEnum.cases.get(ordinal as ElementCount) otherwise panic("enumCaseNameAtOrdinal: in-range ordinal {ordinal} but cases.get failed for enum '{enumName}'")
				return c.name
			end 'inRange2'
		end 'isUnresolved'
		throw EnumCaseProbeError.notFound
	end 'enumCaseNameAtOrdinal'

	// Mark every case name in [loValue..hiValue] (inclusive of lo; upper
	// inclusive for `to`, exclusive for `upto`) as covered. Used after
	// detecting an enum-case range arm so exhaustiveness sees the
	// ordinals the range spans.
	function markEnumRangeCases(seenKeys ReferencedVarSet, pattern MatchPatternSpec)
		let upperInclusive = pattern.hiValue if not pattern.isUpto else pattern.hiValue - 1
		var i = pattern.loValue
		while i <= upperInclusive 'each'
			if let name = try enumCaseNameAtOrdinal(enumName: pattern.enumOwnerName, ordinal: i) 'hit'
				if seenKeys.contains(name) 'isDup'
					reportCompileError(project, code: ErrorCode.parserMatchDuplicatePattern, message: "overlapping pattern in match: '{name}' is already covered", line: pattern.token.line, column: pattern.token.column, filePath: filePath)
				end 'isDup' else 'newName'
					seenKeys.insert(element: name)
				end 'newName'
			end 'hit'
			i = i + 1
		end 'each'
	end 'markEnumRangeCases'

	// Comma-separated list of case names not present in `seenKeys`. Returns
	// an empty string when every case is covered. Used by E2026 messages.
	function enumMissingCases(cases EnumCaseArray, seenKeys ReferencedVarSet) returns String
		var missing = ""
		var first = true
		for c in cases 'eachCase'
			if seenKeys.contains(c.name) 'isCovered'
				continue
			end 'isCovered'
			if first 'firstMiss'
				missing.append(c.name)
				first = false
			end 'firstMiss' else 'subsequent'
				missing.append(", ")
				missing.append(c.name)
			end 'subsequent'
		end 'eachCase'
		return missing
	end 'enumMissingCases'

	// Emit pattern-comparison ops into `block` and return the boolean SSA name
	// holding the combined OR of all comparisons. Caller passes a list of
	// integer-literal patterns; `block` is the comparison block (already
	// allocated). Handles single-pattern and multi-pattern (or-chain) cases.
	function emitIntPatternComparisons(block IrBlock, scrutineeName ByteArray, patterns MatchPatternSpecArray) returns ByteArray
		var combined = ByteArray.create()
		var hasCombined = false
		for pattern in patterns 'each'
			let litRange = SourceRange.ofToken(pattern.token)
			let litName = emitLiteral(block, value: pattern.intValue, valueType: MaxonType.integer, range: litRange)
			let cmpName = freshSynthName()
			module.appendOp(block, op: MaxonOp.cmp(cmpName, left: scrutineeName, right: litName, predicate: CmpPredicate.eq, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: litRange))
			if not hasCombined 'first'
				combined = cmpName
				hasCombined = true
			end 'first' else 'fold'
				let orName = freshSynthName()
				module.appendOp(block, op: MaxonOp.binop(orName, left: combined, right: cmpName, opKind: BinOpKind.bitOr, operandType: MaxonType.integer, range: litRange))
				combined = orName
			end 'fold'
		end 'each'
		return combined
	end 'emitIntPatternComparisons'

	// Parse a statement-form arm body, returning the exit block plus a flag
	// signalling whether the body was a `return` (so the parser can reject
	// `return ... and fallthrough` per E2025). Bodies may be a return, a
	// simple assignment, or a void expression-statement (function call).
	// Sets `inMatchArmBody` so the Pratt parser stops before `and fallthrough`.
	function parseMatchStatementArmBody(block IrBlock) returns MatchStmtArmBodyResult throws ParserError
		let savedInMatchArmBody = inMatchArmBody
		inMatchArmBody = true
		let result = try parseMatchStatementArmBodyInner(block)
		inMatchArmBody = savedInMatchArmBody
		return result
	end 'parseMatchStatementArmBody'

	// Parse a single expression for a match-expression arm body. Sets
	// `inMatchArmBody` so the Pratt parser stops at `and fallthrough`
	// (E2001 is reported separately by `rejectFallthroughInMatchExpression`).
	function parseMatchExpressionArmBody(block IrBlock) returns ExprResult throws ParserError
		let savedInMatchArmBody = inMatchArmBody
		inMatchArmBody = true
		let result = try parseExpression(block)
		inMatchArmBody = savedInMatchArmBody
		return result
	end 'parseMatchExpressionArmBody'

	function parseMatchStatementArmBodyInner(block IrBlock) returns MatchStmtArmBodyResult throws ParserError
		currentBlock = block
		let stmtToken = cursor.current()
		// Reject block-opening statements as arm bodies (E2049). The single-
		// statement arm shape forbids `if`/`while`/`for`/`match`; block-form
		// `try` (`try 'label' ... end 'label'` and `try ... otherwise 'l' ... end 'l'`)
		// is also rejected because it would allocate persistent error-flag
		// slots in the enclosing scope.
		if isBlockOpeningArmBodyToken(stmtToken) 'block'
			reportMatchArmBlockStatement(stmtToken)
			synchronize()
			return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: false)
		end 'block'
		if stmtToken.kind == TokenKind.try and isTryBlockForm() 'tryBlock'
			reportMatchArmTryBlockForm(stmtToken)
			synchronize()
			return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: false)
		end 'tryBlock'
		if stmtToken.kind == TokenKind.return 'isReturn'
			try parseReturnStatement(block)
			return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: true)
		end 'isReturn'
		if stmtToken.kind == TokenKind.break 'isBreak'
			let exitBlock = try parseBreakStatement(currentFunc, block: block)
			currentBlock = exitBlock
			return MatchStmtArmBodyResult.create(exitBlock: exitBlock, hadReturn: false)
		end 'isBreak'
		if stmtToken.kind == TokenKind.continue 'isContinue'
			let exitBlock = try parseContinueStatement(currentFunc, block: block)
			currentBlock = exitBlock
			return MatchStmtArmBodyResult.create(exitBlock: exitBlock, hadReturn: false)
		end 'isContinue'
		if stmtToken.kind == TokenKind.identifier 'maybeAssign'
			let peekTok = try cursor.peek(1) otherwise throw ParserError.unexpectedEof
			if peekTok.kind == TokenKind.equals 'isAssign'
				try parseVarAssignment(block)
				return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: false)
			end 'isAssign'
		end 'maybeAssign'
		// Statement-form `try EXPR [otherwise FALLBACK]` in a match arm:
		// route through parseTryExpression with isStatementContext=true so
		// the void-return guard (E3059) is skipped — the call result is
		// discarded at statement position. parseExpression's default path
		// would call parseTryExpression(isStatementContext=false) and
		// mis-flag a void-returning callee.
		if stmtToken.kind == TokenKind.try 'isTryStmt'
			_ = try parseTryExpression(currentBlock, isStatementContext: true)
			return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: false)
		end 'isTryStmt'
		_ = try parseExpression(block)
		return MatchStmtArmBodyResult.create(exitBlock: currentBlock, hadReturn: false)
	end 'parseMatchStatementArmBodyInner'

	// Token kinds that open a multi-statement block construct. Rejected
	// as match-arm bodies (E2049).
	function isBlockOpeningArmBodyToken(tok Token) returns bool
		return tok.kind == TokenKind.if or tok.kind == TokenKind.while or tok.kind == TokenKind.for or tok.kind == TokenKind.match
	end 'isBlockOpeningArmBodyToken'

	// True when the cursor sits at `try 'label'` (block form). The
	// single-statement form is `try callee()` — the next token is an
	// identifier, not a char literal.
	function isTryBlockForm() returns bool
		let next = try cursor.peek(1) otherwise return false
		return next.kind == TokenKind.charLiteral
	end 'isTryBlockForm'

	function reportMatchArmBlockStatement(tok Token)
		reportCompileError(project, code: ErrorCode.parserMatchBlockStatementNotAllowed, message: "block-opening statement '{tokenValueToString(tok.value)}' is not allowed in a match arm; use a function call instead", line: tok.line, column: tok.column, filePath: filePath)
	end 'reportMatchArmBlockStatement'

	function reportMatchArmTryBlockForm(tok Token)
		reportCompileError(project, code: ErrorCode.parserMatchBlockStatementNotAllowed, message: "block-form 'try ... end' is not allowed in a match arm; use a single-statement try form (e.g. 'try call()' or 'try call() otherwise panic(...)') instead", line: tok.line, column: tok.column, filePath: filePath)
	end 'reportMatchArmTryBlockForm'

	// Emit a `panic` op + synthetic `ret 0` so the static verifier sees the
	// block terminated. The runtime never reaches these — they only fire on
	// an exhaustive match where every arm already returned.
	function emitMatchUnreachableTerminator(block IrBlock)
		let unreachableMsg = project.strings.intern("unreachable: non-exhaustive match")
		module.appendOp(block, op: MaxonOp.panic(unreachableMsg, range: SourceRange.none()))
		let zero = emitLiteral(block, value: 0, valueType: MaxonType.integer)
		module.setTerminator(block, op: MaxonOp.ret(zero, range: SourceRange.none()))
	end 'emitMatchUnreachableTerminator'

	// Mark `block` as `Terminator.dead` (treated as terminated by isTerminated)
	// when it has no terminator yet. Exists because the parser type-system
	// rules forbid mutating a field of a `let`-bound struct in-place at the
	// caller site; threading the block through this helper sidesteps that.
	function markBlockDeadIfUnset(block IrBlock)
		var b = block
		if not b.isTerminated() 'unset'
			b.terminator = Terminator.dead
		end 'unset'
	end 'markBlockDeadIfUnset'

	// Allocate the per-arm body and "next" (cmp-or-fallback) blocks and emit
	// the arm's dispatch into `currentBlock` (the shared cmp block for this
	// arm). For enum-case patterns we keep using the legacy `enumMatchArm` op
	// so TR resolves the case name. For integer-literal patterns we emit
	// literal+cmp+(or)+condBr inline. Default arms get only a body block; the
	// caller wires them after all non-default arms are placed.
	function buildMatchArmBlocks(header MatchHeader, armIndex IntConstant, patterns MatchPatternList, separator TokenKind) returns MatchArmBlocks throws ParserError
		let firstPattern = patterns.first()
		// Diverging arm body: `panic(...)` / `throws Err.case` in place of
		// the then/gives separator. Supported on both `default` and bare
		// patterns (per match-expr-arm-divergent / match-exhaustive-default-
		// panic). The arm body is terminated in-place and contributes no
		// value to a match-expression result-type unifier.
		if at(TokenKind.panic) or at(TokenKind.throws) 'diverging'
			var armBodyBlock = module.addBlockAt(currentFunc, label: "{header.baseLabel}.case{armIndex}", filePath: filePath.toString(), firstLine: firstPattern.token.line)
			if patterns.isDefault() 'isDefaultDiverging'
				try emitDivergingDefaultArm(armBodyBlock)
				return MatchArmBlocks.create(caseToken: firstPattern.token, body: armBodyBlock, next: armBodyBlock, bodyAlreadyTerminated: true)
			end 'isDefaultDiverging'
			// Non-default diverging arm: dispatch into armBodyBlock on
			// pattern match, fall through to nextArmBlock otherwise.
			let nextArmBlock = module.addBlockAt(currentFunc, label: "{header.baseLabel}.next{armIndex}", filePath: filePath.toString(), firstLine: firstPattern.token.line)
			emitArmDispatch(header, patterns: patterns, armBodyId: armBodyBlock.id, nextArmId: nextArmBlock.id)
			try emitDivergingDefaultArm(armBodyBlock)
			return MatchArmBlocks.create(caseToken: firstPattern.token, body: armBodyBlock, next: nextArmBlock, bodyAlreadyTerminated: true)
		end 'diverging'
		try expect(separator)
		let armBodyBlock = module.addBlockAt(currentFunc, label: "{header.baseLabel}.case{armIndex}", filePath: filePath.toString(), firstLine: firstPattern.token.line)
		if patterns.isDefault() 'isDefault'
			// Default arms are bodies only; the caller wires entry once it
			// knows the position. Return a body-only sentinel.
			return MatchArmBlocks.create(caseToken: firstPattern.token, body: armBodyBlock, next: armBodyBlock)
		end 'isDefault'
		let nextArmBlock = module.addBlockAt(currentFunc, label: "{header.baseLabel}.next{armIndex}", filePath: filePath.toString(), firstLine: firstPattern.token.line)
		emitArmDispatch(header, patterns: patterns, armBodyId: armBodyBlock.id, nextArmId: nextArmBlock.id)
		return MatchArmBlocks.create(caseToken: firstPattern.token, body: armBodyBlock, next: nextArmBlock)
	end 'buildMatchArmBlocks'

	// Shared dispatch emission for any non-default arm. Routes to:
	//   - `enumMatchArm` for enum-case patterns (TR fills the raw value)
	//   - chained `emitMixedPatternDispatch` for any arm containing a
	//     range pattern (handles `1 to 5 or 8 to 10` and friends)
	//   - direct `cmp + condBr` for plain integer-literal patterns
	function emitArmDispatch(header MatchHeader, patterns MatchPatternList, armBodyId BlockId, nextArmId BlockId)
		let firstPattern = patterns.first()
		if patterns.isEnumCase() 'isEnum'
			// Enum case names need TR to resolve the raw value. Reuse the
			// existing enumMatchArm op. or-patterns of enum cases aren't
			// reached today (no spec test exercises them) but the placeholder
			// op family permits one arm = one case name.
			module.setTerminator(currentBlock, op: MaxonOp.enumMatchArm(header.scrutineeName, caseName: firstPattern.caseName, scrutineeType: MaxonType.unresolved, rawValue: 0, isFloat: false, resolved: false, thenTarget: armBodyId, elseTarget: nextArmId, bindingNames: firstPattern.bindingNames, range: SourceRange.ofToken(firstPattern.token)))
			return
		end 'isEnum'
		// Range patterns OR-chained with bare int literals are emitted as a
		// sequence of branches into the arm body: each pattern gets its own
		// comparison block, and they fall through to the next pattern on a
		// miss. This handles `1 or 3 to 5 then ...` and `1 to 5 or 8 to 10`
		// uniformly. A single pattern degenerates to either a `rangeMatchArm`
		// (range case) or the legacy `condBr` (int-literal case).
		if patternsContainRange(patterns) 'hasRange'
			emitMixedPatternDispatch(header, patterns: patterns, armBodyId: armBodyId, nextArmId: nextArmId)
			return
		end 'hasRange'
		let combinedCmp = emitIntPatternComparisons(currentBlock, scrutineeName: header.scrutineeName, patterns: patterns.patterns)
		module.setTerminator(currentBlock, op: MaxonOp.condBr(combinedCmp, thenTarget: armBodyId, elseTarget: nextArmId, range: SourceRange.ofToken(firstPattern.token)))
	end 'emitArmDispatch'

	// Phase 9 Stage 3: declare scope variables and emit payload-read +
	// varStore ops at the head of the parser's `currentBlock` for each
	// non-discard binding in an enum-case arm whose scrutinee is a union.
	// Bindings become regular locals so user code like
	// `value(n) then return n` reaches `n` via the standard varLoad path.
	// Discard (`_`) bindings produce no slot and no read. Bare-enum
	// (non-union) scrutinees and arms without bindings skip silently.
	// The payload field's MaxonType is resolved later by TR — the parser
	// can't see cross-file union declarations, and the case's payload
	// arity / field types live in registries TR drains. The caller must
	// position `currentBlock` on the arm body block before invoking.
	function emitUnionArmBindings(scrutineeName ByteArray, pattern MatchPatternSpec, scrutineeMutable bool) returns bool
		if pattern.bindings.count() == 0 'noBindings'
			return false
		end 'noBindings'
		for i in 0 upto pattern.bindings.count() 'eachBinding'
			let binding = try pattern.bindings.get(i) otherwise panic("emitUnionArmBindings: bindings.get OOB at {i}")
			if binding.isDiscard 'discardBinding'
				continue
			end 'discardBinding'
			// Phase 9 Stage 4: payload bindings inherit the scrutinee's
			// mutability per `mutable-enums.md`: a `var u` scrutinee yields
			// writable bindings (assignment rewrites to `enumPayloadStore`);
			// a `let u` scrutinee yields read-only bindings (assignment
			// fires E2013). The per-binding `var` keyword on the pattern
			// (`full(var v)`) is explicit syntax for "I plan to write this"
			// but does NOT override the scrutinee's immutability — `let u`
			// + `var v = …` still surfaces E2013.
			let bindingMutable = scrutineeMutable
			let bindingSlot = scope.declarePayloadBinding(binding.name, varType: MaxonType.unresolved, mutable: bindingMutable, scrutineeName: String.from(scrutineeName), fieldIndex: i as CaseOrdinal, caseName: pattern.caseName)
			let readName = "__match_payload_{binding.name}_{i}".toByteArray()
			module.appendOp(currentBlock, op: MaxonOp.enumPayloadRead(readName, enumValName: scrutineeName, caseName: pattern.caseName, fieldIndex: i as IntConstant, fieldType: MaxonType.unresolved, range: SourceRange.none()))
			module.appendOp(currentBlock, op: MaxonOp.varDecl(bindingSlot, value: readName, slotType: MaxonType.unresolved, range: SourceRange.none()))
		end 'eachBinding'
		return true
	end 'emitUnionArmBindings'

	// Emit the body of a `default panic(...)` or `default throws Err.case`
	// arm into `armBodyBlock`. The arm body terminates the block directly:
	// `panic` appends a panic op then emits a synthetic `ret 0` so the
	// verifier sees a terminated block; `throws` sets a throw terminator.
	// Caller has positioned the cursor at the `panic` / `throws` keyword.
	function emitDivergingDefaultArm(armBodyBlock IrBlock) throws ParserError
		if at(TokenKind.panic) 'isPanic'
			try parsePanicStatement(armBodyBlock)
			// `panic` is a regular op, not a terminator — finish the
			// block with a synthetic `ret 0` so the verifier sees a
			// terminated CFG. The runtime never reaches the ret because
			// `panic` aborts.
			let zero = emitLiteral(armBodyBlock, value: 0, valueType: MaxonType.integer)
			module.setTerminator(armBodyBlock, op: MaxonOp.ret(zero, range: SourceRange.none()))
			return
		end 'isPanic'
		// `default throws Err.case [(args)]` — same source shape as a
		// `throw` statement but uses the `throws` keyword (which elsewhere
		// appears on function signatures). Consume it and reuse the
		// `EnumName.variantName` parse path; associated-value payloads
		// (Phase 9 Stage 5c) thread the constructed union pointer through
		// the throw op's `payloadValueName` slot.
		let throwsToken = try consume()
		let typeNameToken = try consumeExpecting("error type name")
		try expect(TokenKind.dot)
		let variantToken = try consumeExpecting("error variant name")
		if at(TokenKind.leftParen) 'hasPayload'
			let ctorCall = try emitUnionThrowConstruction(armBodyBlock, typeNameToken: typeNameToken, variantToken: variantToken)
			module.setTerminator(armBodyBlock, op: MaxonOp.throw(typeNameToken.value, variantName: variantToken.value, payloadValueName: ctorCall.resultName, range: SourceRange.between(throwsToken, last: ctorCall.lastToken)))
			return
		end 'hasPayload'
		module.setTerminator(armBodyBlock, op: MaxonOp.throw(typeNameToken.value, variantName: variantToken.value, payloadValueName: ByteArray.create(), range: SourceRange.between(throwsToken, last: variantToken)))
	end 'emitDivergingDefaultArm'

	// True if any pattern in the list is a range literal. Used by
	// `buildMatchArmBlocks` to pick the chained-dispatch lowering when the
	// arm mixes range and/or bare-int patterns.
	function patternsContainRange(patterns MatchPatternList) returns bool
		for p in patterns.patterns 'each'
			if p.isRange() 'isRange'
				return true
			end 'isRange'
		end 'each'
		return false
	end 'patternsContainRange'

	// Emit a chain of one-pattern-per-block dispatchers for an arm whose
	// pattern list contains at least one range. Each pattern's success
	// branches to `armBodyId`; a miss flows to the next pattern's block.
	// The final miss flows to `nextArmId` (the caller's "no match" target).
	function emitMixedPatternDispatch(header MatchHeader, patterns MatchPatternList, armBodyId BlockId, nextArmId BlockId)
		let count = patterns.patterns.count()
		var cur = currentBlock
		for i in 0 upto count 'each'
			let pat = try patterns.patterns.get(i) otherwise panic("emitMixedPatternDispatch: patterns OOB at {i}")
			var elseBlock = cur
			var elseId = nextArmId
			if i + 1 < count 'hasNext'
				elseBlock = module.addBlockAt(currentFunc, label: "{header.baseLabel}.cmp{i + 1}", filePath: filePath.toString(), firstLine: pat.token.line)
				elseId = elseBlock.id
			end 'hasNext'
			emitOnePatternDispatch(header, cur: cur, pattern: pat, thenId: armBodyId, elseId: elseId)
			if i + 1 < count 'advance'
				cur = elseBlock
			end 'advance'
		end 'each'
	end 'emitMixedPatternDispatch'

	// Emit a single pattern's dispatch terminator into `block`. Bare int
	// literals lower to `cmp + condBr`; range literals lower to a
	// `rangeMatchArm` terminator. Enum / default never reach this helper —
	// they take dedicated paths in `buildMatchArmBlocks`.
	function emitOnePatternDispatch(header MatchHeader, cur IrBlock, pattern MatchPatternSpec, thenId BlockId, elseId BlockId)
		let patRange = SourceRange.ofToken(pattern.token)
		match pattern.kind 'kind'
			rangeLiteral then module.setTerminator(cur, op: MaxonOp.rangeMatchArm(header.scrutineeName, loValue: pattern.loValue, hiValue: pattern.hiValue, isUpto: pattern.isUpto, hasMinSentinel: pattern.hasMinSentinel, hasMaxSentinel: pattern.hasMaxSentinel, enumOwnerName: pattern.enumOwnerName if pattern.isEnumRange else "", thenTarget: thenId, elseTarget: elseId, range: patRange))
			intLiteral then emitIntPatternCondBr(cur, scrutineeName: header.scrutineeName, pattern: pattern, thenId: thenId, elseId: elseId)
			defaultArm then panic("emitOnePatternDispatch: default arm should be handled by buildMatchArmBlocks")
			enumCase then panic("emitOnePatternDispatch: enum-case arm should be handled by buildMatchArmBlocks")
		end 'kind'
	end 'emitOnePatternDispatch'

	// Emit `const + cmp + condBr` for a single bare-int literal pattern.
	// Mirrors a one-iteration body of `emitIntPatternComparisons` but
	// terminates the block directly rather than threading a combined OR.
	function emitIntPatternCondBr(block IrBlock, scrutineeName ByteArray, pattern MatchPatternSpec, thenId BlockId, elseId BlockId)
		let litRange = SourceRange.ofToken(pattern.token)
		let litName = emitLiteral(block, value: pattern.intValue, valueType: MaxonType.integer, range: litRange)
		let cmpName = freshSynthName()
		module.appendOp(block, op: MaxonOp.cmp(cmpName, left: scrutineeName, right: litName, predicate: CmpPredicate.eq, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: litRange))
		module.setTerminator(block, op: MaxonOp.condBr(cmpName, thenTarget: thenId, elseTarget: elseId, range: litRange))
	end 'emitIntPatternCondBr'

	// Parse: match <expr> 'label' <arms> end 'label' — statement form. Each
	// arm is `<patterns> then <statement>`. Patterns are integer literals
	// (possibly or-chained), bare enum case names, or `default`. Optional
	// `and fallthrough` chains the body to the next arm's body block.
	function parseMatchStatement(block IrBlock) returns IrBlock throws ParserError
		currentBlock = block
		let header = try parseMatchHeader()
		if header.failed 'bailout'
			synchronize()
			return currentBlock
		end 'bailout'
		let mergeBlockId = header.mergeBlock.id

		// Push a match context so `break` inside an arm body exits the match
		// (not an enclosing loop). Mirrors the bootstrap's _matchStack — an
		// unlabeled break prefers match when one is on the stack; a labeled
		// break searches both stacks by SourceLabel. Popped at the end of
		// arm parsing.
		matchStack.push(MatchContext.create(sourceLabel: header.userLabel, mergeBlockId: mergeBlockId))

		var bodies = IrBlockArray.create()
		var fallthroughs = BoolArray.create()
		var defaultBodyId = 0 as BlockId
		var hasDefault = false
		var armIndex = 0 as IntConstant
		var anyArmReachesMerge = false
		var seenKeys = ReferencedVarSet.create()
		var defaultSeen = false
		var hasEnumArm = false
		var lastEnumCaseName = ""
		// E2046 must gate on the scrutinee type, not on pattern shape:
		// `parseOneMatchPattern`'s catch-all synthesizes an `enumCase` pattern
		// for any non-int/non-char/non-default token (string / float literals
		// included), so `hasEnumArm` over-fires on non-enum scrutinees.
		let scrutineeIsKnownNonEnum = matchScrutineeIsKnownNonEnum(header.scrutineeType)

		while not isMatchArmsEnd() 'arms'
			let armPrevPos = cursor.index()
			let patterns = try parseMatchArmPatterns(seenKeys, defaultSeen: defaultSeen)
			// `dispatchBlock` is where this arm's comparison/dispatch lives —
			// for non-default arms it gets the cmp+condBr (or enumMatchArm)
			// terminator wired into `arm.next`; for a default arm it must
			// branch unconditionally into the default body. Capture before
			// `buildMatchArmBlocks` so a default-arm dispatch can be wired
			// after the loop without losing the entry block.
			let dispatchBlock = currentBlock
			// E2046 fires on `default then ...` for enum scrutinees — but
			// `default panic(...)` / `default throws Err.x` are exactly
			// the satisfying forms it directs the user to. Defer the
			// check past those diverging shapes.
			let isDivergingDefault = at(TokenKind.panic) or at(TokenKind.throws)
			if patterns.isDefault() and hasEnumArm and not scrutineeIsKnownNonEnum and not isDivergingDefault 'defaultOnEnum'
				reportDefaultOnEnumMatch(patterns, lastEnumCaseName: lastEnumCaseName)
			end 'defaultOnEnum'
			if patterns.isEnumCase() 'recordEnum'
				hasEnumArm = true
				lastEnumCaseName = patterns.first().caseName
			end 'recordEnum'
			// An enum-case range arm (`red to blue`) counts as an enum
			// arm for exhaustiveness / E2046 purposes even though the
			// pattern kind is `rangeLiteral`.
			if patterns.first().isEnumRange 'recordEnumRange'
				hasEnumArm = true
				// Use any case from the range to identify the owning
				// enum for diagnostics. The first ordinal's case name is
				// recovered via the enum registry; if missing we skip
				// (TR will surface the canonical diagnostic).
				if let rangeCaseName = try enumCaseNameAtOrdinal(enumName: patterns.first().enumOwnerName, ordinal: patterns.first().loValue) 'updateLast'
					lastEnumCaseName = rangeCaseName
				end 'updateLast'
				// Mark every covered ordinal's case name in seenKeys so
				// enum exhaustiveness sees the range's contribution.
				markEnumRangeCases(seenKeys, pattern: patterns.first())
			end 'recordEnumRange'
			let arm = try buildMatchArmBlocks(header, armIndex: armIndex, patterns: patterns, separator: TokenKind.then)
			if patterns.isDefault() 'recordDefault'
				hasDefault = true
				defaultBodyId = arm.body.id
				defaultSeen = true
				module.setTerminator(dispatchBlock, op: MaxonOp.br(arm.body.id, range: SourceRange.none()))
			end 'recordDefault'

			currentBlock = arm.body
			// Diverging arm bodies (`panic(...)` / `throws Err.x`) — for
			// `default` and bare patterns alike — are fully constructed
			// by `buildMatchArmBlocks`: the body block is sealed with a
			// terminator and the cursor has moved past the diverging
			// keyword's payload. Skip arm-body parsing for these and
			// advance `currentBlock` to the arm's next-block so the
			// outer dispatch chain continues to flow.
			if arm.bodyAlreadyTerminated 'preTerminated'
				bodies.push(arm.body)
				fallthroughs.push(false)
				if not patterns.isDefault() 'advanceCursorEarly'
					currentBlock = arm.next
				end 'advanceCursorEarly'
				armIndex = armIndex + 1
				try skipNewlines()
				if cursor.index() <= armPrevPos 'stuckEarly'
					break
				end 'stuckEarly'
				continue
			end 'preTerminated'

			// Phase 9 Stage 3: emit payload-binding reads at the head of
			// the arm body before parsing the user's statements, so that
			// user code observes each binding as a normal scope-local. The
			// helper is a no-op on bindings-free arms and non-union
			// scrutinees. Position `currentBlock` on the arm body first so
			// the helper can append ops via the parser's normal block
			// pointer (avoiding the `let arm = …` immutability friction).
			scope.pushScope()
			currentBlock = arm.body
			_ = emitUnionArmBindings(header.scrutineeName, pattern: patterns.first(), scrutineeMutable: header.scrutineeMutable)
			let bodyExit = try parseMatchStatementArmBody(arm.body)
			scope.popScope()
			let armHasFallthrough = checkAndConsumeFallthrough(hadReturn: bodyExit.hadReturn)

			bodies.push(arm.body)
			fallthroughs.push(armHasFallthrough)

			if not bodyExit.exitBlock.isTerminated() 'armReachesMerge'
				anyArmReachesMerge = true
				// Wire fallthrough later (after we know the next arm's body)
				if not armHasFallthrough 'noFt'
					module.setTerminator(bodyExit.exitBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.none()))
				end 'noFt'
			end 'armReachesMerge'

			if not patterns.isDefault() 'advanceCursor'
				currentBlock = arm.next
			end 'advanceCursor'
			armIndex = armIndex + 1
			try skipNewlines()
			// Stuck-guard: a malformed arm (truncated input, default pattern
			// returned without consumption) can leave the cursor untouched.
			// Break rather than spin so error recovery surfaces a single
			// diagnostic instead of allocating per-iteration arm blocks.
			if cursor.index() <= armPrevPos 'stuck'
				break
			end 'stuck'
		end 'arms'

		// `currentBlock` is now either:
		//   - the last non-default arm's `next` block (the no-arm-matched
		//     fallback), needing a final `br` to default body or merge
		//   - the same block as the default body (when the default was the
		//     last arm) — already terminated by the loop, no further work
		if hasDefault 'wireDefault'
			if currentBlock.id != defaultBodyId 'needsBranch'
				module.setTerminator(currentBlock, op: MaxonOp.br(defaultBodyId, range: SourceRange.none()))
			end 'needsBranch'
		end 'wireDefault' else 'noDefault'
			if anyArmReachesMerge 'wireFallback'
				module.setTerminator(currentBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.none()))
			end 'wireFallback' else 'allArmsTerminated'
				emitMatchUnreachableTerminator(currentBlock)
			end 'allArmsTerminated'
		end 'noDefault'

		// Wire fallthrough exits: each arm flagged `and fallthrough` branches
		// to the *next* arm's body (or to merge if no next arm).
		wireMatchFallthroughs(bodies, fallthroughs: fallthroughs, mergeBlockId: mergeBlockId)

		// Enum match exhaustiveness (E2026): if the match was on an enum and
		// no `default` arm was given, every enum case must be covered. The
		// scrutinee's MaxonType (when known to be a named enum) wins over
		// case-name lookup so case names that exist in multiple enums (e.g.
		// `notFound` in both StringError and a user enum) don't misroute the
		// diagnostic to the wrong enum.
		let scrutineeEnumName = enumScrutineeDisplayNameFromType(header.scrutineeType)
		validateEnumExhaustiveness(hasEnumArm: hasEnumArm, hasDefault: hasDefault, lastEnumCaseName: lastEnumCaseName, scrutineeEnumName: scrutineeEnumName, seenKeys: seenKeys, errorLine: cursor.current().line, errorColumn: cursor.current().column)
		// Non-enum match: every match needs an explicit `default` arm
		// because integer / string / float / char scrutinees can't be
		// enumerated.
		if not hasEnumArm and not hasDefault 'needsDefault'
			let endTok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserMatchNotExhaustive, message: "match is not exhaustive: add a 'default' arm", line: endTok.line, column: endTok.column, filePath: filePath)
		end 'needsDefault'

		// The merge block may be unreachable — when every arm body terminates
		// via return/throw and no fallthrough reaches a non-terminating tail.
		// Mark it dead so parseStatements / parseFunction skip the implicit
		// return / E3013 path. The runtime never reaches these.
		if not anyArmReachesMerge 'mergeDead'
			markBlockDeadIfUnset(header.mergeBlock)
		end 'mergeDead'

		try consumeMatchEndLabel(expectedLabel: header.userLabel)
		try matchStack.pop() otherwise panic("parseMatchStatement: matchStack underflow")
		currentBlock = header.mergeBlock
		return header.mergeBlock
	end 'parseMatchStatement'

	// Emit E2046 (default-without-throws-or-panic in a match on enum) when a
	// default arm follows at least one enum-case arm. The diagnostic must
	// fire at the default arm itself, not at the closing `end`, so it shares
	// a position-aware path between the statement and expression forms.
	function reportDefaultOnEnumMatch(patterns MatchPatternList, lastEnumCaseName String)
		let tok = patterns.first().token
		let enumDisplay = enumScrutineeDisplayNameFromCase(lastEnumCaseName)
		reportCompileError(project, code: ErrorCode.parserMatchDefaultEnumMustThrow, message: "'default' in a match on enum '{enumDisplay}' must be followed by 'throws <error>' or 'panic(\"message\")'", line: tok.line, column: tok.column, filePath: filePath)
	end 'reportDefaultOnEnumMatch'

	// Wire the body-exit block of each fallthrough-flagged arm to the next
	// arm's body block. Iterates after all bodies are parsed so each arm
	// already knows its successor's BlockId. Last arm's fallthrough (if any)
	// targets the merge block since no next arm exists.
	function wireMatchFallthroughs(bodies IrBlockArray, fallthroughs BoolArray, mergeBlockId BlockId)
		for armIdx in 0 upto bodies.count() 'each'
			let didFall = try fallthroughs.get(armIdx) otherwise panic("wireMatchFallthroughs: fallthroughs OOB at {armIdx}")
			if not didFall 'skip'
				continue
			end 'skip'
			let bodyBlock = try bodies.get(armIdx) otherwise panic("wireMatchFallthroughs: bodies OOB at {armIdx}")
			if bodyBlock.isTerminated() 'alreadyTerminated'
				continue
			end 'alreadyTerminated'
			var target = mergeBlockId
			if armIdx + 1 < bodies.count() 'hasNext'
				let nextBody = try bodies.get(armIdx + 1) otherwise panic("wireMatchFallthroughs: bodies OOB at {armIdx + 1}")
				target = nextBody.id
			end 'hasNext'
			module.setTerminator(bodyBlock, op: MaxonOp.br(target, range: SourceRange.none()))
		end 'each'
	end 'wireMatchFallthroughs'

	// Detect optional `and fallthrough` after an arm body. Reports E2025 when
	// the arm body was a `return` (combining return with fallthrough is
	// statically impossible — the return already exits). Returns true if a
	// fallthrough was consumed.
	function checkAndConsumeFallthrough(hadReturn bool) returns bool
		if not at(TokenKind.and) 'noAnd'
			return false
		end 'noAnd'
		let afterAnd = try cursor.peek(1) otherwise return false
		if afterAnd.kind != TokenKind.fallthrough 'notFallthrough'
			return false
		end 'notFallthrough'
		let andToken = cursor.current()
		try cursor.advance() otherwise return false
		try cursor.advance() otherwise return true
		if hadReturn 'returnFt'
			reportCompileError(project, code: ErrorCode.parserMatchFallthroughWithReturn, message: "match fallthrough with return: 'cannot combine 'fallthrough' with 'return''", line: andToken.line, column: andToken.column, filePath: filePath)
		end 'returnFt'
		return true
	end 'checkAndConsumeFallthrough'

	function parseMatchExpression(block IrBlock) returns ExprResult throws ParserError
		currentBlock = block
		let header = try parseMatchHeader()
		if header.failed 'bailout'
			let dummy = freshSynthName()
			return ExprResult.direct(dummy, valueType: MaxonType.integer)
		end 'bailout'
		let mergeBlockId = header.mergeBlock.id

		// Result-holding slot. Type is unknown until the first arm parses,
		// so we declare with `unresolved` and let TypeResolution's slot-type
		// fill-in propagate the actual arm type from the first varStore site
		// (matching how the bool short-circuit emitter materializes its
		// result via a slot). Seed with a zero literal so the unreachable
		// fallback's varLoad reads a well-typed value under wasm's stricter
		// validation.
		let resultSlot = scope.declare("__match_{header.userLabel}_{currentFunc.nextBlockId}", varType: MaxonType.unresolved, mutable: true)
		let seedZero = emitLiteral(currentBlock, value: 0, valueType: MaxonType.integer)
		module.appendOp(currentBlock, op: MaxonOp.varDecl(resultSlot, value: seedZero, slotType: MaxonType.unresolved, range: SourceRange.none()))

		var armIndex = 0 as IntConstant
		var resultType = MaxonType.unresolved
		var defaultBodyId = 0 as BlockId
		var hasDefault = false
		var seenKeys = ReferencedVarSet.create()
		var defaultSeen = false
		var hasEnumArm = false
		var lastEnumCaseName = ""
		// E2046 must gate on the scrutinee type, not on pattern shape: the
		// pattern parser's catch-all wraps non-int/non-char/non-default tokens
		// as `enumCase`, which would otherwise mis-fire on string scrutinees.
		let scrutineeIsKnownNonEnum = matchScrutineeIsKnownNonEnum(header.scrutineeType)

		while not isMatchArmsEnd() 'arms'
			let armPrevPos = cursor.index()
			let patterns = try parseMatchArmPatterns(seenKeys, defaultSeen: defaultSeen)
			let dispatchBlock = currentBlock
			// E2046 fires on `default then ...` for enum scrutinees — but
			// `default panic(...)` / `default throws Err.x` are exactly
			// the satisfying forms it directs the user to. Defer the
			// check past those diverging shapes.
			let isDivergingDefault = at(TokenKind.panic) or at(TokenKind.throws)
			if patterns.isDefault() and hasEnumArm and not scrutineeIsKnownNonEnum and not isDivergingDefault 'defaultOnEnum'
				reportDefaultOnEnumMatch(patterns, lastEnumCaseName: lastEnumCaseName)
			end 'defaultOnEnum'
			if patterns.isEnumCase() 'recordEnum'
				hasEnumArm = true
				lastEnumCaseName = patterns.first().caseName
			end 'recordEnum'
			// An enum-case range arm (`red to blue`) counts as an enum
			// arm for exhaustiveness / E2046 purposes even though the
			// pattern kind is `rangeLiteral`.
			if patterns.first().isEnumRange 'recordEnumRange'
				hasEnumArm = true
				// Use any case from the range to identify the owning
				// enum for diagnostics. The first ordinal's case name is
				// recovered via the enum registry; if missing we skip
				// (TR will surface the canonical diagnostic).
				if let rangeCaseName = try enumCaseNameAtOrdinal(enumName: patterns.first().enumOwnerName, ordinal: patterns.first().loValue) 'updateLast'
					lastEnumCaseName = rangeCaseName
				end 'updateLast'
				// Mark every covered ordinal's case name in seenKeys so
				// enum exhaustiveness sees the range's contribution.
				markEnumRangeCases(seenKeys, pattern: patterns.first())
			end 'recordEnumRange'
			let arm = try buildMatchArmBlocks(header, armIndex: armIndex, patterns: patterns, separator: TokenKind.gives)
			if patterns.isDefault() 'recordDefault'
				hasDefault = true
				defaultBodyId = arm.body.id
				defaultSeen = true
				module.setTerminator(dispatchBlock, op: MaxonOp.br(arm.body.id, range: SourceRange.none()))
			end 'recordDefault'

			currentBlock = arm.body
			// `default panic(...)` / `default throws Err.x` arms (and
			// per-arm `panic` / `throws` shapes added in Stage 0): the
			// arm body is already terminated and contributes no value to
			// the unified result type. Skip the gives expression and
			// don't unify against this arm.
			if arm.bodyAlreadyTerminated 'preTerminated'
				if not patterns.isDefault() 'advanceCursorEarly'
					currentBlock = arm.next
				end 'advanceCursorEarly'
				armIndex = armIndex + 1
				try skipNewlines()
				if cursor.index() <= armPrevPos 'stuckEarly'
					break
				end 'stuckEarly'
				continue
			end 'preTerminated'

			// Phase 9 Stage 3: same payload-binding emission as the
			// match-statement path — bindings become scope locals so
			// `gives n` reads through varLoad. Position `currentBlock`
			// on the arm body before invoking so the helper appends ops
			// via the parser's mutable block pointer.
			scope.pushScope()
			currentBlock = arm.body
			_ = emitUnionArmBindings(header.scrutineeName, pattern: patterns.first(), scrutineeMutable: header.scrutineeMutable)
			let armResult = try parseMatchExpressionArmBody(arm.body)
			scope.popScope()
			rejectFallthroughInMatchExpression()
			// `parseStringLiteral`'s fast path returns a `stringConst` ExprResult
			// without emitting a backing op. The varStore below would otherwise
			// reference an unbound name (E3013 in lowering). Mirror every other
			// site that threads a string-literal expression result into another
			// op — materialize into the arm's exit block before storing.
			let materializedArmResult = materializeStringConstIfNeeded(currentBlock, expr: armResult, range: SourceRange.ofToken(arm.caseToken))
			module.appendOp(currentBlock, op: MaxonOp.varStore(resultSlot, value: exprName(materializedArmResult), range: SourceRange.ofToken(arm.caseToken)))
			module.setTerminator(currentBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.none()))

			if isUnresolvedMaxonType(resultType) 'firstArmType'
				resultType = exprType(materializedArmResult)
			end 'firstArmType'

			if not patterns.isDefault() 'advanceCursor'
				currentBlock = arm.next
			end 'advanceCursor'
			armIndex = armIndex + 1
			try skipNewlines()
			// Stuck-guard: see parseMatchStatement's loop comment.
			if cursor.index() <= armPrevPos 'stuck'
				break
			end 'stuck'
		end 'arms'

		// Wire the no-arm-matched fallback for non-enum matches without an
		// explicit default. Enum matches without `default` rely on the
		// exhaustiveness check below; integer matches without `default`
		// would leave the fallback block unterminated, so route it through
		// the merge block so the verifier sees a fully terminated CFG.
		if hasDefault 'wireDefault'
			if currentBlock.id != defaultBodyId 'needsBranch'
				module.setTerminator(currentBlock, op: MaxonOp.br(defaultBodyId, range: SourceRange.none()))
			end 'needsBranch'
		end 'wireDefault' else 'noDefault'
			module.setTerminator(currentBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.none()))
		end 'noDefault'

		let scrutineeEnumNameExpr = enumScrutineeDisplayNameFromType(header.scrutineeType)
		validateEnumExhaustiveness(hasEnumArm: hasEnumArm, hasDefault: hasDefault, lastEnumCaseName: lastEnumCaseName, scrutineeEnumName: scrutineeEnumNameExpr, seenKeys: seenKeys, errorLine: cursor.current().line, errorColumn: cursor.current().column)
		// Non-enum match expression: requires an explicit `default` arm
		// because integer / string / float / char scrutinees can't be
		// enumerated and the expression must produce a value on every
		// path.
		if not hasEnumArm and not hasDefault 'needsDefault'
			let endTok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserMatchNotExhaustive, message: "match expression is not exhaustive: add a 'default' arm", line: endTok.line, column: endTok.column, filePath: filePath)
		end 'needsDefault'

		try consumeMatchEndLabel(expectedLabel: header.userLabel)

		currentBlock = header.mergeBlock
		let resultName = freshSynthName()
		module.appendOp(currentBlock, op: MaxonOp.varLoad(resultName, slotId: resultSlot, slotType: resultType, range: SourceRange.none()))
		return ExprResult.direct(resultName, valueType: resultType)
	end 'parseMatchExpression'

	function isUnresolvedMaxonType(t MaxonType) returns bool
		return match t 'check'
			unresolved gives true
			boolean to function gives false
			typeParameter to interface gives false
			constInt gives false
		end 'check'
	end 'isUnresolvedMaxonType'

	// --- For statement ---
	//
	// Range-form `for ID in START upto END 'label' ... end 'label'` (and the
	// inclusive `to` variant) desugar in-parser to the same control-flow
	// shape as a hand-written `while`:
	//   ENTRY: slot = START; endTmp = END; br HEADER
	//   HEADER: cur = load(slot); cmp(cur, endTmp, predicate); cond_br BODY EXIT
	//   BODY: <user statements>; cur2 = load(slot); inc = cur2 + 1; store(slot, inc); br HEADER
	//   EXIT
	// `upto` uses `lt` / increment by 1, `to` uses `le` / same increment.
	// Iterating `_` is supported by binding the synthetic name in scope so
	// nothing in the body can reference it (matches the spec's "discard").
	// Collection iteration (`for x in arr`) is not yet implemented; calls
	// reach the parser today only on numeric ranges.
	//
	function parseForStatement(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let forToken = try consume()

		// `for IDENT in ...` is the canonical for-range / for-in shape. A
		// leading `(name1, name2, ...)` opens the tuple-destructuring shape
		// (only used on for-in over a tuple-yielding iterator like
		// `Map.withIterator()` / `Range.withIterator()`). The first name
		// becomes the visible iterName when there's exactly one binding; for
		// >1 the bindings are collected here and field-bound inside the body.
		var destructureNames = StringArray.create()
		var iterName = ""
		if at(TokenKind.leftParen) 'isDestructure'
			try eat(TokenKind.leftParen)
			while true 'destructureLoop'
				if not at(TokenKind.identifier) 'noName2'
					let tok2 = cursor.current()
					reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "expected destructuring variable name", line: tok2.line, column: tok2.column, filePath: filePath)
					synchronize()
					return block
				end 'noName2'
				let nameTok = try consume()
				destructureNames.push(nameTok.value)
				if not at(TokenKind.comma) 'doneList'
					break
				end 'doneList'
				try eat(TokenKind.comma)
			end 'destructureLoop'
			try expect(TokenKind.rightParen)
		end 'isDestructure' else 'singleName'
			if not at(TokenKind.identifier) 'noName'
				let tok = cursor.current()
				reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "expected loop variable name after 'for'", line: tok.line, column: tok.column, filePath: filePath)
				synchronize()
				return block
			end 'noName'
			let nameToken = try consume()
			iterName = nameToken.value
		end 'singleName'

		try expect(TokenKind.in)

		// Parse START into the entry block. For for-range this is the lower
		// bound; for for-in over an iterable it is the source expression
		// (renamed locally as `sourceExpr` once we know which path we're on).
		// Suppress range-as-binary-op so a top-level `to`/`upto` is consumed
		// by this header (fast-path while-loop desugaring) rather than by
		// parseExpressionBP (Range.create/OpenRange.create lowering).
		currentBlock = block
		let savedInForInHeader = inForInHeader
		inForInHeader = true
		let startResult = try parseExpression(block)
		inForInHeader = savedInForInHeader

		let isInclusive = at(TokenKind.to)
		let sawRange = accept(TokenKind.to) or accept(TokenKind.upto)
		if not sawRange 'noRange'
			// Phase 11 Step 9 (parser-only): if the next token is the loop
			// label (a charLiteral, optionally preceded by newlines), this is
			// a for-in over an arbitrary iterable rather than a for-range.
			// Emit a `forInIterable` placeholder so the body still parses;
			// downstream lowering panics with a "Step 8 not implemented yet"
			// message until the iterator-protocol witness-call sequence
			// lands. Only loops in functions that ultimately reach lowering
			// hit the panic — the parser itself accepts the syntax.
			if at(TokenKind.charLiteral) or at(TokenKind.newline) 'iterablePath'
				return try parseForInIterable(func, block: block, forToken: forToken, iterName: iterName, sourceExpr: startResult, destructureNames: destructureNames)
			end 'iterablePath'
			let tok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "expected 'upto', 'to', or loop label after for-in source", line: tok.line, column: tok.column, filePath: filePath)
			synchronize()
			return block
		end 'noRange'

		// Tuple-destructure on for-range is meaningless — the iterator yields
		// a scalar int per step, not a tuple. Report and continue parsing the
		// rest as a normal for-range so the error doesn't cascade.
		if destructureNames.count() > 0 'destructureOnRange'
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "tuple destructuring is not supported on for-range loops; use a single loop variable", line: forToken.line, column: forToken.column, filePath: filePath)
			iterName = try destructureNames.get(0) otherwise "_"
		end 'destructureOnRange'

		// Parse END into the entry block.
		currentBlock = block
		let endResult = try parseExpression(block)

		// Loop label is mandatory (matches `while`).
		if not at(TokenKind.charLiteral) 'noLabel'
			let tok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "expected loop label after for-range", line: tok.line, column: tok.column, filePath: filePath)
			synchronize()
			return block
		end 'noLabel'
		let userLabel = try parseOptionalBlockLabel("loop")

		let forFilePath = filePath.toString()
		let stmtRange = SourceRange.between(forToken, last: previousToken())

		// Allocate iterator slot. `_` is reserved as a discard, but we still
		// need a unique slot — synthesize a fresh name so successive `for _`
		// loops don't collide on the symbol table.
		scope.pushScope()
		var iterSlot = 0
		if iterName == "_" 'discardIter'
			iterSlot = scope.declare("__forrange_iter_{forToken.line}_{forToken.column}", varType: MaxonType.integer, mutable: true)
		end 'discardIter' else 'namedIter'
			iterSlot = defineVariableWithType(iterName, varType: MaxonType.integer)
		end 'namedIter'

		// Snapshot END once into a fresh slot so mutating END's source after
		// loop entry doesn't change the bound.
		let endSlot = scope.declare("__forrange_end_{forToken.line}_{forToken.column}", varType: MaxonType.integer, mutable: true)

		// ENTRY: store START into iterSlot, END into endSlot, branch to header.
		module.appendOp(block, op: MaxonOp.varDecl(iterSlot, value: exprName(startResult), slotType: MaxonType.integer, range: stmtRange))
		module.appendOp(block, op: MaxonOp.varDecl(endSlot, value: exprName(endResult), slotType: MaxonType.integer, range: stmtRange))

		var headerBlock = module.addBlockAt(func, label: "forrange.header", filePath: forFilePath, firstLine: forToken.line)
		let headerBlockId = headerBlock.id
		var bodyBlock = module.addBlockAt(func, label: "{userLabel}_{headerBlockId}", filePath: forFilePath, firstLine: forToken.line)
		let bodyBlockId = bodyBlock.id
		var stepBlock = module.addBlockAt(func, label: "{userLabel}_{headerBlockId}.step", filePath: forFilePath, firstLine: forToken.line)
		let stepBlockId = stepBlock.id
		let exitBlock = module.addBlockAt(func, label: "{userLabel}_{headerBlockId}.exit", filePath: forFilePath, firstLine: forToken.line)
		let exitBlockId = exitBlock.id
		// Keep header label distinct from any other loop's "cond" labels.
		headerBlock.label = "{userLabel}_{headerBlockId}.header"

		module.setTerminator(block, op: MaxonOp.br(headerBlockId, range: SourceRange.none()))

		// HEADER: load iter and end, compare, conditional branch.
		let curName = freshSynthName()
		module.appendOp(headerBlock, op: MaxonOp.varLoad(curName, slotId: iterSlot, slotType: MaxonType.integer, range: stmtRange))
		let endValName = freshSynthName()
		module.appendOp(headerBlock, op: MaxonOp.varLoad(endValName, slotId: endSlot, slotType: MaxonType.integer, range: stmtRange))
		let cmpName = freshSynthName()
		let predicate = CmpPredicate.le if isInclusive else CmpPredicate.lt
		module.appendOp(headerBlock, op: MaxonOp.cmp(cmpName, left: curName, right: endValName, predicate: predicate, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: stmtRange))
		module.setTerminator(headerBlock, op: MaxonOp.condBr(cmpName, thenTarget: bodyBlockId, elseTarget: exitBlockId, range: SourceRange.none()))

		// STEP: increment iter, branch to header. `continue` jumps here so the
		// iter advances; without this block, `continue` would re-enter the
		// header with the iter unchanged and spin forever.
		let cur2Name = freshSynthName()
		module.appendOp(stepBlock, op: MaxonOp.varLoad(cur2Name, slotId: iterSlot, slotType: MaxonType.integer, range: stmtRange))
		let oneName = emitLiteral(stepBlock, value: 1, valueType: MaxonType.integer)
		let incName = freshSynthName()
		module.appendOp(stepBlock, op: MaxonOp.binop(incName, left: cur2Name, right: oneName, opKind: BinOpKind.add, operandType: MaxonType.integer, range: stmtRange))
		module.appendOp(stepBlock, op: MaxonOp.varStore(iterSlot, value: incName, range: stmtRange))
		module.setTerminator(stepBlock, op: MaxonOp.br(headerBlockId, range: SourceRange.none()))

		// BODY: parse user statements; natural fall-through goes to the step block.
		loopStack.push(LoopContext.create(userLabel, headerBlockId: headerBlockId, exitBlockId: exitBlockId, continueBlockId: stepBlockId))
		var bodyExit = try parseStatements(func, block: bodyBlock, lastWasReturn: false)
		try loopStack.pop() otherwise panic("loopStack.pop: stack unexpectedly empty after for-range body parse")

		if not bodyExit.isTerminated() 'needsStep'
			module.setTerminator(bodyExit, op: MaxonOp.br(stepBlockId, range: SourceRange.none()))
		end 'needsStep'

		scope.popScope()

		try skipEndAndLabel()
		return exitBlock
	end 'parseForStatement'

	// Phase 11 Step 8.6: handle `for X in iterable 'label' ... end` by
	// desugaring in the parser to the iterator-protocol shape:
	//
	//   ENTRY (current `block`):
	//     (%iter, %errFlag) = source.createIterator()  # tryMethodCall
	//     varDecl iterSlot = %iter
	//     %cmp = errFlag != 0
	//     cond_br cmp -> EXIT, PREAMBLE
	//
	//   PREAMBLE:
	//     br BODY                                 # skip leading advance
	//
	//   HEADER (continue target):
	//     %iterRef = varLoad iterSlot
	//     (%_, %errFlag2) = %iterRef.advance()    # tryMethodCall
	//     %cmp2 = errFlag2 != 0
	//     cond_br cmp2 -> EXIT, BODY
	//
	//   BODY:
	//     %iterRef2 = varLoad iterSlot
	//     %item = %iterRef2.current()             # methodCall
	//     varDecl iterName = %item                # bind loop variable
	//     <user statements>
	//     br HEADER                               # natural fall-through
	//
	//   EXIT
	//
	// Method-name resolution (Array.createIterator, ArrayIterator.current,
	// ArrayIterator.advance) is left to lowerMethodCall, which qualifies
	// `methodCall(receiver, "name", ...)` via the receiver's resolved struct
	// type. The iter slot's type is filled by TypeResolution's
	// methodCallResultType (which looks up `{ReceiverType}.createIterator`'s
	// return type) — same path as a hand-written `var iter = arr.createIterator()`.
	//
	// `break` exits the loop; `continue` jumps to HEADER (which advances
	// before re-entering BODY) — symmetric with for-range's step block.
	//
	// Cases that don't statically resolve (interface-typed sources, sources
	// whose type the parser can't determine) flow through the same shape.
	// They'll surface a clean error at lowering time when methodCall fails
	// to resolve `.createIterator` on an unresolved receiver — the same
	// failure mode any unresolved methodCall produces today.
	function parseForInIterable(func IrFunction, block IrBlock, forToken Token, iterName String, sourceExpr ExprResult, destructureNames StringArray) returns IrBlock throws ParserError
		let forFilePath = filePath.toString()
		let stmtRange = SourceRange.between(forToken, last: previousToken())

		// Loop label is mandatory (matches `while` and the for-range branch).
		// Allow newlines between the source expression and the label.
		try skipNewlines()
		if not at(TokenKind.charLiteral) 'noLabel'
			let tok = cursor.current()
			reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "expected loop label after for-in source", line: tok.line, column: tok.column, filePath: filePath)
			synchronize()
			return block
		end 'noLabel'
		let userLabel = try parseOptionalBlockLabel("loop")

		let sourceValue = exprName(sourceExpr)

		// Allocate fresh scope. The iter slot holds the iterator value
		// (returned by createIterator); the loop variable holds each
		// element (returned by current()). The iter slot lives outside
		// the loop variable's binding scope so the user can't shadow it.
		scope.pushScope()
		let iterStorageName = "__forin_iter_{forToken.line}_{forToken.column}"
		let iterStorageSlot = scope.declare(iterStorageName, varType: MaxonType.unresolved, mutable: true)

		// ENTRY: %iter = source.createIterator(); bind err flag; check.
		let createIterResultName = freshSynthName()
		let createIterArgs = ByteArrayArray.create()
		let createIterArgLabels = StringArray.create()
		let createIterArgTypes = MaxonTypeArray.create()
		let createIterArgRanges = SourceRangeArray.create()
		let createIterMethodName = "createIterator".toByteArray()
		// Emit createIterator as a throwing methodCall so lowering binds the
		// error flag via the multi-value-return ABI (RDX/X1).
		let createErrorFlagName = freshSynthName()
		module.appendOp(block, op: MaxonOp.tryMethodCall(createIterResultName, receiver: sourceValue, methodName: createIterMethodName, args: createIterArgs, argLabels: createIterArgLabels, argTypes: createIterArgTypes, argRanges: createIterArgRanges, errorBoundName: createErrorFlagName, range: stmtRange))
		// Stash the iterator value into the iter slot.
		module.appendOp(block, op: MaxonOp.varDecl(iterStorageSlot, value: createIterResultName, slotType: MaxonType.unresolved, range: stmtRange))

		// Allocate the four blocks: preamble, header, body, exit.
		var preambleBlock = module.addBlockAt(func, label: "{userLabel}_{block.id}.preamble", filePath: forFilePath, firstLine: forToken.line)
		let preambleBlockId = preambleBlock.id
		var headerBlock = module.addBlockAt(func, label: "{userLabel}_{block.id}.header", filePath: forFilePath, firstLine: forToken.line)
		let headerBlockId = headerBlock.id
		var bodyBlock = module.addBlockAt(func, label: "{userLabel}_{block.id}", filePath: forFilePath, firstLine: forToken.line)
		let bodyBlockId = bodyBlock.id
		let exitBlock = module.addBlockAt(func, label: "{userLabel}_{block.id}.exit", filePath: forFilePath, firstLine: forToken.line)
		let exitBlockId = exitBlock.id

		// ENTRY: cmp errFlag != 0; if error -> exit, else -> preamble.
		let zeroEntryName = emitLiteral(block, value: 0, valueType: MaxonType.integer)
		let cmpEntryName = freshSynthName()
		module.appendOp(block, op: MaxonOp.cmp(cmpEntryName, left: createErrorFlagName, right: zeroEntryName, predicate: CmpPredicate.ne, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: stmtRange))
		module.setTerminator(block, op: MaxonOp.condBr(cmpEntryName, thenTarget: exitBlockId, elseTarget: preambleBlockId, range: SourceRange.none()))

		// PREAMBLE: br body — skip leading advance() so the first iteration
		// observes the cursor at its initial (already-positioned) element.
		module.setTerminator(preambleBlock, op: MaxonOp.br(bodyBlockId, range: SourceRange.none()))

		// HEADER: load iter, advance, bind err flag, check, branch.
		let iterRefHdrName = freshSynthName()
		module.appendOp(headerBlock, op: MaxonOp.varLoad(iterRefHdrName, slotId: iterStorageSlot, slotType: MaxonType.unresolved, range: stmtRange))
		let advanceResultName = freshSynthName()
		let advanceArgs = ByteArrayArray.create()
		let advanceArgLabels = StringArray.create()
		let advanceArgTypes = MaxonTypeArray.create()
		let advanceArgRanges = SourceRangeArray.create()
		let advanceMethodName = "advance".toByteArray()
		// Phase 5: emit advance as a throwing methodCall so lowering binds the
		// error flag via the multi-value-return ABI.
		let advanceErrorFlagName = freshSynthName()
		module.appendOp(headerBlock, op: MaxonOp.tryMethodCall(advanceResultName, receiver: iterRefHdrName, methodName: advanceMethodName, args: advanceArgs, argLabels: advanceArgLabels, argTypes: advanceArgTypes, argRanges: advanceArgRanges, errorBoundName: advanceErrorFlagName, range: stmtRange))
		let zeroHdrName = emitLiteral(headerBlock, value: 0, valueType: MaxonType.integer)
		let cmpHdrName = freshSynthName()
		module.appendOp(headerBlock, op: MaxonOp.cmp(cmpHdrName, left: advanceErrorFlagName, right: zeroHdrName, predicate: CmpPredicate.ne, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: stmtRange))
		module.setTerminator(headerBlock, op: MaxonOp.condBr(cmpHdrName, thenTarget: exitBlockId, elseTarget: bodyBlockId, range: SourceRange.none()))

		// BODY: load iter, call current(), bind loop variable, parse user
		// statements. Iter slot's slotType isn't carried through varLoad
		// reliably (currentBlock varies by analysis); rely on TR's
		// producer-type fill for the methodCall result.
		let iterRefBodyName = freshSynthName()
		module.appendOp(bodyBlock, op: MaxonOp.varLoad(iterRefBodyName, slotId: iterStorageSlot, slotType: MaxonType.unresolved, range: stmtRange))
		let currentResultName = freshSynthName()
		let currentArgs = ByteArrayArray.create()
		let currentArgLabels = StringArray.create()
		let currentArgTypes = MaxonTypeArray.create()
		let currentArgRanges = SourceRangeArray.create()
		let currentMethodName = "current".toByteArray()
		module.appendOp(bodyBlock, op: MaxonOp.methodCall(currentResultName, receiver: iterRefBodyName, methodName: currentMethodName, args: currentArgs, argLabels: currentArgLabels, argTypes: currentArgTypes, argRanges: currentArgRanges, range: stmtRange))

		// Bind the loop variable inside an inner scope so `break`/`continue`
		// inside the body still close over the iter slot scope. The
		// destructuring shape (`for (a, b) in iter ...`) binds the tuple
		// value to a synthetic name and then emits one fieldLoad per name
		// against the tuple's `_0` / `_1` / … field convention (matching
		// parseParenExpr's tuple-literal lowering).
		scope.pushScope()
		var loopVarSlot = 0
		let isDestructure = destructureNames.count() > 0
		let effectiveIterName = "__forin_tuple_{forToken.line}_{forToken.column}" if isDestructure else iterName
		if effectiveIterName == "_" 'discardIter'
			loopVarSlot = scope.declare("__forin_var_{forToken.line}_{forToken.column}", varType: MaxonType.unresolved, mutable: false)
		end 'discardIter' else 'namedIter'
			loopVarSlot = defineVariableWithType(effectiveIterName, varType: MaxonType.unresolved)
		end 'namedIter'
		module.appendOp(bodyBlock, op: MaxonOp.varDecl(loopVarSlot, value: currentResultName, slotType: MaxonType.unresolved, range: stmtRange))
		if isDestructure 'emitFieldBindings'
			for i in 0 upto destructureNames.count() 'eachDestructure'
				let destName = try destructureNames.get(i) otherwise panic("parseForInIterable: destructureNames.get OOB at {i}")
				let fieldName = "_{i}".toByteArray()
				let fieldLoadName = freshSynthName()
				module.appendOp(bodyBlock, op: MaxonOp.fieldLoad(fieldLoadName, receiver: currentResultName, fieldName: fieldName, range: stmtRange))
				var destSlot = 0
				if destName == "_" 'discardField'
					destSlot = scope.declare("__forin_destfield_{forToken.line}_{forToken.column}_{i}", varType: MaxonType.unresolved, mutable: false)
				end 'discardField' else 'namedField'
					destSlot = defineVariableWithType(destName, varType: MaxonType.unresolved)
				end 'namedField'
				module.appendOp(bodyBlock, op: MaxonOp.varDecl(destSlot, value: fieldLoadName, slotType: MaxonType.unresolved, range: stmtRange))
			end 'eachDestructure'
		end 'emitFieldBindings'

		// Parse the body inside the loop context so `break`/`continue`
		// resolve to this loop's labels. `continue` -> header (where advance
		// runs), `break` -> exit. Natural fall-through goes to header.
		loopStack.push(LoopContext.create(userLabel, headerBlockId: headerBlockId, exitBlockId: exitBlockId, continueBlockId: headerBlockId))
		let bodyExit = try parseStatements(func, block: bodyBlock, lastWasReturn: false)
		try loopStack.pop() otherwise panic("loopStack.pop: stack unexpectedly empty after for-in iterable body parse")

		if not bodyExit.isTerminated() 'needsHeader'
			module.setTerminator(bodyExit, op: MaxonOp.br(headerBlockId, range: SourceRange.none()))
		end 'needsHeader'

		scope.popScope()  // pop loop-variable scope
		scope.popScope()  // pop iter-slot scope

		try skipEndAndLabel()
		return exitBlock
	end 'parseForInIterable'

	// --- Break / continue statements ---

	// Parse: break [label]  or  continue [label]
	// Emits an unconditional branch to the loop exit or header block, then
	// returns a fresh detached block so later statements are unreachable.
	//
	// Break semantics: an unlabeled `break` exits the innermost enclosing
	// match (if any) — matching the bootstrap's switch-style behaviour where
	// `break` inside a match arm only leaves the arm and the for/while loop
	// continues. With no match active, it exits the innermost loop. A
	// labeled `break 'foo'` searches both match and loop stacks by source
	// label.
	function parseBreakStatement(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let breakToken = try consume()
		if loopStack.count() == 0 and matchStack.count() == 0 'notInLoopOrMatch'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'break' can only be used inside a loop or match", line: breakToken.line, column: breakToken.column, filePath: filePath)
			return block
		end 'notInLoopOrMatch'

		let targetId = try resolveBreakTarget()
		module.setTerminator(block, op: MaxonOp.br(targetId, range: SourceRange.none()))
		return newDetachedBlock(func)
	end 'parseBreakStatement'

	// Resolve the jump target for break: labeled forms search both match and
	// loop stacks (match takes precedence on tie); unlabeled break prefers
	// the innermost match, falling back to the innermost loop. Returns a
	// BlockId of the merge/exit block. Caller has already verified that at
	// least one of the two stacks is non-empty.
	function resolveBreakTarget() returns BlockId throws ParserError
		if cursor.current().kind != TokenKind.charLiteral 'unlabeled'
			return try innermostBreakTarget()
		end 'unlabeled'
		let labelToken = try consume()
		for i in 0 upto matchStack.count() 'matchSearch'
			let mctx = try matchStack.get(matchStack.count() - 1 - i) otherwise panic("resolveBreakTarget: matchStack index OOB")
			if mctx.sourceLabel == labelToken.value 'foundMatch'
				return mctx.mergeBlockId
			end 'foundMatch'
		end 'matchSearch'
		for i in 0 upto loopStack.count() 'loopSearch'
			let lctx = try loopStack.get(loopStack.count() - 1 - i) otherwise panic("resolveBreakTarget: loopStack index OOB")
			if lctx.sourceLabel == labelToken.value 'foundLoop'
				return lctx.exitBlockId
			end 'foundLoop'
		end 'loopSearch'
		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "No enclosing loop or match with label '{labelToken.value}'", line: labelToken.line, column: labelToken.column, filePath: filePath)
		return try innermostBreakTarget()
	end 'resolveBreakTarget'

	// Innermost break target: prefer an active match (switch-style behaviour),
	// otherwise fall back to the innermost loop exit. Caller guarantees one
	// of the two stacks is non-empty.
	function innermostBreakTarget() returns BlockId throws ParserError
		if matchStack.count() > 0 'preferMatch'
			let mctx = try matchStack.get(matchStack.count() - 1) otherwise panic("innermostBreakTarget: matchStack empty after count check")
			return mctx.mergeBlockId
		end 'preferMatch'
		let lctx = try loopStack.get(loopStack.count() - 1) otherwise panic("innermostBreakTarget: loopStack empty after count check")
		return lctx.exitBlockId
	end 'innermostBreakTarget'

	function parseContinueStatement(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		let continueToken = try consume()
		if loopStack.count() == 0 'notInLoop'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'continue' can only be used inside a loop", line: continueToken.line, column: continueToken.column, filePath: filePath)
			return block
		end 'notInLoop'

		let targetId = try resolveContinueTarget()
		module.setTerminator(block, op: MaxonOp.br(targetId, range: SourceRange.none()))
		return newDetachedBlock(func)
	end 'parseContinueStatement'

	// Resolve the jump target for continue, consuming an optional label token.
	// Continue only searches the loop stack — match contexts have no header to
	// branch back to. entry: cursor AT the token after `continue` (caller
	// already consumed the keyword); loopStack is non-empty (caller checked).
	function resolveContinueTarget() returns BlockId throws ParserError
		let innermostCtx = try loopStack.get(loopStack.count() - 1) otherwise panic("resolveContinueTarget: empty loopStack")
		if cursor.current().kind != TokenKind.charLiteral 'noLabel'
			return innermostCtx.continueBlockId
		end 'noLabel'

		let labelToken = try consume()
		for i in 0 upto loopStack.count() 'search'
			let ctx = try loopStack.get(loopStack.count() - 1 - i) otherwise panic("resolveContinueTarget: loop index out of bounds")
			if ctx.sourceLabel == labelToken.value 'found'
				return ctx.continueBlockId
			end 'found'
		end 'search'

		reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "No enclosing loop with label '{labelToken.value}'", line: labelToken.line, column: labelToken.column, filePath: filePath)
		return innermostCtx.continueBlockId
	end 'resolveContinueTarget'

	// --- Discard assignment ---

	// Parse: _ = expression (discard function result)
	// Uses parserNextSlot as a unique suffix since it increments with each variable
	function parseDiscardAssignment(block IrBlock) throws ParserError
		// Dispatched on identifier `_` followed by `=`; both positions proven.
		try eat(TokenKind.identifier)
		try eat(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(block)
		// Emit into the block control flow landed on — bool short-circuit may
		// have moved it off `block` to a merge block.
		var emitBlock = currentBlock
		let discardName = "__discard_{scope.nextSlot}"
		let slot = defineVariableWithType(discardName, varType: exprType(exprResult))
		module.appendOp(emitBlock, op: MaxonOp.varDecl(slot, value: exprName(exprResult), slotType: exprType(exprResult), range: SourceRange.none()))
	end 'parseDiscardAssignment'

	// --- Variable assignment ---

	// Parse: identifier = expression (variable reassignment)
	function parseVarAssignment(block IrBlock) throws ParserError
		let nameToken = cursor.current()
		// Dispatched on `identifier` followed by `=`; advance through both.
		try eat(TokenKind.identifier)
		try eat(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(block)
		// Emit into the block control flow landed on — bool short-circuit may
		// have moved it off `block` to a merge block.
		var emitBlock = currentBlock
		let stmtRange = SourceRange.between(nameToken, last: previousToken())
		// String literals come back as `ExprResult.stringConst(name, id)`
		// without a producer op (the deferred-materialization shape; see
		// `parseStringLiteral`). For an assignment, this statement IS the
		// consumer — emit the producer now so `varStore`'s value name has a
		// definition. Same idempotent helper that `varDecl` and the
		// interp-arg path use.
		let materializedResult = materializeStringConstIfNeeded(emitBlock, expr: exprResult, range: stmtRange)
		// A bare identifier on the LHS may name a top-level `var`. Locals
		// shadow globals, so we check the scope first; only if no local
		// binding exists do we defer to TypeResolution. The parser emits a
		// single `unresolvedAssign` op carrying the bare name; TypeResolution
		// rewrites it to `globalStore` once `project.topLevelVars` is fully
		// populated, or surfaces a diagnostic if nothing matches.
		if not scope.contains(nameToken.value) 'maybeGlobalWrite'
			module.appendOp(emitBlock, op: MaxonOp.unresolvedAssign(nameToken.value, value: exprName(materializedResult), range: stmtRange))
			return
		end 'maybeGlobalWrite'
		let slot = lookupVariable(nameToken.value, token: nameToken)
		// Phase 9 Stage 4: union match-arm payload bindings rewrite
		// assignment-to-binding into a write-back to the union's heap-
		// resident payload slot. The binding's VarInfo carries the
		// scrutinee SSA name + field index; the lowering emits the
		// `decref-old + incref-new + storeIndirect` triple for managed
		// payloads. When the scrutinee is `let`-bound, `bindingMutable`
		// captured at scope-declare time is `false`, so we surface E2013
		// here rather than emitting a write-back that would silently
		// succeed at the IR level.
		let bindingInfo = scope.getInfo(nameToken.value)
		if bindingInfo.isPayloadBinding 'payloadWrite'
			if not bindingInfo.mutable 'immutableBinding'
				reportCompileError(project, code: ErrorCode.parserImmutableVariable, message: "cannot assign to immutable variable: '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
				return
			end 'immutableBinding'
			module.appendOp(emitBlock, op: MaxonOp.enumPayloadStore(bindingInfo.payloadScrutineeName.toByteArray(), caseName: bindingInfo.payloadCaseName, fieldIndex: bindingInfo.payloadFieldIndex as IntConstant, fieldType: bindingInfo.varType, newValueName: exprName(materializedResult), range: stmtRange))
			return
		end 'payloadWrite'
		if scope.isSelfField(nameToken.value) 'selfFieldWrite'
			// Implicit self-load and field-store share the statement's range —
			// the user wrote `field = value`, not a separate self-load op.
			emitSelfFieldStore(emitBlock, fieldName: nameToken.value, valueName: exprName(materializedResult), range: stmtRange)
		end 'selfFieldWrite' else 'localWrite'
			module.appendOp(emitBlock, op: MaxonOp.varStore(slot, value: exprName(materializedResult), range: stmtRange))
		end 'localWrite'
	end 'parseVarAssignment'

	// --- Variable declaration ---

	function parseVarDecl(block IrBlock) throws ParserError
		// Caller dispatched on `var`/`let`; consume the keyword.
		let kwToken = try consume()
		let isLet = kwToken.kind == TokenKind.let

		// Phase 15e: `let (x, y) = expr` / `var (x, y) = expr` destructure the
		// initializer's tuple result into N freshly-declared locals. Parse the
		// name list and the initializer, then lower to a hidden temp + per-
		// element fieldLoad sequence so the regular varDecl path still owns
		// scope registration / unused-var tracking for each binding.
		if at(TokenKind.leftParen) 'isDestructure'
			try parseTupleDestructureVarDecl(block, kwToken: kwToken, isLet: isLet)
			return
		end 'isDestructure'

		let nameToken = try consumeExpecting("identifier")
		if nameToken.kind != TokenKind.identifier 'badName'
			reportTokenMismatch(nameToken, expectedDisplay: "identifier")
			synchronize()
			return
		end 'badName'
		checkReservedDeclName(nameToken)

		// Track the declaration site so checkUnusedParameters can emit E3012
		// against unused locals after the body is fully parsed. `_` is the
		// discard convention and is skipped — the unused check treats it as
		// always referenced.
		if nameToken.value != "_" 'recordLocal'
			localVarLocations.push(ParamLocation.create(nameToken.value, line: nameToken.line, column: nameToken.column))
		end 'recordLocal'

		try expect(TokenKind.equals)
		currentBlock = block
		// Phase 9 Stage 5 (struct-backing): peek before consuming the
		// initializer expression to detect `let LOCAL = EnumName.caseName`
		// where the case has struct backing. The peek is non-consuming;
		// the actual expression parse below still runs and emits the
		// regular IR. The alias is registered *after* the expression parse
		// (where mutability and discard checks are visible) — we store
		// the peek result here in a flag + value pair so missing isn't
		// distinguished from a real value by a magic empty string.
		var initBackedCaseFound = false
		var initBackedCaseQualified = ""
		if let qualified = try peekStructBackedEnumCaseQualifiedName() 'haveBackedCase'
			initBackedCaseFound = true
			initBackedCaseQualified = qualified
		end 'haveBackedCase'
		let exprResult = try parseExpression(block)
		// Emit the varDecl into the block control flow landed on — bool
		// short-circuit may have moved it off `block` to a merge block.
		var emitBlock = currentBlock
		let lastExprToken = previousToken()
		let stmtRange = SourceRange.between(kwToken, last: lastExprToken)

		// `let LOCAL = "literal"` additionally registers LOCAL as a
		// file-scope top-level constant — the only let-vs-var difference.
		// `var` bindings are mutable so they skip the const-table entry.
		// Both shapes share the producer-emission path below.
		if isLet and exprIsStringConst(exprResult) 'registerLetConst'
			let stringId = exprStringConstId(exprResult)
			let localStrEntry = TopLevelConstant.create(ConstantValue.stringValue(stringId), visibility: Visibility.file, sourceFilePath: filePath)
			try project.topLevelConstants.insert(nameToken.value, value: localStrEntry) otherwise 'dupConst3'
				reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Duplicate constant '{nameToken.value}'", line: nameToken.line, column: nameToken.column, filePath: filePath)
			end 'dupConst3'
		end 'registerLetConst'

		// Phase 9 Stage 5 (struct-backing): record the struct-backed
		// enum-case alias if `peekStructBackedEnumCaseQualifiedName` found
		// one. `var` bindings shadow the alias on reassignment, but since
		// the parser doesn't do flow-sensitive analysis we conservatively
		// record only `let` bindings. Reassigning a `var` later would
		// invalidate the alias; not registering it here keeps the fold
		// soundly compile-time-only.
		if isLet and initBackedCaseFound and nameToken.value != "_" 'recordCaseAlias'
			try letStructBackedEnumCases.insert(nameToken.value, value: initBackedCaseQualified) otherwise ignore
		end 'recordCaseAlias'

		// Materialize any deferred string literal so the producer op exists
		// before we reference its name in the varDecl below. No-op when the
		// initializer isn't a string literal.
		let materializedResult = materializeStringConstIfNeeded(emitBlock, expr: exprResult, range: stmtRange)
		// Phase 9 Stage 4: thread `let`-vs-`var` through Scope so downstream
		// consumers (today: match-arm payload-binding mutability, per
		// `mutable-enums.md`) can distinguish writable from read-only
		// locals. Existing local-let assignments still slip through without
		// E2013 — `parseVarAssignment` doesn't check `mutable` for regular
		// slot stores — but the payload-binding path now consults the
		// recorded mutability and surfaces E2013 on `value = …` against a
		// `let b` scrutinee.
		let slot = scope.declare(nameToken.value, varType: exprType(materializedResult), mutable: not isLet)
		module.appendOp(emitBlock, op: MaxonOp.varDecl(slot, value: exprName(materializedResult), slotType: exprType(materializedResult), range: stmtRange))
	end 'parseVarDecl'

	// Phase 15e: parse `let (x, y, ...) = expr` / `var (x, y, ...) = expr`.
	// Lowered to a hidden temp holding the initializer plus one
	// `let/var <name> = __tmp._N` binding per element, so each name keeps the
	// regular per-slot scoping, mutability tracking, and unused-var
	// diagnostics. The hidden temp is also named so its lifetime extends
	// across all the field-load bindings.
	function parseTupleDestructureVarDecl(block IrBlock, kwToken Token, isLet bool) throws ParserError
		try eat(TokenKind.leftParen)
		var elemNames = StringArray.create()
		var elemNameTokens = TokenArray.create()
		while not at(TokenKind.rightParen) 'collect'
			let elemTok = try consumeExpecting("identifier")
			if elemTok.kind != TokenKind.identifier 'badIdent'
				reportTokenMismatch(elemTok, expectedDisplay: "identifier")
				synchronize()
				return
			end 'badIdent'
			elemNames.push(elemTok.value)
			elemNameTokens.push(elemTok)
			if at(TokenKind.rightParen) 'doneCollect'
				break
			end 'doneCollect'
			try expect(TokenKind.comma)
		end 'collect'
		try expect(TokenKind.rightParen)
		try expect(TokenKind.equals)
		currentBlock = block
		let exprResult = try parseExpression(block)
		let lastExprToken = previousToken()
		let stmtRange = SourceRange.between(kwToken, last: lastExprToken)
		let arity = elemNames.count()
		if arity < 2 'tooFew'
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Tuple destructuring requires at least 2 names, got {arity}", line: kwToken.line, column: kwToken.column, filePath: filePath)
			return
		end 'tooFew'
		// Bind the initializer to a hidden temp so each field-load can use
		// `tmp._N` as its source. `let` / `var` on the temp follows the user's
		// keyword — destructuring `var` still implies a mutable temp so a
		// later element-binding `var` reassignment can read updated fields.
		let tmpName = "__destructure_{kwToken.line}_{kwToken.column}"
		let tmpType = exprType(exprResult)
		let tmpSlot = scope.declare(tmpName, varType: tmpType, mutable: not isLet)
		module.appendOp(currentBlock, op: MaxonOp.varDecl(tmpSlot, value: exprName(exprResult), slotType: tmpType, range: stmtRange))
		// Emit one `let/var <name> = tmp._N` binding per element. Each binding
		// goes through the regular scope.declare path so unused-var diagnostics
		// fire if a name is never referenced.
		for i in 0 upto arity 'eachBinding'
			let elemName = try elemNames.get(i) otherwise panic("parseTupleDestructureVarDecl: elemNames.get OOB at {i}")
			let elemTok = try elemNameTokens.get(i) otherwise panic("parseTupleDestructureVarDecl: elemNameTokens.get OOB at {i}")
			if elemName != "_" 'recordLocal'
				localVarLocations.push(ParamLocation.create(elemName, line: elemTok.line, column: elemTok.column))
			end 'recordLocal'
			let tmpLoadName = freshSynthName()
			module.appendOp(currentBlock, op: MaxonOp.varLoad(tmpLoadName, slotId: tmpSlot, slotType: MaxonType.unresolved, range: stmtRange))
			let fieldLoadName = freshSynthName()
			let fieldBytes = "_{i}".toByteArray()
			module.appendOp(currentBlock, op: MaxonOp.fieldLoad(fieldLoadName, receiver: tmpLoadName, fieldName: fieldBytes, range: stmtRange))
			let elemSlot = scope.declare(elemName, varType: MaxonType.unresolved, mutable: not isLet)
			module.appendOp(currentBlock, op: MaxonOp.varDecl(elemSlot, value: fieldLoadName, slotType: MaxonType.unresolved, range: stmtRange))
		end 'eachBinding'
	end 'parseTupleDestructureVarDecl'

	// Decode escape sequences in a raw string fragment and return the
	// decoded bytes. Used at parse time to canonicalize string literals
	// before interning so identical-after-decode literals share a single
	// StringId (e.g. `"\n"` collapses to a single 0x0A byte).
	function decodeStringEscapes(fragment String) returns ByteArray
		let fragBytes = fragment.toByteArray()
		let fragLen = fragBytes.count()
		var buf = ByteArray.create()
		var i = 0
		while i < fragLen 'decode'
			let ch = try fragBytes.get(i) otherwise panic("decodeStringEscapes: loop guard i < fragLen just succeeded but get({i}) failed (fragLen={fragLen})")
			if ch == '\\' and i + 1 < fragLen 'escape'
				let next = try fragBytes.get(i + 1) otherwise panic("decodeStringEscapes: i + 1 < fragLen just succeeded but get({i + 1}) failed (fragLen={fragLen})")
				if next == 'n' 'escN'
					buf.push(10)
					i = i + 2
					continue
				end 'escN'
				if next == 't' 'escT'
					buf.push(9)
					i = i + 2
					continue
				end 'escT'
				if next == 'r' 'escR'
					buf.push(13)
					i = i + 2
					continue
				end 'escR'
				if next == '0' 'escNul'
					buf.push(0)
					i = i + 2
					continue
				end 'escNul'
				if next == '\\' 'escBS'
					buf.push(92)
					i = i + 2
					continue
				end 'escBS'
				if next == '"' 'escDQ'
					buf.push(34)
					i = i + 2
					continue
				end 'escDQ'
				// `\'` is the char-literal's required escape for the closing
				// quote (the lexer accepts it inside `'...'`). Mirrors C#
				// StringUtils.ResolveEscapes.
				if next == '\'' 'escSQ'
					buf.push(39)
					i = i + 2
					continue
				end 'escSQ'
				// `\{` and `\}` produce literal braces — they're how the user
				// embeds a `{` or `}` in a string without it being parsed as
				// an interpolation marker. Mirrors C# ParseStringInterpParts
				// (Parser.cs:14650). The lexer already skips the byte after
				// `\` so the `{`/`}` reaches us as a raw escape pair.
				if next == '{' 'escLBrace'
					buf.push(123)
					i = i + 2
					continue
				end 'escLBrace'
				if next == '}' 'escRBrace'
					buf.push(125)
					i = i + 2
					continue
				end 'escRBrace'
				// `\xNN` — single-byte hex escape. validateEscapes already
				// reported an error for malformed forms, so we can decode
				// optimistically when the two trailing bytes are hex digits
				// and fall through to literal-copy otherwise.
				if next == 'x' and i + 3 < fragLen 'escHex'
					let h1 = try fragBytes.get(i + 2) otherwise panic("decodeStringEscapes.escHex: get(i+2) failed after bounds check")
					let h2 = try fragBytes.get(i + 3) otherwise panic("decodeStringEscapes.escHex: get(i+3) failed after bounds check")
					if isHexDigitByte(h1) and isHexDigitByte(h2) 'hexOk'
						let hi = hexDigitValue(h1)
						let lo = hexDigitValue(h2)
						buf.push(((hi shl 4) or lo) as Byte)
						i = i + 4
						continue
					end 'hexOk'
				end 'escHex'
				// `\uNNNN` — Unicode codepoint escape (BMP only via 4 hex
				// digits). Emits the UTF-8 encoding of the codepoint.
				// Malformed forms were already reported by validateEscapes;
				// fall through to literal-copy on bad input.
				if next == 'u' and i + 5 < fragLen 'escUni'
					let hexA = try fragBytes.get(i + 2) otherwise panic("decodeStringEscapes.escUni: hex digit 1 out of bounds")
					let hexB = try fragBytes.get(i + 3) otherwise panic("decodeStringEscapes.escUni: hex digit 2 out of bounds")
					let hexC = try fragBytes.get(i + 4) otherwise panic("decodeStringEscapes.escUni: hex digit 3 out of bounds")
					let hexD = try fragBytes.get(i + 5) otherwise panic("decodeStringEscapes.escUni: hex digit 4 out of bounds")
					if isHexDigitByte(hexA) and isHexDigitByte(hexB) and isHexDigitByte(hexC) and isHexDigitByte(hexD) 'uniOk'
						let nibA = hexDigitValue(hexA)
						let nibB = hexDigitValue(hexB)
						let nibC = hexDigitValue(hexC)
						let nibD = hexDigitValue(hexD)
						let cp = (nibA shl 12) or (nibB shl 8) or (nibC shl 4) or nibD
						encodeUtf8Codepoint(buf, codepoint: cp)
						i = i + 6
						continue
					end 'uniOk'
				end 'escUni'
			end 'escape'
			buf.push(ch)
			i = i + 1
		end 'decode'
		return buf
	end 'decodeStringEscapes'

	// Decode a single ASCII hex digit byte (0-9, a-f, A-F) into its 0..15
	// value. Caller must have verified `b` via `isHexDigitByte` — otherwise
	// the panic fires. Used by `\xNN` / `\uNNNN` escape decoding.
	function hexDigitValue(b Byte) returns HexNibble
		if b >= '0' and b <= '9' 'digit'
			return b - '0'
		end 'digit'
		if b >= 'a' and b <= 'f' 'lower'
			return b - 'a' + 10
		end 'lower'
		if b >= 'A' and b <= 'F' 'upper'
			return b - 'A' + 10
		end 'upper'
		panic("hexDigitValue: byte {b} is not a hex digit (caller must verify via isHexDigitByte)")
	end 'hexDigitValue'

	// Append the UTF-8 encoding of a BMP codepoint (0..0xFFFF) to `buf`.
	// Mirrors SpecTestRunner.appendUtf8Codepoint — supplementary-plane
	// codepoints (>0xFFFF) need a `\UNNNNNNNN`-style escape which neither
	// the lexer nor `validateEscapes` currently surfaces, but the encoder
	// supports them so any future widening doesn't lose data silently.
	function encodeUtf8Codepoint(buf ByteArray, codepoint UnicodeCodepoint)
		if codepoint < 0x80 'oneByte'
			buf.push(codepoint as Byte)
			return
		end 'oneByte'
		if codepoint < 0x800 'twoByte'
			buf.push((0xC0 or (codepoint shr 6)) as Byte)
			buf.push((0x80 or (codepoint and 0x3F)) as Byte)
			return
		end 'twoByte'
		if codepoint < 0x10000 'threeByte'
			buf.push((0xE0 or (codepoint shr 12)) as Byte)
			buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as Byte)
			buf.push((0x80 or (codepoint and 0x3F)) as Byte)
			return
		end 'threeByte'
		buf.push((0xF0 or (codepoint shr 18)) as Byte)
		buf.push((0x80 or ((codepoint shr 12) and 0x3F)) as Byte)
		buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as Byte)
		buf.push((0x80 or (codepoint and 0x3F)) as Byte)
	end 'encodeUtf8Codepoint'

	// Lexer invariant: every stringInterpEnd is followed by a stringLiteral
	// fragment (possibly empty when the interpolation is adjacent to the closing
	// `"`). Anything else means the lexer broke its contract — panic with caller
	// context so the bug shows where it surfaced.
	function assertFragmentAfterInterpEnd(callerName String, token Token)
		if token.kind != TokenKind.stringLiteral 'noFrag'
			panic("{callerName}: expected stringLiteral fragment after stringInterpEnd, got {token.kind.name}")
		end 'noFrag'
	end 'assertFragmentAfterInterpEnd'

	// --- Expression Parsing ---

	// Pratt expression parser: single loop handles all binary precedence levels.
	// `to`/`upto` in expression position lower to Range.create/OpenRange.create
	// here so the inner Pratt loop never sees them as infix operators. The
	// for-in header parser sets `inForInHeader` so its outermost call leaves
	// the trailing `to`/`upto` for the for-in fast-path while-loop desugaring;
	// the saved-and-cleared pattern matches C#'s `_inForInIterable` capture so
	// every recursive sub-expression (binop RHS, parens, call args, the range
	// end expression itself) lowers ranges normally.
	function parseExpression(block IrBlock) returns ExprResult throws ParserError
		let suppressRangeLowering = inForInHeader
		inForInHeader = false
		let result = try parseExpressionBP(block, minBP: 0)
		inForInHeader = suppressRangeLowering
		if suppressRangeLowering 'suppressed'
			return result
		end 'suppressed'
		let nextKind = cursor.current().kind
		if nextKind != TokenKind.to and nextKind != TokenKind.upto 'noRange'
			return result
		end 'noRange'
		let rangeToken = try consume()
		let inclusive = rangeToken.kind == TokenKind.to
		let endResult = try parseExpression(currentBlock)
		let calleeName = "Range.create" if inclusive else "OpenRange.create"
		let endLabel = "finish" if inclusive else "endExclusive"
		var args = ByteArrayArray.create()
		args.push(exprName(result))
		args.push(exprName(endResult))
		var argLabels = StringArray.create()
		argLabels.push("")
		argLabels.push(endLabel)
		var argTypes = MaxonTypeArray.create()
		argTypes.push(exprType(result))
		argTypes.push(exprType(endResult))
		var argRanges = SourceRangeArray.create()
		argRanges.push(SourceRange.ofToken(rangeToken))
		argRanges.push(SourceRange.ofToken(rangeToken))
		return emitCallAndResult(calleeName: calleeName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.ofToken(rangeToken))
	end 'parseExpression'

	// entry: cursor AT first operand's first token.
	// exit:  cursor AT last-consumed token of the rightmost accepted operand.
	function parseExpressionBP(block IrBlock, minBP BindingPower) returns ExprResult throws ParserError
		// blk tracks the block this loop is currently emitting into. Bool
		// short-circuit emission moves it to a fresh merge block; subsequent
		// operands and the binop itself land in that merge block, not the
		// block we entered on.
		var blk = block
		currentBlock = blk
		var left = try parseUnary(blk)
		blk = currentBlock

		while true 'prattLoop'
			let bp = try infixBindingPower(cursor.current().kind) otherwise 0
			if bp == 0 'notOp'
				break
			end 'notOp'
			if bp <= minBP 'tooLow'
				break
			end 'tooLow'
			// Inside a match arm body, `and fallthrough` belongs to the
			// match-arm helper — stop the Pratt loop so the helper can pick
			// it up. Without this, `and` is consumed as a binary operator
			// and `fallthrough` (which is a keyword, not an expression)
			// triggers E2004.
			if inMatchArmBody and cursor.current().kind == TokenKind.and and atOffset(TokenKind.fallthrough, offset: 1) 'maybeFt'
				break
			end 'maybeFt'

			let opToken = try consume()

			let leftName = exprName(left)
			let opRange = SourceRange.ofToken(opToken)

			// Bool short-circuit for `and`/`or`. Skips emission of the rhs when
			// the lhs already determines the result. Integer `and`/`or` are
			// bitwise — both sides are always evaluated, so this branch only
			// fires when the lhs's type is bool.
			if (opToken.kind == TokenKind.and or opToken.kind == TokenKind.or) and maxonTypeIsBool(exprType(left)) 'shortCircuit'
				let mergeName = try emitShortCircuit(blk, leftName: leftName, opToken: opToken, rhsMinBP: bp)
				blk = currentBlock
				left = ExprResult.direct(mergeName, valueType: MaxonType.boolean)
				continue
			end 'shortCircuit'

			// Compile-time string constant folding for ==. The interner
			// guarantees identical content shares one StringId, so id
			// comparison is exact: equal ids ⇔ equal content (no value
			// fetch needed). Mirrors the original semantics: when right
			// isn't a stringConst, exprStringConstId returns the sentinel
			// 0, which only matches a left whose own id is 0 (the empty
			// string) — preserves the legacy "left vs `""`" comparison
			// behavior.
			if opToken.kind == TokenKind.equalsEquals 'checkStrFold'
				if exprIsStringConst(left) 'leftIsStr'
					currentBlock = blk
					let right = try parsePrimary(blk)
					blk = currentBlock
					var foldedLeft = 1
					if exprStringConstId(left) != exprStringConstId(right) 'strNeq'
						foldedLeft = 0
					end 'strNeq'
					let leftLitName = emitLiteral(blk, value: foldedLeft, valueType: MaxonType.integer)
					let rightLitName = emitLiteral(blk, value: 1, valueType: MaxonType.integer)
					let resultName = freshSynthName()
					module.appendOp(blk, op: MaxonOp.cmp(resultName, left: leftLitName, right: rightLitName, predicate: CmpPredicate.eq, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: opRange))
					left = ExprResult.direct(resultName, valueType: MaxonType.integer)
					continue
				end 'leftIsStr'
			end 'checkStrFold'

			// Reference identity: is / is not. The parser emits `refEq`
			// unconditionally; TypeResolution validates that both operands
			// are reference (struct) types after the registries are fully
			// populated and surfaces E3005 when they aren't.
			if opToken.kind == TokenKind.is 'isRefEq'
				var negate = false
				if at(TokenKind.not) 'isNot'
					negate = true
					try eat(TokenKind.not)
				end 'isNot'
				currentBlock = blk
				let right = try parseExpressionBP(blk, minBP: bp)
				blk = currentBlock
				let resultName = freshSynthName()
				module.appendOp(blk, op: MaxonOp.refEq(resultName, left: leftName, right: exprName(right), negate: negate, range: opRange))
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
				continue
			end 'isRefEq'

			// Parse right operand with higher minimum binding power for left-associativity
			currentBlock = blk
			let right = try parseExpressionBP(blk, minBP: bp)
			blk = currentBlock

			// `==`/`!=` between two reference (struct) values dispatches to
			// `.equals()` for content comparison; primitives use a regular
			// cmp. The parser doesn't probe `project.structTypes` to decide
			// — TypeResolution walks every cmp op after registries are
			// fully populated and rewrites struct-vs-struct cmps into the
			// `methodCall("equals")` form, with a follow-up `bitNot` for
			// `!=`. Until then, the parser emits a regular cmp and lets TR
			// pattern-match.

			// Materialize any parser-internal stringConst operands as real
			// IR ops before threading their names into a binop/cmp. Without
			// this, lowering's resolveName fails because parser-time
			// stringConst values have no producer in the IR.
			let materializedLeft = materializeStringConstIfNeeded(blk, expr: left, range: opRange)
			let materializedRight = materializeStringConstIfNeeded(blk, expr: right, range: opRange)
			let materializedLeftName = exprName(materializedLeft)
			let resultName = freshSynthName()
			// Pick an advisory operandType from whichever operand carries the
			// most specific source-level type. lowerMaxonToStd sees the
			// fully-resolved operand StdTypes and inserts int↔float promotions
			// and picks the concrete opcodes. Left/right MaxonTypes are recorded
			// separately on the cmp op so TypeResolution can diagnose E3005.
			let leftExprType = exprType(materializedLeft)
			let rightExprType = exprType(materializedRight)
			let operandType = binOpOperandType(leftExprType, rightType: rightExprType, kind: opToken.kind)
			emitBinaryOp(blk, kind: opToken.kind, resultName: resultName, leftName: materializedLeftName, rightName: exprName(materializedRight), leftType: leftExprType, rightType: rightExprType, operandType: operandType, range: opRange)

			// Comparison ops produce int (bool); arithmetic inherits the
			// operand's source-level type so chained expressions stay
			// typed consistently through TypeResolution.
			if opToken.kind == TokenKind.equalsEquals or opToken.kind == TokenKind.bangEquals or opToken.kind == TokenKind.lessThan or opToken.kind == TokenKind.lessEquals or opToken.kind == TokenKind.greaterThan or opToken.kind == TokenKind.greaterEquals 'isCmp'
				left = ExprResult.direct(resultName, valueType: MaxonType.integer)
			end 'isCmp' else 'notCmp'
				left = ExprResult.direct(resultName, valueType: operandType)
			end 'notCmp'
		end 'prattLoop'

		// `otherwise` after a non-`try` expression is a semantic error — it
		// requires a `try` prefix (E3058). Consume `otherwise` and skip the
		// rest of the line so subsequent statements parse cleanly.
		if at(TokenKind.otherwise) 'otherwiseWithoutTry'
			let otherwiseTok = cursor.current()
			reportCompileError(project, code: ErrorCode.semanticOtherwiseRequiresTry, message: "otherwise requires try expression", line: otherwiseTok.line, column: otherwiseTok.column, filePath: filePath)
			try eat(TokenKind.otherwise)
			skipToNextLine()
		end 'otherwiseWithoutTry'

		// Publish the block control flow exited on so callers (statement-level
		// helpers, recursive parseExpressionBP frames) emit subsequent ops in
		// the right place even when bool short-circuit moved us forward.
		currentBlock = blk
		return left
	end 'parseExpressionBP'

	// --- Binary op emission ---

	// Choose the advisory operandType for a binary op. Bitwise ops are
	// integer-only; for everything else we prefer float > named > integer so
	// mixed expressions like `foo + 1.0` retain the `float` type. The actual
	// dispatch happens in lowerMaxonToStd after type resolution.
	function binOpOperandType(leftType MaxonType, rightType MaxonType, kind TokenKind) returns MaxonType
		if kind == TokenKind.or or kind == TokenKind.xor or kind == TokenKind.and or kind == TokenKind.shl or kind == TokenKind.shr or kind == TokenKind.mod 'intOnly'
			return MaxonType.integer
		end 'intOnly'
		if maxonTypeIsFloat(leftType) or maxonTypeIsFloat(rightType) 'anyFloat'
			return MaxonType.float
		end 'anyFloat'
		// Non-numeric operand types that lowering must see preserved into the
		// op's operandType slot. `named(...)` flows the receiver type through
		// to user-defined operator dispatch; `typeParameter(...)` is the
		// trigger for witness-based `Equatable.equals` desugaring inside
		// generic function bodies (see lowerCmp). Either side wins so a
		// mixed `Key == namedValue` carries the more-specific type.
		if shouldCarryAsBinopOperandType(leftType) 'leftCarry'
			return leftType
		end 'leftCarry'
		if shouldCarryAsBinopOperandType(rightType) 'rightCarry'
			return rightType
		end 'rightCarry'
		// If either side is still unresolved at parse time (e.g. a fieldLoad
		// result feeding into `==`), leave the op's operandType as
		// `unresolved` so `fillUnresolvedTypes` rewrites it from the
		// producer-type map. Without this hook a downstream
		// `existing == key` on a type-parameter operand would lose the
		// dispatch trigger.
		if isUnresolvedMaxonType(leftType) or isUnresolvedMaxonType(rightType) 'eitherUnresolved'
			return MaxonType.unresolved
		end 'eitherUnresolved'
		// Both sides are primitive (integer / boolean) — integer is the
		// correct ABI representation for both since `bool` lowers to i1 but
		// arithmetic / comparison ops on bool widen through the integer
		// path.
		return MaxonType.integer
	end 'binOpOperandType'

	function shouldCarryAsBinopOperandType(t MaxonType) returns bool
		return match t 'check'
			named gives true
			typeParameter gives true
			boolean to string gives false
			function gives false
			unresolved gives false
			genericInstance gives false
			interface gives false
			constInt gives false
		end 'check'
	end 'shouldCarryAsBinopOperandType'

	function isNamedMaxonType(t MaxonType) returns bool
		return match t 'check'
			named gives true
			boolean to string gives false
			function to unresolved gives false
			typeParameter to interface gives false
			constInt gives false
		end 'check'
	end 'isNamedMaxonType'

	// Lower a bool `and`/`or` to short-circuit IR. Allocates a varSlot seeded
	// with the short-circuit value (false for `and`, true for `or`), branches
	// on the lhs to either skip the rhs (preserving the seed) or evaluate the
	// rhs and overwrite the slot, then merges. Returns the synthesized result
	// name; updates currentBlock to the merge block. Block layout is always
	// [entry, rhs..., merge] to match the cond_br convention (jcc-to-else +
	// fall-through-to-then). For `or` the lhs is negated so the "then" branch
	// is always the rhs path.
	function emitShortCircuit(entryBlock IrBlock, leftName ByteArray, opToken Token, rhsMinBP BindingPower) returns ByteArray throws ParserError
		let isOr = opToken.kind == TokenKind.or
		var label = "shortAnd"
		var opName = "and"
		var seedValue = 0
		if isOr 'isOrLabel'
			label = "shortOr"
			opName = "or"
			seedValue = 1
		end 'isOrLabel'
		let opRange = SourceRange.ofToken(opToken)
		let opLine = opToken.line

		// Allocate the slot via the parser scope so subsequent varLoad/varStore
		// ops resolve correctly through the existing slot machinery.
		let slot = scope.declare("__{label}_{currentFunc.nextBlockId}", varType: MaxonType.boolean, mutable: true)

		// Seed with the short-circuit value: `and` seeds false, `or` seeds true.
		let seedName = emitLiteral(entryBlock, value: seedValue, valueType: MaxonType.boolean)
		module.appendOp(entryBlock, op: MaxonOp.varDecl(slot, value: seedName, slotType: MaxonType.boolean, range: opRange))

		// For `or`, negate the lhs so we can use the same [rhs(then), merge(else)]
		// layout as `and`: take the rhs path when the negated value is true.
		var branchCondName = leftName
		if isOr 'negateLhs'
			let negatedName = freshSynthName()
			let oneName = emitLiteral(entryBlock, value: 1, valueType: MaxonType.integer)
			module.appendOp(entryBlock, op: MaxonOp.binop(negatedName, left: leftName, right: oneName, opKind: BinOpKind.bitXor, operandType: MaxonType.integer, range: opRange))
			branchCondName = negatedName
		end 'negateLhs'

		// rhs block sits immediately after the entry block. Allocate it
		// before parsing the rhs so its label is fixed; the merge block is
		// allocated AFTER the rhs parse so any nested short-circuit blocks
		// added during rhs parsing slot in between rhs and merge.
		let rhsLabel = "{label}.rhs"
		var rhsBlock = module.addBlockAt(currentFunc, label: rhsLabel, filePath: filePath.toString(), firstLine: opLine)
		let rhsBlockId = rhsBlock.id

		currentBlock = rhsBlock
		let rhsResult = try parseExpressionBP(rhsBlock, minBP: rhsMinBP)
		var rhsExitBlock = currentBlock
		// The rhs type can be MaxonType.unresolved if the rhs is a field-load,
		// methodCall, or other deferred-type producer. Skip the parse-time
		// bool check in that case — TypeResolution re-validates `and`/`or`
		// once producer types are resolved (via validateBinopTypes or the
		// equivalent post-parse pass). Cmp ops (`<`, `>=`, `==`, …) emit
		// their result with valueType `integer` even though they're
		// semantically bool — the comparison-emitter at the Pratt-loop tail
		// hard-codes integer for parser cmp results. Accept integer here so
		// `<bool> and <cmp>` doesn't false-positive.
		let rhsT = exprType(rhsResult)
		if not maxonTypeIsBool(rhsT) and not isUnresolvedMaxonType(rhsT) and not maxonTypeIsInt(rhsT) 'rhsTypeMismatch'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "operator '{opName}' requires both operands to be the same type (both bool or both int)", line: opLine, column: opToken.column, filePath: filePath)
		end 'rhsTypeMismatch'

		module.appendOp(rhsExitBlock, op: MaxonOp.varStore(slot, value: exprName(rhsResult), range: opRange))

		let mergeLabel = "{label}.merge"
		var mergeBlock = module.addBlockAt(currentFunc, label: mergeLabel, filePath: filePath.toString(), firstLine: opLine)
		let mergeBlockId = mergeBlock.id

		module.setTerminator(entryBlock, op: MaxonOp.condBr(branchCondName, thenTarget: rhsBlockId, elseTarget: mergeBlockId, range: opRange))
		module.setTerminator(rhsExitBlock, op: MaxonOp.br(mergeBlockId, range: opRange))

		currentBlock = mergeBlock
		let resultName = freshSynthName()
		module.appendOp(mergeBlock, op: MaxonOp.varLoad(resultName, slotId: slot, slotType: MaxonType.boolean, range: opRange))
		return resultName
	end 'emitShortCircuit'

	// Caller guarantees `kind` is one of the infix operators for which
	// `infixBindingPower` returns a nonzero value (and `is` is intercepted by
	// the pratt loop before reaching here). Any other kind is a dispatch bug —
	// we panic rather than throw, so tests expose it as a compiler invariant
	// violation instead of a recoverable parse error.
	function emitBinaryOp(block IrBlock, kind TokenKind, resultName ByteArray, leftName ByteArray, rightName ByteArray, leftType MaxonType, rightType MaxonType, operandType MaxonType, range SourceRange = SourceRange.none())
		let intType = MaxonType.integer
		let hlOp = match kind 'emit'
			or gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitOr, operandType: intType, range: range)
			xor gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitXor, operandType: intType, range: range)
			and gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.bitAnd, operandType: intType, range: range)
			shl gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shl, operandType: intType, range: range)
			shr gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.shr, operandType: intType, range: range)
			equalsEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.eq, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			bangEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ne, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			lessThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.lt, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			lessEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.le, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			greaterThan gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.gt, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			greaterEquals gives MaxonOp.cmp(resultName, left: leftName, right: rightName, predicate: CmpPredicate.ge, leftType: leftType, rightType: rightType, operandType: operandType, range: range)
			plus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.add, operandType: operandType, range: range)
			minus gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.sub, operandType: operandType, range: range)
			star gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mul, operandType: operandType, range: range)
			slash gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.div, operandType: operandType, range: range)
			mod gives MaxonOp.binop(resultName, left: leftName, right: rightName, opKind: BinOpKind.mod, operandType: intType, range: range)
			default panic("emitBinaryOp: unexpected token kind {kind.name} — pratt loop should have filtered via infixBindingPower")
		end 'emit'
		module.appendOp(block, op: hlOp)
	end 'emitBinaryOp'

	// --- Unary parsing ---

	// Unary: -primary | not primary | primary
	function parseUnary(block IrBlock) returns ExprResult throws ParserError
		// `try EXPR`: error-flag propagation via the multi-value-return error
		// ABI (the secondary return register, RDX/X1, carries the flag). Two
		// forms:
		//
		//   try EXPR                    -- propagation. If the call set the
		//                                  error flag, re-publish it on the
		//                                  current function's secondary
		//                                  return register and return a
		//                                  default primary value. Otherwise
		//                                  the expression evaluates to the
		//                                  call's result.
		//
		//   try EXPR otherwise FALLBACK -- if the call set the error flag,
		//                                  evaluate FALLBACK as the
		//                                  expression's value; otherwise
		//                                  evaluate to the call's result.
		//
		// The inner EXPR must be a function call shape — this is enforced
		// structurally by rewriting the last appended `call` op into a
		// `tryCall`. If the inner expression doesn't end in a call, we
		// emit a parser-level "must be a call" diagnostic and fall
		// through to plain parsing so the rest of the file still parses.
		if at(TokenKind.try) 'isTry'
			return try parseTryExpression(block)
		end 'isTry'

		if at(TokenKind.minus) 'isNeg'
			let opToken = try consume()
			let opRange = SourceRange.ofToken(opToken)
			let operand = try parsePrimary(block)
			let operandType = exprType(operand)
			if maxonTypeIsFloat(operandType) 'floatNeg'
				// Float negation: emit 0.0 - operand. The parser emits directly in
				// terms of MaxonType.float here because the source-level float
				// literal is unambiguous.
				// The synthetic `0.0` literal has no source origin; the binop itself
				// ranges over the `-` operator token that triggered the lowering.
				let zeroName = freshSynthName()
				module.appendOp(block, op: MaxonOp.literal(zeroName, value: 0, valueType: MaxonType.float, range: SourceRange.none()))
				let resultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.binop(resultName, left: zeroName, right: exprName(operand), opKind: BinOpKind.sub, operandType: MaxonType.float, range: opRange))
				return try parseAsCasts(block, expr: ExprResult.direct(resultName, valueType: MaxonType.float))
			end 'floatNeg'
			// For named or integer operands, emit the integer unary-neg op and
			// let lowerMaxonToStd pick the concrete StdType.
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.neg, operandType: operandType, range: opRange))
			return try parseAsCasts(block, expr: ExprResult.direct(resultName, valueType: operandType))
		end 'isNeg' else if at(TokenKind.not) 'isNot'
			let notToken = try consume()
			let notRange = SourceRange.ofToken(notToken)
			let operand = try parseUnary(block)
			// Emit `logicalNot` unconditionally; the lowerer reads the
			// operand's resolved MaxonType (after TypeResolution) to pick
			// between XOR-with-1 (bool) and XOR-with-(-1) (int) semantics.
			// Type-driven dispatch belongs in lowering / TypeResolution,
			// not here.
			//
			// Use `currentBlock` (not the original `block` param) as the
			// emission target: a short-circuit `or`/`and` operand earlier
			// in the call chain (e.g. `not (t or f)`) moves control flow
			// to a merge block, where the operand's defining SSA op lives.
			// Appending here to the original entry block would emit the
			// unop in a different block from its producer, breaking SSA.
			let resultName = freshSynthName()
			module.appendOp(currentBlock, op: MaxonOp.unop(resultName, operand: exprName(operand), opKind: UnaryOpKind.logicalNot, operandType: MaxonType.unresolved, range: notRange))
			return ExprResult.direct(resultName, valueType: MaxonType.unresolved)
		end 'isNot'

		return try parseAsCasts(block, expr: try parsePostfix(block, expr: try parsePrimary(block)))
	end 'parseUnary'

	// Parse a `try EXPR [otherwise FALLBACK]` expression. The inner EXPR
	// must be a function call — enforced by rewriting its terminal `call`
	// MaxonOp into a `tryCall`. The tryCall's `errorBoundName` slot binds
	// the error flag via the multi-value-return ABI (the backend lowers
	// tryCall to a call that picks up the flag from RDX/X1). After the
	// call we emit a cmp+condBr on the flag:
	//
	//   - propagation form (no `otherwise`): the error block re-publishes
	//     the flag in the current function's secondary return register
	//     and returns a default primary value, mirroring `MaxonOp.throw`'s
	//     lowered shape so the enclosing function's caller observes the
	//     same error.
	//
	//   - fallback form (`otherwise FALLBACK`): both arms write into a
	//     parser-allocated result slot, then merge into a join block
	//     where the slot is loaded as the expression's value.
	//
	// `try EXPR otherwise (e) BLOCK` and the multi-statement
	// `try BLOCK ... otherwise BLOCK` are out of scope for Phase 4a-c.
	function parseTryExpression(block IrBlock, isStatementContext bool = false) returns ExprResult throws ParserError
		let tryToken = try consume()  // 'try'
		// Snapshot the op count so we can locate the inner expression's
		// terminal `call` op after parsing. parseUnary may emit multiple
		// ops (chained postfix/methodCall) — we look at the last one.
		// We deliberately call parseUnary, not parseExpressionBP: the
		// rewrite below targets the last emitted op, so the inner must end
		// with the throwing call. A full expression parse would let binops
		// (`try foo() + 1`) emit further ops after the call, leaving the
		// rewrite pointing at `add` instead of `call`. Outer binops are
		// handled by the caller's expression context after we return.
		let opCountBefore = module.ops.count()
		let inner = try parseUnary(block)
		let innerName = exprName(inner)
		// callReturnType starts as the parser-emitted type (usually unresolved
		// for call results). It is refined below after the call is rewritten
		// to a tryCall so the otherwise-type-mismatch check has a concrete
		// expected type to compare against.
		var callReturnType = exprType(inner)
		var innerExitBlock = currentBlock
		let opCountAfter = module.ops.count()

		// Allocate the synthetic flag-binding name up front so it can be
		// stamped into the rewritten tryCall op.
		let errorFlagName = freshSynthName()

		// Rewrite the terminal call to a tryCall (or terminal methodCall to
		// tryMethodCall) so the multi-value-return ABI binds the error flag
		// at the call site.
		var rewroteCall = false
		var calleeThrowsTypeName = ThrowsClause.none
		if opCountAfter > opCountBefore 'haveLastOp'
			let lastIdx = opCountAfter - 1
			let lastOp = try module.ops.get(lastIdx) otherwise panic("parseTryExpression: ops.get OOB at last idx={lastIdx} (count={opCountAfter})")
			rewroteCall = tryRewriteCallToTryCall(opIdx: lastIdx, op: lastOp, errorFlagName: errorFlagName, tryRange: SourceRange.ofToken(tryToken))
			if rewroteCall 'resolveCalleeInfo'
				// Resolve the qualified callee name once from the rewritten tryCall;
				// the void-return guard and throws-type lookup both key off the
				// same name. The callee's return type is filled by TR via
				// producerTypes — the parser leaves callReturnType as whatever
				// `exprType(inner)` reported (typically unresolved for call
				// results), and `validateTryOtherwiseTypes` re-runs the
				// otherwise-type-mismatch check after resolution completes.
				let rewrittenOp = try module.ops.get(lastIdx) otherwise panic("parseTryExpression: re-read OOB after rewrite")
				let qualifiedCallee = qualifiedCalleeFromTryCall(rewrittenOp, opIdx: lastIdx)
				// E3059: void-returning function cannot be used as an assignment expression.
				// Throws ParserError.unhandledToken after reporting so the unsupported
				// otherwise block is never parsed. Kept in the parser because the
				// "expression-context try" signal (isStatementContext) is parser-only
				// and the void return type collapses to unresolved in producerTypes,
				// so TR cannot recover the distinction from the IR alone.
				if not isStatementContext 'checkVoidReturn'
					try checkQualifiedCalleeNotVoidReturn(qualifiedCallee: qualifiedCallee, tryToken: tryToken)
				end 'checkVoidReturn'
				calleeThrowsTypeName = try project.funcThrowsTypes.get(qualifiedCallee) otherwise ThrowsClause.none
			end 'resolveCalleeInfo'
		end 'haveLastOp'
		if not rewroteCall 'noRewrite'
			// The inner expression was a methodCall (or other postfix shape
			// ending in one). Rewrite the preceding methodCall in place to a
			// `tryMethodCall` so lowering emits a single `StdCallOp.tryCall`
			// that yields BOTH the result AND the error flag through the
			// multi-value-return ABI (RDX/X1).
			var rewroteMethodCall = false
			if opCountAfter > opCountBefore 'haveLastOpForMethodRewrite'
				let lastIdx = opCountAfter - 1
				let lastOp = try module.ops.get(lastIdx) otherwise panic("parseTryExpression: ops.get OOB at last idx={lastIdx} (count={opCountAfter})")
				rewroteMethodCall = tryRewriteMethodCallToTryMethodCall(opIdx: lastIdx, op: lastOp, errorFlagName: errorFlagName, tryRange: SourceRange.ofToken(tryToken))
				if rewroteMethodCall 'resolveMethodThrows'
					// Mirror the tryCall path's throws-clause lookup: resolve
					// the receiver-qualified callee via the parser-time
					// op-scan so a bare-enum `(e)` binding gets the right
					// MaxonType (E3005 in match would otherwise fire because
					// the binding falls back to `integer`).
					let rewrittenOp = try module.ops.get(lastIdx) otherwise panic("parseTryExpression: re-read OOB after method rewrite")
					let qualifiedCallee = qualifiedCalleeFromTryCall(rewrittenOp, opIdx: lastIdx)
					calleeThrowsTypeName = try project.funcThrowsTypes.get(qualifiedCallee) otherwise ThrowsClause.none
				end 'resolveMethodThrows'
			end 'haveLastOpForMethodRewrite'
			if not rewroteMethodCall 'noMethodRewrite'
				// Inner expression is neither a call nor a methodCall - cannot bind
				// the error flag without a preceding throwing op. Reaching here is
				// a parser bug because parseTryExpression's gating already requires
				// the inner to be a throwing form.
				panic("parseTryExpression: inner expression has no preceding call/methodCall to rewrite (opCountBefore={opCountBefore}, opCountAfter={opCountAfter})")
			end 'noMethodRewrite'
		end 'noRewrite'

		// cmp flag != 0 — error when nonzero, success otherwise.
		let zeroName = emitLiteral(innerExitBlock, value: 0, valueType: MaxonType.integer)
		let condName = freshSynthName()
		module.appendOp(innerExitBlock, op: MaxonOp.cmp(condName, left: errorFlagName, right: zeroName, predicate: CmpPredicate.ne, leftType: MaxonType.integer, rightType: MaxonType.integer, operandType: MaxonType.integer, range: SourceRange.ofToken(tryToken)))

		let tryFilePath = filePath.toString()
		let baseLabel = "try_{currentFunc.nextBlockId}"

		if at(TokenKind.otherwise) 'isFallback'
			return try parseTryFallback(innerExitBlock: innerExitBlock, tryToken: tryToken, condName: condName, callResultName: innerName, callResultType: callReturnType, baseLabel: baseLabel, tryFilePath: tryFilePath, isStatementContext: isStatementContext, errorFlagName: errorFlagName, calleeThrowsTypeName: calleeThrowsTypeName)
		end 'isFallback'

		return parseTryPropagation(innerExitBlock: innerExitBlock, tryToken: tryToken, condName: condName, errorFlagName: errorFlagName, callResultName: innerName, callResultType: callReturnType, baseLabel: baseLabel, tryFilePath: tryFilePath)
	end 'parseTryExpression'

	// Propagation path: when the called function set the error flag, the
	// current function re-publishes it on its own secondary return register
	// (RDX/X1) and returns a default primary value of its own return type.
	// Success path falls through with the call's result. Returns the call's
	// result name as the expression's value — only the success path reads it.
	function parseTryPropagation(innerExitBlock IrBlock, tryToken Token, condName ByteArray, errorFlagName ByteArray, callResultName ByteArray, callResultType MaxonType, baseLabel String, tryFilePath String) returns ExprResult
		// `var` rather than `let` because addBlockAt's IrBlock is mutated
		// in place by subsequent appendOp/setTerminator calls — the
		// borrow checker rejects passing a `let`-bound IrBlock to those.
		var errorBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.err", filePath: tryFilePath, firstLine: tryToken.line)
		let errorBlockId = errorBlock.id
		let continueBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.cont", filePath: tryFilePath, firstLine: tryToken.line)
		let continueBlockId = continueBlock.id

		// condBr: error (cond `flag != 0`) -> errorBlock, else success -> continueBlock.
		module.setTerminator(innerExitBlock, op: MaxonOp.condBr(condName, thenTarget: errorBlockId, elseTarget: continueBlockId, range: SourceRange.ofToken(tryToken)))

		// Phase 5 (multi-value-return error ABI): re-publish the runtime-bound
		// flag through the multi-value-return ABI. `MaxonOp.rethrow` lowers to
		// `StdCallOp.errorReturn(zero, errorFlagId: flag)` - the same shape
		// `MaxonOp.throw` produces, except the flag value is a runtime SSA
		// name rather than a compile-time-known variant ordinal.
		module.setTerminator(errorBlock, op: MaxonOp.rethrow(errorFlagName, range: SourceRange.ofToken(tryToken)))

		// Continue parsing in continueBlock; the expression's value is the
		// successful call's result.
		currentBlock = continueBlock
		return ExprResult.direct(callResultName, valueType: callResultType)
	end 'parseTryPropagation'

	// Fallback path: `otherwise FALLBACK`. The success arm writes the call
	// result into a slot; the fallback arm either writes a value into the
	// same slot (expression / `ignore`) or terminates (return / panic /
	// throw / break / continue). A merge block then reads the slot as the
	// expression's value.
	//
	// Multi-statement `otherwise BLOCK` and `(e) BLOCK` binding forms are
	// out of scope here — they're handled by a future phase.
	function parseTryFallback(innerExitBlock IrBlock, tryToken Token, condName ByteArray, callResultName ByteArray, callResultType MaxonType, baseLabel String, tryFilePath String, isStatementContext bool, errorFlagName ByteArray, calleeThrowsTypeName ThrowsClause) returns ExprResult throws ParserError
		try eat(TokenKind.otherwise)
		// Result slot. Type is `unresolved` until the success arm stores —
		// TypeResolution propagates the concrete type from there.
		let resultSlot = scope.declare("__try_{baseLabel}_result", varType: MaxonType.unresolved, mutable: true)
		// Seed with a zero literal so the merge block's varLoad reads a
		// well-typed value under wasm's stricter validation, mirroring how
		// `parseMatchExpression` seeds its result slot.
		let seedZero = emitLiteral(innerExitBlock, value: 0, valueType: MaxonType.integer)
		module.appendOp(innerExitBlock, op: MaxonOp.varDecl(resultSlot, value: seedZero, slotType: MaxonType.unresolved, range: SourceRange.ofToken(tryToken)))

		var fallbackBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.otherwise", filePath: tryFilePath, firstLine: tryToken.line)
		let fallbackBlockId = fallbackBlock.id
		var successBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.ok", filePath: tryFilePath, firstLine: tryToken.line)
		let successBlockId = successBlock.id

		// condBr: error (cond `flag != 0`) -> fallback, else success -> success block.
		module.setTerminator(innerExitBlock, op: MaxonOp.condBr(condName, thenTarget: fallbackBlockId, elseTarget: successBlockId, range: SourceRange.ofToken(tryToken)))

		// Success path: store the call result into the merge slot.
		module.appendOp(successBlock, op: MaxonOp.varStore(resultSlot, value: callResultName, range: SourceRange.ofToken(tryToken)))

		// Decide what shape the fallback takes by peeking at the first
		// token after `otherwise`:
		//   return / panic / throw / break / continue → terminator-shaped
		//   ignore                                   → discard error, merge
		//   anything else                            → fallback expression
		// Terminator-shaped fallbacks seal the fallback block themselves;
		// only `ignore` and the expression form branch into the merge block.
		currentBlock = fallbackBlock
		let dispatchToken = cursor.current()
		let dispatched = try parseTryFallbackDispatch(fallbackBlock: fallbackBlock, dispatchToken: dispatchToken, resultSlot: resultSlot, callResultType: callResultType, tryToken: tryToken, isStatementContext: isStatementContext, errorFlagName: errorFlagName, calleeThrowsTypeName: calleeThrowsTypeName)

		// Merge block: load the slot. Even when the fallback is a
		// terminator we still emit the merge block — only the success edge
		// reaches it, but the load needs a home and downstream code has to
		// continue from somewhere.
		var mergeBlock = module.addBlockAt(currentFunc, label: "{baseLabel}.merge", filePath: tryFilePath, firstLine: tryToken.line)
		let mergeBlockId = mergeBlock.id

		module.setTerminator(successBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.ofToken(tryToken)))
		// Only branch the fallback into the merge block when the fallback
		// path is an expression (or `ignore`) — terminator forms have
		// already sealed their block with ret/throw/br/etc.
		if dispatched.mergesIntoSuccess 'mergesIn'
			module.setTerminator(dispatched.fallbackExitBlock, op: MaxonOp.br(mergeBlockId, range: SourceRange.ofToken(tryToken)))
		end 'mergesIn'

		// Result type: prefer the call's type, else the fallback expression's
		// type when present. Either side may be `unresolved` at parse time —
		// TypeResolution fills both.
		var resultType = callResultType
		if isUnresolvedMaxonType(resultType) and dispatched.hasFallbackType 'callUnresolved'
			resultType = dispatched.fallbackType
		end 'callUnresolved'

		currentBlock = mergeBlock
		let resultName = freshSynthName()
		module.appendOp(mergeBlock, op: MaxonOp.varLoad(resultName, slotId: resultSlot, slotType: resultType, range: SourceRange.ofToken(tryToken)))
		return ExprResult.direct(resultName, valueType: resultType)
	end 'parseTryFallback'

	// Dispatch on the token immediately after `otherwise` to pick a
	// fallback shape. Returns enough metadata for the caller to wire the
	// merge edges and pick a result type. The fallback block passed in is
	// the one the caller already created and seeded as currentBlock; this
	// helper either populates it with a fallback expression's varStore
	// (and reports the value's type) or installs a terminator that seals
	// the block from the caller's merge wiring.
	function parseTryFallbackDispatch(fallbackBlock IrBlock, dispatchToken Token, resultSlot VarSlot, callResultType MaxonType, tryToken Token, isStatementContext bool, errorFlagName ByteArray, calleeThrowsTypeName ThrowsClause) returns TryFallbackOutcome throws ParserError
		if dispatchToken.kind == TokenKind.return 'isReturn'
			try parseReturnStatement(fallbackBlock)
			return TryFallbackOutcome.terminator(fallbackBlock)
		end 'isReturn' else if dispatchToken.kind == TokenKind.panic 'isPanic'
			try parsePanicStatement(fallbackBlock)
			// parsePanicStatement only appends MaxonOp.panic — block needs
			// an explicit terminator so the verifier sees it sealed. Use a
			// synthetic ret of zero, mirroring emitMatchUnreachableTerminator.
			let zeroName = emitLiteral(fallbackBlock, value: 0, valueType: MaxonType.integer)
			module.setTerminator(fallbackBlock, op: MaxonOp.ret(zeroName, range: SourceRange.ofToken(tryToken)))
			return TryFallbackOutcome.terminator(fallbackBlock)
		end 'isPanic' else if dispatchToken.kind == TokenKind.throw 'isThrow'
			try parseThrowStatement(fallbackBlock)
			return TryFallbackOutcome.terminator(fallbackBlock)
		end 'isThrow' else if dispatchToken.kind == TokenKind.break 'isBreak'
			// parseBreakStatement returns a fresh detached block — we
			// don't care about it because the fallback path is sealed.
			_ = try parseBreakStatement(currentFunc, block: fallbackBlock)
			return TryFallbackOutcome.terminator(fallbackBlock)
		end 'isBreak' else if dispatchToken.kind == TokenKind.continue 'isContinue'
			_ = try parseContinueStatement(currentFunc, block: fallbackBlock)
			return TryFallbackOutcome.terminator(fallbackBlock)
		end 'isContinue' else if dispatchToken.kind == TokenKind.ignore 'isIgnore'
			// E3059: `otherwise ignore` in expression context leaves the assignment
			// binding undefined — only valid as a statement.
			if not isStatementContext 'ignoreInAssignment'
				reportCompileError(project, code: ErrorCode.semanticOtherwiseTypeMismatch, message: "type mismatch: ''otherwise ignore' cannot be used in assignment'", line: tryToken.line, column: tryToken.column, filePath: filePath)
				throw ParserError.unhandledToken
			end 'ignoreInAssignment'
			try eat(TokenKind.ignore)
			// `ignore` discards the error and falls through. The slot
			// needs a well-typed store on the fallback path so the merge
			// load is well-formed even when control hits the error edge.
			// Use a default-typed literal of the call's success type —
			// the user has documented-undefined semantics if they read it.
			let defaultLitType = defaultIgnoreLiteralType(callResultType)
			let defaultName = emitLiteral(fallbackBlock, value: 0, valueType: defaultLitType)
			module.appendOp(fallbackBlock, op: MaxonOp.varStore(resultSlot, value: defaultName, range: SourceRange.ofToken(tryToken)))
			return TryFallbackOutcome.merges(fallbackBlock)
		end 'isIgnore'

		// E2049: block-form fallbacks (`otherwise (e) 'label' ... end` and
		// `otherwise 'label' ... end`) are statements that span multiple
		// lines; they cannot appear inside a single-statement match arm
		// body. Reject before parsing the handler body so we surface the
		// diagnostic at the dispatch token, matching the spec's expected
		// column. Diverging forms (`return` / `throw` / `panic` / `ignore`
		// / `break` / `continue`) plus expression forms remain allowed.
		if inMatchArmBody and (dispatchToken.kind == TokenKind.leftParen or dispatchToken.kind == TokenKind.charLiteral) 'matchArmBlockForm'
			reportCompileError(project, code: ErrorCode.parserMatchBlockStatementNotAllowed, message: "block-form 'try ... otherwise 'label' ... end' is not allowed in a match arm; use 'otherwise panic(\"...\")', 'otherwise ignore', or 'otherwise return/throw/...' instead", line: dispatchToken.line, column: dispatchToken.column, filePath: filePath)
			throw ParserError.typeError
		end 'matchArmBlockForm'

		// Binding form: `otherwise (e) 'label' ... end 'label'`
		// Binds the typed error value to a name for inspection (e.g., match).
		// For bare-case enums the flag is `ordinal + 1`; subtract 1 to recover
		// the enum ordinal. For associated-value unions (Phase 9 Stage 5c) the
		// flag slot IS the union pointer — bind `e` directly to the flag SSA
		// name so `match e` sees the heap-boxed union with the right tag at
		// offset 0 and the existing union-match lowering applies unchanged.
		if dispatchToken.kind == TokenKind.leftParen 'isBinding'
			try eat(TokenKind.leftParen)
			let bindingToken = try consume()  // identifier: the binding name
			try eat(TokenKind.rightParen)
			_ = try consume()  // charLiteral: the block label
			// Resolve the throws-clause type up front so we can decide
			// between the bare-enum (flag-1) and union-pointer paths.
			// `throwsClauseName` throws when the callee is non-throwing,
			// in which case the binding defaults to int (the bare-enum /
			// flag path).
			var bindingType = MaxonType.integer
			var throwsIsUnion = false
			if let throwsName = try throwsClauseName(calleeThrowsTypeName) 'haveThrowsName'
				bindingType = internMaxonType(project, name: throwsName)
				throwsIsUnion = enumIsAssociatedValueUnion(throwsName)
			end 'haveThrowsName'
			// Declare the binding in a fresh scope so sibling `otherwise (e)`
			// blocks with different error types don't share the slot — the
			// `error.otherwise-block-reused-binding` regression. The scope
			// pops at handler-end before InjectDrops sees the slot.
			scope.pushScope()
			let bindingSlot = scope.declare(bindingToken.value, varType: bindingType, mutable: false)
			var bindingValueName = ByteArray.create()
			if throwsIsUnion 'isUnion'
				// Union throws: the runtime-bound `errorFlagName` IS the
				// union pointer (option-1 ABI). Bind `e` directly to it so
				// `match e` lowers against the union scrutinee and managed-
				// payload decrefs flow through the standard scope-exit drops.
				bindingValueName = errorFlagName
			end 'isUnion' else 'isBare'
				// Bare enum: recover the ordinal via `flag - 1`. The binding
				// is an integer in the enum's domain.
				let oneName = emitLiteral(fallbackBlock, value: 1, valueType: MaxonType.integer)
				let enumOrdinalName = freshSynthName()
				module.appendOp(fallbackBlock, op: MaxonOp.binop(enumOrdinalName, left: errorFlagName, right: oneName, opKind: BinOpKind.sub, operandType: MaxonType.integer, range: SourceRange.ofToken(tryToken)))
				bindingValueName = enumOrdinalName
			end 'isBare'
			module.appendOp(fallbackBlock, op: MaxonOp.varDecl(bindingSlot, value: bindingValueName, slotType: bindingType, range: SourceRange.ofToken(tryToken)))
			var handlerExitBlock = try parseStatements(currentFunc, block: fallbackBlock, lastWasReturn: false)
			scope.popScope()
			try skipEndAndLabel()
			return finalizeFallbackHandler(handlerExitBlock: handlerExitBlock, resultSlot: resultSlot, callResultType: callResultType, tryToken: tryToken)
		end 'isBinding'

		// Block form: `otherwise 'label' ... end 'label'`
		// The dispatch token is a charLiteral (the opening label). Parse
		// the handler body as statements, then close with `end 'label'`.
		// The handler runs for side-effects; the result slot gets a zero-default
		// so the merge load stays well-formed (the try result is unused in
		// statement context, and expression-context block forms are rejected
		// by the type-checker below anyway).
		if dispatchToken.kind == TokenKind.charLiteral 'isBlock'
			try eat(TokenKind.charLiteral)
			var handlerExitBlock = try parseStatements(currentFunc, block: fallbackBlock, lastWasReturn: false)
			try skipEndAndLabel()
			return finalizeFallbackHandler(handlerExitBlock: handlerExitBlock, resultSlot: resultSlot, callResultType: callResultType, tryToken: tryToken)
		end 'isBlock'

		// Default: fallback is an expression. parseExpression may swap
		// currentBlock if the fallback contains short-circuit ops; recover
		// the actual exit block afterwards.
		let rawFallback = try parseExpression(fallbackBlock)
		// `parseStringLiteral`'s fast path returns a `stringConst`
		// ExprResult without emitting a backing op; the varStore below
		// would reference an unbound name (E3013 in lowering). Mirror
		// every other call-emission site that threads a string-literal
		// arg into another op.
		let fallbackResult = materializeStringConstIfNeeded(currentBlock, expr: rawFallback, range: SourceRange.ofToken(tryToken))
		let fallbackType = exprType(fallbackResult)
		// E3059: otherwise expression type must match the success type.
		// Skip the parse-time check when either side is still unresolved or
		// names a type the project hasn't seen yet (typealiases resolve in
		// TypeResolution; calling convertCastCategory on an unknown name
		// panics). TypeResolution's validateTryOtherwiseTypes re-runs this
		// check after resolution completes.
		if not isUnresolvedMaxonType(callResultType) and not isUnresolvedMaxonType(fallbackType) and maxonTypeIsKnown(project, t: callResultType) and maxonTypeIsKnown(project, t: fallbackType) 'doTypeCheck'
			let expectedCategory = convertCastCategory(project, t: callResultType)
			let actualCategory = convertCastCategory(project, t: fallbackType)
			// Allow numeric coercions: int literals coerce to byte-sized named types (e.g. ExitCode).
			let bothIntegerFamily = castCategoryIsIntegerFamily(expectedCategory) and castCategoryIsIntegerFamily(actualCategory)
			if expectedCategory != actualCategory and not bothIntegerFamily 'categoryMismatch'
				let actualName = castCategoryName(actualCategory)
				let expectedName = castCategoryName(expectedCategory)
				reportCompileError(project, code: ErrorCode.semanticOtherwiseTypeMismatch, message: "type mismatch: 'otherwise type '{actualName}' does not match expected type '{expectedName}''", line: tryToken.line, column: tryToken.column, filePath: filePath)
				throw ParserError.unhandledToken
			end 'categoryMismatch'
		end 'doTypeCheck'
		var fallbackExitBlock = currentBlock
		module.appendOp(fallbackExitBlock, op: MaxonOp.varStore(resultSlot, value: exprName(fallbackResult), range: SourceRange.ofToken(tryToken)))
		return TryFallbackOutcome.mergesWithType(fallbackExitBlock, fallbackType: fallbackType)
	end 'parseTryFallbackDispatch'

	// Pick a literal type for the synthetic store the `ignore` arm emits.
	// We want the store to type-match the success arm's call result so the
	// slot's resolved type stays consistent. The slot's value on the
	// ignore arm has documented-undefined semantics, so when we don't know
	// the call's result type at parse time we fall back to `integer` (any
	// 8-byte value is fine here — the user has been told the read is
	// undefined). Literals are typed at parser emission and have no
	// backfill pass, so leaving this `unresolved` would survive past
	// TypeResolution and trip the lowering invariant.
	function defaultIgnoreLiteralType(callResultType MaxonType) returns MaxonType
		if isUnresolvedMaxonType(callResultType) 'unresolved'
			return MaxonType.integer
		end 'unresolved'
		return defaultLiteralTypeOfInner(callResultType)
	end 'defaultIgnoreLiteralType'

	// Shared tail for the `otherwise (e) BLOCK` and `otherwise BLOCK` handler
	// forms: if the handler didn't terminate (return/throw/etc.), append a
	// type-correct zero store into the result slot so the merge load is
	// well-formed. Returns the appropriate TryFallbackOutcome either way.
	function finalizeFallbackHandler(handlerExitBlock IrBlock, resultSlot VarSlot, callResultType MaxonType, tryToken Token) returns TryFallbackOutcome
		if handlerExitBlock.isTerminated() 'terminated'
			return TryFallbackOutcome.terminator(handlerExitBlock)
		end 'terminated'
		let defaultLitType = defaultIgnoreLiteralType(callResultType)
		let defaultName = emitLiteral(handlerExitBlock, value: 0, valueType: defaultLitType)
		module.appendOp(handlerExitBlock, op: MaxonOp.varStore(resultSlot, value: defaultName, range: SourceRange.ofToken(tryToken)))
		return TryFallbackOutcome.merges(handlerExitBlock)
	end 'finalizeFallbackHandler'

	// Pattern-match the parser's just-emitted op to detect a free-call.
	// When the inner expression of `try EXPR` ended in `MaxonOp.call`,
	// rewrite it in place to `MaxonOp.tryCall` carrying the parser-allocated
	// `errorFlagName` so the lowering pass binds the post-call error flag
	// (via the multi-value-return ABI) at the right spot. Returns true on
	// rewrite, false when the op is some other shape (method call, postfix
	// chain, etc.) — the caller falls back to `tryRewriteMethodCallToTryMethodCall`.
	function tryRewriteCallToTryCall(opIdx OpIndex, op MaxonOp, errorFlagName ByteArray, tryRange SourceRange) returns bool
		if op.name != "call" 'notACall'
			return false
		end 'notACall'
		match op 'shape'
			call(callResult, callee, callContext, args, argLabels, argTypes, argRanges, _) then return rewriteCallOpToTryCall(opIdx: opIdx, callResult: callResult, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorFlagName: errorFlagName, range: tryRange)
			default panic("tryRewriteCallToTryCall: op.name == 'call' but match did not extract")
		end 'shape'
	end 'tryRewriteCallToTryCall'

	function rewriteCallOpToTryCall(opIdx OpIndex, callResult ByteArray, callee ByteArray, callContext CallContext, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorFlagName ByteArray, range SourceRange) returns bool
		try module.ops.set(opIdx, value: MaxonOp.tryCall(callResult, callee: callee, callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorFlagName, range: range)) otherwise panic("rewriteCallOpToTryCall: ops.set OOB at idx={opIdx}")
		return true
	end 'rewriteCallOpToTryCall'

	// Rewrite the terminal `methodCall` in place to a `tryMethodCall` so
	// lowering binds the post-call error flag via the multi-value-return
	// ABI (RDX/X1). Mirrors `tryRewriteCallToTryCall`'s relationship to
	// `tryCall`.
	function tryRewriteMethodCallToTryMethodCall(opIdx OpIndex, op MaxonOp, errorFlagName ByteArray, tryRange SourceRange) returns bool
		if op.name != "methodCall" 'notAMethodCall'
			return false
		end 'notAMethodCall'
		match op 'shape'
			methodCall(methodResult, receiver, methodName, args, argLabels, argTypes, argRanges, _) then return rewriteMethodCallOpToTryMethodCall(opIdx: opIdx, methodResult: methodResult, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorFlagName: errorFlagName, range: tryRange)
			default panic("tryRewriteMethodCallToTryMethodCall: op.name == 'methodCall' but match did not extract")
		end 'shape'
	end 'tryRewriteMethodCallToTryMethodCall'

	function rewriteMethodCallOpToTryMethodCall(opIdx OpIndex, methodResult ByteArray, receiver ByteArray, methodName ByteArray, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, errorFlagName ByteArray, range SourceRange) returns bool
		try module.ops.set(opIdx, value: MaxonOp.tryMethodCall(methodResult, receiver: receiver, methodName: methodName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, errorBoundName: errorFlagName, range: range)) otherwise panic("rewriteMethodCallOpToTryMethodCall: ops.set OOB at idx={opIdx}")
		return true
	end 'rewriteMethodCallOpToTryMethodCall'

	// Pull the qualified callee name out of a tryCall or tryMethodCall op.
	// Callers may have rewritten either a `call` (→ `tryCall`) or a
	// `methodCall` (→ `tryMethodCall`) so we accept both shapes. For
	// `tryCall` we apply the parser's qualifier rules (namespace, current
	// file). For `tryMethodCall` we walk back through recently-emitted ops
	// to recover the receiver's MaxonType — when the receiver is a
	// local-scope varLoad (or chains through one) the slotType on that op
	// gives the concrete receiver type, which combined with the method name
	// yields the qualified callee key that `project.funcThrowsTypes` uses.
	// Returns the bare method name when the receiver's type cannot be
	// recovered at parse time (e.g. the receiver is a methodCall result
	// whose return type stays unresolved until TR runs); the caller falls
	// through to a `ThrowsClause.none` binding, mirroring the pre-walkback
	// behaviour for that case.
	function qualifiedCalleeFromTryCall(op MaxonOp, opIdx OpIndex) returns String
		return match op 'extract'
			tryCall(_, callee, callContext, _, _, _, _, _, _) gives qualifyCalleeForContext(project, bare: String.from(callee), callContext: callContext, currentNamespace: namespace, readerFilePath: filePath)
			tryMethodCall(_, receiver, methodName, _, _, _, _, _, _) gives qualifyMethodCalleeFromReceiver(receiver: receiver, methodName: String.from(methodName), scanFrom: opIdx)
			default panic("qualifiedCalleeFromTryCall: expected tryCall or tryMethodCall op, got '{op.name}'")
		end 'extract'
	end 'qualifiedCalleeFromTryCall'

	// Recover the receiver's MaxonType for a tryMethodCall at parse time by
	// scanning backward from `scanFrom` (exclusive) for the op that
	// produced `receiverName`. Returns the bare method name unchanged when
	// the receiver's type cannot be resolved — that yields a miss against
	// `project.funcThrowsTypes`, which is the correct conservative answer
	// for not-yet-resolvable shapes (call results, chained postfix
	// expressions whose intermediate types are still unresolved).
	function qualifyMethodCalleeFromReceiver(receiver ByteArray, methodName String, scanFrom OpIndex) returns String
		let receiverType = scanProducerTypeForName(receiver, scanFrom: scanFrom)
		logTrace(LogCategory.parser, message: () gives "qualifyMethodCalleeFromReceiver: receiver='{String.from(receiver)}' methodName='{methodName}' scanFrom={scanFrom} receiverType.kind='{receiverType.name}'")
		if isUnresolvedMaxonType(receiverType) 'unresolved'
			return methodName
		end 'unresolved'
		let structName = try maxonTypeStructName(project, t: receiverType) otherwise return methodName
		logTrace(LogCategory.parser, message: () gives "qualifyMethodCalleeFromReceiver: structName='{structName}' -> '{structName}.{methodName}'")
		return "{structName}.{methodName}"
	end 'qualifyMethodCalleeFromReceiver'

	// Walk module.ops backward from `scanFrom - 1` looking for the op that
	// produced `targetName`. Returns the producer's MaxonType when it can
	// be read directly off the op (varLoad's slotType, selfFieldLoad's
	// implicit self-type, structAlloc's named result type) or
	// `MaxonType.unresolved` when no such producer is found in range or
	// the producer's result type isn't recoverable without running TR.
	// Bounded by the current function's first op so we don't accidentally
	// cross into another function's op slice.
	//
	// When a producer is a `varLoad` whose `slotType` is `unresolved`, fall
	// back to recovering the slot's value by scanning further back for its
	// `varDecl` and recursing on the varDecl's value (a `call` to a stdlib
	// function like `Map.init` or `Array.create` has a registered return
	// type, so the chain resolves even when the surface-level slot type
	// was inferred-from-initializer). Without this, `var m = [1: 10]`'s
	// slot stays unresolved at parse time and the `m.insert` qualified
	// callee lookup misses funcThrowsTypes for `Map.insert`, breaking the
	// `otherwise (e) ... match e` binding-type plumbing for map literals.
	function scanProducerTypeForName(targetName ByteArray, scanFrom OpIndex) returns MaxonType
		return scanProducerTypeForNameWithDepth(targetName, scanFrom: scanFrom, depth: 0)
	end 'scanProducerTypeForName'

	// Bounded-depth recursion: at most 3 levels of varLoad→varDecl→producer
	// chain (one for the receiver's varLoad, one for the initializer's call
	// result, one safety margin). Self-referential or cyclic IR shapes are
	// not possible in well-formed parser output, but the depth cap keeps
	// pathological inputs from infinite recursion.
	function scanProducerTypeForNameWithDepth(targetName ByteArray, scanFrom OpIndex, depth ScanDepth) returns MaxonType
		if depth >= 3 'maxDepth'
			return MaxonType.unresolved
		end 'maxDepth'
		if scanFrom == 0 'noOps'
			return MaxonType.unresolved
		end 'noOps'
		var idx = scanFrom - 1
		while true 'scan'
			let op = try module.ops.get(idx) otherwise return MaxonType.unresolved
			let producerType = producerTypeIfNameMatches(op, targetName: targetName)
			if not isUnresolvedMaxonType(producerType) 'haveType'
				return producerType
			end 'haveType'
			if op.name == "varLoad" 'isVarLoadMatch'
				let chainedType = chaseVarLoadProducerType(op, targetName: targetName, scanFrom: idx, depth: depth)
				if not isUnresolvedMaxonType(chainedType) 'chained'
					return chainedType
				end 'chained'
			end 'isVarLoadMatch'
			if op.name == "call" or op.name == "tryCall" 'isCallMatch'
				let callType = callResultTypeIfNameMatches(op, targetName: targetName)
				if not isUnresolvedMaxonType(callType) 'haveCallType'
					return callType
				end 'haveCallType'
			end 'isCallMatch'
			if idx == 0 'atStart'
				return MaxonType.unresolved
			end 'atStart'
			idx = idx - 1
		end 'scan'
		return MaxonType.unresolved
	end 'scanProducerTypeForNameWithDepth'

	// When `op` is a `varLoad` whose result name equals `targetName` but
	// whose `slotType` is `unresolved`, recover the slot's true type by
	// walking back for its `varDecl` and recursing on the varDecl's value.
	// Returns `unresolved` when the op shape doesn't match, the result name
	// doesn't match, or the slot's varDecl can't be located.
	function chaseVarLoadProducerType(op MaxonOp, targetName ByteArray, scanFrom OpIndex, depth ScanDepth) returns MaxonType
		let slotInfo = extractVarLoadSlotIfMatch(op, targetName: targetName)
		if not slotInfo.matched 'noMatch'
			return MaxonType.unresolved
		end 'noMatch'
		if not isUnresolvedMaxonType(slotInfo.slotType) 'haveSlotType'
			return slotInfo.slotType
		end 'haveSlotType'
		if scanFrom == 0 'noPrev'
			return MaxonType.unresolved
		end 'noPrev'
		var declIdx = scanFrom - 1
		while true 'findDecl'
			let prevOp = try module.ops.get(declIdx) otherwise return MaxonType.unresolved
			if prevOp.name == "varDecl" 'isDecl'
				let declMatch = extractVarDeclValueIfSlot(prevOp, slotId: slotInfo.slot)
				if declMatch.matched 'found'
					return scanProducerTypeForNameWithDepth(declMatch.value, scanFrom: declIdx, depth: depth + 1)
				end 'found'
			end 'isDecl'
			if declIdx == 0 'atStart'
				return MaxonType.unresolved
			end 'atStart'
			declIdx = declIdx - 1
		end 'findDecl'
		return MaxonType.unresolved
	end 'chaseVarLoadProducerType'

	function extractVarLoadSlotIfMatch(op MaxonOp, targetName ByteArray) returns VarLoadSlotInfo
		return match op 'shape'
			varLoad(name, slotId, slotType, _) gives nameMatchSlotInfo(name, target: targetName, slot: slotId, slotType: slotType)
			default panic("extractVarLoadSlotIfMatch: op.name == 'varLoad' but match did not extract")
		end 'shape'
	end 'extractVarLoadSlotIfMatch'

	function nameMatchSlotInfo(name ByteArray, target ByteArray, slot VarSlot, slotType MaxonType) returns VarLoadSlotInfo
		if name.equals(target) 'isMatch'
			return VarLoadSlotInfo.matchedAt(slot, slotType: slotType)
		end 'isMatch'
		return VarLoadSlotInfo.notMatched()
	end 'nameMatchSlotInfo'

	function extractVarDeclValueIfSlot(op MaxonOp, slotId VarSlot) returns VarDeclValueInfo
		return match op 'shape'
			varDecl(declSlot, value, _, _) gives slotMatchValueInfo(declSlot, target: slotId, value: value)
			default panic("extractVarDeclValueIfSlot: op.name == 'varDecl' but match did not extract")
		end 'shape'
	end 'extractVarDeclValueIfSlot'

	function slotMatchValueInfo(declSlot VarSlot, target VarSlot, value ByteArray) returns VarDeclValueInfo
		if declSlot == target 'isMatch'
			return VarDeclValueInfo.matchedWith(value)
		end 'isMatch'
		return VarDeclValueInfo.notMatched()
	end 'slotMatchValueInfo'

	// Return the result type for a `call`/`tryCall` op when its result name
	// matches `targetName` — looks up the callee in `project.funcReturnTypes`
	// so the parser can chase `var m = MapInit()` through to `Map<...>`. Free
	// calls qualify via `CallContext` + namespace; method calls handle their
	// own qualification in `qualifyMethodCalleeFromReceiver`, so this helper
	// stays focused on the call-context-qualified shape.
	function callResultTypeIfNameMatches(op MaxonOp, targetName ByteArray) returns MaxonType
		let info = extractCallProducerInfo(op, targetName: targetName)
		if not info.matched 'noMatch'
			return MaxonType.unresolved
		end 'noMatch'
		let bare = String.from(info.callee)
		let qualified = qualifyCalleeForContext(project, bare: bare, callContext: info.callContext, currentNamespace: namespace, readerFilePath: filePath)
		let returnType = try project.funcReturnTypes.get(qualified) otherwise return MaxonType.unresolved
		return maxonReturnTypeValueOrUnresolved(returnType)
	end 'callResultTypeIfNameMatches'

	function extractCallProducerInfo(op MaxonOp, targetName ByteArray) returns CallProducerInfo
		if op.name == "call" 'isCall'
			return match op 'shape'
				call(result, calleeName, ctx, _, _, _, _, _) gives callProducerInfoIfResultMatch(result, target: targetName, callee: calleeName, callContext: ctx)
				default panic("extractCallProducerInfo: op.name == 'call' but match did not extract")
			end 'shape'
		end 'isCall'
		if op.name == "tryCall" 'isTryCall'
			return match op 'tryShape'
				tryCall(result, calleeName, ctx, _, _, _, _, _, _) gives callProducerInfoIfResultMatch(result, target: targetName, callee: calleeName, callContext: ctx)
				default panic("extractCallProducerInfo: op.name == 'tryCall' but match did not extract")
			end 'tryShape'
		end 'isTryCall'
		return CallProducerInfo.notMatched()
	end 'extractCallProducerInfo'

	function callProducerInfoIfResultMatch(result ByteArray, target ByteArray, callee ByteArray, callContext CallContext) returns CallProducerInfo
		if result.equals(target) 'isMatch'
			return CallProducerInfo.matched(callee, callContext: callContext)
		end 'isMatch'
		return CallProducerInfo.notMatched()
	end 'callProducerInfoIfResultMatch'

	// Inspect a single op: when its result name equals `targetName`, return
	// the op-stamped type for that result. Only the op shapes whose result
	// type is parser-knowable participate; anything else returns unresolved
	// so the scan keeps walking. Dispatch on `op.name` first so the inner
	// `match` only needs to extract the variants we care about — avoids
	// enumerating every MaxonOp constructor while still complying with the
	// "no silent default" invariant.
	function producerTypeIfNameMatches(op MaxonOp, targetName ByteArray) returns MaxonType
		if op.name == "varLoad" 'isVarLoad'
			return match op 'shape'
				varLoad(name, _, slotType, _) gives typeIfNamesEqual(name, target: targetName, t: slotType)
				default panic("producerTypeIfNameMatches: op.name == 'varLoad' but match did not extract")
			end 'shape'
		end 'isVarLoad'
		if op.name == "structAlloc" 'isStructAlloc'
			return match op 'shape'
				structAlloc(result, structName, _) gives typeIfNamesEqual(result, target: targetName, t: MaxonType.named(project.typeNames.intern(String.from(structName))))
				default panic("producerTypeIfNameMatches: op.name == 'structAlloc' but match did not extract")
			end 'shape'
		end 'isStructAlloc'
		if op.name == "literal" 'isLiteral'
			return match op 'shape'
				literal(result, _, valueType, _) gives typeIfNamesEqual(result, target: targetName, t: valueType)
				default panic("producerTypeIfNameMatches: op.name == 'literal' but match did not extract")
			end 'shape'
		end 'isLiteral'
		if op.name == "convert" 'isConvert'
			return match op 'shape'
				convert(result, _, _, toType, _, _) gives typeIfNamesEqual(result, target: targetName, t: toType)
				default panic("producerTypeIfNameMatches: op.name == 'convert' but match did not extract")
			end 'shape'
		end 'isConvert'
		if op.name == "globalLoad" 'isGlobalLoad'
			return match op 'shape'
				globalLoad(result, _, slotType, _) gives typeIfNamesEqual(result, target: targetName, t: slotType)
				default panic("producerTypeIfNameMatches: op.name == 'globalLoad' but match did not extract")
			end 'shape'
		end 'isGlobalLoad'
		return MaxonType.unresolved
	end 'producerTypeIfNameMatches'

	function typeIfNamesEqual(name ByteArray, target ByteArray, t MaxonType) returns MaxonType
		if name.equals(target) 'match'
			return t
		end 'match'
		return MaxonType.unresolved
	end 'typeIfNamesEqual'

	// E3059 guard: if the qualified callee is registered as void-returning,
	// emit E3059 "does not return a value" and throw so the rest of the
	// (unsupported) otherwise clause is never parsed.
	function checkQualifiedCalleeNotVoidReturn(qualifiedCallee String, tryToken Token) throws ParserError
		let retType = try project.funcReturnTypes.get(qualifiedCallee) otherwise return
		if maxonReturnTypeIsVoid(retType) 'isVoid'
			reportCompileError(project, code: ErrorCode.semanticOtherwiseTypeMismatch, message: "type mismatch: ''{qualifiedCallee}' does not return a value'", line: tryToken.line, column: tryToken.column, filePath: filePath)
			throw ParserError.unhandledToken
		end 'isVoid'
	end 'checkQualifiedCalleeNotVoidReturn'

	// Emit a literal of the current function's return type's family —
	// 0 (i64) for ints/byte/bool, 0.0 (f64) for floats. void return types
	// also get an i64 0 (unused, the ret op will be dropped at lowering).
	// Used by `parseTryPropagation` to manufacture the default primary
	// value the error path returns.
	function emitDefaultReturnLiteral(block IrBlock, range SourceRange) returns ByteArray
		let litType = defaultReturnLiteralType(currentFunc.maxonReturnType)
		return emitLiteral(block, value: 0, valueType: litType, range: range)
	end 'emitDefaultReturnLiteral'

	function defaultReturnLiteralType(rt MaxonReturnType) returns MaxonType
		return match rt 'pick'
			void gives MaxonType.integer
			value(inner) gives defaultLiteralTypeOfInner(inner)
		end 'pick'
	end 'defaultReturnLiteralType'

	function defaultLiteralTypeOfInner(inner MaxonType) returns MaxonType
		// Function-typed inner has no Maxon-numeric default; the parser only
		// reaches this on a numeric-literal context, so non-float arms all
		// fall through to integer.
		return match inner 'pick'
			float gives MaxonType.float
			boolean gives MaxonType.integer
			integer gives MaxonType.integer
			string to unresolved gives MaxonType.integer
			typeParameter to interface gives MaxonType.integer
			constInt gives MaxonType.integer
		end 'pick'
	end 'defaultLiteralTypeOfInner'

	// --- Cast expression parsing ---

	// Parse zero or more `as Type` casts following an expression. Casts bind
	// tighter than any binary operator, so we apply them as a postfix chain
	// before returning to the Pratt loop. Each cast emits a maxon.convert op
	// whose fromType/toType drive width selection during lowering. Cast
	// validity (widening rules, narrowing rejection) is checked by the
	// TypeResolution pass after all named types have been resolved.
	function parseAsCasts(block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr
		while at(TokenKind.as) 'castLoop'
			let asToken = try consume()
			let targetLastToken = cursor.current()
			let targetMaxonType = try parseCastTargetType()
			let fromMaxonType = exprType(result)
			let resultName = freshSynthName()
			let castRange = SourceRange.between(asToken, last: targetLastToken)
			module.appendOp(block, op: MaxonOp.convert(resultName, operand: exprName(result), fromType: fromMaxonType, toType: targetMaxonType, implicit: false, range: castRange))
			// Pair every named-type cast with a `castCheck` placeholder so
			// the post-resolution `expandCastRangeChecks` pass can splice
			// in a runtime range guard once the alias's bounds are known.
			// Casts to primitive `int`/`float`/`bool`/`byte` (no alias name)
			// don't need a runtime check — the parser already gates literal
			// values via E3009. Same-alias casts (`b as Byte` where `b: Byte`)
			// are also skipped — the value is already constrained to the
			// alias's range by an earlier check at its definition site.
			if not maxonTypesStructurallyEqual(fromMaxonType, b: targetMaxonType) 'differentTypes'
				emitCastCheckIfNamed(block, value: resultName, targetType: targetMaxonType, castRange: castRange)
			end 'differentTypes'
			result = ExprResult.direct(resultName, valueType: targetMaxonType)
		end 'castLoop'
		return result
	end 'parseAsCasts'

	// Emit a `castCheck` placeholder when the cast target is a named type.
	// The post-resolution expander walks every `castCheck`, looks up the
	// alias's range, and either drops the op (full-range alias, or alias
	// that wasn't a ranged primitive at all) or splits the host block to
	// insert a runtime guard.
	function emitCastCheckIfNamed(block IrBlock, value ByteArray, targetType MaxonType, castRange SourceRange)
		let aliasName = targetType.namedAliasNameOrEmpty(project)
		if aliasName.isEmpty() 'noAlias'
			return
		end 'noAlias'
		module.appendOp(block, op: MaxonOp.castCheck(value, aliasName: aliasName, range: castRange))
	end 'emitCastCheckIfNamed'

	// Parse the type appearing after `as`. Accepts the bare primitive
	// keywords (`int`, `float`, `bool`) and registered typealias
	// identifiers — the former resolve to MaxonType primitives, the latter
	// stay as MaxonType.named so the typealias registry drives lowering.
	function parseCastTargetType() returns MaxonType throws ParserError
		let typeToken = try consume()
		if typeToken.kind == TokenKind.int 'isInt'
			return MaxonType.integer
		end 'isInt'
		if typeToken.kind == TokenKind.float 'isFloat'
			return MaxonType.float
		end 'isFloat'
		if typeToken.kind == TokenKind.bool 'isBool'
			return MaxonType.boolean
		end 'isBool'
		if typeToken.kind == TokenKind.identifier 'isIdent'
			// E3062: `expr as IntArray` is a use of `IntArray`.
			usedTypeAliases.insert(element: typeToken.value)
			return internMaxonType(project, name: typeToken.value)
		end 'isIdent'
		reportCompileError(project, code: ErrorCode.parserExpectedToken, message: "Expected type name after 'as'", line: typeToken.line, column: typeToken.column, filePath: filePath)
		// Error-recovery placeholder: callers continue parsing so a single bad
		// cast doesn't cascade. `unresolved` propagates as an explicit "no
		// concrete type known" through TypeResolution rather than mistyping
		// the cast's output as an int.
		return MaxonType.unresolved
	end 'parseCastTargetType'

	// --- Postfix expression chain ---

	// Translate a member-access RHS token into a field name. Identifier tokens
	// pass through verbatim; integer-literal tokens become tuple positional
	// names `_0`/`_1`/... matching the `__TupleN` struct shape that
	// parseParenExpr emits for `(e0, e1, ...)` literals.
	function computeFieldNameForMemberToken(token Token) returns String
		if token.kind == TokenKind.intLiteral 'isTuple'
			return "_{token.value}"
		end 'isTuple'
		return token.value
	end 'computeFieldNameForMemberToken'

	// Phase 15e: parser-time test for the "can intern a specialised
	// `genericInstance(__TupleN, args)` right now" case. Only primitive arms
	// and `named` MaxonTypes qualify — those are pinned at parse time without
	// further substitution. typeParameter/unresolved/genericInstance/function
	// /interface arms are left to TypeResolution's `refineTupleStructAlloc`
	// post-pass.
	function tupleElemTypesAllConcreteAtParse(elemTypes MaxonTypeArray) returns bool
		for i in 0 upto elemTypes.count() 'each'
			let t = try elemTypes.get(i) otherwise return false
			let ok = match t 'check'
				boolean to string gives true
				named gives true
				function gives false
				unresolved gives false
				typeParameter gives false
				genericInstance gives false
				interface gives false
				constInt gives false
			end 'check'
			if not ok 'reject'
				return false
			end 'reject'
		end 'each'
		return true
	end 'tupleElemTypesAllConcreteAtParse'

	// Chain continuation is purely token-driven: as long as the next token is
	// `.`, we emit the next chain segment without consulting the receiver's
	// struct type. Lowering performs the receiver-type lookup when it sees
	// the resulting fieldLoad / methodCall ops.
	//
	// Step 6b.6 TODO (deferred): the bootstrap's `ValidateThrowingBuiltinCallContext`
	// rejects calls like `mm.set(0, value: 42)` that are NOT wrapped in a
	// `try ... otherwise` when the resolved callee is one of the throwing
	// `__ManagedMemory.*` builtins (`setLength`, `get`, `set`, `remove`,
	// `grow`, `shiftRight`, `shiftLeft`, `byteAt`, `setByte`, `slice`, plus
	// the static `create`). The self-hosted parser cannot mirror that check
	// here cleanly because:
	//   1. Receiver-type discrimination requires resolved types — at parse
	//      time the receiver is `MaxonType.unresolved`, so we can't tell
	//      `mm.set(...)` (where `mm: __ManagedMemory`) from
	//      `widget.set(...)` (where `widget` happens to share the method
	//      name) without a post-parse pass.
	//   2. Threading an `inTry` flag through every nested-call parse site
	//      (parseExpression / parseUnary / parsePrimary / parseTryExpression
	//      / parseTryFallback) requires save/restore pairs at every recursion
	//      boundary; getting it wrong silently weakens the diagnostic.
	// The post-parse home for this check is TypeResolution (where receiver
	// types are resolved and call ops sit in a flat module-level walk). For
	// now, malformed user code (forgetting `try`) lowers to a regular
	// methodCall; the runtime intrinsic still sets the error flag, so the
	// failure surfaces — just without the front-end E2052 message. Step 6b.7
	// tests wrap every call in `try ... otherwise`, so this gap doesn't
	// affect the green-test path.
	function parsePostfix(block IrBlock, expr ExprResult) returns ExprResult throws ParserError
		var result = expr

		while at(TokenKind.dot) 'postfixLoop'
			try eat(TokenKind.dot)
			// Phase 15e: `t.0` / `t.1` / ... is positional tuple-field syntax
			// sugar; the synthetic `__TupleN` struct names its fields `_0`, `_1`
			// (see parseParenExpr's tuple-literal lowering), so rewrite the
			// integer-literal field name to `_<N>` here and continue as a
			// normal field access.
			// Member-name position after `.` accepts plain identifiers,
			// integer literals (`t.0` tuple-positional syntax), and
			// identifier-like keywords (e.g. `String.from(...)`, `.to(...)`)
			// so a contextual-keyword spelling can still serve as a method
			// or field name. Mirrors the C# bootstrap's IsIdentifierLikeToken
			// gate at the same call site (maxon-sharp Parser.cs:19016).
			if not tokenIsIdentifierLike(cursor.current()) and not at(TokenKind.intLiteral) 'noMember'
				reportTokenMismatch(cursor.current(), expectedDisplay: "identifier")
				synchronize()
				return result
			end 'noMember'
			let memberToken = try consume()
			let memberName = computeFieldNameForMemberToken(memberToken)
			let memberNameBytes = memberName.toByteArray()

			// Materialize a stringConst receiver before referencing it — the
			// fast-path stringConst ExprResult carries a synth name with no
			// backing op (parseStringLiteral defers emission), so the bare
			// `exprName` would point at an unbound name. The methodCall arm
			// of parsePostfix is the first site that needs the receiver's SSA
			// name (call-arg sites all use `materializeStringConstIfNeeded`
			// in parseCallArgsRaw; field access has its own primitive-receiver
			// guard).
			result = materializeStringConstIfNeeded(block, expr: result, range: SourceRange.ofToken(memberToken))
			let receiverName = exprName(result)

			if accept(TokenKind.leftParen) 'isMethodCall'
				// Method calls defer the named-arg-required check (E3005) to
				// TypeResolution because at parse time we cannot tell a
				// builtin like `mm.set(idx, val)` (where `mm: __ManagedMemory`)
				// from a user-defined `widget.set(idx, val)` without resolving
				// the receiver type. `validateCallArgLabels` re-applies the
				// rule with receiver-type awareness.
				let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
				let rparenToken = previousToken()
				let methodResultName = freshSynthName()
				// Emit into `currentBlock` — argument parsing may have moved
				// control flow (e.g. a nested `try EXPR otherwise FB`), so the
				// methodCall must live where its args' defining ops dominate.
				module.appendOp(currentBlock, op: MaxonOp.methodCall(methodResultName, receiver: receiverName, methodName: memberNameBytes, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(memberToken, last: rparenToken)))
				// Method-call result type is filled in by TypeResolution from
				// the resolved callee signature — the parser doesn't peek
				// into `project.funcReturnTypes`.
				result = ExprResult.direct(methodResultName, valueType: MaxonType.unresolved)
				continue
			end 'isMethodCall'

			// Field access on a primitive value (e.g. `(5).a`) is statically
			// invalid — primitives have no fields. Report E4006 and bail out
			// of the chain so any trailing `.` in a long chain doesn't
			// cascade into a follow-up "Expected identifier" diagnostic.
			// Mirrors the C# bootstrap's E4006 check at the same parse site.
			if maxonTypeIsPrimitive(exprType(result)) 'primitiveReceiver'
				reportCompileError(project, code: ErrorCode.irInvalidFieldAccess, message: "Cannot access field on non-struct value", line: memberToken.line, column: memberToken.column, filePath: filePath)
				skipToNextLine()
				return result
			end 'primitiveReceiver'

			let fieldLoadName = freshSynthName()
			module.appendOp(block, op: MaxonOp.fieldLoad(fieldLoadName, receiver: receiverName, fieldName: memberNameBytes, range: SourceRange.ofToken(memberToken)))
			// Field-load result type is filled in by TypeResolution from
			// the receiver's resolved struct-field layout — the parser
			// doesn't peek into `project.structTypes`.
			result = ExprResult.direct(fieldLoadName, valueType: MaxonType.unresolved)
		end 'postfixLoop'

		return result
	end 'parsePostfix'

	// --- Primary expression parsing ---

	function parseIdentifierExpr(block IrBlock) returns ExprResult throws ParserError
		let token = try consume()
		// Cursor now sits on whatever follows the identifier. at(K) below
		// inspects that follower; tolerates EOF (falls through to the bare-
		// variable-read tail when nothing follows).

		// `TypeName from "literal"` / `TypeName from 'c'` / `TypeName from [..]`
		// — initialize a type conforming to InitableFromStringLiteral /
		// InitableFromCharLiteral / InitableFromArrayLiteral via its
		// `init(value)` static method. Lowered to a qualified call on
		// `TypeName.init`; TypeResolution validates the conformance against
		// the resolved struct.
		if at(TokenKind.from) 'maybeFromLiteral'
			let nextTok = try cursor.peek(1) otherwise Token.eof()
			if nextTok.kind == TokenKind.stringLiteral or nextTok.kind == TokenKind.charLiteral or nextTok.kind == TokenKind.leftBracket 'isFromLiteral'
				return try parseFromLiteralCall(block, typeToken: token)
			end 'isFromLiteral'
		end 'maybeFromLiteral'

		// Ident.Ident(args) — disambiguated using local-scope membership only:
		//   - `c.method(...)` where `c` is a known local var: emit methodCall
		//     and let lowering resolve `{receiverType}.method` from the value-
		//     type map.
		//   - `Type.method(...)` otherwise: emit a qualified call; lowering
		//     uses the callee verbatim.
		// We deliberately do NOT consult `project.structTypes` here — the
		// scope check is purely function-local and doesn't reach into
		// cross-declaration registries.
		if at(TokenKind.dot) 'maybeDotCall'
			let memberToken = try cursor.peek(1) otherwise Token.eof()
			let afterMember = try cursor.peek(2) otherwise Token.eof()
			// Accept identifier-like keywords (`from`, `to`, `with`, …) as
			// member names alongside plain identifiers so type-qualified
			// static calls like `FilePath.from(...)` route through the
			// dedicated static-call path instead of being misparsed as a
			// method call on an `unresolvedRead`'d "FilePath" boolean.
			// Mirrors the same identifier-like gate in parsePostfix.
			if tokenIsIdentifierLike(memberToken) and afterMember.kind == TokenKind.leftParen 'isDotCall'
				let memberNameBytes = memberToken.value.toByteArray()
				// `globalVar.method(...)` where `globalVar` is a registered
				// top-level mutable var (`var x = ...` / `let xs = [...]`):
				// emit the global load + methodCall pair. Without this branch
				// the catch-all qualified-static-call arm below would treat
				// the prefix as a type name and produce an unresolvable
				// `globalVar.method` callee at lowering. Mirrors the
				// in-function `c.method(...)` path on a local receiver.
				if not scope.contains(token.value) and project.topLevelVars.contains(token.value) 'isMethodOnGlobal'
					let receiverLoadName = freshSynthName()
					module.appendOp(block, op: MaxonOp.unresolvedRead(receiverLoadName, name: token.value, range: SourceRange.ofToken(token)))
					try eat(TokenKind.dot)
					_ = try consume()
					try eat(TokenKind.leftParen)
					let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
					let rparenToken = previousToken()
					let methodResultName = freshSynthName()
					// Emit into `currentBlock` — see emitCallAndResult for rationale.
					module.appendOp(currentBlock, op: MaxonOp.methodCall(methodResultName, receiver: receiverLoadName, methodName: memberNameBytes, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(token, last: rparenToken)))
					return ExprResult.direct(methodResultName, valueType: MaxonType.unresolved)
				end 'isMethodOnGlobal'
				if scope.contains(token.value) 'isMethodOnLocal'
					// Method call on a local-scope value receiver. The
					// receiver may be a true local (var/let), a parameter, or
					// a self-field alias inside an instance method — branch on
					// `isSelfField` so the receiver load op carries the type
					// from the right source.
					let receiverVarType = scope.getType(token.value)
					let receiverLoadName = freshSynthName()
					if scope.isSelfField(token.value) 'selfFieldReceiver'
						module.appendOp(block, op: MaxonOp.selfFieldLoad(receiverLoadName, fieldName: token.value.toByteArray(), range: SourceRange.ofToken(token)))
					end 'selfFieldReceiver' else 'localReceiver'
						let receiverSlot = lookupVariable(token.value, token: token)
						module.appendOp(block, op: MaxonOp.varLoad(receiverLoadName, slotId: receiverSlot, slotType: receiverVarType, range: SourceRange.ofToken(token)))
					end 'localReceiver'
					try eat(TokenKind.dot)
					_ = try consume()
					try eat(TokenKind.leftParen)
					// methodCall on a local receiver — defer the named-arg-required
					// check (E3005) to TypeResolution. See the parsePostfix
					// methodCall site above for rationale.
					let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
					let rparenToken = previousToken()
					let methodResultName = freshSynthName()
					// Emit into `currentBlock` — see emitCallAndResult for rationale.
					module.appendOp(currentBlock, op: MaxonOp.methodCall(methodResultName, receiver: receiverLoadName, methodName: memberNameBytes, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(token, last: rparenToken)))
					// methodCall result type is filled in by TypeResolution
					// from `funcReturnTypes` once registries are populated.
					return ExprResult.direct(methodResultName, valueType: MaxonType.unresolved)
				end 'isMethodOnLocal'
				// Qualified static call: Type.method(...) — lowering resolves verbatim.
				// Defer the named-arg-required check (E3005) to TypeResolution
				// because at parse time we cannot tell a builtin like
				// `__ManagedMemory.create(...)` (or its typealias `ByteMemory.create(...)`)
				// from a user-defined `Widget.create(...)` without resolving
				// the qualifier. `validateCallArgLabels` re-applies the rule
				// with type-awareness.
				// E3062 use-tracking: the qualifier in `Foo.method(...)` is the
				// most common explicit use of an `Array with X` typealias
				// (`IntArray.create()`).
				usedTypeAliases.insert(element: token.value)
				// Phase 9 Stage 5: redirect `<EnumName>.fromRawValue(...)` /
				// `<EnumName>.fromName(...)` to the per-enum synthesized lookup
				// helpers. The synthesis runs during `parseEnumDecl` /
				// `registerUnionCasesCompanion`, so any reachable enum or
				// `.unionCases` companion already has these helpers registered
				// in `funcSignatures` by the time a call site is parsed —
				// preserving forward-reference resolution (cross-file calls hit
				// the helpers once their declaration file finishes parsing).
				// Unions themselves are excluded from `.fromRawValue` per the
				// spec (E3034 surfaces in TypeResolution); `.fromName` on
				// associated-value unions is not yet supported and falls
				// through to the regular dispatch, where it will fail to
				// resolve until Stage 5's union-`fromName` work lands.
				var calleeName = "{token.value}.{memberToken.value}"
				let memberStr = memberToken.value
				let prefixIsEnumName = project.unresolvedEnums.contains(token.value) or project.enumTypes.contains(token.value)
				if prefixIsEnumName and memberStr == "fromRawValue" 'redirectFromRawValue'
					if enumIsStructBacked(token.value) 'isStructBacked'
						// Struct-backed enums can't reconstruct their raw
						// value from an integer (`= StructType{...}`); per
						// `enum-struct-backing.md`'s
						// `error.struct-backing-fromRawValue` test we
						// surface E3034 at the call site rather than letting
						// the call fall through to an unresolved callee.
						reportCompileError(project, code: ErrorCode.semanticEnumUnknownCase, message: "unknown enum case: 'fromRawValue'", line: memberToken.line, column: memberToken.column, filePath: filePath)
					end 'isStructBacked'
					if not enumIsAssociatedValueUnion(token.value) and not enumIsStructBacked(token.value) 'notAssocUnion'
						calleeName = enumFromRawValueSymbolName(token.value)
					end 'notAssocUnion'
				end 'redirectFromRawValue'
				if prefixIsEnumName and memberStr == "fromName" 'redirectFromName'
					if not enumIsAssociatedValueUnion(token.value) 'notAssocUnionFn'
						calleeName = enumFromNameSymbolName(token.value)
					end 'notAssocUnionFn'
				end 'redirectFromName'
				try eat(TokenKind.dot)
				_ = try consume()
				try eat(TokenKind.leftParen)
				let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
				let rparenToken = previousToken()
				return emitCallAndResult(calleeName: calleeName, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.between(token, last: rparenToken))
			end 'isDotCall'
		end 'maybeDotCall'

		// Sized type bound: `u16.max`, `i32.min`, etc. as a standalone
		// expression. Must run before the qualified-read path below — that
		// path emits an `unresolvedRead("u16.max")` which TypeResolution
		// can't satisfy.
		if at(TokenKind.dot) and isSizedTypeName(token.value) 'maybeTypeBoundExpr'
			let fieldToken = try cursor.peek(1) otherwise Token.eof()
			if fieldToken.kind == TokenKind.identifier and (fieldToken.value == "min" or fieldToken.value == "max") 'isTypeBoundExpr'
				let bound = resolveTypeBound(token.value, field: fieldToken.value)
				try eat(TokenKind.dot)
				try eat(TokenKind.identifier)
				let boundName = emitLiteral(block, value: bound, valueType: MaxonType.integer, range: SourceRange.between(token, last: fieldToken))
				return ExprResult.direct(boundName, valueType: MaxonType.integer)
			end 'isTypeBoundExpr'
		end 'maybeTypeBoundExpr'

		// Phase 9 Stage 5 (struct-backing): `local.rawValue.field[.field]+`
		// where `local` was bound via `let local = EnumName.case` and the
		// enum case carries a struct-backing literal — fold the access
		// chain at parse time. `letStructBackedEnumCases` was populated by
		// `parseVarDecl`'s pre-expression peek. The expected access shape
		// is `local.rawValue.<field>...`; we only fold when `.rawValue`
		// follows the local (so `.ordinal` / `.name` still flow through
		// the enum-builtin-accessor path), AND when at least one chained
		// `.field` follows `.rawValue` (so a bare `.rawValue` access still
		// flows through the standard fieldLoad path that aliases the
		// integer-typed value).
		if at(TokenKind.dot) and scope.contains(token.value) 'maybeLocalStructBacking'
			let nextMember = try cursor.peek(1) otherwise Token.eof()
			let afterMember = try cursor.peek(2) otherwise Token.eof()
			let afterMember2 = try cursor.peek(3) otherwise Token.eof()
			let isRawValueChain = nextMember.kind == TokenKind.identifier and nextMember.value == "rawValue" and afterMember.kind == TokenKind.dot and afterMember2.kind == TokenKind.identifier
			if isRawValueChain 'isChain'
				if let qualifiedCase = try letStructBackedEnumCases.get(token.value) 'haveCaseAlias'
					let dotIdx = lastIndexOfDotByte(qualifiedCase.toByteArray())
					if dotIdx < qualifiedCase.toByteArray().count() 'haveDot'
						let bytes = qualifiedCase.toByteArray()
						let enumNameStr = byteSliceToString(bytes, startIndex: 0, endIndex: dotIdx)
						let caseNameStr = byteSliceToString(bytes, startIndex: dotIdx + 1, endIndex: bytes.count())
						// Mark `op` as referenced so E3012 (unused variable)
						// doesn't trip on `let op = TestOp.mul; return op.rawValue.value`.
						referencedVars.insert(element: token.value)
						let backingExprId = try lookupCaseStructBackingExprId(enumName: enumNameStr, caseName: caseNameStr) otherwise panic("parseIdentifierExpr: caseHasStructBacking('{enumNameStr}.{caseNameStr}') guarded the call but lookup failed")
						let foldResult = try parseStructBackingAccessChain(rootExprId: backingExprId, prefixToken: token, memberToken: token, block: block) otherwise return ExprResult.direct(freshSynthName(), valueType: MaxonType.unresolved)
						return foldResult
					end 'haveDot'
				end 'haveCaseAlias'
			end 'isChain'
		end 'maybeLocalStructBacking'

		// Closure capture of an outer-scope local that's the receiver of a
		// postfix chain (`outer.field`, `outer.method(...)`). Without this
		// branch, the next block (`maybeQualifiedRead`) would treat `outer`
		// as a type qualifier and emit `unresolvedRead("outer.field")`
		// because the lifted body's fresh scope doesn't contain `outer`.
		// Emitting the env-load now lets parsePostfix handle the trailing
		// chain on the captured value, identical to a plain local receiver.
		if inClosure and at(TokenKind.dot) and not scope.contains(token.value) and closureOuterScope.contains(token.value) and not closureOuterScope.isSelfField(token.value) 'captureOuterReceiver'
			let captureType = closureOuterScope.getType(token.value)
			let captureName = emitClosureCapture(block, name: token.value, captureType: captureType, range: SourceRange.ofToken(token))
			return ExprResult.direct(captureName, valueType: captureType)
		end 'captureOuterReceiver'

		// Qualified static-field read: TypeName.field, where the qualified name
		// names a registered static var (.data slot) or static let
		// (compile-time integer constant). Methods take precedence above;
		// this branch fires when the next token after `.field` is NOT `(`.
		// The parser doesn't peek into `topLevelVars` / `topLevelConstants`;
		// it emits a single `unresolvedRead` op for the qualified name and
		// lets TypeResolution rewrite it to `globalLoad` (var) or `literal`
		// (let — folded to its concrete ConstantValue) once project
		// registries are fully populated. Local-scoped receivers
		// (`localVar.field`) must NOT take this path — they go through the
		// field-load chain in the postfix walk. The
		// `not scope.contains(token.value)` guard keeps local-scope reads
		// on their normal path.
		if at(TokenKind.dot) and not scope.contains(token.value) 'maybeQualifiedRead'
			let memberToken = try cursor.peek(1) otherwise Token.eof()
			let afterMember = try cursor.peek(2) otherwise Token.eof()
			// Member name is normally an identifier, but enum-case spellings
			// permit keyword tokens (`function`, `return`, `end`, `if`, …).
			// When the prefix is a registered enum, accept any non-`(`-followed
			// token with a non-empty value as the member name.
			let prefixIsEnum = project.unresolvedEnums.contains(token.value) or project.enumTypes.contains(token.value)
			let memberIsIdent = memberToken.kind == TokenKind.identifier
			let memberIsEnumCaseKeyword = prefixIsEnum and not memberToken.value.isEmpty()
			// Phase 9 Stage 1: `EnumName.allCases` / `EnumName.allCaseNames`
			// expand to inline array literals before the catch-all qualified-
			// read path tries (and fails) to look the dotted name up as a
			// top-level constant. Mirrors the C# bootstrap dispatch at
			// 2-Parser.cs:14113-14128.
			if prefixIsEnum and memberIsIdent and afterMember.kind != TokenKind.leftParen 'maybeEnumStatic'
				if memberToken.value == "allCases" 'isAllCases'
					usedTypeAliases.insert(element: token.value)
					try eat(TokenKind.dot)
					_ = try consume()
					let accessRange = SourceRange.between(token, last: memberToken)
					return try emitEnumAllCases(token.value, accessRange: accessRange)
				end 'isAllCases'
				if memberToken.value == "allCaseNames" 'isAllCaseNames'
					usedTypeAliases.insert(element: token.value)
					try eat(TokenKind.dot)
					_ = try consume()
					let accessRange = SourceRange.between(token, last: memberToken)
					return try emitEnumAllCaseNames(token.value, accessRange: accessRange)
				end 'isAllCaseNames'
				// Phase 9 Stage 4: `UnionName.unionCases.<member>` re-dispatches
				// against the synthesized companion enum named
				// `UnionName.unionCases`. The companion is registered at
				// parse time of the union itself (see `parseUnionDecl`), so
				// the lookup succeeds before TypeResolution runs.
				//   `.allCases` / `.allCaseNames` reuse the Stage 1 emitters
				//   `.<caseName>` resolves to the case's `TopLevelConstant`
				if memberToken.value == "unionCases" and afterMember.kind == TokenKind.dot 'isUnionCases'
					let companionName = "{token.value}.unionCases"
					if project.unresolvedEnums.contains(companionName) or project.enumTypes.contains(companionName) 'companionExists'
						let innerToken = try cursor.peek(3) otherwise Token.eof()
						let afterInner = try cursor.peek(4) otherwise Token.eof()
						if not innerToken.value.isEmpty() 'haveInner'
							// Phase 9 Stage 5: `Shape.unionCases.fromRawValue(...)`
							// / `Shape.unionCases.fromName(...)` — redirect to the
							// per-companion synthesized lookup helpers. The
							// companion is a bare enum so the same helper
							// machinery used for `Color.fromRawValue` applies.
							// Unknown methods on the companion fall through to
							// the regular qualified-callee path, which surfaces
							// the unresolved-callee diagnostic at TR time.
							if afterInner.kind == TokenKind.leftParen 'isCompanionCall'
								usedTypeAliases.insert(element: token.value)
								try eat(TokenKind.dot)
								_ = try consume()
								try eat(TokenKind.dot)
								_ = try consume()
								try eat(TokenKind.leftParen)
								let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
								let rparenToken = previousToken()
								var calleeStr = "{companionName}.{innerToken.value}"
								if innerToken.value == "fromRawValue" 'redirectCompanionFRV'
									calleeStr = enumFromRawValueSymbolName(companionName)
								end 'redirectCompanionFRV'
								if innerToken.value == "fromName" 'redirectCompanionFN'
									calleeStr = enumFromNameSymbolName(companionName)
								end 'redirectCompanionFN'
								let calleeName = project.calleeNames.intern(calleeStr)
								let callResultName = freshSynthName()
								// Emit into `currentBlock` — see emitCallAndResult for rationale.
								module.appendOp(currentBlock, op: MaxonOp.call(callResultName, callee: calleeName, callContext: CallContext.qualified, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(token, last: rparenToken)))
								return ExprResult.direct(callResultName, valueType: MaxonType.unresolved)
							end 'isCompanionCall'
							// Static member: allCases / allCaseNames / caseName
							if innerToken.value == "allCases" 'companionAllCases'
								usedTypeAliases.insert(element: token.value)
								try eat(TokenKind.dot)
								_ = try consume()
								try eat(TokenKind.dot)
								_ = try consume()
								let accessRange = SourceRange.between(token, last: innerToken)
								return try emitEnumAllCases(companionName, accessRange: accessRange)
							end 'companionAllCases'
							if innerToken.value == "allCaseNames" 'companionAllCaseNames'
								usedTypeAliases.insert(element: token.value)
								try eat(TokenKind.dot)
								_ = try consume()
								try eat(TokenKind.dot)
								_ = try consume()
								let accessRange = SourceRange.between(token, last: innerToken)
								return try emitEnumAllCaseNames(companionName, accessRange: accessRange)
							end 'companionAllCaseNames'
							let companionCaseQualified = "{companionName}.{innerToken.value}"
							if project.topLevelConstants.contains(companionCaseQualified) 'companionCaseHit'
								usedTypeAliases.insert(element: token.value)
								try eat(TokenKind.dot)
								_ = try consume()
								try eat(TokenKind.dot)
								_ = try consume()
								let resultName = freshSynthName()
								module.appendOp(block, op: MaxonOp.unresolvedRead(resultName, name: companionCaseQualified, range: SourceRange.between(token, last: innerToken)))
								return ExprResult.direct(resultName, valueType: MaxonType.unresolved)
							end 'companionCaseHit'
						end 'haveInner'
					end 'companionExists'
				end 'isUnionCases'
			end 'maybeEnumStatic'
			// Phase 9 Stage 5 (struct-backing): `EnumName.caseName.field[.field]+`
			// where `EnumName.caseName` carries a `= StructType{...}` /
			// `= StructType.create(...)` backing literal — fold the whole
			// chain to the leaf field's constant at parse time. The runtime
			// never observes the struct value; access is pure compile-time
			// metadata. Bare `EnumName.caseName` (no follow-up `.`) falls
			// through to the existing isFieldRead path so the case literal
			// still routes through `topLevelConstants`. Union-case names of
			// payload-bearing variants are skipped — they're constructor
			// dispatchers, not constant cases.
			if prefixIsEnum and (memberIsIdent or memberIsEnumCaseKeyword) and afterMember.kind == TokenKind.dot 'maybeStructBacking'
				if caseHasStructBacking(enumName: token.value, caseName: memberToken.value) 'haveBacking'
					let backingExprId = try lookupCaseStructBackingExprId(enumName: token.value, caseName: memberToken.value) otherwise panic("parseIdentifierExpr: caseHasStructBacking('{token.value}.{memberToken.value}') guarded the call but lookup failed")
					let foldResult = try parseStructBackingAccessChain(rootExprId: backingExprId, prefixToken: token, memberToken: memberToken, block: block) otherwise return ExprResult.direct(freshSynthName(), valueType: MaxonType.unresolved)
					return foldResult
				end 'haveBacking'
			end 'maybeStructBacking'
			if (memberIsIdent or memberIsEnumCaseKeyword) and afterMember.kind != TokenKind.leftParen 'isFieldRead'
				// E3062 use-tracking: `Foo.field` and `Foo.case` count as
				// explicit references to `Foo`.
				usedTypeAliases.insert(element: token.value)
				let qualifiedName = "{token.value}.{memberToken.value}"
				try eat(TokenKind.dot)
				_ = try consume()
				let resultName = freshSynthName()
				module.appendOp(block, op: MaxonOp.unresolvedRead(resultName, name: qualifiedName, range: SourceRange.between(token, last: memberToken)))
				// Producer type is filled in by TypeResolution when it
				// rewrites the unresolvedRead — see `enumLiteralType`.
				return ExprResult.direct(resultName, valueType: MaxonType.unresolved)
			end 'isFieldRead'
		end 'maybeQualifiedRead'

		if accept(TokenKind.leftParen) 'isCall'
			// Stage E (closures): if `bareName` is bound to a function-typed
			// local, route through `indirectCall` so lowering forwards the
			// matching `__env_<bareName>` slot. Otherwise emit a regular
			// name-symbolic call: CallContext tells lowering how to qualify
			// (sibling-method probe inside a type body, then free resolution
			// via currentNamespace + stdlib fallback). Lowering also detects
			// __self instance-method calls and prepends the receiver.
			let bareCallee = token.value
			if scope.contains(bareCallee) and isFunctionMaxonType(scope.getType(bareCallee)) 'isIndirect'
				let calleeSlot = lookupVariable(bareCallee, token: token)
				let calleeType = scope.getType(bareCallee)
				let calleeLoadName = freshSynthName()
				module.appendOp(block, op: MaxonOp.varLoad(calleeLoadName, slotId: calleeSlot, slotType: calleeType, range: SourceRange.ofToken(token)))
				// Function-typed locals carry no source-level param names —
				// the function type registry stores positional types only —
				// so the named-arg-required check (E3005) doesn't apply.
				let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
				let rparenToken = previousToken()
				let fnTypeId = functionMaxonTypeId(calleeType)
				let resultName = freshSynthName()
				let returnType = functionMaxonReturnType(project, t: calleeType)
				// Emit into `currentBlock` — see emitCallAndResult for rationale.
				module.appendOp(currentBlock, op: MaxonOp.indirectCall(resultName, callee: calleeLoadName, fnTypeId: fnTypeId, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: SourceRange.between(token, last: rparenToken)))
				return ExprResult.direct(resultName, valueType: maxonReturnTypeValueOrUnresolved(returnType))
			end 'isIndirect'
			// Math intrinsics (`min(a, b)`, `max(a, b)`, plus the unary ones)
			// accept positional args by design — they're built into the
			// compiler and have no source-level param names that could anchor a
			// label. Suppress the parse-time E3005 named-arg check for them.
			let allowPositional = isMathIntrinsic(bareCallee)
			let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: not allowPositional)
			let rparenToken = previousToken()
			var ctx = CallContext.free
			if not currentTypeName.isEmpty() 'inMethod'
				ctx = CallContext.sibling(currentTypeName)
			end 'inMethod'
			return emitCallAndResult(calleeName: bareCallee, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: ctx, range: SourceRange.between(token, last: rparenToken))
		end 'isCall'

		// Struct construction: TypeName{field: value, ...}
		// Ranged-primitive construction (`Foo{42}`) was removed in favor of
		// `42 as Foo`, so `Foo{...}` here unambiguously means struct literal.
		// The parser doesn't peek into `structTypes`; the downstream lowering
		// reports an error if the name doesn't resolve to a struct.
		if at(TokenKind.leftBrace) 'isStructLiteral'
			// E3062: `Foo{...}` is a literal use of `Foo`.
			usedTypeAliases.insert(element: token.value)
			return try parseStructLiteral(block, typeName: token.value, typeToken: token, typeNameConsumed: true)
		end 'isStructLiteral'

		// Stage E (closures): inside a closure body, an unbound name may name
		// an outer-scope local that the lifted function captures by reference.
		// Check the saved enclosing scope before falling through to the
		// global/top-level resolver; on a hit, route to closureEnvLoad and
		// register the capture. The closure cannot capture self-field aliases
		// (their backing __self is captured separately and field access goes
		// through the post-loaded receiver) so we exclude `isSelfField` here.
		if inClosure and not scope.contains(token.value) and closureOuterScope.contains(token.value) and not closureOuterScope.isSelfField(token.value) 'captureOuter'
			let captureType = closureOuterScope.getType(token.value)
			let captureName = emitClosureCapture(block, name: token.value, captureType: captureType, range: SourceRange.ofToken(token))
			return ExprResult.direct(captureName, valueType: captureType)
		end 'captureOuter'

		// Bare function reference: `let f = double`, `apply(triple, ...)`.
		// When the unbound name resolves to a known free function (after the
		// same context-aware qualification a bare call would do), emit a
		// `functionRef` op carrying the resolved fnTypeId so the surrounding
		// context (varDecl, arg position) sees a function-typed value
		// instead of an `unresolvedRead`. Sibling instance methods aren't
		// included here — they need an implicit `__self` receiver that the
		// reference syntax can't provide, and the parser leaves them as
		// `unresolvedRead` to surface as a clean E2004.
		if not scope.contains(token.value) 'maybeFunctionRef'
			var fnRefCtx = CallContext.free
			if not currentTypeName.isEmpty() 'inMethodFnRef'
				fnRefCtx = CallContext.sibling(currentTypeName)
			end 'inMethodFnRef'
			let qualified = qualifyCalleeForContext(project, bare: token.value, callContext: fnRefCtx, currentNamespace: namespace, readerFilePath: filePath)
			if project.funcSignatures.contains(qualified) and project.funcReturnTypes.contains(qualified) 'isFnRef'
				let sig = try project.funcSignatures.get(qualified) otherwise panic("parseIdentifierExpr.maybeFunctionRef: funcSignatures.contains(true) but get() failed for '{qualified}'")
				let returnType = try project.funcReturnTypes.get(qualified) otherwise panic("parseIdentifierExpr.maybeFunctionRef: funcReturnTypes.contains(true) but get() failed for '{qualified}'")
				// Instance methods take an implicit `__self` as their first
				// parameter; referencing them by bare name has no receiver
				// to thread through. Skip these and let `unresolvedRead`
				// surface the expected E2004 below.
				var isInstanceMethod = false
				if sig.paramNames.count() > 0 'hasParams'
					let firstParam = try sig.paramNames.get(0) otherwise panic("parseIdentifierExpr.maybeFunctionRef: paramNames.get(0) failed after count guard")
					if firstParam == "__self" 'isSelf'
						isInstanceMethod = true
					end 'isSelf'
				end 'hasParams'
				if not isInstanceMethod 'freeFunction'
					let fnTypeId = internFunctionType(project, paramTypes: sig.paramTypes, returnType: returnType)
					let resultName = freshSynthName()
					module.appendOp(block, op: MaxonOp.functionRef(resultName, funcName: qualified, fnTypeId: fnTypeId, range: SourceRange.ofToken(token)))
					return ExprResult.direct(resultName, valueType: MaxonType.function(fnTypeId))
				end 'freeFunction'
			end 'isFnRef'
		end 'maybeFunctionRef'

		// Bare identifier that isn't bound as a local: defer name resolution
		// to TypeResolution. The `unresolvedRead` op is rewritten to
		// `globalLoad` (for top-level `var`s), `literal` (for top-level int
		// constants), or substituted with the interned StringId of a
		// top-level string constant via `unresolvedRead`'s rewrite path —
		// and TypeResolution handles the print/cmp consumers downstream by
		// pattern-matching on the producer. The parser does not peek into
		// `project.topLevelConstants`; the string-const peek that used to
		// live here was a parse-time substitution that depended on
		// same-file ordering of constant declarations, which the post-
		// resolve pass eliminates.
		if not scope.contains(token.value) 'isUnresolvedName'
			let resultName = freshSynthName()
			module.appendOp(block, op: MaxonOp.unresolvedRead(resultName, name: token.value, range: SourceRange.ofToken(token)))
			return ExprResult.direct(resultName, valueType: MaxonType.unresolved)
		end 'isUnresolvedName'

		let slot = lookupVariable(token.value, token: token)
		let name = freshSynthName()
		let varType = scope.getType(token.value)
		let tokRange = SourceRange.ofToken(token)
		if scope.isSelfField(token.value) 'selfFieldRead'
			module.appendOp(block, op: MaxonOp.selfFieldLoad(name, fieldName: token.value.toByteArray(), range: tokRange))
		end 'selfFieldRead' else 'localRead'
			module.appendOp(block, op: MaxonOp.varLoad(name, slotId: slot, slotType: varType, range: tokRange))
		end 'localRead'
		return ExprResult.direct(name, valueType: varType)
	end 'parseIdentifierExpr'

	// `TypeName from <literal>` — initialize a type that conforms to
	// InitableFromStringLiteral or InitableFromCharLiteral by calling its
	// static `init(value)` method. The cursor is AT the `from` keyword on
	// entry; on exit, it sits past the literal token.
	//
	// Lowered as a qualified call to `TypeName.init` with the literal as the
	// single positional argument. The literal is emitted via the existing
	// parseStringLiteral / parseCharLiteralExpr path so escape decoding and
	// interpolation handling stay shared. Conformance / arity checking
	// happens in TypeResolution once the struct's interfaces are resolved.
	function parseFromLiteralCall(block IrBlock, typeToken Token) returns ExprResult throws ParserError
		try eat(TokenKind.from)
		let litToken = cursor.current()

		// `T from [...]` where T conforms to `BuiltinArrayLiteral` (e.g.
		// `Vector from [1,2,3]`): the destination type IS the array-literal
		// wrapper, so we lower directly to `T.init(__mm)` rather than first
		// wrapping the literal in the canonical `Array.init(__mm)` and then
		// trying to call `T.init(Array)` — which would fail at type
		// resolution (param expects `__ManagedMemory with Element`, not
		// `Array with Element`). Mirrors the C# bootstrap's BAL fast path
		// in `ParseFromExpression`. The non-array literal forms (string /
		// char) fall through to the InitableFromXxxLiteral path below.
		if litToken.kind == TokenKind.leftBracket and typeConformsToBuiltinArrayLiteral(typeToken.value) 'isBalArray'
			return try parseBalFromArrayLiteral(block, typeToken: typeToken)
		end 'isBalArray'

		let literalResult = match litToken.kind 'parseLit'
			stringLiteral gives try parseStringLiteral(block)
			charLiteral gives try parseCharLiteralExpr(block)
			leftBracket gives try parseArrayLiteralExpr(block)
			default panic("parseFromLiteralCall: caller proved literal kind, got {litToken.kind.name}")
		end 'parseLit'

		// Force the literal into an emitted op so we can name it as a call
		// argument — stringConst-shaped ExprResults carry a synth name with
		// no backing op until they're materialized.
		let materialized = materializeStringConstIfNeeded(block, expr: literalResult, range: SourceRange.ofToken(litToken))
		let argName = exprName(materialized)
		let argType = exprType(materialized)

		var args = ByteArrayArray.create()
		args.push(argName)
		var argLabels = StringArray.create()
		argLabels.push("")
		var argTypes = MaxonTypeArray.create()
		argTypes.push(argType)
		var argRanges = SourceRangeArray.create()
		argRanges.push(SourceRange.ofToken(litToken))

		usedTypeAliases.insert(element: typeToken.value)
		let calleeName = "{typeToken.value}.init"
		return emitCallAndResult(calleeName: calleeName, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.between(typeToken, last: litToken))
	end 'parseFromLiteralCall'

	// True when `typeName` is a known struct declaring conformance to
	// `BuiltinArrayLiteral`. Reads against `unresolvedStructTypes` so the
	// check fires correctly during the parser's initial sweep (before
	// `resolveAllStructTypes` has drained the staging map). Empty struct
	// entries / unknown names yield false; the caller falls back to the
	// InitableFromArrayLiteral path which will surface a clearer
	// diagnostic if the type doesn't conform to either interface.
	function typeConformsToBuiltinArrayLiteral(typeName String) returns bool
		if let entry = try project.unresolvedStructTypes.get(typeName) 'isUnresolved'
			return structDeclaresBuiltinArrayLiteral(entry)
		end 'isUnresolved'
		// Stdlib-cache restore path: by the time user code is parsed, Vector /
		// Array have moved out of `unresolvedStructTypes` and their
		// conformances are recorded in `project.conformances`.
		return project.conformances.contains(typeName, interfaceName: "BuiltinArrayLiteral")
	end 'typeConformsToBuiltinArrayLiteral'

	// `T from [...]` for `T` conforming to `BuiltinArrayLiteral`: parse
	// the bracketed literal, build the __ManagedMemory backing buffer, and
	// emit `T.init(__mm)` so the call's parameter (declared as
	// `__ManagedMemory with Element`) sees the right shape. The
	// arrayLiteralProducer entry is registered under both names so
	// TypeResolution's `arrayLiteralResultType` lookup recovers
	// `genericInstance(T, [InferredElement])` for the result. Mirrors
	// `emitArrayLiteralResult` but pinned to a user-chosen destination
	// type rather than the canonical BAL discovery.
	function parseBalFromArrayLiteral(block IrBlock, typeToken Token) returns ExprResult throws ParserError
		let bracketToken = cursor.current()
		try eat(TokenKind.leftBracket)
		try skipNewlines()
		var elemNames = ByteArrayArray.create()
		var elemRanges = SourceRangeArray.create()
		if at(TokenKind.rightBracket) 'emptyLit'
			try eat(TokenKind.rightBracket)
		end 'emptyLit' else 'nonEmpty'
			let firstStartPos = cursor.index()
			let firstFirstToken = cursor.current()
			let firstParsed = try parseExpression(block)
			let firstLastToken = previousToken()
			let firstRange = SourceRange.between(firstFirstToken, last: firstLastToken)
			let firstMaterialized = materializeStringConstIfNeeded(block, expr: firstParsed, range: firstRange)
			elemNames.push(exprName(firstMaterialized))
			elemRanges.push(firstRange)
			try parseRemainingArrayElements(block, elemNames: elemNames, elemRanges: elemRanges, firstStartPos: firstStartPos)
			try expect(TokenKind.rightBracket)
		end 'nonEmpty'

		let literalRange = SourceRange.between(bracketToken, last: previousToken())
		let mmName = emitManagedMemoryFromElements(block, elemNames: elemNames, elemRanges: elemRanges, literalRange: literalRange)

		let arrName = freshSynthName()
		var initArgs = ByteArrayArray.create()
		initArgs.push(mmName)
		var initLabels = StringArray.create()
		initLabels.push("")
		var initArgTypes = MaxonTypeArray.create()
		initArgTypes.push(MaxonType.unresolved)
		var initArgRanges = SourceRangeArray.create()
		initArgRanges.push(literalRange)
		let initCallee = "{typeToken.value}.init"
		module.appendOp(currentBlock, op: MaxonOp.call(arrName, callee: project.calleeNames.intern(initCallee), callContext: CallContext.qualified, args: initArgs, argLabels: initLabels, argTypes: initArgTypes, argRanges: initArgRanges, range: literalRange))

		let producer = ArrayLiteralProducer.create(typeToken.value, mmResultName: mmName, initResultName: arrName, elemNames: elemNames, elemRanges: elemRanges, sourceFilePath: filePath)
		try project.arrayLiteralProducers.insert(arrayLiteralProducerKey(funcName: currentFunc.name, valueName: mmName), value: producer) otherwise ignore
		try project.arrayLiteralProducers.insert(arrayLiteralProducerKey(funcName: currentFunc.name, valueName: arrName), value: producer) otherwise ignore
		usedTypeAliases.insert(element: typeToken.value)

		return ExprResult.direct(arrName, valueType: MaxonType.unresolved)
	end 'parseBalFromArrayLiteral'

	// Parse call arguments, validating named args for 2nd+ arguments.
	// When calleeName resolves to a registered function signature, the first
	// argument may be positional (mapped to paramStartIndex) and subsequent
	// arguments are reordered by name so IR parameter order matches the
	// callee's declaration. Missing arguments with integer defaults are filled
	// in automatically. When no signature is registered (stdlib calls before
	// cache warm-up, interface calls, etc.) the legacy positional-order path
	// is used.
	// Parser-only path: walk the argument list and collect parallel arrays
	// of value names + source labels. No signature lookup, no slot fill, no
	// default insertion — those happen in LowerMaxonToStd's slotArgsForCall.
	// Each arg's label is "" when the arg was positional, or the source-level
	// `name:` label otherwise. Replaces the parser-time signature-driven
	// slotting that lived in parseCallArgsWithSignature.
	// entry: cursor AT first-arg-first-token OR AT `)` if no args.
	// exit:  cursor on the token AFTER `)`.
	function parseCallArgsRaw(block IrBlock, requireNamed bool = true) returns (ByteArrayArray, StringArray, MaxonTypeArray, SourceRangeArray) throws ParserError
		var args = ByteArrayArray.create()
		var labels = StringArray.create()
		var argTypes = MaxonTypeArray.create()
		var argRanges = SourceRangeArray.create()
		var argIndex = 0
		// Per-arg expressions may shift `currentBlock` (try/otherwise merge,
		// bool short-circuit merge, etc). Seed `currentBlock` from the
		// caller's `block` and re-read it before each materialise / parse,
		// so the materialised constString op lands in whatever block the
		// previous arg's parse settled into. Without this, a `try ... otherwise
		// panic(...)` arg leaves `currentBlock = merge` but later args /
		// materialisations would still target the sealed entry block.
		currentBlock = block
		if not at(TokenKind.rightParen) 'hasArgs'
			while true 'argLoop'
				let argStartPos = cursor.index()
				let labelOpt = try consumeArgLabel(requireNamed: requireNamed and argIndex >= 1)
				var labelStr = ""
				if labelOpt.hasValue 'hasLabel'
					labelStr = labelOpt.token.value
				end 'hasLabel'
				let argFirstToken = cursor.current()
				let argResult = try parseExpression(currentBlock)
				let argLastToken = previousToken()
				let argRange = SourceRange.between(argFirstToken, last: argLastToken)
				// Phase 7: a bare stringConst arg (`f("hello")`) carries
				// the legacy `MaxonType.string` primitive tag in its ExprResult,
				// which doesn't match a callee's `String`-typed parameter
				// (`MaxonType.named("String")`). Materialize the stringConst
				// to a real IR op + retag with the named String type.
				let materializedArg = materializeStringConstIfNeeded(currentBlock, expr: argResult, range: argRange)
				args.push(exprName(materializedArg))
				labels.push(labelStr)
				argTypes.push(exprType(materializedArg))
				argRanges.push(argRange)
				argIndex = argIndex + 1
				if at(TokenKind.rightParen) 'endArgs'
					break
				end 'endArgs'
				// Stuck-guard: when an inner expression's recovery parks the
				// cursor on a synchronization-stop token (e.g. `synchronize()`
				// from `expect(rightParen)` after a malformed inline closure
				// landed on a newline), the next iteration would re-recover at
				// the same position — infinite loop. Break out and let the
				// trailing `expect(rightParen)` report the cascade.
				if cursor.index() <= argStartPos 'stuckArg'
					break
				end 'stuckArg'
				try expect(TokenKind.comma)
			end 'argLoop'
		end 'hasArgs'
		try expect(TokenKind.rightParen)
		return (args, labels, argTypes, argRanges)
	end 'parseCallArgsRaw'

	// Consume and validate an optional `name:` label on the next argument.
	// When requireNamed is true and no label is present, reports E3005. When
	// a label is present (regardless of requireNamed), consumes both tokens
	// and returns them; otherwise returns an empty OptionalToken.
	//
	// Method-call call sites pass `requireNamed: false` from
	// `parseCallArgsRaw` (because the receiver type isn't resolved at parse
	// time and we cannot tell a builtin like `mm.set(...)` apart from a
	// user-defined `widget.set(...)`). For methodCall ops the post-
	// resolution validator `validateCallArgLabels` in TypeResolution
	// re-applies the rule using the resolved receiver type, exempting
	// `__ManagedMemory.*` and other compiler-builtin types to match the
	// C# bootstrap's `allowAllPositional: true` behavior in
	// `ParseBuiltinMethodArgs`. Free / qualified `call` ops keep the parse-
	// time check because the bare callee name is enough to identify a
	// builtin (anything that starts with `__`).
	function consumeArgLabel(requireNamed bool) returns OptionalToken throws ParserError
		let maybeLabel = cursor.current()
		let afterLabel = try cursor.peek(1) otherwise 'eof'
			// Source ran out mid-arg-list (e.g. `f(1,` with no closing
			// paren). Report at the current cursor as expecting an
			// expression, then unwind.
			reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "Unexpected end of input, expected expression", line: maybeLabel.line, column: maybeLabel.column, filePath: filePath)
			throw ParserError.unexpectedEof
		end 'eof'
		let isNamed = tokenIsIdentifierLike(maybeLabel) and afterLabel.kind == TokenKind.colon
		if requireNamed and not isNamed 'notNamed'
			reportCompileError(project, code: ErrorCode.semanticTypeMismatch, message: "Second and subsequent arguments must be named. Use 'name: value' syntax", line: maybeLabel.line, column: maybeLabel.column, filePath: filePath)
		end 'notNamed'
		if not isNamed 'noLabel'
			return OptionalToken.empty()
		end 'noLabel'
		let nameToken = try consume()
		try eat(TokenKind.colon)
		return OptionalToken.some(nameToken)
	end 'consumeArgLabel'

	// Emit a function call op. The parser does NOT do callee dispatch,
	// signature-driven arg slotting, or return-type resolution — TypeResolution
	// fills in the call's result type from `funcReturnTypes` once the project
	// registries are fully populated, and lowering performs the signature-
	// driven arg slot fill. Result type is `MaxonType.unresolved` at parse
	// time.
	// `range` covers the call-site span (the callee name through the closing
	// `)`); caller captures it before parsing arguments and passes it in.
	// `callContext` tells lowering how to qualify the bare callee name:
	// CallContext.qualified for already-qualified names, .sibling(typeName)
	// for bare names inside a method body, .free for everything else.
	// Emits into `currentBlock` rather than a caller-supplied block —
	// argument parsing may have moved control flow (e.g. a nested
	// `try EXPR otherwise FB` lands its merge in a fresh block), and the
	// call op must live in the same block as its defining args.
	function emitCallAndResult(calleeName String, args ByteArrayArray, argLabels StringArray, argTypes MaxonTypeArray, argRanges SourceRangeArray, callContext CallContext, range SourceRange = SourceRange.none()) returns ExprResult
		let callName = freshSynthName()
		module.appendOp(currentBlock, op: MaxonOp.call(callName, callee: project.calleeNames.intern(calleeName), callContext: callContext, args: args, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, range: range))
		// Call result type is filled in by TypeResolution from
		// `funcReturnTypes` once registries are fully populated.
		return ExprResult.direct(callName, valueType: MaxonType.unresolved)
	end 'emitCallAndResult'

	// entry: cursor AT type-name identifier (if not typeNameConsumed) OR AT `{`.
	// exit:  cursor on the token AFTER `}`.
	//
	// Parser does NOT consult `project.structTypes` — it emits a structAlloc
	// op carrying the type name and per-field fieldStore ops carrying the
	// field name. Lowering looks up the byte size, validates field names,
	// and computes offsets.
	function parseStructLiteral(block IrBlock, typeName String, typeToken Token, typeNameConsumed bool = false) returns ExprResult throws ParserError
		if not typeNameConsumed 'consumeTypeName'
			try eat(TokenKind.identifier)
		end 'consumeTypeName'
		try eat(TokenKind.leftBrace)
		try skipNewlines()

		// Per-field expressions may shift `currentBlock` to a fresh merge
		// block — e.g. when a field value is `try f() otherwise panic(...)`,
		// the parser opens a success / fallback / merge CFG triplet and
		// leaves `currentBlock = merge` on return. Every subsequent op
		// (fieldStore for this field, the next field's expression, the
		// trailing `__field_init_*` calls, and the literal's overall result)
		// must land in the post-control-flow block — not in the entry
		// `block`, which is sealed by the condBr the try lowering installed.
		// Without this threading, fieldStore lands in a sealed block and the
		// merge block ends up terminator-less.
		currentBlock = block

		let typeNameBytes = typeName.toByteArray()
		let ptrName = freshSynthName()
		module.appendOp(currentBlock, op: MaxonOp.structAlloc(ptrName, structName: typeNameBytes, range: SourceRange.ofToken(typeToken)))

		// Track user-provided field names so we can synthesize calls to
		// `<TypeName>.__field_init_<fieldName>` for any defaulted fields
		// the literal omits. Lookup goes through `unresolvedStructTypes`
		// — at parse time this is the only place fields land (the resolved
		// `structTypes` registry is populated later by TypeResolution).
		var providedFieldNames = StringArray.create()

		// Parse field: value pairs and emit one fieldStore per field. Pairs
		// may be separated by commas, newlines, or both.
		while not at(TokenKind.rightBrace) 'fields'
			let fieldNameToken = try consume()
			try eat(TokenKind.colon)
			let fieldValue = try parseExpression(currentBlock)
			let fieldLastToken = previousToken()

			module.appendOp(currentBlock, op: MaxonOp.fieldStore(ptrName, fieldName: fieldNameToken.value.toByteArray(), value: exprName(fieldValue), isInit: true, range: SourceRange.between(fieldNameToken, last: fieldLastToken)))
			providedFieldNames.push(fieldNameToken.value)

			_ = accept(TokenKind.comma)
			try skipNewlines()
		end 'fields'
		try eat(TokenKind.rightBrace)

		// Phase 11.x: for every defaulted field the literal didn't supply,
		// emit a call to its `__field_init_*` helper followed by a
		// fieldStore. The helper was synthesized during `parseTypeDecl`,
		// so it's registered in `project.funcReturnTypes` by the time any
		// `Self{...}` (or cross-method literal) parses. Cross-file struct
		// literals work the same way provided the declaring file was
		// parsed first — the parser walks files in user-declared order,
		// matching `project.unresolvedStructTypes` population timing.
		if let unresolved = try project.unresolvedStructTypes.get(typeName) 'haveDecl'
			for declField in unresolved.fields 'eachField'
				if not declField.hasDefault 'noDefault'
					continue
				end 'noDefault'
				if stringArrayContains(providedFieldNames, name: declField.name) 'userProvided'
					continue
				end 'userProvided'
				let helperName = "{typeName}.__field_init_{declField.name}"
				let initCallName = freshSynthName()
				module.appendOp(currentBlock, op: MaxonOp.call(initCallName, callee: project.calleeNames.intern(helperName), callContext: CallContext.qualified, args: ByteArrayArray.create(), argLabels: StringArray.create(), argTypes: MaxonTypeArray.create(), argRanges: SourceRangeArray.create(), range: SourceRange.ofToken(typeToken)))
				module.appendOp(currentBlock, op: MaxonOp.fieldStore(ptrName, fieldName: declField.name.toByteArray(), value: initCallName, isInit: true, range: SourceRange.ofToken(typeToken)))
			end 'eachField'
		end 'haveDecl'

		return ExprResult.direct(ptrName, valueType: internMaxonType(project, name: typeName))
	end 'parseStructLiteral'

	function stringArrayContains(arr StringArray, name String) returns bool
		for item in arr 'scan'
			if item == name 'hit'
				return true
			end 'hit'
		end 'scan'
		return false
	end 'stringArrayContains'

	function parsePrimaryMatch(block IrBlock) returns ExprResult throws ParserError
		// Each leaf consumes its first token itself (stream-style) and exits
		// past its last-consumed token.
		// Keyword tokens whose source spelling is identifier-like (e.g. `with`
		// used as a local var name in stdlib's String.replace) need to route
		// through the identifier path when they appear in expression position
		// AND the local scope binds them. Without the scope check this would
		// cripple every other expression-context use of these keywords.
		let cur = cursor.current()
		if cur.kind != TokenKind.identifier and tokenIsIdentifierLike(cur) and scope.contains(cur.value) 'isKeywordVar'
			return try parseIdentifierExpr(block)
		end 'isKeywordVar'
		// Primitive-type static method call: `int.method(...)`, `float.method(...)`,
		// `bool.method(...)`. The primitive-type keyword (`int`/`float`/`bool`)
		// is NOT a valid primary on its own, so without this hook the
		// `default throws unhandledToken` arm below fires and emits an E2004
		// "Expected expression". Mirrors `TryRewritePrimitiveStaticMethod` in
		// the C# bootstrap parser (Parser.cs:18826) — both compilers map
		// `<primtype>.<method>(args)` to the stdlib `__<primtype>_<method>`
		// free function. Today only `fromString` is registered (in
		// stdlib/Builtins.maxon), but any unrecognized method name falls
		// through to the same unresolved-callee diagnostic the rest of the
		// pipeline emits for free calls.
		if isPrimitiveTypeStaticCallStart(cur) 'isPrimStaticCall'
			return try parsePrimitiveTypeStaticCall(block)
		end 'isPrimStaticCall'
		match cur.kind 'primary'
			intLiteral then return try parseIntLiteral(block)
			floatLiteral then return try parseFloatLiteral(block)
			identifier then return try parseIdentifierExpr(block)
			stringLiteral then return try parseStringLiteral(block)
			byteStringLiteral then return try parseByteStringLiteralExpr(block)
			charLiteral then return try parseCharLiteralExpr(block)
			true then return try parseBoolLiteral(block, value: 1)
			false then return try parseBoolLiteral(block, value: 0)
			leftParen then return try parseParenExpr(block)
			leftBracket then return try parseArrayLiteralExpr(block)
			selfType then return try parseSelfExpr(block)
			self then return try parseSelfInstanceExpr(block)
			match then return try parseMatchExpression(block)
			default throws ParserError.unhandledToken
		end 'primary'
	end 'parsePrimaryMatch'

	// True when the cursor is sitting on a primitive-type keyword (`int`,
	// `float`, `bool`) followed by `.<ident>(`. The byte-primitive lost its
	// keyword in commit 1c1aec4c6 (folded into `int(0 to u8.max)`), so it's
	// reached as an identifier through the regular qualified-call path and
	// doesn't need a token-kind branch here. Caller (parsePrimaryMatch)
	// peeks via the same 3-lookahead window the C# bootstrap uses.
	function isPrimitiveTypeStaticCallStart(cur Token) returns bool
		let kind = cur.kind
		let isPrimType = kind == TokenKind.int or kind == TokenKind.float or kind == TokenKind.bool
		if not isPrimType 'notPrim'
			return false
		end 'notPrim'
		let dotTok = try cursor.peek(1) otherwise return false
		if dotTok.kind != TokenKind.dot 'notDot'
			return false
		end 'notDot'
		let memberTok = try cursor.peek(2) otherwise return false
		if memberTok.kind != TokenKind.identifier 'notIdent'
			return false
		end 'notIdent'
		let openTok = try cursor.peek(3) otherwise return false
		return openTok.kind == TokenKind.leftParen
	end 'isPrimitiveTypeStaticCallStart'

	// Parse `<primtype>.<method>(<args>)` as a static call into the
	// stdlib's `__<primtype>_<method>` free function. Caller has already
	// verified the shape via `isPrimitiveTypeStaticCallStart`; we just
	// stream-consume the four anchor tokens and parse the arg list.
	//
	// We emit the callee as a pre-qualified `stdlib.__<primtype>_<method>`
	// with `CallContext.qualified` so the call survives
	// `qualifyCalleeForContext`'s `__`-prefix gate (the qualified-callee
	// branch chases typealiases only; the gate that rejects bare `__`
	// references from non-internals files lives in the free/sibling probe
	// chain). Returning the unqualified `__<primtype>_<method>` with
	// `CallContext.free` would be silently rewritten to a `<namespace>.__…`
	// stub that doesn't exist.
	function parsePrimitiveTypeStaticCall(block IrBlock) returns ExprResult throws ParserError
		let typeToken = try consume()
		try eat(TokenKind.dot)
		let methodToken = try consume()
		try eat(TokenKind.leftParen)
		let (argNames, argLabels, argTypes, argRanges) = try parseCallArgsRaw(block, requireNamed: false)
		let rparenToken = previousToken()
		let calleeName = "stdlib.__{typeToken.value}_{methodToken.value}"
		return emitCallAndResult(calleeName: calleeName, args: argNames, argLabels: argLabels, argTypes: argTypes, argRanges: argRanges, callContext: CallContext.qualified, range: SourceRange.between(typeToken, last: rparenToken))
	end 'parsePrimitiveTypeStaticCall'

	// Discover (once per process) the stdlib type that implements the
	// `BuiltinArrayLiteral` interface. The compiler knows nothing about
	// "Array" specifically — it only knows the protocol contract: the type
	// declares `static function init(<single __ManagedMemory param>) returns
	// Self`, and the parser desugars `[e0, ..., eN]` into a `T.init(__mm)`
	// call where T is whichever type opted in via the conformance.
	//
	// Walks `project.unresolvedStructTypes` because that's the parser-time
	// registry that still carries `implementedInterfaces`. After cache hits
	// the walk finds nothing — but `restoreStdlibMetadata` republishes the
	// previously-discovered name into the static cache before user code is
	// parsed, so the static path covers cache-hit runs too.
	function discoverBuiltinArrayLiteralType() returns String throws BuiltinArrayLiteralError
		let cached = getCachedBuiltinArrayLiteralTypeName()
		if not cached.isEmpty() 'haveCached'
			return cached
		end 'haveCached'
		// Stdlib's `Array` is the canonical desugaring target — when it
		// declares `implements BuiltinArrayLiteral`, return it directly so
		// user types that also declare the conformance don't displace the
		// stdlib entry. Falls back to the first conforming type otherwise.
		if let arrayEntry = try project.unresolvedStructTypes.get("Array") 'arrayKnown'
			if structDeclaresBuiltinArrayLiteral(arrayEntry) 'isBal'
				setCachedBuiltinArrayLiteralTypeName("Array")
				return "Array"
			end 'isBal'
		end 'arrayKnown'

		for (typeName, entry) in project.unresolvedStructTypes 'scan'
			if structDeclaresBuiltinArrayLiteral(entry) 'isBal'
				setCachedBuiltinArrayLiteralTypeName(typeName)
				return typeName
			end 'isBal'
		end 'scan'
		throw BuiltinArrayLiteralError.unresolved
	end 'discoverBuiltinArrayLiteralType'

	// True when an unresolved struct entry's `implementedInterfaces` list
	// declares conformance to `BuiltinArrayLiteral`. Helper for the
	// canonical-vs-fallback branches in `discoverBuiltinArrayLiteralType`.
	function structDeclaresBuiltinArrayLiteral(entry UnresolvedStructType) returns bool
		for conf in entry.implementedInterfaces 'eachConf'
			if conf.interfaceName == "BuiltinArrayLiteral" 'isBal'
				return true
			end 'isBal'
		end 'eachConf'
		return false
	end 'structDeclaresBuiltinArrayLiteral'

	// Array literal in expression position. Desugars `[e0, e1, ..., eN]` via
	// the BuiltinArrayLiteral protocol into:
	//
	//     __mm = __ManagedMemory.create(N, elementSize: 8)
	//     (_, _) = __mm.set(0, value: e0)        // tryMethodCall, flag dropped
	//     ...
	//     (_, _) = __mm.set(N-1, value: eN)      // tryMethodCall, flag dropped
	//     (_, _) = __mm.setLength(N)             // tryMethodCall, flag dropped
	//     __arr = T.init(__mm)
	//
	// where T is the stdlib type that opted in via `implements
	// BuiltinArrayLiteral`. Element size is hardcoded to 8 (the default for
	// the runtime's bit-packed __ManagedMemory layout); generalizing this
	// requires per-element type-info that isn't yet plumbed through —
	// recorded as a TODO below.
	//
	// On the throw-handling side we rely on a structural invariant: capacity
	// is exactly the literal's element count, and `__managed_mem_set` /
	// `__managed_mem_set_length` bounds-check against capacity (see
	// LowerMaxonToStd Step 8.8). So OOB cannot happen by construction. The
	// throwing methodCalls are emitted as `tryMethodCall` ops whose error
	// flag is bound to a synthetic name and immediately dropped — equivalent
	// to a `try ... otherwise panic` arm whose panic is statically
	// unreachable, but emitted without the CFG-construction overhead of
	// building condBr + panic blocks per element.
	//
	// Empty `[]` literals still emit the create + init pair so the result is
	// a real T value (TypeResolution lifts the result type from T.init's
	// return shape).
	//
	// Commas between elements are stripped by the lexer (see actionTable's
	// `skipOther`), so the inner loop just keeps parsing expressions until
	// it sees `]`.
	function parseArrayLiteralExpr(block IrBlock) returns ExprResult throws ParserError
		consumeExpectedDisplay = "expression"
		let bracketToken = cursor.current()
		try eat(TokenKind.leftBracket)
		// Permit a newline immediately after `[` so multi-line array/map
		// literals (`[\n\t1: 100,\n\t2: 200,\n]`) parse the same as their
		// single-line forms. parseExpression doesn't skip leading newlines
		// itself; without this the first element parse trips E2004.
		try skipNewlines()

		// Phase 1: peek for the empty-literal shape. `[]` always desugars to
		// an empty array (a `Map.init` call with two empty managed-memory
		// buffers requires named key/value type info the parser doesn't
		// have at literal-emission time).
		if at(TokenKind.rightBracket) 'emptyLit'
			try eat(TokenKind.rightBracket)
			let literalRange = SourceRange.between(bracketToken, last: previousToken())
			return try emitArrayLiteralResult(block, elemNames: ByteArrayArray.create(), elemRanges: SourceRangeArray.create(), literalRange: literalRange, bracketToken: bracketToken)
		end 'emptyLit'

		// Phase 2: parse the first element. After parsing we peek for `:`
		// to decide between array-literal (`[v0, v1, ...]`) and map-literal
		// (`[k0: v0, k1: v1, ...]`) parsing paths.
		let firstStartPos = cursor.index()
		let firstFirstToken = cursor.current()
		let firstParsed = try parseExpression(block)
		let firstLastToken = previousToken()
		let firstRange = SourceRange.between(firstFirstToken, last: firstLastToken)
		let firstMaterialized = materializeStringConstIfNeeded(block, expr: firstParsed, range: firstRange)

		if at(TokenKind.colon) 'mapLit'
			return try parseMapLiteralBodyAfterFirstKey(block, bracketToken: bracketToken, firstKeyName: exprName(firstMaterialized), firstKeyRange: firstRange)
		end 'mapLit'

		// Array-literal path: first element already parsed.
		var elemNames = ByteArrayArray.create()
		var elemRanges = SourceRangeArray.create()
		elemNames.push(exprName(firstMaterialized))
		elemRanges.push(firstRange)
		try parseRemainingArrayElements(block, elemNames: elemNames, elemRanges: elemRanges, firstStartPos: firstStartPos)
		try expect(TokenKind.rightBracket)
		let literalRange = SourceRange.between(bracketToken, last: previousToken())
		return try emitArrayLiteralResult(block, elemNames: elemNames, elemRanges: elemRanges, literalRange: literalRange, bracketToken: bracketToken)
	end 'parseArrayLiteralExpr'

	// Parse the trailing `, e1, e2, ..., eN` of an array literal (the leading
	// `[e0` has already been consumed). Stuck-guard mirrors parseCallArgsRaw:
	// an inner expression's recovery may park the cursor without advancing —
	// break out so the trailing `expect(rightBracket)` reports the cascade
	// instead of looping.
	function parseRemainingArrayElements(block IrBlock, elemNames ByteArrayArray, elemRanges SourceRangeArray, firstStartPos ParsedInt) throws ParserError
		// Multi-line literal: tolerate a trailing newline after the first
		// element so `[\n\t1,\n\t2,\n\t3\n]` reaches the `]` cleanly.
		try skipNewlines()
		if at(TokenKind.rightBracket) 'doneAfterFirst'
			return
		end 'doneAfterFirst'
		if cursor.index() <= firstStartPos 'stuckOnFirst'
			return
		end 'stuckOnFirst'
		try expect(TokenKind.comma)
		while true 'elemLoop'
			try skipNewlines()
			if at(TokenKind.rightBracket) 'trailingComma'
				return
			end 'trailingComma'
			let elemStartPos = cursor.index()
			let elemFirstToken = cursor.current()
			let parsedElem = try parseExpression(block)
			let elemLastToken = previousToken()
			let elemRange = SourceRange.between(elemFirstToken, last: elemLastToken)
			let elemResult = materializeStringConstIfNeeded(block, expr: parsedElem, range: elemRange)
			elemNames.push(exprName(elemResult))
			elemRanges.push(elemRange)
			try skipNewlines()
			if at(TokenKind.rightBracket) 'doneList'
				break
			end 'doneList'
			if cursor.index() <= elemStartPos 'stuckElem'
				break
			end 'stuckElem'
			try expect(TokenKind.comma)
		end 'elemLoop'
	end 'parseRemainingArrayElements'

	// Parse the rest of a map literal once the first key has been parsed.
	// Tokens consumed so far: `[ <firstKey>` — the cursor is parked on `:`.
	// Reads `: <firstValue> ( , <key> : <value> )* ]` and emits the matching
	// IR sequence.
	function parseMapLiteralBodyAfterFirstKey(block IrBlock, bracketToken Token, firstKeyName ByteArray, firstKeyRange SourceRange) returns ExprResult throws ParserError
		var keyNames = ByteArrayArray.create()
		var keyRanges = SourceRangeArray.create()
		var valueNames = ByteArrayArray.create()
		var valueRanges = SourceRangeArray.create()

		keyNames.push(firstKeyName)
		keyRanges.push(firstKeyRange)

		try expect(TokenKind.colon)
		let firstValueFirst = cursor.current()
		let firstValueExpr = try parseExpression(block)
		let firstValueRange = SourceRange.between(firstValueFirst, last: previousToken())
		let firstValueResult = materializeStringConstIfNeeded(block, expr: firstValueExpr, range: firstValueRange)
		valueNames.push(exprName(firstValueResult))
		valueRanges.push(firstValueRange)

		try skipNewlines()
		while at(TokenKind.comma) 'morePairs'
			try eat(TokenKind.comma)
			try skipNewlines()
			if at(TokenKind.rightBracket) 'trailing'
				break
			end 'trailing'
			let pairStartPos = cursor.index()

			let keyFirst = cursor.current()
			let keyExpr = try parseExpression(block)
			let keyRange = SourceRange.between(keyFirst, last: previousToken())
			let keyResult = materializeStringConstIfNeeded(block, expr: keyExpr, range: keyRange)
			keyNames.push(exprName(keyResult))
			keyRanges.push(keyRange)

			try expect(TokenKind.colon)

			let valFirst = cursor.current()
			let valExpr = try parseExpression(block)
			let valRange = SourceRange.between(valFirst, last: previousToken())
			let valResult = materializeStringConstIfNeeded(block, expr: valExpr, range: valRange)
			valueNames.push(exprName(valResult))
			valueRanges.push(valRange)
			try skipNewlines()

			if cursor.index() <= pairStartPos 'stuckPair'
				break
			end 'stuckPair'
		end 'morePairs'

		try expect(TokenKind.rightBracket)
		let literalRange = SourceRange.between(bracketToken, last: previousToken())

		// Discover the stdlib type implementing BuiltinDictionaryLiteral.
		// Throws on missing → trip a parser-time diagnostic and fall back to
		// a dummy ExprResult so downstream parsing stays well-formed.
		let mapTypeName = getCachedBuiltinDictionaryLiteralTypeName()
		if mapTypeName.isEmpty() 'noMapType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "map literal: no stdlib type implements BuiltinDictionaryLiteral", line: bracketToken.line, column: bracketToken.column, filePath: filePath)
			let zeroName = emitLiteral(block, value: 0, valueType: MaxonType.integer, range: literalRange)
			return ExprResult.direct(zeroName, valueType: MaxonType.unresolved)
		end 'noMapType'

		// Emit two __ManagedMemory.create + set + setLength sequences (one
		// per axis). Each axis registers an ArrayLiteralProducer under its
		// __mm name so the existing single-axis type-resolution path
		// pins the key/value element type.
		let keyMmName = emitManagedMemoryFromElements(block, elemNames: keyNames, elemRanges: keyRanges, literalRange: literalRange)
		registerArrayLiteralAxis(mmResultName: keyMmName, elemNames: keyNames, elemRanges: keyRanges)
		let valueMmName = emitManagedMemoryFromElements(block, elemNames: valueNames, elemRanges: valueRanges, literalRange: literalRange)
		registerArrayLiteralAxis(mmResultName: valueMmName, elemNames: valueNames, elemRanges: valueRanges)

		// Emit `<mapType>.init(keyMm, valueMm)`. The first arg goes positional
		// (label="") per Maxon's calling convention; the second carries the
		// `initValues` label to satisfy `validateQualifiedCallArgLabels`'
		// "second-and-subsequent must be named" check. The label matches the
		// stdlib's Map.init signature so signature-driven slot assignment
		// resolves it back to the right parameter.
		let initResultName = freshSynthName()
		var initArgs = ByteArrayArray.create()
		initArgs.push(keyMmName)
		initArgs.push(valueMmName)
		var initLabels = StringArray.create()
		initLabels.push("")
		initLabels.push("initValues")
		var initArgTypes = MaxonTypeArray.create()
		initArgTypes.push(MaxonType.unresolved)
		initArgTypes.push(MaxonType.unresolved)
		var initArgRanges = SourceRangeArray.create()
		initArgRanges.push(literalRange)
		initArgRanges.push(literalRange)
		let initCallee = "{mapTypeName}.init"
		// Emit into `currentBlock` — see emitCallAndResult for rationale.
		module.appendOp(currentBlock, op: MaxonOp.call(initResultName, callee: project.calleeNames.intern(initCallee), callContext: CallContext.qualified, args: initArgs, argLabels: initLabels, argTypes: initArgTypes, argRanges: initArgRanges, range: literalRange))

		let producer = MapLiteralProducer.create(mapTypeName, initResultName: initResultName, keyMmResultName: keyMmName, valueMmResultName: valueMmName, sourceRange: literalRange, sourceFilePath: filePath)
		try project.mapLiteralProducers.insert(mapLiteralProducerKey(funcName: currentFunc.name, valueName: initResultName), value: producer) otherwise ignore

		return ExprResult.direct(initResultName, valueType: MaxonType.unresolved)
	end 'parseMapLiteralBodyAfterFirstKey'

	// Emit Phase 3-5 of the array-literal lowering: allocate a
	// `__ManagedMemory` sized to elemCount, write each element via
	// `__mm.set(i, value: elem)`, then `__mm.setLength(elemCount)`. Each
	// throwing call's error flag is drained because capacity = elemCount and
	// `set`/`setLength`'s bounds checks are against capacity — OOB is
	// statically impossible. Returns the `__mm` result name.
	//
	// Shared between array-literal lowering (`[v0, ..., vN]`) and per-axis
	// map-literal lowering (`[k0: v0, ...]` emits two of these).
	function emitManagedMemoryFromElements(block IrBlock, elemNames ByteArrayArray, elemRanges SourceRangeArray, literalRange SourceRange) returns ByteArray
		// TODO(elementSize): all current callers store 8-byte values, so the
		// stride is hardcoded. Generalizing requires either (a) propagating
		// the per-element MaxonType through TypeResolution to a real
		// elementSize, or (b) lowering the array literal in a later pass
		// after types are resolved.
		let elemCount = elemNames.count() as ParsedInt
		let countLitName = emitLiteral(block, value: elemCount, valueType: MaxonType.integer, range: literalRange)
		let elemSizeLitName = emitLiteral(block, value: 8, valueType: MaxonType.integer, range: literalRange)

		let mmName = freshSynthName()
		var createArgs = ByteArrayArray.create()
		createArgs.push(countLitName)
		createArgs.push(elemSizeLitName)
		var createLabels = StringArray.create()
		createLabels.push("")
		createLabels.push("elementSize")
		var createArgTypes = MaxonTypeArray.create()
		createArgTypes.push(MaxonType.integer)
		createArgTypes.push(MaxonType.integer)
		var createArgRanges = SourceRangeArray.create()
		createArgRanges.push(literalRange)
		createArgRanges.push(literalRange)
		// Emit into `currentBlock` — see emitCallAndResult for rationale.
		module.appendOp(currentBlock, op: MaxonOp.call(mmName, callee: project.calleeNames.intern("__ManagedMemory.create"), callContext: CallContext.qualified, args: createArgs, argLabels: createLabels, argTypes: createArgTypes, argRanges: createArgRanges, range: literalRange))
		// __ManagedMemory.create signals OOM via the error flag; drain it so a
		// subsequent `try` doesn't see a stale flag. By construction (capacity
		// = elemCount, no other concurrent allocations) the only failure mode
		// is OOM — silently swallowing it here is consistent with how the
		// stdlib's `Array.create` already behaves.
		emitErrorFlagDrain(range: literalRange)

		// Per-element `__mm.set(i, value: elem)`, each followed by an
		// error-flag drain. argTypes default to `unresolved` —
		// `fillArgTypes` in TypeResolution backfills both slots from
		// producerTypes.
		let setMethodName = "set".toByteArray()
		for i in 0 upto elemNames.count() 'eachElem'
			let elemName = try elemNames.get(i) otherwise panic("array literal: elemNames.get OOB at {i} (count={elemNames.count()})")
			let elemRange = try elemRanges.get(i) otherwise panic("array literal: elemRanges.get OOB at {i}")
			let indexLitName = emitLiteral(block, value: i as ParsedInt, valueType: MaxonType.integer, range: elemRange)
			let setResultName = freshSynthName()
			var setArgs = ByteArrayArray.create()
			setArgs.push(indexLitName)
			setArgs.push(elemName)
			var setLabels = StringArray.create()
			setLabels.push("")
			setLabels.push("value")
			var setArgTypes = MaxonTypeArray.create()
			setArgTypes.push(MaxonType.integer)
			setArgTypes.push(MaxonType.unresolved)
			var setArgRanges = SourceRangeArray.create()
			setArgRanges.push(elemRange)
			setArgRanges.push(elemRange)
			// Emit into `currentBlock` — see emitCallAndResult for rationale.
			module.appendOp(currentBlock, op: MaxonOp.methodCall(setResultName, receiver: mmName, methodName: setMethodName, args: setArgs, argLabels: setLabels, argTypes: setArgTypes, argRanges: setArgRanges, range: elemRange))
			emitErrorFlagDrain(range: elemRange)
		end 'eachElem'

		// `__mm.setLength(elemCount)`. Same drain rationale as per-element set.
		let lengthLitName = emitLiteral(block, value: elemCount, valueType: MaxonType.integer, range: literalRange)
		let setLenResultName = freshSynthName()
		var setLenArgs = ByteArrayArray.create()
		setLenArgs.push(lengthLitName)
		var setLenLabels = StringArray.create()
		setLenLabels.push("")
		var setLenArgTypes = MaxonTypeArray.create()
		setLenArgTypes.push(MaxonType.integer)
		var setLenArgRanges = SourceRangeArray.create()
		setLenArgRanges.push(literalRange)
		let setLenMethodName = "setLength".toByteArray()
		// Emit into `currentBlock` — see emitCallAndResult for rationale.
		module.appendOp(currentBlock, op: MaxonOp.methodCall(setLenResultName, receiver: mmName, methodName: setLenMethodName, args: setLenArgs, argLabels: setLenLabels, argTypes: setLenArgTypes, argRanges: setLenArgRanges, range: literalRange))
		emitErrorFlagDrain(range: literalRange)

		return mmName
	end 'emitManagedMemoryFromElements'

	// Phase 6 of the array-literal lowering: wrap the populated __ManagedMemory
	// via `<arrayType>.init(__mm)` and register the literal's structural
	// pieces in `arrayLiteralProducers` so TypeResolution can pin its
	// element type. Also handles the empty-literal case where the caller
	// passed in zero-length element arrays.
	function emitArrayLiteralResult(block IrBlock, elemNames ByteArrayArray, elemRanges SourceRangeArray, literalRange SourceRange, bracketToken Token) returns ExprResult throws ParserError
		// Discover the stdlib type implementing BuiltinArrayLiteral. Throws on
		// missing or ambiguous → trip a parser-time diagnostic and fall back
		// to a dummy ExprResult so downstream parsing stays well-formed.
		let arrayTypeName = try discoverBuiltinArrayLiteralType() otherwise 'noArrayType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "array literal: no stdlib type implements BuiltinArrayLiteral (or multiple do)", line: bracketToken.line, column: bracketToken.column, filePath: filePath)
			let zeroName = emitLiteral(block, value: 0, valueType: MaxonType.integer, range: literalRange)
			return ExprResult.direct(zeroName, valueType: MaxonType.unresolved)
		end 'noArrayType'

		let mmName = emitManagedMemoryFromElements(block, elemNames: elemNames, elemRanges: elemRanges, literalRange: literalRange)

		// Wrap via `T.init(__mm)`. The single user param is positional
		// (label="") so the lowering's slot resolver matches by position
		// rather than by name — keeping the parser ignorant of the stdlib's
		// chosen parameter spelling.
		let arrName = freshSynthName()
		var initArgs = ByteArrayArray.create()
		initArgs.push(mmName)
		var initLabels = StringArray.create()
		initLabels.push("")
		var initArgTypes = MaxonTypeArray.create()
		initArgTypes.push(MaxonType.unresolved)
		var initArgRanges = SourceRangeArray.create()
		initArgRanges.push(literalRange)
		let initCallee = "{arrayTypeName}.init"
		// Emit into `currentBlock` — see emitCallAndResult for rationale.
		module.appendOp(currentBlock, op: MaxonOp.call(arrName, callee: project.calleeNames.intern(initCallee), callContext: CallContext.qualified, args: initArgs, argLabels: initLabels, argTypes: initArgTypes, argRanges: initArgRanges, range: literalRange))

		// Hand the structural pieces off to TypeResolution, which unifies
		// the elements' producer types and writes the matching
		// `genericInstance(...)` arms onto the `__mm` and `__arr` producers.
		// The same entry goes in under both `mmName` and `arrName` so
		// both the `__ManagedMemory.create` and `<arrayType>.init` lookups
		// in TypeResolution are O(1). `funcName` keeps per-function
		// `freshSynthName` counters from colliding (e.g.
		// `__module_init_0`'s `$t5` and `main`'s `$t5` are distinct).
		let producer = ArrayLiteralProducer.create(arrayTypeName, mmResultName: mmName, initResultName: arrName, elemNames: elemNames, elemRanges: elemRanges, sourceFilePath: filePath)
		try project.arrayLiteralProducers.insert(arrayLiteralProducerKey(funcName: currentFunc.name, valueName: mmName), value: producer) otherwise ignore
		try project.arrayLiteralProducers.insert(arrayLiteralProducerKey(funcName: currentFunc.name, valueName: arrName), value: producer) otherwise ignore

		return ExprResult.direct(arrName, valueType: MaxonType.unresolved)
	end 'emitArrayLiteralResult'

	// Phase 9 Stage 1: emit `EnumName.allCases` as an inline array literal of
	// enum-typed case literals in declaration order. Mirrors the C# bootstrap's
	// `EmitEnumAllCases` (2-Parser.cs:5482). The receiver `enumName` must name
	// a registered (resolved or unresolved) bare enum. Each case literal
	// carries the enum's named type so downstream for-in / index access
	// typechecks against the enum rather than the bare backing scalar.
	// Note on float-backed enums: their `rawValue` is the IEEE-754 bit
	// pattern stored as an `IntConstant` in the EnumCase. We emit the
	// literal as `MaxonType.named(EnumName)` (which lowers to an i64-shaped
	// SSA value carrying the same bit pattern) rather than `MaxonType.float`
	// — the array slot is 8 bytes and the existing `__mm.set` /
	// loadIndirect path moves i64-shaped values. The receiver type metadata
	// is what downstream `.rawValue` access uses to recover the f64 nature
	// (via stdTypeIsFloat on the named alias).
	function emitEnumAllCases(enumName String, accessRange SourceRange) returns ExprResult throws ParserError
		let elemType = MaxonType.named(project.typeNames.intern(enumName))
		var elemNames = ByteArrayArray.create()
		var elemRanges = SourceRangeArray.create()
		let cases = try enumCasesOrEmpty(enumName) otherwise EnumCaseArray.create()
		for i in 0 upto cases.count() 'eachCase'
			let c = try cases.get(i) otherwise panic("emitEnumAllCases: cases.get OOB at {i}")
			let litName = emitLiteral(currentBlock, value: c.rawValue, valueType: elemType, range: accessRange)
			elemNames.push(litName)
			elemRanges.push(accessRange)
		end 'eachCase'
		return try emitArrayLiteralResult(currentBlock, elemNames: elemNames, elemRanges: elemRanges, literalRange: accessRange, bracketToken: cursor.current())
	end 'emitEnumAllCases'

	// Phase 9 Stage 1: emit `EnumName.allCaseNames` as an inline array literal
	// of case-name string constants in declaration order. Mirrors the C#
	// bootstrap's `EmitEnumAllCaseNames` (2-Parser.cs:5522). Works for both
	// resolved and pre-registered enums.
	function emitEnumAllCaseNames(enumName String, accessRange SourceRange) returns ExprResult throws ParserError
		var elemNames = ByteArrayArray.create()
		var elemRanges = SourceRangeArray.create()
		let cases = try enumCasesOrEmpty(enumName) otherwise EnumCaseArray.create()
		for i in 0 upto cases.count() 'eachCase'
			let c = try cases.get(i) otherwise panic("emitEnumAllCaseNames: cases.get OOB at {i}")
			let stringId = project.strings.intern(c.name)
			let name = freshSynthName()
			module.appendOp(currentBlock, op: MaxonOp.stringConst(name, stringId: stringId, range: accessRange))
			elemNames.push(name)
			elemRanges.push(accessRange)
		end 'eachCase'
		return try emitArrayLiteralResult(currentBlock, elemNames: elemNames, elemRanges: elemRanges, literalRange: accessRange, bracketToken: cursor.current())
	end 'emitEnumAllCaseNames'

	// Look up an enum's case list across both the resolved-enum map (post-
	// TypeResolution) and the pre-registered unresolvedEnums map (set at
	// parse time before the body finishes). Used by .allCases / .allCaseNames
	// synthesis to fetch declaration-ordered cases regardless of whether the
	// enum body has fully landed by the time the access is parsed.
	function enumCasesOrEmpty(enumName String) returns EnumCaseArray throws ParserError
		if let resolved = try project.enumTypes.get(enumName) 'isResolved'
			return resolved.cases
		end 'isResolved'
		if let unresolved = try project.unresolvedEnums.get(enumName) 'isUnresolved'
			return unresolved.cases
		end 'isUnresolved'
		throw ParserError.unhandledToken
	end 'enumCasesOrEmpty'

	// Returns true iff `enumName` names a float-backed enum (raw values come
	// from `floatLiteral` tokens). Falls back to false for any non-enum or
	// unknown name — the caller is expected to have validated `enumName`
	// against `enumTypes` / `unresolvedEnums` already.
	function enumIsFloatBacked(enumName String) returns bool
		if let resolved = try project.enumTypes.get(enumName) 'isResolved'
			return resolved.isFloatBacked
		end 'isResolved'
		if let unresolved = try project.unresolvedEnums.get(enumName) 'isUnresolved'
			return unresolved.isFloatBacked
		end 'isUnresolved'
		return false
	end 'enumIsFloatBacked'

	// Register a single map-literal axis (keys or values) as a synthetic
	// array-literal producer keyed on the axis's `__mm` result name only.
	// `arrayTypeName` is "" because the axis has no init-call result name —
	// only the `__ManagedMemory` allocation is user-addressable. The
	// `initResultName` is intentionally left empty so `arrayLiteralBaseTypeName`
	// rejects an `initResultName == name` match (an empty ByteArray cannot
	// equal a `freshSynthName`-minted name) and falls through to the
	// `mmResultName == name` branch.
	function registerArrayLiteralAxis(mmResultName ByteArray, elemNames ByteArrayArray, elemRanges SourceRangeArray)
		let producer = ArrayLiteralProducer.create("", mmResultName: mmResultName, initResultName: ByteArray.create(), elemNames: elemNames, elemRanges: elemRanges, sourceFilePath: filePath)
		try project.arrayLiteralProducers.insert(arrayLiteralProducerKey(funcName: currentFunc.name, valueName: mmResultName), value: producer) otherwise ignore
	end 'registerArrayLiteralAxis'

	// The preceding op publishes its error flag via the multi-value-return
	// ABI (RDX/X1). Rewrite that preceding op in place to its `try*` form,
	// binding a fresh synthetic name as the errorBoundName. Lowering writes
	// the flag into the bound name in the same op as the call. The bound
	// name is intentionally never read; the flag is silently swallowed
	// because every caller of this helper has already proven its preceding
	// call cannot fail by construction (capacity-sized __ManagedMemory.create
	// + bounded __mm.set / setLength against that capacity).
	function emitErrorFlagDrain(range SourceRange)
		let drainName = freshSynthName()
		let opCount = module.ops.count()
		if opCount == 0 'noPrev'
			panic("emitErrorFlagDrain: no preceding op to rewrite to try-form")
		end 'noPrev'
		let lastIdx = opCount - 1
		let lastOp = try module.ops.get(lastIdx) otherwise panic("emitErrorFlagDrain: ops.get OOB at last idx={lastIdx}")
		if lastOp.name == "call" 'isCall'
			let rewrote = tryRewriteCallToTryCall(opIdx: lastIdx, op: lastOp, errorFlagName: drainName, tryRange: range)
			if not rewrote 'failedCallRewrite'
				panic("emitErrorFlagDrain: tryRewriteCallToTryCall returned false on lastOp.name=='call'")
			end 'failedCallRewrite'
			return
		end 'isCall'
		if lastOp.name == "methodCall" 'isMethodCall'
			let rewrote = tryRewriteMethodCallToTryMethodCall(opIdx: lastIdx, op: lastOp, errorFlagName: drainName, tryRange: range)
			if not rewrote 'failedMethodRewrite'
				panic("emitErrorFlagDrain: tryRewriteMethodCallToTryMethodCall returned false on lastOp.name=='methodCall'")
			end 'failedMethodRewrite'
			return
		end 'isMethodCall'
		panic("emitErrorFlagDrain: preceding op kind '{lastOp.name}' is neither call nor methodCall")
	end 'emitErrorFlagDrain'

	// Single-quote literal in expression position. The lexer also produces
	// charLiteral tokens for block labels (`'loop'`); the parser
	// distinguishes by context — labels are consumed by parseOptionalBlockLabel
	// before the expression parser ever sees them. Emits an integer literal
	// carrying the byte value of an ASCII character (e.g. `'a'` → 97), which
	// matches the way the rest of self-hosted treats Character (single byte).
	// Multi-byte / EGC literals require the full stdlib Character type; report
	// them as a diagnostic instead of silently producing the wrong byte.
	function parseCharLiteralExpr(block IrBlock) returns ExprResult throws ParserError
		let token = try consume()
		validateEscapes(token, kind: "character literal")
		let decoded = decodeStringEscapes(token.value)
		let range = SourceRange.ofToken(token)
		if decoded.count() == 1 'singleByte'
			// Single-byte (ASCII) fast path. Stays as an integer literal so
			// the lexer/parser's many `b == 'a'` style byte comparisons keep
			// compiling without coercions. Multi-byte chars take the
			// charLiteral path (real Character struct). The literal's value
			// name is recorded in `project.charByteLiterals` so consumers
			// that need char-ness (overload disambiguation, interpolation
			// lowering) can recover it without the type system having to
			// distinguish int from byte-char everywhere.
			let byteVal = try decoded.get(0) otherwise panic("parseCharLiteralExpr: count==1 but get(0) failed")
			let name = emitLiteral(block, value: byteVal as ParsedInt, valueType: MaxonType.integer, range: range)
			project.charByteLiterals.insert(charByteLiteralKey(funcName: currentFunc.name, valueName: name))
			return ExprResult.direct(name, valueType: MaxonType.integer)
		end 'singleByte'
		// Phase 7 step 6: multi-byte character literal — intern the decoded
		// UTF-8 bytes and emit a charLiteral op. Lowering will materialize a
		// Character struct (8 bytes: managed@0 ptr to MM) backed by
		// rdata-resident __ManagedMemory.
		let stringId = project.strings.intern(String.from(decoded))
		let name = freshSynthName()
		module.appendOp(block, op: MaxonOp.charLiteral(name, stringId: stringId, range: range))
		let charType = MaxonType.named(project.typeNames.intern("Character"))
		return ExprResult.direct(name, valueType: charType)
	end 'parseCharLiteralExpr'

	// Phase 7 step 7: parse a byte-string literal `b"..."`. The lexer has
	// emitted a single `byteStringLiteral` token whose value contains the
	// raw (still-escaped) body bytes. We decode escapes the same way as
	// regular string literals, intern the resulting bytes, and emit a
	// `byteStringLiteral` op. Result type: `Array` — the user-visible
	// `ByteArray` typealias (`Array with Byte`) consumes byte-string
	// literals via the standard struct-method dispatch, so .count(),
	// .get(i), etc. resolve to Array's stdlib methods.
	function parseByteStringLiteralExpr(block IrBlock) returns ExprResult throws ParserError
		let token = try consume()
		validateEscapes(token, kind: "byte string literal")
		let decoded = decodeStringEscapes(token.value)
		let range = SourceRange.ofToken(token)
		let stringId = project.strings.intern(String.from(decoded))
		let name = freshSynthName()
		module.appendOp(block, op: MaxonOp.byteStringLiteral(name, stringId: stringId, range: range))
		// Leave the bound generic-instance result type to TypeResolution —
		// matching how `parseArrayLiteralExpr` returns `unresolved` and lets
		// the resolver intern the `Array with ...` gid. The parser only emits
		// the op; type-system facts belong to the resolution pass.
		return ExprResult.direct(name, valueType: MaxonType.unresolved)
	end 'parseByteStringLiteralExpr'

	function parseSelfExpr(block IrBlock) returns ExprResult throws ParserError
		let selfToken = try consume()
		if currentTypeName.isEmpty() 'notInType'
			reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "'Self' can only be used inside a type declaration", line: selfToken.line, column: selfToken.column, filePath: filePath)
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'notInType'
		if at(TokenKind.leftBrace) 'isStructLiteral'
			return try parseStructLiteral(block, typeName: currentTypeName, typeToken: selfToken, typeNameConsumed: true)
		end 'isStructLiteral'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Expected '\{' after Self", line: selfToken.line, column: selfToken.column, filePath: filePath)
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'parseSelfExpr'

	function parseSelfInstanceExpr(block IrBlock) returns ExprResult throws ParserError
		let selfToken = try consume()
		if reportSelfOutsideType(selfToken) 'notInType'
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'notInType'
		let selfLoadName = emitSelfLoad(block, token: selfToken, range: SourceRange.ofToken(selfToken))
		return ExprResult.direct(selfLoadName, valueType: internMaxonType(project, name: currentTypeName))
	end 'parseSelfInstanceExpr'

	function parsePrimary(block IrBlock) returns ExprResult throws ParserError
		let token = cursor.current()
		// `parsePrimaryMatch` throws ParserError for two distinct reasons:
		//   - `unhandledToken`: the current token can't start any primary
		//     (real "expected expression" error — call raiseUnexpectedToken).
		//   - `unexpectedEof` (or any other error from a nested helper):
		//     the token DID start a valid primary (e.g. `f(...)` is a call),
		//     but parsing the rest of it ran out of input. Re-throw so the
		//     caller can surface the precise downstream diagnostic — the
		//     primary identifier itself isn't the problem.
		let result = try parsePrimaryMatch(block) otherwise(e) 'primaryFail'
			match e 'kind'
				unhandledToken then return raiseUnexpectedToken(block, token: token)
				typeError then throw ParserError.typeError
				overflow then throw ParserError.overflow
				unexpectedEof then throw ParserError.unexpectedEof
			end 'kind'
		end 'primaryFail'
		return result
	end 'parsePrimary'

	// Expression-position parse failure: the next token doesn't start any known
	// primary. Report the diagnostic (for batch compile output), emit a
	// `MaxonOp.error` that anchors the failed span in the IR (for the LSP),
	// skip to the end of the line to avoid cascading errors, and return a
	// dummy ExprResult so the caller's type shape stays intact.
	function raiseUnexpectedToken(block IrBlock, token Token) returns ExprResult
		// Use reportTokenMismatch so EOF/empty-content tokens surface as
		// "Unexpected end of input, expected expression" rather than the
		// misleading "got '(empty)'" form. The MaxonOp.error span anchors
		// at the same token regardless of phrasing.
		reportTokenMismatch(token, expectedDisplay: "expression", wrongKindCode: ErrorCode.parserExpectedExpression)
		let message = "Expected expression but got '{tokenValueToString(token.value)}'"
		module.appendOp(block, op: MaxonOp.error(MaxonErrorKind.expectedExpression, message: message, range: SourceRange.ofToken(token)))
		// Skip ahead to the next newline so a single bad expression doesn't
		// cascade into a follow-up "Expected expression" on the same line.
		// Stop on EOF without consuming the sentinel — leaves cursor parked on
		// it so callers can branch on `at(eof)` without re-reading past end.
		while not at(TokenKind.newline) and not at(TokenKind.eof) 'skip'
			try cursor.advance() otherwise break
		end 'skip'
		return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
	end 'raiseUnexpectedToken'

	function parseIntLiteral(block IrBlock) returns ExprResult throws ParserError
		let token = try consume()
		let value = try parseInt(token.value) otherwise 'overflow'
			reportLiteralOverflow(token: token, message: "Integer literal '{tokenValueToString(token.value)}' is outside the range of int (-9223372036854775808 to 9223372036854775807)")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
		end 'overflow'
		let name = emitLiteral(block, value: value, valueType: MaxonType.integer, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.integer)
	end 'parseIntLiteral'

	function parseFloatLiteral(block IrBlock) returns ExprResult throws ParserError
		let token = try consume()
		let rawBits = try parseFloatBits(token.value) otherwise 'overflow'
			reportLiteralOverflow(token: token, message: "Float literal '{tokenValueToString(token.value)}' is outside the range of float")
			return ExprResult.direct(ByteArray.create(), valueType: MaxonType.float)
		end 'overflow'
		let name = emitLiteral(block, value: rawBits, valueType: MaxonType.float, range: SourceRange.ofToken(token))
		return ExprResult.direct(name, valueType: MaxonType.float)
	end 'parseFloatLiteral'

	// Phase 7 step 5: parse a (possibly interpolated) double-quoted string
	// literal in expression position. Lexer token shape:
	//   stringLiteral(frag0) [stringInterpStart <expr> stringInterpEnd stringLiteral(fragN)]*
	//
	// No interp markers → emit `ExprResult.stringConst(name, stringId)` so the
	// existing parser-time fold paths (compile-time `==`, `let LOCAL = "lit"`
	// constant registration) continue to work — they read the StringId
	// directly off the ExprResult and assume no backing IR op exists.
	//
	// One or more interp markers → build a `StringInterpPartArray` and emit a
	// `MaxonOp.stringInterp(name, parts, range)`. Each fragment becomes a
	// `literal(stringId)`; each interpolated subexpression becomes an
	// `expr(name, kind)` with `kind` classified by `inferInterpKind`.
	function parseStringLiteral(block IrBlock) returns ExprResult throws ParserError
		let leadToken = try consume()
		validateEscapes(leadToken, kind: "string interpolation")
		let leadDecoded = decodeStringEscapes(leadToken.value)
		let leadStringId = project.strings.intern(String.from(leadDecoded))
		// Fast path: no interp markers — preserve stringConst ExprResult shape.
		if cursor.current().kind != TokenKind.stringInterpStart 'noInterp'
			let name = freshSynthName()
			return ExprResult.stringConst(name, stringId: leadStringId)
		end 'noInterp'
		var parts = StringInterpPartArray.create()
		parts.push(StringInterpPart.literal(leadStringId))
		while at(TokenKind.stringInterpStart) 'interpLoop'
			try eat(TokenKind.stringInterpStart)
			currentBlock = block
			let interpStartTok = previousToken()
			let exprResult = try parseExpression(block)
			// Inner expressions that came back as `stringConst` (e.g. a nested
			// `"..."` literal with no interp markers of its own) carry a
			// parser-internal synth name that has no backing op. Force the op
			// to be emitted now so the outer `stringInterp` op's expr-part
			// reference resolves during lowering. Without this, deeply-nested
			// interp like `"{ "inner" }"` errors with E3013 'unresolved value
			// name'.
			let materializedExpr = materializeStringConstIfNeeded(block, expr: exprResult, range: SourceRange.ofToken(interpStartTok))
			let exprNameSlice = exprName(materializedExpr)
			let kind = inferInterpKind(exprType(materializedExpr))
			let formatSpecId = try parseInterpFormatSpec()
			parts.push(StringInterpPart.expr(exprNameSlice, kind: kind, formatSpecId: formatSpecId))
			try expect(TokenKind.stringInterpEnd)
			if not at(TokenKind.stringLiteral) 'recoveredFromInterp'
				// Parser recovery may have left us past the closing quote on
				// malformed input; bail with what we have so far rather than
				// asserting the lexer's frag-after-end invariant.
				break
			end 'recoveredFromInterp'
			let fragToken = try consume()
			validateEscapes(fragToken, kind: "string interpolation")
			let fragDecoded = decodeStringEscapes(fragToken.value)
			let fragStringId = project.strings.intern(String.from(fragDecoded))
			parts.push(StringInterpPart.literal(fragStringId))
		end 'interpLoop'
		let lastTok = previousToken()
		let interpRange = SourceRange.between(leadToken, last: lastTok)
		let resultName = freshSynthName()
		// Emit into `currentBlock` — an inner interp expression with short-
		// circuit `and`/`or` or a nested `try ... otherwise` moves control
		// flow, and the stringInterp op must reference its parts from the
		// block where they were defined.
		module.appendOp(currentBlock, op: MaxonOp.stringInterp(resultName, parts: parts, range: interpRange))
		return ExprResult.direct(resultName, valueType: MaxonType.named(project.typeNames.intern("String")))
	end 'parseStringLiteral'

	// Phase 7 step 5 — format-spec capture. Called immediately after the
	// interpolation subexpression has parsed; cursor is on either `:` (format
	// spec present) or `stringInterpEnd` (no format spec). When present, the
	// tokens between `:` and `stringInterpEnd` are concatenated into a raw
	// format-spec string (e.g. `04x`, `.3`, `6.2`, `verbose`) and interned via
	// `project.strings`. Returns the empty-string id when no `:` is present so
	// downstream code can branch on `isEmpty()` instead of an extra flag.
	//
	// The lexer pre-tokenizes the spec body (e.g. `:6.2` lexes as `colon`
	// + `floatLiteral("6.2")`; `:04x` lexes as `colon` + `intLiteral("04")`
	// + `identifier("x")`; `:.3` lexes as `colon` + `dot` + `intLiteral("3")`).
	// Concatenating token.value preserves the original spec text losslessly
	// because each format-spec token's value field carries the source-aligned
	// byte sequence the lexer recognized.
	function parseInterpFormatSpec() returns StringId throws ParserError
		if not at(TokenKind.colon) 'noFmt'
			return project.strings.intern("")
		end 'noFmt'
		try eat(TokenKind.colon)
		var formatBytes = ByteArray.create()
		while not at(TokenKind.stringInterpEnd) 'collect'
			if at(TokenKind.eof) 'fmtEof'
				break
			end 'fmtEof'
			let tok = try consume()
			let valBytes = tok.value.toByteArray()
			for i in 0 upto valBytes.count() 'eachByte'
				let b = try valBytes.get(i) otherwise panic("parseInterpFormatSpec: valBytes.get OOB at {i}")
				formatBytes.push(b)
			end 'eachByte'
		end 'collect'
		return project.strings.intern(String.from(formatBytes))
	end 'parseInterpFormatSpec'

	// Phase 7 step 5: classify the parser-inferred MaxonType of an
	// interpolated subexpression so lowering knows which runtime helper
	// (or struct-field load) to emit. Returns `i64` as the conservative
	// default for unresolved / unknown types — TypeResolution may refine
	// this later, but for now the i64 path is the safest fall-through
	// because every numeric literal in stdlib resolves to it.
	function inferInterpKind(t MaxonType) returns InterpExprKind
		return match t 'k'
			boolean gives InterpExprKind.bool
			integer gives InterpExprKind.i64
			float gives InterpExprKind.f64
			string gives InterpExprKind.string
			named(id) gives interpKindForNamed(project.typeNames.get(id))
			function to unresolved gives InterpExprKind.i64
			typeParameter to interface gives InterpExprKind.i64
			constInt gives InterpExprKind.i64
		end 'k'
	end 'inferInterpKind'

	function interpKindForNamed(name String) returns InterpExprKind
		if name == "String" 'isString'
			return InterpExprKind.string
		end 'isString'
		if name == "Character" 'isChar'
			return InterpExprKind.character
		end 'isChar'
		if name == "bool" 'isBool'
			return InterpExprKind.bool
		end 'isBool'
		// Default: treat as i64 (named ints widen through the same
		// runtime helper). f32/f64 are routed via inferInterpKind on
		// `MaxonType.float` already; this fall-through only fires for
		// unresolved named types where i64 is the conservative default.
		return InterpExprKind.i64
	end 'interpKindForNamed'

	// Materialize a parser-internal stringConst into a real IR op when its
	// `name` is about to be referenced by an op operand (e.g. it survives
	// past the compile-time fold path and ends up on either side of a cmp
	// that didn't fold). Without the backing op, lowering's resolveName
	// would fail with "parser did not bind this name". Idempotent: callers
	// invoke this on every ExprResult before threading its name into a
	// downstream op so the producer is guaranteed to be present in the IR.
	function materializeStringConstIfNeeded(block IrBlock, expr ExprResult, range SourceRange) returns ExprResult
		if not exprIsStringConst(expr) 'notStr'
			return expr
		end 'notStr'
		let stringId = exprStringConstId(expr)
		let name = exprName(expr)
		module.appendOp(block, op: MaxonOp.stringConst(name, stringId: stringId, range: range))
		// Phase 7: a materialized stringConst is a real `String` struct value;
		// TypeResolution refines the named type once stdlib registers `String`.
		// Falls back to the legacy `MaxonType.string` primitive tag pre-Phase-7.
		return ExprResult.direct(name, valueType: MaxonType.named(project.typeNames.intern("String")))
	end 'materializeStringConstIfNeeded'

	// Validate \xNN and \uNNNN escape sequences in `token.value`. Reports
	// `lexerInvalidEscape` matching the C# bootstrap's diagnostic text:
	//   "Invalid hex escape '\xZZ': expected 2 hex digits in <kind>"
	//   "Invalid unicode escape '\uZZZZ': expected 4 hex digits in <kind>"
	// `kind` is the trailing context phrase — "string interpolation" for
	// double-quoted strings, "character literal" for single-quoted strings,
	// "byte string literal" for `b"..."` byte strings.
	function validateEscapes(token Token, kind String)
		let bytes = token.value.toByteArray()
		let n = bytes.count()
		var i = 0 as ByteOffset
		for _ in 0 upto n 'walk'
			if i >= n 'eofWalk'
				break
			end 'eofWalk'
			let b = try bytes.get(i) otherwise panic("validateEscapes: i < n invariant")
			if b == '\\' 'esc'
				if i + 1 >= n 'lonelyBackslash'
					// Trailing backslash — handled by lexer's unterminated path.
					return
				end 'lonelyBackslash'
				let next = try bytes.get(i + 1) otherwise panic("validateEscapes: i+1 < n invariant")
				if next == 'x' 'hex'
					if i + 3 >= n or not isHexDigitByte(try bytes.get(i + 2) otherwise 0) or not isHexDigitByte(try bytes.get(i + 3) otherwise 0) 'badHex'
						var availLen = 4 as ByteOffset
						if (n - i) < 4 'shortHex'
							availLen = n - i
						end 'shortHex'
						let avail = try bytes.slice(i + 1, endIndex: i + availLen) otherwise panic("validateEscapes.badHex: slice invariant")
						let availStr = String.from(avail)
						reportCompileError(project, code: ErrorCode.lexerInvalidEscape, message: "Invalid hex escape '\\{availStr}': expected 2 hex digits in {kind}", line: token.line, column: token.column + i, filePath: filePath)
						return
					end 'badHex'
					i = i + 4
				end 'hex' else if next == 'u' 'uni'
					if i + 5 >= n or not isHexDigitByte(try bytes.get(i + 2) otherwise 0) or not isHexDigitByte(try bytes.get(i + 3) otherwise 0) or not isHexDigitByte(try bytes.get(i + 4) otherwise 0) or not isHexDigitByte(try bytes.get(i + 5) otherwise 0) 'badUni'
						var availLen = 6 as ByteOffset
						if (n - i) < 6 'shortUni'
							availLen = n - i
						end 'shortUni'
						let avail = try bytes.slice(i + 1, endIndex: i + availLen) otherwise panic("validateEscapes.badUni: slice invariant")
						let availStr = String.from(avail)
						reportCompileError(project, code: ErrorCode.lexerInvalidEscape, message: "Invalid unicode escape '\\{availStr}': expected 4 hex digits in {kind}", line: token.line, column: token.column + i, filePath: filePath)
						return
					end 'badUni'
					i = i + 6
				end 'uni' else 'simple'
					i = i + 2
				end 'simple'
			end 'esc' else 'plain'
				i = i + 1
			end 'plain'
		end 'walk'
	end 'validateEscapes'

	function isHexDigitByte(b Byte) returns bool
		return (b >= '0' and b <= '9') or (b >= 'a' and b <= 'f') or (b >= 'A' and b <= 'F')
	end 'isHexDigitByte'

	// Whether a token is acceptable as a type-name in a parameter list, a
	// `returns <type>` clause, etc. Identifiers are user types; the
	// keyword-like primitive types (`int`, `float`, `bool`) are
	// also valid type-name tokens.
	function isTypeNameToken(token Token) returns bool
		return token.kind == TokenKind.identifier or token.kind == TokenKind.int or token.kind == TokenKind.float or token.kind == TokenKind.bool or token.kind == TokenKind.array
	end 'isTypeNameToken'

	// Consume tokens from a composite interpolated string. Used by
	// error-recovery paths that reject interpolations but still need to
	// advance past them so surrounding parsing stays sane.
	// entry: cursor AT stringInterpStart (caller has consumed the opening fragment).
	// exit:  cursor on the first token AFTER the final stringLiteral fragment.
	function skipInterpolatedRemainder() throws ParserError
		while cursor.current().kind == TokenKind.stringInterpStart 'interp'
			try eat(TokenKind.stringInterpStart)
			while cursor.current().kind != TokenKind.stringInterpEnd 'skipExpr'
				_ = try consume()
			end 'skipExpr'
			try eat(TokenKind.stringInterpEnd)
			assertFragmentAfterInterpEnd(callerName: "skipInterpolatedRemainder", token: cursor.current())
			try eat(TokenKind.stringLiteral)
		end 'interp'
	end 'skipInterpolatedRemainder'

	function parseBoolLiteral(block IrBlock, value ParsedInt) returns ExprResult throws ParserError
		let tok = try consume()
		let name = emitLiteral(block, value: value, valueType: MaxonType.boolean, range: SourceRange.ofToken(tok))
		return ExprResult.direct(name, valueType: MaxonType.boolean)
	end 'parseBoolLiteral'

	function parseParenExpr(block IrBlock) returns ExprResult throws ParserError
		// Stage B (closures): a leading `(` may open either a parenthesized
		// expression OR a closure literal (`() gives ...`, `(x T) gives ...`).
		// Distinguish via lookahead before committing to expression parsing —
		// otherwise the first token inside `()` reaches `parsePrimary` and
		// emits E2004 ("Expected expression but got ')'").
		if isClosure() 'isClos'
			return try parseClosure(block)
		end 'isClos'
		let openToken = cursor.current()
		try eat(TokenKind.leftParen)
		// Parenthesized sub-expression: clear `inForInHeader` so an inner
		// `to`/`upto` lowers to Range.create/OpenRange.create (the for-in
		// header's range-suppression only applies to the unparenthesized
		// top-level bounds).
		let savedInForInHeader = inForInHeader
		inForInHeader = false
		let inner = try parseExpression(block)
		inForInHeader = savedInForInHeader
		if not at(TokenKind.comma) 'plainParen'
			try expect(TokenKind.rightParen)
			return inner
		end 'plainParen'
		// Tuple expression `(e0, e1, ...)` — desugars to a struct literal
		// for the synthetic `__TupleN` base struct (arity from element
		// count). Fields are named `_0`, `_1`, etc. Elements are
		// comma-separated; the leading `(`, first element, and comma have
		// already been consumed. String-literal elements need to be
		// materialised through the lazy-stringConst path before being
		// referenced by the fieldStore op (otherwise their producer name
		// is never bound — see materializeStringConstIfNeeded).
		var elemNames = ByteArrayArray.create()
		var elemTypes = MaxonTypeArray.create()
		let innerMat = materializeStringConstIfNeeded(block, expr: inner, range: SourceRange.ofToken(openToken))
		elemNames.push(exprName(innerMat))
		elemTypes.push(exprType(innerMat))
		while accept(TokenKind.comma) 'tupleLoop'
			let loopStart = cursor.index()
			let nextElem = try parseExpression(block)
			let nextMat = materializeStringConstIfNeeded(block, expr: nextElem, range: SourceRange.ofToken(openToken))
			elemNames.push(exprName(nextMat))
			elemTypes.push(exprType(nextMat))
			// Stuck-guard mirrors parseCallArgsRaw: a failed inner parse
			// may park the cursor on a synchronization-stop token; without
			// this we'd spin in place.
			if cursor.index() <= loopStart 'stuck'
				break
			end 'stuck'
		end 'tupleLoop'
		try expect(TokenKind.rightParen)
		let arity = elemNames.count()
		let baseName = "__Tuple{arity}"
		let typeNameBytes = baseName.toByteArray()
		let ptrName = freshSynthName()
		module.appendOp(block, op: MaxonOp.structAlloc(ptrName, structName: typeNameBytes, range: SourceRange.ofToken(openToken)))
		for i in 0 upto arity 'eachField'
			let elemValue = try elemNames.get(i) otherwise panic("parseParenExpr: elemNames.get OOB at {i}")
			let fieldName = "_{i}".toByteArray()
			module.appendOp(block, op: MaxonOp.fieldStore(ptrName, fieldName: fieldName, value: elemValue, isInit: true, range: SourceRange.ofToken(openToken)))
		end 'eachField'
		// Phase 15e: when every element has a concrete parse-time type (literal
		// int/float/bool/string/char and named structs all qualify), intern a
		// specialised `genericInstance(__TupleN, [T0..TN])` and pin it under
		// the allocation's result name so lowerStructAlloc can recover the
		// receiver-context the parser inferred. Tuples whose element types
		// stay unresolved at parse time (e.g. method-call results — type
		// pinned by TypeResolution) fall back to the bare named form; the
		// `refineTupleStructAlloc` post-pass picks them up via producer-types.
		if tupleElemTypesAllConcreteAtParse(elemTypes) 'concreteAtParse'
			let baseId = project.typeNames.intern(baseName)
			let giid = project.genericInstances.intern(baseId, args: elemTypes)
			project.tupleAllocGids.upsert(ptrName, value: giid)
			return ExprResult.direct(ptrName, valueType: MaxonType.genericInstance(giid))
		end 'concreteAtParse'
		return ExprResult.direct(ptrName, valueType: internMaxonType(project, name: baseName))
	end 'parseParenExpr'

	// Stage B (closures): lookahead-only test for the closure-expression
	// shape. Mirrors C# IsClosure() at 2-Parser.cs:18427-18473. Cursor
	// must be AT a `(`; the helper does not consume any tokens.
	//
	// Recognized shapes:
	//   `()` `gives`                          → empty-param closure
	//   `(` ident TYPE_STARTER                → typed closure (≥1 param)
	//   `(` ident `)` `gives`                 → untyped single-param closure
	//   `(` ident `,` ...balanced-`)`... `gives` → multi-param closure
	// where TYPE_STARTER is the start of a `parseTypeRef` form: an
	// identifier (named type like `Integer`) or `(` (nested function type).
	//
	// Untyped closure parameters take their concrete types from the call-site
	// signature during TypeResolution (see propagateCallArgClosureTypes) —
	// at parse time their slots are stamped `MaxonType.unresolved` and the
	// body parses with that placeholder. Multi-param disambiguation against a
	// tuple expression requires scanning to a balanced `)` and checking that
	// `gives` follows; without `gives`, `(a, b)` remains a tuple.
	//
	// EOF on any peek bails to false rather than throwing; the caller falls
	// back to the parenthesized-expression path which will surface the
	// truncated input via its own diagnostic.
	function isClosure() returns bool
		if not at(TokenKind.leftParen) 'noLP'
			return false
		end 'noLP'
		// `()` ⇒ closure iff `gives` follows.
		let p1 = try cursor.peek(1) otherwise return false
		if p1.kind == TokenKind.rightParen 'emptyParams'
			let p2 = try cursor.peek(2) otherwise return false
			return p2.kind == TokenKind.gives
		end 'emptyParams'
		// `(name TYPE...` — name is identifier (or `_`, lexed as identifier
		// with value "_"). TYPE must be a parseTypeRef opener: an identifier
		// or a `(`.
		if p1.kind != TokenKind.identifier 'notIdent'
			return false
		end 'notIdent'
		let p2 = try cursor.peek(2) otherwise return false
		if p2.kind == TokenKind.identifier or p2.kind == TokenKind.leftParen 'isTypeStart'
			return true
		end 'isTypeStart'
		// `(name)` followed by `gives` — untyped single-param closure.
		if p2.kind == TokenKind.rightParen 'noTypeOneParam'
			let p3 = try cursor.peek(3) otherwise return false
			return p3.kind == TokenKind.gives
		end 'noTypeOneParam'
		// `(name,` — possibly an untyped multi-param closure OR a tuple
		// expression. Scan past balanced parens to the matching `)` and
		// check whether `gives` follows; this is the only way to
		// distinguish `(a, b) gives a` from the tuple `(a, b)`.
		if p2.kind == TokenKind.comma 'maybeMultiUntyped'
			var depth = 1
			var offset = 2
			while depth > 0 'scanBalanced'
				let tok = try cursor.peek(offset) otherwise return false
				if tok.kind == TokenKind.leftParen 'lp'
					depth = depth + 1
				end 'lp' else if tok.kind == TokenKind.rightParen 'rp'
					depth = depth - 1
				end 'rp'
				offset = offset + 1
				// Safety bound — closure headers should not exceed this in
				// practice; bail rather than scanning the entire stream.
				if offset > 128 'tooFar'
					return false
				end 'tooFar'
			end 'scanBalanced'
			let after = try cursor.peek(offset) otherwise return false
			return after.kind == TokenKind.gives
		end 'maybeMultiUntyped'
		return false
	end 'isClosure'

	// Stage B (closures): parse a closure-literal expression and emit a
	// `MaxonOp.functionRef` at the call site. The closure body becomes a
	// fresh `IrFunction` named `_$closure_<N>` appended to the current
	// module.
	//
	// entry: cursor AT the leading `(` (verified by `isClosure`).
	// exit:  cursor AT the first token AFTER the body expression.
	//
	// Capture analysis is Stage E. For now the lifted body parses against
	// the OUTER scope — references to outer locals will lookup directly,
	// which is incorrect at runtime but acceptable for Stages B+C: the
	// only currently-passing target is the `() gives self` shape inside a
	// free function (test 3), where `parseSelfInstanceExpr` reports E2001
	// before the body finishes parsing.
	function parseClosure(block IrBlock) returns ExprResult throws ParserError
		let leftParenToken = try consume()
		let closureRange = SourceRange.ofToken(leftParenToken)

		// Parse closure parameters. The `_` underscore name is allowed (it
		// is the conventional ignore-the-arg shape used by tests 1 and 2);
		// other identifiers go through the standard reserved-name check.
		var paramNames = StringArray.create()
		var paramTypes = MaxonTypeArray.create()
		var paramCount = 0
		while not at(TokenKind.rightParen) 'paramLoop'
			let nameToken = try consumeExpecting("closure parameter name")
			if nameToken.kind != TokenKind.identifier 'badName'
				reportTokenMismatch(nameToken, expectedDisplay: "closure parameter name")
				synchronize()
				return ExprResult.direct(ByteArray.create(), valueType: MaxonType.integer)
			end 'badName'
			if nameToken.value != "_" 'notDiscard'
				checkReservedDeclName(nameToken)
			end 'notDiscard'

			// Untyped closure params (`(p) gives ...` / `(a, b) gives ...`)
			// stamp slots `MaxonType.unresolved`; the concrete type is
			// inferred at TypeResolution from the call-arg slot the closure
			// flows into (see propagateClosureArgTypesFromCall). A type-ref
			// is expected only when the next token starts one — an
			// identifier or `(` — so that untyped params followed by `,` or
			// `)` skip straight to the next slot without consuming the
			// trailing punctuation.
			let nextTok = cursor.current()
			var paramType = MaxonType.unresolved
			if nextTok.kind == TokenKind.identifier or nextTok.kind == TokenKind.leftParen 'hasType'
				paramType = try parseTypeRef()
			end 'hasType'
			paramNames.push(nameToken.value)
			paramTypes.push(paramType)
			paramCount = paramCount + 1
			if at(TokenKind.rightParen) 'doneClosureParams'
				break
			end 'doneClosureParams'
			try expect(TokenKind.comma)
		end 'paramLoop'

		try expect(TokenKind.rightParen)
		try eat(TokenKind.gives)

		// Mint the lifted-function name. Per-project counter — see
		// Project.nextClosureId. Two closures in the same module always
		// get distinct ids, and two closures in different modules can
		// safely co-exist when their modules merge.
		let closureNum = project.nextClosureId()
		let closureName = "_$closure_{closureNum}"

		// We don't yet know the body's return type — it falls out of the
		// body expression once parsed. Construct the IrFunction with an
		// `unresolved` placeholder return type and patch it after the
		// body emits its `ret`. The function-type registry entry is
		// created the same way and replaced once the body settles, so
		// downstream type-flow sees a concrete signature rather than the
		// placeholder.
		let placeholderReturn = MaxonReturnType.value(MaxonType.unresolved)
		var liftedFunc = IrFunction.create(closureName, maxonReturnType: placeholderReturn, paramCount: paramCount, maxonParamTypes: paramTypes, returnLine: leftParenToken.line)
		liftedFunc.namespace = namespace
		liftedFunc.visibility = Visibility.file
		liftedFunc.sourceFilePath = filePath

		// Save the parser's per-function context so we can switch into the
		// lifted function for body parsing and restore on exit. Closures
		// nested inside enclosing instance methods share `currentTypeName`
		// — `self` inside the closure body still resolves against the
		// enclosing type, but the access is rewritten by `emitSelfLoad`
		// into a `closureEnvLoad` that recovers the captured `__self`
		// pointer at runtime instead of the lifted function's
		// non-existent `__self` slot.
		let savedFunc = currentFunc
		let savedBlock = currentBlock
		let savedScope = scope
		let savedParamLocations = paramLocations
		let savedReferencedVars = referencedVars
		let savedSynthCounter = synthNameCounter
		// Stage E (closures): save outer closure-state so nested closures
		// don't leak captures into one another. The body parses with
		// `inClosure = true`, the outer scope visible via
		// `closureOuterScope` (used by the capture lookup branches in
		// `emitSelfLoad` / `parseIdentifierExpr`), and a fresh empty
		// `closureCaptures` array that fills as captures are encountered.
		let savedInClosure = inClosure
		let savedOuterScope = closureOuterScope
		let savedCaptures = closureCaptures

		// Switch into the lifted function. Each closure body gets a fresh
		// scope and synth-name space so the outer function's slot
		// numbering is undisturbed when we restore. Param locations and
		// referenced-var tracking are also reset; the lifted function
		// runs its own (lightweight) unused-param check below.
		currentFunc = liftedFunc
		currentBlock = module.addBlockAt(liftedFunc, label: "entry", filePath: filePath.toString(), firstLine: leftParenToken.line)
		scope = Scope.create()
		paramLocations = ParamLocationArray.create()
		localVarLocations = ParamLocationArray.create()
		referencedVars = ReferencedVarSet.create()
		synthNameCounter = 0
		inClosure = true
		closureOuterScope = savedScope
		closureCaptures = CaptureInfoArray.create()

		// Register each param in the lifted function's fresh scope so
		// in-body references resolve through the parser's normal
		// `lookupVariable` path.
		for i in 0 upto paramCount 'pushParam'
			let pName = try paramNames.get(i) otherwise panic("parseClosure: paramNames.get OOB at {i}")
			let pType = try paramTypes.get(i) otherwise panic("parseClosure: paramTypes.get OOB at {i}")
			if pName != "_" 'realName'
				_ = defineVariableWithType(pName, varType: pType)
				paramLocations.push(ParamLocation.create(pName, line: leftParenToken.line, column: leftParenToken.column))
			end 'realName'
		end 'pushParam'

		// Parse the body expression into the lifted function's entry block.
		let bodyResult = try parseExpression(currentBlock)
		let bodyType = exprType(bodyResult)
		let bodyName = exprName(bodyResult)

		// Emit the closure body's terminator: `ret <bodyValue>`.
		// `currentBlock` may have advanced if the body expression spawned
		// short-circuit blocks; the final emission lands wherever control
		// flow currently sits.
		module.setTerminator(currentBlock, op: MaxonOp.ret(bodyName, range: closureRange))

		// Stage E (closures): if any captures were recorded, append a
		// synthetic `__env i64` param to the lifted function so its ABI
		// shape matches a function-typed param's expanded (fnPtr, env)
		// pair. The env-param does NOT join the FunctionTypeRegistry
		// signature nor the FuncSignature.paramNames — those describe the
		// user-facing shape `(Integer) returns Integer`, which is what
		// `apply`'s caller passes around. The hidden env param is plumbed
		// through the `fnEnvVarNames` map at lowering time. Capturing
		// closures emit `closureCreate`; non-capturing closures stay at
		// `functionRef` with a null env at the indirect-call site.
		//
		// Snapshot the user-facing arrays BEFORE we mutate
		// `liftedFunc.maxonParamTypes` (which aliases the local
		// `paramTypes` reference); FunctionTypeRegistry and FuncSignature
		// must see the un-augmented param list.
		let captures = closureCaptures
		let captureCount = captures.count()
		var userParamTypes = MaxonTypeArray.create()
		var userParamNames = StringArray.create()
		for i in 0 upto paramCount 'snapshotUserParams'
			let pt = try paramTypes.get(i) otherwise panic("parseClosure: paramTypes.get OOB at {i} during snapshot")
			let pn = try paramNames.get(i) otherwise panic("parseClosure: paramNames.get OOB at {i} during snapshot")
			userParamTypes.push(pt)
			userParamNames.push(pn)
		end 'snapshotUserParams'
		// Every lifted closure body — capturing or not — must accept the
		// hidden `__env` param. Non-capturing closures still flow through
		// the indirect-call ABI (`apply(f, x)` where `f` came from a
		// `functionRef`), and wasm's `call_indirect` requires the table
		// element's signature to match the call site's expected signature
		// exactly, env arg included. Without this, a non-capturing closure
		// table entry has shape `(args) -> R` while the call site pushes
		// `[args, env]` and call_indirect traps with "indirect call type
		// mismatch". For capturing closures, body lowering reads the env
		// via `closureEnvLoad`; for non-capturing ones it stays unused.
		liftedFunc.maxonParamTypes.push(MaxonType.integer)
		liftedFunc.paramCount = liftedFunc.paramCount + 1

		// Patch the lifted function's return type now that the body type
		// is known, and rewrite the function-type registry entry to match.
		let actualReturn = MaxonReturnType.value(bodyType)
		liftedFunc.maxonReturnType = actualReturn
		// Intern the user-facing signature (without the hidden env param)
		// so callers passing this closure to a `(T) returns R`-typed param
		// see a structurally compatible id.
		let fnTypeId = internFunctionType(project, paramTypes: userParamTypes, returnType: actualReturn)

		// Restore the outer function's parser context. Body parsing is
		// done; outer parsing resumes from the token immediately after
		// the body expression.
		currentFunc = savedFunc
		currentBlock = savedBlock
		scope = savedScope
		paramLocations = savedParamLocations
		referencedVars = savedReferencedVars
		synthNameCounter = savedSynthCounter
		inClosure = savedInClosure
		closureOuterScope = savedOuterScope
		closureCaptures = savedCaptures

		// Append the lifted function to the module and register its
		// signature so direct-call resolution works. Closures are
		// file-private — never cross-file callable by name. The
		// signature stored here mirrors the user-facing param list
		// (without `__env`) so source-level slot fill, default
		// insertion, and type-checking of an indirectly-called closure
		// reuse the same machinery as a normal call.
		module.functions.push(liftedFunc)
		var closureParamDefaults = ParamDefaultArray.create()
		for _ in 0 upto paramCount 'pushDefaults'
			closureParamDefaults.push(ParamDefault.none)
		end 'pushDefaults'
		try project.funcReturnTypes.insert(closureName, value: actualReturn) otherwise panic("parseClosure: duplicate closure name '{closureName}' — counter desync")
		try project.funcSignatures.insert(closureName, value: FuncSignature.create(userParamNames, paramTypes: userParamTypes, paramDefaults: closureParamDefaults)) otherwise panic("parseClosure: duplicate funcSignatures entry for '{closureName}'")
		try project.funcVisibilities.insert(closureName, value: FuncVisibilityInfo.create(Visibility.file, sourceFilePath: filePath)) otherwise ignore

		let resultName = freshSynthName()
		if captureCount > 0 'emitCreate'
			// Materialize the parallel arrays the `closureCreate` op
			// carries: capture names in source-encounter order
			// (matches env-array slot index) and their MaxonTypes for
			// load-width selection at lowering time.
			var capturedNames = StringArray.create()
			var capturedTypes = MaxonTypeArray.create()
			for i in 0 upto captureCount 'eachCap'
				let info = try captures.get(i) otherwise panic("parseClosure: captures.get OOB at {i}")
				capturedNames.push(info.name)
				capturedTypes.push(info.captureType)
			end 'eachCap'
			module.appendOp(block, op: MaxonOp.closureCreate(resultName, funcName: closureName, fnTypeId: fnTypeId, capturedNames: capturedNames, capturedTypes: capturedTypes, range: closureRange))
		end 'emitCreate' else 'emitRef'
			module.appendOp(block, op: MaxonOp.functionRef(resultName, funcName: closureName, fnTypeId: fnTypeId, range: closureRange))
		end 'emitRef'
		return ExprResult.direct(resultName, valueType: MaxonType.function(fnTypeId))
	end 'parseClosure'

	// Return the current token and advance past it. If the consumed token was
	// the last in the stream, cursor stays at last-valid — consistent with
	// the exit-AT-last-consumed contract at helper boundaries.
	function consume() returns Token throws ParserError
		let token = cursor.current()
		try cursor.advance() otherwise 'eof'
			// Pre-flight EOF report — without this, the throw propagates
			// silently up to queryParseOps and falls back to a generic
			// "Unexpected end of input" with no context. The caller
			// should set `consumeExpectedDisplay` before invoking via the
			// `consumeExpecting` wrapper; otherwise it falls back to
			// "more input".
			reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "Unexpected end of input, expected {consumeExpectedDisplay}", line: token.line, column: token.column, filePath: filePath)
			throw ParserError.unexpectedEof
		end 'eof'
		return token
	end 'consume'

	// Like consume(), but sets the EOF-diagnostic context first. Use this
	// at sites where the next token has a specific user-facing role so
	// truncated-source diagnostics tell the user what was missing.
	function consumeExpecting(expectedDisplay String) returns Token throws ParserError
		consumeExpectedDisplay = expectedDisplay
		return try consume()
	end 'consumeExpecting'

	// Verify the current token is `kind` and advance past it. Advancing off
	// the end of the stream throws ParserError.unexpectedEof so callers don't
	// have to rescue a silent success separately — anything that still needs
	// work after `expect` can rely on a valid next token. Wrong-kind reports
	// parserExpectedToken (or parserUnexpectedEof for synthetic EOF) and
	// returns without advancing.
	function expect(kind TokenKind) throws ParserError
		if cursor.current().kind != kind 'matched'
			let token = cursor.current()
			reportTokenMismatch(token, expectedDisplay: tokenKindDisplay(kind))
			// Advance past the bad token to a statement/top-level boundary.
			// Without this, the calling helper typically re-reads the same
			// bad token and emits a follow-up diagnostic — exactly the
			// cascade pattern the first-error gate was added to suppress.
			// Synchronizing here avoids relying on the gate.
			synchronize()
			return
		end 'matched'

		try cursor.advance() otherwise throw ParserError.unexpectedEof
	end 'expect'

	// Shared helper: emit either "Unexpected end of input, expected X" or
	// "Expected X but got 'value'" depending on whether `token` represents
	// a real EOF / empty-content token (newline, eof sentinel) or a
	// genuine wrong-kind token. `expectedDisplay` is the user-facing
	// description of what was wanted (`tokenKindDisplay(kind)`, "type name",
	// "expression", etc.). `wrongKindCode` lets callers in expression
	// position emit `parserExpectedExpression` (E2004) instead of the
	// default `parserExpectedToken` (E2010); the EOF path always uses
	// `parserUnexpectedEof` (E2007).
	function reportTokenMismatch(token Token, expectedDisplay String, wrongKindCode ErrorCode = ErrorCode.parserExpectedToken)
		// True EOF (cursor on last token + only empty-content tokens
		// remaining), OR a stringInterpEnd in expression position (the
		// closing `}` of an interpolation acts like EOF for the inner
		// expression — there's nowhere left for the expression to grow).
		// In either case, surface as "Unexpected end of input" to match
		// C#'s phrasing rather than reporting the literal `}` or a trailing
		// `(empty)` newline that the user didn't write.
		let isInterpClose = token.kind == TokenKind.stringInterpEnd
		if isInterpClose or ((token.kind == TokenKind.eof or token.value.isEmpty()) and not hasMoreTokens()) 'isEof'
			reportCompileError(project, code: ErrorCode.parserUnexpectedEof, message: "Unexpected end of input, expected {expectedDisplay}", line: token.line, column: token.column, filePath: filePath)
			return
		end 'isEof'
		// Expression-position diagnostics render newline / empty values as the
		// literal text "(empty)"; other paths render them as the empty string
		// itself. Mirrors the split between FormatTokenValueForError and raw
		// `Current().Value` in the C# bootstrap.
		var displayValue = tokenValueToString(token.value)
		if wrongKindCode.rawValue == ErrorCode.parserExpectedExpression.rawValue 'expressionForm'
			displayValue = formatExpressionTokenValue(token.value)
		end 'expressionForm'
		reportCompileError(project, code: wrongKindCode, message: "Expected {expectedDisplay} but got '{displayValue}'", line: token.line, column: token.column, filePath: filePath)
	end 'reportTokenMismatch'

	// Returns true if there's at least one non-empty token at or after the
	// current cursor position. Used to distinguish "unexpected newline at
	// statement boundary" (more code follows) from "truly truncated input".
	function hasMoreTokens() returns bool
		var idx = cursor.index() + 1
		for _ in 0 upto 100 'lookahead'
			let tok = try cursor.peek(idx - cursor.index()) otherwise return false
			if not tok.value.isEmpty() and tok.kind != TokenKind.newline 'foundContent'
				return true
			end 'foundContent'
			idx = idx + 1
		end 'lookahead'
		return false
	end 'hasMoreTokens'

	// Is the current token of kind `kind`? Pure peek — no advance, no EOF
	// throw. Use this to branch on the cursor.
	function at(kind TokenKind) returns bool
		return cursor.current().kind == kind
	end 'at'

	// Returns the most recently consumed token (the one before the cursor).
	// Use this for source-range capture after a parseX call: stream-style
	// helpers exit past their last token, so cursor.current() is one too
	// far for SourceRange.between(start, last: ...).
	function previousToken() returns Token
		let idx = cursor.index()
		if idx == 0 'atStart'
			return cursor.current()
		end 'atStart'
		return try tokens.get(idx - 1) otherwise panic("Parser.previousToken: index {idx - 1} out of bounds")
	end 'previousToken'

	// Is the token at peek(offset) of kind `kind`? Tolerates EOF — returns
	// false if the lookahead exhausts the cursor. Use for multi-token
	// shape-matching where you want to commit only if every position lines up.
	function atOffset(kind TokenKind, offset ElementCount) returns bool
		let tok = try cursor.peek(offset) otherwise return false
		return tok.kind == kind
	end 'atOffset'

	// If the current token matches `kind`, consume it (advancing past it,
	// silently tolerating EOF) and return true. Otherwise leave the cursor in
	// place and return false. Use for optional consumption where you need
	// to know whether the token was there.
	function accept(kind TokenKind) returns bool
		if cursor.current().kind != kind 'noMatch'
			return false
		end 'noMatch'
		try cursor.advance() otherwise return true
		return true
	end 'accept'

	// Advance past the current token, asserting that it has kind `kind`.
	// Mismatch is a parser-bug class panic — `eat` is for kinds you've
	// already proven via at()/peek/dispatch, where a wrong kind means the
	// surrounding control flow is broken, not that the user typed something
	// wrong. EOF rethrows as ParserError.unexpectedEof. No diagnostic.
	function eat(kind TokenKind) throws ParserError
		if cursor.current().kind != kind 'mismatch'
			panic("Parser.eat({tokenKindDisplay(kind)}): expected by caller, got '{tokenValueToString(cursor.current().value)}' (kind={cursor.current().kind})")
		end 'mismatch'
		try cursor.advance() otherwise throw ParserError.unexpectedEof
	end 'eat'

	// Advance past consecutive newline tokens. Exits with cursor AT the next
	// non-newline. Throws ParserError.unexpectedEof if the cursor exhausts
	// while skipping — call sites that expect more content after the blank
	// lines (mid-construct: between fields, after `end 'label'`, etc.) get
	// a clean error rather than a silent fallthrough.
	function skipNewlines() throws ParserError
		while at(TokenKind.newline) 'skip'
			try cursor.advance() otherwise throw ParserError.unexpectedEof
		end 'skip'
	end 'skipNewlines'

	// Like skipNewlines, but tolerates EOF — returns true when there's still
	// content to parse, false when the cursor is exhausted. For top-level
	// dispatch loops where trailing newlines are a normal end-of-file shape.
	function skipOptionalNewlines() returns bool
		while at(TokenKind.newline) 'skip'
			try cursor.advance() otherwise return false
		end 'skip'
		// EOF sentinel marks the end of the user-visible token stream — treat
		// it like exhaustion so callers stop dispatching once nothing real
		// remains.
		if at(TokenKind.eof) 'isEof'
			return false
		end 'isEof'
		return cursor.index() < tokens.count()
	end 'skipOptionalNewlines'

	function expectNewlineAfterLabel() throws ParserError
		if cursor.current().kind != TokenKind.newline 'noNewline'
			let token = cursor.current()
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "Expected newline after block label, got '{tokenValueToString(token.value)}'", line: token.line, column: token.column, filePath: filePath)
		end 'noNewline'
		try skipNewlines()
	end 'expectNewlineAfterLabel'

	// Parse an optional block label of the form `'label'` after control-flow
	// keywords like `if` or `while`. Returns the label string if present,
	// otherwise the provided default. Consumes the trailing newline in both cases.
	function parseOptionalBlockLabel(defaultLabel String) returns String throws ParserError
		if at(TokenKind.charLiteral) 'hasLabel'
			let labelToken = try consume()
			try expectNewlineAfterLabel()
			return labelToken.value
		end 'hasLabel'
		try skipNewlines()
		return defaultLabel
	end 'parseOptionalBlockLabel'

	// entry: cursor AT `end`.
	// exit:  cursor on the token AFTER `end` (or after its label if present),
	//        or at exhaustion if `end` was the last token.
	function skipEndAndLabel() throws ParserError
		if not at(TokenKind.end) 'notEnd'
			reportTokenMismatch(cursor.current(), expectedDisplay: "'end'")
			synchronize()
			return
		end 'notEnd'
		// Step past `end`. EOF here means the file ended after `end` — that's fine.
		try cursor.advance() otherwise return
		if at(TokenKind.charLiteral) 'hasLabel'
			try cursor.advance() otherwise return
		end 'hasLabel'
	end 'skipEndAndLabel'

	function skipToNextLine()
		// Iterate until we land on a newline (or exhaust at EOF). Body breaks
		// the moment we see one, leaving cursor AT the newline. EOF stops the
		// scan without consuming the sentinel so callers stay parked on a
		// valid position.
		while not at(TokenKind.newline) and not at(TokenKind.eof) 'skip'
			try cursor.advance() otherwise return
		end 'skip'
	end 'skipToNextLine'

	// Error recovery: skip to next statement boundary.
	// Always advances at least 1 token to prevent infinite loops. Swallows
	// exhaustion because we're already in an error-recovery state.
	function synchronize()
		try cursor.advance() otherwise return
		// Stop at the next newline or `end`, or park on the EOF sentinel
		// without consuming it.
		while not at(TokenKind.end) and not at(TokenKind.newline) and not at(TokenKind.eof) 'sync'
			try cursor.advance() otherwise return
		end 'sync'
	end 'synchronize'

	// Synchronize to the next top-level declaration after an error.
	function synchronizeToTopLevel()
		while not isTopLevelOpener(cursor.current().kind) and not at(TokenKind.export) and not at(TokenKind.eof) 'sync'
			try cursor.advance() otherwise return
		end 'sync'
	end 'synchronizeToTopLevel'

	// --- Emission helpers ---

	// Mint a fresh synthetic intermediate name. Used for every op result that
	// doesn't directly correspond to a source-level variable (e.g. the result
	// of `a + b`). The `$t` prefix keeps these names disjoint from any
	// lexer-emitted identifier. Counter resets per function in resetSymbolTable.
	//
	// synthNameCache is keyed by counter value and grown on demand — the first
	// time we mint `$tN`, we allocate the ByteArray and push it at index N;
	// subsequent functions in the same Parser reuse the same entry without
	// re-allocating. Since synthNameCounter resets per function, entries
	// 0..K stay hot across the whole parse.
	function freshSynthName() returns ByteArray
		let n = synthNameCounter
		synthNameCounter = synthNameCounter + 1
		if n < synthNameCache.count() 'cached'
			return try synthNameCache.get(n) otherwise panic("freshSynthName: count() said {synthNameCache.count()} > {n} but get failed")
		end 'cached'
		// Cache miss: this is the first time the counter has reached n. By
		// construction n == synthNameCache.count(), so pushing appends at
		// exactly the right index.
		let name = "$t{n}".toByteArray()
		synthNameCache.push(name)
		return name
	end 'freshSynthName'

	// When the literal has an originating source token (int/float/bool
	// literal, type-bound constant like `u64.max`), callers pass its range
	// so hover/rename can map back to the source. Compiler-synthesized
	// literals (zero for implicit return, struct-byte-size, default arg
	// fallback) pass `SourceRange.none()` because they have no source origin.
	function emitLiteral(block IrBlock, value ParsedInt, valueType MaxonType, range SourceRange = SourceRange.none()) returns ByteArray
		let name = freshSynthName()
		module.appendOp(block, op: MaxonOp.literal(name, value: value, valueType: valueType, range: range))
		return name
	end 'emitLiteral'

	function emitImplicitReturn(block IrBlock)
		let zeroName = emitLiteral(block, value: 0, valueType: MaxonType.integer)
		module.setTerminator(block, op: MaxonOp.ret(zeroName, range: SourceRange.none()))
	end 'emitImplicitReturn'

	// Emit a varLoad for the implicit `__self` slot and return the fresh name
	// that holds the struct pointer. Caller must ensure we are inside an
	// instance method — in a static context lookupVariable("__self", …) will
	// report "Undefined variable '__self'".
	//
	// Inside a closure body (`inClosure == true`), `__self` lives in the
	// enclosing instance method's scope, NOT in the lifted function's fresh
	// scope. We re-route through the capture machinery: record the capture
	// (deduped by name) and emit a `closureEnvLoad` whose lowering walks the
	// hidden `__env` parameter to recover the captured pointer. Without this
	// branch the lifted body would crash at parse time with
	// "Undefined variable '__self'".
	function emitSelfLoad(block IrBlock, token Token, range SourceRange) returns ByteArray
		let selfType = internMaxonType(project, name: currentTypeName)
		if inClosure and not scope.contains("__self") and closureOuterScope.contains("__self") 'captureSelf'
			return emitClosureCapture(block, name: "__self", captureType: selfType, range: range)
		end 'captureSelf'
		let selfSlot = lookupVariable("__self", token: token)
		let selfLoadName = freshSynthName()
		module.appendOp(block, op: MaxonOp.varLoad(selfLoadName, slotId: selfSlot, slotType: selfType, range: range))
		return selfLoadName
	end 'emitSelfLoad'

	// Stage E (closures): record (or reuse) a capture entry for `name` and
	// emit the corresponding `closureEnvLoad` op against the current closure
	// body block. Returns the fresh result name so callers can compose it
	// into postfix expressions (`self.field`, `self.method()`, etc.) without
	// caring whether the receiver came from a `varLoad` or a capture chain.
	// Capture index assignment is monotonic in source-encounter order, so
	// `closureCreate` later mirrors the same order when storing captured
	// addresses into env[i].
	function emitClosureCapture(block IrBlock, name String, captureType MaxonType, range SourceRange) returns ByteArray
		var idx = -1
		for i in 0 upto closureCaptures.count() 'scan'
			let info = try closureCaptures.get(i) otherwise panic("emitClosureCapture: closureCaptures.get OOB at {i}")
			if info.name == name 'hit'
				idx = i
				break
			end 'hit'
		end 'scan'
		if idx < 0 'fresh'
			idx = closureCaptures.count()
			closureCaptures.push(CaptureInfo.create(name, captureType: captureType, index: idx))
		end 'fresh'
		let resultName = freshSynthName()
		module.appendOp(block, op: MaxonOp.closureEnvLoad(resultName, captureIndex: idx, captureName: name.toByteArray(), captureType: captureType, range: range))
		return resultName
	end 'emitClosureCapture'

	// Emit `self.<fieldName> = <valueName>` — load self then store the value at
	// the resolved field offset. Shared by implicit (`field = v`) and explicit
	// (`self.field = v`) field-assign parse paths; both reuse the same range
	// for the self-load and the store to keep debug info attached to the full
	// statement rather than to a synthetic receiver.
	function emitSelfFieldStore(block IrBlock, fieldName String, valueName ByteArray, range SourceRange)
		module.appendOp(block, op: MaxonOp.selfFieldStore(fieldName: fieldName.toByteArray(), value: valueName, range: range))
	end 'emitSelfFieldStore'

	// Diagnose bare `self` outside any type body. Returns true when we are
	// NOT inside a type (caller should return early). Keeps the error message
	// consistent between statement- and expression-context `self`.
	function reportSelfOutsideType(token Token) returns bool
		if currentTypeName.isEmpty() 'notInType'
			// Stage C (closures): emit E2001 with the spec's plural phrasing —
			// "instance methods" — matching closure-self's error fixture and
			// the C# bootstrap.
			reportCompileError(project, code: ErrorCode.parserUnexpectedToken, message: "'self' can only be used inside instance methods", line: token.line, column: token.column, filePath: filePath)
			return true
		end 'notInType'
		return false
	end 'reportSelfOutsideType'

	// Finalize an if/else by emitting the condBr and returning either a
	// detached block (both branches terminated) or a new merge block.
	// Uses captured block IDs to avoid stale references from nested parsing.
	// `mergeLine` is the source line for the synthetic merge block — typically
	// the line just past the if's closing `end`, i.e. where post-if statements
	// will land.
	function finalizeIfElseById(func IrFunction, condBlock IrBlock, condName ByteArray, thenBlockId BlockId, thenExit IrBlock, elseBlockId BlockId, elseExit IrBlock, baseLabel String, mergeLine LineNumber) returns IrBlock
		module.setTerminator(condBlock, op: MaxonOp.condBr(condName, thenTarget: thenBlockId, elseTarget: elseBlockId, range: SourceRange.none()))
		// isTerminated covers both real terminators and dead blocks, so
		// a branch whose arm ends in a fully-terminated nested if/else
		// contributes no live path to the merge.
		if thenExit.isTerminated() and elseExit.isTerminated() 'bothTerminated'
			return newDetachedBlock(func)
		end 'bothTerminated'
		let mergeBlock = module.addBlockAt(func, label: "{baseLabel}.merge", filePath: filePath.toString(), firstLine: mergeLine)
		branchIfNeeded(thenExit, target: mergeBlock.id)
		branchIfNeeded(elseExit, target: mergeBlock.id)
		return mergeBlock
	end 'finalizeIfElseById'

	function branchIfNeeded(block IrBlock, target BlockId)
		// Dead blocks are already terminated (unreachably), so isTerminated
		// is enough — leaving them without an op keeps them absent from the CFG.
		if not block.isTerminated() 'needsBranch'
			module.setTerminator(block, op: MaxonOp.br(target, range: SourceRange.none()))
		end 'needsBranch'
	end 'branchIfNeeded'

	// --- Symbol table helpers ---

	function resetSymbolTable()
		// Allocate a fresh Scope rather than mutating in place. The
		// previous function's `func.scope` field on its IrFunction holds
		// a reference to its Scope object — calling `scope.reset()` here
		// would wipe that object too, breaking downstream consumers that
		// later read the prior function's scope (Stage E's
		// `lookupOuterSlotForCapture` walks the enclosing function's
		// scope to resolve captured slot ids long after parsing finished).
		scope = Scope.create()
		paramLocations = ParamLocationArray.create()
		localVarLocations = ParamLocationArray.create()
		referencedVars = ReferencedVarSet.create()
		synthNameCounter = 0
		// Phase 9 Stage 5: reset the per-function struct-backed enum-case
		// bindings so a fresh function doesn't see stale `let op = Op.mul`
		// entries from the previous body.
		letStructBackedEnumCases = StructBackedEnumCaseBindingMap.create()
	end 'resetSymbolTable'

	// Defer this function's unused-variable check (E3012) onto Project so
	// SemanticCheck can run it after TypeResolution has reported any primary
	// diagnostics for the same body. Parameters are pushed first, locals
	// after — that order lets the consumer report parameters before locals
	// (matching the C# bootstrap's first-issue-wins emission). `_` parameters
	// are the discard convention and are filtered out at capture time.
	//
	// Phase 11.7: parameters of methods that satisfy an interface's required
	// signature are dictated by the interface — record `skipParamCheck` so
	// the consumer skips the param scan but still reports unused locals
	// (interface-method-unused-param-allowed accepts unused params; the
	// matching local-still-errors test still requires a local check).
	function checkUnusedParameters(methodName String, isMethod bool, startLine LineNumber, endLine LineNumber)
		let skipParamCheck = isMethod and isInterfaceRequiredMethod(methodName)
		var candidates = UnusedCandidateArray.create()
		for param in paramLocations 'eachParam'
			if param.name == "_" 'isDiscard'
				continue
			end 'isDiscard'
			candidates.push(UnusedCandidate.create(param.name, line: param.line, column: param.column))
		end 'eachParam'
		let paramCount = candidates.count()
		for local in localVarLocations 'eachLocal'
			candidates.push(UnusedCandidate.create(local.name, line: local.line, column: local.column))
		end 'eachLocal'

		if candidates.count() == 0 'nothingToCheck'
			return
		end 'nothingToCheck'

		var referenced = ReferencedNameSet.create()
		for name in referencedVars 'eachRef'
			referenced.insert(element: name)
		end 'eachRef'

		project.pendingUnusedChecks.push(PendingUnusedCheck.create(filePath, candidates: candidates, referenced: referenced, skipParamCheck: skipParamCheck, paramCount: paramCount, startLine: startLine, endLine: endLine))
	end 'checkUnusedParameters'

	// Phase 11.7: does the enclosing type's `implements` list (transitively
	// via `interface I extends Base`) declare a method named `methodName`?
	// Resolved interfaces sit in `project.interfaces`; in-flight ones still
	// in `project.unresolvedInterfaces`. Both registries are consulted.
	function isInterfaceRequiredMethod(methodName String) returns bool
		for conf in currentTypeConformances 'eachConf'
			if interfaceDeclaresMethod(conf.interfaceName, methodName: methodName) 'found'
				return true
			end 'found'
		end 'eachConf'
		return false
	end 'isInterfaceRequiredMethod'

	// Walk the named interface (resolved or unresolved) and any `extends`
	// parents looking for a method matching `methodName`. The recursion
	// terminates because interface graphs are required to be a DAG (cycle
	// detection happens during interface resolution); a duplicate-visit
	// guard keeps a malformed cycle from looping the parser.
	function interfaceDeclaresMethod(interfaceName String, methodName String) returns bool
		var visited = StringArray.create()
		return interfaceDeclaresMethodHelper(interfaceName, methodName: methodName, visited: visited)
	end 'interfaceDeclaresMethod'

	function interfaceDeclaresMethodHelper(interfaceName String, methodName String, visited StringArray) returns bool
		for v in visited 'cycleGuard'
			if v == interfaceName 'seen'
				return false
			end 'seen'
		end 'cycleGuard'
		visited.push(interfaceName)
		if let unresolved = try project.unresolvedInterfaces.get(interfaceName) 'fromUnresolved'
			for m in unresolved.methods 'eachMethod'
				if m.name == methodName 'match'
					return true
				end 'match'
			end 'eachMethod'
			for parent in unresolved.extendsNames 'eachParent'
				if interfaceDeclaresMethodHelper(parent, methodName: methodName, visited: visited) 'parentMatch'
					return true
				end 'parentMatch'
			end 'eachParent'
			return false
		end 'fromUnresolved'
		if let resolved = try project.interfaces.get(interfaceName) 'fromResolved'
			for m in resolved.methods 'eachMethod'
				if m.name == methodName 'match'
					return true
				end 'match'
			end 'eachMethod'
			for parent in resolved.extendsNames 'eachParent'
				if interfaceDeclaresMethodHelper(parent, methodName: methodName, visited: visited) 'parentMatch'
					return true
				end 'parentMatch'
			end 'eachParent'
		end 'fromResolved'
		return false
	end 'interfaceDeclaresMethodHelper'

	// Declare a variable carrying the given source-level MaxonType. Slot
	// width is NOT picked here — lowerMaxonToStd resolves MaxonType via the
	// typealias registry after TypeResolution has run.
	function defineVariableWithType(name String, varType MaxonType) returns VarSlot
		return scope.declare(name, varType: varType, mutable: true)
	end 'defineVariableWithType'

	function lookupVariable(name String, token Token) returns VarSlot
		if let slot = try scope.lookup(name) 'found'
			referencedVars.insert(element: name)
			return slot
		end 'found'
		reportCompileError(project, code: ErrorCode.parserExpectedExpression, message: "Undefined variable '{tokenValueToString(name)}'", line: token.line, column: token.column, filePath: filePath)
		return 0
	end 'lookupVariable'

	function parseScopedStatements(func IrFunction, block IrBlock) returns IrBlock throws ParserError
		scope.pushScope()
		var lastWasReturn = false
		let exitBlock = try parseStatements(func, block: block, lastWasReturn: lastWasReturn)
		scope.popScope()
		return exitBlock
	end 'parseScopedStatements'
end 'Parser'

// Result for the parser-time varLoad lookup in `chaseVarLoadProducerType`.
// `matched` is true when the varLoad's result name equals the target name;
// callers must ignore `slot` and `slotType` when `matched` is false.
type VarLoadSlotInfo
	export var matched bool
	export var slot VarSlot
	export var slotType MaxonType

	export static function notMatched() returns VarLoadSlotInfo
		return Self{matched: false, slot: 0 as VarSlot, slotType: MaxonType.unresolved}
	end 'notMatched'

	export static function matchedAt(slot VarSlot, slotType MaxonType) returns VarLoadSlotInfo
		return Self{matched: true, slot: slot, slotType: slotType}
	end 'matchedAt'
end 'VarLoadSlotInfo'

// Result for the parser-time call/tryCall lookup in
// `callResultTypeIfNameMatches`. `matched` is true when the call/tryCall's
// result name equals the target name; callers must ignore `callee` and
// `callContext` when `matched` is false.
type CallProducerInfo
	export var matched bool
	export var callee ByteArray
	export var callContext CallContext

	export static function notMatched() returns CallProducerInfo
		return Self{matched: false, callee: ByteArray.create(), callContext: CallContext.qualified}
	end 'notMatched'

	export static function matched(callee ByteArray, callContext CallContext) returns CallProducerInfo
		return Self{matched: true, callee: callee, callContext: callContext}
	end 'matched'
end 'CallProducerInfo'

// Result for the parser-time varDecl lookup in `chaseVarLoadProducerType`.
// `matched` is true when a varDecl's slotId equals the target slot; callers
// must ignore `value` when `matched` is false.
type VarDeclValueInfo
	export var matched bool
	export var value ByteArray

	export static function notMatched() returns VarDeclValueInfo
		return Self{matched: false, value: ByteArray.create()}
	end 'notMatched'

	export static function matchedWith(value ByteArray) returns VarDeclValueInfo
		return Self{matched: true, value: value}
	end 'matchedWith'
end 'VarDeclValueInfo'

// Per-function set type used by `propagateCharByteThroughVarChains` to flow
// char-byte taint from `varDecl(slot, value)` to subsequent `varLoad(result,
// slot)` ops. Lives stack-local to one function's walk; the project-level
// `charByteLiterals` set accumulates the result names so consumers
// downstream don't need any per-function tracking.
typealias CharByteSlotSet = Set with VarSlot

// Walk every function in `module` once, in op-emission order, extending
// `project.charByteLiterals` with every `varLoad` result that reads a slot
// previously bound to a char-byte value. The literal-emission site already
// recorded raw literal value names at the char-literal parse site; this
// helper picks up the indirect-through-binding case (`let c = 'A'; print
// ("{c}")`) by maintaining a per-function `charByteSlots` set keyed on
// VarSlot.
//
// Semantics:
//   - `varDecl(slot, value, _)` taints `slot` when `value` is a char-byte.
//   - `varLoad(result, slot, _)` against a tainted slot records `result`.
//   - `varStore(slot, value)` re-taints when `value` is char-byte, clears
//     the taint otherwise (overwriting a char-byte var with an unrelated
//     int loses the provenance).
//
// All keys go through `charByteLiteralKey` so the per-function value-name
// space matches the `arrayLiteralProducerKey` scheme used elsewhere.
function propagateCharByteThroughVarChains(project Project, module MaxonModule)
	for func in module.functions 'eachFunc'
		var charByteSlots = CharByteSlotSet.create()
		for blockRef in func.blockRefs 'eachBlock'
			let block = try module.blocks.get(blockRef) otherwise panic("propagateCharByteThroughVarChains: blockRef OOB")
			for opIdx in block.opRefs 'eachOp'
				let op = try module.ops.get(opIdx) otherwise panic("propagateCharByteThroughVarChains: opIdx OOB")
				propagateCharByteForOp(project, op: op, funcName: func.name, charByteSlots: charByteSlots)
			end 'eachOp'
			if block.hasTerminatorOp() 'hasTerm'
				let termIdx = block.terminatorIndex()
				let termOp = try module.ops.get(termIdx) otherwise panic("propagateCharByteThroughVarChains: terminator OOB")
				propagateCharByteForOp(project, op: termOp, funcName: func.name, charByteSlots: charByteSlots)
			end 'hasTerm'
		end 'eachBlock'
	end 'eachFunc'
end 'propagateCharByteThroughVarChains'

function propagateCharByteForOp(project Project, op MaxonOp, funcName String, charByteSlots CharByteSlotSet)
	// Cheap pre-filter on op tag avoids exhaustively listing every other
	// MaxonOp arm just to skip them. The three arms below are the only ones
	// that participate in char-byte slot taint flow.
	if op.name != "varDecl" and op.name != "varLoad" and op.name != "varStore" 'unrelated'
		return
	end 'unrelated'
	match op 'rec'
		varDecl(slotId, value, _, _) then handleCharByteVarDecl(project, funcName: funcName, slotId: slotId, value: value, charByteSlots: charByteSlots)
		varLoad(result, slotId, _, _) then handleCharByteVarLoad(project, funcName: funcName, result: result, slotId: slotId, charByteSlots: charByteSlots)
		varStore(slotId, value, _) then handleCharByteVarStore(project, funcName: funcName, slotId: slotId, value: value, charByteSlots: charByteSlots)
		default panic("propagateCharByteForOp: pre-filter let through op.name={op.name}")
	end 'rec'
end 'propagateCharByteForOp'

function handleCharByteVarDecl(project Project, funcName String, slotId VarSlot, value ByteArray, charByteSlots CharByteSlotSet)
	if project.charByteLiterals.contains(charByteLiteralKey(funcName: funcName, valueName: value)) 'inherit'
		charByteSlots.insert(slotId)
	end 'inherit'
end 'handleCharByteVarDecl'

function handleCharByteVarLoad(project Project, funcName String, result ByteArray, slotId VarSlot, charByteSlots CharByteSlotSet)
	if charByteSlots.contains(slotId) 'tainted'
		project.charByteLiterals.insert(charByteLiteralKey(funcName: funcName, valueName: result))
	end 'tainted'
end 'handleCharByteVarLoad'

function handleCharByteVarStore(project Project, funcName String, slotId VarSlot, value ByteArray, charByteSlots CharByteSlotSet)
	let valueIsCharByte = project.charByteLiterals.contains(charByteLiteralKey(funcName: funcName, valueName: value))
	if valueIsCharByte 'taintNow'
		charByteSlots.insert(slotId)
		return
	end 'taintNow'
	if charByteSlots.contains(slotId) 'wasTainted'
		_ = charByteSlots.remove(slotId)
	end 'wasTainted'
end 'handleCharByteVarStore'

// --- Standalone pure functions ---

// --- MaxonType predicates for parser use ---
// Named types are "unresolved" at parse time: whether they're struct/enum/
// typealias is a property of the registries maintained alongside the parse,
// so helpers consult Project to answer concrete questions.

function maxonTypeIsFloat(t MaxonType) returns bool
	return match t 'check'
		float gives true
		boolean to integer gives false
		string to unresolved gives false
		typeParameter to interface gives false
		constInt gives false
	end 'check'
end 'maxonTypeIsFloat'

// True for numeric and bool primitives — types that have no fields. Used by
// parsePostfix to emit E4006 when source tries to access a field on `(5)` or
// similar. Strings are excluded because String is a struct internally and
// supports method/field-style access. Named/unresolved types are deferred —
// TypeResolution makes the final call when the receiver shape is known.
function maxonTypeIsPrimitive(t MaxonType) returns bool
	// Function types support call syntax, not field access — for E4006's
	// "primitives have no fields" check, function types behave like named
	// values (deferred to TypeResolution). Generic-aware arms (Phase 11.0)
	// behave like named values for the same reason — their concrete shape
	// is decided post-substitution, so primitive-ness can't be determined
	// at parse time.
	return match t 'check'
		boolean to float gives true
		string gives false
		named to unresolved gives false
		typeParameter to interface gives false
		constInt gives false
	end 'check'
end 'maxonTypeIsPrimitive'

function maxonTypeIsBool(t MaxonType) returns bool
	return match t 'check'
		boolean gives true
		integer to unresolved gives false
		typeParameter to interface gives false
		constInt gives false
	end 'check'
end 'maxonTypeIsBool'

function maxonTypeIsInt(t MaxonType) returns bool
	return match t 'check'
		integer gives true
		boolean gives false
		float to unresolved gives false
		typeParameter to interface gives false
		constInt gives false
	end 'check'
end 'maxonTypeIsInt'

// A named type is a "reference" (heap-allocated struct/enum/function) when
// the project knows about it in the corresponding registry. For named types
// that aren't yet registered (forward references across files), we
// conservatively return false; the TypeResolution pass catches truly-unknown
// names after all files have been parsed.
export function maxonTypeIsRef(project Project, t MaxonType) returns bool
	let nameStr = t.nameOrEmpty(project)
	return not nameStr.isEmpty() and project.structTypes.contains(nameStr)
end 'maxonTypeIsRef'

// Thrown by `maxonTypeStructName` when the receiver type doesn't resolve to
// a registered struct or enum (the common cases: primitives, interfaces,
// type parameters, free `unresolved`, or a `named` arm whose name was never
// registered). Callers handle this with `try ... otherwise` to take the
// non-struct path (primitive-extension dispatch, fat-pointer interface
// dispatch, skipped validation, etc.).
export enum MaxonTypeStructNameError implements Error
	notAStruct
end 'MaxonTypeStructNameError'

enum BuiltinArrayLiteralError implements Error
	unresolved
end 'BuiltinArrayLiteralError'

// Probe-style lookup misses for parser-side helpers that walk the enum /
// struct registries without an authoritative single owner. Probes throw
// `notFound` so callers must consciously handle the miss instead of
// distinguishing it from a valid value via a magic sentinel.
enum EnumCaseProbeError implements Error
	notFound
end 'EnumCaseProbeError'

enum StructFieldProbeError implements Error
	notFound
end 'StructFieldProbeError'

// Return the underlying struct-type name for a named MaxonType. Throws
// `MaxonTypeStructNameError.notAStruct` when the type is not currently
// registered as a struct or enum — callers must handle the throw with
// `try ... otherwise` to fall through to the non-struct dispatch path
// (primitive extension, interface witness, etc.). Exported because the
// Maxon→Std lowering pass uses it to resolve receiver types for fieldLoad,
// fieldStore, and methodCall ops the parser now leaves name-symbolic.
export function maxonTypeStructName(project Project, t MaxonType) returns String throws MaxonTypeStructNameError
	let nameStr = t.nameOrEmpty(project)
	if nameStr.isEmpty() 'noName'
		throw MaxonTypeStructNameError.notAStruct
	end 'noName'
	if project.structTypes.contains(nameStr) 'isStruct'
		return nameStr
	end 'isStruct'
	// Stage K.X.A: parse-time callers (parser's tryMethodCall qualifier)
	// run before resolveAllStructTypes has drained
	// `unresolvedStructTypes`, so a concrete user/stdlib struct still
	// lives in the unresolved registry. Recognise it as a struct here so
	// methodCall qualification doesn't fall back to a bare-name lookup
	// that misses funcThrowsTypes / funcReturnTypes (the latter is keyed
	// by qualified `T.method`).
	if project.unresolvedStructTypes.contains(nameStr) 'isUnresolvedStruct'
		return nameStr
	end 'isUnresolvedStruct'
	// Enums share the method-dispatch path with structs: a method call on
	// an enum-typed receiver qualifies the callee with the enum's name.
	// Lookup against `enumTypes` (post-resolution) and `unresolvedEnums`
	// (parse-time, before resolution drains) covers both phases.
	if project.enumTypes.contains(nameStr) or project.unresolvedEnums.contains(nameStr) 'isEnum'
		return nameStr
	end 'isEnum'
	// Generic typealias: `typealias ByteArray = Array with Byte` resolves
	// to `MaxonType.genericInstance(Array<Byte>)` in `genericTypealiases`.
	// Receivers typed via the alias name (e.g. parameter `bytes ByteArray`)
	// arrive here as `MaxonType.named("ByteArray")`; chase through the alias
	// to recover the underlying struct name (`Array`) so field/method
	// lookups against the alias work the same as against the base type.
	if let aliased = try project.genericTypealiases.get(nameStr) 'haveAlias'
		let aliasedName = aliased.nameOrEmpty(project)
		if not aliasedName.isEmpty() 'haveAliasName'
			if project.structTypes.contains(aliasedName) 'aliasIsStruct'
				return aliasedName
			end 'aliasIsStruct'
			if project.enumTypes.contains(aliasedName) or project.unresolvedEnums.contains(aliasedName) 'aliasIsEnum'
				return aliasedName
			end 'aliasIsEnum'
		end 'haveAliasName'
	end 'haveAlias'
	throw MaxonTypeStructNameError.notAStruct
end 'maxonTypeStructName'

// Create a block that is not added to the function's block list.
// Used as a sink for dead code after fully-terminated if/else branches.
// Terminator.dead marks it unreachable so later checks can distinguish
// it from a real block that simply has not had its terminator set yet.
function newDetachedBlock(func IrFunction) returns IrBlock
	let id = func.nextBlockId
	func.nextBlockId = func.nextBlockId + 1
	var block = IrBlock.create(id, label: "dead")
	block.terminator = Terminator.dead
	return block
end 'newDetachedBlock'

// Render a token's value for inclusion in a diagnostic. Empty values render
// as the empty string itself so messages match C#'s "got ''" phrasing for
// EOF / synthetic tokens — matching the call sites that quote `Current().Value`
// directly. Use `formatExpressionTokenValue` for the expression-error path
// (E2004) which substitutes the literal text "(empty)" instead.
function tokenValueToString(value String) returns String
	return value
end 'tokenValueToString'

// Render an empty/newline token value as "(empty)" for the expression-error
// path. Mirrors `FormatTokenValueForError` in the C# bootstrap so messages
// like "Expected expression but got '(empty)'" line up across compilers.
function formatExpressionTokenValue(value String) returns String
	if value.isEmpty() or value == "\n" or value == "\r\n" 'isEmpty'
		return "(empty)"
	end 'isEmpty'
	return value
end 'formatExpressionTokenValue'

// Render a TokenKind for use inside a diagnostic message. Keywords,
// operators, and punctuation get wrapped in single quotes (`'function'`,
// `'('`, `'=='`); category labels that already read as English phrases
// (`identifier`, `integer literal`, `end of file`, ...) are passed
// through unmodified. The space-vs-no-space heuristic distinguishes the
// two without needing a per-kind table — the enum's backing strings
// deliberately keep punctuation and keywords as single tokens.
function tokenKindDisplay(kind TokenKind) returns String
	let display = kind.rawValue
	if display.contains(" ") 'category'
		return display
	end 'category'
	return "'{display}'"
end 'tokenKindDisplay'

// True if `token` is usable as an identifier-like name. Mirrors the C#
// bootstrap's `IsIdentifierLikeToken` (Parser.cs:19016): plain identifiers
// always qualify, plus any keyword whose source spelling starts with a
// letter or underscore (i.e. lexes as if it were an identifier and was
// only reclassified by `classifyIdentifier`). Used at param-name sites
// where stdlib code legitimately picks names like `with`, `type`, `enum`,
// or `return` — every keyword whose value-string is alphabetic.
function tokenIsIdentifierLike(token Token) returns bool
	if token.kind == TokenKind.identifier 'isIdent'
		return true
	end 'isIdent'
	let bytes = token.value.toByteArray()
	if bytes.count() == 0 'empty'
		return false
	end 'empty'
	let first = try bytes.get(0) otherwise return false
	let isLower = first >= 'a' and first <= 'z'
	let isUpper = first >= 'A' and first <= 'Z'
	let isUnderscore = first == '_'
	return isLower or isUpper or isUnderscore
end 'tokenIsIdentifierLike'

// Qualify a function name with namespace: "ns.name".
// Returns the raw name if namespace is empty. Exported because the Maxon→Std
// lowering pass also walks the funcReturnTypes registry to resolve the
// callee names that the parser now leaves unqualified.
export function qualifyName(ns String, name String) returns String
	if ns.isEmpty() 'noNs'
		return name
	end 'noNs'
	return "{ns}.{name}"
end 'qualifyName'

// --- Pratt parser binding power ---

typealias BindingPower = int(0 to 14)

// Throws for non-operator tokens; the call site uses `otherwise 0` to stop the Pratt loop.
function infixBindingPower(kind TokenKind) returns BindingPower throws ParserError
	return match kind 'bp'
		or gives 2
		xor gives 4
		and gives 6
		shl gives 8
		shr gives 8
		equalsEquals gives 10
		bangEquals gives 10
		is gives 10
		lessThan gives 10
		lessEquals gives 10
		greaterThan gives 10
		greaterEquals gives 10
		plus gives 12
		minus gives 12
		star gives 14
		slash gives 14
		mod gives 14
		default throws ParserError.unhandledToken
	end 'bp'
end 'infixBindingPower'

// --- Type bound parsing helpers ---

export typealias BoundValue = int(i64.min to i64.max)

// Captured parse result for a single int/float range bound — the integer
// value (or IEEE-754 i64 bit pattern, for floats) plus the source-level
// type qualifier (`u32`, `i64`, …) when the bound was a `T.min`/`T.max`
// expression. The qualifier is empty for plain literals; callers compare
// the two sides' qualifiers to detect E3005 mismatches.
type BoundResult
	export let value BoundValue
	export let qualifier String

	export static function create(value BoundValue, qualifier String) returns BoundResult
		return Self{value: value, qualifier: qualifier}
	end 'create'
end 'BoundResult'

let typeBoundsTable = [
	"u8.min": 0, "u8.max": 255, "u16.min": 0, "u16.max": 65535, "u32.min": 0, "u32.max": 4294967295, "u64.min": 0, "u64.max": -1,
	"i8.min": -128, "i8.max": 127, "i16.min": -32768, "i16.max": 32767, "i32.min": -2147483648, "i32.max": 2147483647, "i64.min": -9223372036854775808, "i64.max": 9223372036854775807
]

function resolveTypeBound(typeName String, field String) returns BoundValue
	let key = "{typeName}.{field}"
	// Sentinel: 0 means "not a known type-qualified bound"; callers treat 0 as "fall through to literal parsing".
	return try typeBoundsTable.get(key) otherwise 0
end 'resolveTypeBound'

// IEEE-754 bit patterns for f32/f64 finite extremes, encoded as i64 so the
// existing RangeBound (which is i64) can carry them through the resolver.
let floatTypeBoundsTable = [
	"f64.min": -4503599627370497, "f64.max": 9218868437227405311,
	"f32.min": -1011110350135427073, "f32.max": 5727507168572555263
]

function resolveFloatTypeBound(typeName String, field String) returns BoundValue
	let key = "{typeName}.{field}"
	return try floatTypeBoundsTable.get(key) otherwise 0
end 'resolveFloatTypeBound'

// True when `name` is one of the fixed-width integer keywords whose
// `.min`/`.max` bound expressions exist in `typeBoundsTable`. Inlined at
// each runtime call site for years; kept as a helper now that the const
// expression parser also needs the same predicate.
export function isSizedTypeName(name String) returns bool
	return name == "u8" or name == "u16" or name == "u32" or name == "u64" or name == "i8" or name == "i16" or name == "i32" or name == "i64"
end 'isSizedTypeName'

// True when `expr` is the `invalid` sentinel arm. Suppresses the unused-
// typealias cascade so a single E3005 reaches the user.
export function isInvalidTypealiasExpr(expr UnresolvedTypeExpr) returns bool
	return match expr 'check'
		invalid gives true
		boolPrim gives false
		rangedInt gives false
		rangedFloat gives false
		aliasName gives false
		genericAlias gives false
		sizedGenericAlias gives false
	end 'check'
end 'isInvalidTypealiasExpr'

// Negate an IEEE-754 double encoded as i64 bits — flip the sign bit.
function negateFloatBits(bits BoundValue) returns BoundValue
	let signBit = -9223372036854775808
	return bits xor signBit
end 'negateFloatBits'

// Convert a signed integer to its IEEE-754 double bit pattern. Only used
// for small range-bound literals (0, 100, etc.) where rounding loss is
// inconsequential.
function floatBitsFromInt(value BoundValue) returns BoundValue
	if value == 0 'zero'
		return 0
	end 'zero'
	let isNeg = value < 0
	let mag = value if not isNeg else 0 - value
	// Find leading-bit position. mag is positive non-zero in the i64 range,
	// so the position is in [0, 62].
	var pos = 0
	var probe = mag
	while probe > 1 'shift'
		probe = probe shr 1
		pos = pos + 1
	end 'shift'
	let exponent = pos + 1023
	// Mantissa: drop the implicit leading 1, shift to fill 52 bits.
	let topBit = 1 shl pos
	let fraction = mag - topBit
	var mantissa = 0
	if pos <= 52 'leftShift'
		mantissa = fraction shl (52 - pos)
	end 'leftShift' else 'rightShift'
		mantissa = fraction shr (pos - 52)
	end 'rightShift'
	let signBit = -9223372036854775808 if isNeg else 0
	let exponentBits = exponent shl 52
	return signBit or exponentBits or mantissa
end 'floatBitsFromInt'

// Compare two doubles encoded as i64 bit patterns: true iff `a > b` in
// IEEE-754 ordering. Used to validate `lower <= upper` without a runtime
// float-compare op.
export function floatBitsGreater(a BoundValue, b BoundValue) returns bool
	if a == b 'eq'
		return false
	end 'eq'
	let aNeg = a < 0
	let bNeg = b < 0
	if aNeg and not bNeg 'aLess'
		return false
	end 'aLess'
	if bNeg and not aNeg 'aGreater'
		return true
	end 'aGreater'
	if aNeg 'bothNeg'
		// Larger magnitude (smaller signed bits) is the smaller double.
		return a < b
	end 'bothNeg'
	return a > b
end 'floatBitsGreater'

// True when an int range (lower, upper, upperInclusive) is invalid.
// `0 to u64.max` is fine: u64.max stores as the wrapped value -1, and a
// non-negative `lower` with a wrapped `upper` represents the full unsigned
// span, which is always valid.
function isInvalidIntRange(lower BoundValue, upper BoundValue, upperInclusive bool) returns bool
	// Unsigned compare: when both operands are non-negative as signed,
	// signed comparison agrees with unsigned. When `upper < 0` it
	// represents a u64 value above i64.max; that's always larger than a
	// non-negative lower so the range is valid.
	if lower >= 0 and upper < 0 'unsignedWrapped'
		return false
	end 'unsignedWrapped'
	return lower > upper or (lower == upper and not upperInclusive)
end 'isInvalidIntRange'

// Pick the narrowest StdType that can hold an `int(...)` alias's range.
// The alias's *cast category* is tracked separately via
// `project.typealiasCastCategories`, so narrowing to u8/u16 here doesn't
// flip a user-declared `int(...)` into the `byte` cast family — storage
// is independent of category.
//
// Negative-bounded ranges select narrow signed widths (i8/i16/i32) when
// the bounds fit; otherwise fall through to i64. Backend load/store
// lowering carries the resulting width through `StoreWidth`.
export function computeOptimalIntType(lower BoundValue, upper BoundValue) returns StdType
	if lower >= 0 'unsigned'
		// `upper < 0` represents a u64 value above i64.max — needs full u64
		// to round-trip cleanly.
		if upper < 0 'wrappedU64'
			return StdType.u64
		end 'wrappedU64'
		if upper <= u8.max 'u8'
			return StdType.u8
		end 'u8'
		if upper <= u16.max 'u16'
			return StdType.u16
		end 'u16'
		if upper <= u32.max 'u32'
			return StdType.u32
		end 'u32'
		return StdType.u64
	end 'unsigned'
	if lower >= i8.min and upper <= i8.max 'i8'
		return StdType.i8
	end 'i8'
	if lower >= i16.min and upper <= i16.max 'i16'
		return StdType.i16
	end 'i16'
	if lower >= i32.min and upper <= i32.max 'i32'
		return StdType.i32
	end 'i32'
	return StdType.i64
end 'computeOptimalIntType'

// --- ExprResult enum ---

// Result of parsing an expression. The parser only ever tracks the
// source-level MaxonType on the value; int-vs-float dispatch and width
// selection happen in lowerMaxonToStd, not here.
//
// The `name` field carries a `ByteArray` — either a zero-copy slice over the
// lexer's source buffer (for a user-written variable) or a synthetic name
// (`$tN`) minted by the parser for an intermediate. SSA numbering is assigned
// only when the Maxon dialect is lowered to Std.
export union ExprResult
	// Computed value — already emitted as an op
	direct(name ByteArray, valueType MaxonType)
	// Compile-time string constant — carries the interned StringId so
	// downstream consumers (top-level constant registration, string-equality
	// folding) reference the literal by its stable project-wide id rather
	// than re-allocating its bytes.
	stringConst(name ByteArray, stringId StringId)
end 'ExprResult'

// --- ExprResult helpers ---

function exprName(expr ExprResult) returns ByteArray
	return match expr 'getName'
		direct(name, _) gives name
		stringConst(name, _) gives name
	end 'getName'
end 'exprName'

function exprType(expr ExprResult) returns MaxonType
	return match expr 'getType'
		direct(_, valueType) gives valueType
		stringConst gives MaxonType.string
	end 'getType'
end 'exprType'

function exprIsStringConst(expr ExprResult) returns bool
	return match expr 'check'
		stringConst gives true
		direct gives false
	end 'check'
end 'exprIsStringConst'

function exprStringConstId(expr ExprResult) returns StringId
	return match expr 'getId'
		stringConst(_, stringId) gives stringId
		direct gives 0
	end 'getId'
end 'exprStringConstId'

// --- Context stacks for loops and match ---

type LoopContext
	export var sourceLabel String
	export var headerBlockId BlockId
	export var exitBlockId BlockId
	// Where `continue` jumps. For while-loops this is the cond/header block; for
	// for-range loops it's a step block that increments the iter then branches
	// to the header — without that step, `continue` would re-enter the header
	// with the iter unchanged and spin forever.
	export var continueBlockId BlockId

	export static function create(sourceLabel String, headerBlockId BlockId, exitBlockId BlockId, continueBlockId BlockId) returns LoopContext
		return Self{sourceLabel: sourceLabel, headerBlockId: headerBlockId, exitBlockId: exitBlockId, continueBlockId: continueBlockId}
	end 'create'
end 'LoopContext'

typealias LoopContextArray = Array with LoopContext

type MatchContext
	export var sourceLabel String
	export var mergeBlockId BlockId

	export static function create(sourceLabel String, mergeBlockId BlockId) returns MatchContext
		return Self{sourceLabel: sourceLabel, mergeBlockId: mergeBlockId}
	end 'create'
end 'MatchContext'

typealias MatchContextArray = Array with MatchContext

// Result of parsing a `match <expr> '<label>'` prelude. `failed` is set when
// the label is missing (the diagnostic was already emitted); callers branch
// on it to pick a recovery path appropriate to the form (statement vs.
// expression). `mergeBlock` is created up-front so arm bodies can branch to
// it without each arm rediscovering it.
type MatchHeader
	export var scrutineeName ByteArray
	export var scrutineeType MaxonType
	export var userLabel String
	export var baseLabel String
	export var mergeBlock IrBlock
	export var failed bool
	// Phase 9 Stage 4: source-level mutability of the match scrutinee, used
	// only when the scrutinee is a union value and the match introduces
	// payload bindings. True when the scrutinee was a bare identifier
	// referring to a `var` local (or other mutable origin). For non-bare
	// scrutinees (computed expressions, struct-field reads, etc.) this stays
	// false — the binding can still be matched against but `value = …` is
	// rejected with E2013 because there's no source-level slot to write back
	// to. For bare-let scrutinees the same E2013 fires.
	export var scrutineeMutable bool

	export static function create(scrutineeName ByteArray, scrutineeType MaxonType, userLabel String, baseLabel String, mergeBlock IrBlock, scrutineeMutable bool) returns MatchHeader
		return Self{scrutineeName: scrutineeName, scrutineeType: scrutineeType, userLabel: userLabel, baseLabel: baseLabel, mergeBlock: mergeBlock, failed: false, scrutineeMutable: scrutineeMutable}
	end 'create'

	export static function failed() returns MatchHeader
		return Self{scrutineeName: ByteArray.create(), scrutineeType: MaxonType.unresolved, userLabel: "", baseLabel: "", mergeBlock: IrBlock.create(0 as BlockId, label: ""), failed: true, scrutineeMutable: false}
	end 'failed'
end 'MatchHeader'

// The two blocks freshly created for a match arm: the body block whose
// content the caller fills in, and the next-arm block control flows to on
// a non-match. `caseToken` is captured so the caller can attach source
// ranges for varStore / br ops emitted into the body.
type MatchArmBlocks
	export var caseToken Token
	export var body IrBlock
	export var next IrBlock
	// True when `buildMatchArmBlocks` already populated the body's
	// terminator (e.g. for `default panic(...)` / `default throws Err.x`).
	// The outer loop must NOT call `parseMatchStatementArmBody` /
	// `parseMatchExpressionArmBody` for these arms because the cursor has
	// already advanced past the diverging keyword's body.
	export var bodyAlreadyTerminated bool

	export static function create(caseToken Token, body IrBlock, next IrBlock, bodyAlreadyTerminated bool = false) returns MatchArmBlocks
		return Self{caseToken: caseToken, body: body, next: next, bodyAlreadyTerminated: bodyAlreadyTerminated}
	end 'create'
end 'MatchArmBlocks'

// One parsed pattern within a match-arm pattern list. `kind` discriminates
// between the catch-all default (`defaultArm`), an integer-literal pattern
// (`intValue` populated), an enum-case pattern (`caseName` populated), and
// a range-literal pattern (`loValue`/`hiValue`/sentinels populated).
// `displayName` is the duplicate-detection / E2027 message string. The
// `defaultArm` variant is named with a suffix because `default` is a
// reserved keyword.
//
// Phase 9 Stage 2: an enum-case pattern may carry payload bindings
// (`caseName(x, _, var y)`); they live alongside `caseName` in the same
// kind so existing `.isEnumCase()` predicates continue to fire for bare
// and bound forms alike. `bindingNames` holds the source-level binding
// names (with `_` for discards) and parallels `bindingIsVar` / `bindingIsDiscard`.
export union MatchPatternKind
	defaultArm
	intLiteral
	enumCase
	rangeLiteral
end 'MatchPatternKind'

// Phase 9 Stage 2: parsed payload-binding descriptor. Each entry in
// `MatchPatternSpec.bindings` records one position in the source
// `caseName(b1, b2, ...)` list. `name` is the source-level binding name
// (or empty when the binding is `_`); `isDiscard` distinguishes `_` from
// a named binding so downstream consumers don't trip over an empty name;
// `isVar` distinguishes `var name` (mutable) from `name` (immutable).
// Location captured for E3035 / E3081 anchoring.
export type MatchPatternBinding
	export var name String
	export var isDiscard bool
	export var isVar bool
	export var line LineNumber
	export var column ColumnNumber

	export static function create(name String, isDiscard bool, isVar bool, line LineNumber, column ColumnNumber) returns MatchPatternBinding
		return Self{name: name, isDiscard: isDiscard, isVar: isVar, line: line, column: column}
	end 'create'
end 'MatchPatternBinding'

export typealias MatchPatternBindingArray = Array with MatchPatternBinding

export type MatchPatternSpec
	export var kind MatchPatternKind
	export var token Token
	export var intValue ParsedInt
	export var caseName String
	export var displayName String
	// Range-pattern fields (only meaningful when kind == rangeLiteral).
	// `loValue` is 0 when `hasMinSentinel` is true; `hiValue` is 0 when
	// `hasMaxSentinel` is true. `isUpto` selects exclusive upper bound.
	export var loValue ParsedInt
	export var hiValue ParsedInt
	export var isUpto bool
	export var hasMinSentinel bool
	export var hasMaxSentinel bool
	// True when this pattern is a range whose bounds are enum case names
	// (e.g. `red to blue`). Bound ordinals live in `loValue` / `hiValue`.
	// Used by exhaustiveness validation to track ordinal coverage and by
	// the enum-default check to treat the arm as an enum-case arm.
	export var isEnumRange bool
	// Owning enum name when `isEnumRange` is true. Empty otherwise.
	export var enumOwnerName String
	// Phase 9 Stage 2: parsed payload bindings for an enum-case pattern
	// (`caseName(x, _, var y)`). Empty for bare-case arms and for every
	// non-enum-case kind. `bindingNames` mirrors the same list as
	// `ByteArrayArray` so the dialect-level enumMatchArm op (which lives
	// outside the parser's String/ByteArray boundary) sees the names
	// in the form its slot expects without a per-arm conversion.
	export var bindings MatchPatternBindingArray
	export var bindingNames ByteArrayArray

	export static function defaultPattern(token Token) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.defaultArm, token: token, intValue: 0, caseName: "", displayName: "default", loValue: 0, hiValue: 0, isUpto: false, hasMinSentinel: false, hasMaxSentinel: false, isEnumRange: false, enumOwnerName: "", bindings: MatchPatternBindingArray.create(), bindingNames: ByteArrayArray.create()}
	end 'defaultPattern'

	export static function intLiteral(token Token, value ParsedInt, displayName String) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.intLiteral, token: token, intValue: value, caseName: "", displayName: displayName, loValue: 0, hiValue: 0, isUpto: false, hasMinSentinel: false, hasMaxSentinel: false, isEnumRange: false, enumOwnerName: "", bindings: MatchPatternBindingArray.create(), bindingNames: ByteArrayArray.create()}
	end 'intLiteral'

	export static function enumCase(token Token, caseName String) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.enumCase, token: token, intValue: 0, caseName: caseName, displayName: caseName, loValue: 0, hiValue: 0, isUpto: false, hasMinSentinel: false, hasMaxSentinel: false, isEnumRange: false, enumOwnerName: "", bindings: MatchPatternBindingArray.create(), bindingNames: ByteArrayArray.create()}
	end 'enumCase'

	// Phase 9 Stage 2: enum-case pattern with payload bindings.
	// `bindings` is the parser's structured view; `bindingNames` is the
	// flat ByteArrayArray slot consumed by the dialect-level
	// enumMatchArm op. Both arrays are parallel and the same length.
	export static function enumCaseWithBindings(token Token, caseName String, bindings MatchPatternBindingArray, bindingNames ByteArrayArray) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.enumCase, token: token, intValue: 0, caseName: caseName, displayName: caseName, loValue: 0, hiValue: 0, isUpto: false, hasMinSentinel: false, hasMaxSentinel: false, isEnumRange: false, enumOwnerName: "", bindings: bindings, bindingNames: bindingNames}
	end 'enumCaseWithBindings'

	// Range pattern: `loValue to|upto hiValue`. Either bound may be a
	// `min` / `max` sentinel (open-ended), but never both. `displayName`
	// is the source form used in duplicate / single-value diagnostics.
	export static function rangeLiteral(token Token, loValue ParsedInt, hiValue ParsedInt, isUpto bool, hasMinSentinel bool, hasMaxSentinel bool, displayName String) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.rangeLiteral, token: token, intValue: 0, caseName: "", displayName: displayName, loValue: loValue, hiValue: hiValue, isUpto: isUpto, hasMinSentinel: hasMinSentinel, hasMaxSentinel: hasMaxSentinel, isEnumRange: false, enumOwnerName: "", bindings: MatchPatternBindingArray.create(), bindingNames: ByteArrayArray.create()}
	end 'rangeLiteral'

	// Enum-case range: `caseName to|upto caseName`. The `loValue`/`hiValue`
	// fields hold the case ordinals so lowering can compare against the
	// integer-backed scrutinee. `enumOwnerName` identifies the enum for
	// exhaustiveness coverage tracking.
	export static function enumRange(token Token, loOrdinal ParsedInt, hiOrdinal ParsedInt, isUpto bool, hasMaxSentinel bool, displayName String, enumOwnerName String) returns MatchPatternSpec
		return Self{kind: MatchPatternKind.rangeLiteral, token: token, intValue: 0, caseName: "", displayName: displayName, loValue: loOrdinal, hiValue: hiOrdinal, isUpto: isUpto, hasMinSentinel: false, hasMaxSentinel: hasMaxSentinel, isEnumRange: true, enumOwnerName: enumOwnerName, bindings: MatchPatternBindingArray.create(), bindingNames: ByteArrayArray.create()}
	end 'enumRange'

	export function isDefault() returns bool
		return match self.kind 'check'
			defaultArm gives true
			intLiteral gives false
			enumCase gives false
			rangeLiteral gives false
		end 'check'
	end 'isDefault'

	export function isRange() returns bool
		return match self.kind 'check'
			defaultArm gives false
			intLiteral gives false
			enumCase gives false
			rangeLiteral gives true
		end 'check'
	end 'isRange'
end 'MatchPatternSpec'

export typealias MatchPatternSpecArray = Array with MatchPatternSpec

// Bundle of patterns belonging to one arm. The arm is a `default` arm when
// the first (only) entry is a default pattern; an enum-case arm when the
// first entry is an enum-case pattern; an integer-literal arm otherwise.
// Patterns within an arm share a kind by construction (the parser only
// chains `or`-separated literals, never mixing literals with enum cases or
// `default` — a mix would mean a single arm is matching a heterogeneous set
// of values, which the language explicitly disallows).
export type MatchPatternList
	export var patterns MatchPatternSpecArray

	export static function create(patterns MatchPatternSpecArray) returns MatchPatternList
		return Self{patterns: patterns}
	end 'create'

	export function first() returns MatchPatternSpec
		return try self.patterns.get(0) otherwise panic("MatchPatternList.first: empty list")
	end 'first'

	export function isDefault() returns bool
		return self.first().isDefault()
	end 'isDefault'

	export function isEnumCase() returns bool
		return match self.first().kind 'check'
			defaultArm gives false
			intLiteral gives false
			enumCase gives true
			rangeLiteral gives false
		end 'check'
	end 'isEnumCase'

	export function isRange() returns bool
		return self.first().isRange()
	end 'isRange'
end 'MatchPatternList'

// Outcome of parsing one match-statement arm body: the block control flow
// landed on after the body statement plus a flag indicating whether the
// statement was a `return` (so the parser can reject `return ... and
// fallthrough` per E2025).
export type MatchStmtArmBodyResult
	export var exitBlock IrBlock
	export var hadReturn bool

	export static function create(exitBlock IrBlock, hadReturn bool) returns MatchStmtArmBodyResult
		return Self{exitBlock: exitBlock, hadReturn: hadReturn}
	end 'create'
end 'MatchStmtArmBodyResult'

// Outcome of parsing one `otherwise FALLBACK` shape. The fallback can
// either merge into the success path through the merge block (expression
// or `ignore` shapes — `mergesIntoSuccess: true`) or seal its own block
// with a terminator like ret/throw/br (return / panic / throw / break /
// continue — `mergesIntoSuccess: false`). When the fallback is an
// expression, `hasFallbackType` is true and `fallbackType` holds the
// expression's type so the caller can fall back to it when the success
// arm's call type is unresolved at parse time.
type TryFallbackOutcome
	export let mergesIntoSuccess bool
	export let fallbackExitBlock IrBlock
	export let hasFallbackType bool
	export let fallbackType MaxonType

	// Terminator-shaped fallback: block is already sealed; merge edge
	// must NOT be added.
	export static function terminator(fallbackExitBlock IrBlock) returns TryFallbackOutcome
		return Self{mergesIntoSuccess: false, fallbackExitBlock: fallbackExitBlock, hasFallbackType: false, fallbackType: MaxonType.unresolved}
	end 'terminator'

	// `ignore`-shaped fallback: the slot is stored with a typed default
	// and we branch through to the merge block. No fallback expression
	// type — the success arm dictates the slot's resolved type.
	export static function merges(fallbackExitBlock IrBlock) returns TryFallbackOutcome
		return Self{mergesIntoSuccess: true, fallbackExitBlock: fallbackExitBlock, hasFallbackType: false, fallbackType: MaxonType.unresolved}
	end 'merges'

	// Expression-shaped fallback: report the expression's type so the
	// caller can use it when the call's success type is unresolved.
	export static function mergesWithType(fallbackExitBlock IrBlock, fallbackType MaxonType) returns TryFallbackOutcome
		return Self{mergesIntoSuccess: true, fallbackExitBlock: fallbackExitBlock, hasFallbackType: true, fallbackType: fallbackType}
	end 'mergesWithType'
end 'TryFallbackOutcome'

// Phase 9 Stage 5c: result of constructing an associated-value union payload
// inside a `throw EnumName.case(args)` statement. `resultName` is the SSA
// name bound to the synthesized constructor's return value (a union pointer);
// `lastToken` is the closing `)` so the caller can attach the throw op's
// source range to the full `throw … (…)` span.
type ThrowConstructionResult
	export let resultName ByteArray
	export let lastToken Token

	export static function create(resultName ByteArray, lastToken Token) returns ThrowConstructionResult
		return Self{resultName: resultName, lastToken: lastToken}
	end 'create'
end 'ThrowConstructionResult'

// Tracks the source location of a parameter so CheckUnusedVariables can pin
// an E3012 error back to the declaration site rather than the function header.
type ParamLocation
	export let name String
	export let line LineNumber
	export let column ColumnNumber

	export static function create(name String, line LineNumber, column ColumnNumber) returns ParamLocation
		return Self{name: name, line: line, column: column}
	end 'create'
end 'ParamLocation'

typealias ParamLocationArray = Array with ParamLocation
typealias ReferencedVarSet = Set with String

// Tracks each `typealias` declaration parsed in this file so the parser can
// emit E3062 (unused typealias) at end-of-module. Only file-private aliases
// participate in the unused check — exported / module-visible aliases skip it
// because cross-file uses aren't observable from a single Parser instance.
type LocalTypealias
	export let name String
	export let line LineNumber
	export let column ColumnNumber

	export static function create(name String, line LineNumber, column ColumnNumber) returns LocalTypealias
		return Self{name: name, line: line, column: column}
	end 'create'
end 'LocalTypealias'

typealias LocalTypealiasArray = Array with LocalTypealias

// Optional Token wrapper returned by consumeArgLabel. Maxon has no built-in
// optional type, so a small struct with a presence flag keeps the call-site
// unwrap obvious (hasValue/token) without resorting to sentinel tokens.
type OptionalToken
	export let hasValue bool
	export let token Token

	export static function some(token Token) returns OptionalToken
		return Self{hasValue: true, token: token}
	end 'some'

	export static function empty() returns OptionalToken
		return Self{hasValue: false, token: Token.eof()}
	end 'empty'
end 'OptionalToken'

// MlirBlock: a basic block in the control flow graph.
// Contains a linked list of op references (packed dialect tag + index) and
// exactly one terminator (always CfOp). Block arguments represent φ-nodes
// in SSA form — values passed from predecessor blocks via branch argument lists.
//
// Ops are stored in module-level per-dialect arrays. Each entry in the block's
// ops list is a packed int: (dialectTag << 56) | dialectArrayIndex.
// This allows single-dialect iteration without enum dispatch.

export typealias BlockId = int(0 to u64.max)
export typealias BlockIdArray = Array with BlockId

// Packed op reference: encodes which dialect array and which index within it.
export typealias OpRef = int(i64.min to i64.max)
export typealias OpRefList = List with OpRef

// Dialect tags for packing into OpRef.
let DIALECT_SHIFT = 56
let INDEX_MASK = 0x00FFFFFFFFFFFFFF

export let TAG_MAXON = 0
export let TAG_ARITH = 1
export let TAG_CF = 2
export let TAG_FUNC = 3
export let TAG_MEMREF = 4
export let TAG_RUNTIME = 5
export let TAG_SYS = 6
export let TAG_MIR = 7
export let TAG_X64 = 8
export let TAG_ARM64 = 9

export function packOpRef(dialect OpRef, index OpRef) returns OpRef
	return (dialect shl DIALECT_SHIFT) or index
end 'packOpRef'

export function opRefDialect(packed OpRef) returns OpRef
	return packed shr DIALECT_SHIFT
end 'opRefDialect'

export function opRefIndex(packed OpRef) returns OpRef
	return packed and INDEX_MASK
end 'opRefIndex'

// A block argument (φ-node): a value defined at block entry, bound by
// the branch op that transfers control to this block.
export type MlirBlockArg
	export var valueId ValueId
	export var argType StdType

	export static function create(valueId ValueId, argType StdType) returns MlirBlockArg
		return Self{valueId: valueId, argType: argType}
	end 'create'
end 'MlirBlockArg'

export typealias MlirBlockArgArray = Array with MlirBlockArg

export type MlirBlock
	export var id BlockId
	export var label String
	export var ops OpRefList
	export var terminator OpRef
	export var hasTerminator bool
	export var blockArgs MlirBlockArgArray

	export static function create(id BlockId, label String) returns MlirBlock
		return Self{
			id: id,
			label: label,
			ops: OpRefList.create(),
			terminator: 0,
			hasTerminator: false,
			blockArgs: MlirBlockArgArray.create()
		}
	end 'create'
end 'MlirBlock'

export typealias MlirBlockArray = Array with MlirBlock

export function createMlirBlock(id BlockId, label String) returns MlirBlock
	return MlirBlock.create(id, label: label)
end 'createMlirBlock'

// ============================================================
// Per-dialect append helpers
// ============================================================
// Each appends the op to the module's dialect array and adds
// a packed reference to the block's ops list.

export function appendMaxonOp(module MlirModule, block MlirBlock, op MaxonOp)
	let idx = module.maxonOps.count()
	module.maxonOps.push(op)
	block.ops.append(packOpRef(TAG_MAXON, index: idx))

end 'appendMaxonOp'

export function appendArithOp(module MlirModule, block MlirBlock, op ArithOp)
	let idx = module.arithOps.count()
	module.arithOps.push(op)
	block.ops.append(packOpRef(TAG_ARITH, index: idx))

end 'appendArithOp'

export function appendCfOp(module MlirModule, block MlirBlock, op CfOp)
	let idx = module.cfOps.count()
	module.cfOps.push(op)
	block.ops.append(packOpRef(TAG_CF, index: idx))

end 'appendCfOp'

export function appendFuncOp(module MlirModule, block MlirBlock, op FuncOp)
	let idx = module.funcOps.count()
	module.funcOps.push(op)
	block.ops.append(packOpRef(TAG_FUNC, index: idx))

end 'appendFuncOp'

export function appendMemrefOp(module MlirModule, block MlirBlock, op MemRefOp)
	let idx = module.memrefOps.count()
	module.memrefOps.push(op)
	block.ops.append(packOpRef(TAG_MEMREF, index: idx))

end 'appendMemrefOp'

export function appendRuntimeOp(module MlirModule, block MlirBlock, op RuntimeOp)
	let idx = module.runtimeOps.count()
	module.runtimeOps.push(op)
	block.ops.append(packOpRef(TAG_RUNTIME, index: idx))

end 'appendRuntimeOp'

export function appendSysOp(module MlirModule, block MlirBlock, op SysOp)
	let idx = module.sysOps.count()
	module.sysOps.push(op)
	block.ops.append(packOpRef(TAG_SYS, index: idx))

end 'appendSysOp'

export function appendMirOp(module MlirModule, block MlirBlock, op MirOp)
	let idx = module.mirOps.count()
	module.mirOps.push(op)
	block.ops.append(packOpRef(TAG_MIR, index: idx))

end 'appendMirOp'

export function appendX64Op(module MlirModule, block MlirBlock, op X64Op)
	let idx = module.x64Ops.count()
	module.x64Ops.push(op)
	block.ops.append(packOpRef(TAG_X64, index: idx))

end 'appendX64Op'

export function appendArm64Op(module MlirModule, block MlirBlock, op Arm64Op)
	let idx = module.arm64Ops.count()
	module.arm64Ops.push(op)
	block.ops.append(packOpRef(TAG_ARM64, index: idx))

end 'appendArm64Op'

// ============================================================
// Terminator helpers
// ============================================================
// The terminator is stored as a packed OpRef, same as regular ops,
// but stored in block.terminator instead of the ops list.

export function setMaxonTerminator(module MlirModule, block MlirBlock, op MaxonOp)
	let idx = module.maxonOps.count()
	module.maxonOps.push(op)
	block.terminator = packOpRef(TAG_MAXON, index: idx)
	block.hasTerminator = true

end 'setMaxonTerminator'

export function setCfTerminator(module MlirModule, block MlirBlock, op CfOp)
	let idx = module.cfOps.count()
	module.cfOps.push(op)
	block.terminator = packOpRef(TAG_CF, index: idx)
	block.hasTerminator = true

end 'setCfTerminator'

export function setFuncTerminator(module MlirModule, block MlirBlock, op FuncOp)
	let idx = module.funcOps.count()
	module.funcOps.push(op)
	block.terminator = packOpRef(TAG_FUNC, index: idx)
	block.hasTerminator = true

end 'setFuncTerminator'

export function setMirTerminator(module MlirModule, block MlirBlock, op MirOp)
	let idx = module.mirOps.count()
	module.mirOps.push(op)
	block.terminator = packOpRef(TAG_MIR, index: idx)
	block.hasTerminator = true

end 'setMirTerminator'

export function setX64Terminator(module MlirModule, block MlirBlock, op X64Op)
	let idx = module.x64Ops.count()
	module.x64Ops.push(op)
	block.terminator = packOpRef(TAG_X64, index: idx)
	block.hasTerminator = true

end 'setX64Terminator'

export function setArm64Terminator(module MlirModule, block MlirBlock, op Arm64Op)
	let idx = module.arm64Ops.count()
	module.arm64Ops.push(op)
	block.terminator = packOpRef(TAG_ARM64, index: idx)
	block.hasTerminator = true

end 'setArm64Terminator'


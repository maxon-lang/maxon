// MlirOp: wrapper enum dispatching to per-dialect operation enums.
// Ops from different dialects coexist in the same block.
// Each lowering pass handles the ops it cares about and passes others through.

export enum MlirOp
	maxon(op MaxonOp)
	arith(op ArithOp)
	cf(op CfOp)
	func(op FuncOp)
	memref(op MemRefOp)
	runtime(op RuntimeOp)
	sys(op SysOp)
	mir(op MirOp)
	x64(op X64Op)
	arm64(op Arm64Op)
end 'MlirOp'

export typealias MlirOpArray = Array with MlirOp

// MlirOp: wrapper union dispatching to per-dialect operation unions.
// Ops from different dialects coexist in the same block.
// Each lowering pass handles the ops it cares about and passes others through.

export union MlirOp
	maxhl(op MaxHLOp)
	arith(op ArithOp)
	cf(op CfOp)
	func(op FuncOp)
	memref(op MemRefOp)
	runtime(op RuntimeOp)
	sys(op SysOp)
	maxx64(op MaxX64Op)
	maxarm64(op MaxArm64Op)
end 'MlirOp'

export typealias MlirOpArray = Array with MlirOp

// Maxon dialect -> Standard dialect conversion.

export typealias StdOpArray = Array with StdOp

export function lowerMaxonOpsToStd(maxonOps MaxonOpArray) returns StdOpArray
    var ops = StdOpArray{}

    for mOp in maxonOps 'opLoop'
        match mOp 'lower'
            literal(resultId, value) then ops.push(StdOp.constI64(resultId, value))
            returnOp(retValId) then ops.push(StdOp.returnOp(retValId))
            varDecl(slotId, valueId) then ops.push(StdOp.storeSlot(slotId, valueId))
            varLoad(resultId, slotId) then ops.push(StdOp.loadSlot(resultId, slotId))
            add(resultId, leftId, rightId) then ops.push(StdOp.addI64(resultId, leftId, rightId))
            sub(resultId, leftId, rightId) then ops.push(StdOp.subI64(resultId, leftId, rightId))
            mul(resultId, leftId, rightId) then ops.push(StdOp.mulI64(resultId, leftId, rightId))
            pushValue then ops.push(StdOp.pushValue)
            popToRcx then ops.push(StdOp.popToRcx)
            printLiteral(data) then ops.push(StdOp.printLiteral(data))
            printInt(valueId) then ops.push(StdOp.printInt(valueId))
        end 'lower'
    end 'opLoop'

    return ops
end 'lowerMaxonOpsToStd'

// Maxon dialect -> Standard dialect conversion.

export typealias StdOpArray = Array with StdOp

export function lowerMaxonOpsToStd(maxonOps MaxonOpArray) returns StdOpArray
    logDebug(LogCategory.mlir, message: "Lowering {maxonOps.count()} Maxon ops to Standard dialect")
    var ops = StdOpArray{}

    for mOp in maxonOps 'opLoop'
        match mOp 'lower'
            literal(resultId, value) then ops.push(StdOp.constI64(resultId, value))
            floatLiteral(resultId, rawBits) then ops.push(StdOp.constF64(resultId, rawBits))
            returnOp(retValId) then ops.push(StdOp.returnOp(retValId))
            varDecl(slotId, valueId) then ops.push(StdOp.storeSlot(slotId, valueId))
            varLoad(resultId, slotId) then ops.push(StdOp.loadSlot(resultId, slotId))
            add(resultId, leftId, rightId) then ops.push(StdOp.addI64(resultId, leftId, rightId))
            sub(resultId, leftId, rightId) then ops.push(StdOp.subI64(resultId, leftId, rightId))
            mul(resultId, leftId, rightId) then ops.push(StdOp.mulI64(resultId, leftId, rightId))
            cmpEq(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Eq(resultId, leftId, rightId))
            cmpNe(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Ne(resultId, leftId, rightId))
            cmpLt(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Lt(resultId, leftId, rightId))
            cmpLe(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Le(resultId, leftId, rightId))
            cmpGt(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Gt(resultId, leftId, rightId))
            cmpGe(resultId, leftId, rightId) then ops.push(StdOp.cmpI64Ge(resultId, leftId, rightId))
            floatCmpEq(resultId, leftId, rightId) then ops.push(StdOp.cmpF64Eq(resultId, leftId, rightId))
            condBr(condId, thenLabel, elseLabel) then ops.push(StdOp.condBr(condId, thenLabel, elseLabel))
            br(targetLabel) then ops.push(StdOp.br(targetLabel))
            label(name) then ops.push(StdOp.label(name))
            printLiteral(data) then ops.push(StdOp.printLiteral(data))
            printInt(valueId) then ops.push(StdOp.printInt(valueId))
            funcBegin(name, returnType) then ops.push(StdOp.funcBegin(name, returnType))
            funcEnd then ops.push(StdOp.funcEnd)
            call(resultId, callee) then ops.push(StdOp.call(resultId, callee))
        end 'lower'
    end 'opLoop'

    logDebug(LogCategory.mlir, message: "Maxon->Std lowering complete: {ops.count()} Standard ops")
    return ops
end 'lowerMaxonOpsToStd'

// Common Subexpression Elimination (CSE) Pass.
// Walks module -> functions -> blocks -> ops.
// For each arith.binary, computes a value number from (opcode, leftId, rightId).
// If a duplicate expression is found within the same block, remaps the result
// to the earlier computation's resultId.
// After identifying duplicates, applies substitution across all remaining ops.

// Sentinel meaning "no remap for this valueId"
let REMAP_NONE = i64.max

// Value numbering entry: stores the triple (opcode ordinal, leftId, rightId)
// and the resultId of the first computation.
type ValueNumberEntry
	export let opcodeOrd ValueId
	export let leftId ValueId
	export let rightId ValueId
	export let resultId ValueId

	static function create(opcodeOrd ValueId, leftId ValueId, rightId ValueId, resultId ValueId) returns ValueNumberEntry
		return Self{opcodeOrd: opcodeOrd, leftId: leftId, rightId: rightId, resultId: resultId}
	end 'create'
end 'ValueNumberEntry'

typealias ValueNumberTable = Array with ValueNumberEntry

// Look up an existing value number entry matching (opcodeOrd, leftId, rightId).
// Returns the resultId of the matching entry, or REMAP_NONE if not found.
function valueNumberLookup(table ValueNumberTable, opcodeOrd ValueId, leftId ValueId, rightId ValueId) returns ValueId
	for entry in table 'search'
		if entry.opcodeOrd == opcodeOrd and entry.leftId == leftId and entry.rightId == rightId 'match'
			return entry.resultId
		end 'match'
	end 'search'
	return REMAP_NONE
end 'valueNumberLookup'

function valueNumberInsert(table ValueNumberTable, opcodeOrd ValueId, leftId ValueId, rightId ValueId, resultId ValueId)
	table.push(ValueNumberEntry.create(opcodeOrd, leftId: leftId, rightId: rightId, resultId: resultId))
end 'valueNumberInsert'

export function eliminateCommonSubexpressions(module MlirModule) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Running CSE pass")

	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise 'skip'
				panic("Block not found in module")
			end 'skip'

			// Phase 1: Walk ops, build value numbering table and remap table
			var vnTable = ValueNumberTable.create()
			var remap = ValueIdArray.create()

			for packed in block.opRefs 'buildVN'
				cseAnalyzePackedOp(module, packed: packed, vnTable: vnTable, remap: remap)
			end 'buildVN'

			// Phase 2: Rewrite ops — skip duplicate binary ops, substitute values in all others
			let oldOps = block.opRefs
			block.opRefs = OpRefList.create()
			for packed in oldOps 'rewrite'
				if isDuplicatePackedOp(module, packed: packed, remap: remap) 'skipDup'
					continue
				end 'skipDup'
				cseSubstitutePackedOp(module, packed: packed, remap: remap, dstBlock: block)
			end 'rewrite'

			// Rewrite terminator
			if block.hasTerminator 'hasTerm'
				cseSubstituteTerminator(module, terminator: block.terminator, remap: remap, dstBlock: block)
			end 'hasTerm'
		end 'eachBlock'
	end 'eachFunc'

	return module
end 'eliminateCommonSubexpressions'

// ============================================================
// Phase 1: Analysis — build value numbering and remap tables
// ============================================================

function cseAnalyzePackedOp(module MlirModule, packed OpRef, vnTable ValueNumberTable, remap ValueIdArray)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noBlock'
			return
		end 'noBlock'
		cseAnalyzeArithOp(arithOp, vnTable: vnTable, remap: remap)
	end 'isArith'
	// Only arith binary ops participate in CSE analysis
end 'cseAnalyzePackedOp'

function cseAnalyzeArithOp(op ArithOp, vnTable ValueNumberTable, remap ValueIdArray)
	match op 'dispatch'
		binary(b) then cseAnalyzeBinaryOp(b, vnTable: vnTable, remap: remap)
		const to unary then break 'dispatch'
	end 'dispatch'
end 'cseAnalyzeArithOp'

function cseAnalyzeBinaryOp(b ArithBinaryOp, vnTable ValueNumberTable, remap ValueIdArray)
	let opcodeOrd = b.opcode.ordinal
	let existing = valueNumberLookup(vnTable, opcodeOrd: opcodeOrd, leftId: b.leftId, rightId: b.rightId)

	if existing != REMAP_NONE 'duplicate'
		// This binary op is a duplicate — remap its resultId to the earlier one
		growRemap(remap, size: b.resultId + 1)
		remap.set(b.resultId, value: existing)
		logTrace(LogCategory.mlir, message: () gives "cse: %{b.resultId} duplicates %{existing} ({b.opcode.rawValue} %{b.leftId}, %{b.rightId})")
	end 'duplicate' else 'novel'
		// First occurrence — record it in the value number table
		valueNumberInsert(vnTable, opcodeOrd: opcodeOrd, leftId: b.leftId, rightId: b.rightId, resultId: b.resultId)
	end 'novel'
end 'cseAnalyzeBinaryOp'

// ============================================================
// Duplicate detection
// ============================================================

function isDuplicatePackedOp(module MlirModule, packed OpRef, remap ValueIdArray) returns bool
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noMatch'
			return false
		end 'noMatch'
		return isRemappedArithOp(arithOp, remap: remap)
	end 'isArith'

	return false
end 'isDuplicatePackedOp'

function isRemappedArithOp(op ArithOp, remap ValueIdArray) returns bool
	return match op 'check'
		binary(b) gives isRemapped(b.resultId, remap: remap)
		const to unary gives false
	end 'check'
end 'isRemappedArithOp'

function isRemapped(valueId ValueId, remap ValueIdArray) returns bool
	if valueId >= remap.count() 'outOfBounds'
		return false
	end 'outOfBounds'
	let mapped = try remap.get(valueId) otherwise REMAP_NONE
	return mapped != REMAP_NONE
end 'isRemapped'

// ============================================================
// Remap helpers
// ============================================================

function growRemap(remap ValueIdArray, size ValueId)
	while remap.count() < size 'grow'
		remap.push(REMAP_NONE)
	end 'grow'
end 'growRemap'

function cseRemapValue(valueId ValueId, remap ValueIdArray) returns ValueId
	if valueId >= remap.count() 'noEntry'
		return valueId
	end 'noEntry'
	let mapped = try remap.get(valueId) otherwise REMAP_NONE
	if mapped == REMAP_NONE 'noRemap'
		return valueId
	end 'noRemap'
	return mapped
end 'cseRemapValue'

function cseRemapValueIds(argIds ValueIdArray, remap ValueIdArray) returns ValueIdArray
	var result = ValueIdArray.create()
	for argId in argIds 'each'
		result.push(cseRemapValue(argId, remap: remap))
	end 'each'
	return result
end 'cseRemapValueIds'

// ============================================================
// Value substitution across all op types
// ============================================================

function cseSubstitutePackedOp(module MlirModule, packed OpRef, remap ValueIdArray, dstBlock MlirBlock)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendArithOp(module, block: dstBlock, op: cseSubstArith(arithOp, remap: remap))
		return
	end 'isArith'

	if tag == TAG_CF 'isCf'
		let cfOp = try module.cfOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendCfOp(module, block: dstBlock, op: cseSubstCf(cfOp, remap: remap))
		return
	end 'isCf'

	if tag == TAG_FUNC 'isFunc'
		let funcOp = try module.funcOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendFuncOp(module, block: dstBlock, op: cseSubstFunc(funcOp, remap: remap))
		return
	end 'isFunc'

	if tag == TAG_MEMREF 'isMemref'
		let memOp = try module.memrefOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendMemrefOp(module, block: dstBlock, op: cseSubstMemRef(memOp, remap: remap))
		return
	end 'isMemref'

	if tag == TAG_RUNTIME 'isRuntime'
		let rtOp = try module.runtimeOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendRuntimeOp(module, block: dstBlock, op: cseSubstRuntime(rtOp, remap: remap))
		return
	end 'isRuntime'

	if tag == TAG_SYS 'isSys'
		let sysOp = try module.sysOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		appendSysOp(module, block: dstBlock, op: cseSubstSys(sysOp, remap: remap))
		return
	end 'isSys'

	// maxon, mir, x64, arm64 — pass through unchanged
	dstBlock.opRefs.append(packed)
end 'cseSubstitutePackedOp'

// Substitute values in the terminator and set it on the destination block.
function cseSubstituteTerminator(module MlirModule, terminator OpRef, remap ValueIdArray, dstBlock MlirBlock)
	let tag = opRefDialect(terminator)
	let idx = opRefIndex(terminator)

	if tag == TAG_CF 'isCf'
		let cfOp = try module.cfOps.get(idx) otherwise 'noOp'
			dstBlock.terminator = terminator
			dstBlock.hasTerminator = true
			return
		end 'noOp'
		setCfTerminator(module, block: dstBlock, op: cseSubstCf(cfOp, remap: remap))
		return
	end 'isCf'

	if tag == TAG_FUNC 'isFunc'
		let funcOp = try module.funcOps.get(idx) otherwise 'noOp'
			dstBlock.terminator = terminator
			dstBlock.hasTerminator = true
			return
		end 'noOp'
		setFuncTerminator(module, block: dstBlock, op: cseSubstFunc(funcOp, remap: remap))
		return
	end 'isFunc'

	// Other terminators pass through unchanged
	dstBlock.terminator = terminator
	dstBlock.hasTerminator = true
end 'cseSubstituteTerminator'

function cseSubstArith(op ArithOp, remap ValueIdArray) returns ArithOp
	return match op 'subst'
		const(c) gives ArithOp.const(c)
		unary(u) gives ArithOp.unary(ArithUnaryOp.create(u.opcode, resultId: u.resultId, operandId: cseRemapValue(u.operandId, remap: remap)))
		binary(b) gives ArithOp.binary(ArithBinaryOp.create(b.opcode, resultId: b.resultId, leftId: cseRemapValue(b.leftId, remap: remap), rightId: cseRemapValue(b.rightId, remap: remap)))
	end 'subst'
end 'cseSubstArith'

function cseSubstCf(op CfOp, remap ValueIdArray) returns CfOp
	return match op 'subst'
		br(target, argIds) gives CfOp.br(target, argIds: cseRemapValueIds(argIds, remap: remap))
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) gives CfOp.condBr(cseRemapValue(condId, remap: remap), thenTarget: thenTarget, thenArgIds: cseRemapValueIds(thenArgIds, remap: remap), elseTarget: elseTarget, elseArgIds: cseRemapValueIds(elseArgIds, remap: remap))
	end 'subst'
end 'cseSubstCf'

function cseSubstFunc(op FuncOp, remap ValueIdArray) returns FuncOp
	return match op 'subst'
		ret(retValId) gives FuncOp.ret(cseRemapValue(retValId, remap: remap))
		call(resultId, callee, argIds) gives FuncOp.call(resultId, callee: callee, argIds: cseRemapValueIds(argIds, remap: remap))
		tryCall(resultId, callee, argIds, errorFlagId) gives FuncOp.tryCall(resultId, callee: callee, argIds: cseRemapValueIds(argIds, remap: remap), errorFlagId: errorFlagId)
		indirectCall(resultId, calleeId, argIds) gives FuncOp.indirectCall(resultId, calleeId: cseRemapValue(calleeId, remap: remap), argIds: cseRemapValueIds(argIds, remap: remap))
		funcRef(resultId, funcName) gives FuncOp.funcRef(resultId, funcName: funcName)
		tailCall(callee, argIds) gives FuncOp.tailCall(callee, argIds: cseRemapValueIds(argIds, remap: remap))
		param(resultId, paramIndex, paramType) gives FuncOp.param(resultId, paramIndex: paramIndex, paramType: paramType)
	end 'subst'
end 'cseSubstFunc'

function cseSubstMemRef(op MemRefOp, remap ValueIdArray) returns MemRefOp
	return match op 'subst'
		storeSlot(slotId, valueId) gives MemRefOp.storeSlot(slotId, valueId: cseRemapValue(valueId, remap: remap))
		loadSlot(resultId, slotId) gives MemRefOp.loadSlot(resultId, slotId: slotId)
	end 'subst'
end 'cseSubstMemRef'

function cseSubstRuntime(op RuntimeOp, remap ValueIdArray) returns RuntimeOp
	return match op 'subst'
		printLiteral(data) gives RuntimeOp.printLiteral(data)
		printInt(valueId) gives RuntimeOp.printInt(cseRemapValue(valueId, remap: remap))
		drop(valueId) gives RuntimeOp.drop(cseRemapValue(valueId, remap: remap))
	end 'subst'
end 'cseSubstRuntime'

function cseSubstSys(op SysOp, remap ValueIdArray) returns SysOp
	return match op 'subst'
		syscall(resultId, number, argIds) gives SysOp.syscall(resultId, number: number, argIds: cseRemapValueIds(argIds, remap: remap))
		iatCall(resultId, slotIndex, argIds) gives SysOp.iatCall(resultId, slotIndex: slotIndex, argIds: cseRemapValueIds(argIds, remap: remap))
		globalAddr(resultId, name) gives SysOp.globalAddr(resultId, name: name)
		memcpy(dstId, srcId, lenId) gives SysOp.memcpy(cseRemapValue(dstId, remap: remap), srcId: cseRemapValue(srcId, remap: remap), lenId: cseRemapValue(lenId, remap: remap))
		stackAddr(resultId, slotId) gives SysOp.stackAddr(resultId, slotId: slotId)
		storeByte(baseId, offsetId, byteId) gives SysOp.storeByte(cseRemapValue(baseId, remap: remap), offsetId: cseRemapValue(offsetId, remap: remap), byteId: cseRemapValue(byteId, remap: remap))
		loadByte(resultId, baseId, offsetId) gives SysOp.loadByte(resultId, baseId: cseRemapValue(baseId, remap: remap), offsetId: cseRemapValue(offsetId, remap: remap))
		osExit(codeId) gives SysOp.osExit(cseRemapValue(codeId, remap: remap))
		osWrite(ptrId, lenId) gives SysOp.osWrite(cseRemapValue(ptrId, remap: remap), lenId: cseRemapValue(lenId, remap: remap))
		free(ptrId) gives SysOp.free(cseRemapValue(ptrId, remap: remap))
		osWriteErr(ptrId, lenId) gives SysOp.osWriteErr(cseRemapValue(ptrId, remap: remap), lenId: cseRemapValue(lenId, remap: remap))
		loadFramePtr(resultId) gives SysOp.loadFramePtr(resultId)
		loadIndirect(resultId, addrId, offset) gives SysOp.loadIndirect(resultId, addrId: cseRemapValue(addrId, remap: remap), offset: offset)
		funcAddr(resultId, name) gives SysOp.funcAddr(resultId, name: name)
		storeIndirect(addrId, offset, valueId) gives SysOp.storeIndirect(cseRemapValue(addrId, remap: remap), offset: offset, valueId: cseRemapValue(valueId, remap: remap))
	end 'subst'
end 'cseSubstSys'

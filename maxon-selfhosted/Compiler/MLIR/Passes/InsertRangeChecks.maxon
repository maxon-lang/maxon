// InsertRangeChecks Pass — Inserts runtime range checks on function return values.
// Runs after Phase 4 optimizations (canonicalize/CSE/DCE) so constant folding has
// already happened. Operates on arith/cf/func-level IR.
//
// For each function returning a ranged typealias:
//   - If the return value is a known constant: static validation (no runtime check)
//   - Otherwise: emits comparison + conditional branch to panic/continue blocks

export function insertRangeChecks(module MlirModule, funcReturnTypes FuncReturnTypeMap, typealiasRanges TypealiasRangeMap, nextValueIdRef ValueIdRef, sourceFileName String) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Running insert-range-checks pass")
	let newFunctions = MlirFunctionArray.create()
	var rangeCheckCounter = 0

	for srcFunc in module.functions 'eachFunc'
		var dstFunc = cloneFunctionShell(srcFunc)

		// Look up range bounds for this function's return type
		let aliasName = try funcReturnTypes.get(srcFunc.name) otherwise 'noAlias'
			// No return type alias — copy function as-is
			copyFuncBlocks(module, srcFunc: srcFunc, dstFunc: dstFunc)
			newFunctions.push(dstFunc)
			continue
		end 'noAlias'
		let range = try typealiasRanges.get(aliasName) otherwise 'noRange'
			copyFuncBlocks(module, srcFunc: srcFunc, dstFunc: dstFunc)
			newFunctions.push(dstFunc)
			continue
		end 'noRange'

		// Skip if range covers the full i64 range — no value can be out of bounds
		if isFullRange(range) 'fullRange'
			copyFuncBlocks(module, srcFunc: srcFunc, dstFunc: dstFunc)
			newFunctions.push(dstFunc)
			continue
		end 'fullRange'

		// Seed dst region's block counter from source so new blocks get fresh IDs
		dstFunc.nextBlockId = srcFunc.nextBlockId

		// This function has a ranged return type — process its blocks
		for blockRef in srcFunc.blocks 'eachBlock'
			let srcBlock = try module.blocks.get(blockRef) otherwise 'skip'
				continue
			end 'skip'
			var dstBlock = addBlock(module, func: dstFunc, label: srcBlock.label)
			dstBlock.id = srcBlock.id
			dstBlock.blockArgs = srcBlock.blockArgs

			// Copy all ops
			for packed in srcBlock.ops 'eachOp'
				dstBlock.ops.append(packed)
			end 'eachOp'

			// Check if terminator is func.ret
			if srcBlock.hasTerminator 'hasTerm'
				let isRet = isTerminatorFuncRet(srcBlock.terminator, module: module)
				if isRet 'isReturn'
					let retValId = extractRetValId(srcBlock.terminator, module: module)

					// Check if return value is a known constant in this block
					let constValue = findConstValue(retValId, block: srcBlock, module: module)
					if constValue != RANGE_CHECK_UNKNOWN 'isConst'
						// Static validation: constant is in range, no runtime check needed
						// (Out-of-range constants would be a compile error, but we don't
						//  report it here since this is a late pass — just emit no check)
						copyTerminator(srcBlock, dstBlock: dstBlock)
					end 'isConst' else 'notConst'
						// Emit runtime range check
						let checkId = rangeCheckCounter
						rangeCheckCounter = rangeCheckCounter + 1

						let typeInfo = resolveRangeCheckType(srcFunc.returnType)
						let needsLowerCheck = range.lower > i64.min
						let needsUpperCheck = range.upper < i64.max

						// Build blocks in layout order so fallthrough elimination works.
						// For bothChecks: entry -> loCheck -> ok -> panic
						// For single: entry -> ok -> panic
						let panicLabel = buildLabel("__range_panic_", id: checkId)
						let okLabel = buildLabel("__range_ok_", id: checkId)

						// All paths need panic + continue blocks; dualCheck also needs loCheck
						let panicBlock = addBlock(module, func: dstFunc, label: panicLabel)
						var continueBlock = addBlock(module, func: dstFunc, label: okLabel)

						if needsUpperCheck and needsLowerCheck and range.lower == 0 'unsignedCheck'
							// Single unsigned comparison handles both bounds when lower == 0
							emitUnsignedUpperCheck(module, block: dstBlock, valueId: retValId, upper: range.upper, typeInfo: typeInfo, panicBlockId: panicBlock.id, okBlockId: continueBlock.id, nextValueIdRef: nextValueIdRef)
						end 'unsignedCheck' else if needsUpperCheck and needsLowerCheck 'dualCheck'
							// Dual-bound with non-zero lower: two separate signed comparisons
							let loLabel = buildLabel("__range_check_lo_", id: checkId)
							let loCheckBlock = addBlock(module, func: dstFunc, label: loLabel)
							emitUpperCheck(module, block: dstBlock, valueId: retValId, upper: range.upper, typeInfo: typeInfo, passBlockId: loCheckBlock.id, panicBlockId: panicBlock.id, nextValueIdRef: nextValueIdRef)
							emitLowerCheck(module, block: loCheckBlock, valueId: retValId, lower: range.lower, typeInfo: typeInfo, passBlockId: continueBlock.id, panicBlockId: panicBlock.id, nextValueIdRef: nextValueIdRef)
						end 'dualCheck' else 'singleCheck'
							emitSingleRangeCheck(module, block: dstBlock, valueId: retValId, lower: range.lower, upper: range.upper, typeInfo: typeInfo, panicBlockId: panicBlock.id, okBlockId: continueBlock.id, nextValueIdRef: nextValueIdRef)
						end 'singleCheck'

						let panicMsg = buildPanicMessage(aliasName, sourceFileName: sourceFileName, sourceLine: srcFunc.returnLine)
						appendMaxonOp(module, block: panicBlock, op: MaxonOp.panic(panicMsg, panicId: checkId))
						setFuncTerminator(module, block: continueBlock, op: FuncOp.ret(retValId))
					end 'notConst'
				end 'isReturn' else 'notReturn'
					copyTerminator(srcBlock, dstBlock: dstBlock)
				end 'notReturn'
			end 'hasTerm'
		end 'eachBlock'

		newFunctions.push(dstFunc)
	end 'eachFunc'

	module.functions = newFunctions
	return module
end 'insertRangeChecks'

// Copy all blocks from srcFunc to dstFunc unchanged.
function copyFuncBlocks(module MlirModule, srcFunc MlirFunction, dstFunc MlirFunction)
	for blockRef in srcFunc.blocks 'eachBlock'
		let srcBlock = try module.blocks.get(blockRef) otherwise 'skipOp'
			continue
		end 'skipOp'
		var dstBlock = addBlock(module, func: dstFunc, label: srcBlock.label)
		dstBlock.id = srcBlock.id
		dstBlock.blockArgs = srcBlock.blockArgs
		for packed in srcBlock.ops 'eachOp'
			dstBlock.ops.append(packed)
		end 'eachOp'
		if srcBlock.hasTerminator 'hasTerm'
			copyTerminator(srcBlock, dstBlock: dstBlock)
		end 'hasTerm'
	end 'eachBlock'
	dstFunc.nextBlockId = srcFunc.nextBlockId
end 'copyFuncBlocks'

// Check if a terminator op is func.ret
function isTerminatorFuncRet(packed OpRef, module MlirModule) returns bool
	let tag = opRefDialect(packed)
	if tag == TAG_FUNC 'isFunc'
		let idx = opRefIndex(packed)
		let funcOp = try module.funcOps.get(idx) otherwise 'noFuncOp'
			return false
		end 'noFuncOp'
		return match funcOp 'checkRet'
			ret gives true
			call to param gives false
		end 'checkRet'
	end 'isFunc'
	return false
end 'isTerminatorFuncRet'

// Extract the return value ID from a func.ret terminator.
function extractRetValId(packed OpRef, module MlirModule) returns ValueId
	let tag = opRefDialect(packed)
	if tag == TAG_FUNC 'isFunc'
		let idx = opRefIndex(packed)
		let funcOp = try module.funcOps.get(idx) otherwise 'noFuncOp'
			return 0
		end 'noFuncOp'
		return match funcOp 'extractRet'
			ret(retValId) gives retValId
			call to param gives 0
		end 'extractRet'
	end 'isFunc'
	return 0
end 'extractRetValId'

let RANGE_CHECK_UNKNOWN = i64.max

// Find the constant value for a ValueId by searching for its arith.const definition.
// Returns RANGE_CHECK_UNKNOWN if not a constant.
function findConstValue(valueId ValueId, block MlirBlock, module MlirModule) returns ParsedInt
	for packed in block.ops 'search'
		let tag = opRefDialect(packed)
		if tag == TAG_ARITH 'isArith'
			let idx = opRefIndex(packed)
			let arithOp = try module.arithOps.get(idx) otherwise 'skipBlock'
				continue
			end 'skipBlock'
			let found = match arithOp 'checkConst'
				const(c) gives c.resultId == valueId
				unary to binary gives false
			end 'checkConst'
			if found 'isConst'
				return extractArithConstValue(arithOp)
			end 'isConst'
		end 'isArith'
	end 'search'
	return RANGE_CHECK_UNKNOWN
end 'findConstValue'

function extractArithConstValue(op ArithOp) returns ParsedInt
	return match op 'extract'
		const(c) gives c.value
		unary to binary gives RANGE_CHECK_UNKNOWN
	end 'extract'
end 'extractArithConstValue'

// Emit a bound check: compare value against bound, branch to thenBlock if true, else elseBlock.
function emitBoundCheck(module MlirModule, block MlirBlock, valueId ValueId, bound RangeBound, constOpcode ArithConstOpcode, cmpOpcode ArithBinaryOpcode, thenBlockId BlockId, elseBlockId BlockId, nextValueIdRef ValueIdRef)
	let boundLitId = allocValueId(nextValueIdRef)
	appendArithOp(module, block: block, op: ArithOp.const(ArithConst.create(constOpcode, resultId: boundLitId, value: bound)))
	let cmpId = allocValueId(nextValueIdRef)
	appendArithOp(module, block: block, op: ArithOp.binary(ArithBinaryOp.create(cmpOpcode, resultId: cmpId, leftId: valueId, rightId: boundLitId)))
	setCfTerminator(module, block: block, op: CfOp.condBr(cmpId, thenTarget: thenBlockId, thenArgIds: ValueIdArray.create(), elseTarget: elseBlockId, elseArgIds: ValueIdArray.create()))
end 'emitBoundCheck'

// Upper bound: cmp le -> passBlock, else -> panic (inverted so fallthrough elimination works)
function emitUpperCheck(module MlirModule, block MlirBlock, valueId ValueId, upper RangeBound, typeInfo RangeCheckTypeInfo, passBlockId BlockId, panicBlockId BlockId, nextValueIdRef ValueIdRef)
	emitBoundCheck(module, block: block, valueId: valueId, bound: upper, constOpcode: typeInfo.constOpcode, cmpOpcode: typeInfo.cmpLeOpcode, thenBlockId: passBlockId, elseBlockId: panicBlockId, nextValueIdRef: nextValueIdRef)
end 'emitUpperCheck'

// Lower bound: cmp lt -> panic, else -> passBlock
function emitLowerCheck(module MlirModule, block MlirBlock, valueId ValueId, lower RangeBound, typeInfo RangeCheckTypeInfo, passBlockId BlockId, panicBlockId BlockId, nextValueIdRef ValueIdRef)
	emitBoundCheck(module, block: block, valueId: valueId, bound: lower, constOpcode: typeInfo.constOpcode, cmpOpcode: typeInfo.cmpLtOpcode, thenBlockId: panicBlockId, elseBlockId: passBlockId, nextValueIdRef: nextValueIdRef)
end 'emitLowerCheck'

// Unsigned upper bound: single cmp ugt covers both bounds when lower == 0
function emitUnsignedUpperCheck(module MlirModule, block MlirBlock, valueId ValueId, upper RangeBound, typeInfo RangeCheckTypeInfo, panicBlockId BlockId, okBlockId BlockId, nextValueIdRef ValueIdRef)
	emitBoundCheck(module, block: block, valueId: valueId, bound: upper, constOpcode: typeInfo.constOpcode, cmpOpcode: ArithBinaryOpcode.cmpI64Ugt, thenBlockId: panicBlockId, elseBlockId: okBlockId, nextValueIdRef: nextValueIdRef)
end 'emitUnsignedUpperCheck'

// Single-bound range check (only upper or only lower).
function emitSingleRangeCheck(module MlirModule, block MlirBlock, valueId ValueId, lower RangeBound, upper RangeBound, typeInfo RangeCheckTypeInfo, panicBlockId BlockId, okBlockId BlockId, nextValueIdRef ValueIdRef)
	if upper < i64.max 'upperOnly'
		emitBoundCheck(module, block: block, valueId: valueId, bound: upper, constOpcode: typeInfo.constOpcode, cmpOpcode: typeInfo.cmpGtOpcode, thenBlockId: panicBlockId, elseBlockId: okBlockId, nextValueIdRef: nextValueIdRef)
	end 'upperOnly' else 'lowerOnly'
		emitBoundCheck(module, block: block, valueId: valueId, bound: lower, constOpcode: typeInfo.constOpcode, cmpOpcode: typeInfo.cmpLtOpcode, thenBlockId: panicBlockId, elseBlockId: okBlockId, nextValueIdRef: nextValueIdRef)
	end 'lowerOnly'
end 'emitSingleRangeCheck'

// Build a block label like "__range_panic_0".
function buildLabel(prefix String, id ValueId) returns String
	return "{prefix}{id}"
end 'buildLabel'

function buildPanicMessage(aliasName String, sourceFileName String, sourceLine LineNumber) returns String
	return "panic at {sourceFileName}:{sourceLine}: Range check failed: value outside typealias '{aliasName}'"
end 'buildPanicMessage'

// Check if a range covers the full i64 range (no value can be out of bounds).
// All values in the self-hosted compiler are i64 at runtime, so a range that
// spans i64.min to i64.max needs no check.
function isFullRange(range TypealiasRange) returns bool
	return range.lower <= i64.min and range.upper == i64.max
end 'isFullRange'

// Opcodes and StdType for range checks, resolved from the function's return type.
type RangeCheckTypeInfo
	export var stdType StdType
	export var constOpcode ArithConstOpcode
	export var cmpLtOpcode ArithBinaryOpcode
	export var cmpGtOpcode ArithBinaryOpcode
	export var cmpLeOpcode ArithBinaryOpcode
	export var cmpGeOpcode ArithBinaryOpcode

	static function create(stdType StdType, constOpcode ArithConstOpcode, cmpLtOpcode ArithBinaryOpcode, cmpGtOpcode ArithBinaryOpcode, cmpLeOpcode ArithBinaryOpcode, cmpGeOpcode ArithBinaryOpcode) returns RangeCheckTypeInfo
		return Self{stdType: stdType, constOpcode: constOpcode, cmpLtOpcode: cmpLtOpcode, cmpGtOpcode: cmpGtOpcode, cmpLeOpcode: cmpLeOpcode, cmpGeOpcode: cmpGeOpcode}
	end 'create'
end 'RangeCheckTypeInfo'

// Resolve the correct opcodes for a given MLIR return type.
// Panics on unrecognised types to catch missing cases early.
function resolveRangeCheckType(returnType String) returns RangeCheckTypeInfo
	if returnType == "f64" or returnType == "f32" 'isFloat'
		return RangeCheckTypeInfo.create(StdType.f64, constOpcode: ArithConstOpcode.constF64, cmpLtOpcode: ArithBinaryOpcode.cmpF64Lt, cmpGtOpcode: ArithBinaryOpcode.cmpF64Gt, cmpLeOpcode: ArithBinaryOpcode.cmpF64Le, cmpGeOpcode: ArithBinaryOpcode.cmpF64Ge)
	end 'isFloat'
	if returnType == "i64" or returnType == "i32" or returnType == "i16" or returnType == "i8" or returnType == "u64" or returnType == "u32" or returnType == "u16" or returnType == "u8" 'isInt'
		return RangeCheckTypeInfo.create(StdType.i64, constOpcode: ArithConstOpcode.constI64, cmpLtOpcode: ArithBinaryOpcode.cmpI64Lt, cmpGtOpcode: ArithBinaryOpcode.cmpI64Gt, cmpLeOpcode: ArithBinaryOpcode.cmpI64Le, cmpGeOpcode: ArithBinaryOpcode.cmpI64Ge)
	end 'isInt'
	panic("resolveRangeCheckType: unrecognised return type '{returnType}'")
end 'resolveRangeCheckType'

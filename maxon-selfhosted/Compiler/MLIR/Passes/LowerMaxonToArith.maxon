// Maxon -> Mid-level conversion, Pass A (Phase 2): lowerMaxonToArith
// Lowers maxon math/vars/cf/funcs to arith/memref/cf/func ops.
// Leaves printLiteral/printInt/panic as maxon ops for Phase 5.
//
// Lowers:
//   maxon.literal       -> arith.const
//   maxon.binop         -> arith.binary
//   maxon.unop          -> arith.unary
//   maxon.truncFloat    -> arith.unary (fpToSiI64)
//   maxon.intToFloat    -> arith.unary (siToFpF64)
//   maxon.cmp           -> arith.binary (comparison)
//   maxon.refEq         -> arith.binary (comparison)
//   maxon.varDecl/Store -> memref.storeSlot
//   maxon.varLoad       -> memref.loadSlot
//   maxon.condBr/br     -> cf.condBr/br
//   maxon.call/ret      -> func.call/ret
// Passes through:
//   maxon.printLiteral  -> unchanged (still maxon)
//   maxon.printInt      -> unchanged (still maxon)

export function lowerMaxonToArith(module MlirModule, project Project) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Running lower-maxon-to-arith pass")

	for func in module.functions 'eachFunc'
		for blockRef in func.blocks 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise 'skip'
				continue
			end 'skip'

			// Lower ops: save old list, give block a fresh list, iterate old ops
			let oldOps = block.ops
			block.ops = OpRefList.create()
			for packed in oldOps 'eachOp'
				let tag = opRefDialect(packed)
				if tag == TAG_MAXON 'isMaxon'
					let idx = opRefIndex(packed)
					let hlOp = try module.maxonOps.get(idx) otherwise 'skipOp'
						continue
					end 'skipOp'
					lowerMaxonOpToArith(module, hlOp: hlOp, dstBlock: block)
				end 'isMaxon' else 'passThrough'
					block.ops.append(packed)
				end 'passThrough'
			end 'eachOp'

			// Lower terminator
			if block.hasTerminator 'hasTerm'
				let termTag = opRefDialect(block.terminator)
				if termTag == TAG_MAXON 'isMaxonTerm'
					let termIdx = opRefIndex(block.terminator)
					let hlOp = try module.maxonOps.get(termIdx) otherwise 'skipBlock'
						continue
					end 'skipBlock'
					lowerMaxonTerminatorToArith(module, hlOp: hlOp, dstBlock: block)
				end 'isMaxonTerm'
			end 'hasTerm'
		end 'eachBlock'
	end 'eachFunc'

	// Resolve return types after lowering (requires mutable access via index)
	for i in 0 upto module.functions.count() 'resolveReturnTypes'
		var func = try module.functions.get(i) otherwise 'skipFunc'
			continue
		end 'skipFunc'
		func.returnType = resolveTypeName(project, name: func.returnType)
		module.functions.set(i, value: func)
	end 'resolveReturnTypes'

	return module
end 'lowerMaxonToArith'

function lowerMaxonOpToArith(module MlirModule, hlOp MaxonOp, dstBlock MlirBlock)
	match hlOp 'lower'
		literal(resultId, value, isFloat) then appendArithOp(module, block: dstBlock, op: ArithOp.const(ArithConst.create(literalToArithOpcode(isFloat), resultId: resultId, value: value)))
		varDecl(slotId, valueId) then appendMemrefOp(module, block: dstBlock, op: MemRefOp.storeSlot(slotId, valueId: valueId))
		varLoad(resultId, slotId) then appendMemrefOp(module, block: dstBlock, op: MemRefOp.loadSlot(resultId, slotId: slotId))
		varStore(slotId, valueId) then appendMemrefOp(module, block: dstBlock, op: MemRefOp.storeSlot(slotId, valueId: valueId))
		binop(resultId, leftId, rightId, opKind, isFloat) then appendArithOp(module, block: dstBlock, op: ArithOp.binary(ArithBinaryOp.create(binOpKindToArithOpcode(opKind, isFloat: isFloat), resultId: resultId, leftId: leftId, rightId: rightId)))
		unop(resultId, operandId, opKind, isFloat) then appendArithOp(module, block: dstBlock, op: ArithOp.unary(ArithUnaryOp.create(unaryOpKindToArithOpcode(opKind), resultId: resultId, operandId: operandId)))
		truncFloat(resultId, operandId) then appendArithOp(module, block: dstBlock, op: ArithOp.unary(ArithUnaryOp.create(ArithUnaryOpcode.fpToSiI64, resultId: resultId, operandId: operandId)))
		intToFloat(resultId, operandId) then appendArithOp(module, block: dstBlock, op: ArithOp.unary(ArithUnaryOp.create(ArithUnaryOpcode.siToFpF64, resultId: resultId, operandId: operandId)))
		cmp(resultId, leftId, rightId, predicate, isFloat) then appendArithOp(module, block: dstBlock, op: ArithOp.binary(ArithBinaryOp.create(cmpPredicateToArithOpcode(predicate, isFloat: isFloat), resultId: resultId, leftId: leftId, rightId: rightId)))
		refEq(resultId, leftId, rightId, negate) then appendArithOp(module, block: dstBlock, op: ArithOp.binary(ArithBinaryOp.create(refEqOpcode(negate), resultId: resultId, leftId: leftId, rightId: rightId)))
		condBr(condId, thenTarget, elseTarget) then appendCfOp(module, block: dstBlock, op: CfOp.condBr(condId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create()))
		br(target) then appendCfOp(module, block: dstBlock, op: CfOp.br(target, argIds: ValueIdArray.create()))
		call(resultId, callee, argIds) then appendFuncOp(module, block: dstBlock, op: FuncOp.call(resultId, callee: callee, argIds: argIds))
		ret(retValId) then appendFuncOp(module, block: dstBlock, op: FuncOp.ret(retValId))
		// Print and panic ops are NOT lowered here — they stay as maxon ops for Phase 5
		printLiteral(data) then appendMaxonOp(module, block: dstBlock, op: MaxonOp.printLiteral(data))
		printInt(valueId) then appendMaxonOp(module, block: dstBlock, op: MaxonOp.printInt(valueId))
		panic(message, panicId) then appendMaxonOp(module, block: dstBlock, op: MaxonOp.panic(message, panicId: panicId))
		// Struct ops: lower to runtime call (alloc) and sys load/store indirect
		structAlloc(resultId, byteSize) then lowerStructAlloc(module, resultId: resultId, byteSize: byteSize, dstBlock: dstBlock)
		fieldLoad(resultId, structId, offset) then appendSysOp(module, block: dstBlock, op: SysOp.loadIndirect(resultId, addrId: structId, offset: offset))
		fieldStore(structId, offset, valueId) then appendSysOp(module, block: dstBlock, op: SysOp.storeIndirect(structId, offset: offset, valueId: valueId))
	end 'lower'
end 'lowerMaxonOpToArith'

function lowerMaxonTerminatorToArith(module MlirModule, hlOp MaxonOp, dstBlock MlirBlock)
	match hlOp 'lower'
		condBr(condId, thenTarget, elseTarget) then setCfTerminator(module, block: dstBlock, op: CfOp.condBr(condId, thenTarget: thenTarget, thenArgIds: ValueIdArray.create(), elseTarget: elseTarget, elseArgIds: ValueIdArray.create()))
		br(target) then setCfTerminator(module, block: dstBlock, op: CfOp.br(target, argIds: ValueIdArray.create()))
		ret(retValId) then setFuncTerminator(module, block: dstBlock, op: FuncOp.ret(retValId))
		literal to refEq then setMaxonTerminator(module, block: dstBlock, op: hlOp)
		call then setMaxonTerminator(module, block: dstBlock, op: hlOp)
		printLiteral to panic then setMaxonTerminator(module, block: dstBlock, op: hlOp)
		structAlloc to fieldStore then setMaxonTerminator(module, block: dstBlock, op: hlOp)
	end 'lower'
end 'lowerMaxonTerminatorToArith'

// Allocates a heap struct by calling mrt_alloc with the byte size.
function lowerStructAlloc(module MlirModule, resultId ValueId, byteSize ValueId, dstBlock MlirBlock)
	let argIds = ValueIdArray.create()
	argIds.push(byteSize)
	appendFuncOp(module, block: dstBlock, op: FuncOp.call(resultId, callee: "mrt_alloc", argIds: argIds))
end 'lowerStructAlloc'

// ============================================================
// Helper functions
// ============================================================

function literalToArithOpcode(isFloat bool) returns ArithConstOpcode
	if isFloat 'f'
		return ArithConstOpcode.constF64
	end 'f'
	return ArithConstOpcode.constI64
end 'literalToArithOpcode'

function binOpKindToArithOpcode(opKind BinOpKind, isFloat bool) returns ArithBinaryOpcode
	if isFloat 'floatOp'
		return floatBinOpKindToArithOpcode(opKind)
	end 'floatOp'
	return match opKind 'map'
		add gives ArithBinaryOpcode.addI64
		sub gives ArithBinaryOpcode.subI64
		mul gives ArithBinaryOpcode.mulI64
		div gives ArithBinaryOpcode.divI64
		mod gives ArithBinaryOpcode.remI64
		bitAnd gives ArithBinaryOpcode.andI64
		bitOr gives ArithBinaryOpcode.orI64
		boolOr gives ArithBinaryOpcode.orI1
		bitXor gives ArithBinaryOpcode.xorI64
		shl gives ArithBinaryOpcode.shlI64
		shr gives ArithBinaryOpcode.shrI64
	end 'map'
end 'binOpKindToArithOpcode'

function floatBinOpKindToArithOpcode(opKind BinOpKind) returns ArithBinaryOpcode
	match opKind 'dispatch'
		add then return ArithBinaryOpcode.addF64
		sub then return ArithBinaryOpcode.subF64
		mul then return ArithBinaryOpcode.mulF64
		div then return ArithBinaryOpcode.divF64
		mod to shr then panic("floatBinOpKindToArithOpcode: bitwise/mod ops not supported on floats")
	end 'dispatch'
end 'floatBinOpKindToArithOpcode'

function unaryOpKindToArithOpcode(opKind UnaryOpKind) returns ArithUnaryOpcode
	return match opKind 'map'
		neg gives ArithUnaryOpcode.negI64
		bitNot gives ArithUnaryOpcode.bitNotI64
	end 'map'
end 'unaryOpKindToArithOpcode'

function cmpPredicateToArithOpcode(predicate CmpPredicate, isFloat bool) returns ArithBinaryOpcode
	if isFloat 'f'
		return match predicate 'floatOp'
			eq gives ArithBinaryOpcode.cmpF64Eq
			ne gives ArithBinaryOpcode.cmpF64Ne
			lt gives ArithBinaryOpcode.cmpF64Lt
			le gives ArithBinaryOpcode.cmpF64Le
			gt gives ArithBinaryOpcode.cmpF64Gt
			ge gives ArithBinaryOpcode.cmpF64Ge
		end 'floatOp'
	end 'f'
	return match predicate 'intOp'
		eq gives ArithBinaryOpcode.cmpI64Eq
		ne gives ArithBinaryOpcode.cmpI64Ne
		lt gives ArithBinaryOpcode.cmpI64Lt
		le gives ArithBinaryOpcode.cmpI64Le
		gt gives ArithBinaryOpcode.cmpI64Gt
		ge gives ArithBinaryOpcode.cmpI64Ge
	end 'intOp'
end 'cmpPredicateToArithOpcode'

function refEqOpcode(negate bool) returns ArithBinaryOpcode
	if negate 'ne'
		return ArithBinaryOpcode.cmpI64Ne
	end 'ne'
	return ArithBinaryOpcode.cmpI64Eq
end 'refEqOpcode'

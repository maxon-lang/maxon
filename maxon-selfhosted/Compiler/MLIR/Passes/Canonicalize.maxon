// Canonicalize Pass — Constant folding for arithmetic ops.
// Walks module -> functions -> blocks -> ops.
// For each arith.binary where both operands are arith.const in the same block,
// folds the computation into a new arith.const.
// Currently folds: addI64, subI64, mulI64. All others are left as-is.

// Sentinel meaning "no known constant for this ValueId"
let CONST_UNKNOWN = i64.max

// Per-block constant map: maps ValueId -> known constant value.
// CONST_UNKNOWN means the ValueId is not a known constant.

function constMapSet(map ValueIdArray, valueId ValueId, value ParsedInt)
	while map.count() <= valueId 'grow'
		map.push(CONST_UNKNOWN)
	end 'grow'
	map.set(valueId, value: value)
end 'constMapSet'

function constMapGet(map ValueIdArray, valueId ValueId) returns ParsedInt
	if valueId >= map.count() 'outOfBounds'
		return CONST_UNKNOWN
	end 'outOfBounds'
	return try map.get(valueId) otherwise CONST_UNKNOWN
end 'constMapGet'

export function canonicalize(module MlirModule) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Running canonicalize pass")

	for func in module.functions 'eachFunc'
		for blockRef in func.blockRefs 'eachBlock'
			var block = try module.blocks.get(blockRef) otherwise 'skip'
				panic("Block not found in module")
			end 'skip'

			// Build a per-block constant map and fold ops
			let constMap = ValueIdArray.create()

			let oldOps = block.opRefs
			block.opRefs = OpRefList.create()
			for packed in oldOps 'eachOp'
				tryFoldPackedOp(module, packed: packed, constMap: constMap, dstBlock: block)
			end 'eachOp'
			// Terminators are never foldable — left in place
		end 'eachBlock'
	end 'eachFunc'

	return module
end 'canonicalize'

// Try to fold a packed op. If it is a foldable arith.binary with both operands
// known constant, replace with arith.const. Otherwise pass through unchanged.
// Also populates constMap for arith.const ops encountered.
function tryFoldPackedOp(module MlirModule, packed OpRef, constMap ValueIdArray, dstBlock MlirBlock)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noOp'
			dstBlock.opRefs.append(packed)
			return
		end 'noOp'
		tryFoldArithOp(module, op: arithOp, constMap: constMap, dstBlock: dstBlock)
		return
	end 'isArith'

	// All non-arith ops pass through unchanged
	dstBlock.opRefs.append(packed)
end 'tryFoldPackedOp'

function tryFoldArithOp(module MlirModule, op ArithOp, constMap ValueIdArray, dstBlock MlirBlock)
	match op 'dispatch'
		const(c) then registerAndPassConst(module, c: c, constMap: constMap, dstBlock: dstBlock)
		binary(b) then tryFoldBinaryOp(module, b: b, constMap: constMap, dstBlock: dstBlock)
		unary(u) then appendArithOp(module, block: dstBlock, op: ArithOp.unary(u))
	end 'dispatch'
end 'tryFoldArithOp'

// Register an arith.const value in the constant map and emit it unchanged.
function registerAndPassConst(module MlirModule, c ArithConst, constMap ValueIdArray, dstBlock MlirBlock)
	// Only track integer constants for folding (float folding is future work)
	match c.opcode 'checkOpcode'
		constI64 then constMapSet(constMap, valueId: c.resultId, value: c.value)
		constF64 then break 'checkOpcode'
	end 'checkOpcode'
	appendArithOp(module, block: dstBlock, op: ArithOp.const(c))
end 'registerAndPassConst'

// Try to fold a binary op. If both operands are known integer constants
// and the opcode is one we can fold, produce a new arith.const.
function tryFoldBinaryOp(module MlirModule, b ArithBinaryOp, constMap ValueIdArray, dstBlock MlirBlock)
	let leftVal = constMapGet(constMap, valueId: b.leftId)
	let rightVal = constMapGet(constMap, valueId: b.rightId)

	// If either operand is not a known constant, emit the op unchanged
	if leftVal == CONST_UNKNOWN or rightVal == CONST_UNKNOWN 'notFoldable'
		appendArithOp(module, block: dstBlock, op: ArithOp.binary(b))
		return
	end 'notFoldable'

	// Try to compute the folded value
	let foldResult = tryComputeFold(b.opcode, leftVal: leftVal, rightVal: rightVal)
	if foldResult == CONST_UNKNOWN 'cannotFold'
		appendArithOp(module, block: dstBlock, op: ArithOp.binary(b))
		return
	end 'cannotFold'

	// Successfully folded: emit a new arith.const with the binary op's resultId
	// Register the folded value so downstream ops can also fold
	constMapSet(constMap, valueId: b.resultId, value: foldResult)
	logTrace(LogCategory.mlir, message: () gives "canonicalize: folded %{b.resultId} = {b.opcode.rawValue} %{b.leftId}, %{b.rightId} -> const {foldResult}")
	appendArithOp(module, block: dstBlock, op: ArithOp.const(ArithConst.create(ArithConstOpcode.constI64, resultId: b.resultId, value: foldResult)))
end 'tryFoldBinaryOp'

// Compute the folded value for an integer binary op.
// Returns CONST_UNKNOWN if the opcode is not supported for folding.
function tryComputeFold(opcode ArithBinaryOpcode, leftVal ParsedInt, rightVal ParsedInt) returns ParsedInt
	return match opcode 'fold'
		addI64 gives leftVal + rightVal
		subI64 gives leftVal - rightVal
		mulI64 gives leftVal * rightVal
		divI64 to shrI64 gives CONST_UNKNOWN
		addF64 to divF64 gives CONST_UNKNOWN
		cmpI64Eq to cmpF64Ge gives CONST_UNKNOWN
	end 'fold'
end 'tryComputeFold'

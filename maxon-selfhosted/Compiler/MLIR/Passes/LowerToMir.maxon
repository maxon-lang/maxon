// Mid-to-MIR Conversion (Phase 6).
// Converts mid-level dialect ops (arith, cf, func, memref, sys, runtime)
// into target-independent MIR dialect ops. After this pass, only mir ops
// remain (plus pass-through memref/sys ops and x64/arm64 ops).

// ============================================================
// Public entry point
// ============================================================

export function lowerToMir(module MlirModule) returns MlirModule
	logDebug(LogCategory.mlir, message: () gives "Running lower-to-mir pass")
	let newFunctions = MlirFunctionArray.create()

	for srcFunc in module.functions 'eachFunc'
		var dstFunc = cloneFunctionShell(srcFunc)

		for blockRef in srcFunc.blocks 'eachBlock'
			let srcBlock = try module.blocks.get(blockRef) otherwise 'skip'
				continue
			end 'skip'
			var dstBlock = addBlock(module, func: dstFunc, label: srcBlock.label)
			dstBlock.id = srcBlock.id
			dstBlock.blockArgs = srcBlock.blockArgs

			// Convert non-terminator ops
			for packed in srcBlock.ops 'eachOp'
				convertOpToMir(module, packed: packed, dstBlock: dstBlock)
			end 'eachOp'

			// Convert terminator
			if srcBlock.hasTerminator 'hasTerm'
				convertTerminatorToMir(module, packed: srcBlock.terminator, dstBlock: dstBlock)
			end 'hasTerm'
		end 'eachBlock'

		dstFunc.nextBlockId = srcFunc.nextBlockId
		newFunctions.push(dstFunc)
	end 'eachFunc'

	module.functions = newFunctions
	return module
end 'lowerToMir'

// ============================================================
// Top-level op dispatch
// ============================================================

function convertOpToMir(module MlirModule, packed OpRef, dstBlock MlirBlock)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_MAXON 'isMaxon'
		panic("lower-to-mir: unexpected maxon op — should have been fully lowered by Phase 5")
	end 'isMaxon'

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noOp'
			panic("lower-to-mir: invalid arith op index {idx}")
		end 'noOp'
		convertArithOpToMir(module, arithOp: arithOp, dstBlock: dstBlock)
		return
	end 'isArith'

	if tag == TAG_CF 'isCf'
		let cfOp = try module.cfOps.get(idx) otherwise 'noBlock'
			panic("lower-to-mir: invalid cf op index {idx}")
		end 'noBlock'
		convertCfOpToMir(module, cfOp: cfOp, dstBlock: dstBlock)
		return
	end 'isCf'

	if tag == TAG_FUNC 'isFunc'
		let funcOp = try module.funcOps.get(idx) otherwise 'noMatch'
			panic("lower-to-mir: invalid func op index {idx}")
		end 'noMatch'
		convertFuncOpToMir(module, funcOp: funcOp, dstBlock: dstBlock)
		return
	end 'isFunc'

	if tag == TAG_MEMREF 'isMemref'
		let memrefOp = try module.memrefOps.get(idx) otherwise 'noResult'
			panic("lower-to-mir: invalid memref op index {idx}")
		end 'noResult'
		convertMemRefOpToMir(module, memrefOp: memrefOp, dstBlock: dstBlock)
		return
	end 'isMemref'

	if tag == TAG_RUNTIME 'isRuntime'
		let rtOp = try module.runtimeOps.get(idx) otherwise 'noEntry'
			panic("lower-to-mir: invalid runtime op index {idx}")
		end 'noEntry'
		convertRuntimeOpToMir(rtOp, dstBlock: dstBlock)
		return
	end 'isRuntime'

	if tag == TAG_SYS 'isSys'
		let sysOp = try module.sysOps.get(idx) otherwise 'noItem'
			panic("lower-to-mir: invalid sys op index {idx}")
		end 'noItem'
		convertSysOpToMir(module, sysOp: sysOp, dstBlock: dstBlock)
		return
	end 'isSys'

	// mir, x64, arm64 pass through as-is
	dstBlock.ops.append(packed)
end 'convertOpToMir'

function convertTerminatorToMir(module MlirModule, packed OpRef, dstBlock MlirBlock)
	let tag = opRefDialect(packed)
	let idx = opRefIndex(packed)

	if tag == TAG_MAXON 'isMaxon'
		panic("lower-to-mir: unexpected maxon terminator — should have been fully lowered by Phase 5")
	end 'isMaxon'

	if tag == TAG_ARITH 'isArith'
		let arithOp = try module.arithOps.get(idx) otherwise 'noElem'
			panic("lower-to-mir: invalid arith terminator index {idx}")
		end 'noElem'
		convertArithOpToMir(module, arithOp: arithOp, dstBlock: dstBlock)
		return
	end 'isArith'

	if tag == TAG_CF 'isCf'
		let cfOp = try module.cfOps.get(idx) otherwise 'noVal'
			panic("lower-to-mir: invalid cf terminator index {idx}")
		end 'noVal'
		convertCfTerminatorToMir(module, cfOp: cfOp, dstBlock: dstBlock)
		return
	end 'isCf'

	if tag == TAG_FUNC 'isFunc'
		let funcOp = try module.funcOps.get(idx) otherwise 'noRef'
			panic("lower-to-mir: invalid func terminator index {idx}")
		end 'noRef'
		convertFuncTerminatorToMir(module, funcOp: funcOp, dstBlock: dstBlock)
		return
	end 'isFunc'

	if tag == TAG_MEMREF 'isMemref'
		let memrefOp = try module.memrefOps.get(idx) otherwise 'noIdx'
			panic("lower-to-mir: invalid memref terminator index {idx}")
		end 'noIdx'
		convertMemRefOpToMir(module, memrefOp: memrefOp, dstBlock: dstBlock)
		return
	end 'isMemref'

	if tag == TAG_RUNTIME 'isRuntime'
		let rtOp = try module.runtimeOps.get(idx) otherwise 'noData'
			panic("lower-to-mir: invalid runtime terminator index {idx}")
		end 'noData'
		convertRuntimeOpToMir(rtOp, dstBlock: dstBlock)
		return
	end 'isRuntime'

	if tag == TAG_SYS 'isSys'
		let sysOp = try module.sysOps.get(idx) otherwise 'notFound'
			panic("lower-to-mir: invalid sys terminator index {idx}")
		end 'notFound'
		convertSysOpToMir(module, sysOp: sysOp, dstBlock: dstBlock)
		return
	end 'isSys'

	// mir, x64, arm64 pass through as terminator
	dstBlock.terminator = packed
	dstBlock.hasTerminator = true
end 'convertTerminatorToMir'

// ============================================================
// Arith dialect conversion
// ============================================================

function convertArithOpToMir(module MlirModule, arithOp ArithOp, dstBlock MlirBlock)
	match arithOp 'dispatch'
		const(c) then convertArithConstToMir(module, c: c, dstBlock: dstBlock)
		unary(u) then convertArithUnaryToMir(module, u: u, dstBlock: dstBlock)
		binary(b) then convertArithBinaryToMir(module, b: b, dstBlock: dstBlock)
	end 'dispatch'
end 'convertArithOpToMir'

function convertArithConstToMir(module MlirModule, c ArithConst, dstBlock MlirBlock)
	let isFloat = c.opcode == ArithConstOpcode.constF64
	let mirOp = MirOp.movImm(c.resultId, value: c.value, isFloat: isFloat)
	appendMirOp(module, block: dstBlock, op: mirOp)
end 'convertArithConstToMir'

function convertArithUnaryToMir(module MlirModule, u ArithUnaryOp, dstBlock MlirBlock)
	let mirOpcode = arithUnaryOpcodeToMir(u.opcode)
	let mirOp = MirOp.unaryOp(u.resultId, operandId: u.operandId, opcode: mirOpcode)
	appendMirOp(module, block: dstBlock, op: mirOp)
end 'convertArithUnaryToMir'

function convertArithBinaryToMir(module MlirModule, b ArithBinaryOp, dstBlock MlirBlock)
	if isComparisonOpcode(b.opcode) 'isCmp'
		let predicate = arithBinaryOpcodeToCmpPredicate(b.opcode)
		let mirOp = MirOp.cmp(b.resultId, leftId: b.leftId, rightId: b.rightId, predicate: predicate)
		appendMirOp(module, block: dstBlock, op: mirOp)
	end 'isCmp' else 'isArith'
		let mirOpcode = arithBinaryOpcodeToMir(b.opcode)
		let mirOp = MirOp.binOp(b.resultId, leftId: b.leftId, rightId: b.rightId, opcode: mirOpcode)
		appendMirOp(module, block: dstBlock, op: mirOp)
	end 'isArith'
end 'convertArithBinaryToMir'

// ============================================================
// Cf dialect conversion
// ============================================================

function convertCfOpToMir(module MlirModule, cfOp CfOp, dstBlock MlirBlock)
	let mirOp = convertCfToMirOp(cfOp)
	appendMirOp(module, block: dstBlock, op: mirOp)
end 'convertCfOpToMir'

function convertCfTerminatorToMir(module MlirModule, cfOp CfOp, dstBlock MlirBlock)
	let mirOp = convertCfToMirOp(cfOp)
	setMirTerminator(module, block: dstBlock, op: mirOp)
end 'convertCfTerminatorToMir'

function convertCfToMirOp(cfOp CfOp) returns MirOp
	return match cfOp 'dispatch'
		br(target, argIds) gives MirOp.branch(target, args: argIds)
		condBr(condId, thenTarget, thenArgIds, elseTarget, elseArgIds) gives MirOp.condBranch(condId, thenBlock: thenTarget, thenArgs: thenArgIds, elseBlock: elseTarget, elseArgs: elseArgIds)
	end 'dispatch'
end 'convertCfToMirOp'

// ============================================================
// Func dialect conversion
// ============================================================

function convertFuncOpToMir(module MlirModule, funcOp FuncOp, dstBlock MlirBlock)
	match funcOp 'dispatch'
		call(resultId, callee, argIds) then appendMirOp(module, block: dstBlock, op: MirOp.call(resultId, callee: callee, argIds: argIds))
		ret(retValId) then appendMirOp(module, block: dstBlock, op: MirOp.ret(retValId))
		param(resultId, paramIndex, paramType) then appendMirOp(module, block: dstBlock, op: MirOp.param(resultId, paramIndex: paramIndex, paramType: paramType))
		indirectCall(resultId, calleeId, argIds) then appendMirOp(module, block: dstBlock, op: MirOp.indirectCall(resultId, calleeId: calleeId, argIds: argIds))
		funcRef(resultId, funcName) then appendMirOp(module, block: dstBlock, op: MirOp.globalAddr(resultId, name: funcName))
		tailCall(callee, argIds) then appendMirOp(module, block: dstBlock, op: MirOp.call(0, callee: callee, argIds: argIds))
		tryCall(resultId, callee, argIds, _) then appendMirOp(module, block: dstBlock, op: MirOp.call(resultId, callee: callee, argIds: argIds))
	end 'dispatch'
end 'convertFuncOpToMir'

function convertFuncTerminatorToMir(module MlirModule, funcOp FuncOp, dstBlock MlirBlock)
	match funcOp 'dispatch'
		ret(retValId) then setMirTerminator(module, block: dstBlock, op: MirOp.ret(retValId))
		call(resultId, callee, argIds) then setMirTerminator(module, block: dstBlock, op: MirOp.call(resultId, callee: callee, argIds: argIds))
		tailCall(callee, argIds) then setMirTerminator(module, block: dstBlock, op: MirOp.call(0, callee: callee, argIds: argIds))
		tryCall(resultId, callee, argIds, _) then setMirTerminator(module, block: dstBlock, op: MirOp.call(resultId, callee: callee, argIds: argIds))
		param(resultId, paramIndex, paramType) then appendMirOp(module, block: dstBlock, op: MirOp.param(resultId, paramIndex: paramIndex, paramType: paramType))
		indirectCall(resultId, calleeId, argIds) then setMirTerminator(module, block: dstBlock, op: MirOp.indirectCall(resultId, calleeId: calleeId, argIds: argIds))
		funcRef(resultId, funcName) then appendMirOp(module, block: dstBlock, op: MirOp.globalAddr(resultId, name: funcName))
	end 'dispatch'
end 'convertFuncTerminatorToMir'

// ============================================================
// MemRef dialect conversion
// ============================================================
// Remaining memref ops after mem2reg are passed through as-is.
// The target backends (MidToX64/Arm64) handle memref.storeSlot/loadSlot
// natively with slot-based addressing (movSlot/loadSlot x64 ops), which is
// more efficient than expanding to stackSlotAddr + store/load pairs.

function convertMemRefOpToMir(module MlirModule, memrefOp MemRefOp, dstBlock MlirBlock)
	appendMemrefOp(module, block: dstBlock, op: memrefOp)
end 'convertMemRefOpToMir'

// ============================================================
// Sys dialect conversion
// ============================================================

function convertSysOpToMir(module MlirModule, sysOp SysOp, dstBlock MlirBlock)
	match sysOp 'dispatch'
		syscall(resultId, number, argIds) then appendMirOp(module, block: dstBlock, op: MirOp.syscall(resultId, number: number, argIds: argIds))
		iatCall(resultId, slotIndex, argIds) then appendMirOp(module, block: dstBlock, op: MirOp.iatCall(resultId, slotIndex: slotIndex, argIds: argIds))
		globalAddr(resultId, name) then appendMirOp(module, block: dstBlock, op: MirOp.globalAddr(resultId, name: name))
		memcpy(dstId, srcId, lenId) then appendMirOp(module, block: dstBlock, op: MirOp.memcpy(dstId, srcId: srcId, lenId: lenId))
		stackAddr(resultId, slotId) then appendMirOp(module, block: dstBlock, op: MirOp.stackSlotAddr(resultId, slotId: slotId))
		storeByte(baseId, offsetId, byteId) then appendMirOp(module, block: dstBlock, op: MirOp.storeByte(baseId, offsetId: offsetId, byteId: byteId))
		loadByte(resultId, baseId, offsetId) then appendMirOp(module, block: dstBlock, op: MirOp.loadByte(resultId, baseId: baseId, offsetId: offsetId))
		osExit(codeId) then appendMirOp(module, block: dstBlock, op: MirOp.osExit(codeId))
		osWrite(ptrId, lenId) then appendMirOp(module, block: dstBlock, op: MirOp.osWrite(ptrId, lenId: lenId))
		free(ptrId) then convertSysFreeToMir(module, ptrId: ptrId, dstBlock: dstBlock)
		osWriteErr then appendSysOp(module, block: dstBlock, op: sysOp)
		loadFramePtr then appendSysOp(module, block: dstBlock, op: sysOp)
		loadIndirect then appendSysOp(module, block: dstBlock, op: sysOp)
		funcAddr then appendSysOp(module, block: dstBlock, op: sysOp)
		storeIndirect then appendSysOp(module, block: dstBlock, op: sysOp)
	end 'dispatch'
end 'convertSysOpToMir'

function convertSysFreeToMir(module MlirModule, ptrId ValueId, dstBlock MlirBlock)
	let argIds = ValueIdArray.create()
	argIds.push(ptrId)
	appendMirOp(module, block: dstBlock, op: MirOp.call(0, callee: b"mrt_free", argIds: argIds))
end 'convertSysFreeToMir'

// ============================================================
// Runtime dialect conversion
// ============================================================

function convertRuntimeOpToMir(rtOp RuntimeOp, dstBlock MlirBlock)
	match rtOp 'dispatch'
		printLiteral then panic("lower-to-mir: runtime.printLiteral should have been lowered in Phase 5 ({dstBlock.id})")
		printInt then panic("lower-to-mir: runtime.printInt should have been lowered in Phase 5")
		// runtime.drop is a no-op for primitive types. Emit nothing.
		drop then break 'dispatch'
	end 'dispatch'
end 'convertRuntimeOpToMir'

// ============================================================
// Opcode mapping helpers
// ============================================================

// Maps arithmetic binary opcodes to MIR binary opcodes.
// Only call this for non-comparison opcodes.
function arithBinaryOpcodeToMir(opcode ArithBinaryOpcode) returns MirBinOpcode
	match opcode 'check'
		cmpI64Eq to cmpF64Ge then panic("arithBinaryOpcodeToMir: comparison opcode passed to arithmetic mapping")
		addI64 to divF64 then break 'check'
	end 'check'
	return match opcode 'map'
		addI64 gives MirBinOpcode.addI64
		subI64 gives MirBinOpcode.subI64
		mulI64 gives MirBinOpcode.mulI64
		divI64 gives MirBinOpcode.divI64
		remI64 gives MirBinOpcode.remI64
		andI64 gives MirBinOpcode.andI64
		orI64 gives MirBinOpcode.orI64
		orI1 gives MirBinOpcode.orI64
		xorI64 gives MirBinOpcode.xorI64
		shlI64 gives MirBinOpcode.shlI64
		shrI64 gives MirBinOpcode.shrI64
		addF64 gives MirBinOpcode.addF64
		subF64 gives MirBinOpcode.subF64
		mulF64 gives MirBinOpcode.mulF64
		divF64 gives MirBinOpcode.divF64
		default panic("arithBinaryOpcodeToMir: comparison opcode in arithmetic mapping")
	end 'map'
end 'arithBinaryOpcodeToMir'

// Maps comparison binary opcodes to MIR comparison predicates.
// Only call this for comparison opcodes.
function arithBinaryOpcodeToCmpPredicate(opcode ArithBinaryOpcode) returns MirCmpPredicate
	match opcode 'check'
		addI64 to divF64 then panic("arithBinaryOpcodeToCmpPredicate: arithmetic opcode passed to comparison mapping")
		cmpI64Eq to cmpF64Ge then break 'check'
	end 'check'
	return match opcode 'map'
		cmpI64Eq gives MirCmpPredicate.eq
		cmpI64Ne gives MirCmpPredicate.ne
		cmpI64Lt gives MirCmpPredicate.lt
		cmpI64Le gives MirCmpPredicate.le
		cmpI64Gt gives MirCmpPredicate.gt
		cmpI64Ge gives MirCmpPredicate.ge
		cmpI64Ugt gives MirCmpPredicate.ugt
		cmpF64Eq gives MirCmpPredicate.feq
		cmpF64Ne gives MirCmpPredicate.fne
		cmpF64Lt gives MirCmpPredicate.flt
		cmpF64Le gives MirCmpPredicate.fle
		cmpF64Gt gives MirCmpPredicate.fgt
		cmpF64Ge gives MirCmpPredicate.fge
		default panic("arithBinaryOpcodeToCmpPredicate: arithmetic opcode in comparison mapping")
	end 'map'
end 'arithBinaryOpcodeToCmpPredicate'

// Returns true if the ArithBinaryOpcode is a comparison (cmpI64* or cmpF64*).
function isComparisonOpcode(opcode ArithBinaryOpcode) returns bool
	return match opcode 'check'
		addI64 to divF64 gives false
		cmpI64Eq to cmpF64Ge gives true
	end 'check'
end 'isComparisonOpcode'

// Maps unary opcodes from the arith dialect to MIR unary opcodes.
function arithUnaryOpcodeToMir(opcode ArithUnaryOpcode) returns MirUnaryOpcode
	return match opcode 'map'
		negI64 gives MirUnaryOpcode.negI64
		bitNotI64 gives MirUnaryOpcode.bitNotI64
		fpToSiI64 gives MirUnaryOpcode.fpToSiI64
		siToFpF64 gives MirUnaryOpcode.siToFpF64
	end 'map'
end 'arithUnaryOpcodeToMir'

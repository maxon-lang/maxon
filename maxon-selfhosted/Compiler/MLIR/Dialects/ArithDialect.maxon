// Arith Dialect — Standard typed arithmetic operations.
// Split into const, unary, and binary sub-enums for type-safe dispatch.

export union ArithOp
	const(op ArithConst)
	unary(op ArithUnaryOp)
	binary(op ArithBinaryOp)
end 'ArithOp'

export typealias ArithOpArray = Array with ArithOp

export union ArithConstOpcode
	constI64
	constF64
end 'ArithConstOpcode'

export type ArithConst
	export let opcode ArithConstOpcode
	export let resultId ValueId
	export let value ParsedInt

	export static function create(opcode ArithConstOpcode, resultId ValueId, value ParsedInt) returns ArithConst
		return Self{opcode: opcode, resultId: resultId, value: value}
	end 'create'
end 'ArithConst'

export union ArithUnaryOpcode
	negI64
	bitNotI64
	fpToSiI64
	siToFpF64
end 'ArithUnaryOpcode'

export type ArithUnaryOp
	export let opcode ArithUnaryOpcode
	export let resultId ValueId
	export let operandId ValueId

	export static function create(opcode ArithUnaryOpcode, resultId ValueId, operandId ValueId) returns ArithUnaryOp
		return Self{opcode: opcode, resultId: resultId, operandId: operandId}
	end 'create'
end 'ArithUnaryOp'

export union ArithBinaryOpcode
	addI64 = "addi"
	subI64 = "subi"
	mulI64 = "muli"
	divI64 = "divsi"
	remI64 = "remsi"
	andI64 = "andi"
	orI64 = "ori"
	orI1 = "ori1"
	xorI64 = "xori"
	shlI64 = "shli"
	shrI64 = "shrsi"
	addF64 = "addf"
	subF64 = "subf"
	mulF64 = "mulf"
	divF64 = "divf"
	cmpI64Eq = "cmpi eq,"
	cmpI64Ne = "cmpi ne,"
	cmpI64Lt = "cmpi lt,"
	cmpI64Le = "cmpi le,"
	cmpI64Gt = "cmpi gt,"
	cmpI64Ge = "cmpi ge,"
	cmpI64Ugt = "cmpi ugt,"
	cmpF64Eq = "cmpf eq,"
	cmpF64Ne = "cmpf ne,"
	cmpF64Lt = "cmpf lt,"
	cmpF64Le = "cmpf le,"
	cmpF64Gt = "cmpf gt,"
	cmpF64Ge = "cmpf ge,"
end 'ArithBinaryOpcode'

export type ArithBinaryOp
	export let opcode ArithBinaryOpcode
	export let resultId ValueId
	export let leftId ValueId
	export let rightId ValueId

	export static function create(opcode ArithBinaryOpcode, resultId ValueId, leftId ValueId, rightId ValueId) returns ArithBinaryOp
		return Self{opcode: opcode, resultId: resultId, leftId: leftId, rightId: rightId}
	end 'create'
end 'ArithBinaryOp'

export function arithOpToString(op ArithOp) returns String
	return match op 'dispatch'
		const(c) gives arithConstToString(c)
		unary(u) gives arithUnaryOpToString(u)
		binary(b) gives "%{b.resultId} = arith.{b.opcode.rawValue} %{b.leftId}, %{b.rightId}"
	end 'dispatch'
end 'arithOpToString'

function arithConstToString(op ArithConst) returns String
	return match op.opcode 'toString'
		constI64 gives "%{op.resultId} = arith.constant \{value = {op.value} : i64\}"
		constF64 gives "%{op.resultId} = arith.float_constant \{value = {op.value} : f64\}"
	end 'toString'
end 'arithConstToString'

function arithUnaryOpToString(op ArithUnaryOp) returns String
	return match op.opcode 'toString'
		negI64 gives "%{op.resultId} = arith.negi %{op.operandId}"
		bitNotI64 gives "%{op.resultId} = arith.noti %{op.operandId}"
		fpToSiI64 gives "%{op.resultId} = arith.fptosi %{op.operandId}"
		siToFpF64 gives "%{op.resultId} = arith.sitofp %{op.operandId}"
	end 'toString'
end 'arithUnaryOpToString'

// Arith Dialect — Standard typed arithmetic operations.
// Split into const, unary, and binary sub-unions for type-safe dispatch.

export union ArithConst
  constI64(resultId ValueId, value ParsedInt)
  constF64(resultId ValueId, rawBits ParsedInt)
end 'ArithConst'

export union ArithUnaryOp
  negI64(resultId ValueId, operandId ValueId)
  bitNotI64(resultId ValueId, operandId ValueId)
end 'ArithUnaryOp'

export enum ArithBinaryOpcode
  addI64
  subI64
  mulI64
  divI64
  remI64
  andI64
  orI64
  xorI64
  shlI64
  shrI64
  cmpI64Eq
  cmpI64Ne
  cmpI64Lt
  cmpI64Le
  cmpI64Gt
  cmpI64Ge
  cmpF64Eq
  cmpF64Ne
  cmpF64Lt
  cmpF64Le
  cmpF64Gt
  cmpF64Ge
end 'ArithBinaryOpcode'

export type ArithBinaryOp
  export let opcode ArithBinaryOpcode
  export let resultId ValueId
  export let leftId ValueId
  export let rightId ValueId
end 'ArithBinaryOp'

export union ArithOp
  const(op ArithConst)
  unary(op ArithUnaryOp)
  binary(op ArithBinaryOp)
end 'ArithOp'

export function printArithOp(op ArithOp) returns String
  return match op 'dispatch'
    const(c) gives printArithConst(c)
    unary(u) gives printArithUnaryOp(u)
    binary(b) gives printArithBinaryOp(b)
  end 'dispatch'
end 'printArithOp'

function printArithConst(op ArithConst) returns String
  return match op 'print'
    constI64(resultId, value) gives "%{resultId} = arith.constant \{value = {value} : i64\}"
    constF64(resultId, rawBits) gives "%{resultId} = arith.float_constant \{rawBits = {rawBits} : f64\}"
  end 'print'
end 'printArithConst'

function printArithUnaryOp(op ArithUnaryOp) returns String
  return match op 'print'
    negI64(resultId, operandId) gives "%{resultId} = arith.negi %{operandId}"
    bitNotI64(resultId, operandId) gives "%{resultId} = arith.noti %{operandId}"
  end 'print'
end 'printArithUnaryOp'

function printArithBinaryOp(op ArithBinaryOp) returns String
  let name = match op.opcode 'name'
    ArithBinaryOpcode.addI64 gives "addi"
    ArithBinaryOpcode.subI64 gives "subi"
    ArithBinaryOpcode.mulI64 gives "muli"
    ArithBinaryOpcode.divI64 gives "divsi"
    ArithBinaryOpcode.remI64 gives "remsi"
    ArithBinaryOpcode.andI64 gives "andi"
    ArithBinaryOpcode.orI64 gives "ori"
    ArithBinaryOpcode.xorI64 gives "xori"
    ArithBinaryOpcode.shlI64 gives "shli"
    ArithBinaryOpcode.shrI64 gives "shrsi"
    ArithBinaryOpcode.cmpI64Eq gives "cmpi eq,"
    ArithBinaryOpcode.cmpI64Ne gives "cmpi ne,"
    ArithBinaryOpcode.cmpI64Lt gives "cmpi lt,"
    ArithBinaryOpcode.cmpI64Le gives "cmpi le,"
    ArithBinaryOpcode.cmpI64Gt gives "cmpi gt,"
    ArithBinaryOpcode.cmpI64Ge gives "cmpi ge,"
    ArithBinaryOpcode.cmpF64Eq gives "cmpf eq,"
    ArithBinaryOpcode.cmpF64Ne gives "cmpf ne,"
    ArithBinaryOpcode.cmpF64Lt gives "cmpf lt,"
    ArithBinaryOpcode.cmpF64Le gives "cmpf le,"
    ArithBinaryOpcode.cmpF64Gt gives "cmpf gt,"
    ArithBinaryOpcode.cmpF64Ge gives "cmpf ge,"
  end 'name'
  return "%{op.resultId} = arith.{name} %{op.leftId}, %{op.rightId}"
end 'printArithBinaryOp'

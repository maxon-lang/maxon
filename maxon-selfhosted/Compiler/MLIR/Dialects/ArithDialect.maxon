// Arith Dialect — Standard typed arithmetic operations.

export union ArithOp
    constI64(resultId ValueId, value ParsedInt)
    constF64(resultId ValueId, rawBits ParsedInt)
    addI64(resultId ValueId, leftId ValueId, rightId ValueId)
    subI64(resultId ValueId, leftId ValueId, rightId ValueId)
    mulI64(resultId ValueId, leftId ValueId, rightId ValueId)
    divI64(resultId ValueId, leftId ValueId, rightId ValueId)
    remI64(resultId ValueId, leftId ValueId, rightId ValueId)
    negI64(resultId ValueId, operandId ValueId)
    bitNotI64(resultId ValueId, operandId ValueId)
    andI64(resultId ValueId, leftId ValueId, rightId ValueId)
    orI64(resultId ValueId, leftId ValueId, rightId ValueId)
    xorI64(resultId ValueId, leftId ValueId, rightId ValueId)
    shlI64(resultId ValueId, leftId ValueId, rightId ValueId)
    shrI64(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Eq(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Ne(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Lt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Le(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Gt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpI64Ge(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Eq(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Ne(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Lt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Le(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Gt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpF64Ge(resultId ValueId, leftId ValueId, rightId ValueId)
end 'ArithOp'

export function printArithOp(op ArithOp) returns String
    let lb = "\{"
    let rb = "\}"
    return match op 'print'
        constI64(resultId, value) gives "%{resultId} = arith.constant {lb}value = {value} : i64{rb}"
        constF64(resultId, rawBits) gives "%{resultId} = arith.float_constant {lb}rawBits = {rawBits}{rb}"
        addI64(resultId, leftId, rightId) gives "%{resultId} = arith.addi %{leftId}, %{rightId}"
        subI64(resultId, leftId, rightId) gives "%{resultId} = arith.subi %{leftId}, %{rightId}"
        mulI64(resultId, leftId, rightId) gives "%{resultId} = arith.muli %{leftId}, %{rightId}"
        divI64(resultId, leftId, rightId) gives "%{resultId} = arith.divsi %{leftId}, %{rightId}"
        remI64(resultId, leftId, rightId) gives "%{resultId} = arith.remsi %{leftId}, %{rightId}"
        negI64(resultId, operandId) gives "%{resultId} = arith.negi %{operandId}"
        bitNotI64(resultId, operandId) gives "%{resultId} = arith.noti %{operandId}"
        andI64(resultId, leftId, rightId) gives "%{resultId} = arith.andi %{leftId}, %{rightId}"
        orI64(resultId, leftId, rightId) gives "%{resultId} = arith.ori %{leftId}, %{rightId}"
        xorI64(resultId, leftId, rightId) gives "%{resultId} = arith.xori %{leftId}, %{rightId}"
        shlI64(resultId, leftId, rightId) gives "%{resultId} = arith.shli %{leftId}, %{rightId}"
        shrI64(resultId, leftId, rightId) gives "%{resultId} = arith.shrsi %{leftId}, %{rightId}"
        cmpI64Eq(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi eq, %{leftId}, %{rightId}"
        cmpI64Ne(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi ne, %{leftId}, %{rightId}"
        cmpI64Lt(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi lt, %{leftId}, %{rightId}"
        cmpI64Le(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi le, %{leftId}, %{rightId}"
        cmpI64Gt(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi gt, %{leftId}, %{rightId}"
        cmpI64Ge(resultId, leftId, rightId) gives "%{resultId} = arith.cmpi ge, %{leftId}, %{rightId}"
        cmpF64Eq(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf eq, %{leftId}, %{rightId}"
        cmpF64Ne(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf ne, %{leftId}, %{rightId}"
        cmpF64Lt(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf lt, %{leftId}, %{rightId}"
        cmpF64Le(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf le, %{leftId}, %{rightId}"
        cmpF64Gt(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf gt, %{leftId}, %{rightId}"
        cmpF64Ge(resultId, leftId, rightId) gives "%{resultId} = arith.cmpf ge, %{leftId}, %{rightId}"
    end 'print'
end 'printArithOp'

// X86 Dialect

export enum X86Register
    rax
    rcx
    rdx
    rbx
    rsp
    rbp
    rsi
    rdi
    r8
    r9
    r10
    r11
end 'X86Register'

export enum X86Op
    prologue(stackSize I64)
    epilogue
    movRegImm(dest X86Register, value I64)
    movSlot(slotIndex I64, srcReg X86Register)
    loadSlot(destReg X86Register, slotIndex I64)
    addRegReg(destReg X86Register, srcReg X86Register)
    subRegReg(destReg X86Register, srcReg X86Register)
    imulRegReg(destReg X86Register, srcReg X86Register)
    pushRax
    popRcx
    printLiteral(data ByteBuffer)
    printInt
end 'X86Op'

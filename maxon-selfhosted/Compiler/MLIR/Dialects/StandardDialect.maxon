// Standard Dialect Operations

export enum StdOp
    constI64(resultId ValueId, value ParsedInt)
    returnOp(retValId ValueId)
    storeSlot(slotId VarSlot, valueId ValueId)
    loadSlot(resultId ValueId, slotId VarSlot)
    addI64(resultId ValueId, leftId ValueId, rightId ValueId)
    subI64(resultId ValueId, leftId ValueId, rightId ValueId)
    mulI64(resultId ValueId, leftId ValueId, rightId ValueId)
    pushValue
    popToRcx
    printLiteral(data ByteBuffer)
    printInt(valueId ValueId)
    funcBegin(name String)
    funcEnd
    call(resultId ValueId, callee String)
end 'StdOp'

// Standard Dialect Operations

export enum StdOp
    constI64(resultId I64, value I64)
    returnOp(retValId I64)
    storeSlot(slotId I64, valueId I64)
    loadSlot(resultId I64, slotId I64)
    addI64(resultId I64, leftId I64, rightId I64)
    subI64(resultId I64, leftId I64, rightId I64)
    mulI64(resultId I64, leftId I64, rightId I64)
    pushValue
    popToRcx
    printLiteral(data ByteBuffer)
    printInt(valueId I64)
end 'StdOp'

// Maxon Dialect Operations

export enum MaxonOp
    literal(resultId I64, value I64)
    returnOp(retValId I64)
    varDecl(slotId I64, valueId I64)
    varLoad(resultId I64, slotId I64)
    add(resultId I64, leftId I64, rightId I64)
    sub(resultId I64, leftId I64, rightId I64)
    mul(resultId I64, leftId I64, rightId I64)
    pushValue
    popToRcx
    printLiteral(data ByteBuffer)
    printInt(valueId I64)
end 'MaxonOp'

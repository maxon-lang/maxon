// Maxon Dialect Operations

export enum MaxonOp
    literal(resultId ValueId, value ParsedInt)
    floatLiteral(resultId ValueId, rawBits ParsedInt)
    returnOp(retValId ValueId)
    varDecl(slotId VarSlot, valueId ValueId)
    varLoad(resultId ValueId, slotId VarSlot)
    add(resultId ValueId, leftId ValueId, rightId ValueId)
    sub(resultId ValueId, leftId ValueId, rightId ValueId)
    mul(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpEq(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpNe(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpLt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpLe(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpGt(resultId ValueId, leftId ValueId, rightId ValueId)
    cmpGe(resultId ValueId, leftId ValueId, rightId ValueId)
    floatCmpEq(resultId ValueId, leftId ValueId, rightId ValueId)
    condBr(condId ValueId, thenLabel String, elseLabel String)
    br(targetLabel String)
    label(name String)
    pushValue
    popToRcx
    printLiteral(data ByteBuffer)
    printInt(valueId ValueId)
    funcBegin(name String, returnType String)
    funcEnd
    call(resultId ValueId, callee String)
end 'MaxonOp'

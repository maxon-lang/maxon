// MemRef Dialect — Memory slot operations.

export union MemRefOp
	storeSlot(slotId VarSlot, valueId ValueId)
	loadSlot(resultId ValueId, slotId VarSlot)
end 'MemRefOp'

export function memRefOpToString(op MemRefOp) returns String
	return match op 'print'
		storeSlot(slotId, valueId) gives "memref.store %{valueId}, slot_{slotId}"
		loadSlot(resultId, slotId) gives "%{resultId} = memref.load slot_{slotId}"
	end 'print'
end 'memRefOpToString'

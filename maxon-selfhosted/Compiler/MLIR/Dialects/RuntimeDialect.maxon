// Runtime Dialect — I/O and runtime intrinsics.

export union RuntimeOp
	printLiteral(data ByteArray)
	printInt(valueId ValueId)
end 'RuntimeOp'

export function runtimeOpToString(op RuntimeOp) returns String
	return match op 'print'
		printLiteral(data) gives "runtime.print_literal \"{String.from(data)}\""
		printInt(valueId) gives "runtime.print_int %{valueId}"
	end 'print'
end 'runtimeOpToString'

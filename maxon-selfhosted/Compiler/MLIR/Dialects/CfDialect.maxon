// Cf (Control Flow) Dialect — Block terminators.

export union CfOp
	br(target BlockId)
	condBr(condId ValueId, thenTarget BlockId, elseTarget BlockId)
end 'CfOp'

export function cfOpToString(op CfOp, blocks MlirBlockArray) returns String
	return match op 'print'
		br(target) gives cfBrToString(target, blocks: blocks)
		condBr(condId, thenTarget, elseTarget) gives cfCondBrToString(condId, thenTarget: thenTarget, elseTarget: elseTarget, blocks: blocks)
	end 'print'
end 'cfOpToString'

function cfBrToString(target BlockId, blocks MlirBlockArray) returns String
	let label = resolveBlockLabel(target, blocks: blocks)
	return "cf.br {label}"
end 'cfBrToString'

function cfCondBrToString(condId ValueId, thenTarget BlockId, elseTarget BlockId, blocks MlirBlockArray) returns String
	let thenLabel = resolveBlockLabel(thenTarget, blocks: blocks)
	let elseLabel = resolveBlockLabel(elseTarget, blocks: blocks)
	return "cf.cond_br %{condId} [then: {thenLabel}, else: {elseLabel}]"
end 'cfCondBrToString'

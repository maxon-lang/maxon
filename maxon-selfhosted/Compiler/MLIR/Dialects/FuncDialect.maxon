// Func Dialect — Function-level operations.

export union StdType
	i1
	i8
	i16
	i32
	i64
	u8
	u16
	u32
	u64
	f32
	f64
end 'StdType'

export union FuncOp
	ret(retValId ValueId)
	call(resultId ValueId, callee String, argIds ValueIdArray)
	tryCall(resultId ValueId, callee String, argIds ValueIdArray, errorFlagId ValueId)
	indirectCall(resultId ValueId, calleeId ValueId, argIds ValueIdArray)
	funcRef(resultId ValueId, funcName String)
	tailCall(callee String, argIds ValueIdArray)
	param(resultId ValueId, paramIndex VarSlot, paramType StdType)
end 'FuncOp'

export typealias FuncOpArray = Array with FuncOp

export function funcOpToString(op FuncOp) returns String
	return match op 'print'
		ret(retValId) gives "func.return %{retValId}"
		call(resultId, callee, argIds) gives "%{resultId} = func.call @{callee}({formatArgIds(argIds)})"
		tryCall(resultId, callee, argIds, errorFlagId) gives "%{resultId}, %{errorFlagId} = func.try_call @{callee}({formatArgIds(argIds)})"
		indirectCall(resultId, calleeId, argIds) gives "%{resultId} = func.indirect_call %{calleeId}({formatArgIds(argIds)})"
		funcRef(resultId, funcName) gives "%{resultId} = func.ref @{funcName}"
		tailCall(callee, argIds) gives "func.tail_call @{callee}({formatArgIds(argIds)})"
		param(resultId, paramIndex, paramType) gives "%{resultId} = func.param {paramIndex} : {stdTypeToString(paramType)}"
	end 'print'
end 'funcOpToString'

export function stdTypeToString(t StdType) returns String
	return match t 'str'
		i1 gives "i1"
		i8 gives "i8"
		i16 gives "i16"
		i32 gives "i32"
		i64 gives "i64"
		u8 gives "u8"
		u16 gives "u16"
		u32 gives "u32"
		u64 gives "u64"
		f32 gives "f32"
		f64 gives "f64"
	end 'str'
end 'stdTypeToString'

export function stdTypeIsFloat(t StdType) returns bool
	return match t 'check'
		f32 gives true
		f64 gives true
		i1 to u64 gives false
	end 'check'
end 'stdTypeIsFloat'

export function resolvedTypeToStdType(resolved String) returns StdType
	if resolved == "f64" 'isF64'
		return StdType.f64
	end 'isF64'
	if resolved == "f32" 'isF32'
		return StdType.f32
	end 'isF32'
	if resolved == "i1" 'isI1'
		return StdType.i1
	end 'isI1'
	if resolved == "i8" 'isI8'
		return StdType.i8
	end 'isI8'
	if resolved == "i16" 'isI16'
		return StdType.i16
	end 'isI16'
	if resolved == "i32" 'isI32'
		return StdType.i32
	end 'isI32'
	if resolved == "u8" 'isU8'
		return StdType.u8
	end 'isU8'
	if resolved == "u16" 'isU16'
		return StdType.u16
	end 'isU16'
	if resolved == "u32" 'isU32'
		return StdType.u32
	end 'isU32'
	if resolved == "u64" 'isU64'
		return StdType.u64
	end 'isU64'
	return StdType.i64
end 'resolvedTypeToStdType'

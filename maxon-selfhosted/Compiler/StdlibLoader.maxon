var cachedStdlibModule = MaxonModule.create()

// J.4e: stdlibParsedModuleArr holds the parsed stdlib MaxonModule and its
// owning sandbox Project as a singleton array. Empty when no parse has
// happened in this process; the array form sidesteps the "top-level var
// initializer must be a compile-time constant" restriction that prevents
// stashing a Project / MaxonModule value directly.
var stdlibParsedModuleArr = StdlibParseSnapshotArray.create()
var stdlibLoaded = false
var stdlibTypealiases = TypealiasMap.create()

// Cache v17 in-process companion to `stdlibTypealiases`. The disk cache now
// persists per-typealias visibility + sourceFilePath; we mirror that snapshot
// here so the in-process fast path (same compiler reusing cached stdlib for
// a second project) restores the same sidecar information. Without this,
// file-private stdlib aliases collapse to `(global, stdlib-bootstrap path)`
// on the second project and trip the parser's E2001 shadowing check.
var stdlibTypealiasVisibilities = TypealiasVisibilityMap.create()
var stdlibTypealiasRanges = TypealiasRangeMap.create()

// Sidecar mirror of `project.typealiasCastCategories` for the in-process
// stdlib snapshot. Same rationale as the visibility/range mirrors above:
// a second project reusing the cached stdlib needs to see the same
// user-declared cast category for ranged aliases (so `int(0 to 255)`
// stays `int` even after the u8-storage choice).
var stdlibTypealiasCastCategories = TypealiasCastCategoryMap.create()

// Phase 11.6 cross-module inlining: process-wide snapshot of the stdlib's
// post-dce StdModule. Populated either by the cache-build path (from
// `pipeline.stdModulePostDceSnapshot`) or by the cache-hit path (from the
// disk-cache's `inlinerStdModule` field). The user pipeline's inliner pass
// reads this via `getCachedStdlibStdModule()` and merges it into the user
// stdModule for the duration of the inliner pass; merged functions are
// dropped right after the splice so the linker-side stdlib cache stays the
// sole source of stdlib machine code.
var cachedStdlibStdModule = StdModule.create()

export function getCachedStdlibStdModule() returns StdModule
	return cachedStdlibStdModule
end 'getCachedStdlibStdModule'

// Precomputed Std-DFE reachability edges for the cached stdlib functions
// (call edges + witness/layout/globalAddr label demands), one record per
// function. Populated either by the cache-build path (via `extractFuncEdges`
// over the post-dce snapshot) or by the cache-hit path (from the disk
// cache's `stdFuncEdges` field). Std-DFE reads this via `cachedStdFuncEdges`
// to follow cached call edges + witness/layout demands without re-walking
// the cached Std-IR snapshot. Empty on a cache-miss compile, where the
// bodies are still in the user Std module and the in-module walk covers them.
var cachedStdlibFuncEdges = CachedFuncEdgeMap.create()

export function cachedStdFuncEdges() returns CachedFuncEdgeMap
	return cachedStdlibFuncEdges
end 'cachedStdFuncEdges'

// v80 lazy codegen: process-wide memo of the reconstructed, fully-lowered
// stdlib MIR module that `ensureStdlibFunctionsCompiled` codegens subsets
// from on demand. Built once (the first time any stdlib function must be
// lazily compiled) by re-merging the persisted post-dce Std-IR snapshot
// (`cachedStdlibStdModule`) with the cache-side runtime bodies and running
// lowerStdToMir + commuteForCoalescing + scheduleInstructions over the
// union — the exact prefix `buildAndWriteStdlibCache` runs before its
// backend tail, so per-function lowering is byte-identical to the eager
// path. `lazyStdlibMirBuilt` guards the one-time build; keyed implicitly to
// the process's single active target.
var lazyStdlibMir = MirModule.create()
var lazyStdlibMirBuilt = false

// The reconstructed stdlib+runtime Std module (snapshot ∪ cache-side runtime),
// retained between the cheap edge-build and the on-demand MIR lowering so the
// merge isn't repeated. Built by `ensureLazyStdlibEdges`.
var lazyReconstructed = StdModule.create()
var lazyStdlibEdgesBuilt = false

// Full Std-IR call-edge map over the RECONSTRUCTED module (stdlib snapshot +
// runtime bodies), so the lazy needed-closure can follow runtime->runtime and
// runtime->stdlib edges that `cachedStdlibFuncEdges` (stdlib-only snapshot)
// omits. Built by `ensureLazyStdlibEdges` (cheap; no MIR lowering).
var lazyStdlibFuncEdges = CachedFuncEdgeMap.create()

// Names already present in `cachedStdlibCacheData.functions`, for O(1)
// missing-set computation without rescanning the function array each link.
var lazyCompiledStdlibNames = StdlibFuncNameSet.create()

// Gate for persisting the user-path lazy-codegen growth back to the on-disk
// cache. Safe ONLY when the stdlib metadata was captured in the SAME project
// that is now compiling user code — true for a single-project CLI `maxon
// build` (the stdlib cache is built in the user's own project, so its
// `topLevelConstants` string ids are valid in that project's interner for
// re-serialization). FALSE for the spec runner / in-memory compiles, where
// stdlib is built in a warmup project and fragments compile in separate
// worker projects whose interner lacks those ids — re-serializing there
// panics in `writeConstantValue`. `compile()` (the CLI path) sets this true.
var stdlibCachePersistAllowed = false

export function setStdlibCachePersistAllowed(allowed bool)
	stdlibCachePersistAllowed = allowed
end 'setStdlibCachePersistAllowed'

// Process-wide accessor for the parsed stdlib MaxonModule (the Maxon-IR
// shape of every stdlib function body whitelisted by `stdlibWhitelist`).
// Consumers — today only `MonomorphizeExtensions` falling back when a
// stdlib-declared interface-extension callee isn't in the user module —
// read this to discover Maxon-IR bodies that the codegen cache doesn't
// persist.
//
// J.4e: the underlying sandbox parse uses its own dedicated `Project` so
// the parse never collides with user-code project state (E2001 duplicate
// names). MaxonType / StringId / FunctionTypeId payloads in the parsed
// IR reference the sandbox project's registries; we translate them into
// the caller's project on every call via `translateStdlibParsedModule`.
// The first call in a process triggers the lazy parse; subsequent calls
// re-use the cached sandbox snapshot.
export function getStdlibParsedModule(userProject Project) returns MaxonModule
	if stdlibParsedModuleArr.count() == 0 'needsParse'
		ensureStdlibSandboxParsed(userProject.target)
	end 'needsParse'
	let snapshot = try stdlibParsedModuleArr.get(0) otherwise panic("getStdlibParsedModule: sandbox snapshot not present after ensure")
	return translateStdlibParsedModule(snapshot.project, user: userProject, src: snapshot.module)
end 'getStdlibParsedModule'

// Build the sandbox snapshot if it hasn't been populated yet. The sandbox
// project is a dedicated empty Project with the same target as the user's
// pipeline; the parse runs against it so user-code projects' registries
// stay pristine. The bootstrap source + every whitelisted stdlib file are
// parsed into a single fresh MaxonModule, then stashed alongside the
// sandbox project for the cross-project translator to consume on demand.
function ensureStdlibSandboxParsed(target Target)
	if stdlibParsedModuleArr.count() > 0 'alreadyDone'
		return
	end 'alreadyDone'
	let stdlibPath = findStdlibPath()
	if stdlibPath.isEmpty() 'noStdlib'
		return
	end 'noStdlib'
	let projectRoot = try stdlibPath.parent() otherwise FilePath from ""
	if projectRoot.isEmpty() 'noRoot'
		return
	end 'noRoot'
	var sandbox = createProject(projectRoot, target: target)
	registerMmIntrinsicSignatures(sandbox)
	registerManagedMemoryType(sandbox)
	registerManagedFileType(sandbox)
	registerManagedDirectoryType(sandbox)
	// Phase C: register the `__ManagedList` / `__ManagedListNode` builtin
	// structs and the `__ManagedListError` enum so `stdlib/List.maxon`
	// parses + type-resolves. Bodies are intercepted by
	// `lowerManagedListBuiltin` / `lowerManagedListNodeBuiltin` and routed
	// to `mrt_managed_list_*` runtime helpers.
	registerManagedListType(sandbox)
	registerManagedListNodeType(sandbox)
	// Phase D: register the `__ManagedSocket` builtin struct and the
	// `__ManagedSocketError` enum so `stdlib/TcpClient.maxon` parses +
	// type-resolves. Bodies are intercepted by `lowerManagedSocketBuiltin`
	// and routed to `mrt_managed_socket_*` runtime helpers.
	registerManagedSocketType(sandbox)
	registerBuiltinsIntrinsicSignatures(sandbox)
	registerInternalsIntrinsicSignatures(sandbox)
	var module = MaxonModule.create()
	for fp in collectStdlibFiles() 'eachFile'
		if File.exists(fp) 'exists'
			let content = try File.readText(fp) otherwise 'readErr'
				continue
			end 'readErr'
			parseStdlibSource(sandbox, allModule: module, filePath: fp, rootPath: projectRoot, content: content)
		end 'exists'
	end 'eachFile'
	// Drain pending cross-file function renames produced when a late-parsed
	// file overloaded a function declared in an earlier-parsed sibling. The
	// per-file parser's in-module rekey couldn't reach the IrFunction once
	// it had been merged into `allModule`; we now apply each rename here so
	// the unified IrFunction.name matches the project-level mangled key.
	applyPendingFuncRenames(sandbox, allModule: module)
	// G.2: now that every stdlib file is parsed, the parser's optimistic
	// `<TypeName>.fromRawValue` / `<TypeName>.fromName` rewrite gets
	// validated against the now-fully-populated enum tables. Bare-case
	// enums get their per-enum lookup helper synthesized into `module`;
	// struct- / alt-backed enums and associated-value unions get E3034
	// diagnostics; non-enum receivers get the callee rewritten back to
	// the natural form so the standard unknown-callee diagnostic fires.
	validateEnumLookupCalls(sandbox, allModule: module)
	stdlibParsedModuleArr.push(StdlibParseSnapshot.create(sandbox, module: module))
end 'ensureStdlibSandboxParsed'

// Walk `allModule.functions` and rename any IrFunction whose `.name` matches
// a pending rename entry. The map is cleared after the walk so a follow-up
// parse (user project) starts with a fresh state.
function applyPendingFuncRenames(project Project, allModule MaxonModule)
	if project.pendingFuncRenames.count() == 0 'noRenames'
		return
	end 'noRenames'
	for i in 0 upto allModule.functions.count() 'eachFunc'
		var f = try allModule.functions.get(i) otherwise continue
		if let newName = try project.pendingFuncRenames.get(f.name) 'haveRename'
			f.name = newName
			try allModule.functions.set(i, value: f) otherwise ignore
		end 'haveRename'
	end 'eachFunc'
	project.pendingFuncRenames = FuncRenameMap.create()
end 'applyPendingFuncRenames'

// Pre-compiled stdlib cache (machine code level, per-target)
var cachedStdlibCacheData = StdlibCacheData.create()
var stdlibCacheValid = false
var stdlibCacheTargetSet = false
var stdlibCacheCpuOrd = 0
var stdlibCacheOsOrd = 0
var stdlibCacheProjectDirs = FilePathArray.create()

// Discovery cache for the BuiltinArrayLiteral protocol. The parser walks
// `project.unresolvedStructTypes` once at parse time and writes the
// implementing type's name here; subsequent array-literal expansions in the
// same process read the cached value rather than re-walking. The disk-cache
// write/read paths plumb this through `StdlibCacheData.builtinArrayLiteralTypeName`
// so cache-hit runs (which skip the stdlib parse) still find the type name.
//
// Stored as ByteArray rather than String because top-level var initializers
// only accept compile-time constants and struct constructors; an empty
// ByteArray.create() is a valid such initializer while a `""` String literal
// is not (E2004). Accessors round-trip through String at the boundary.
var cachedBuiltinArrayLiteralTypeName = ByteArray.create()

export function getCachedBuiltinArrayLiteralTypeName() returns String
	return String.from(cachedBuiltinArrayLiteralTypeName)
end 'getCachedBuiltinArrayLiteralTypeName'

export function setCachedBuiltinArrayLiteralTypeName(name String)
	cachedBuiltinArrayLiteralTypeName = name.toByteArray()
end 'setCachedBuiltinArrayLiteralTypeName'

// Mirror of `cachedBuiltinArrayLiteralTypeName` for the `BuiltinDictionaryLiteral`
// protocol — the parser walks `project.unresolvedStructTypes` once at parse
// time and records the implementing type's name here so user-code map literals
// resolve through whichever stdlib type opted in.
var cachedBuiltinDictionaryLiteralTypeName = ByteArray.create()

export function getCachedBuiltinDictionaryLiteralTypeName() returns String
	return String.from(cachedBuiltinDictionaryLiteralTypeName)
end 'getCachedBuiltinDictionaryLiteralTypeName'

export function setCachedBuiltinDictionaryLiteralTypeName(name String)
	cachedBuiltinDictionaryLiteralTypeName = name.toByteArray()
end 'setCachedBuiltinDictionaryLiteralTypeName'

// Mirror of `cachedBuiltinArrayLiteralTypeName` for the `BuiltinCharLiteral`
// protocol — the type a single-quote character literal (`'x'`) lowers to. The
// compiler knows nothing about "Character" specifically; it discovers whichever
// stdlib type declares `implements BuiltinCharLiteral` (parser walk over
// `unresolvedStructTypes`, republished into this cache by `restoreStdlibMetadata`
// on cache-hit runs). Every site that previously hardcoded the `"Character"` type
// name reads `builtinCharLiteralTypeName(project)` instead.
var cachedBuiltinCharLiteralTypeName = ByteArray.create()

export function getCachedBuiltinCharLiteralTypeName() returns String
	return String.from(cachedBuiltinCharLiteralTypeName)
end 'getCachedBuiltinCharLiteralTypeName'

export function setCachedBuiltinCharLiteralTypeName(name String)
	cachedBuiltinCharLiteralTypeName = name.toByteArray()
end 'setCachedBuiltinCharLiteralTypeName'

// Mirror of `cachedBuiltinCharLiteralTypeName` for the `BuiltinStringLiteral`
// protocol — the type a double-quote string literal (`"..."`) and the `string`
// primitive type-arm lower to. The compiler knows nothing about "String"
// specifically; it discovers whichever stdlib type declares `implements
// BuiltinStringLiteral`.
var cachedBuiltinStringLiteralTypeName = ByteArray.create()

export function getCachedBuiltinStringLiteralTypeName() returns String
	return String.from(cachedBuiltinStringLiteralTypeName)
end 'getCachedBuiltinStringLiteralTypeName'

export function setCachedBuiltinStringLiteralTypeName(name String)
	cachedBuiltinStringLiteralTypeName = name.toByteArray()
end 'setCachedBuiltinStringLiteralTypeName'

// Invalidate the v80 lazy-codegen memo (reconstructed MIR, edge map, and the
// already-compiled-name set). Called on every cross-target switch
// (`loadCacheForTarget`) — the memo is keyed to one target's reconstructed
// module + arch backend and must not leak across.
// `lazyCompiledStdlibNames` is re-seeded from the loaded cache's real-code
// entries by `syncLazyCompiledNames` on the next lazy fill.
function resetLazyStdlibState()
	lazyStdlibMir = MirModule.create()
	lazyStdlibMirBuilt = false
	lazyReconstructed = StdModule.create()
	lazyStdlibEdgesBuilt = false
	lazyStdlibFuncEdges = CachedFuncEdgeMap.create()
	lazyCompiledStdlibNames = StdlibFuncNameSet.create()
end 'resetLazyStdlibState'

export function findStdlibPath() returns FilePath
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		let candidate = dir.join("stdlib")
		if Directory.exists(candidate) 'found'
			return candidate
		end 'found'
		let parentDir = try dir.parent() otherwise return FilePath from ""
		dir = parentDir
	end 'search'
	return FilePath from ""
end 'findStdlibPath'

// Resolve the project root that holds `stdlib/`. Returned path is the parent
// of `findStdlibPath()`; empty when stdlib can't be located. All whitelist
// entries are joined onto this root.
function findStdlibProjectRoot() returns FilePath
	let stdlibPath = findStdlibPath()
	if stdlibPath.isEmpty() 'noStdlib'
		return FilePath from ""
	end 'noStdlib'
	return try stdlibPath.parent() otherwise FilePath from ""
end 'findStdlibProjectRoot'

// Recursively collect every `.maxon` file under `stdlib/`. Load order is
// whatever order the filesystem returns — the type / conformance resolver
// is order-independent, so the cache build does not depend on which file
// parses first.
function collectStdlibFiles() returns FilePathArray
	var files = FilePathArray.create()
	let stdlibPath = findStdlibPath()
	if stdlibPath.isEmpty() 'noStdlib'
		return files
	end 'noStdlib'
	collectMaxonFilesUnder(stdlibPath, into: files)
	return files
end 'collectStdlibFiles'

// Walk `dir` recursively and push every `.maxon` file into `out`. Hidden
// entries (`.something`) and non-existent / unreadable directories are
// silently ignored — the stdlib tree is trusted content, so a missing
// subdirectory is treated as "nothing to add" rather than a fatal error.
function collectMaxonFilesUnder(dir FilePath, into FilePathArray)
	let entries = try Directory.list(dir) otherwise return
	for entry in entries 'eachEntry'
		if Directory.exists(entry) 'isDir'
			collectMaxonFilesUnder(entry, into: into)
		end 'isDir' else 'isFile'
			let name = entry.filename()
			if not name.endsWith(".maxon") 'notMaxon'
				continue
			end 'notMaxon'
			into.push(entry)
		end 'isFile'
	end 'eachEntry'
end 'collectMaxonFilesUnder'

// Cache key for the currently-discoverable stdlib: every file the recursive
// walk surfaces plus runtime.std (the latter affects compiled output, so
// the on-disk cache must invalidate when runtime.std changes). The wasm green
// thread runtime (runtime_wasm.std) is folded in alongside the stdlib files so
// edits to the wasm coroutine bodies bust the on-disk cache too.
function currentStdlibChecksum(_ Target) returns CacheChecksum
	var files = collectStdlibFiles()
	let wasmGtRuntime = findWasmGtRuntimePath()
	if not wasmGtRuntime.isEmpty() 'hasWasmGt'
		files.push(wasmGtRuntime)
	end 'hasWasmGt'
	return computeStdlibChecksum(files, runtimePath: findRuntimePath())
end 'currentStdlibChecksum'

// Parse a single stdlib source string and merge its module into `allModule`.
// Bundled stdlib content (whitelisted files + the synthesized bootstrap) is
// trusted: any lex/parse failure is a compiler bug rather than a user input
// problem, so we panic with a precise message instead of skipping silently.
//
// `rootPath` is the per-file compile anchor for namespace derivation — for
// stdlib files this is the parent of the `stdlib/` install dir
// (`findStdlibProjectRoot()`). The directory-as-module redesign derives
// each file's namespace from its path relative to that anchor, so
// `stdlib/Math.maxon` parses with namespace `stdlib` and
// `stdlib/helpers/string/utf8.maxon` parses with namespace
// `stdlib.helpers.string`. Decl-registration in the parser then qualifies
// every free function under the file's directory namespace, matching the
// C# bootstrap's behavior.
function parseStdlibSource(project Project, allModule MaxonModule, filePath FilePath, rootPath FilePath, content String)
	logDebug(LogCategory.compiler, message: function() gives "  Parsing {filePath}")
	let tokens = try tokenize(content) otherwise panic("StdlibLoader: lexer error in bundled stdlib file {filePath}")
	let ns = deriveNamespace(filePath, rootPath: rootPath)
	var parser = try Parser.create(project, tokens: tokens, filePath: filePath, rootPath: rootPath, namespace: ns) otherwise panic("StdlibLoader: empty or malformed stdlib file {filePath}")
	let parsed = try parser.parseModule() otherwise panic("StdlibLoader: parse failed for stdlib file {filePath}")
	// Whitelist-grade stdlib content must parse without diagnostics. The
	// downstream pipeline assumes well-formed IR; running on a broken parse
	// risks an infinite loop in one of the passes that walks unterminated
	// CFGs. Surface the parser diagnostics here rather than rolling forward
	// into a hang.
	if hasErrors(project) 'parseErrors'
		panic("StdlibLoader: parse errors in stdlib file — see diagnostics above")
	end 'parseErrors'
	parsed.assertAllBlocksTerminated()
	allModule.merge(parsed)
end 'parseStdlibSource'

// Seed the allocator/MM boundary functions the runtime calls into as stdlib-DFE
// liveness roots. The runtime bodies (`mrt_start` + the runtime.std MM/container
// helpers) are merged into the user module AFTER the stdlib DFE runs (see
// `augmentWithRuntime`), so the DFE never sees edges like `mrt_start`→`__slab_init`
// or `mrt_alloc`→`__mm_alloc` and would prune the Internals bodies — leaving the
// cache-off / mm-trace bypass leg (empty `stdlibFunctions`) with no definition to
// resolve those calls' signatures against. The cache-on linker pulls the same
// closure transitively from `mrt_start`/`mrt_alloc`, so rooting them keeps the
// from-source and cached builds' function sets in lockstep. Transitive callees
// follow the DFE walk.
function seedRuntimeBootstrapStdlibRoots(project Project)
	let roots = [
		"stdlib.__slab_init",
		"stdlib.__slab_free",
		"stdlib.__mm_alloc",
		"stdlib.__mm_free",
		"stdlib.__mm_incref",
		"stdlib.__mm_decref",
		"stdlib.__mm_drop",
		"stdlib.__mm_panic_list_empty",
		"stdlib.__managed_mem_create"
	]
	for r in roots 'seed'
		project.livenessRoots.push(r)
	end 'seed'
end 'seedRuntimeBootstrapStdlibRoots'

export function getStdlibModule(project Project) returns MaxonModule
	// Register the allocator-runtime intrinsics (`__mm_alloc`,
	// `__mm_decref`, etc.) so user Maxon source can call them as plain
	// functions. Done unconditionally on every project before any of the
	// cache / parse paths below populate the rest of the registries — these
	// names are stable across all projects and don't depend on user code or
	// cached stdlib state. Idempotent: each `try ... insert ... otherwise
	// ignore` in the helper drops a duplicate silently if a previous call
	// in the same process already populated the same project.
	registerMmIntrinsicSignatures(project)
	// Step 6b.1 + 6b.2: register the `__ManagedMemory` builtin struct, the
	// `__ManagedMemoryError` enum, and the 18 `__ManagedMemory.*` method
	// signatures so the type checker accepts user calls like
	// `mm.length()` / `__ManagedMemory.create(...)`. Idempotent for the
	// same reason as the intrinsic-signature register above.
	registerManagedMemoryType(project)
	// Phase 15c: register the `__ManagedFile` / `__ManagedDirectory` builtin
	// structs, their `__Managed{File,Directory}Error` enums, and the method
	// signatures used by `stdlib/File.maxon` / `stdlib/Directory.maxon`.
	// Bodies are absent — Stream 2.3 will add the lowering dispatch that
	// intercepts `__ManagedFile.*` / `__ManagedDirectory.*` calls before
	// the generic callee resolver runs. Same idempotency rationale as the
	// `__ManagedMemory` registration above.
	registerManagedFileType(project)
	registerManagedDirectoryType(project)
	// Phase C: register the `__ManagedList` / `__ManagedListNode` builtin
	// structs and the `__ManagedListError` enum so `stdlib/List.maxon`
	// parses + type-resolves. Same idempotency rationale as above.
	registerManagedListType(project)
	registerManagedListNodeType(project)
	// Phase D: register the `__ManagedSocket` builtin struct and the
	// `__ManagedSocketError` enum so `stdlib/TcpClient.maxon` parses +
	// type-resolves. Same idempotency rationale as above.
	registerManagedSocketType(project)
	// Phase 7: register `__Builtins.writeStdout` / `__Builtins.writeStderr`
	// as qualified static intrinsic signatures so stdlib `Print.maxon`
	// (`__Builtins.writeStdout(value.managed)`) parses + type-resolves.
	// Lowering intercepts the call and emits a runtime call into
	// `mrt_write_stdout` / `mrt_write_stderr`.
	registerBuiltinsIntrinsicSignatures(project)
	// Register `__Internals.*` intrinsic signatures so `stdlib/Internals.maxon`
	// can call raw Std-level system ops (atomicInc, atomicXadd, ...) using a
	// qualified-static call shape. File-path gating in `lowerInternalsIntrinsic`
	// rejects callers outside the designated internals file.
	registerInternalsIntrinsicSignatures(project)
	// The runtime (`mrt_start` + the runtime.std MM/container bodies) calls a
	// fixed set of allocator/MM functions defined in `stdlib/Internals.maxon`
	// (`__slab_init`, `__mm_alloc`, `__managed_mem_create`, …). The runtime is
	// merged into the user module AFTER the stdlib DFE runs (see
	// `augmentWithRuntime`), so the stdlib DFE never sees those call edges and
	// would prune the Internals bodies — leaving `mrt_start`'s `call __slab_init`
	// with no definition to resolve its signature against (the cache-off /
	// mm-trace bypass leg, where `stdlibFunctions` is empty). Seeding them as
	// liveness roots keeps the bodies alive through the from-source build. The
	// cache-on path restores the same roots from `data.livenessRoots`.
	seedRuntimeBootstrapStdlibRoots(project)
	if stdlibLoaded 'cached'
		let restoreStart = passTimerStart()
		// Restore metadata into the new project
		if stdlibCacheValid 'restoreFromCache'
			restoreStdlibMetadata(project, data: cachedStdlibCacheData)
			seedModuleInitFuncsFromLivenessRoots(project)
		end 'restoreFromCache' else 'restoreFromParse'
			for (name, baseType) in stdlibTypealiases 'restoreAliases'
				try project.typealiases.insert(name, value: baseType) otherwise ignore
			end 'restoreAliases'
			for (name, infos) in stdlibTypealiasVisibilities 'restoreAliasVis'
				for info in infos 'eachInfo'
					appendTypealiasVisibility(project, name: name, info: info)
				end 'eachInfo'
			end 'restoreAliasVis'
			for (name, range) in stdlibTypealiasRanges 'restoreRanges'
				try project.typealiasRanges.insert(name, value: range) otherwise ignore
			end 'restoreRanges'
			for (name, category) in stdlibTypealiasCastCategories 'restoreCategories'
				try project.typealiasCastCategories.insert(name, value: category) otherwise ignore
			end 'restoreCategories'
		end 'restoreFromParse'
		recordPassSince("__restoreStdlibMetadata", startMs: restoreStart)

		// If the target changed, try loading the disk cache for the new target
		let targetChanged = not stdlibCacheTargetSet or project.target.cpu.ordinal != stdlibCacheCpuOrd or project.target.os.ordinal != stdlibCacheOsOrd
		if targetChanged 'loadNewTarget'
			loadCacheForTarget(project)
		end 'loadNewTarget'

		return cachedStdlibModule
	end 'cached'

	let stdlibPath = findStdlibPath()
	if stdlibPath.isEmpty() 'noStdlib'
		logInfo(LogCategory.compiler, message: function() gives "No stdlib/ found, skipping stdlib")
		stdlibLoaded = true
		return cachedStdlibModule
	end 'noStdlib'

	logInfo(LogCategory.compiler, message: function() gives "Loading stdlib from {stdlibPath}")

	// Try loading pre-compiled stdlib cache from project's .maxon/cache/ directory.
	// For single-file builds, use the parent directory. The user-supplied path
	// can be relative (e.g. `maxon build test.maxon` from inside its directory) —
	// a bare filename has no separator, so .parent() would throw. Resolve against
	// the current working directory first to guarantee a parent exists.
	// Save the project dir so loadCacheForTarget uses the same path.
	var projectDir = project.rootPath
	if File.exists(project.rootPath) 'isSingleFile'
		let absoluteFile = project.rootPath.resolve(Directory.currentPath())
		projectDir = try absoluteFile.parent() otherwise panic("single-file path has no parent after resolving against cwd: {absoluteFile.toString()}")
	end 'isSingleFile'
	if stdlibCacheProjectDirs.count() == 0 'firstSet'
		stdlibCacheProjectDirs.push(projectDir)
	end 'firstSet'
	let cacheDir = projectDir.join(".maxon").join("cache")
	let cachePath = cacheDir.join("stdlib-{targetToString(project.target)}.mxc")
	let checksumStart = passTimerStart()
	let contentChecksum = currentStdlibChecksum(project.target)
	recordPassSince("__stdlib-checksum", startMs: checksumStart)
	let cacheResult = readStdlibCache(project, path: cachePath, target: project.target, expectedChecksum: contentChecksum)

	if cacheResult.valid 'cacheHit'
		logInfo(LogCategory.compiler, message: function() gives "Stdlib cache hit: {countCompiledStdlibFunctions(cacheResult.data)} functions cached")
		activateStdlibCache(cacheResult.data, target: project.target)

		// Restore parser metadata so user code can reference stdlib types.
		// Route through the global `cachedStdlibCacheData` (just populated by
		// `activateStdlibCache`) so `restoreStdlibMetadata`'s rebuild of
		// `data.writerGidToProjectGid` persists for subsequent compiles, and
		// so the immutable `cacheResult.data` binding isn't passed to a
		// mutating-parameter function.
		restoreStdlibMetadata(project, data: cachedStdlibCacheData)
		seedModuleInitFuncsFromLivenessRoots(project)

		// Phase 11.6 cross-module inlining: republish the stdlib StdModule
		// snapshot pulled from disk so the user pipeline's inliner pass can
		// see stdlib accessor bodies.
		cachedStdlibStdModule = cacheResult.data.inlinerStdModule

		// v68: republish the precomputed Std-DFE edge table so the load-time
		// Std-DFE follows the cached call graph + witness/layout demands
		// without re-walking the snapshot IR.
		cachedStdlibFuncEdges = cacheResult.data.stdFuncEdges

		// Return empty module — stdlib is pre-compiled to machine code
		cachedStdlibModule = MaxonModule.create()
		stdlibLoaded = true
		return cachedStdlibModule
	end 'cacheHit'

	logInfo(LogCategory.compiler, message: function() gives "Stdlib cache miss: compiling from source")

	// Cache miss — parse from source. Whitelist drives which stdlib files the
	// self-hosted compiler can handle today; see stdlibWhitelist above.
	let stdlibFiles = collectStdlibFiles()

	var allModule = MaxonModule.create()
	let stdlibRoot = findStdlibProjectRoot()
	let parseStart = passTimerStart()
	for fp in stdlibFiles 'eachFile'
		if File.exists(fp) 'exists'
			let content = try File.readText(fp) otherwise 'readErr'
				logDebug(LogCategory.compiler, message: function() gives "  Failed to read {fp}")
				continue
			end 'readErr'
			parseStdlibSource(project, allModule: allModule, filePath: fp, rootPath: stdlibRoot, content: content)
		end 'exists'
	end 'eachFile'
	recordPassSince("__stdlib-parse", startMs: parseStart)
	// Drain cross-file overload renames produced by `rekeyExistingFunction`
	// when a late-parsed file overloaded a sibling's function name. The
	// per-file parser couldn't reach the IrFunction sitting in `allModule`,
	// so the rename was queued; apply it now before the cache build keys
	// off `.name`.
	applyPendingFuncRenames(project, allModule: allModule)
	// G.2: validate every `<TypeName>.fromRawValue(...)` /
	// `<TypeName>.fromName(...)` call the parser optimistically rewrote
	// to `__enum_<TypeName>_fromRawValue` / `__enum_<TypeName>_fromName`.
	// See `validateEnumLookupCalls` for the synth-/diagnose-/restore
	// contract; this must run before the cache build because codegen
	// would otherwise panic on an unrewritten callee.
	validateEnumLookupCalls(project, allModule: allModule)
	cachedStdlibModule = allModule
	// J.4e: do NOT stash the just-parsed module here. The `allModule` we
	// just produced is about to be mutated in-place by
	// `buildAndWriteStdlibCache` below — the stdlib pipeline's DCE pass
	// prunes unreachable blocks from each stdlib function's `blockRefs`
	// while leaving their `nextBlockId` and the Maxon-form terminator ops
	// pointing at the pruned ids. If we stashed `allModule` here and a
	// later user compile in this process asked the monomorphizer to clone
	// a stdlib extension method (e.g. `Iterable.map` -> `Array.map`), the
	// cloner would copy the post-DCE `blockRefs` (sparse) but inherit the
	// pre-DCE Maxon-form terminators (referencing pruned ids), producing a
	// cloned function whose `cf.br`/`cf.condBr` targets blocks that don't
	// exist — Mem2Reg's `findBlockById` then panics.
	//
	// Instead, let `getStdlibParsedModule` trigger a fresh parse on demand
	// (see `ensureStdlibSandboxParsed`). The lazy re-parse runs in its own
	// sandbox project and is invariant against downstream pipeline
	// mutation.

	// Snapshot stdlib typealiases into separate maps
	for (name, baseType) in project.typealiases 'cacheAliases'
		stdlibTypealiases.upsert(name, value: baseType)
	end 'cacheAliases'
	for (name, infos) in project.typealiasVisibilities 'cacheAliasVis'
		var copied = TypealiasVisibilityInfoArray.create()
		for info in infos 'eachInfo'
			copied.push(info)
		end 'eachInfo'
		stdlibTypealiasVisibilities.upsert(name, value: copied)
	end 'cacheAliasVis'
	for (name, range) in project.typealiasRanges 'cacheRanges'
		stdlibTypealiasRanges.upsert(name, value: range)
	end 'cacheRanges'
	for (name, category) in project.typealiasCastCategories 'cacheCategories'
		stdlibTypealiasCastCategories.upsert(name, value: category)
	end 'cacheCategories'

	// Build and write the stdlib cache for next time, then switch to cached
	// mode so subsequent calls in the same process (e.g. spec tests)
	// consistently use the pre-compiled path.
	buildAndWriteStdlibCache(project, allModule: allModule, cachePath: cachePath, contentChecksum: contentChecksum)
	stdlibLoaded = true

	// The user binary picks up stdlib via the pre-compiled cache (linked at
	// codegen) plus the metadata already restored on this project, so the
	// parsed module must NOT flow into the user pipeline — otherwise
	// emitWasm/x64 sees the same stdlib functions twice (once from the IR and
	// once from the cache) and the wasm validator rejects the duplicate
	// definitions. Return an empty module.
	cachedStdlibModule = MaxonModule.create()
	return cachedStdlibModule
end 'getStdlibModule'

// Build the stdlib cache by compiling the parsed MaxonModule through the mid
// pipeline + metadata capture. v80: on NATIVE targets it writes the cache
// metadata-only (signature stubs, no eager regalloc — the ~7.8s backend tail
// over ~992 functions is deferred to lazy per-function codegen at link time),
// then eagerly compiles just the universal runtime floor; on WASM it emits
// every function eagerly (wasm has no lazy path — see the emit block below).
function buildAndWriteStdlibCache(project Project, allModule MaxonModule, cachePath FilePath, contentChecksum CacheChecksum)
	var globalData = createGlobalDataTable()
	let sourceFileName = ""

	// Stdlib pipeline is flagged `isStdlib: true` so that lowerMaxonToStd
	// prefixes its panic-message labels with `__stdlib_panic_msg_` instead
	// of `__panic_msg_`, keeping stdlib and user panic labels in disjoint
	// link-time namespaces.
	var pipeline = PassPipeline.create(allModule, project: project, globalData: globalData, target: project.target, sourceFileName: sourceFileName, isStdlib: true)

	// Phases 2-5: shared across all targets (through MIR)
	// resolveTypes drains the unresolvedTypealiases registry (populated by
	// the stdlib parse) into the resolved typealiases/typealiasRanges maps
	// so lowerMaxonToStd can look up named types successfully.
	// Skip semanticCheck — it requires main() which stdlib doesn't have
	pipeline.addPass(PassKind.resolveTypes)
	// Phase 11.2 / 11.3: emit layout descriptors and witness tables for
	// every interned generic instance / conformance the stdlib parse
	// produced. lowerMaxonToStd's `materializeLayoutArg` reads
	// `project.layoutDescriptors` at every generic-method call site, so
	// without these passes stdlib lowering panics with a
	// "no descriptor for gid …" tripwire on the first such call.
	pipeline.addPass(PassKind.buildLayoutDescriptors)
	pipeline.addPass(PassKind.buildWitnessTables)
	// Expand parser-emitted `castCheck` placeholders before lowering so
	// stdlib's own `as RangedAlias` casts get their runtime guards.
	pipeline.addPass(PassKind.expandCastRangeChecks)
	pipeline.addPass(PassKind.constantArrayLiteralRdata)
	pipeline.addPass(PassKind.lowerMaxonToStd)
	// No maxonBorrowCheck in the stdlib sandbox — stdlib is exempt from the
	// E3070 borrow check (user code can't fix it, and the bootstrap skips it).
	pipeline.addPass(PassKind.mem2reg)
	pipeline.addPass(PassKind.canonicalize)
	pipeline.addPass(PassKind.cse)
	pipeline.addPass(PassKind.licm)
	pipeline.addPass(PassKind.dce)
	// Argument-consume analysis (Concept C) — compute the stdlib's structural
	// per-parameter consume facts on the FULL stdlib call graph (every container
	// body present, nothing inlined away here), so they can be PERSISTED in the cache
	// (`captureStdlibMetadata`) and restored into the user project. Without this the
	// user build's consuming stdlib callees are signature-only stubs with no body to
	// analyze, leaving `funcParamConsumes` empty and forcing the inserter onto the
	// retired callee-name allowlists. Must run before `insertRefcounts` (which reads
	// the facts to suppress a consumed arg's release).
	pipeline.addPass(PassKind.analyzeParamConsumes)
	// Return-borrow analysis (Concept C's return-side dual) — compute the stdlib's
	// structural return-borrow facts on the FULL stdlib call graph so they can be
	// PERSISTED in the cache (`captureStdlibMetadata` → `funcReturnsBorrow`) and
	// restored into the user project. The bodyless element-loader intrinsics
	// (`__managed_mem_get` → `__managed_mem_load_sized` → `__Internals.loadIndirect`)
	// ARE real Maxon functions whose bodies return a param-derived `load`, so the
	// structural leaf rule classifies them borrow-returning HERE (where their bodies are
	// present) — replacing the `calleeIsBorrowIntrinsic` name allowlist the user build
	// fell back on (the user module sees them only as bodyless external calls). Must run
	// after `analyzeParamConsumes` (its container-consume narrowing reads the consume
	// set) and before `insertRefcounts` (which reads the borrow classes).
	pipeline.addPass(PassKind.analyzeReturnBorrows)
	// SSA refcount inserter (post-mem2reg) — the retired pre-mem2reg injectDrops's
	// replacement; runs on the SSA form from per-value liveness + ownership class.
	pipeline.addPass(PassKind.insertRefcounts)
	// Skip insertRangeChecks — it emits mrt_panic calls that require runtime
	// functions, but stdlib functions take validated inputs from their callers.
	pipeline.addPass(PassKind.lowerABI)

	// Run Phase 4 passes first; runtime bodies (already-Std, post-mem2reg
	// from loadRuntimeModule) get spliced in next so they ride through
	// lowerStdToMir + backend phases the same way stdlib bodies do.
	//
	// Stdlib content is trusted: a pipeline failure here is a compiler bug
	// (an unsupported language feature reached lowering, or a pass crashed
	// on a stdlib-only shape). Surfacing it as a panic prevents the cache
	// from silently rolling forward in a half-built state where downstream
	// user code dispatches to phantom witnesses or missing builtin methods.
	try pipeline.run() otherwise panic("Stdlib cache build failed during mid pipeline; see error diagnostics above")

	// Detach the post-dce snapshot before merging runtime bodies. The
	// snapshot and `pipeline.stdModule` share array references — mutating
	// one mutates the other — and the user-pipeline inliner reads the
	// snapshot as its source of stdlib bodies. If runtime bodies leak into
	// the snapshot, the inliner inlines runtime helpers (mm_alloc, the
	// __slab_* family) into user `main`, both bloating user code and
	// breaking the linker's expectation that runtime callees resolve
	// through the cached ObjectFunctions by name.
	var detachedSnapshot = StdModule.create()
	detachedSnapshot.merge(pipeline.stdModulePostDceSnapshot)
	pipeline.stdModulePostDceSnapshot = detachedSnapshot

	let isWasm = project.target.cpu == CpuArch.wasm32

	// Splice runtime bodies into the stdlib StdModule on native targets.
	// The cache then emits ObjectFunctions for the ~46 project-independent
	// runtime functions (mrt_panic, mrt_write_*, __slab_*, mm_*,
	// __managed_mem_*, __layout_word_*, __destruct_*) — the linker pulls
	// them in by name when user code references them. The per-compile
	// names (entry-point variants and coverage helpers) stay out because
	// `patchMrtStartWithModuleInits` and the coverage globals are project-
	// specific and applied freshly per user compile.
	//
	// WASM emission stays on the old "runtime emitted by user pipeline"
	// path because the wasm `call_indirect` instruction encodes a type-
	// section index inline in the body bytes — caching wasm runtime bodies
	// would require a fixup mechanism similar to `callFixups` for those
	// type indices, plus walking stdlib/runtime indirect-call types in
	// `emitWasmModule`'s type-section build. The win on wasm is also
	// smaller because wasm doesn't go through commuteForCoalescing /
	// scheduleInstructions / lowerMirToTarget / allocateRegisters.
	if not isWasm 'spliceRuntime'
		let runtimeForCache = buildCacheSideRuntime(loadRuntimeModule())
		pipeline.stdModule.merge(runtimeForCache)
	end 'spliceRuntime'

	// Continue through Phase 5+: lowerStdToMir converts the merged module
	// (stdlib functions + runtime bodies on native, stdlib only on wasm)
	// to MIR. Reset the pass list and re-run on the same pipeline so the
	// stdModule, mirModule, and project state stay coherent.
	pipeline.passes = PassKindArray.create()
	pipeline.addPass(PassKind.lowerStdToMir)

	if not isWasm 'nativePasses'
		pipeline.addPass(PassKind.commuteForCoalescing)
		pipeline.addPass(PassKind.scheduleInstructions)
	end 'nativePasses'

	try pipeline.run() otherwise panic("Stdlib cache build failed during late pipeline; see error diagnostics above")

	// On wasm, restore the old `injectRuntimeSignatures` post-MIR fixup so
	// stdlib calls into runtime resolve at backend lowering time. The
	// per-target filter below strips runtime stubs back out before cache
	// write, mirroring the pre-change wasm behavior.
	if isWasm 'injectWasmRuntimeSigs'
		injectRuntimeSignatures(pipeline.mirModule)
	end 'injectWasmRuntimeSigs'

	// Phase 11.6 cross-module inlining: capture the stdlib's post-dce
	// StdModule (PassPipeline.stdModulePostDceSnapshot is populated at the
	// `dce` step's exit) for the user pipeline's inliner to consume.
	// Stored both in-process (so the immediately-following user pipeline
	// run sees it) and into the cache buffer (for next-run cache hits).
	// Captured pre-runtime-merge so the inliner doesn't see runtime bodies
	// it would never inline anyway (panic-helper gate, splice-shape limits).
	cachedStdlibStdModule = pipeline.stdModulePostDceSnapshot

	// Build cache data
	let metaStart = passTimerStart()
	var cacheData = StdlibCacheData.create()
	cacheData.globalData = pipeline.globalData
	captureStdlibMetadata(project, data: cacheData)
	cacheData.inlinerStdModule = pipeline.stdModulePostDceSnapshot
	// v68: extract each snapshot function's Std-DFE edges once (a pure
	// function of the body) so the load-time Std-DFE consults a flat table
	// instead of re-walking the snapshot. Populated both in-process (for the
	// immediately-following user pipeline run) and into the cache buffer (for
	// next-run cache hits).
	cachedStdlibFuncEdges = buildStdFuncEdgeMap(pipeline.stdModulePostDceSnapshot)
	cacheData.stdFuncEdges = cachedStdlibFuncEdges
	recordPassSince("__stdlib-captureMetadata", startMs: metaStart)

	// Emit per-function bytecode (dispatched by target).
	//
	// v80 lazy codegen: on the metadata-only cold path, SKIP all per-function
	// regalloc + emit (the ~7.8s `buildStdlibNativeWith` cost over ~992
	// functions). `cacheData.functions` holds signature-only stubs; the user
	// build compiles each reached function on demand at link time (see
	// `ensureStdlibFunctionsCompiled`), filling the stubs' real bytecode.
	// Everything ABOVE this point (metadata,
	// `inlinerStdModule` Std-IR snapshot, `stdFuncEdges`, the merged-MIR
	// `pipeline.mirModule` that the in-process lazy-fill reuses) is still
	// produced in full — only the expensive backend tail is deferred.
	//
	// Native: the merged stdModule contains runtime bodies (excluding
	// per-compile names — entry-point variants and coverage helpers); they
	// lower into ObjectFunctions identically to stdlib bodies, and the
	// linker pulls them by name when user code references them. The
	// per-compile filter strips empties for those names defensively.
	// Wasm: runtime bodies are NOT in the pipeline (signatures only via
	// `injectRuntimeSignatures`); the user pipeline supplies them. Strip
	// every runtime function from the cache so the empty stubs the wasm
	// emitter produces for runtime signatures don't shadow real bodies.
	// Native (x64/arm64): write SIGNATURE-ONLY stubs (name + return type + param
	// types, empty code/fixups) for every function — NO eager regalloc/emit (the
	// ~7.8s cost over ~992 functions is deferred). The stubs let the user
	// build's per-function target lowering resolve callee signatures via
	// `findCalleeSignature`'s `stdlibFunctions` fallback (runtime callees like
	// `__gt_init` aren't in the user module on a valid native cache). Lazy
	// codegen fills each reached stub's real code in place at link time
	// (`ensureStdlibFunctionsCompiled`). Stubs carry no callFixups, so the
	// linker's fixup-closure (`computeNeededStdlibFunctions`) never traverses a
	// stub — the edge-map closure (`lazyNeededClosure`) drives compilation, then
	// the linker sees real fixups on the filled-in entries.
	//
	// Wasm stays EAGER: its runtime sigs come from the user pipeline's
	// `injectRuntimeSignatures` (not the cache), so the native signature-stub +
	// lazy-backend mechanism doesn't apply. Emit every wasm function now.
	if isWasm 'emitWasm'
		let wasmEmitStart = passTimerStart()
		cacheData.wasmFunctions = emitWasmPerFunction(pipeline.mirModule, globalData: pipeline.globalData).filter(function(func) gives not isRuntimeFunctionName(func.name))
		recordPassSince("__stdlib-emitWasm", startMs: wasmEmitStart)
		logInfo(LogCategory.compiler, message: function() gives "Wrote stdlib cache: {cacheData.wasmFunctions.count()} WASM functions to {cachePath}")
	end 'emitWasm' else 'nativeStubs'
		cacheData.functions = buildSignatureStubs(pipeline.mirModule)
		logInfo(LogCategory.compiler, message: function() gives "Wrote stdlib cache (metadata-only): {cacheData.functions.count()} signature stubs, bytecode compiled lazily on demand -> {cachePath}")
	end 'nativeStubs'

	// Write to disk and activate cache for subsequent compilations in this process
	let writeStart = passTimerStart()
	writeStdlibCache(project, path: cachePath, data: cacheData, target: project.target, contentChecksum: contentChecksum)
	recordPassSince("__stdlib-writeCache", startMs: writeStart)
	activateStdlibCache(cacheData, target: project.target)

	// v80: on native, eagerly compile the universal runtime FLOOR (the functions
	// every native program links — the `mrt_*`/`mm_*`/`__slab_*` runtime + entry
	// machinery) into the just-written cache. This runs in the STDLIB BUILD
	// project, whose interner holds the metadata's constant string ids, so the
	// re-serialize (inside `ensureStdlibFunctionsCompiled`, when persist is
	// allowed) is safe. The payoff: the very next build of ANY program finds the
	// floor already compiled on disk and lazily compiles nothing for a
	// stdlib-free program — a sub-500ms warm `return 0`. Program-specific
	// functions a user build reaches beyond the floor are compiled (and, on a
	// CLI build, persisted) lazily by the user-build link path.
	if not isWasm 'eagerFloor'
		var floorSeeds = StringArray.create()
		appendX64EagerFloorSeeds(floorSeeds, os: project.target.os)
		ensureStdlibFunctionsCompiled(project, seeds: floorSeeds)
	end 'eagerFloor'
end 'buildAndWriteStdlibCache'

// Load `runtime.std` and push signature-only entries (name, paramCount,
// paramTypes, returnType) for every runtime function into the stdlib
// pipeline's MirModule. Backend param-type lookups (lookupFuncParamTypes)
// walk IrFunctionArray looking for a name match, so once these entries
// exist, calls from stdlib code into `mrt_*` resolve correctly during
// per-function wasm lowering. Used only on the wasm cache build path —
// native targets splice the full runtime bodies into the StdModule before
// lowerStdToMir, so they don't need this post-MIR signature fixup.
//
// We don't copy blockRefs or any ops — only the header — so the backend
// emits an empty stub that the per-target filter strips before the cache
// is written. The wasm path's filter strips every runtime body (matching
// the pre-change behavior where the user pipeline supplied them).
function injectRuntimeSignatures(mirModule MirModule)
	let runtimePath = findRuntimePath()
	if runtimePath.isEmpty() 'noRuntime'
		return
	end 'noRuntime'
	let runtime = loadRuntimeModule()
	for rtFunc in runtime.functions 'eachRt'
		var alreadyPresent = false
		for existing in mirModule.functions 'checkExisting'
			if existing.name == rtFunc.name 'match'
				alreadyPresent = true
				break
			end 'match'
		end 'checkExisting'
		if alreadyPresent 'skip'
			continue
		end 'skip'
		let sig = IrFunction.createFromStd(rtFunc.name, returnType: rtFunc.returnType, paramCount: rtFunc.paramCount, paramTypes: rtFunc.paramTypes, returnLine: 0)
		mirModule.functions.push(sig)
	end 'eachRt'
end 'injectRuntimeSignatures'

// Try to load the stdlib cache for a different target (cross-compilation).
// The metadata is already loaded; only the target-specific code data changes.
// Reserve `__module_init_<n>` name slots so the user pipeline's parser
// allocates fresh names that don't collide with stdlib init names already
// baked into the cached function table. Without this reservation, a
// cache-hit user compile starts with `count() == 0`, the user's first
// init grabs `__module_init_0`, and the linker call from `mrt_start`
// resolves to either the cached stdlib body or the user body depending on
// symbol resolution order — silent ABI corruption (the cached stdlib
// body writes to `__data_<stdlibVar>` slots that don't exist in the user
// project's `.data` section, scribbling on whatever lives at offset 0).
//
// After v55 the cache persists `project.moduleInitFuncs` directly via
// `restoreStdlibMetadata`, so the names are already present (with their
// real callable identifiers, not placeholders). This function then
// becomes a no-op fallback for legacy paths where the cache restore
// hasn't populated `moduleInitFuncs`. The fallback pushes empty strings
// — `patchMrtStartWithModuleInits` filters empty entries via the same
// `name.isEmpty()` guard used elsewhere for inactive runtime helpers.
function seedModuleInitFuncsFromLivenessRoots(project Project)
	if project.moduleInitFuncs.count() > 0 'alreadyPopulated'
		return
	end 'alreadyPopulated'
	let prefix = "__module_init_"
	var stdlibInitCount = 0
	for root in project.livenessRoots 'eachRoot'
		if root.startsWith(prefix) 'isInit'
			stdlibInitCount = stdlibInitCount + 1
		end 'isInit'
	end 'eachRoot'
	for _ in 0 upto stdlibInitCount 'reserveSlots'
		project.moduleInitFuncs.push("")
	end 'reserveSlots'
end 'seedModuleInitFuncsFromLivenessRoots'

function loadCacheForTarget(project Project)
	// Cross-target switch: the lazy MIR / edge map / compiled-name set are all
	// keyed to the PREVIOUS target's reconstructed module and arch backend.
	// Invalidate them so the new target rebuilds its own (otherwise
	// `ensureStdlibFunctionsCompiled` would run the new arch's backend over the
	// old arch's lazy MIR and treat old-target names as already compiled).
	resetLazyStdlibState()

	let stdlibPath = findStdlibPath()
	if stdlibPath.isEmpty() 'noStdlib'
		return
	end 'noStdlib'

	// Use the same project directory as the initial cache load
	let projectDir = try stdlibCacheProjectDirs.get(0) otherwise return
	let cacheDir = projectDir.join(".maxon").join("cache")
	let cachePath = cacheDir.join("stdlib-{targetToString(project.target)}.mxc")
	let contentChecksum = currentStdlibChecksum(project.target)

	let cacheResult = readStdlibCache(project, path: cachePath, target: project.target, expectedChecksum: contentChecksum)

	if cacheResult.valid 'cacheHit'
		logInfo(LogCategory.compiler, message: function() gives "Stdlib cache hit for {targetToString(project.target)}: {countCompiledStdlibFunctions(cacheResult.data)} of {cacheResult.data.functions.count()} native functions have bytecode (rest deferred stubs) + {cacheResult.data.wasmFunctions.count()} WASM functions")
		activateStdlibCache(cacheResult.data, target: project.target)
		return
	end 'cacheHit'

	// Cache miss for this target — parse fresh into the destination project
	// so its registries / interners hold the same entries a from-source
	// build would. `loadCacheForTarget` runs after the in-process fast path
	// already restored stdlib metadata for *another* target, so we can't
	// re-use the cross-project sandbox snapshot here without conflating its
	// id-space with `project`'s.
	let stdlibFiles = collectStdlibFiles()
	var allModule = MaxonModule.create()
	let stdlibRoot = findStdlibProjectRoot()
	for fp in stdlibFiles 'iter'
		if File.exists(fp) 'exists'
			let content = try File.readText(fp) otherwise panic("StdlibLoader: failed to read bundled stdlib file {fp}")
			parseStdlibSource(project, allModule: allModule, filePath: fp, rootPath: stdlibRoot, content: content)
		end 'exists'
	end 'iter'
	// Drain cross-file overload renames (see comments in the cache-miss path
	// in `getStdlibModule`). Same rationale: the per-file parser rekey can't
	// reach the merged IrFunction in `allModule`.
	applyPendingFuncRenames(project, allModule: allModule)
	// G.2: same post-parse validation as in `getStdlibModule`. See there
	// for the contract; required here too because `loadCacheForTarget`
	// reparses from source on a per-target cache miss.
	validateEnumLookupCalls(project, allModule: allModule)

	logInfo(LogCategory.compiler, message: function() gives "Stdlib cache miss for {targetToString(project.target)}: building")
	buildAndWriteStdlibCache(project, allModule: allModule, cachePath: cachePath, contentChecksum: contentChecksum)
end 'loadCacheForTarget'

export function getStdlibCacheData() returns StdlibCacheData
	return cachedStdlibCacheData
end 'getStdlibCacheData'

function activateStdlibCache(data StdlibCacheData, target Target)
	cachedStdlibCacheData = data
	stdlibCacheValid = true
	stdlibCacheCpuOrd = target.cpu.ordinal
	stdlibCacheOsOrd = target.os.ordinal
	stdlibCacheTargetSet = true
end 'activateStdlibCache'

export function isStdlibCacheValid() returns bool
	return stdlibCacheValid
end 'isStdlibCacheValid'

// v68: extract the precomputed Std-DFE edge table from a post-dce Std-IR
// snapshot — one record per function, each a pure function of the body
// (call edges + witness/layout/globalAddr label demands). Built once at
// cache-build time so the load-time Std-DFE follows the cached call graph +
// witness/layout demands by consulting a flat table instead of re-walking
// the snapshot IR. This keeps the witness-method impls
// (`Character.hash`/`equals`) and their funcAbs64 slot relocs alive for
// generics built only inside a cached `<Type>.<field>.__lazy_init`.
// Target-independent (works for x64 and wasm alike) because it names only
// callees + rdata labels.
function buildStdFuncEdgeMap(snapshot StdModule) returns CachedFuncEdgeMap
	var edgeMap = CachedFuncEdgeMap.create()
	for func in snapshot.functions 'eachFunc'
		edgeMap.upsert(func.name, value: extractFuncEdges(snapshot, func: func))
	end 'eachFunc'
	return edgeMap
end 'buildStdFuncEdgeMap'

// ============================================================
// v80 lazy per-function stdlib codegen
// ============================================================

// Build signature-only `ObjectFunction` stubs (name + return type + param
// count/types, empty code/fixups) from the lowered MIR module, one per
// function the eager native path would have emitted (same
// `isPerCompileRuntimeName` filter). These let the user build's per-function
// target lowering resolve every stdlib/runtime callee signature on a cold
// metadata-only cache, before lazy codegen fills in the real bytecode. The
// MIR `IrFunction` carries the post-lowerStdToMir signature (paramTypes are
// already StdType, matching the eager ObjectFunction's paramTypes).
function buildSignatureStubs(mirModule MirModule) returns ObjectFunctionArray
	var stubs = ObjectFunctionArray.create()
	for func in mirModule.functions 'eachFunc'
		if isPerCompileRuntimeName(func.name) 'perCompile'
			continue
		end 'perCompile'
		var stub = ObjectFunction.create(func.name, returnType: func.returnType, paramCount: func.paramCount)
		stub.paramTypes = func.paramTypes
		stubs.push(stub)
	end 'eachFunc'
	return stubs
end 'buildSignatureStubs'

// Reconstruct the merged stdlib+runtime StdModule and extract its full
// call-edge map — the CHEAP half of lazy setup (a couple of merges + an edge
// walk, no lowering). Memoized via `lazyStdlibEdgesBuilt`. The needed-closure
// only needs the edge map, so a warm build whose every reachable function is
// already compiled pays just this — never the expensive MIR lowering below.
//
// `cachedStdlibStdModule` is the post-dce snapshot (stdlib bodies, no runtime);
// merging the cache-side runtime bodies mirrors the eager build's
// `pipeline.stdModule.merge(buildCacheSideRuntime(...))` splice point. The
// reconstructed module is retained for `ensureLazyStdlibMir` to lower on
// demand.
function ensureLazyStdlibEdges()
	if lazyStdlibEdgesBuilt 'already'
		return
	end 'already'

	var reconstructed = StdModule.create()
	reconstructed.merge(cachedStdlibStdModule)
	let runtimeForCache = buildCacheSideRuntime(loadRuntimeModule())
	reconstructed.merge(runtimeForCache)

	lazyReconstructed = reconstructed
	lazyStdlibFuncEdges = buildStdFuncEdgeMap(reconstructed)
	lazyStdlibEdgesBuilt = true
end 'ensureLazyStdlibEdges'

// Lower the reconstructed module to MIR — the EXPENSIVE half (lowerStdToMir +
// commuteForCoalescing + scheduleInstructions over ~992 functions, ~170ms).
// Only called when there is at least one function to compile, so a fully-warm
// build skips it. Memoized via `lazyStdlibMirBuilt`. Because every one of those
// passes is `perFunction` (intra-function) and panic-message labels are
// content-hashed (pipeline-independent), a function lowered here is
// byte-identical to the same function in a whole-module eager build.
//
// `project` supplies the target + globalData context. Native-only; wasm lazy
// codegen is handled on its own path.
function ensureLazyStdlibMir(project Project)
	if lazyStdlibMirBuilt 'already'
		return
	end 'already'
	ensureLazyStdlibEdges()

	var pipeline = PassPipeline.create(MaxonModule.create(), project: project, globalData: cachedStdlibCacheData.globalData, target: project.target, sourceFileName: "", isStdlib: true)
	pipeline.stdModule = lazyReconstructed
	pipeline.addPass(PassKind.lowerStdToMir)
	pipeline.addPass(PassKind.commuteForCoalescing)
	pipeline.addPass(PassKind.scheduleInstructions)
	try pipeline.run() otherwise panic("Lazy stdlib MIR build failed; see error diagnostics above")

	lazyStdlibMir = pipeline.mirModule
	lazyStdlibMirBuilt = true
end 'ensureLazyStdlibMir'

// Transitive closure over the reconstructed Std-IR call-edge map, resolving
// each (possibly bare) seed name to its actual function key (mirrors
// `resolveStdlibCacheKey`: a bare runtime call to a `stdlib.`-qualified
// Internals function probes the qualified form). Returns every function name
// reachable from `seeds` — the set the lazy backend must compile so the
// linker's name-keyed closure resolves with no gap.
function lazyNeededClosure(project Project, seeds StringArray) returns StdlibFuncNameSet
	var needed = StdlibFuncNameSet.create()
	var worklist = StringArray.create()

	for name in seeds 'seed'
		let key = resolveLazyEdgeKey(name)
		if not key.isEmpty() and not needed.contains(key) 'isFunc'
			needed.insert(key)
			worklist.push(key)
		end 'isFunc'
	end 'seed'

	var wi = 0
	while wi < worklist.count() 'walk'
		let nameRef = try worklist.get(wi) otherwise 'skip'
			wi = wi + 1
			continue
		end 'skip'
		let name = "{nameRef}"
		wi = wi + 1
		let edges = try lazyStdlibFuncEdges.get(name) otherwise continue
		for callee in edges.callees 'eachCallee'
			let depKey = resolveLazyEdgeKey(callee)
			if not depKey.isEmpty() and not needed.contains(depKey) 'newDep'
				needed.insert(depKey)
				worklist.push(depKey)
			end 'newDep'
		end 'eachCallee'
		// Witness/layout conditional-root labels (`loadWitnessTable` /
		// `loadLayoutDescriptor`) reach their impl functions only through
		// `project.witnessConditionalRoots`, NOT a `call`/`funcAddr` edge — mirror
		// the in-module DFE's `promoteConditionalRoots` so a generic whose witness
		// impls are reachable solely via a conditional-root label still gets those
		// impls compiled (otherwise they would link as `.text+0` stubs). `seen`
		// for labels is `needed` membership of the resolved impl names — the
		// closure converges because impls are finite.
		for label in edges.conditionalRootLabels 'eachCondRoot'
			if let bucket = try project.witnessConditionalRoots.get(label) 'haveBucket'
				for i in 0 upto bucket.count() 'eachImpl'
					let implName = try bucket.get(i) otherwise panic("lazyNeededClosure: witnessConditionalRoots bucket OOB at {i}")
					let implKey = resolveLazyEdgeKey(implName)
					if not implKey.isEmpty() and not needed.contains(implKey) 'newImpl'
						needed.insert(implKey)
						worklist.push(implKey)
					end 'newImpl'
				end 'eachImpl'
			end 'haveBucket'
		end 'eachCondRoot'
	end 'walk'

	return needed
end 'lazyNeededClosure'

// Resolve a (possibly bare) name to its key in `lazyStdlibFuncEdges`, probing
// the `stdlib.`-qualified form for bare runtime->Internals calls. Empty when
// neither form is a known function.
function resolveLazyEdgeKey(name String) returns String
	if lazyStdlibFuncEdges.contains(name) 'exact'
		return name
	end 'exact'
	let qualified = "stdlib.{name}"
	if lazyStdlibFuncEdges.contains(qualified) 'qualified'
		return qualified
	end 'qualified'
	return ""
end 'resolveLazyEdgeKey'

// Seed `lazyCompiledStdlibNames` from cache entries that already carry REAL
// machine code (non-empty `code`). Signature-only stubs (empty `code`, written
// by `buildSignatureStubs` on a cold cache) are NOT marked compiled — they
// still need their bytecode filled in. On a warm cache that accreted real code
// over prior builds, those entries pre-mark so we don't recompile them.
// Idempotent — safe to call before each lazy-fill.
function syncLazyCompiledNames()
	for func in cachedStdlibCacheData.functions 'eachEntry'
		if func.code.count() > 0 and not lazyCompiledStdlibNames.contains(func.name) 'isReal'
			lazyCompiledStdlibNames.insert(func.name)
		end 'isReal'
	end 'eachEntry'
end 'syncLazyCompiledNames'

// Count cache entries that carry REAL machine code (non-empty `code`), as
// opposed to v80 signature-only stubs (empty `code`, bytecode still deferred).
// Used for honest cache-hit logging — `functions.count()` alone counts stubs
// as if they were compiled.
export function countCompiledStdlibFunctions(data StdlibCacheData) returns MachineWord
	var n = 0
	for func in data.functions 'eachFunc'
		if func.code.count() > 0 'hasCode'
			n = n + 1
		end 'hasCode'
	end 'eachFunc'
	return n
end 'countCompiledStdlibFunctions'

// Map each cache function name to its index in `cachedStdlibCacheData.functions`,
// so lazy codegen can replace a signature stub in place (`.set`) rather than
// append — keeping the array's order (and the linker's `.text` layout derived
// from it) stable and stub-free of duplicates.
function buildCacheFuncIndex() returns StdlibFuncIndexMap
	var index = StdlibFuncIndexMap.create()
	for (iter, func) in cachedStdlibCacheData.functions.withIterator() 'eachEntry'
		index.upsert(func.name, value: iter.index())
	end 'eachEntry'
	return index
end 'buildCacheFuncIndex'

// Compile every native stdlib/runtime function transitively reachable from
// `seeds` that is not yet present in the cache's `functions` array, filling
// each freshly-emitted ObjectFunction into its pre-existing signature-stub
// slot. Called by the native linkers (x64/arm64) BEFORE
// `computeNeededStdlibFunctions` so the cache holds every function the
// name-keyed link closure will then resolve. A no-op (beyond the cheap
// missing-set scan) when the cache already carries every reachable function —
// the steady-state warm-cache hit.
//
// The closure runs over the reconstructed Std-IR edge map (`lazyNeededClosure`),
// NOT the compiled `callFixups`: on a metadata-only cold cache the `functions`
// entries are signature-only stubs with EMPTY callFixups, so
// `computeNeededStdlibFunctions`' own fixup closure would resolve nothing past
// the seeds. The edge map is the codegen-free call graph derived from the same
// bodies, so its closure equals the eventual fixup closure.
//
// Determinism: each emitted body is written IN PLACE into the slot its
// signature stub already occupies (`.set` by name index, below), so the
// `functions` array order never deviates from the cold-build stub order — and
// the linker's `.text` layout, which iterates that array, stays stable across
// builds regardless of which program triggered which compiles. The stub order
// is itself build-order-independent (`buildSignatureStubs` emits in
// `mirModule.functions` order, a pure function of the stdlib's structure), so
// slot-preservation — NOT a name sort — is what makes cache-parity hold. Do
// not "sort by name" here: that would reorder fills relative to the stubs and
// break parity.
//
// Mutates the process-global `cachedStdlibCacheData` directly (not a passed-in
// value) so the link path's immutable `stdlibCache` binding — which aliases
// the same heap-backed `functions` array via `getStdlibCacheData()` — sees the
// additions without threading a `mutates` annotation up through
// `queryCodeResult`. Maxon `Array` is reference-backed, so a push on the
// global is visible through every alias.
export function ensureStdlibFunctionsCompiled(project Project, seeds StringArray)
	syncLazyCompiledNames()

	let lazyStart = passTimerStart()
	// Cheap: build the edge map (no MIR lowering) and compute what the program
	// transitively reaches, minus what the cache already has real code for.
	ensureLazyStdlibEdges()
	let needed = lazyNeededClosure(project, seeds: seeds)

	var missingSet = StdlibFuncNameSet.create()
	for name in needed 'eachNeeded'
		if not lazyCompiledStdlibNames.contains(name) 'isMissing'
			missingSet.insert(name)
		end 'isMissing'
	end 'eachNeeded'

	if missingSet.count() == 0 'nothingToDo'
		// Fully-warm hit: every reachable function already carries real code.
		// We paid only the cheap edge build — no MIR lowering, no regalloc.
		return
	end 'nothingToDo'

	// Something to compile — NOW pay the expensive MIR lowering (once).
	ensureLazyStdlibMir(project)

	// Select the MIR functions to lower in the SAME order they appear in the
	// reconstructed module (preserving lowering context), restricted to the
	// missing set. The emitted results are filled back into their existing
	// stub slots below (`.set` by name index), so the cache's function order
	// stays fixed at the build-order-independent stub order.
	var funcsToLower = IrFunctionArray.create()
	for func in lazyStdlibMir.functions 'pickMir'
		if missingSet.contains(func.name) 'wanted'
			funcsToLower.push(func)
		end 'wanted'
	end 'pickMir'

	let emitted = compileStdlibMirSubsetNative(project, funcsToLower: funcsToLower)

	// Fill each freshly-emitted function's real bytecode into its existing
	// signature-stub slot (`.set` by name index), preserving the cache array's
	// order so the linker's `.text` layout stays stable regardless of which
	// program triggered the compile. Every MIR function gets a stub on the cold
	// build, so the `.set` path always taken; the `else` push is a correctness
	// backstop for the unreachable no-stub case (it keeps the body linkable,
	// though an out-of-stub-order append would perturb parity — which is why it
	// must stay unreachable).
	let index = buildCacheFuncIndex()
	var keptCount = 0
	for func in emitted 'fill'
		if isPerCompileRuntimeName(func.name) 'perCompile'
			continue
		end 'perCompile'
		if lazyCompiledStdlibNames.contains(func.name) 'alreadyReal'
			continue
		end 'alreadyReal'
		if let slot = try index.get(func.name) 'hasStub'
			try cachedStdlibCacheData.functions.set(slot, value: func) otherwise panic("lazy codegen: stub slot {slot} for '{func.name}' out of bounds")
		end 'hasStub' else 'noStub'
			cachedStdlibCacheData.functions.push(func)
		end 'noStub'
		lazyCompiledStdlibNames.insert(func.name)
		keptCount = keptCount + 1
	end 'fill'

	// Safety tripwire (risk #2 in the design): every reachable function MUST now
	// carry real code, or the linker's name-keyed closure would link a stub's
	// empty `code` and resolve calls into it to `.text+0` — a silent corruption.
	// A miss here means `lazyNeededClosure` (edge map) under-approximated the
	// linker's fixup closure. Per-compile runtime names are intentionally NOT in
	// the cache (the user pipeline supplies them), so they're exempt.
	for name in missingSet 'verify'
		if isPerCompileRuntimeName(name) 'exemptPerCompile'
			continue
		end 'exemptPerCompile'
		if not lazyCompiledStdlibNames.contains(name) 'gap'
			panic("lazy codegen: needed stdlib function '{name}' has no compiled body after lazy fill — edge-map closure under-approximated the linker closure (would link .text+0)")
		end 'gap'
	end 'verify'

	// Persist the grown cache so the NEXT build reuses the just-compiled
	// bytecode (zero regalloc). Only safe from a single-project CLI build (see
	// `stdlibCachePersistAllowed`); the spec runner's cross-project workers
	// leave it false and recompile in-process each run (no on-disk growth).
	if stdlibCachePersistAllowed 'persist'
		persistGrownStdlibCache(project)
	end 'persist'

	recordPassSince("__stdlib-lazyCodegen", startMs: lazyStart)
	// `lazyCompiledStdlibNames` counts entries that now carry REAL machine code;
	// `functions.count()` is the TOTAL of compiled bodies + signature-only stubs
	// (the un-reached functions whose bytecode is still deferred). Report both so
	// the line doesn't misclaim every stub as compiled.
	logInfo(LogCategory.compiler, message: function() gives "Lazily compiled {keptCount} stdlib functions ({lazyCompiledStdlibNames.count()} cached)")
end 'ensureStdlibFunctionsCompiled'

// Compute the on-disk cache path for `project`'s target, mirroring the loader's
// path computation (`getStdlibModule` / `loadCacheForTarget`). Empty when no
// project dir has been pinned yet (the cache can't be located).
function currentStdlibCachePath(project Project) returns FilePath
	let projectDir = try stdlibCacheProjectDirs.get(0) otherwise return FilePath from ""
	return projectDir.join(".maxon").join("cache").join("stdlib-{targetToString(project.target)}.mxc")
end 'currentStdlibCachePath'

// Re-serialize the in-memory `cachedStdlibCacheData` (now carrying the
// lazily-compiled bytecode) to the cache file, so subsequent builds reuse it.
function persistGrownStdlibCache(project Project)
	let cachePath = currentStdlibCachePath(project)
	if cachePath.isEmpty() 'noPath'
		return
	end 'noPath'
	let contentChecksum = currentStdlibChecksum(project.target)
	writeStdlibCache(project, path: cachePath, data: cachedStdlibCacheData, target: project.target, contentChecksum: contentChecksum)
end 'persistGrownStdlibCache'

// Run the native backend tail (target lowering + regalloc + prologue/epilogue
// + emit) over a SUBSET of the lazy MIR module's functions, returning their
// ObjectFunctions. Mirrors `buildStdlibNativeWith` exactly except it lowers
// `funcsToLower` instead of the whole module — `lowerMirToTargetForFunctions`
// keeps `allFunctions` pointing at the full module for callee-signature
// resolution, and per-function regalloc/emit are byte-identical to the eager
// whole-module path (the existing incremental-emit guarantee).
//
// `lowerMirToTargetForFunctions` stores the lowered module into the backend's
// own `targetModule` field (which `emitPerFunction` later reads); the same
// reference is what `allocateRegisters` (in-place mutation) and
// `insertPrologueEpilogueWith` operate on, so all four steps act on one
// module — exactly as `buildStdlibNativeWith` does.
function compileStdlibMirSubsetNative(project Project, funcsToLower IrFunctionArray) returns ObjectFunctionArray
	match project.target.cpu 'arch'
		x64 then return runNativeBackendTail(X64Backend.create(lazyStdlibMir, target: project.target, globalData: cachedStdlibCacheData.globalData, stdlibFunctions: cachedStdlibCacheData.functions), funcsToLower: funcsToLower, target: project.target)
		arm64 then return runNativeBackendTail(Arm64Backend.create(lazyStdlibMir, target: project.target, globalData: cachedStdlibCacheData.globalData, stdlibFunctions: cachedStdlibCacheData.functions), funcsToLower: funcsToLower, target: project.target)
		default panic("compileStdlibMirSubsetNative: non-native target reached lazy native codegen")
	end 'arch'
end 'compileStdlibMirSubsetNative'

// Run the backend tail (subset target-lowering -> regalloc -> prologue/epilogue
// -> per-function emit) on `backend`, returning the emitted ObjectFunctions.
// Takes `backend` as a `TargetBackend` parameter (the proven dispatch shape
// used by `prepareTargetModuleForFunctions`); the per-arch concrete backend is
// constructed by the caller's `match` so the interface value is a parameter,
// not a local from a returning function (which the C# bootstrap can't resolve
// interface-dispatch on).
function runNativeBackendTail(backend TargetBackend, funcsToLower IrFunctionArray, target Target) returns ObjectFunctionArray
	var targetModule = backend.lowerMirToTargetForFunctions(funcsToLower)
	targetModule = allocateRegisters(targetModule, target: target)
	insertPrologueEpilogueWith(targetModule, backend: backend)
	return backend.emitPerFunction()
end 'runNativeBackendTail'

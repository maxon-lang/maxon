// Logging system for the compiler.
// Mirrors maxon-sharp/Logger.cs with per-category log levels.

export enum LogLevel
    NONE
    ERROR
    INFO
    DEBUG
    TRACE
end 'LogLevel'

export enum LogCategory
    compiler
    lexer
    parser
    semantic
    mlir
    codegen
    pe
    testing

    function code() returns String
        match self 'code'
            LogCategory.compiler then return "CMP"
            LogCategory.lexer then return "LEX"
            LogCategory.parser then return "PAR"
            LogCategory.semantic then return "SEM"
            LogCategory.mlir then return "MLR"
            LogCategory.codegen then return "GEN"
            LogCategory.pe then return "PE "
            LogCategory.testing then return "TST"
        end 'code'
    end 'code'
end 'LogCategory'

var categoryLevels = [2, 2, 2, 2, 2, 2, 2, 2]

export function setLogLevel(level LogLevel)
    var i = 0
    while i < categoryLevels.count() 'reset'
        categoryLevels.set(i, value: level.rawValue)
        i = i + 1
    end 'reset'
end 'setLogLevel'

export function setCategoryLevel(category LogCategory, level LogLevel)
    categoryLevels.set(category.rawValue, value: level.rawValue)
end 'setCategoryLevel'

function getCategoryLevel(category LogCategory) returns int
    return try categoryLevels.get(category.rawValue) otherwise 0
end 'getCategoryLevel'

function isEnabled(category LogCategory, level LogLevel) returns bool
    return level.rawValue <= getCategoryLevel(category)
end 'isEnabled'

export function logError(category LogCategory, message String)
    log(category, level: LogLevel.ERROR, message: message)
end 'logError'

export function logInfo(category LogCategory, message String)
    log(category, level: LogLevel.INFO, message: message)
end 'logInfo'

export function logDebug(category LogCategory, message String)
    log(category, level: LogLevel.DEBUG, message: message)
end 'logDebug'

export function logTrace(category LogCategory, message String)
    log(category, level: LogLevel.TRACE, message: message)
end 'logTrace'

function log(category LogCategory, level LogLevel, message String)
    if isEnabled(category, level: level) 'check'
        printError("[{category.code()}] {level.name}: {message}\n")
    end 'check'
end 'log'

// Parses a log option string like "debug" or "lexer:trace".
export function parseLogOption(option String) returns bool
    let colonIdx = try option.findFirst(":") otherwise 'globalLevel'
        let level = try LogLevel.fromName(option.toUpper()) otherwise 'badLevel'
            return false
        end 'badLevel'
        setLogLevel(level)
        return true
    end 'globalLevel'

    let categoryStr = option.slice(option.startIndex(), endIndex: colonIdx)
    let afterColon = try option.indexAfter(colonIdx) otherwise 'noLevel'
        return false
    end 'noLevel'
    let levelStr = option.slice(afterColon, endIndex: option.endIndex())

    let category = try LogCategory.fromName(categoryStr) otherwise 'badCat'
        return false
    end 'badCat'

    let level = try LogLevel.fromName(levelStr.toUpper()) otherwise 'badLevel2'
        return false
    end 'badLevel2'

    setCategoryLevel(category, level: level)
    return true
end 'parseLogOption'

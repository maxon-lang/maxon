// Logging system for the compiler.

export union LogLevel
	NONE
	ERROR
	INFO
	DEBUG
	TRACE
end 'LogLevel'

export union LogCategory
	compiler = "CMP"
	lexer = "LEX"
	parser = "PAR"
	semantic = "SEM"
	ir = "IR "
	codegen = "GEN"
	binary = "BIN"
	testing = "TST"
end 'LogCategory'

var globalLogLevel = 2

typealias CaptureMessageArray = Array with String
typealias LazyMessage = function() returns String

function joinLines(lines CaptureMessageArray) returns String
	var result = ""
	var first = true
	for line in lines 'join'
		if first 'isFirst'
			result = line
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}\n{line}"
		end 'notFirst'
	end 'join'
	return result
end 'joinLines'

// When true, error messages are appended to capturedErrors instead of only going to stderr.
var capturingErrors = false
var capturedErrors = CaptureMessageArray.create()

export function startCapturingErrors()
	capturingErrors = true
	capturedErrors = CaptureMessageArray.create()
end 'startCapturingErrors'

export function stopCapturingErrors() returns String
	capturingErrors = false
	let result = joinLines(capturedErrors)
	capturedErrors = CaptureMessageArray.create()
	return result
end 'stopCapturingErrors'

export function cancelCapturingErrors()
	capturingErrors = false
	capturedErrors = CaptureMessageArray.create()
end 'cancelCapturingErrors'

// When true, trace messages are appended to capturedTrace instead of going to stderr.
var capturingTrace = false
var capturedTrace = CaptureMessageArray.create()

export function startCapturingTrace()
	capturingTrace = true
	capturedTrace = CaptureMessageArray.create()
end 'startCapturingTrace'

export function stopCapturingTrace() returns String
	capturingTrace = false
	let result = joinLines(capturedTrace)
	capturedTrace = CaptureMessageArray.create()
	return result
end 'stopCapturingTrace'

export function cancelCapturingTrace()
	capturingTrace = false
	capturedTrace = CaptureMessageArray.create()
end 'cancelCapturingTrace'

// Offset by 1 so 0 can mean "unset" without conflicting with LogLevel.NONE (rawValue 0).
// Ranges kept at i64-width because Array with ranged types smaller than i64 has a sizing bug.
typealias StoredLevel = int(0 to u64.max)
typealias CategoryLevelArray = Array with StoredLevel

var categoryLogLevels = CategoryLevelArray.create()
var categoryLevelsInitialized = false

function ensureCategoryLevels()
	if categoryLevelsInitialized 'alreadyDone'
		return
	end 'alreadyDone'
	categoryLevelsInitialized = true
	for _ in 0 upto 8 'fill'
		categoryLogLevels.push(0)
	end 'fill'
end 'ensureCategoryLevels'

function effectiveLogLevel(category LogCategory) returns StoredLevel
	if categoryLevelsInitialized 'hasLevels'
		// Sentinel: 0 = "no category-specific override"; caller falls through to globalLogLevel.
		let stored = try categoryLogLevels.get(category.ordinal) otherwise 0
		if stored > 0 'hasOverride'
			return stored - 1
		end 'hasOverride'
	end 'hasLevels'
	return globalLogLevel
end 'effectiveLogLevel'

export function logError(category LogCategory, message LazyMessage)
	log(category, level: LogLevel.ERROR, message: message)
end 'logError'

export function logInfo(category LogCategory, message LazyMessage)
	log(category, level: LogLevel.INFO, message: message)
end 'logInfo'

export function logDebug(category LogCategory, message LazyMessage)
	log(category, level: LogLevel.DEBUG, message: message)
end 'logDebug'

export function logTrace(category LogCategory, message LazyMessage)
	log(category, level: LogLevel.TRACE, message: message)
end 'logTrace'

export function isLogEnabled(category LogCategory, level LogLevel) returns bool
	return level.rawValue <= effectiveLogLevel(category)
end 'isLogEnabled'

export function setLogLevel(level LogLevel)
	globalLogLevel = level.rawValue
end 'setLogLevel'

export function setCategoryLogLevel(category LogCategory, level LogLevel)
	ensureCategoryLevels()
	try categoryLogLevels.set(category.ordinal, value: level.rawValue + 1) otherwise panic("invariant: categoryLogLevels.set OOB")
end 'setCategoryLogLevel'

// Parses a log option string like "debug" or "lexer:trace".
export function parseLogOption(option String) returns bool
	let parts = option.split(":")
	if parts.count() == 1 'noColon'
		let level = try LogLevel.fromName(option.toUpper()) otherwise return false
		setLogLevel(level)
		return true
	end 'noColon'

	let categoryStr = try parts.get(0) otherwise return false
	var levelStr = try parts.get(1) otherwise return false

	let category = try LogCategory.fromName(categoryStr) otherwise return false

	let level = try LogLevel.fromName(levelStr.toUpper()) otherwise return false

	setCategoryLogLevel(category, level: level)
	return true
end 'parseLogOption'

function log(category LogCategory, level LogLevel, message LazyMessage)
	let effectiveLevel = effectiveLogLevel(category)
	if level.rawValue <= effectiveLevel 'check'
		let msg = message()
		if capturingErrors 'capturing'
			if level.rawValue <= 1 'isError'
				capturedErrors.push(msg)
				return
			end 'isError'
		end 'capturing'
		if capturingTrace 'capTrace'
			if level.rawValue >= LogLevel.DEBUG.rawValue 'isDebugOrTrace'
				if level.rawValue == LogLevel.TRACE.rawValue 'isTrace'
					capturedTrace.push(msg)
				end 'isTrace'
				return
			end 'isDebugOrTrace'
		end 'capTrace'
		printError("[{category.rawValue}] {level.name}: {msg}\n")
	end 'check'
end 'log'

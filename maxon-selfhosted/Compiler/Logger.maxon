// Logging system for the compiler.

export enum LogLevel
    NONE
    ERROR
    INFO
    DEBUG
    TRACE
end 'LogLevel'

export enum LogCategory
    compiler = "CMP"
    lexer = "LEX"
    parser = "PAR"
    semantic = "SEM"
    mlir = "MLR"
    codegen = "GEN"
    pe = "PE "
    testing = "TST"
end 'LogCategory'

var globalLogLevel = 2

export function logError(category LogCategory, message String)
    log(category, level: LogLevel.ERROR, message: message)
end 'logError'

export function logInfo(category LogCategory, message String)
    log(category, level: LogLevel.INFO, message: message)
end 'logInfo'

export function logDebug(category LogCategory, message String)
    log(category, level: LogLevel.DEBUG, message: message)
end 'logDebug'

export function logTrace(category LogCategory, message String)
    log(category, level: LogLevel.TRACE, message: message)
end 'logTrace'

export function setLogLevel(level LogLevel)
    globalLogLevel = level.rawValue
end 'setLogLevel'

// Parses a log option string like "debug" or "lexer:trace".
export function parseLogOption(option String) returns bool
    let level = try LogLevel.fromName(option.toUpper()) otherwise 'badLevel'
        return false
    end 'badLevel'
    setLogLevel(level)
    return true
end 'parseLogOption'

function log(category LogCategory, level LogLevel, message String)
    if level.rawValue <= globalLogLevel 'check'
        printError("[{category.rawValue}] {level.name}: {message}\n")
    end 'check'
end 'log'

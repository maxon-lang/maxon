// Full-featured spec file parser for the self-hosted compiler.
// Parses markdown spec files to extract tests, matching the C# SpecParser behavior.

export typealias TextLineArray = Array with String
export typealias IntArray = Array with ParsedInt

export type SpecFrontmatter
	export var feature as String
	export var status as String
	export var category as String

	export static function create(feature String, status String, category String) returns SpecFrontmatter
		return Self{feature: feature, status: status, category: category}
	end 'create'
end 'SpecFrontmatter'

export type TestExpectation
	export var exitCode as ParsedInt
	export var hasExitCode as bool
	export var stdout as String
	export var hasStdout as bool
	export var compilerStderr as String
	export var hasCompilerStderr as bool
	export var runtimeStderr as String
	export var hasRuntimeStderr as bool
	export var requiredLowering as String
	export var hasRequiredLowering as bool
	// True when the spec defines a RequiredLowering block for any target —
	// even one that doesn't match the current run's target. The runner uses
	// this to flag tests that author RequiredLowering for some targets but
	// silently skip the check on others (a parity gap that lets target-
	// specific lowering changes drift unobserved).
	export var hasAnyRequiredLowering as bool
	export var requiredRdata as String
	export var hasRequiredRdata as bool
	export var requiredData as String
	export var hasRequiredData as bool
	export var mmTrace as bool
	export var asyncTrace as bool
	// When true, the captured CompiledIR snapshot includes stdlib functions
	// reachable from `main` (dceFunctions has already pruned unreachable ones).
	// Opt-in via the `<!-- IncludeStdlibIr -->` spec directive; defaults to
	// false so existing tests are unaffected.
	export var includeStdlibIr as bool
	// True when the spec file contains a top-level `<!-- CacheParity -->`
	// directive. The runner double-compiles every test in such a file —
	// once with the stdlib cache forced off, once with it on — and fails
	// if the captured RequiredLowering or RequiredRdata diverges between
	// legs. Used to surface cache-masked bugs as test failures.
	export var cacheParity as bool

	export static function create() returns TestExpectation
		return Self{exitCode: 0, hasExitCode: false, stdout: "", hasStdout: false, compilerStderr: "", hasCompilerStderr: false, runtimeStderr: "", hasRuntimeStderr: false, requiredLowering: "", hasRequiredLowering: false, hasAnyRequiredLowering: false, requiredRdata: "", hasRequiredRdata: false, requiredData: "", hasRequiredData: false, mmTrace: false, asyncTrace: false, includeStdlibIr: false, cacheParity: false}
	end 'create'
end 'TestExpectation'

export type SourceFilePair
	export var fileName as String
	export var source as String

	export static function create(fileName String, source String) returns SourceFilePair
		return Self{fileName: fileName, source: source}
	end 'create'
end 'SourceFilePair'

export typealias SourceFileArray = Array with SourceFilePair

export type SpecTest
	export var name as String
	export var source as String
	export var expectation as TestExpectation
	export var args as String
	export var sourceFiles as SourceFileArray
	export var hasMultiFile as bool
	export var mmTrace as bool
	export var asyncTrace as bool
	export var includeStdlibIr as bool
	export var cacheParity as bool

	export static function create(name String, source String, expectation TestExpectation, args String, sourceFiles SourceFileArray, hasMultiFile bool, mmTrace bool, asyncTrace bool, includeStdlibIr bool = false, cacheParity bool = false) returns SpecTest
		return Self{name: name, source: source, expectation: expectation, args: args, sourceFiles: sourceFiles, hasMultiFile: hasMultiFile, mmTrace: mmTrace, asyncTrace: asyncTrace, includeStdlibIr: includeStdlibIr, cacheParity: cacheParity}
	end 'create'
end 'SpecTest'

export typealias SpecTestArray = Array with SpecTest

export type SpecFile
	export var filePath as String
	export var frontmatter as SpecFrontmatter
	export var tests as SpecTestArray
end 'SpecFile'

export typealias SpecFileArray = Array with SpecFile

export type Fragment
	export var filePath as String
	export var testName as String
	export var source as String
	export var expectation as TestExpectation
	export var generatedIR as String
	export var hasGeneratedIR as bool
	export var args as String
	export var sourceFiles as SourceFileArray
	export var hasMultiFile as bool
	export var mmTrace as bool
	export var asyncTrace as bool
	export var includeStdlibIr as bool
	export var cacheParity as bool

	export static function create(filePath String, testName String, source String, expectation TestExpectation, generatedIR String, hasGeneratedIR bool, args String, sourceFiles SourceFileArray, hasMultiFile bool, mmTrace bool, asyncTrace bool, includeStdlibIr bool = false, cacheParity bool = false) returns Fragment
		return Self{filePath: filePath, testName: testName, source: source, expectation: expectation, generatedIR: generatedIR, hasGeneratedIR: hasGeneratedIR, args: args, sourceFiles: sourceFiles, hasMultiFile: hasMultiFile, mmTrace: mmTrace, asyncTrace: asyncTrace, includeStdlibIr: includeStdlibIr, cacheParity: cacheParity}
	end 'create'
end 'Fragment'

export type TestResult
	export var testName as String
	export var passed as bool
	export var errorMessage as String
	export var filePath as String
	export var loweringLog as String
	export var compileIr as String

	export static function create(testName String, passed bool, errorMessage String, filePath String, loweringLog String, compileIr String) returns TestResult
		return Self{testName: testName, passed: passed, errorMessage: errorMessage, filePath: filePath, loweringLog: loweringLog, compileIr: compileIr}
	end 'create'
end 'TestResult'

export typealias TestResultArray = Array with TestResult

// Trim leading/trailing whitespace (spaces, tabs, \r, \n) from a string.
export function trimWhitespace(s String) returns String
	var idx = s.startIndex()
	let endIdx = s.endIndex()
	// Skip leading whitespace
	while idx < endIdx 'leading'
		if not Ascii.isWhitespace(s.charAt(idx)) 'notWs'
			break
		end 'notWs'

		idx = try s.indexAfter(idx) otherwise break
	end 'leading'

	let startPos = idx
	// Walk to find last non-whitespace position
	var lastNonWsEnd = idx
	while idx < endIdx 'trailing'
		let nextIdx = try s.indexAfter(idx) otherwise 'lastOne'
			if not Ascii.isWhitespace(s.charAt(idx)) 'notWsLast'
				lastNonWsEnd = endIdx
			end 'notWsLast'
			break
		end 'lastOne'

		if not Ascii.isWhitespace(s.charAt(idx)) 'notWs2'
			lastNonWsEnd = nextIdx
		end 'notWs2'

		idx = nextIdx
	end 'trailing'

	return s.slice(startPos, endIndex: lastNonWsEnd)
end 'trimWhitespace'

// Drop the trailing three bytes (the closing ```) from a line. Callers gate
// this on `line.endsWith("```")` so the underflow case is unreachable.
function stripTrailingFence(line String) returns String
	let bytes = line.toByteArray()
	let n = bytes.count()
	if n <= 3 'allFence'
		return ""
	end 'allFence'
	var head = ByteArray.create()
	for i in 0 upto (n - 3) 'copy'
		let b = try bytes.get(i) otherwise panic("stripTrailingFence: byte get OOB at {i} (n={n})")
		head.push(b)
	end 'copy'
	return String.from(head)
end 'stripTrailingFence'

// Read lines from startLine until a closing ``` is found, joining with newlines.
// A line that *ends* with ``` (e.g. `42```` written without a trailing newline
// before the fence) is treated as the closing fence, with any leading content
// included in the block. Without this, the reader greedily swallows the next
// test's source until it finds a standalone ``` line, mis-attributing the
// neighbour's exitcode/stdout to the malformed test.
export function readCodeBlock(lines TextLineArray, startLine LineNumber, lineCount LineNumber) returns String
	var result = ""
	var first = true
	for i in startLine upto lineCount 'read'
		let line = try lines.get(i) otherwise break
		if line.startsWith("```") 'endBlock'
			break
		end 'endBlock'
		// Trailing-fence form: the closing ``` shares the line with content.
		// Strip the fence and append the content as the block's last line.
		if line.endsWith("```") 'inlineEnd'
			let stripped = stripTrailingFence(line)
			if first 'isFirstInline'
				result = stripped
			end 'isFirstInline' else 'notFirstInline'
				result = "{result}\n{stripped}"
			end 'notFirstInline'
			break
		end 'inlineEnd'
		if first 'isFirst'
			result = line
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}\n{line}"
		end 'notFirst'
	end 'read'
	return result
end 'readCodeBlock'

// Skip past a code block's closing ```.
export function skipCodeBlock(lines TextLineArray, startLine LineNumber, lineCount LineNumber) returns LineNumber
	for i in startLine upto lineCount 'scan'
		let line = try lines.get(i) otherwise break
		if line.startsWith("```") 'endBlock'
			return i + 1
		end 'endBlock'
		if line.endsWith("```") 'inlineEnd'
			// Inline closing fence: this line *is* the last line of the block.
			return i + 1
		end 'inlineEnd'
	end 'scan'
	return lineCount
end 'skipCodeBlock'

// Parse YAML frontmatter from a spec file.
export function parseFrontmatter(content String) returns SpecFrontmatter
	var fm = SpecFrontmatter.create("unknown", status: "unknown", category: "unknown")
	let lines = content.split("\n")
	let lineCount = lines.count()

	// Check for opening ---
	let firstLine = trimWhitespace(try lines.get(0) otherwise "")
	if firstLine != "---" 'noFrontmatter'
		return fm
	end 'noFrontmatter'

	// Scan for closing ---
	for i in 1 upto lineCount 'scan'
		let line = trimWhitespace(try lines.get(i) otherwise "")
		if line == "---" 'endFrontmatter'
			break
		end 'endFrontmatter'

		// Parse "key: value" lines
		let colonIdx = try line.findFirst(": ") otherwise continue
		let key = line.slice(line.startIndex(), endIndex: colonIdx)
		let afterColon = try line.indexAfter(colonIdx) otherwise continue
		let afterSpace = try line.indexAfter(afterColon) otherwise continue
		let value = trimWhitespace(line.slice(afterSpace, endIndex: line.endIndex()))

		if key == "feature" 'isFeature'
			fm.feature = value
		end 'isFeature' else if key == "status" 'isStatus'
			fm.status = value
		end 'isStatus' else if key == "category" 'isCategory'
			fm.category = value
		end 'isCategory'
	end 'scan'

	return fm
end 'parseFrontmatter'

// Split source containing "// --- file: name.maxon" markers into multiple files.
// Returns empty array if no file markers found.
export function splitMultiFileSource(source String) returns SourceFileArray
	var files = SourceFileArray.create()
	let lines = source.split("\n")
	let lineCount = lines.count()

	// First pass: find all marker positions
	var markerLines = IntArray.create()
	var markerNames = TextLineArray.create()

	for i in 0 upto lineCount 'findMarkers'
		let line = try lines.get(i) otherwise panic("invariant: i < lineCount but lines.get failed")
		if line.startsWith("// --- file: ") 'isMarker'
			markerLines.push(i)
			// Extract filename: everything after "// --- file: "
			// Skip "// --- file: " (13 chars) to get filename
			var nameIdx = line.startIndex()
			for _ in 0 upto 13 'skipPrefix'
				nameIdx = try line.indexAfter(nameIdx) otherwise break
			end 'skipPrefix'
			let fileName = trimWhitespace(line.slice(nameIdx, endIndex: line.endIndex()))
			markerNames.push(fileName)
		end 'isMarker'
	end 'findMarkers'

	if markerLines.count() == 0 'noMarkers'
		return files
	end 'noMarkers'

	// Second pass: extract source between markers
	for m in 0 upto markerLines.count() 'extractFiles'
		let startLine = (try markerLines.get(m) otherwise panic("extractFiles: m < markerLines.count() but get({m}) failed")) + 1
		// Sentinel: m+1 may be past the last marker; default lineCount means "to end of file".
		let endLine = try markerLines.get(m + 1) otherwise lineCount
		let fileName = try markerNames.get(m) otherwise panic("extractFiles: markerNames kept parallel to markerLines but get({m}) failed (markerNames.count={markerNames.count()}, markerLines.count={markerLines.count()})")

		var fileSource = ""
		var first = true
		for i in startLine upto endLine 'buildSource'
			let line = try lines.get(i) otherwise panic("invariant: i < lineCount but lines.get failed")
			if first 'isFirst'
				fileSource = line
				first = false
			end 'isFirst' else 'notFirst'
				fileSource = "{fileSource}\n{line}"
			end 'notFirst'
		end 'buildSource'

		let pair = SourceFilePair.create(fileName, source: trimWhitespace(fileSource))
		files.push(pair)
	end 'extractFiles'

	return files
end 'splitMultiFileSource'

// Parse a spec file and extract all tests.
export function parseSpecFile(content String, targetKey String) returns SpecTestArray
	var tests = SpecTestArray.create()
	let lines = content.split("\n")
	var i = 0
	let lineCount = lines.count()

	// Find the ## Tests section (skip ## Documentation). While scanning, also
	// look for the file-level `<!-- CacheParity -->` directive so it can be
	// stamped on every test produced from this file.
	var inTestsSection = false
	var testsStartLine = 0
	var fileCacheParity = false

	while i < lineCount 'findTests'
		let line = try lines.get(i) otherwise 'skip'
			i = i + 1
			continue
		end 'skip'

		if line.contains("<!-- CacheParity") 'isCacheParity'
			fileCacheParity = true
		end 'isCacheParity'

		if line.startsWith("## Tests") 'foundTests'
			inTestsSection = true
			testsStartLine = i + 1
			i = i + 1
			break
		end 'foundTests'

		// If we hit a test marker before ## Tests, just start parsing from here
		if line.contains("<!-- test:") 'earlyTest'
			inTestsSection = true
			testsStartLine = i
			break
		end 'earlyTest'

		if line.contains("<!-- disabled-test:") 'earlyDisabled'
			inTestsSection = true
			testsStartLine = i
			break
		end 'earlyDisabled'

		i = i + 1
	end 'findTests'

	if not inTestsSection 'noTests'
		// Try extracting doc examples even without a Tests section
		let docTests = extractDocExamples(content)
		return docTests
	end 'noTests'

	i = testsStartLine

	while i < lineCount 'scan'
		let line = try lines.get(i) otherwise 'skipScan'
			i = i + 1
			continue
		end 'skipScan'

		// Check for disabled test marker (acts as boundary only)
		if line.contains("<!-- disabled-test:") 'isDisabled'
			i = i + 1
			// Skip until next test marker
			while i < lineCount 'skipDisabled'
				let dLine = try lines.get(i) otherwise 'skipD'
					i = i + 1
					continue
				end 'skipD'
				if dLine.contains("<!-- test:") 'nextActive'
					break
				end 'nextActive'
				if dLine.contains("<!-- disabled-test:") 'nextDisabled'
					break
				end 'nextDisabled'
				i = i + 1
			end 'skipDisabled'
			continue
		end 'isDisabled'

		// Check for active test marker
		if line.contains("<!-- test:") 'isTestMarker'
			// Extract test name between "<!-- test: " and " -->"
			let nameStart = try line.findFirst(": ") otherwise 'skipMarker'
				i = i + 1
				continue
			end 'skipMarker'
			let nameStartIdx = try line.indexAfter(nameStart) otherwise 'skipMarker2'
				i = i + 1
				continue
			end 'skipMarker2'
			let nameStartIdx2 = try line.indexAfter(nameStartIdx) otherwise 'skipMarker3'
				i = i + 1
				continue
			end 'skipMarker3'
			let nameEnd = try line.findFirst(" -->") otherwise 'skipMarker4'
				i = i + 1
				continue
			end 'skipMarker4'
			let testName = line.slice(nameStartIdx2, endIndex: nameEnd)

			// Scan for directives and code blocks after this marker
			var source = ""
			var expectation = TestExpectation.create()
			var testArgs = ""
			var testMmTrace = false
			var testAsyncTrace = false
			var testIncludeStdlibIr = false
			i = i + 1

			while i < lineCount 'blocks'
				let blockLine = try lines.get(i) otherwise 'skipBlock'
					i = i + 1
					continue
				end 'skipBlock'

				// Hit next test marker (active or disabled) — stop
				if blockLine.contains("<!-- test:") 'nextTest'
					break
				end 'nextTest'
				if blockLine.contains("<!-- disabled-test:") 'nextDisabledTest'
					break
				end 'nextDisabledTest'

				// Parse Args directive
				if blockLine.contains("<!-- Args:") 'isArgs'
					// Skip past "Args: " (6 chars)
					var argsIdx = try blockLine.findFirst("Args: ") otherwise 'skipArgs'
						i = i + 1
						continue
					end 'skipArgs'
					for _ in 0 upto 6 'skipPrefix'
						argsIdx = try blockLine.indexAfter(argsIdx) otherwise 'skipArgs2'
							i = i + 1
							continue
						end 'skipArgs2'
					end 'skipPrefix'
					let argsEnd = try blockLine.findFirst(" -->") otherwise 'skipArgs3'
						i = i + 1
						continue
					end 'skipArgs3'
					testArgs = blockLine.slice(argsIdx, endIndex: argsEnd)
					i = i + 1
					continue
				end 'isArgs'

				// Parse MmTrace directive
				if blockLine.contains("<!-- MmTrace") 'isMmTrace'
					testMmTrace = true
					i = i + 1
					continue
				end 'isMmTrace'

				// Parse AsyncTrace directive
				if blockLine.contains("<!-- AsyncTrace") 'isAsyncTrace'
					testAsyncTrace = true
					i = i + 1
					continue
				end 'isAsyncTrace'

				// Parse IncludeStdlibIr directive — opt-in for surfacing stdlib
				// function bodies inside the CompiledIR snapshot. Reachable-only
				// (dceFunctions has already pruned unused stdlib functions by
				// the time the IR is rendered).
				if blockLine.contains("<!-- IncludeStdlibIr") 'isIncludeStdlibIr'
					testIncludeStdlibIr = true
					i = i + 1
					continue
				end 'isIncludeStdlibIr'

				// Recognize SelfhostedOnly directive — the C# runner uses this
				// to skip tests that exercise self-hosted-only diagnostics
				// (e.g. E3095). Self-hosted runs the test normally; here we
				// just consume the directive line so it isn't treated as
				// stray content.
				if blockLine.contains("<!-- SelfhostedOnly") 'isSelfhostedOnly'
					i = i + 1
					continue
				end 'isSelfhostedOnly'

				// Check maxoncstderr before maxon since "```maxoncstderr" also startsWith "```maxon"
				if blockLine.startsWith("```maxoncstderr") 'isCompilerStderr'
					i = i + 1
					let stderrBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					expectation.compilerStderr = stderrBlock
					expectation.hasCompilerStderr = true
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					continue
				end 'isCompilerStderr'

				if blockLine.startsWith("```maxon") 'isMaxon'
					if source.isEmpty() 'firstMaxonBlock'
						i = i + 1
						source = readCodeBlock(lines, startLine: i, lineCount: lineCount)
						i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					end 'firstMaxonBlock' else 'duplicateMaxonBlock'
						panic("Spec parser: test '{testName}' has multiple maxon blocks. Each code block should be a separate test with its own <!-- test: name --> marker.")
					end 'duplicateMaxonBlock'
					continue
				end 'isMaxon'

				if blockLine.startsWith("```stderr") 'isRuntimeStderr'
					i = i + 1
					let runtimeStderrBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					expectation.runtimeStderr = runtimeStderrBlock
					expectation.hasRuntimeStderr = true
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					continue
				end 'isRuntimeStderr'

				if blockLine.startsWith("```exitcode") 'isExitCode'
					i = i + 1
					let ecStr = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					let ecVal = try int.fromString(trimWhitespace(ecStr)) otherwise continue
					expectation.exitCode = ecVal
					expectation.hasExitCode = true
					continue
				end 'isExitCode'

				if blockLine.startsWith("```stdout") 'isStdout'
					i = i + 1
					let stdoutBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					expectation.stdout = stdoutBlock
					expectation.hasStdout = true
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					continue
				end 'isStdout'

				// Skip RequiredIR blocks (handled by C# compiler only)
				if blockLine.startsWith("```RequiredIR") 'isIR'
					i = skipCodeBlock(lines, startLine: i + 1, lineCount: lineCount)
					continue
				end 'isIR'

				// RequiredLowering — always target-qualified, no unqualified fallback
				if not targetKey.isEmpty() 'hasTargetKeyLowering'
					if blockLine.startsWith("```RequiredLowering:{targetKey}") 'isTargetLowering'
						i = i + 1
						let loweringBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
						expectation.requiredLowering = loweringBlock
						expectation.hasRequiredLowering = true
						expectation.hasAnyRequiredLowering = true
						i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
						continue
					end 'isTargetLowering'
				end 'hasTargetKeyLowering'

				// Skip non-matching RequiredLowering blocks, but record that
				// the test authored a lowering block for *some* target — the
				// runner uses this to flag tests that have a check on one
				// platform but silently pass on another (parity drift).
				if blockLine.startsWith("```RequiredLowering") 'isOtherLowering'
					expectation.hasAnyRequiredLowering = true
					i = skipCodeBlock(lines, startLine: i + 1, lineCount: lineCount)
					continue
				end 'isOtherLowering'

				if blockLine.startsWith("```RequiredRdata") 'isRdata'
					i = i + 1
					let rdataBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					expectation.requiredRdata = rdataBlock
					expectation.hasRequiredRdata = true
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					continue
				end 'isRdata'

				if blockLine.startsWith("```RequiredData") 'isData'
					i = i + 1
					let dataBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
					expectation.requiredData = dataBlock
					expectation.hasRequiredData = true
					i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
					continue
				end 'isData'

				i = i + 1
			end 'blocks'

			// Only add test if we found source code
			if not source.isEmpty() 'hasSource'
				expectation.mmTrace = testMmTrace
				expectation.asyncTrace = testAsyncTrace
				expectation.includeStdlibIr = testIncludeStdlibIr
				expectation.cacheParity = fileCacheParity

				// Split multi-file source
				let sourceFiles = splitMultiFileSource(source)
				let hasMulti = sourceFiles.count() > 0

				let test = SpecTest.create(testName, source: source, expectation: expectation, args: testArgs, sourceFiles: sourceFiles, hasMultiFile: hasMulti, mmTrace: testMmTrace, asyncTrace: testAsyncTrace, includeStdlibIr: testIncludeStdlibIr, cacheParity: fileCacheParity)
				tests.push(test)
			end 'hasSource'
			continue
		end 'isTestMarker'

		i = i + 1
	end 'scan'

	// Also extract documentation examples
	let docTests = extractDocExamples(content)
	for docTest in docTests 'addDocs'
		tests.push(docTest)
	end 'addDocs'

	return tests
end 'parseSpecFile'

// Extract executable examples from the ## Documentation section.
export function extractDocExamples(content String) returns SpecTestArray
	var tests = SpecTestArray.create()
	let lines = content.split("\n")
	let lineCount = lines.count()

	// Find ## Documentation section
	var docStart = -1
	var docEnd = lines.count()
	for i in 0 upto lineCount 'findDoc'
		let line = try lines.get(i) otherwise panic("invariant: i < lineCount but lines.get failed")
		if line.startsWith("## Documentation") 'foundDoc'
			docStart = i + 1
		end 'foundDoc' else if docStart >= 0 'afterDoc'
			if line.startsWith("## Tests") 'foundTests'
				docEnd = i
				break
			end 'foundTests'
		end 'afterDoc'
	end 'findDoc'

	if docStart < 0 'noDoc'
		return tests
	end 'noDoc'

	var exampleIndex = 0
	var i = docStart

	while i < docEnd 'scanDoc'
		let line = try lines.get(i) otherwise 'skipLine'
			i = i + 1
			continue
		end 'skipLine'

		if line.startsWith("```maxon") 'isMaxonBlock'
			i = i + 1
			let code = readCodeBlock(lines, startLine: i, lineCount: docEnd)
			let blockEndLine = skipCodeBlock(lines, startLine: i, lineCount: docEnd)

			// Only include examples with main function
			if code.contains("function main()") 'hasMain'
				exampleIndex = exampleIndex + 1
				let testName = "docs-example-{exampleIndex}"

				var expectation = TestExpectation.create()

				// Check for maxoncstderr block immediately after
				let nextLine = try lines.get(blockEndLine) otherwise panic("docs-example: blockEndLine < docEnd <= lines.count() but get({blockEndLine}) failed")
				if nextLine.startsWith("```maxoncstderr") 'hasCompilerErr'
					let stderrBlock = readCodeBlock(lines, startLine: blockEndLine + 1, lineCount: docEnd)
					expectation.compilerStderr = stderrBlock
					expectation.hasCompilerStderr = true
				end 'hasCompilerErr' else if nextLine.startsWith("```exitcode") 'hasExitCode'
					let ecStr = readCodeBlock(lines, startLine: blockEndLine + 1, lineCount: docEnd)
					let ecVal = try int.fromString(trimWhitespace(ecStr)) otherwise continue
					expectation.exitCode = ecVal
					expectation.hasExitCode = true
				end 'hasExitCode' else 'defaultExitCode'
					// Default: expect exit code 0
					expectation.exitCode = 0
					expectation.hasExitCode = true
				end 'defaultExitCode'

				let test = SpecTest.create(testName, source: code, expectation: expectation, args: "", sourceFiles: SourceFileArray.create(), hasMultiFile: false, mmTrace: false, asyncTrace: false)
				tests.push(test)
			end 'hasMain'

			i = blockEndLine
			continue
		end 'isMaxonBlock'

		i = i + 1
	end 'scanDoc'

	return tests
end 'extractDocExamples'

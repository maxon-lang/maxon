// Spec test runner for the self-hosted compiler.
// Parses spec files and compiles tests using the self-hosted compiler.

// Whitelisted specs to run (only specs the self-hosted compiler cares about).
// IMPORTANT: must be local to avoid module-level array iterator persistence across calls.
let SPEC_WHITELIST_BASICS = "basics"
let SPEC_WHITELIST_PRINT = "print-function"
let SPEC_WHITELIST_VARS = "variables"
let SPEC_WHITELIST_ARITHMETIC = "arithmetic"
let SPEC_WHITELIST_ARITHMETIC_OPS = "arithmetic-operators"
let SPEC_WHITELIST_COMPARISON_OPS = "comparison-operators"
let SPEC_WHITELIST_BITWISE_OPS = "bitwise-operators"
let SPEC_WHITELIST_UNARY_OPS = "unary-operators"
let SPEC_WHITELIST_UNARY_NEG = "unary-negation"
let SPEC_WHITELIST_EXPRESSIONS = "expressions"
let SPEC_WHITELIST_LITERALS = "literals"
let SPEC_WHITELIST_PARENTHESES = "parentheses"
let SPEC_WHITELIST_BOOL_TYPE = "bool-type"
let SPEC_WHITELIST_CONTEXTUAL_TYPING = "contextual-literal-typing"
let SPEC_WHITELIST_BLOCK_SCOPING = "block-scoping"

// Trim leading/trailing whitespace (spaces, tabs, \r, \n) from a string.
function trimWhitespace(s String) returns String
  // Walk string with charAt + indexAfter to find trim boundaries
  var idx = s.startIndex()
  let endIdx = s.endIndex()
  // Skip leading whitespace
  while idx < endIdx 'leading'
    var cp = s.charAt(idx)
    var isCpWs = false
    for b in cp.bytes() 'checkByte'
      if b == ' ' 'sp'
        isCpWs = true
      end 'sp' else if b == '\n' 'lf'
        isCpWs = true
      end 'lf' else if b == '\r' 'cr'
        isCpWs = true
      end 'cr' else if b == '\t' 'tab'
        isCpWs = true
      end 'tab'
    end 'checkByte'
    if not isCpWs 'notWs'
      break
    end 'notWs'
    idx = try s.indexAfter(idx) otherwise 'done'
      break
    end 'done'
  end 'leading'
  var startPos = idx
  // Walk to find last non-whitespace position
  var lastNonWsEnd = idx
  while idx < endIdx 'trailing'
    var cp = s.charAt(idx)
    let nextIdx = try s.indexAfter(idx) otherwise 'lastOne'
      var isWs = false
      for b in cp.bytes() 'checkByte2'
        if b == ' ' 'sp2'
          isWs = true
        end 'sp2' else if b == '\n' 'lf2'
          isWs = true
        end 'lf2' else if b == '\r' 'cr2'
          isWs = true
        end 'cr2' else if b == '\t' 'tab2'
          isWs = true
        end 'tab2'
      end 'checkByte2'
      if not isWs 'notWs2'
        lastNonWsEnd = endIdx
      end 'notWs2'
      break
    end 'lastOne'
    var isWs2 = false
    for b in cp.bytes() 'checkByte3'
      if b == ' ' 'sp3'
        isWs2 = true
      end 'sp3' else if b == '\n' 'lf3'
        isWs2 = true
      end 'lf3' else if b == '\r' 'cr3'
        isWs2 = true
      end 'cr3' else if b == '\t' 'tab3'
        isWs2 = true
      end 'tab3'
    end 'checkByte3'
    if not isWs2 'notWs3'
      lastNonWsEnd = nextIdx
    end 'notWs3'
    idx = nextIdx
  end 'trailing'
  return s.slice(startPos, endIndex: lastNonWsEnd)
end 'trimWhitespace'

// Simple string-to-integer parser.
function parseInteger(s String) returns ParsedInt throws CompileError
  var result = 0
  var negative = false
  for (i, cp) in s.codepoints().enumerated() 'chars'
    if cp == '-' 'minus'
      if i == 0 'first'
        negative = true
        continue
      end 'first'

      throw CompileError.readError
    end 'minus'

    if cp >= '0' and cp <= '9' 'digit'
      result = result * 10 + cp - '0'
      continue
    end 'digit'

    throw CompileError.readError
  end 'chars'
  if negative 'neg'
    return 0 - result
  end 'neg'
  return result
end 'parseInteger'

type TestExpectation
  export var exitCode ParsedInt
  export var hasExitCode bool
  export var stdout String
  export var hasStdout bool
  export var stderr String
  export var hasStderr bool
  export var runtimeStderr String
  export var hasRuntimeStderr bool
end 'TestExpectation'

type SpecTest
  export var name String
  export var source String
  export var expectation TestExpectation
  export var args String
end 'SpecTest'

typealias SpecTestArray = Array with SpecTest

// Find the project root by walking up from cwd looking for a specs/ directory.
function findProjectRoot() returns String throws CompileError
  var dir = Directory.currentDirectory()
  for _ in 0 upto 10 'search'
    let specsPath = "{dir}/specs"
    if Directory.exists(specsPath) 'found'
      return dir
    end 'found'
    // Go up one level
    let lastSlash = try dir.findLast("/") otherwise 'tryBackslash'
      let lastBs = try dir.findLast("\\") otherwise 'noParent'
        throw CompileError.directoryNotFound
      end 'noParent'
      dir = dir.slice(dir.startIndex(), endIndex: lastBs)
      continue
    end 'tryBackslash'
    dir = dir.slice(dir.startIndex(), endIndex: lastSlash)
  end 'search'
  throw CompileError.directoryNotFound
end 'findProjectRoot'

// Split a string by newlines into an array of lines.
function splitLines(text String) returns StringArray
  var lines = StringArray{}
  var remaining = text
  while not remaining.isEmpty() 'scan'
    let nlPos = try remaining.findFirst("\n") otherwise 'lastLine'
      lines.push(remaining)
      break
    end 'lastLine'
    lines.push(remaining.slice(remaining.startIndex(), endIndex: nlPos))
    let nextIdx = try remaining.indexAfter(nlPos) otherwise 'done'
      break
    end 'done'
    remaining = remaining.slice(nextIdx, endIndex: remaining.endIndex())
  end 'scan'
  return lines
end 'splitLines'

// Parse a spec file and extract tests.
function parseSpecFile(content String, specName String) returns SpecTestArray
  var tests = SpecTestArray{}
  let lines = splitLines(content)
  var i = 0
  let lineCount = lines.count()

  while i < lineCount 'scan'
    let line = try lines.get(i) otherwise 'skip'
      i = i + 1
      continue
    end 'skip'
    let containsResult = line.contains("<!-- test:")

    // Look for test markers: <!-- test: name -->
    if containsResult 'isTestMarker'
      try line.findFirst("<!-- test:") otherwise 'skipMarker'
        i = i + 1
        continue
      end 'skipMarker'
      // Extract test name between "<!-- test: " and " -->"
      let nameStart = try line.findFirst(": ") otherwise 'skipMarker2'
        i = i + 1
        continue
      end 'skipMarker2'
      let nameStartIdx = try line.indexAfter(nameStart) otherwise 'skipMarker3'
        i = i + 1
        continue
      end 'skipMarker3'
      let nameStartIdx2 = try line.indexAfter(nameStartIdx) otherwise 'skipMarker4'
        i = i + 1
        continue
      end 'skipMarker4'
      let nameEnd = try line.findFirst(" -->") otherwise 'skipMarker5'
        i = i + 1
        continue
      end 'skipMarker5'
      let testName = line.slice(nameStartIdx2, endIndex: nameEnd)

      // Now scan for code blocks after this marker
      var source = ""
      var expectation = TestExpectation{}
      var testArgs = ""
      i = i + 1

      while i < lineCount 'blocks'
        let blockLine = try lines.get(i) otherwise 'skipBlock'
          i = i + 1
          continue
        end 'skipBlock'

        if blockLine.contains("<!-- test:") 'nextTest'
          // Hit next test marker, stop parsing this test
          break
        end 'nextTest'

        if blockLine.contains("<!-- Args:") 'isArgs'
          // Extract args value between "Args: " and " -->"
          let argsStart = try blockLine.findFirst("Args: ") otherwise 'skipArgs'
            i = i + 1
            continue
          end 'skipArgs'
          // Skip past "Args: " (6 chars)
          var argsIdx = argsStart
          for _ in 0 upto 6 'skipPrefix'
            argsIdx = try blockLine.indexAfter(argsIdx) otherwise 'skipArgs2'
              i = i + 1
              continue
            end 'skipArgs2'
          end 'skipPrefix'
          let argsEnd = try blockLine.findFirst(" -->") otherwise 'skipArgs3'
            i = i + 1
            continue
          end 'skipArgs3'
          testArgs = blockLine.slice(argsIdx, endIndex: argsEnd)
          i = i + 1
          continue
        end 'isArgs'

        // Check maxoncstderr before maxon since "```maxoncstderr" also startsWith "```maxon"
        if blockLine.startsWith("```maxoncstderr") 'isStderr'
          i = i + 1
          let stderrBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
          expectation.stderr = stderrBlock
          expectation.hasStderr = true
          i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
          continue
        end 'isStderr'

        if blockLine.startsWith("```maxon") 'isMaxon'
          i = i + 1
          source = readCodeBlock(lines, startLine: i, lineCount: lineCount)
          i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
          continue
        end 'isMaxon'

        if blockLine.startsWith("```stderr") 'isRuntimeStderr'
          i = i + 1
          let runtimeStderrBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
          expectation.runtimeStderr = runtimeStderrBlock
          expectation.hasRuntimeStderr = true
          i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
          continue
        end 'isRuntimeStderr'

        if blockLine.startsWith("```exitcode") 'isExitCode'
          i = i + 1
          let ecStr = readCodeBlock(lines, startLine: i, lineCount: lineCount)
          i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
          let ecVal = try parseInteger(trimWhitespace(ecStr)) otherwise 'badEc'
            continue
          end 'badEc'
          expectation.exitCode = ecVal
          expectation.hasExitCode = true
          continue
        end 'isExitCode'

        if blockLine.startsWith("```stdout") 'isStdout'
          i = i + 1
          let stdoutBlock = readCodeBlock(lines, startLine: i, lineCount: lineCount)
          expectation.stdout = stdoutBlock
          expectation.hasStdout = true
          i = skipCodeBlock(lines, startLine: i, lineCount: lineCount)
          continue
        end 'isStdout'

        i = i + 1
      end 'blocks'

      if not source.isEmpty() 'hasSource'
        var test = SpecTest{}
        test.name = "{specName}/{testName}"
        test.source = source
        test.expectation = expectation
        test.args = testArgs
        tests.push(test)
      end 'hasSource'
      continue
    end 'isTestMarker'

    i = i + 1
  end 'scan'

  return tests
end 'parseSpecFile'

// Read lines from startLine until a closing ``` is found, joining with newlines.
function readCodeBlock(lines StringArray, startLine LineNumber, lineCount LineNumber) returns String
  var result = ""
  var first = true
  for i in startLine upto lineCount 'read'
    let line = try lines.get(i) otherwise 'done'
      break
    end 'done'
    if line.startsWith("```") 'endBlock'
      break
    end 'endBlock'
    if first 'isFirst'
      result = line
      first = false
    end 'isFirst' else 'notFirst'
      result = "{result}\n{line}"
    end 'notFirst'
  end 'read'
  return result
end 'readCodeBlock'

// Skip past a code block's closing ```.
function skipCodeBlock(lines StringArray, startLine LineNumber, lineCount LineNumber) returns LineNumber
  for i in startLine upto lineCount 'scan'
    let line = try lines.get(i) otherwise 'done'
      break
    end 'done'
    if line.startsWith("```") 'endBlock'
      return i + 1
    end 'endBlock'
  end 'scan'
  return lineCount
end 'skipCodeBlock'


// Check if a target matches the host (x86_64-windows-msvc).
function isHostTarget(target TargetTriple) returns bool
  let host = detectHostTriple()
  let targetStr = tripleToString(target)
  let hostStr = tripleToString(host)
  return targetStr == hostStr
end 'isHostTarget'

// Check if we can execute binaries for this target.
// Host target runs natively, Linux targets run via Docker.
// Non-host Windows targets (e.g. aarch64-windows) are compile-only.
function canExecuteTarget(target TargetTriple) returns bool
  if isHostTarget(target) 'isHost'
    return true
  end 'isHost'
  match target.os 'checkOs'
    Os.linux then return true
    Os.windows then return false
  end 'checkOs'
end 'canExecuteTarget'

// Build the command to run a compiled binary.
// Host targets run directly; Linux targets run via Docker.
function buildRunCommand(outputPath String, target TargetTriple, projectRoot String, testArgs String) returns String
  if isHostTarget(target) 'isHost'
    if not testArgs.isEmpty() 'hasArgs'
      return "{outputPath} {testArgs}"
    end 'hasArgs'
    return outputPath
  end 'isHost'

  // Docker execution for Linux targets
  var dockerArch = "amd64"
  match target.cpu 'pickArch'
    CpuArch.x86_64 then dockerArch = "amd64"
    CpuArch.aarch64 then dockerArch = "arm64"
  end 'pickArch'

  // Convert Windows path to forward slashes for Docker volume mount
  let tempDir = "{projectRoot}/temp"
  var dockerCmd = "docker run --rm --platform linux/{dockerArch} -v {tempDir}:/work alpine /work/spectest_temp"
  if not testArgs.isEmpty() 'hasDockerArgs'
    dockerCmd = "docker run --rm --platform linux/{dockerArch} -v {tempDir}:/work alpine /work/spectest_temp {testArgs}"
  end 'hasDockerArgs'
  return dockerCmd
end 'buildRunCommand'

// Run all whitelisted spec tests for a specific target. Returns (passed, failed).
export function runAllSpecTests(filter String, target TargetTriple) returns ExitCode
  let root = try findProjectRoot() otherwise 'noRoot'
    logError(LogCategory.testing, message: "Could not find project root (no specs/ directory found)")
    return 1
  end 'noRoot'

  var totalPassed = 0
  var totalFailed = 0
  var totalTests = 0

  // Local array avoids module-level iterator persistence across calls
  let whitelist = [SPEC_WHITELIST_BASICS, SPEC_WHITELIST_PRINT, SPEC_WHITELIST_VARS]

  for specName in whitelist 'eachSpec'
    let specPath = "{root}/specs/{specName}.md"
    let content = try File.readText(specPath) otherwise 'readErr'
      logError(LogCategory.testing, message: "Could not read spec: {specPath}")
      continue
    end 'readErr'

    let tests = parseSpecFile(content, specName: specName)

    for test in tests 'eachTest'
      // Apply filter
      if not filter.isEmpty() 'hasFilter'
        if not test.name.contains(filter) 'noMatch'
          continue
        end 'noMatch'
      end 'hasFilter'

      totalTests = totalTests + 1
      let passed = runSingleTest(test, projectRoot: root, target: target)
      if passed 'pass'
        totalPassed = totalPassed + 1
      end 'pass' else 'fail'
        totalFailed = totalFailed + 1
      end 'fail'
    end 'eachTest'
  end 'eachSpec'

  if totalTests == 0 'noTests'
    logInfo(LogCategory.testing, message: "No tests found")
    return 0
  end 'noTests'

  if totalFailed == 0 'allPass'
    logInfo(LogCategory.testing, message: "Tests: {totalPassed} passed (total: {totalTests})")
  end 'allPass' else 'someFail'
    logInfo(LogCategory.testing, message: "Tests: {totalPassed} passed, {totalFailed} failed (total: {totalTests})")
  end 'someFail'

  if totalFailed > 0 'hasFail'
    return 1
  end 'hasFail'
  return 0
end 'runAllSpecTests'

// Run a single test. Returns true if passed.
function runSingleTest(test SpecTest, projectRoot String, target TargetTriple) returns bool
  let tempDir = "{projectRoot}/temp"
  let tempSource = "{tempDir}/spectest_temp.maxon"
  let ext = executableExtension(target)
  let tempExe = "{tempDir}/spectest_temp{ext}"

  // Prepend "// Test:" header so line numbers match the spec fragment files
  let sourceWithHeader = "// Test: {test.name}\n{test.source}"
  // Write source to temp file
  try File.writeText(tempSource, content: sourceWithHeader) otherwise 'writeErr'
    logError(LogCategory.testing, message: "[FAIL] {test.name} - could not write temp file")
    return false
  end 'writeErr'

  // Compile using the self-hosted compiler, capturing any error output
  startCapturingErrors()
  let outputPath = try compile(tempSource, target: target) otherwise 'compileFailed'
    let capturedErrors = stopCapturingErrors()

    if test.expectation.hasStderr 'expectedError'
      // Compilation failed as expected — validate the error message
      let expectedStderr = normalizeStderr(test.expectation.stderr)
      let actualStderr = normalizeStderr(capturedErrors)
      if actualStderr != expectedStderr 'stderrMismatch'
        logError(LogCategory.testing, message: "[FAIL] {test.name}")
        logError(LogCategory.testing, message: "  Expected stderr: {expectedStderr}")
        logError(LogCategory.testing, message: "  Actual stderr:   {actualStderr}")
        cleanup(tempSource, tempExe: tempExe)
        return false
      end 'stderrMismatch'
      logDebug(LogCategory.testing, message: "[PASS] {test.name}")
      cleanup(tempSource, tempExe: tempExe)
      return true
    end 'expectedError'

    logError(LogCategory.testing, message: "[FAIL] {test.name}")
    logError(LogCategory.testing, message: "  Compilation failed unexpectedly: {capturedErrors}")
    cleanup(tempSource, tempExe: tempExe)
    return false
  end 'compileFailed'
  cancelCapturingErrors()

  if test.expectation.hasStderr 'isCompilerError'
    // Expected a compiler error but compilation succeeded
    logError(LogCategory.testing, message: "[FAIL] {test.name}")
    logError(LogCategory.testing, message: "  Expected compilation error but compilation succeeded")
    cleanup(tempSource, tempExe: tempExe)
    return false
  end 'isCompilerError'

  // For targets we can't execute (e.g. aarch64-windows), compilation success is the test
  if not canExecuteTarget(target) 'compileOnly'
    logDebug(LogCategory.testing, message: "[PASS] {test.name} (compile-only)")
    cleanup(tempSource, tempExe: tempExe)
    return true
  end 'compileOnly'

  // Run the compiled executable
  let runCommand = buildRunCommand(outputPath, target: target, projectRoot: projectRoot, testArgs: test.args)
  let runCap = Process.captureStart(runCommand)
  let runStdout = Process.captureStdout(runCap)
  let runStderr = Process.captureStderr(runCap)
  let runEc = Process.captureWait(runCap, timeoutMs: 30000)

  var passed = true

  // Check exit code
  if test.expectation.hasExitCode 'checkEc'
    if runEc != test.expectation.exitCode 'ecMismatch'
      logError(LogCategory.testing, message: "[FAIL] {test.name}")
      logError(LogCategory.testing, message: "  Expected exit code {test.expectation.exitCode}, got {runEc}")
      passed = false
    end 'ecMismatch'
  end 'checkEc'

  // Check stdout
  if test.expectation.hasStdout 'checkStdout'
    let expectedOut = trimWhitespace(test.expectation.stdout)
    let actualOut = trimWhitespace(runStdout)
    if actualOut != expectedOut 'stdoutMismatch'
      if passed 'firstFail'
        logError(LogCategory.testing, message: "[FAIL] {test.name}")
      end 'firstFail'
      logError(LogCategory.testing, message: "  Expected stdout: {expectedOut}")
      logError(LogCategory.testing, message: "  Actual stdout:   {actualOut}")
      passed = false
    end 'stdoutMismatch'
  end 'checkStdout'

  // Check runtime stderr
  if test.expectation.hasRuntimeStderr 'checkStderr'
    let expectedErr = trimWhitespace(test.expectation.runtimeStderr)
    let actualErr = trimWhitespace(runStderr)
    if actualErr != expectedErr 'stderrMismatch'
      if passed 'firstFailStderr'
        logError(LogCategory.testing, message: "[FAIL] {test.name}")
      end 'firstFailStderr'
      logError(LogCategory.testing, message: "  Expected stderr: {expectedErr}")
      logError(LogCategory.testing, message: "  Actual stderr:   {actualErr}")
      passed = false
    end 'stderrMismatch'
  end 'checkStderr'

  if passed 'didPass'
    logDebug(LogCategory.testing, message: "[PASS] {test.name}")
  end 'didPass'

  cleanup(tempSource, tempExe: tempExe)
  return passed
end 'runSingleTest'

// Normalize stderr for comparison: trim, CRLF→LF, backslash→forward slash,
// and strip file paths from error messages so temp paths match fragment paths.
function normalizeStderr(s String) returns String
  var result = trimWhitespace(s)
  result = result.replace("\r\n", with: "\n")
  result = result.replace("\\", with: "/")
  // Strip file paths from error lines: "error EXXXX: /path/file:L:C: msg" → "error EXXXX: msg"
  let errorLines = splitLines(result)
  var normalized = ""
  var first = true
  for errLine in errorLines 'eachLine'
    let stripped = stripFilePathFromError(errLine)
    if first 'isFirst'
      normalized = stripped
      first = false
    end 'isFirst' else 'notFirst'
      normalized = "{normalized}\n{stripped}"
    end 'notFirst'
  end 'eachLine'
  return normalized
end 'normalizeStderr'

// Strip file path from an error line.
// Input:  "error E2010: /some/path/file.maxon:3:8: Expected '=' but got ':'"
// Output: "error E2010: Expected '=' but got ':'"
function stripFilePathFromError(line String) returns String
  // Look for "error E" prefix
  if not line.contains("error E") 'notError'
    return line
  end 'notError'
  // Find the first ": " after "error E" — this starts the file path or message
  try line.findFirst("error E") otherwise 'noE'
    return line
  end 'noE'
  // Find the ": " after the error code (e.g., after "error E2010")
  let firstColon = try line.findFirst(": ") otherwise 'noColon'
    return line
  end 'noColon'
  let afterFirstColon = try line.indexAfter(firstColon) otherwise 'noAfter'
    return line
  end 'noAfter'
  let afterFirstColonSpace = try line.indexAfter(afterFirstColon) otherwise 'noAfter2'
    return line
  end 'noAfter2'
  // The rest could be "filepath:line:col: message" or just "message"
  let rest = line.slice(afterFirstColonSpace, endIndex: line.endIndex())
  // Check if rest looks like a file path (contains "/" or "\" before a ": ")
  if not rest.contains("/") 'noPath'
    return line
  end 'noPath'
  // Find the message after "line:col: " — look for ": " pattern after digits
  // Strategy: find the last colon-space-uppercase pattern that starts a message
  // Simpler: count colons in rest — filepath:line:col: has 3 colons before message
  let prefix = line.slice(line.startIndex(), endIndex: afterFirstColonSpace)
  // Find third ": " in rest (after filepath:line:col)
  let c1 = try rest.findFirst(":") otherwise 'simple'
    return line
  end 'simple'
  let afterC1 = try rest.indexAfter(c1) otherwise 'simple2'
    return line
  end 'simple2'
  let restAfterC1 = rest.slice(afterC1, endIndex: rest.endIndex())
  let c2 = try restAfterC1.findFirst(":") otherwise 'simple3'
    return line
  end 'simple3'
  let afterC2 = try restAfterC1.indexAfter(c2) otherwise 'simple4'
    return line
  end 'simple4'
  let restAfterC2 = restAfterC1.slice(afterC2, endIndex: restAfterC1.endIndex())
  let c3 = try restAfterC2.findFirst(": ") otherwise 'simple5'
    return line
  end 'simple5'
  let afterC3 = try restAfterC2.indexAfter(c3) otherwise 'simple6'
    return line
  end 'simple6'
  let afterC3Space = try restAfterC2.indexAfter(afterC3) otherwise 'simple7'
    return line
  end 'simple7'
  let message = restAfterC2.slice(afterC3Space, endIndex: restAfterC2.endIndex())
  return "{prefix}{message}"
end 'stripFilePathFromError'

function cleanup(tempSource String, tempExe String)
  if File.exists(tempSource) 'src'
    try File.delete(tempSource) otherwise 'delErr'
    end 'delErr'
  end 'src'
  if File.exists(tempExe) 'exe'
    try File.delete(tempExe) otherwise 'delErr2'
    end 'delErr2'
  end 'exe'
end 'cleanup'

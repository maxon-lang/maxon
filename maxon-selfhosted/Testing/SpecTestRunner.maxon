// Spec test runner for the self-hosted compiler.
// Parses spec files, generates fragments, and runs tests.
// Uses the fragment-based pipeline matching the C# test runner.

let whitelist = ["basics",
	"print-function",
	"variables",
	"arithmetic",
	"float-type",
	"panic",
	"range-check-panic",
	"assignment",
	"comparison-operators",
	"expressions",
	"function-declaration",
	"if-statements",
	"literals",
	"return-statement",
	"unary-negation",
	"method-calls",
	"static-methods",
	"byte-type",
	"type-casting",
	"lexer-edge-cases",
	"unary-operators",
	"parentheses",
	"missing-return-error",
	"unknown-keyword-error",
	"expected-expression-error",
	"unused-parameters",
	"parameter-labels",
	"duplicate-block-identifiers",
	"method-call-on-parameter",
	"type-methods",
	"self-keyword",
	"contextual-literal-typing",
	"implicit-type-conversion",
	"namespaces",
	"stdlib-basic",
	"stdlib-autodiscovery",
	"pow",
	"enums-simple",
	"match-simple",
	"module-keyword",
	"lexer-parser-robustness",
	"try-otherwise-value-flow",
	"closure-self",
	"reserved-double-underscore",
	"managed-memory-builtin",
	// "ranges", — 20/22 fragments pass after expression-position `to`/`upto`
	//             lowering (Range.create / OpenRange.create), iterator
	//             passthrough at lowering time, and for-tuple destructuring.
	//             Remaining 2 need character-literal type tracking through
	//             for-range (`character-range-print`) and interface-extension
	//             method monomorphization (`with-iterator` — Phase 11).
	"arrays",
	"export-keyword",
	"static-variables",
	// "vector", — needs sized `Vector with N` type
	"bitwise-operators",
	"interface-conformance",
	"interfaces",
	"equatable",
	"primitive-stringable",
	"byte-string-literal",
	// "where-clauses", — disabled: Phase 11.x in-progress failures
	// "associated-types", — disabled: Phase 11.x in-progress failures
	"ranged-typealias",
	// "set",
	// "first-class-functions",
	"challenge-struct-field-assign",
	"challenge-nested-structs",
	"challenge-array-of-structs",
	"challenge-struct-lifetime",
	"bool-type",
	// "bool-bit-packing", — 11/15 pass; 4 need bool/int implicit cast + Vector.insert/remove fixes
	"byte-enum-comparison",
	// "char-literal-to-int", — 7/8 pass; codepoint-iteration test hits an
	//                          unresolved-name parser bug
	"error-handling",
	"interface-dispatch-throws-match",
	"initablefromarrayliteral",
	"array-managed-elements",
	// "array-realloc-dangling-ref", — needs E3070 borrow-check diagnostics
	"array-return-element-from-loop",
	"array-slice-managed-elements",
	"array-append-managed-elements",
	// "array-managed-field-reassign", — pre-existing cross-type-resolution
	// gap on `struct.arrayField = newArray` field reassignment, not
	// related to Phase 9 unions (revisited at Stage 5 audit 2026-05-12).
	// "array-managed-multi-call-lifecycle", — same field-reassign gap.
	"array-enum-element-size",
	// "repro-array-union-field-reassign", — pre-existing E3070
	// self-field-shadowing diagnostic gaps; orthogonal to unions.
	// "struct-enum-array-grow", — backend panic on large returned
	// struct with many arrays; orthogonal to unions.
	// "init-from-literal",
	// "interfaces",
	// "interface-extensions", — 5/9 pass after the extension-callee redirect
	//                          and per-receiver witness pairing. Remaining 4
	//                          need stdlib-side parser features: `Set from`,
	//                          map-literal, and for-pair iteration on Map.
	// "conditional-extensions",
	// "associated-types",
	// "collection",
	"primitive-hashable",
	"primitive-cloneable",
	// "primitive-comparable", — 26/28 pass after Phase 11.4 multi-witness
	//                          dispatch; remaining 2 are float-NaN ordering
	//                          edge cases (`compare(nan, nan)` returns wrong
	//                          arm) — pre-existing bug, not the dispatch path.
	// "exp",
	// "type-checking",
	// "ownership",
	// "map",
	// "stdlib-array",
	// "stdlib-set",
	// "enums",
	// "top-level-let",
	// Partial-pass specs are kept OFF the whitelist so a green run is fully
	// green. Each is listed with its current pass count and the gating
	// feature; re-enable when the residual fragment(s) are addressable.
	// "match-statements" (11/12) — 1 residual fragment uses non-enum
	//                              scrutinee patterns (string-literal match).
	// "match-expr-arm-divergent" (1/2) — `arm-panic.interpolated-message`
	//                              needs Phase-7 panic-string interpolation.
	// "match-exhaustive-default-panic" (9/10) — `default-panic.enum-range-statement`
	//                              hits an unexpected-op panic in lowering;
	//                              separate range-arm cleanup.
	// "enum-allcases" (5/8) — `error-enum` needs Phase-11 Hashable witness;
	//                              `string-backed` / `char-backed` need the
	//                              non-numeric-raw-value parser feature.
	// "enum-allcasenames" (7/8) — `string-backed` (same parser gap).
	// "enum-ordinal" (7/9) — `string-backed` / `char-backed` (same parser gap).
	"match-range-single-value",
	// "enum-match-exhaustive" — 17/17 on x64-windows but 16/17 on wasm32-wasi:
	// `enum-exhaustive.float-backed-range` hits a pre-existing wasm-backend
	// float-backed-enum codegen bug (i64/f64 type mismatch in wasm validator).
	// Phase 9 Stage 4: union destructors landed, so the previously-leaking
	// associated-value specs no longer hit exit-code-101. `enum-match-only`
	// stays off — `enum-map-key-still-works.test` panics on a Hashable
	// witness lookup for a bare enum nested in a `Map with (Color, Int)`
	// typealias, which is a Phase-5 (witness-table registration) gap
	// orthogonal to Stage 4's destructor work. `enum-full` stays off —
	// several E-code diagnostic strings need to match the C# bootstrap
	// wording (E3036/E3034/E3081/E3032) and `Container.fromName` lowering
	// panics in the X64 backend; both are Stage 5 follow-ups.
	"match-enum-typed-binding",
	"enum-struct-field-match",
	"mutable-enums",
	"union-cases",
	"enum-struct-backing",
	"enum-nested-struct-backing",
	"union-struct-backing",
	"enum-narrow-storage",
	// `enum-hashable` panics on `simple-enum-as-map-key` — `Map with
	// (Color, Int)` needs a Hashable witness for the bare-enum element
	// type, and BuildWitnessTables doesn't emit one. Same gap blocks
	// `enum-match-only.enum-map-key-still-works`. Phase-5 (witness-table
	// registration for primitive-conforming enums) territory.
	// "safe-ffi",
	// "challenge-struct-ownership",
	// "challenge-struct-lifetime",
	// "challenge-nested-structs",
	// "challenge-array-of-structs",
	// "optimizations",
	// "export-var-fields",
	// "parsable-interface",
]

// Signed elapsed time in milliseconds (deltas between Process.currentTimeMs() reads).
typealias Millis = int(i64.min to i64.max)

// Signed process exit code: typically 0..255 / u32.max, but Process APIs surface
// -1 on internal failure so the field has to accommodate negative sentinels.
typealias ProcessExitCode = int(i64.min to i64.max)
typealias TestCount = int(0 to u64.max)

// Per-test-process wall-clock budget. Test fragments hitting this limit are
// terminated by the runtime's processWait kill-on-timeout path so a runaway
// child (e.g. an infinite-loop fragment) can't pin the runner. Tuned for
// fast feedback on local runs; raise if a legitimately heavy test trips it.
let testProcessTimeoutMs = 2000

var totalCompileMs = 0

// Phase timestamp helper: emits "[PHASE +<deltaMs>ms] <label>" lines to
// stderr when --profile-passes is active. Used to find which phase of the
// parallel runner is dragging on a given workload. Stderr (not stdout) so it
// never leaks into the worker IPC stream the parent needs to parse.
var lastPhaseTimestamp = 0
var phaseTimingActive = false

function markPhase(label String)
	if not phaseTimingActive 'inactive'
		return
	end 'inactive'
	let now = Process.currentTimeMs()
	let delta = now - lastPhaseTimestamp
	lastPhaseTimestamp = now
	printError("[PHASE +{delta}ms] {label}\n")
end 'markPhase'

// Best-effort delete of any leftover capture files from a prior crashed run.
// Runtime processCloseCapture normally deletes them; if the runner or a worker
// crashed mid-test, files remain behind. We sweep the fragment directory tree
// and remove any whose name suggests it's a capture leftover:
//   - top level: ".capture-*.out|.err"  (worker stdout/stderr)
//   - per-spec subdirs: "*.capture.out|.err" (per-test compiled-binary captures)
// Errors (missing dir, permission, ...) are silently ignored — this is purely
// hygienic.
function cleanupLeftoverCaptureFiles(fragmentDir FilePath)
	if not Directory.exists(fragmentDir) 'noDir'
		return
	end 'noDir'
	let entries = try Directory.list(fragmentDir) otherwise return
	for entry in entries 'each'
		if Directory.isDirectory(entry) 'isDir'
			cleanupLeftoverCaptureFiles(entry)
			continue
		end 'isDir'
		let name = entry.filename()
		let isWorkerCapture = name.startsWith(".capture-") and (name.endsWith(".out") or name.endsWith(".err"))
		let isPerTestCapture = name.endsWith(".capture.out") or name.endsWith(".capture.err")
		if isWorkerCapture or isPerTestCapture 'isCapture'
			try File.delete(entry) otherwise ignore
		end 'isCapture'
	end 'each'
end 'cleanupLeftoverCaptureFiles'

// Build the pair of capture file paths for a worker/test redirect, both rooted
// under fragmentDir/.spec-cache so a `.gitignore` entry on `.spec-cache`
// covers them automatically. `stem` is a short descriptor like "bw-3" or
// "retry-arrays-foo" — file extensions .out/.err are appended.
function captureFilePaths(fragmentDir FilePath, stem String) returns (FilePath, FilePath)
	let cacheDir = fragmentDir.join(".spec-cache")
	let outPath = cacheDir.join(".capture-{stem}.out")
	let errPath = cacheDir.join(".capture-{stem}.err")
	return (outPath, errPath)
end 'captureFilePaths'

function startPhaseTiming()
	if not passTimingsActive() 'inactive'
		return
	end 'inactive'
	phaseTimingActive = true
	lastPhaseTimestamp = Process.currentTimeMs()
	printError("[PHASE +0ms] start\n")
end 'startPhaseTiming'

// Walk up from cwd looking for a specs/ directory, returning its parent.
export function findSpecsRoot() returns FilePath throws CompileError
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		let specsPath = dir.join("specs")
		if Directory.exists(specsPath) 'found'
			return dir
		end 'found'
		let parentDir = try dir.parent() otherwise throw CompileError.directoryNotFound(dir)
		dir = parentDir
	end 'search'
	throw CompileError.directoryNotFound(Directory.currentPath())
end 'findSpecsRoot'

// Check if a target matches the host.
function isHostTarget(target Target) returns bool
	let host = detectHostTarget()
	let targetStr = targetToString(target)
	let hostStr = targetToString(host)
	return targetStr == hostStr
end 'isHostTarget'

// Find the vendored wasmtime binary relative to the project root.
function findWasmtimePath() returns String
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		let candidate = dir.join("vendor").join("wasmtime").join("wasmtime.exe")
		if File.exists(candidate) 'found'
			return candidate.toString()
		end 'found'
		// Also check for non-Windows binary name
		let candidate2 = dir.join("vendor").join("wasmtime").join("wasmtime")
		if File.exists(candidate2) 'found2'
			return candidate2.toString()
		end 'found2'
		let parentDir = try dir.parent() otherwise return ""
		dir = parentDir
	end 'search'
	return ""
end 'findWasmtimePath'

// Build the command to run a compiled binary. The runner's upstream
// `isSupportedTarget` gate guarantees we only get here for the host target or
// wasm32-wasi — no other cross-execution paths are supported.
function buildRunCommand(outputPath FilePath, target Target, testArgs String) returns String
	if target.os == Os.wasi 'isWasm'
		return buildWasmRunCommand(outputPath, testArgs: testArgs)
	end 'isWasm'

	if not testArgs.isEmpty() 'hasArgs'
		return "{outputPath} {testArgs}"
	end 'hasArgs'
	return outputPath.toString()
end 'buildRunCommand'

// Build the command to run a WASM binary via vendored wasmtime.
function buildWasmRunCommand(outputPath FilePath, testArgs String) returns String
	let wasmtimePath = findWasmtimePath()
	if wasmtimePath.isEmpty() 'noWasmtime'
		panic("wasmtime not found in vendor/wasmtime/")
	end 'noWasmtime'
	if not testArgs.isEmpty() 'hasArgs'
		return "{wasmtimePath} run {outputPath} -- {testArgs}"
	end 'hasArgs'
	return "{wasmtimePath} run {outputPath}"
end 'buildWasmRunCommand'

// Compile a test and capture its lowering trace log. Returns empty string on failure.
function captureLoweringLog(source String, testName String, specName String, tempDir FilePath, target Target) returns String
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.TRACE)
	startCapturingTrace()
	let tempSource = tempDir.join("{testName}.test")
	let ext = executableExtension(target)
	let tempExe = tempDir.join("{specName}{ext}")
	// parseFragment trims the source; mirror that here so this lowering
	// capture sees the same byte stream the runner will measure against.
	let normalizedSource = source.trim()
	_ = try compileSourceWithIr(normalizedSource, virtualPath: tempSource, target: target, outputPath: tempExe, coverage: false, covMapPath: tempExe.changeExtension(".covmap")) otherwise 'compileFailed'
		cancelCapturingTrace()
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
		return ""
	end 'compileFailed'
	let loweringLog = stopCapturingTrace()
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
	cleanup(tempExe)
	return loweringLog
end 'captureLoweringLog'

// Update RequiredLowering blocks in all spec files by compiling each test and capturing lowering output.
function updateAllRequiredLowering(specDir FilePath, tempDir FilePath, filter String, target Target, targetKey String)
	for specName in whitelist 'eachSpec'
		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise continue
		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			continue
		end 'isDraft'
		let tests = parseSpecFile(content, targetKey: targetKey)
		var results = TestResultArray.create()
		for test in tests 'eachTest'
			if not filter.isEmpty() 'hasFilter'
				let testPath = "{specName}/{test.name}"
				if not testPath.contains(filter) 'noMatch'
					continue
				end 'noMatch'
			end 'hasFilter'
			if test.expectation.hasCompilerStderr 'skipErrorTest'
				continue
			end 'skipErrorTest'
			let loweringLog = captureLoweringLog(test.source, testName: test.name, specName: specName, tempDir: tempDir, target: target)
			if not loweringLog.isEmpty() 'hasLog'
				results.push(TestResult.create(test.name, passed: true, errorMessage: "", filePath: "", loweringLog: loweringLog, compileIr: ""))
			end 'hasLog'
		end 'eachTest'
		if results.count() > 0 'hasResults'
			updateSpecLowering(specPath, targetKey: targetKey, results: results)
		end 'hasResults'
	end 'eachSpec'
	logInfo(LogCategory.testing, message: () gives "Updated RequiredLowering blocks in spec files")
end 'updateAllRequiredLowering'

// Run all whitelisted spec tests for a specific target.
// Warm the stdlib cache before running spec tests. This ensures all tests
// see consistent behavior: stdlib functions are pre-compiled to machine code
// and linked in, rather than the first test compiling from source.
function warmStdlibCache(target Target)
	let exePath = Process.executablePath()
	let exeParent = try exePath.parent() otherwise panic("executable has no parent directory")
	let projectDir = try exeParent.parent() otherwise panic("executable parent has no parent directory")
	logInfo(LogCategory.testing, message: () gives "Compiling stdlib cache using project dir: {projectDir}")
	var warmupProject = createProject(projectDir, target: target)
	_ = getStdlibModule(warmupProject)
	// Trigger the process-wide runtime-module load + mem2reg-promotion now,
	// while the global log level is still ERROR. Without this, the first
	// test that triggers `augmentWithRuntime` pays the load cost AND emits
	// mem2reg trace lines into its captured RequiredLowering output —
	// which then desyncs from every subsequent test that hits the cached
	// (silent) path. Pre-warming makes runtime-loading invisible to test
	// trace capture.
	_ = loadRuntimeModule()
end 'warmStdlibCache'

// Outcome of running one spec end-to-end via the in-process serial path.
// `ran` distinguishes "spec absent or draft" (no observation) from "spec ran
// and produced 0 tests after filter" — only the former should leave a prior
// failure entry untouched.
type SpecRunOutcome
	export var ran bool
	export var passed TestCount
	export var failed TestCount
	export var totalTests TestCount
	export var fragmentsWritten TestCount

	export static function notRun() returns SpecRunOutcome
		return Self{ran: false, passed: 0, failed: 0, totalTests: 0, fragmentsWritten: 0}
	end 'notRun'

	export static function create(ran bool, passed TestCount, failed TestCount, totalTests TestCount, fragmentsWritten TestCount) returns SpecRunOutcome
		return Self{ran: ran, passed: passed, failed: failed, totalTests: totalTests, fragmentsWritten: fragmentsWritten}
	end 'create'
end 'SpecRunOutcome'

// Run one spec end-to-end on the in-process serial path: parse the spec file,
// partition tests, run the batched compile, then run any non-batchable tests
// per-fragment. Logs the per-spec [FAIL] header inline so callers don't repeat
// the formatting. Returns ran=false when the spec file is missing or the spec
// is in draft status — those cases must NOT clear an entry from the failure
// state file.
function runOneSpecSerial(specName String, specDir FilePath, fragmentDir FilePath, specCacheDir FilePath, root FilePath, target Target, filter String, targetKey String, verbose bool) returns SpecRunOutcome
	let specPath = specDir.join("{specName}.md")
	let content = try File.readText(specPath) otherwise 'readErr'
		logError(LogCategory.testing, message: () gives "Could not read spec: {specPath}")
		return SpecRunOutcome.notRun()
	end 'readErr'

	let fm = parseFrontmatter(content)
	if fm.status == "draft" 'isDraft'
		logDebug(LogCategory.testing, message: () gives "Skipping draft spec: {specName}")
		return SpecRunOutcome.notRun()
	end 'isDraft'

	let tests = parseSpecFile(content, targetKey: targetKey)
	var unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
	let totalTests = unit.totalCount()

	// If the filter excluded every test (or the spec genuinely has none), we
	// observed nothing for this spec. Return ran=false so the caller leaves the
	// prior failure state untouched — the spec is neither newly-failed nor
	// newly-passed.
	if totalTests == 0 'noTests'
		return SpecRunOutcome.notRun()
	end 'noTests'

	var specPassed = 0 as TestCount
	var specFailed = unit.missingLoweringCount
	var specFailures = TextLineArray.create()
	for msg in unit.missingLoweringFailures 'copyMissing'
		specFailures.push(msg)
	end 'copyMissing'

	if unit.batchable.count() > 0 'hasBatch'
		let batchOutcome = runSpecBatch(unit.batchable, specName: specName, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target)
		specPassed = specPassed + batchOutcome.passed
		if verbose 'showBatch'
			for verboseLine in batchOutcome.verboseLines 'eachVerbose'
				logInfo(LogCategory.testing, message: () gives verboseLine)
			end 'eachVerbose'
		end 'showBatch'
		appendSkippedToFallback(unit.nonBatchable, batchable: unit.batchable, skippedNames: batchOutcome.skippedTestNames)
	end 'hasBatch'

	var fragmentsWritten = 0 as TestCount
	for test in unit.nonBatchable 'eachSingle'
		let testPath = "{specName}/{test.name}"
		let fragPath = fragmentDir.join(specName).join("{test.name}.test")
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: "")
		fragmentsWritten = fragmentsWritten + 1

		let fragment = try parseFragment(fragPath) otherwise 'parseFailed'
			logError(LogCategory.testing, message: () gives "[FAIL] {testPath} - could not parse fragment")
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			specFailures.push("  Failed to parse fragment file")
			continue
		end 'parseFailed'

		let result = runTestFromFragment(fragment, projectRoot: root, target: target, specName: specName, specCacheDir: specCacheDir)

		if not result.compileIr.isEmpty() 'hasIr'
			writeFragment(fragmentDir, specName: specName, test: test, compileIr: result.compileIr)
		end 'hasIr'
		if result.passed 'pass'
			specPassed = specPassed + 1
		end 'pass' else 'fail'
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			if not result.errorMessage.isEmpty() 'hasErr'
				specFailures.push("  {result.errorMessage}")
			end 'hasErr'
		end 'fail'

		if verbose 'showTest'
			if result.passed 'showPass'
				logInfo(LogCategory.testing, message: () gives "[PASS] {testPath}")
			end 'showPass' else 'showFail'
				logInfo(LogCategory.testing, message: () gives "[FAIL] {testPath}")
			end 'showFail'
		end 'showTest'
	end 'eachSingle'

	if specFailed > 0 'hasSpecFail'
		let specTotal = specPassed + specFailed
		logError(LogCategory.testing, message: () gives "[FAIL] {specName} ({specPassed}/{specTotal})")
		logSpecFailureMessages(specFailures)
	end 'hasSpecFail'

	return SpecRunOutcome.create(true, passed: specPassed, failed: specFailed, totalTests: totalTests, fragmentsWritten: fragmentsWritten)
end 'runOneSpecSerial'

export function runAllSpecTests(filter String, target Target, updateRequired bool = false, verbose bool = false) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: () gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	// Suppress compiler info/debug output during spec tests so only test results are visible
	setLogLevel(LogLevel.ERROR)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let startTime = Process.currentTimeMs()
	totalCompileMs = 0

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let tempDir = root.join("temp")

	// Ensure fragment directory exists
	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Process.execute("mkdir -p {fragmentDir}", timeoutMs: 5000)
	end 'noFragDir'

	// Reap any leftover capture files from a prior crashed run.
	cleanupLeftoverCaptureFiles(fragmentDir)

	// Warm the stdlib cache before running tests so all tests see consistent
	// behavior (pre-compiled stdlib via linker, not compiled from source).
	warmStdlibCache(target)

	// Update spec files before generating fragments so tests compare against current output
	if updateRequired 'preUpdate'
		updateAllRequiredLowering(specDir, tempDir: tempDir, filter: filter, target: target, targetKey: targetKey)
	end 'preUpdate'

	// On-disk staging area for compiled exes. The run step needs a stable
	// file path to invoke; the directory is NOT used for skipping recompilation.
	// Every test recompiles its fragment on every run.
	let specCacheDir = fragmentDir.join(".spec-cache")
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	// Pre-create spec subdirectories under the staging area
	for specName2 in whitelist 'createCacheDirs'
		let cacheSubDir = specCacheDir.join(specName2)
		if not Directory.exists(cacheSubDir) 'noCacheSub'
			_ = Directory.create(cacheSubDir)
		end 'noCacheSub'
	end 'createCacheDirs'

	var totalPassed = 0
	var totalFailed = 0
	var totalTests = 0
	var totalFragmentsWritten = 0

	for specName in whitelist 'eachSpec'
		let outcome = runOneSpecSerial(specName, specDir: specDir, fragmentDir: fragmentDir, specCacheDir: specCacheDir, root: root, target: target, filter: filter, targetKey: targetKey, verbose: verbose)
		if not outcome.ran 'skipped'
			continue
		end 'skipped'
		totalTests = totalTests + outcome.totalTests
		totalPassed = totalPassed + outcome.passed
		totalFailed = totalFailed + outcome.failed
		totalFragmentsWritten = totalFragmentsWritten + outcome.fragmentsWritten
	end 'eachSpec'

	if totalTests == 0 'noTests'
		logInfo(LogCategory.testing, message: () gives "No tests found")
		return 0
	end 'noTests'

	if totalFragmentsWritten > 0 'showFrags'
		logInfo(LogCategory.testing, message: () gives "Wrote {totalFragmentsWritten} fragment(s)")
	end 'showFrags'

	let elapsedMs = Process.currentTimeMs() - startTime
	logInfo(LogCategory.testing, message: () gives "Total compile time: {totalCompileMs}ms")

	if totalFailed == 0 'allPass'
		logInfo(LogCategory.testing, message: () gives "Tests: {totalPassed} passed (total: {totalTests}) in {elapsedMs}ms")
	end 'allPass' else 'someFail'
		logInfo(LogCategory.testing, message: () gives "Tests: {totalPassed} passed, {totalFailed} failed (total: {totalTests}) in {elapsedMs}ms")
	end 'someFail'

	if totalFailed > 0 'hasFail'
		return 1
	end 'hasFail'
	return 0
end 'runAllSpecTests'

// Outcome of running one spec's batch. Only PASS results survive batching:
// any failure shape forces the affected tests onto the per-fragment path via
// `skippedTestNames`, so the caller — not this type — produces FAIL records
// for those tests.
type BatchOutcome
	export var passed TestCount
	export var verboseLines TextLineArray
	// Tests that must be re-run via the per-fragment path: those the rewriter
	// rejected up front, plus (when any batched test fails) every batchable
	// test in the spec. The batched dispatcher omits the rewriter-rejected
	// tests entirely; rerouting failures keeps batching invisible in reports.
	export var skippedTestNames StringArray

	export static function create() returns BatchOutcome
		return Self{passed: 0, verboseLines: TextLineArray.create(), skippedTestNames: StringArray.create()}
	end 'create'
end 'BatchOutcome'

// True if `name` appears in the rewriter's skipped-names list. Used to
// suppress the dispatcher's run/result accounting for tests that aren't
// part of the batched binary — they're already routed through the
// per-fragment path by the caller.
function isSkippedTestName(skippedNames StringArray, name String) returns bool
	for skipName in skippedNames 'each'
		if skipName == name 'match'
			return true
		end 'match'
	end 'each'
	return false
end 'isSkippedTestName'

// Mark every test that the rewriter accepted (i.e., NOT in `alreadySkipped`)
// for the per-fragment fallback path. Used when the shared batched binary
// fails in any way that can't be cleanly attributed to one test — the user
// sees real per-test pass/fail instead of a batch-flavored error.
function pushBatchableForFallback(outcome BatchOutcome, tests SpecTestArray, alreadySkipped StringArray)
	for test in tests 'each'
		if isSkippedTestName(alreadySkipped, name: test.name) 'skip'
			continue
		end 'skip'
		outcome.skippedTestNames.push(test.name.clone())
	end 'each'
end 'pushBatchableForFallback'

// Build a batched source for `tests`, compile it once to a shared exe, then
// run the exe ONCE: the dispatcher runs every included test in sequence and
// prints BEGIN/END markers around each so we can slice the output into
// per-test stdout and exit code. Tests rejected by the rewriter are returned
// in `outcome.skippedTestNames` for the caller to run via the per-fragment
// path. A batched-compile failure marks every test in the batch failed with
// a clear error message — the runner deliberately does NOT fall back
// silently, so a developer notices and either fixes the rewriter or adjusts
// the spec.
function runSpecBatch(tests SpecTestArray, specName String, fragmentDir FilePath, specCacheDir FilePath, target Target) returns BatchOutcome
	var outcome = BatchOutcome.create()

	let buildResult = buildBatchSource(specName, tests: tests)
	for skipName in buildResult.skippedNames 'collectSkipped'
		outcome.skippedTestNames.push(skipName.clone())
	end 'collectSkipped'
	for reason in buildResult.skippedReasons 'logSkipped'
		logDebug(LogCategory.testing, message: () gives "[BATCH SKIP] {reason}")
	end 'logSkipped'

	if not buildResult.hasSource 'allRejected'
		// No batchable tests survived the rewriter. The caller will run them
		// all via the per-fragment path; outcome stays empty here.
		return outcome
	end 'allRejected'

	// Compile the batched source to <specCacheDir>/<spec>/<spec>_batch<ext>
	let cacheSpecDir = specCacheDir.join(specName)
	if not Directory.exists(cacheSpecDir) 'noCacheDir'
		_ = Directory.create(cacheSpecDir)
	end 'noCacheDir'

	let ext = executableExtension(target)
	let batchBaseName = batchFragmentBaseName(specName)
	let batchExePath = cacheSpecDir.join("{batchBaseName}{ext}")

	// Virtual path for the batched source used when invoking the compiler.
	// Use the spec name (not `<spec>_batch`) as the stem so the parser-derived
	// namespace matches a non-batched compile — otherwise per-test IR slices
	// inherit `<spec>_batch.<name>` qualifiers that leak the batching detail.
	let virtualPath = fragmentDir.join(specName).join("{specName}.maxon")

	startCapturingErrors()
	let compileStart = Process.currentTimeMs()
	let batchedSource = buildResult.source
	let covMapPath = batchExePath.changeExtension(".covmap")
	emitWorkerCompiling("{specName} (batch of {tests.count()})")
	let cr = try compileSourceWithIr(batchedSource, virtualPath: virtualPath, target: target, outputPath: batchExePath, coverage: false, covMapPath: covMapPath) otherwise 'batchCompileFailed'
		totalCompileMs = totalCompileMs + (Process.currentTimeMs() - compileStart) as Millis
		let capturedErrors = stopCapturingErrors()
		// The shared compile didn't identify any single test — re-run every
		// batchable test via the per-fragment path so callers see real
		// individual pass/fail instead of a generic batch-flavored error.
		logDebug(LogCategory.testing, message: () gives "[BATCH FALLBACK] {specName}: batch compile failed: {capturedErrors}")
		pushBatchableForFallback(outcome, tests: tests, alreadySkipped: buildResult.skippedNames)
		return outcome
	end 'batchCompileFailed'
	totalCompileMs = totalCompileMs + (Process.currentTimeMs() - compileStart) as Millis
	cancelCapturingErrors()
	logDebug(LogCategory.testing, message: () gives "[BATCH OK] {specName} compiled to {cr.outputPath}")

	// Run the batched binary ONCE. The dispatcher runs every included test
	// in sequence and emits BEGIN/END markers around each so we can slice
	// the binary's stdout into per-test stdout and per-test exit code.
	let runCommand = buildRunCommand(batchExePath, target: target, testArgs: "")
	let captureOut = batchExePath.changeExtension(".capture.out")
	let captureErr = batchExePath.changeExtension(".capture.err")
	let runResult = Process.captureOutput(runCommand, stdoutPath: captureOut, stderrPath: captureErr, timeoutMs: testProcessTimeoutMs)

	// First pass: check each batchable test's slice. Tests with a present and
	// passing slice are committed as PASS immediately; tests with a missing
	// slice or a stdout/exit-code mismatch get pushed onto `outcome.skippedTestNames`
	// so the caller re-runs *just those tests* via the per-fragment path. Tests
	// that succeeded in the batch are NOT re-run — that would double the work
	// every time a single sibling test happens to fail.
	var pendingPassed = TextLineArray.create()
	var failedNames = StringArray.create()
	for test in tests 'firstPass'
		if isSkippedTestName(buildResult.skippedNames, name: test.name) 'skipRun'
			continue
		end 'skipRun'

		let slice = parseBatchSlice(runResult.stdout, testName: test.name)
		if not slice.found 'noSlice'
			failedNames.push(test.name.clone())
			continue
		end 'noSlice'

		var passed = true
		if test.expectation.hasExitCode 'checkEcBatch'
			if slice.exitCode != test.expectation.exitCode 'ecMismatchBatch'
				passed = false
			end 'ecMismatchBatch'
		end 'checkEcBatch'

		if test.expectation.hasStdout 'checkStdoutBatch'
			let expectedOut = trimWhitespace(test.expectation.stdout.replace("\r\n", with: "\n"))
			let actualOut = trimWhitespace(slice.stdout.replace("\r\n", with: "\n"))
			if actualOut != expectedOut 'stdoutMismatchBatch'
				passed = false
			end 'stdoutMismatchBatch'
		end 'checkStdoutBatch'

		if passed 'passBatch'
			pendingPassed.push("[PASS] {specName}/{test.name}")
		end 'passBatch' else 'failBatch'
			failedNames.push(test.name.clone())
		end 'failBatch'
	end 'firstPass'

	if failedNames.count() > 0 'someFailed'
		logDebug(LogCategory.testing, message: () gives "[BATCH FALLBACK] {specName}: re-running {failedNames.count()} failing batchable test(s) individually")
	end 'someFailed'

	// Commit passes regardless of whether any tests failed — the failed ones
	// will be re-run via the per-fragment path, but the passes are real.
	for line in pendingPassed 'commitPassed'
		outcome.passed = outcome.passed + 1
		outcome.verboseLines.push(line)
	end 'commitPassed'

	// Route only the failed tests (plus rewriter-rejected ones) to the
	// fallback path. The rewriter-rejected names were appended at the top
	// of this function; we add the per-test failures here.
	for failName in failedNames 'addFailedToSkipped'
		outcome.skippedTestNames.push(failName)
	end 'addFailedToSkipped'

	// Slice the batched IR text into per-test snippets and write a fragment
	// file for each batchable test. Inspection aid only — the IR may differ
	// from a per-fragment compile because batched optimization decisions
	// aren't identical.
	writePerTestFragmentsFromBatch(tests, fragmentDir: fragmentDir, specName: specName, batchedIr: cr.ir, skippedNames: buildResult.skippedNames)

	return outcome
end 'runSpecBatch'

// After a successful batched compile, slice the batched IR text into per-test
// snippets and write a fragment file for each batchable test. Tests rejected
// by the rewriter aren't in the binary; the caller reruns those via the
// per-fragment path which writes its own fragment.
function writePerTestFragmentsFromBatch(tests SpecTestArray, fragmentDir FilePath, specName String, batchedIr String, skippedNames StringArray)
	let slices = splitBatchedIr(batchedIr, tests: tests, specName: specName)
	for test in tests 'eachTest'
		if isSkippedTestName(skippedNames, name: test.name) 'skipRewriterRejected'
			continue
		end 'skipRewriterRejected'
		let ir = lookupSliceIr(slices, testName: test.name)
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: ir)
	end 'eachTest'
end 'writePerTestFragmentsFromBatch'

// Find the IR snippet for `testName` in a BatchIrSliceArray. Returns "" when
// no slice was attributed to the test (e.g. the rewriter renamed all of its
// declarations away from any `_b_<sanitized>_` form).
function lookupSliceIr(slices BatchIrSliceArray, testName String) returns String
	for slice in slices 'each'
		if slice.testName == testName 'match'
			return slice.ir
		end 'match'
	end 'each'
	return ""
end 'lookupSliceIr'

// Per-test slice of a batched binary's output. Used by parseBatchSlice.
type BatchSlice
	export var stdout String
	export var exitCode ProcessExitCode
	export var found bool

	export static function missing() returns BatchSlice
		return Self{stdout: "", exitCode: 0, found: false}
	end 'missing'

	export static function present(stdout String, exitCode ProcessExitCode) returns BatchSlice
		return Self{stdout: stdout, exitCode: exitCode, found: true}
	end 'present'
end 'BatchSlice'

// Walk the batched binary's stdout looking for the BEGIN/END marker pair
// belonging to `testName`. Returns the test's per-test stdout (the bytes
// between the BEGIN line and the END line) plus the exit code its
// renamed-main returned. If either marker is missing, returns
// `BatchSlice.missing()` — the caller treats that as "did not run".
function parseBatchSlice(stdout String, testName String) returns BatchSlice
	let beginTag = "{batchTestBeginMarker}{testName}{batchMarkerSuffix}"
	let endTagPrefix = "{batchTestEndMarker}{testName}:"

	let beginIdx = try stdout.findFirst(beginTag) otherwise return BatchSlice.missing()
	// Skip to the character after the BEGIN tag.
	let stdoutStart = beginIdx.bytePos() + beginTag.count()
	let bodyAfterBegin = sliceFromBytePos(stdout, bytePos: stdoutStart)
	let endIdx = try bodyAfterBegin.findFirst(endTagPrefix) otherwise return BatchSlice.missing()
	let testStdoutRaw = bodyAfterBegin.slice(bodyAfterBegin.startIndex(), endIndex: endIdx)

	// Read the exit code: from the char after `:` up to the marker suffix.
	// The dispatcher emits this verbatim from a captured `let ec_<name> =
	// renamedMain()` so the format is fully under our control — a parse
	// failure here means the dispatcher template has drifted from this
	// parser, not a runtime condition.
	let afterEndTagPrefix = sliceFromBytePos(bodyAfterBegin, bytePos: endIdx.bytePos() + endTagPrefix.count())
	let suffixIdx = try afterEndTagPrefix.findFirst(batchMarkerSuffix) otherwise return BatchSlice.missing()
	let exitStr = afterEndTagPrefix.slice(afterEndTagPrefix.startIndex(), endIndex: suffixIdx)
	let ec = try int.fromString(exitStr) otherwise panic("batch dispatcher emitted non-integer exit code '{exitStr}' for {testName}")

	// Trim leading/trailing whitespace that came from the marker lines.
	// (The test's own stdout content gets compared after another trim at the
	// expectation site, so this is symmetric.)
	let cleaned = trimWhitespace(testStdoutRaw)
	return BatchSlice.present(cleaned, exitCode: ec as ProcessExitCode)
end 'parseBatchSlice'

// Return the substring of `s` starting at byte position `bytePos`. Falls
// back to "" if the position is out of range.
function sliceFromBytePos(s String, bytePos BytePos) returns String
	let endIdx = s.endIndex()
	if bytePos >= s.count() 'past'
		return ""
	end 'past'
	let startIdx = StringIndex.create(bytePos, bytePos: bytePos)
	return s.slice(startIdx, endIndex: endIdx)
end 'sliceFromBytePos'

// Dispatch to single- or multi-file compile based on whether the test
// authored `// --- file: name.maxon` markers. The single-file branch keeps
// the fragment's on-disk path so error messages line up with what the
// reader sees in the editor; the multi-file branch synthesizes per-file
// virtual paths under a directory derived from the fragment so module
// visibility (which depends on directory subtree relationships) works.
function compileFragmentInMemory(fragment Fragment, virtualSourcePath FilePath, target Target, outputExe FilePath) returns CompileWithIrResult throws CompileError
	let covMapPath = outputExe.changeExtension(".covmap")
	if not fragment.hasMultiFile 'isSingle'
		return try compileSourceWithIr(fragment.source, virtualPath: virtualSourcePath, target: target, outputPath: outputExe, coverage: false, covMapPath: covMapPath, includeStdlibIr: fragment.includeStdlibIr)
	end 'isSingle'

	// Anchor virtual paths in the fragment's directory so module-visibility
	// rules (which compare directory subtrees) match the spec author's
	// intent: a file marker `feature/main.maxon` lands in `<fragmentDir>/feature/main.maxon`.
	// The runner always gives us an absolute fragment path, so .parent()
	// should never fail; treat a failure as an invariant break.
	let fragmentDir = try virtualSourcePath.parent() otherwise panic("compileFragmentInMemory: fragment path '{virtualSourcePath}' has no parent directory")
	var virtualFiles = VirtualSourceFileArray.create()
	for pair in fragment.sourceFiles 'eachFile'
		let path = fragmentDir.join(pair.fileName)
		// Per-file slices come from the spec parser already trimmed of
		// trailing whitespace; the parser's tokenizer needs a final newline
		// so it doesn't hit EOF mid-statement.
		let normalizedSource = pair.source if pair.source.endsWith("\n") else "{pair.source}\n"
		virtualFiles.push(VirtualSourceFile.create(path, source: normalizedSource))
	end 'eachFile'
	return try compileMultiFileSourceWithIr(virtualFiles, target: target, outputPath: outputExe, coverage: false, covMapPath: covMapPath, includeStdlibIr: fragment.includeStdlibIr)
end 'compileFragmentInMemory'

// Run a single test from a parsed fragment. Returns TestResult.
function runTestFromFragment(fragment Fragment, projectRoot FilePath, target Target, captureTrace bool = false, specName String, specCacheDir FilePath) returns TestResult
	let tempDir = projectRoot.join("temp")
	// virtualPath ends up embedded in compiler error messages, so point it at
	// the on-disk fragment we just wrote — readers can open the path verbatim.
	let virtualSourcePath = try FilePath.from(fragment.filePath) otherwise tempDir.join("{fragment.testName}.test")
	let ext = executableExtension(target)
	let testName = fragment.testName

	// compiler_error tests compile to temp (we only care about the error message)
	// success tests compile to the cache directory so the exe can be reused
	var outputExe = tempDir.join("{specName}{ext}")
	if not fragment.expectation.hasCompilerStderr 'isSuccessTest'
		let cacheSpecDir = specCacheDir.join(specName)
		if not Directory.exists(cacheSpecDir) 'noCacheDir'
			_ = Directory.create(cacheSpecDir)
		end 'noCacheDir'
		outputExe = cacheSpecDir.join("{fragment.testName}{ext}")
	end 'isSuccessTest'

	// Enable trace capture for RequiredLowering validation or --update-required
	let needTrace = fragment.expectation.hasRequiredLowering or captureTrace
	if needTrace 'enableTrace'
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.TRACE)
		startCapturingTrace()
	end 'enableTrace'

	// Compile source directly from memory, capturing any error output.
	// Multi-file tests (those with `// --- file: name.maxon` markers) feed
	// each fragment as a distinct compilation unit so cross-file references
	// resolve like a real on-disk project.
	startCapturingErrors()
	let compileStart = Process.currentTimeMs()
	emitWorkerCompiling("{specName}/{testName}")
	let compileResult = try compileFragmentInMemory(fragment, virtualSourcePath: virtualSourcePath, target: target, outputExe: outputExe) otherwise 'compileFailed'
		totalCompileMs = totalCompileMs + (Process.currentTimeMs() - compileStart) as Millis
		let capturedErrors = stopCapturingErrors()
		if needTrace 'cancelTrace'
			cancelCapturingTrace()
			setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
		end 'cancelTrace'

		if fragment.expectation.hasCompilerStderr 'expectedError'
			// Compilation failed as expected — validate the error message
			let expectedStderr = normalizeStderr(fragment.expectation.compilerStderr)
			let actualStderr = normalizeStderr(capturedErrors)
			if actualStderr != expectedStderr 'stderrMismatch'
				cleanup(outputExe)
				return TestResult.create(testName, passed: false, errorMessage: "Stderr mismatch.\nExpected:\n  {expectedStderr}\nActual:\n  {actualStderr}", filePath: fragment.filePath, loweringLog: "", compileIr: "")
			end 'stderrMismatch'
			cleanup(outputExe)
			return TestResult.create(testName, passed: true, errorMessage: "", filePath: fragment.filePath, loweringLog: "", compileIr: "")
		end 'expectedError'

		cleanup(outputExe)
		return TestResult.create(testName, passed: false, errorMessage: "Compilation failed: {capturedErrors}", filePath: fragment.filePath, loweringLog: "", compileIr: "")
	end 'compileFailed'
	totalCompileMs = totalCompileMs + (Process.currentTimeMs() - compileStart) as Millis
	cancelCapturingErrors()
	let outputPath = compileResult.outputPath
	let compileIr = compileResult.ir

	// Capture lowering log if needed
	var loweringLog = ""
	if needTrace 'captureLowering'
		loweringLog = stopCapturingTrace()
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
	end 'captureLowering'

	if fragment.expectation.hasCompilerStderr 'unexpectedSuccess'
		cleanup(outputExe)
		return TestResult.create(testName, passed: false, errorMessage: "Expected compilation error but compilation succeeded", filePath: fragment.filePath, loweringLog: "", compileIr: "")
	end 'unexpectedSuccess'

	// Run the compiled executable.
	let runCommand = buildRunCommand(outputPath, target: target, testArgs: fragment.args)
	let captureOut = outputPath.changeExtension(".capture.out")
	let captureErr = outputPath.changeExtension(".capture.err")
	let runResult = Process.captureOutput(runCommand, stdoutPath: captureOut, stderrPath: captureErr, timeoutMs: testProcessTimeoutMs)
	let runStdout = runResult.stdout
	let runStderr = runResult.stderr
	let runEc = runResult.exitCode as ProcessExitCode

	var passed = true
	var errorMsg = ""

	// Check exit code (skip for tests that expect stderr — panic exit codes are platform-dependent)
	if fragment.expectation.hasExitCode and not fragment.expectation.hasRuntimeStderr 'checkEc'
		if runEc != fragment.expectation.exitCode 'ecMismatch'
			passed = false
			errorMsg = "Expected exit code {fragment.expectation.exitCode}, got {runEc}"
		end 'ecMismatch'
	end 'checkEc'

	// Check stdout
	if fragment.expectation.hasStdout 'checkStdout'
		let expectedOut = trimWhitespace(fragment.expectation.stdout)
		let actualOut = trimWhitespace(runStdout)
		if actualOut != expectedOut 'stdoutMismatch'
			passed = false
			if errorMsg.isEmpty() 'firstStdout'
				errorMsg = "Stdout mismatch:\nExpected: {expectedOut}\nActual: {actualOut}"
			end 'firstStdout' else 'appendStdout'
				errorMsg = "{errorMsg}\nStdout mismatch:\nExpected: {expectedOut}\nActual: {actualOut}"
			end 'appendStdout'
		end 'stdoutMismatch'
	end 'checkStdout'

	// Check runtime stderr
	if fragment.expectation.hasRuntimeStderr 'checkStderr'
		let expectedErr = trimWhitespace(fragment.expectation.runtimeStderr)
		var actualErr = trimWhitespace(runStderr)
		// Convert wasmtime trap output into Maxon-style stack trace
		if target.os == Os.wasi 'convertWasmtimeOutput'
			actualErr = convertWasmtimeStderr(actualErr)
		end 'convertWasmtimeOutput'
		if actualErr != expectedErr 'stderrMismatch'
			passed = false
			if errorMsg.isEmpty() 'firstStderr'
				errorMsg = "Stderr mismatch:\nExpected: {expectedErr}\nActual: {actualErr}"
			end 'firstStderr' else 'appendStderr'
				errorMsg = "{errorMsg}\nStderr mismatch:\nExpected: {expectedErr}\nActual: {actualErr}"
			end 'appendStderr'
		end 'stderrMismatch'
	end 'checkStderr' else 'noExpectedStderr'
		// Unexpected stderr detection
		let trimmedStderr = trimWhitespace(runStderr)
		if not trimmedStderr.isEmpty() 'unexpectedStderr'
			passed = false
			if errorMsg.isEmpty() 'firstUnexpected'
				errorMsg = "Unexpected stderr output:\n{trimmedStderr}"
			end 'firstUnexpected' else 'appendUnexpected'
				errorMsg = "{errorMsg}\nUnexpected stderr output:\n{trimmedStderr}"
			end 'appendUnexpected'
		end 'unexpectedStderr'
	end 'noExpectedStderr'

	// Check RequiredLowering
	if fragment.expectation.hasRequiredLowering 'checkLowering'
		let loweringResult = checkRequiredLowering(fragment.expectation.requiredLowering, actual: loweringLog)
		if not loweringResult.passed 'loweringFailed'
			passed = false
			if errorMsg.isEmpty() 'firstLowering'
				errorMsg = loweringResult.message
			end 'firstLowering' else 'appendLowering'
				errorMsg = "{errorMsg}\n{loweringResult.message}"
			end 'appendLowering'
		end 'loweringFailed'
	end 'checkLowering'

	// Check RequiredRdata — byte-for-byte compare the compiled .exe's .rdata
	// section against the typed values in the spec block. PE-only; ELF and
	// Mach-O don't have a `.rdata` section. Mirrors TestRunner.cs:748.
	if fragment.expectation.hasRequiredRdata 'checkRdata'
		if target.os == Os.windows 'isWindows'
			let rdataResult = checkRequiredRdataBytes(fragment.expectation.requiredRdata, exePath: outputPath)
			if not rdataResult.passed 'rdataFailed'
				passed = false
				if errorMsg.isEmpty() 'firstRdata'
					errorMsg = "Required Rdata mismatch: {rdataResult.message}"
				end 'firstRdata' else 'appendRdata'
					errorMsg = "{errorMsg}\nRequired Rdata mismatch: {rdataResult.message}"
				end 'appendRdata'
			end 'rdataFailed'
		end 'isWindows'
	end 'checkRdata'

	if passed 'didPass'
		logDebug(LogCategory.testing, message: () gives "[PASS] {testName}")
	end 'didPass'

	// Keep the exe only for passing success tests (cached for future runs)
	if not passed or fragment.expectation.hasCompilerStderr 'cleanupExe'
		cleanup(outputExe)
	end 'cleanupExe'
	return TestResult.create(testName, passed: passed, errorMessage: errorMsg, filePath: fragment.filePath, loweringLog: loweringLog, compileIr: compileIr)
end 'runTestFromFragment'

// Normalize stderr for comparison: trim, CRLF→LF, backslash→forward slash,
// and strip file paths from error messages so temp paths match fragment paths.
// Convert wasmtime's trap stderr into a Maxon-style stack trace.
// Input:  "panic at ...\nError: failed to run...\n...wasm backtrace:\n  0: 0x445 - <unknown>!mrt_panic\n  1: 0x485 - <unknown>!main\n..."
// Output: "panic at ...\nStack trace:\n  in main\n  in mrt_start"
// Strips mrt_panic from the trace (it's an implementation detail) and the wasmtime boilerplate.
function convertWasmtimeStderr(s String) returns String
	let marker = "\nError: failed to run"
	let markerIdx = try s.findFirst(marker) otherwise return s
	// Extract the program's stderr (before wasmtime's error)
	let programStderr = s.slice(s.startIndex(), endIndex: markerIdx)

	// Extract function names from wasmtime backtrace lines
	// Each line looks like: "           0:  0x445 - <unknown>!funcname"
	var trace = "\nStack trace:"
	let lines = s.split("\n")
	for line in lines 'eachLine'
		let bangIdx = try line.findFirst("!") otherwise continue
		let afterBangIdx = try line.indexAfter(bangIdx) otherwise continue
		let afterBang = line.slice(afterBangIdx, endIndex: line.endIndex())
		let funcName = trimWhitespace(afterBang)
		// Skip mrt_panic (implementation detail) and mrt_start (always last)
		if funcName == "mrt_panic" 'skipPanic'
			continue
		end 'skipPanic'
		trace = "{trace}\n  in {funcName}"
	end 'eachLine'

	return "{programStderr}{trace}"
end 'convertWasmtimeStderr'

function normalizeStderr(s String) returns String
	var result = trimWhitespace(s)
	result = result.replace("\r\n", with: "\n")
	result = result.replace("\\", with: "/")
	let errorLines = result.split("\n")
	var normalized = ""
	var first = true
	for errLine in errorLines 'eachLine'
		let stripped = stripFilePathFromError(errLine)
		if first 'isFirst'
			normalized = stripped
			first = false
		end 'isFirst' else 'notFirst'
			normalized = "{normalized}\n{stripped}"
		end 'notFirst'
	end 'eachLine'
	return normalized
end 'normalizeStderr'

// Strip file path from an error line.
// Input:  "error E2010: /some/path/file.maxon:3:8: Expected '=' but got ':'"
// Output: "error E2010: Expected '=' but got ':'"
function stripFilePathFromError(line String) returns String
	if not line.contains("error E") 'notError'
		return line
	end 'notError'
	try line.findFirst("error E") otherwise return line
	let firstColon = try line.findFirst(": ") otherwise return line
	let afterFirstColon = try line.indexAfter(firstColon) otherwise return line
	let afterFirstColonSpace = try line.indexAfter(afterFirstColon) otherwise return line
	let rest = line.slice(afterFirstColonSpace, endIndex: line.endIndex())
	if not rest.contains("/") 'noPath'
		return line
	end 'noPath'
	let prefix = line.slice(line.startIndex(), endIndex: afterFirstColonSpace)
	let c1 = try rest.findFirst(":") otherwise return line
	let afterC1 = try rest.indexAfter(c1) otherwise return line
	let restAfterC1 = rest.slice(afterC1, endIndex: rest.endIndex())
	let c2 = try restAfterC1.findFirst(":") otherwise return line
	let afterC2 = try restAfterC1.indexAfter(c2) otherwise return line
	let restAfterC2 = restAfterC1.slice(afterC2, endIndex: restAfterC1.endIndex())
	let c3 = try restAfterC2.findFirst(": ") otherwise return line
	let afterC3 = try restAfterC2.indexAfter(c3) otherwise return line
	let afterC3Space = try restAfterC2.indexAfter(afterC3) otherwise return line
	let message = restAfterC2.slice(afterC3Space, endIndex: restAfterC2.endIndex())
	return "{prefix}{message}"
end 'stripFilePathFromError'

function cleanup(tempExe FilePath)
	try File.delete(tempExe) otherwise ignore
end 'cleanup'

// --- RequiredRdata validation ---
//
// Verify a compiled PE executable's `.rdata` section matches the typed-value
// block declared in the spec's `RequiredRdata` block. This is the byte-level
// counterpart to `RequiredIR` — it pins the on-disk constant layout produced
// by the backend so a regression in narrow-storage lowering, struct field
// packing, or rdata serialization surfaces as a comparison failure.
//
// The check is gated on `target.os == Os.windows` because only PE has a
// `.rdata` section. ELF (Linux) and Mach-O (macOS) place read-only data in
// other sections; mirroring this for those formats is out-of-scope here and
// matches the bootstrap's behaviour.

typealias RdataByte = int(0 to u8.max)
typealias RdataValue = int(i64.min to i64.max)
typealias SectionByteCount = int(0 to u64.max)
typealias SectionFileOffset = int(0 to u64.max)
typealias RdataWidth = int(1 to 8)
typealias HexNibble = int(0 to 15)
typealias UnicodeCodepoint = int(0 to 0x10FFFF)

type RdataCheckResult
	export var passed bool
	export var message String

	static function create(passed bool, message String) returns RdataCheckResult
		return Self{passed: passed, message: message}
	end 'create'
end 'RdataCheckResult'

enum RdataParseError implements Error
	missingType            // line had no space between type tag and value
	unknownType            // unrecognised type tag
	badInteger             // int.fromString failed
	outOfRange             // integer literal outside the requested type's range
	badFloat               // float.fromString failed
	badQuotedString        // utf8 form missing surrounding quotes
	badEscapeSequence      // unknown / malformed escape inside utf8 string
end 'RdataParseError'

enum PeParseError implements Error
	notPeFile          // missing DOS magic or PE signature
	truncated          // header read off the end of the buffer
	sectionMissing     // requested section name not present
end 'PeParseError'

type PeSectionInfo
	export var name String
	export var virtualSize SectionByteCount
	export var rawSize SectionByteCount
	export var rawOffset SectionFileOffset

	static function create(name String, virtualSize SectionByteCount, rawSize SectionByteCount, rawOffset SectionFileOffset) returns PeSectionInfo
		return Self{name: name, virtualSize: virtualSize, rawSize: rawSize, rawOffset: rawOffset}
	end 'create'
end 'PeSectionInfo'

typealias PeSectionInfoArray = Array with PeSectionInfo

// Append `value` as `width` little-endian bytes to `buf`. For signed inputs,
// rely on two's-complement bit patterns: `(value and 0xFF)` extracts the
// low byte regardless of sign. Width is the integer width in bytes (1, 2,
// 4, or 8); other widths panic.
function appendLittleEndian(buf ByteArray, value RdataValue, width RdataWidth)
	var v = value
	var i = 0
	while i < width 'shift'
		buf.push((v and 0xFF) as RdataByte)
		v = v shr 8
		i = i + 1
	end 'shift'
end 'appendLittleEndian'

// Parse a signed decimal integer, verify it fits in `[lo, hi]`, and return
// the value. Trims surrounding whitespace first because the spec format is
// comma-or-space separated and individual elements often carry trailing
// spaces.
function parseRangedInt(text String, lo RdataValue, hi RdataValue) returns RdataValue throws RdataParseError
	let trimmed = trimWhitespace(text)
	let value = try int.fromString(trimmed) otherwise throw RdataParseError.badInteger
	if value < lo 'tooSmall'
		throw RdataParseError.outOfRange
	end 'tooSmall'
	if value > hi 'tooBig'
		throw RdataParseError.outOfRange
	end 'tooBig'
	return value
end 'parseRangedInt'

// Decode escape sequences inside a `utf8 "..."` value: supports \n, \t, \r,
// \0, \\, \", \', \xNN, \uNNNN. Mirrors maxon-sharp/StringUtils.ResolveEscapes
// so the bootstrap and self-hosted runners accept the same spec syntax.
function decodeUtf8Escapes(text String) returns ByteArray throws RdataParseError
	let src = text.toByteArray()
	let n = src.count()
	var out = ByteArray.create()
	var i = 0
	while i < n 'walk'
		let c = try src.get(i) otherwise panic("decodeUtf8Escapes: i < n just checked but get({i}) failed")
		if c != '\\' 'plain'
			out.push(c)
			i = i + 1
			continue
		end 'plain'

		if i + 1 >= n 'trailingBackslash'
			throw RdataParseError.badEscapeSequence
		end 'trailingBackslash'

		let next = try src.get(i + 1) otherwise panic("decodeUtf8Escapes: i + 1 < n just checked but get failed")
		if next == 'x' 'hexEscape'
			if i + 3 >= n 'shortHex'
				throw RdataParseError.badEscapeSequence
			end 'shortHex'
			let h1 = try src.get(i + 2) otherwise panic("decodeUtf8Escapes: i + 3 < n just checked")
			let h2 = try src.get(i + 3) otherwise panic("decodeUtf8Escapes: i + 3 < n just checked")
			let v1 = try hexDigitValue(h1) otherwise throw RdataParseError.badEscapeSequence
			let v2 = try hexDigitValue(h2) otherwise throw RdataParseError.badEscapeSequence
			out.push(((v1 shl 4) or v2) as RdataByte)
			i = i + 4
			continue
		end 'hexEscape'

		if next == 'u' 'unicodeEscape'
			if i + 5 >= n 'shortU'
				throw RdataParseError.badEscapeSequence
			end 'shortU'
			let u1 = try src.get(i + 2) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u2 = try src.get(i + 3) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u3 = try src.get(i + 4) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u4 = try src.get(i + 5) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let v1 = try hexDigitValue(u1) otherwise throw RdataParseError.badEscapeSequence
			let v2 = try hexDigitValue(u2) otherwise throw RdataParseError.badEscapeSequence
			let v3 = try hexDigitValue(u3) otherwise throw RdataParseError.badEscapeSequence
			let v4 = try hexDigitValue(u4) otherwise throw RdataParseError.badEscapeSequence
			let cp = (v1 shl 12) or (v2 shl 8) or (v3 shl 4) or v4
			appendUtf8Codepoint(out, codepoint: cp)
			i = i + 6
			continue
		end 'unicodeEscape'

		var decoded = 0
		if next == 'n' 'esc_n'
			decoded = 10
		end 'esc_n' else if next == 't' 'esc_t'
			decoded = 9
		end 'esc_t' else if next == 'r' 'esc_r'
			decoded = 13
		end 'esc_r' else if next == '0' 'esc_0'
			decoded = 0
		end 'esc_0' else if next == '\\' 'esc_bs'
			decoded = 92
		end 'esc_bs' else if next == '"' 'esc_dq'
			decoded = 34
		end 'esc_dq' else if next == '\'' 'esc_sq'
			decoded = 39
		end 'esc_sq' else 'unknown'
			throw RdataParseError.badEscapeSequence
		end 'unknown'

		out.push(decoded as RdataByte)
		i = i + 2
	end 'walk'

	return out
end 'decodeUtf8Escapes'

function hexDigitValue(c RdataByte) returns HexNibble throws RdataParseError
	if c >= '0' 'gteZero'
		if c <= '9' 'isDigit'
			return c - '0'
		end 'isDigit'
	end 'gteZero'
	if c >= 'a' 'gteLowerA'
		if c <= 'f' 'isLower'
			return c - 'a' + 10
		end 'isLower'
	end 'gteLowerA'
	if c >= 'A' 'gteUpperA'
		if c <= 'F' 'isUpper'
			return c - 'A' + 10
		end 'isUpper'
	end 'gteUpperA'
	throw RdataParseError.badEscapeSequence
end 'hexDigitValue'

// Encode `codepoint` as UTF-8 into `buf`. Used by the \uNNNN escape — the
// BMP fits in at most 3 bytes per RFC 3629.
function appendUtf8Codepoint(buf ByteArray, codepoint UnicodeCodepoint)
	if codepoint < 0x80 'oneByte'
		buf.push(codepoint as RdataByte)
		return
	end 'oneByte'
	if codepoint < 0x800 'twoByte'
		buf.push((0xC0 or (codepoint shr 6)) as RdataByte)
		buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
		return
	end 'twoByte'
	if codepoint < 0x10000 'threeByte'
		buf.push((0xE0 or (codepoint shr 12)) as RdataByte)
		buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as RdataByte)
		buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
		return
	end 'threeByte'
	buf.push((0xF0 or (codepoint shr 18)) as RdataByte)
	buf.push((0x80 or ((codepoint shr 12) and 0x3F)) as RdataByte)
	buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as RdataByte)
	buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
end 'appendUtf8Codepoint'

// Parse one comma-separated list of integers and append each as little-endian
// bytes of the given width. Range-checked against `[lo, hi]`.
function parseIntList(buf ByteArray, value String, lo RdataValue, hi RdataValue, width RdataWidth) throws RdataParseError
	let parts = value.split(",")
	for part in parts 'each'
		let n = try parseRangedInt(part, lo: lo, hi: hi)
		appendLittleEndian(buf, value: n, width: width)
	end 'each'
end 'parseIntList'

// Parse one space-separated list of integers — used only by the `u16` form
// (single line, multiple values separated by spaces), preserved for parity
// with the bootstrap parser.
function parseSpaceSeparatedU16(buf ByteArray, value String) throws RdataParseError
	let parts = value.split(" ")
	for part in parts 'each'
		let trimmed = trimWhitespace(part)
		if trimmed.isEmpty() 'skipEmpty'
			continue
		end 'skipEmpty'
		let n = try parseRangedInt(trimmed, lo: 0, hi: 0xFFFF)
		appendLittleEndian(buf, value: n, width: 2)
	end 'each'
end 'parseSpaceSeparatedU16'

function parseUtf8Value(buf ByteArray, value String) throws RdataParseError
	let trimmed = trimWhitespace(value)
	let len = trimmed.bytes().count()
	if len < 2 'tooShort'
		throw RdataParseError.badQuotedString
	end 'tooShort'
	let bytes = trimmed.toByteArray()
	let first = try bytes.get(0) otherwise panic("parseUtf8Value: bytes.count() >= 2 just verified")
	let last = try bytes.get(len - 1) otherwise panic("parseUtf8Value: bytes.count() >= 2 just verified")
	if first != '"' 'noOpenQuote'
		throw RdataParseError.badQuotedString
	end 'noOpenQuote'
	if last != '"' 'noCloseQuote'
		throw RdataParseError.badQuotedString
	end 'noCloseQuote'
	let inner = trimmed.slice(try trimmed.indexAfter(trimmed.startIndex()) otherwise panic("parseUtf8Value: indexAfter(start) failed on non-empty string"), endIndex: try previousIndex(trimmed, idx: trimmed.endIndex()) otherwise panic("parseUtf8Value: previousIndex(end) failed on non-empty string"))
	let decoded = try decodeUtf8Escapes(inner)
	for i in 0 upto decoded.count() 'copy'
		let b = try decoded.get(i) otherwise panic("parseUtf8Value: i < decoded.count() invariant")
		buf.push(b)
	end 'copy'
end 'parseUtf8Value'

// Return the StringIndex one step before `idx`. We need this for `utf8`
// because String slicing is half-open and we want to drop the trailing
// double-quote. Implemented as a linear walk from the start; the utf8 block
// is small enough that this is fine, and avoids needing a `previous` API.
function previousIndex(s String, idx StringIndex) returns StringIndex throws StringError
	var cur = s.startIndex()
	let endIdx = s.endIndex()
	if cur >= idx 'noStep'
		throw StringError.invalidIndex
	end 'noStep'
	while cur < endIdx 'walk'
		let next = try s.indexAfter(cur)
		if next >= idx 'reached'
			return cur
		end 'reached'
		cur = next
	end 'walk'
	throw StringError.invalidIndex
end 'previousIndex'

// Parse a `RequiredRdata` block into the concrete byte sequence the .rdata
// section should start with. Each line is a typed-value form; supported tags
// match the bootstrap (TestRunner.cs:ParseTypedSectionValues) plus the new
// narrow-storage forms (u8[], u16[], u32, u32[], i16[], i32[]) added for the
// enum-narrow-storage spec.
function parseRequiredRdataBytes(spec String) returns ByteArray throws RdataParseError
	var buf = ByteArray.create()
	let lines = spec.split("\n")
	for rawLine in lines 'eachLine'
		let line = trimWhitespace(rawLine)
		if line.isEmpty() 'skipBlank'
			continue
		end 'skipBlank'

		let spaceIdx = try line.findFirst(" ") otherwise throw RdataParseError.missingType
		let afterSpace = try line.indexAfter(spaceIdx) otherwise throw RdataParseError.missingType
		let typeTag = line.slice(line.startIndex(), endIndex: spaceIdx)
		let value = trimWhitespace(line.slice(afterSpace, endIndex: line.endIndex()))

		if typeTag == "i8" 'tagI8'
			let n = try parseRangedInt(value, lo: -128, hi: 127)
			appendLittleEndian(buf, value: n, width: 1)
			continue
		end 'tagI8'
		if typeTag == "u8" 'tagU8'
			let n = try parseRangedInt(value, lo: 0, hi: 0xFF)
			appendLittleEndian(buf, value: n, width: 1)
			continue
		end 'tagU8'
		if typeTag == "i16" 'tagI16'
			let n = try parseRangedInt(value, lo: -32768, hi: 32767)
			appendLittleEndian(buf, value: n, width: 2)
			continue
		end 'tagI16'
		if typeTag == "i32" 'tagI32'
			let n = try parseRangedInt(value, lo: -2147483648, hi: 2147483647)
			appendLittleEndian(buf, value: n, width: 4)
			continue
		end 'tagI32'
		if typeTag == "i64" 'tagI64'
			let n = try parseRangedInt(value, lo: i64.min, hi: i64.max)
			appendLittleEndian(buf, value: n, width: 8)
			continue
		end 'tagI64'
		if typeTag == "u32" 'tagU32'
			let n = try parseRangedInt(value, lo: 0, hi: 0xFFFFFFFF)
			appendLittleEndian(buf, value: n, width: 4)
			continue
		end 'tagU32'
		if typeTag == "u16" 'tagU16'
			// Space-separated values to match the bootstrap (short-type.md).
			try parseSpaceSeparatedU16(buf, value: value)
			continue
		end 'tagU16'
		if typeTag == "i8[]" 'tagI8Arr'
			try parseIntList(buf, value: value, lo: -128, hi: 127, width: 1)
			continue
		end 'tagI8Arr'
		if typeTag == "u8[]" 'tagU8Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFF, width: 1)
			continue
		end 'tagU8Arr'
		if typeTag == "i16[]" 'tagI16Arr'
			try parseIntList(buf, value: value, lo: -32768, hi: 32767, width: 2)
			continue
		end 'tagI16Arr'
		if typeTag == "u16[]" 'tagU16Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFFFF, width: 2)
			continue
		end 'tagU16Arr'
		if typeTag == "i32[]" 'tagI32Arr'
			try parseIntList(buf, value: value, lo: -2147483648, hi: 2147483647, width: 4)
			continue
		end 'tagI32Arr'
		if typeTag == "u32[]" 'tagU32Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFFFFFFFF, width: 4)
			continue
		end 'tagU32Arr'
		if typeTag == "i64[]" 'tagI64Arr'
			let parts = value.split(",")
			for part in parts 'eachI64'
				let trimmed = trimWhitespace(part)
				let n = try int.fromString(trimmed) otherwise throw RdataParseError.badInteger
				appendLittleEndian(buf, value: n, width: 8)
			end 'eachI64'
			continue
		end 'tagI64Arr'
		if typeTag == "f64" 'tagF64'
			let trimmed = trimWhitespace(value)
			let f = try float.fromString(trimmed) otherwise throw RdataParseError.badFloat
			let bits = __Builtins.floatToBits(f)
			appendLittleEndian(buf, value: bits, width: 8)
			continue
		end 'tagF64'
		if typeTag == "utf8" 'tagUtf8'
			try parseUtf8Value(buf, value: value)
			continue
		end 'tagUtf8'
		if typeTag == "pad" 'tagPad'
			let count = try parseRangedInt(value, lo: 0, hi: 0xFFFFFFFF)
			for _ in 0 upto count 'zero'
				buf.push(0)
			end 'zero'
			continue
		end 'tagPad'

		throw RdataParseError.unknownType
	end 'eachLine'
	return buf
end 'parseRequiredRdataBytes'

// Read a 16-bit little-endian unsigned int at `offset` from `buf`.
function readWordLE(buf ByteArray, offset SectionFileOffset) returns RdataValue throws PeParseError
	if offset + 2 > buf.count() 'oob'
		throw PeParseError.truncated
	end 'oob'
	let b0 = try buf.get(offset) otherwise panic("readWordLE: bounds checked above")
	let b1 = try buf.get(offset + 1) otherwise panic("readWordLE: bounds checked above")
	return b0 or (b1 shl 8)
end 'readWordLE'

// Read a 32-bit little-endian unsigned int at `offset` from `buf`.
function readDwordLE(buf ByteArray, offset SectionFileOffset) returns RdataValue throws PeParseError
	if offset + 4 > buf.count() 'oob'
		throw PeParseError.truncated
	end 'oob'
	let b0 = try buf.get(offset) otherwise panic("readDwordLE: bounds checked above")
	let b1 = try buf.get(offset + 1) otherwise panic("readDwordLE: bounds checked above")
	let b2 = try buf.get(offset + 2) otherwise panic("readDwordLE: bounds checked above")
	let b3 = try buf.get(offset + 3) otherwise panic("readDwordLE: bounds checked above")
	return b0 or (b1 shl 8) or (b2 shl 16) or (b3 shl 24)
end 'readDwordLE'

// Parse a PE file's section table from an in-memory copy of the executable.
// Layout reference (PE/COFF spec):
//   0x00      DOS magic ("MZ")
//   0x3C      u32 PE header file offset
//   <PE>      "PE\0\0" signature (4B), COFF header (20B), optional header (size in COFF.OptHdrSize)
//   <secs>    NumberOfSections × 40B section table entries
// Each section entry: name(8) | virtualSize(4) | virtualAddress(4) |
//   rawSize(4) | rawOffset(4) | 12 bytes padding | characteristics(4).
function parsePeSections(buf ByteArray) returns PeSectionInfoArray throws PeParseError
	let dosMagic = try readWordLE(buf, offset: 0)
	if dosMagic != 0x5A4D 'badDos'
		throw PeParseError.notPeFile
	end 'badDos'

	let peOffset = try readDwordLE(buf, offset: 0x3C)
	let peSignature = try readDwordLE(buf, offset: peOffset)
	if peSignature != 0x00004550 'badPe'
		throw PeParseError.notPeFile
	end 'badPe'

	// COFF header begins immediately after the 4-byte PE signature.
	let coff = peOffset + 4
	let numberOfSections = try readWordLE(buf, offset: coff + 2)
	let sizeOfOptionalHeader = try readWordLE(buf, offset: coff + 16)
	// Section table follows COFF (20B) + optional header.
	var entry = coff + 20 + sizeOfOptionalHeader

	var sections = PeSectionInfoArray.create()
	var idx = 0
	while idx < numberOfSections 'eachSection'
		if entry + 40 > buf.count() 'oob'
			throw PeParseError.truncated
		end 'oob'
		let name = readSectionName(buf, offset: entry)
		let virtualSize = try readDwordLE(buf, offset: entry + 8)
		// entry + 12 is virtualAddress (unused — we read the file image directly).
		let rawSize = try readDwordLE(buf, offset: entry + 16)
		let rawOffset = try readDwordLE(buf, offset: entry + 20)
		sections.push(PeSectionInfo.create(name, virtualSize: virtualSize, rawSize: rawSize, rawOffset: rawOffset))
		entry = entry + 40
		idx = idx + 1
	end 'eachSection'
	return sections
end 'parsePeSections'

// Read the 8-byte ASCII section name and strip trailing NUL padding. PE
// names are fixed-width; shorter names are zero-padded.
function readSectionName(buf ByteArray, offset SectionFileOffset) returns String
	var out = ""
	for i in 0 upto 8 'each'
		let b = try buf.get(offset + i) otherwise break
		if b == 0 'pad'
			break
		end 'pad'
		let ch = Character.fromCodepoint(b)
		out = "{out}{ch.toString()}"
	end 'each'
	return out
end 'readSectionName'

// Locate and read a named section's on-disk bytes. PE file padding stops at
// `min(virtualSize, rawSize)` — virtualSize is the logical extent of the
// section's contents, and rawSize is the file-aligned size which may include
// trailing zero padding. Reading `min(...)` matches the bootstrap and trims
// the alignment tail before the byte comparison.
function readPeSectionBytes(buf ByteArray, info PeSectionInfo) returns ByteArray
	var out = ByteArray.create()
	let logical = info.virtualSize if info.virtualSize < info.rawSize else info.rawSize
	let endOff = info.rawOffset + logical
	let cap = buf.count()
	let stop = endOff if endOff <= cap else cap
	for off in info.rawOffset upto stop 'copy'
		let b = try buf.get(off) otherwise break
		out.push(b)
	end 'copy'
	return out
end 'readPeSectionBytes'

// Format a byte array as space-separated lowercase hex for error messages.
function formatHexBytes(bytes ByteArray) returns String
	var out = ""
	let n = bytes.count()
	for i in 0 upto n 'each'
		let b = try bytes.get(i) otherwise break
		if i > 0 'sep'
			out = "{out} "
		end 'sep'
		out = "{out}{b:02x}"
	end 'each'
	return out
end 'formatHexBytes'

function findSection(sections PeSectionInfoArray, name String) returns PeSectionInfo throws PeParseError
	for section in sections 'each'
		if section.name == name 'match'
			return section
		end 'match'
	end 'each'
	throw PeParseError.sectionMissing
end 'findSection'

// Read the executable, locate `.rdata`, and verify the section's leading
// bytes match `expectedSpec`. The match is a prefix-match: the runtime may
// append extra rdata-resident data (string-interner pool, witness tables,
// etc.) after the user values, so we only compare up to the expected length.
// Trailing zero file-alignment padding is excluded by capping the read at
// `virtualSize` in readPeSectionBytes.
export function checkRequiredRdataBytes(expectedSpec String, exePath FilePath) returns RdataCheckResult
	let expected = try parseRequiredRdataBytes(expectedSpec) otherwise(e) 'parseFail'
		let reason = match e 'kind'
			missingType gives "missing type tag (expected '<type> <value>')"
			unknownType gives "unknown type tag"
			badInteger gives "could not parse integer literal"
			outOfRange gives "integer literal outside declared type's range"
			badFloat gives "could not parse float literal"
			badQuotedString gives "utf8 value missing surrounding double-quotes"
			badEscapeSequence gives "malformed escape sequence in utf8 string"
		end 'kind'
		return RdataCheckResult.create(false, message: "RequiredRdata parse error: {reason}")
	end 'parseFail'

	let exeBytes = try File.readBinary(exePath) otherwise 'readFail'
		return RdataCheckResult.create(false, message: "Failed to read executable at {exePath}")
	end 'readFail'

	let sections = try parsePeSections(exeBytes) otherwise(e) 'peFail'
		let reason = match e 'kind'
			notPeFile gives "not a PE file (DOS/PE signature missing)"
			truncated gives "PE headers truncated"
			sectionMissing gives "internal: sectionMissing thrown during parse"
		end 'kind'
		return RdataCheckResult.create(false, message: "Failed to parse PE: {reason}")
	end 'peFail'

	let rdata = try findSection(sections, name: ".rdata") otherwise 'noRdata'
		return RdataCheckResult.create(false, message: "PE does not contain .rdata section")
	end 'noRdata'

	let actual = readPeSectionBytes(exeBytes, info: rdata)
	let expectedLen = expected.count()
	let actualLen = actual.count()

	if actualLen < expectedLen 'tooShort'
		return RdataCheckResult.create(false, message: ".rdata mismatch.\nExpected ({expectedLen} bytes): {formatHexBytes(expected)}\nActual ({actualLen} bytes): {formatHexBytes(actual)}")
	end 'tooShort'

	for i in 0 upto expectedLen 'eachByte'
		let want = try expected.get(i) otherwise panic("checkRequiredRdataBytes: i < expectedLen invariant")
		let got = try actual.get(i) otherwise panic("checkRequiredRdataBytes: i < actualLen >= expectedLen invariant")
		if want != got 'mismatch'
			return RdataCheckResult.create(false, message: ".rdata mismatch.\nExpected ({expectedLen} bytes): {formatHexBytes(expected)}\nActual ({actualLen} bytes): {formatHexBytes(actual)}")
		end 'mismatch'
	end 'eachByte'

	return RdataCheckResult.create(true, message: "")
end 'checkRequiredRdataBytes'

// --- RequiredLowering validation ---

type LoweringCheckResult
	export var passed bool
	export var message String

	static function create(passed bool, message String) returns LoweringCheckResult
		return Self{passed: passed, message: message}
	end 'create'
end 'LoweringCheckResult'

function checkRequiredLowering(expected String, actual String) returns LoweringCheckResult
	let expNorm = normalizeLowering(expected)
	let actNorm = normalizeLowering(actual)
	if expNorm != actNorm 'mismatch'
		return LoweringCheckResult.create(false, message: "Lowering mismatch.\nExpected:\n{expNorm}\nActual:\n{actNorm}")
	end 'mismatch'
	return LoweringCheckResult.create(true, message: "")
end 'checkRequiredLowering'

function normalizeLowering(text String) returns String
	let lines = text.split("\n")
	var result = ""
	var first = true

	for line in lines 'eachLine'
		let trimmed = trimWhitespace(line)
		if trimmed.isEmpty() 'skipEmpty'
			continue
		end 'skipEmpty'
		if first 'isFirst'
			result = trimmed
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}\n{trimmed}"
		end 'notFirst'
	end 'eachLine'

	return result
end 'normalizeLowering'

// --- Update RequiredLowering blocks in spec files ---

// Update a single spec file with lowering logs collected during test runs.
function updateSpecLowering(specPath FilePath, targetKey String, results TestResultArray)
	var specContent = try File.readText(specPath) otherwise return

	var modified = false
	var totalUpdated = 0

	for result in results 'eachResult'
		if result.loweringLog.isEmpty() 'noLog'
			continue
		end 'noLog'

		let updatedContent = updateLoweringBlock(specContent, testName: result.testName, targetKey: targetKey, loweringLog: result.loweringLog)
		if updatedContent != specContent 'changed'
			specContent = updatedContent
			modified = true
			totalUpdated = totalUpdated + 1
			logInfo(LogCategory.testing, message: () gives "Updated RequiredLowering:{targetKey} for {result.testName}")
		end 'changed'
	end 'eachResult'

	if modified 'writeBack'
		try File.writeText(specPath, content: specContent) otherwise 'writeErr'
			logError(LogCategory.testing, message: () gives "Failed to write spec: {specPath}")
		end 'writeErr'
	end 'writeBack'

	if totalUpdated > 0 'showCount'
		logInfo(LogCategory.testing, message: () gives "Updated {totalUpdated} RequiredLowering block(s) in {specPath}")
	end 'showCount'
end 'updateSpecLowering'

// Update or insert a RequiredLowering:{targetKey} block for a given test in spec content.
function updateLoweringBlock(specContent String, testName String, targetKey String, loweringLog String) returns String
	let lines = specContent.split("\n")
	let lineCount = lines.count()
	let testMarker = "<!-- test: {testName} -->"
	let blockHeader = "```RequiredLowering:{targetKey}"

	// Find the test marker line
	var testLine = -1
	for i in 0 upto lineCount 'findTest'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed == testMarker 'found'
			testLine = i
			break
		end 'found'
	end 'findTest'

	if testLine < 0 'notFound'
		return specContent
	end 'notFound'

	// Find the boundary: next test marker or end of file
	var nextTestLine = lines.count()
	for i in (testLine + 1) upto lineCount 'findNext'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith("<!-- test:") 'isNext'
			nextTestLine = i
			break
		end 'isNext'
		if trimmed.startsWith("<!-- disabled-test:") 'isDisabledNext'
			nextTestLine = i
			break
		end 'isDisabledNext'
	end 'findNext'

	// Look for existing RequiredLowering:{targetKey} block in this test's range
	var existingStart = -1
	var existingEnd = -1
	for i in (testLine + 1) upto nextTestLine 'findExisting'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith(blockHeader) 'foundStart'
			existingStart = i
		end 'foundStart'
		if existingStart >= 0 'inBlock'
			if i > existingStart 'afterHeader'
				if trimmed == "```" 'foundEnd'
					existingEnd = i
					break
				end 'foundEnd'
			end 'afterHeader'
		end 'inBlock'
	end 'findExisting'

	if existingStart >= 0 'replaceExisting'
		if existingEnd < 0 'noEnd'
			return specContent
		end 'noEnd'
		// Replace lines existingStart..existingEnd (inclusive) with new block
		var result = ""
		let lastLine = lineCount - 1
		for i in 0 upto lineCount 'rebuild'
			if i == existingStart 'insertNew'
				result = "{result}{blockHeader}\n{loweringLog}\n```"
			end 'insertNew' else if i > existingStart 'skipOld'
				if i <= existingEnd 'inOldBlock'
					continue
				end 'inOldBlock'
				let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild: i < lineCount = lines.count() but get({i}) failed")
				result = "{result}{line}"
			end 'skipOld' else 'keepLine'
				let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild: i < lineCount = lines.count() but get({i}) failed")
				result = "{result}{line}"
			end 'keepLine'
			if i < lastLine 'addNewline'
				result = "{result}\n"
			end 'addNewline'
		end 'rebuild'
		return result
	end 'replaceExisting'

	// No block for this target. Only insert one when the test already has a
	// RequiredLowering block for some OTHER target — the author signaled
	// they want lowering checks, so the new target needs parity. Tests with
	// no RequiredLowering anywhere are left alone (this isn't a backfill
	// tool); the missing-target check at run-time only fires when another
	// target's block exists.
	var hasOtherTargetBlock = false
	for i in (testLine + 1) upto nextTestLine 'findOther'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith("```RequiredLowering:") 'isLowering'
			hasOtherTargetBlock = true
			break
		end 'isLowering'
	end 'findOther'

	if not hasOtherTargetBlock 'noOther'
		return specContent
	end 'noOther'

	// Insert before nextTestLine, after the last non-empty line of the test
	// region (so blocks stay grouped under the test marker).
	var insertBefore = nextTestLine
	while insertBefore > testLine + 1 'skipTrailingBlank'
		let prevLine = try lines.get(insertBefore - 1) otherwise break
		if not trimWhitespace(prevLine).isEmpty() 'nonBlank'
			break
		end 'nonBlank'
		insertBefore = insertBefore - 1
	end 'skipTrailingBlank'

	var result2 = ""
	let lastLine2 = lineCount - 1
	for i in 0 upto lineCount 'rebuild2'
		if i == insertBefore 'insertHere'
			// Blank line between sibling blocks for readability.
			result2 = "{result2}\n{blockHeader}\n{loweringLog}\n```\n"
		end 'insertHere'
		let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild2: i < lineCount but get({i}) failed")
		result2 = "{result2}{line}"
		if i < lastLine2 'addNewline2'
			result2 = "{result2}\n"
		end 'addNewline2'
	end 'rebuild2'
	if insertBefore >= lineCount 'insertAtEnd'
		result2 = "{result2}\n\n{blockHeader}\n{loweringLog}\n```"
	end 'insertAtEnd'
	return result2
end 'updateLoweringBlock'

// ─── Parallel batch infrastructure ───────────────────────────────────────────

// Prefix for the machine-readable result line a batch worker emits to stdout.
let workerBatchResultMarker = "WORKER_BATCH_RESULT:"

// Print one spec's failure messages, separating each failure with a blank
// line. Failure groups start with the fragment path (no leading spaces);
// indented lines that follow describe the failure cause. The blank-line
// gap before each new path keeps consecutive fragment failures visually
// distinct in the test runner output.
function logSpecFailureMessages(failures TextLineArray)
	for failMsg in failures 'eachFailure'
		if not failMsg.startsWith("  ") 'isPath'
			logError(LogCategory.testing, message: () gives "")
		end 'isPath'
		logError(LogCategory.testing, message: () gives failMsg)
	end 'eachFailure'
end 'logSpecFailureMessages'

// Join a StringArray with "|" separators (used for encoding skipped test names).
function joinPipe(names StringArray) returns String
	var result = ""
	var first = true
	for name in names 'each'
		if first 'isFirst'
			result = name
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}|{name}"
		end 'notFirst'
	end 'each'
	return result
end 'joinPipe'

// Emit one WORKER_BATCH_RESULT line on stdout. Format:
//   WORKER_BATCH_RESULT:{specName}:{passed}:compileMs:{ms}:skipped:{name1|name2|...}
// The fixed `compileMs:` and `skipped:` markers let parseBatchWorkerResult skip
// over them positionally, isolating the parser from accidental colons in names.
function emitWorkerResult(specName String, passed TestCount, compileMs Millis, skippedNames StringArray)
	let skippedStr = joinPipe(skippedNames)
	print("{workerBatchResultMarker}{specName}:{passed}:compileMs:{compileMs}:skipped:{skippedStr}\n")
end 'emitWorkerResult'

// Run multiple specs' batches in worker mode. Invoked when --worker-spec= is set;
// the value is a comma-separated list of spec names assigned to this worker.
// Warms the stdlib cache once, then runs each spec's batch sequentially, emitting
// one WORKER_BATCH_RESULT line per spec. All log output goes to stderr so it does
// not contaminate the result lines the parent needs to parse.
export function runSpecBatchWorker(workerSpecs String, filter String, target Target, verbose bool) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: () gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	// Suppress all log output below ERROR (matches the parent runner's policy)
	// so the worker's stderr stream is dominated by real failures rather than
	// "Compiling stdlib cache..." chatter the parent would have to forward.
	// Re-enable testing INFO so verbose pass/fail lines reach the parent.
	setLogLevel(LogLevel.ERROR)
	warmStdlibCache(target)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let specCacheDir = fragmentDir.join(".spec-cache")

	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Process.execute("mkdir -p {fragmentDir}", timeoutMs: 5000)
	end 'noFragDir'
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	let specNames = workerSpecs.split(",")
	for specName in specNames 'eachSpec'
		let cacheSpecDir = specCacheDir.join(specName)
		let fragSpecDir = fragmentDir.join(specName)
		if not Directory.exists(cacheSpecDir) 'noCacheSpecDir'
			_ = Directory.create(cacheSpecDir)
		end 'noCacheSpecDir'
		if not Directory.exists(fragSpecDir) 'noFragSpecDir'
			_ = Directory.create(fragSpecDir)
		end 'noFragSpecDir'

		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise 'readErr'
			logError(LogCategory.testing, message: () gives "Could not read spec: {specPath}")
			emitWorkerResult(specName, passed: 0, compileMs: 0, skippedNames: StringArray.create())
			continue
		end 'readErr'

		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			emitWorkerResult(specName, passed: 0, compileMs: 0, skippedNames: StringArray.create())
			continue
		end 'isDraft'

		let tests = parseSpecFile(content, targetKey: targetKey)
		let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
		let batchable = unit.batchable

		if batchable.count() == 0 'noBatch'
			emitWorkerResult(specName, passed: 0, compileMs: 0, skippedNames: StringArray.create())
			continue
		end 'noBatch'

		// Reset per-spec so the result line reports this spec's compile time only.
		totalCompileMs = 0
		let outcome = runSpecBatch(batchable, specName: specName, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target)

		if verbose 'showBatch'
			for verboseLine in outcome.verboseLines 'eachVerbose'
				logInfo(LogCategory.testing, message: () gives verboseLine)
			end 'eachVerbose'
		end 'showBatch'

		emitWorkerResult(specName, passed: outcome.passed, compileMs: totalCompileMs, skippedNames: outcome.skippedTestNames)
	end 'eachSpec'
	return 0
end 'runSpecBatchWorker'

// Markers for the singles worker protocol. The `FAIL` lines carry one fragment-
// failure message each (verbatim after the prefix); the `RESULT` line summarises
// pass/fail counts and compile time for a spec.
let workerSingleFailMarker = "WORKER_SINGLE_FAIL:"
let workerSingleResultMarker = "WORKER_SINGLE_RESULT:"

// Breadcrumb marker workers emit on stderr right before each compile. The
// parent uses the most recent one to identify which compile triggered a panic.
// Format: `WORKER_COMPILING:<label>\n` where label is `spec/test` for single
// fragments, `spec (batch of N)` for batch compiles. Stripped by the parent
// before forwarding stderr so they don't pollute normal test output.
let workerCompilingMarker = "WORKER_COMPILING:"

// Emit the breadcrumb. Workers call this immediately before each compile so
// that if the compile panics, the parent can read the last breadcrumb and
// report which test was being compiled.
function emitWorkerCompiling(label String)
	printError("{workerCompilingMarker}{label}\n")
end 'emitWorkerCompiling'

// Pull the most recent `WORKER_COMPILING:` label out of the worker's stderr,
// or empty if none. Walks lines; the last match wins, since panics happen
// during the most recent compile.
function lastCompilingLabelFromStderr(stderr String) returns String
	var lastLabel = ""
	let lines = stderr.split("\n")
	for line in lines 'each'
		let trimmed = trimWhitespace(line)
		if not trimmed.startsWith(workerCompilingMarker) 'notMarker'
			continue
		end 'notMarker'
		// The marker ends in `:` and the payload follows. Find the first colon
		// so we don't have to take the marker's character count manually.
		let colonIdx = try trimmed.findFirst(":") otherwise continue
		let afterColon = try trimmed.indexAfter(colonIdx) otherwise continue
		lastLabel = trimmed.slice(afterColon, endIndex: trimmed.endIndex())
	end 'each'
	return lastLabel
end 'lastCompilingLabelFromStderr'

// Strip `WORKER_COMPILING:` lines from a stderr blob so the parent's normal
// forwarding doesn't dump them on the user. We keep the trailing newline of
// each non-stripped line intact so multi-line panic traces stay readable.
function stripCompilingBreadcrumbs(stderr String) returns String
	if not stderr.contains(workerCompilingMarker) 'fastPath'
		return stderr
	end 'fastPath'
	let lines = stderr.split("\n")
	var out = ""
	var first = true
	for line in lines 'each'
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith(workerCompilingMarker) 'skip'
			continue
		end 'skip'
		if first 'firstLine'
			out = line
			first = false
		end 'firstLine' else 'restLine'
			out = "{out}\n{line}"
		end 'restLine'
	end 'each'
	return out
end 'stripCompilingBreadcrumbs'

// True if the worker's stderr looks like a runtime panic from the compiler
// itself (not a test fragment's panic — those are captured into the per-test
// .err file, not the worker's own stderr). The runtime emits panics in a fixed
// format: a `panic at <file>:<line>: <msg>` line followed by `Stack trace:`
// and one `  in <funcName>` per frame. Detecting both anchors avoids false
// positives from logs that incidentally contain the word "panic".
function workerStderrIsCompilerPanic(stderr String) returns bool
	if stderr.isEmpty() 'empty'
		return false
	end 'empty'
	if not stderr.contains("panic at ") 'noPanicAt'
		return false
	end 'noPanicAt'
	return stderr.contains("\nStack trace:")
end 'workerStderrIsCompilerPanic'

// Abort the parent runner immediately with the worker's panic output. Called
// when a worker subprocess panicked during compilation: re-running the same
// fragment in a fresh subprocess would just re-panic, so further retries waste
// minutes. Print the worker's stderr verbatim (it already includes the panic
// message and stack trace) and panic the parent with a one-line summary so
// the test run aborts with a non-zero exit code.
function abortOnWorkerCompilerPanic(workerLabel String, stderr String)
	let compilingLabel = lastCompilingLabelFromStderr(stderr)
	let cleaned = stripCompilingBreadcrumbs(stderr)
	printError("\n=== Compiler panic in worker ({workerLabel}) — aborting test run ===\n")
	if not compilingLabel.isEmpty() 'hasLabel'
		printError("Panicked while compiling: {compilingLabel}\n")
	end 'hasLabel'
	printError(cleaned)
	if not cleaned.endsWith("\n") 'noTrailingNl'
		printError("\n")
	end 'noTrailingNl'
	if compilingLabel.isEmpty() 'noLabel'
		panic("Compiler panicked while running spec tests; see stderr above")
	end 'noLabel'
	panic("Compiler panicked while compiling {compilingLabel}; see stderr above")
end 'abortOnWorkerCompilerPanic'

// Emit one WORKER_SINGLE_RESULT summary line for a spec.
// Format: WORKER_SINGLE_RESULT:{specName}:{passed}:{failed}:compileMs:{ms}
function emitWorkerSinglesResult(specName String, passed TestCount, failed TestCount, compileMs Millis)
	print("{workerSingleResultMarker}{specName}:{passed}:{failed}:compileMs:{compileMs}\n")
end 'emitWorkerSinglesResult'

// Emit one failure line for the given spec. The remainder of the line after the
// prefix is the failure text with newlines escaped so the parent's line-based
// reader sees a single `\n`-terminated record per call. specName contains no
// colons so the boundary between marker and payload is unambiguous.
function emitWorkerSinglesFail(specName String, line String)
	print("{workerSingleFailMarker}{specName}:{encodeFailPayload(line)}\n")
end 'emitWorkerSinglesFail'

// Encode a multi-line failure payload into a single line so the parent's
// line-based reader sees a single `\n`-terminated record per call.
// Backslash-first so the subsequent newline/CR rules don't double-escape
// the inserted backslashes. Reversed by `decodeFailPayload`.
function encodeFailPayload(s String) returns String
	var result = s.replace("\\", with: "\\\\")
	result = result.replace("\n", with: "\\n")
	result = result.replace("\r", with: "\\r")
	return result
end 'encodeFailPayload'

// Reverse of `encodeFailPayload`. Walks the bytes once so escape sequences
// don't recursively re-expand: `\\` → `\`, `\n` → newline, `\r` → CR.
function decodeFailPayload(s String) returns String
	let bytes = s.toByteArray()
	let n = bytes.count()
	var result = ByteArray.create()
	var i = 0
	while i < n 'walk'
		let b = try bytes.get(i) otherwise break
		if b == '\\' and i + 1 < n 'isEscape'
			let nextByte = try bytes.get(i + 1) otherwise 0
			if nextByte == 'n' 'isN'
				result.push(10 as Byte)
				i = i + 2
				continue
			end 'isN'
			if nextByte == 'r' 'isR'
				result.push(13 as Byte)
				i = i + 2
				continue
			end 'isR'
			if nextByte == '\\' 'isBackslash'
				result.push(92 as Byte)
				i = i + 2
				continue
			end 'isBackslash'
		end 'isEscape'
		result.push(b)
		i = i + 1
	end 'walk'
	return String.from(result)
end 'decodeFailPayload'

// Run the non-batchable (single) tests for a comma-separated list of specs.
// Mirrors runSpecBatchWorker for the non-batchable path so a panic in compile
// pipeline code (which would otherwise kill the parent runner) is contained
// here: the parent observes a missing/short result stream, marks the spec as
// failed, and continues. Each test is compiled via runTestFromFragment, the
// same machinery the in-process Phase 3/5 paths use.
export function runSpecSinglesWorker(workerSpecs String, filter String, target Target, verbose bool) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: () gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	setLogLevel(LogLevel.ERROR)
	warmStdlibCache(target)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let specCacheDir = fragmentDir.join(".spec-cache")

	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Process.execute("mkdir -p {fragmentDir}", timeoutMs: 5000)
	end 'noFragDir'
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	let specNames = workerSpecs.split(",")
	for specName in specNames 'eachSpec'
		let cacheSpecDir = specCacheDir.join(specName)
		let fragSpecDir = fragmentDir.join(specName)
		if not Directory.exists(cacheSpecDir) 'noCacheSpecDir'
			_ = Directory.create(cacheSpecDir)
		end 'noCacheSpecDir'
		if not Directory.exists(fragSpecDir) 'noFragSpecDir'
			_ = Directory.create(fragSpecDir)
		end 'noFragSpecDir'

		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise 'readErr'
			logError(LogCategory.testing, message: () gives "Could not read spec: {specPath}")
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'readErr'

		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'isDraft'

		let tests = parseSpecFile(content, targetKey: targetKey)
		let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)

		if unit.nonBatchable.count() == 0 and unit.missingLoweringCount == 0 'noSingles'
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'noSingles'

		totalCompileMs = 0
		let (sp, sf, failures) = runSingleTests(unit, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, verbose: verbose)

		for failLine in failures 'eachFailure'
			emitWorkerSinglesFail(specName, line: failLine)
		end 'eachFailure'

		emitWorkerSinglesResult(specName, passed: sp, failed: sf, compileMs: totalCompileMs)
	end 'eachSpec'
	return 0
end 'runSpecSinglesWorker'

// Fallback worker mode: run a specified list of test names from each spec via
// the per-fragment path. Uses the same WORKER_SINGLE_FAIL/WORKER_SINGLE_RESULT
// protocol as the singles worker so the parent's collection code is shared.
// `groupsArg` is `spec1:t1|t2;spec2:t3|t4` — semicolons separate spec groups,
// colons separate the spec name from its pipe-joined test-name list.
export function runSpecFallbackWorker(groupsArg String, filter String, target Target, verbose bool) returns ExitCode
	// `filter` is accepted for symmetry with the singles worker; the parent has
	// already filtered when it built the test-name list. We log it for
	// debugging when verbose so the unused-variable check is satisfied.
	if verbose and not filter.isEmpty() 'showFilter'
		logInfo(LogCategory.testing, message: () gives "[FALLBACK WORKER] filter (informational, ignored): {filter}")
	end 'showFilter'
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: () gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	setLogLevel(LogLevel.ERROR)
	warmStdlibCache(target)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let specCacheDir = fragmentDir.join(".spec-cache")

	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Process.execute("mkdir -p {fragmentDir}", timeoutMs: 5000)
	end 'noFragDir'
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	let groups = groupsArg.split(";")
	for group in groups 'eachGroup'
		let trimmedGroup = trimWhitespace(group)
		if trimmedGroup.isEmpty() 'emptyGroup'
			continue
		end 'emptyGroup'
		let colonIdx = try trimmedGroup.findFirst(":") otherwise 'badGroup'
			logError(LogCategory.testing, message: () gives "[FALLBACK WORKER] malformed group (no colon): {trimmedGroup}")
			continue
		end 'badGroup'
		let specName = trimmedGroup.slice(trimmedGroup.startIndex(), endIndex: colonIdx)
		let afterColon = try trimmedGroup.indexAfter(colonIdx) otherwise 'badGroupAfter'
			logError(LogCategory.testing, message: () gives "[FALLBACK WORKER] malformed group (truncated): {trimmedGroup}")
			continue
		end 'badGroupAfter'
		let namesPart = trimmedGroup.slice(afterColon, endIndex: trimmedGroup.endIndex())
		let testNames = namesPart.split("|")

		let cacheSpecDir = specCacheDir.join(specName)
		let fragSpecDir = fragmentDir.join(specName)
		if not Directory.exists(cacheSpecDir) 'noCacheSpecDir'
			_ = Directory.create(cacheSpecDir)
		end 'noCacheSpecDir'
		if not Directory.exists(fragSpecDir) 'noFragSpecDir'
			_ = Directory.create(fragSpecDir)
		end 'noFragSpecDir'

		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise 'readErr'
			logError(LogCategory.testing, message: () gives "Could not read spec: {specPath}")
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'readErr'

		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'isDraft'

		let allTests = parseSpecFile(content, targetKey: targetKey)
		// Build a synthetic SpecWorkUnit whose nonBatchable list contains exactly
		// the named tests, so runSingleTests routes them through the per-fragment
		// path. We do not honour `filter` here — the parent has already filtered
		// when computing the fallback list.
		var selected = SpecTestArray.create()
		for tn in testNames 'eachName'
			let trimmedName = trimWhitespace(tn)
			if trimmedName.isEmpty() 'emptyName'
				continue
			end 'emptyName'
			for t in allTests 'findTest'
				if t.name == trimmedName 'matched'
					selected.push(t)
					break
				end 'matched'
			end 'findTest'
		end 'eachName'

		if selected.count() == 0 'noSelected'
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			continue
		end 'noSelected'

		let unit = SpecWorkUnit.create(specName, nonBatchable: selected, batchable: SpecTestArray.create(), missingLoweringFailures: TextLineArray.create(), missingLoweringCount: 0 as TestCount)
		totalCompileMs = 0
		let (sp, sf, failures) = runSingleTests(unit, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, verbose: verbose)

		for failLine in failures 'eachFailure'
			emitWorkerSinglesFail(specName, line: failLine)
		end 'eachFailure'

		emitWorkerSinglesResult(specName, passed: sp, failed: sf, compileMs: totalCompileMs)
	end 'eachGroup'
	return 0
end 'runSpecFallbackWorker'

// Build the command line for a fallback worker.
function buildFallbackWorkerCommand(exePath String, groupsArg String, targetStr String, filter String, verbose bool) returns String
	var cmd = "{exePath} spec-test --worker-fallback={groupsArg} --target={targetStr} --workers=1"
	if not filter.isEmpty() 'hasFilter'
		cmd = "{cmd} --filter={filter}"
	end 'hasFilter'
	if verbose 'isVerbose'
		cmd = "{cmd} --verbose"
	end 'isVerbose'
	return cmd
end 'buildFallbackWorkerCommand'

// Spawn fallback workers in parallel via captureStart, then drain via
// captureStdout/captureStderr/captureWait. Each worker handles a round-robin
// chunk of units encoded as a `;`-joined groupsArg. Phase 5 runs after Phase 4
// has drained and closed every batch-worker handle, but the drain_both
// runtime fix (50ms initial WaitForSingleObject + ReadFile-fallback on
// peek-FALSE) makes the race-free even when other captures are still alive.
function runFallbackPhase(fallbackUnits SpecWorkUnitArray, exePath String, targetStr String, filter String, verbose bool, fragmentDir FilePath, numWorkers TestCount) returns (TestCount, TestCount)
	if fallbackUnits.count() == 0 'noWork'
		return (0 as TestCount, 0 as TestCount)
	end 'noWork'

	// Build a flat list of (specName, testName) pairs so we can round-robin
	// individual tests across workers — chunking by spec leaves us bottlenecked
	// on the slowest spec when one fallback unit has many more tests than another.
	var specForTest = StringArray.create()
	var testNames = StringArray.create()
	var seenSpecs = StringArray.create()
	for unit in fallbackUnits 'buildPairs'
		if unit.nonBatchable.count() == 0 'empty'
			continue
		end 'empty'
		seenSpecs.push(unit.specName)
		for t in unit.nonBatchable 'eachTest'
			specForTest.push(unit.specName)
			testNames.push(t.name)
		end 'eachTest'
	end 'buildPairs'

	let totalTestsInFallback = testNames.count()
	if totalTestsInFallback == 0 'noTests'
		return (0 as TestCount, 0 as TestCount)
	end 'noTests'
	markPhase("fallback: {seenSpecs.count()} units, {totalTestsInFallback} tests")

	// Use as many workers as we have tests, capped at numWorkers. Round-robin
	// individual tests so each worker compiles ~total/N tests (one compile per
	// test). With 36 tests across 8 workers, worst-case worker gets 5 compiles.
	var fallbackWorkerCount = numWorkers
	if (totalTestsInFallback as TestCount) < fallbackWorkerCount 'fewerTests'
		fallbackWorkerCount = totalTestsInFallback as TestCount
	end 'fewerTests'
	if fallbackWorkerCount < 1 'tooFew'
		fallbackWorkerCount = 1 as TestCount
	end 'tooFew'

	// Phase A: spawn workers in parallel via captureStart. Each worker receives
	// a round-robin slice of the (spec, test) pairs, regrouped into the
	// `spec1:t1|t2;spec2:t3` format the worker dispatcher expects.
	var handles = BatchWorkerHandleArray.create()
	for i in 0 upto fallbackWorkerCount 'spawnChunks'
		var groupsArg = ""
		var chunkSpecs = ""
		var lastSpec = ""
		var k = i
		while k < totalTestsInFallback 'collectChunk'
			let sn = try specForTest.get(k) otherwise break
			let tn = try testNames.get(k) otherwise break
			if sn != lastSpec 'newSpec'
				if groupsArg.isEmpty() 'firstGroup'
					groupsArg = "{sn}:{tn}"
					chunkSpecs = sn
				end 'firstGroup' else 'notFirstGroup'
					groupsArg = "{groupsArg};{sn}:{tn}"
					chunkSpecs = "{chunkSpecs},{sn}"
				end 'notFirstGroup'
				lastSpec = sn
			end 'newSpec' else 'sameSpec'
				groupsArg = "{groupsArg}|{tn}"
			end 'sameSpec'
			k = k + fallbackWorkerCount
		end 'collectChunk'
		if not groupsArg.isEmpty() 'hasChunk'
			let cmd = buildFallbackWorkerCommand(exePath, groupsArg: groupsArg, targetStr: targetStr, filter: filter, verbose: verbose)
			let (captureOut, captureErr) = captureFilePaths(fragmentDir, stem: "fb-{i}")
			let handle = Process.captureStart(cmd, stdoutPath: captureOut, stderrPath: captureErr)
			handles.push(BatchWorkerHandle.create(chunkSpecs, handle: handle))
		end 'hasChunk'
	end 'spawnChunks'

	// Phase B: drain each worker. captureStdout reads until EOF; other workers
	// continue running concurrently in the OS background, so total wall time
	// is gated by the slowest worker rather than the sum.
	var workerStdouts = TextLineArray.create()
	var workerSpecLists = StringArray.create()
	for h in handles 'drainHandles'
		let stdoutStr = Process.captureStdout(h.handle)
		let stderrStr = Process.captureStderr(h.handle)
		_ = Process.captureWait(h.handle, timeoutMs: 0)
		// Abort if the worker panicked — see batch/singles drain sites for
		// rationale.
		if workerStderrIsCompilerPanic(stderrStr) 'panicked'
			abortOnWorkerCompilerPanic("fallback [{h.specNames}]", stderr: stderrStr)
		end 'panicked'
		let cleanedStderr = stripCompilingBreadcrumbs(stderrStr)
		if not cleanedStderr.isEmpty() 'hasStderr'
			printError(cleanedStderr)
		end 'hasStderr'
		workerStdouts.push(stdoutStr)
		workerSpecLists.push(h.specNames)
	end 'drainHandles'

	var totalPassed = 0 as TestCount
	var totalFailed = 0 as TestCount

	// Flat per-line buffers keyed by spec name; we filter by name at print time.
	// Avoids the borrow-checker contortions of nested-array mutation.
	var failOwners = StringArray.create()
	var failPayloads = TextLineArray.create()

	// Walk one worker's output at a time so per-worker `pending` tracking stays
	// scoped to that worker's assignment; a missing-result spec from worker A
	// must not be retried inside worker B's output.
	let workerOutCount = workerStdouts.count()
	for wi in 0 upto workerOutCount 'eachWorker'
		let stdout = try workerStdouts.get(wi) otherwise ""
		let specsStr = try workerSpecLists.get(wi) otherwise ""
		var pending = specsStr.split(",")

		let lines = stdout.split("\n")
		for line in lines 'parseLines'
			let trimmedLine = trimWhitespace(line)
			if trimmedLine.startsWith(workerSingleFailMarker) 'isFail'
				var matched = false
				for pn in pending 'matchSpec'
					let payload = parseSinglesFailLine(trimmedLine, specName: pn)
					if not payload.isEmpty() or trimmedLine == "{workerSingleFailMarker}{pn}:" 'isPnMatch'
						failOwners.push(pn)
						failPayloads.push(payload)
						matched = true
						break
					end 'isPnMatch'
				end 'matchSpec'
				if not matched 'unmatched'
					logError(LogCategory.testing, message: () gives "[FALLBACK ERROR] orphan fail line: {trimmedLine}")
				end 'unmatched'
				continue
			end 'isFail'
			if not trimmedLine.startsWith(workerSingleResultMarker) 'notResult'
				continue
			end 'notResult'
			let result = parseSinglesResultLine(trimmedLine)
			if not result.valid 'invalidResult'
				logError(LogCategory.testing, message: () gives "[FALLBACK ERROR] malformed result line: {trimmedLine}")
				continue
			end 'invalidResult'

			var remaining = StringArray.create()
			for pn in pending 'filterPending'
				if pn != result.specName 'keep'
					remaining.push(pn)
				end 'keep'
			end 'filterPending'
			pending = remaining

			totalCompileMs = totalCompileMs + result.compileMs
			totalPassed = totalPassed + result.passed
			totalFailed = totalFailed + result.failed

			if result.failed > 0 'hasFail'
				let specTotal = result.passed + result.failed
				logError(LogCategory.testing, message: () gives "[FAIL] {result.specName} fallback ({result.passed}/{specTotal})")
				logSpecFailuresFor(failOwners, payloads: failPayloads, specName: result.specName)
			end 'hasFail'
		end 'parseLines'

		// A worker that crashed mid-batch leaves its remaining specs unreported.
		// Re-run each missing test in its own subprocess so a single panicking
		// test only blames itself; everything else in the same batch still gets
		// a real pass/fail. The retry walks every pending spec → every test in
		// that spec → one subprocess per test.
		for pendingName in pending 'handleMissing'
			let pn = trimWhitespace(pendingName)
			if pn.isEmpty() 'emptyName'
				continue
			end 'emptyName'
			var crashedTests = SpecTestArray.create()
			for unit in fallbackUnits 'findUnit'
				if unit.specName == pn 'matched'
					crashedTests = cloneSpecTests(unit.nonBatchable)
					break
				end 'matched'
			end 'findUnit'
			if crashedTests.count() == 0 'noFallback'
				continue
			end 'noFallback'
			markPhase("fallback retrying spec [{pn}] with {crashedTests.count()} tests")
			let (rp, rf) = retryAndAccountCrashedSpec(pn, tests: crashedTests, exePath: exePath, targetStr: targetStr, verbose: verbose, failOwners: failOwners, failPayloads: failPayloads, phaseLabel: "fallback", fragmentDir: fragmentDir)
			totalPassed = totalPassed + rp
			totalFailed = totalFailed + rf
		end 'handleMissing'
	end 'eachWorker'

	return (totalPassed, totalFailed)
end 'runFallbackPhase'

// Retry crashed tests one-per-subprocess, accumulate the results into the
// caller's running totals, and log the [FAIL] lines (per-test crashes plus
// regular failures). `phaseLabel` distinguishes "fallback" vs the singles
// phase label in log output. Returns (added passed, added failed) so the
// caller can keep its own running totals in sync.
function retryAndAccountCrashedSpec(specName String, tests SpecTestArray, exePath String, targetStr String, verbose bool, failOwners StringArray, failPayloads TextLineArray, phaseLabel String, fragmentDir FilePath) returns (TestCount, TestCount)
	let (rp, rf, rfMissing) = retryFallbackTestsIndividually(specName, tests: tests, exePath: exePath, targetStr: targetStr, verbose: verbose, failOwners: failOwners, failPayloads: failPayloads, fragmentDir: fragmentDir)
	let specTotal = rp + rf
	if rf > 0 'someFailed'
		logError(LogCategory.testing, message: () gives "[FAIL] {specName} {phaseLabel} ({rp}/{specTotal})")
		logSpecFailuresFor(failOwners, payloads: failPayloads, specName: specName)
	end 'someFailed'
	if rfMissing > 0 'someMissing'
		logError(LogCategory.testing, message: () gives "[FAIL] {specName} ({rfMissing} {phaseLabel} test(s) crashed individually too)")
	end 'someMissing'
	return (rp, rf)
end 'retryAndAccountCrashedSpec'

// Run each test in `tests` in a fresh fallback-worker subprocess. A panic in
// one test only kills its own subprocess, leaving the others' results intact.
// Returns (passed, failed, stillCrashed) — stillCrashed counts subprocesses
// that produced no result line (worker died before reporting).
function retryFallbackTestsIndividually(specName String, tests SpecTestArray, exePath String, targetStr String, verbose bool, failOwners StringArray, failPayloads TextLineArray, fragmentDir FilePath) returns (TestCount, TestCount, TestCount)
	var passed = 0 as TestCount
	var failed = 0 as TestCount
	var crashed = 0 as TestCount
	for t in tests 'eachTest'
		let groupsArg = "{specName}:{t.name}"
		let cmd = buildFallbackWorkerCommand(exePath, groupsArg: groupsArg, targetStr: targetStr, filter: "", verbose: verbose)
		let (captureOut, captureErr) = captureFilePaths(fragmentDir, stem: "retry-{specName}-{t.name}")
		let pr = Process.captureOutput(cmd, stdoutPath: captureOut, stderrPath: captureErr, timeoutMs: 0)
		// A panic during the per-test retry means the compiler is broken for
		// this test — looping over the rest will just waste time re-panicking.
		if workerStderrIsCompilerPanic(pr.stderr) 'panicked'
			abortOnWorkerCompilerPanic("retry [{specName}/{t.name}]", stderr: pr.stderr)
		end 'panicked'
		let cleanedStderr = stripCompilingBreadcrumbs(pr.stderr)
		if not cleanedStderr.isEmpty() 'hasStderr'
			printError(cleanedStderr)
		end 'hasStderr'
		var sawResult = false
		let lines = pr.stdout.split("\n")
		for line in lines 'parseLines'
			let trimmedLine = trimWhitespace(line)
			if trimmedLine.startsWith(workerSingleFailMarker) 'isFail'
				let payload = parseSinglesFailLine(trimmedLine, specName: specName)
				if not payload.isEmpty() or trimmedLine == "{workerSingleFailMarker}{specName}:" 'isPnMatch'
					failOwners.push(specName)
					failPayloads.push(payload)
				end 'isPnMatch'
				continue
			end 'isFail'
			if not trimmedLine.startsWith(workerSingleResultMarker) 'notResult'
				continue
			end 'notResult'
			let result = parseSinglesResultLine(trimmedLine)
			if not result.valid 'invalidResult'
				continue
			end 'invalidResult'
			totalCompileMs = totalCompileMs + result.compileMs
			passed = passed + result.passed
			failed = failed + result.failed
			sawResult = true
		end 'parseLines'
		if not sawResult 'workerCrashed'
			// One subprocess per test, so a missing result means *this* test's
			// compile crashed. Charge the failure to it specifically rather
			// than re-blaming the whole spec.
			failed = failed + (1 as TestCount)
			crashed = crashed + (1 as TestCount)
			failOwners.push(specName)
			failPayloads.push("  {specName}/{t.name}: worker crashed (panic, timeout, or non-zero exit)")
		end 'workerCrashed'
	end 'eachTest'
	return (passed, failed, crashed)
end 'retryFallbackTestsIndividually'

// Aggregated outcome for one spec collected from a singles worker's stdout.
type SinglesWorkerResult
	export var specName String
	export var passed TestCount
	export var failed TestCount
	export var compileMs Millis
	export var failures TextLineArray
	export var valid bool

	export static function invalid() returns SinglesWorkerResult
		return Self{specName: "", passed: 0, failed: 0, compileMs: 0, failures: TextLineArray.create(), valid: false}
	end 'invalid'

	export static function create(specName String, passed TestCount, failed TestCount, compileMs Millis, failures TextLineArray) returns SinglesWorkerResult
		return Self{specName: specName, passed: passed, failed: failed, compileMs: compileMs, failures: failures, valid: true}
	end 'create'
end 'SinglesWorkerResult'

// Parse one WORKER_SINGLE_RESULT line. Returns invalid() on any parse failure.
// Format: WORKER_SINGLE_RESULT:{specName}:{passed}:{failed}:compileMs:{ms}
function parseSinglesResultLine(line String) returns SinglesWorkerResult
	let parts = line.split(":")
	if parts.count() < 6 'tooFew'
		return SinglesWorkerResult.invalid()
	end 'tooFew'
	let tag = try parts.get(0) otherwise return SinglesWorkerResult.invalid()
	if tag != "WORKER_SINGLE_RESULT" 'wrongTag'
		return SinglesWorkerResult.invalid()
	end 'wrongTag'
	let specName = try parts.get(1) otherwise return SinglesWorkerResult.invalid()
	if specName.isEmpty() 'noSpec'
		return SinglesWorkerResult.invalid()
	end 'noSpec'
	let passedStr = try parts.get(2) otherwise return SinglesWorkerResult.invalid()
	let passed = try int.fromString(passedStr) otherwise return SinglesWorkerResult.invalid()
	let failedStr = try parts.get(3) otherwise return SinglesWorkerResult.invalid()
	let failed = try int.fromString(failedStr) otherwise return SinglesWorkerResult.invalid()
	let compileMsStr = try parts.get(5) otherwise return SinglesWorkerResult.invalid()
	let compileMs = try int.fromString(compileMsStr) otherwise return SinglesWorkerResult.invalid()
	return SinglesWorkerResult.create(specName, passed: passed as TestCount, failed: failed as TestCount, compileMs: compileMs as Millis, failures: TextLineArray.create())
end 'parseSinglesResultLine'

// Extract the failure-text payload from a WORKER_SINGLE_FAIL line, given the
// spec name. Returns the empty string if the prefix doesn't match. The marker
// is ASCII and spec names contain no colons, so the second colon in the line
// (the one immediately after `{marker}{specName}`) is the payload boundary.
function parseSinglesFailLine(line String, specName String) returns String
	let prefix = "{workerSingleFailMarker}{specName}:"
	if not line.startsWith(prefix) 'noPrefix'
		return ""
	end 'noPrefix'
	var idx = line.startIndex()
	let prefixLen = prefix.count()
	for _ in 0 upto prefixLen 'advance'
		idx = try line.indexAfter(idx) otherwise return ""
	end 'advance'
	return decodeFailPayload(line.slice(idx, endIndex: line.endIndex()))
end 'parseSinglesFailLine'

// A running singles-worker subprocess.
type SinglesWorkerHandle
	export var specNames String
	export var handle ProcessHandle

	export static function create(specNames String, handle ProcessHandle) returns SinglesWorkerHandle
		return Self{specNames: specNames, handle: handle}
	end 'create'
end 'SinglesWorkerHandle'

export typealias SinglesWorkerHandleArray = Array with SinglesWorkerHandle

// Build the command line for a singles worker.
// --workers=1 prevents the child from spawning its own sub-workers.
function buildSinglesWorkerCommand(exePath String, workerSpecs String, targetStr String, filter String, verbose bool) returns String
	var cmd = "{exePath} spec-test --worker-singles={workerSpecs} --target={targetStr} --workers=1"
	if not filter.isEmpty() 'hasFilter'
		cmd = "{cmd} --filter={filter}"
	end 'hasFilter'
	if verbose 'isVerbose'
		cmd = "{cmd} --verbose"
	end 'isVerbose'
	return cmd
end 'buildSinglesWorkerCommand'

// Per-worker outcome bundled with the spec list for aggregation.
type SinglesWorkerOutcome
	export var specNames String
	export var stdout String
	export var stderr String

	export static function create(specNames String, stdout String, stderr String) returns SinglesWorkerOutcome
		return Self{specNames: specNames, stdout: stdout, stderr: stderr}
	end 'create'
end 'SinglesWorkerOutcome'

export typealias SinglesWorkerOutcomeArray = Array with SinglesWorkerOutcome

// Spawn singles workers to handle the non-batchable tests of `specNames`,
// distributing specs round-robin across `numWorkers` subprocesses. Aggregates
// pass/fail counts and failure messages back into the parent. Specs whose
// worker crashes (panic, timeout, non-zero exit) have their non-batchable
// tests counted as failed via the `units` table; we never retry in-process,
// because a deterministic panic would then take down the parent runner.
//
// Spawn singles workers in parallel via captureStart, then drain via
// captureStdout/captureStderr/captureWait. Each worker handles a round-robin
// chunk of specs. Spawning all workers up front lets the OS run them
// concurrently across cores; the drain loop then reads each in turn. The
// runtime fix to maxon_process_drain_both (50ms initial WaitForSingleObject
// + ReadFile-fallback on broken-pipe peek) makes this safe even when batch
// workers from Phase 2 are still alive in the parent.
function runSinglesPhase(specNames StringArray, units SpecWorkUnitArray, exePath String, targetStr String, filter String, verbose bool, numWorkers TestCount, phaseLabel String, fragmentDir FilePath) returns (TestCount, TestCount)
	let count = specNames.count()
	if count == 0 'noWork'
		return (0 as TestCount, 0 as TestCount)
	end 'noWork'

	var effectiveWorkers = numWorkers
	if (count as TestCount) < effectiveWorkers 'fewerSpecs'
		effectiveWorkers = count as TestCount
	end 'fewerSpecs'
	if effectiveWorkers < 1 'tooFew'
		effectiveWorkers = 1 as TestCount
	end 'tooFew'

	// Phase A: spawn every worker via captureStart so they all run in parallel.
	var handles = BatchWorkerHandleArray.create()
	for i in 0 upto effectiveWorkers 'spawnChunks'
		var specStr = ""
		var j = i
		while j < count 'collectChunk'
			let sn = try specNames.get(j) otherwise break
			if specStr.isEmpty() 'firstInChunk'
				specStr = sn
			end 'firstInChunk' else 'notFirstInChunk'
				specStr = "{specStr},{sn}"
			end 'notFirstInChunk'
			j = j + effectiveWorkers
		end 'collectChunk'
		if not specStr.isEmpty() 'hasChunk'
			let cmd = buildSinglesWorkerCommand(exePath, workerSpecs: specStr, targetStr: targetStr, filter: filter, verbose: verbose)
			let (captureOut, captureErr) = captureFilePaths(fragmentDir, stem: "sg-{i}")
			let handle = Process.captureStart(cmd, stdoutPath: captureOut, stderrPath: captureErr)
			handles.push(BatchWorkerHandle.create(specStr, handle: handle))
		end 'hasChunk'
	end 'spawnChunks'

	// Phase B: drain each worker. captureStdout blocks until that worker exits;
	// the others continue running concurrently in the OS background, so total
	// wall time is gated by the slowest worker rather than the sum.
	var outcomes = SinglesWorkerOutcomeArray.create()
	for h in handles 'collectHandles'
		let stdoutStr = Process.captureStdout(h.handle)
		let stderrStr = Process.captureStderr(h.handle)
		_ = Process.captureWait(h.handle, timeoutMs: 0)
		// Abort early on a compiler panic. Per-test retry of a deterministic
		// panic just compounds the wait — fail fast so the user sees the
		// panic now instead of after every other worker has also drained.
		if workerStderrIsCompilerPanic(stderrStr) 'panicked'
			abortOnWorkerCompilerPanic("singles [{h.specNames}]", stderr: stderrStr)
		end 'panicked'
		outcomes.push(SinglesWorkerOutcome.create(h.specNames, stdout: stdoutStr, stderr: stderrStr))
	end 'collectHandles'

	var totalPassed = 0 as TestCount
	var totalFailed = 0 as TestCount

	for w in outcomes 'collect'
		let stdout = w.stdout
		let stderr = stripCompilingBreadcrumbs(w.stderr)

		if not stderr.isEmpty() 'hasStderr'
			printError(stderr)
		end 'hasStderr'

		var pendingSpecs = w.specNames.split(",")
		// Flat per-line buffers keyed by spec name; we filter by name at print
		// time. Avoids the borrow-checker contortions of nested-array mutation.
		var failOwners = StringArray.create()
		var failPayloads = TextLineArray.create()

		let lines = stdout.split("\n")
		for line in lines 'parseLines'
			let trimmedLine = trimWhitespace(line)
			if trimmedLine.startsWith(workerSingleFailMarker) 'isFail'
				var matched = false
				for pn in pendingSpecs 'matchSpec'
					let payload = parseSinglesFailLine(trimmedLine, specName: pn)
					if not payload.isEmpty() or trimmedLine == "{workerSingleFailMarker}{pn}:" 'isPnMatch'
						failOwners.push(pn)
						failPayloads.push(payload)
						matched = true
						break
					end 'isPnMatch'
				end 'matchSpec'
				if not matched 'unmatched'
					logError(LogCategory.testing, message: () gives "[SINGLES ERROR] orphan fail line: {trimmedLine}")
				end 'unmatched'
				continue
			end 'isFail'
			if not trimmedLine.startsWith(workerSingleResultMarker) 'notResult'
				continue
			end 'notResult'
			let result = parseSinglesResultLine(trimmedLine)
			if not result.valid 'invalidResult'
				logError(LogCategory.testing, message: () gives "[SINGLES ERROR] malformed result line: {trimmedLine}")
				continue
			end 'invalidResult'

			var remaining = StringArray.create()
			for pn in pendingSpecs 'filterPending'
				if pn != result.specName 'keep'
					remaining.push(pn)
				end 'keep'
			end 'filterPending'
			pendingSpecs = remaining

			totalCompileMs = totalCompileMs + result.compileMs
			totalPassed = totalPassed + result.passed
			totalFailed = totalFailed + result.failed

			if result.failed > 0 'hasFail'
				let specTotal = result.passed + result.failed
				logError(LogCategory.testing, message: () gives "[FAIL] {result.specName} ({result.passed}/{specTotal})")
				logSpecFailuresFor(failOwners, payloads: failPayloads, specName: result.specName)
			end 'hasFail'
		end 'parseLines'

		// Specs the worker never reported a RESULT for — the worker crashed
		// (panic, timeout, or non-zero exit). For each, re-run every test in
		// its own subprocess so a single panicking test doesn't blame its
		// peers. The missing-lowering tally is structurally inert (it counts
		// tests excluded by the rewriter, not crashed compiles), so it folds
		// into `totalFailed` directly.
		for pendingName in pendingSpecs 'handleMissing'
			let pn = trimWhitespace(pendingName)
			if pn.isEmpty() 'emptyName'
				continue
			end 'emptyName'
			let unit = findUnitByName(units, specName: pn)
			let nonBatchableCount = unit.nonBatchable.count() as TestCount
			let crashedCount = nonBatchableCount + unit.missingLoweringCount
			if crashedCount == 0 'noSingles'
				continue
			end 'noSingles'
			totalFailed = totalFailed + unit.missingLoweringCount
			if nonBatchableCount > 0 'hasNonBatchable'
				let (rp, rf) = retryAndAccountCrashedSpec(pn, tests: unit.nonBatchable, exePath: exePath, targetStr: targetStr, verbose: verbose, failOwners: failOwners, failPayloads: failPayloads, phaseLabel: phaseLabel, fragmentDir: fragmentDir)
				totalPassed = totalPassed + rp
				totalFailed = totalFailed + rf
			end 'hasNonBatchable' else 'onlyMissing'
				logError(LogCategory.testing, message: () gives "[FAIL] {pn} ({crashedCount} {phaseLabel} test(s)): worker crashed (panic, timeout, or non-zero exit)")
				logSpecFailuresFor(failOwners, payloads: failPayloads, specName: pn)
			end 'onlyMissing'
		end 'handleMissing'
	end 'collect'

	return (totalPassed, totalFailed)
end 'runSinglesPhase'

// Print all failure-lines whose owner equals `specName`, in stream order.
// Mirrors logSpecFailureMessages but operates on the flat (owners, payloads)
// parallel-array buffer used by runSinglesPhase / runFallbackPhase.
function logSpecFailuresFor(owners StringArray, payloads TextLineArray, specName String)
	let count = owners.count()
	for i in 0 upto count 'each'
		let owner = try owners.get(i) otherwise continue
		if owner != specName 'skipOther'
			continue
		end 'skipOther'
		let payload = try payloads.get(i) otherwise continue
		if not payload.startsWith("  ") 'isPath'
			logError(LogCategory.testing, message: () gives "")
		end 'isPath'
		logError(LogCategory.testing, message: () gives payload)
	end 'each'
end 'logSpecFailuresFor'

// A running batch worker subprocess. `specNames` is the comma-joined list of
// spec names assigned to this worker; used to detect missing result lines.
type BatchWorkerHandle
	export var specNames String
	export var handle ProcessHandle

	export static function create(specNames String, handle ProcessHandle) returns BatchWorkerHandle
		return Self{specNames: specNames, handle: handle}
	end 'create'
end 'BatchWorkerHandle'

export typealias BatchWorkerHandleArray = Array with BatchWorkerHandle

// Assemble the command to run this executable as a batch worker.
// `workerSpecs` is a comma-joined list of spec names.
// --workers=1 prevents the child from spawning its own sub-workers.
function buildBatchWorkerCommand(exePath String, workerSpecs String, targetStr String, filter String, verbose bool) returns String
	var cmd = "{exePath} spec-test --worker-spec={workerSpecs} --target={targetStr} --workers=1"
	if not filter.isEmpty() 'hasFilter'
		cmd = "{cmd} --filter={filter}"
	end 'hasFilter'
	if verbose 'isVerbose'
		cmd = "{cmd} --verbose"
	end 'isVerbose'
	return cmd
end 'buildBatchWorkerCommand'

// Parsed outcome from one spec's WORKER_BATCH_RESULT stdout line.
type BatchWorkerResult
	export var specName String
	export var passed TestCount
	export var compileMs Millis
	export var skippedNames StringArray
	export var valid bool

	export static function invalid() returns BatchWorkerResult
		return Self{specName: "", passed: 0, compileMs: 0, skippedNames: StringArray.create(), valid: false}
	end 'invalid'

	export static function create(specName String, passed TestCount, compileMs Millis, skippedNames StringArray) returns BatchWorkerResult
		return Self{specName: specName, passed: passed, compileMs: compileMs, skippedNames: skippedNames, valid: true}
	end 'create'
end 'BatchWorkerResult'

// Parse WORKER_BATCH_RESULT:{specName}:{passed}:compileMs:{ms}:skipped:{name1|name2|...}
// Returns invalid() on any parse failure; the caller then routes all batchable
// tests for this spec to the per-fragment fallback path.
function parseBatchWorkerResult(line String) returns BatchWorkerResult
	let parts = line.split(":")
	// [0]=WORKER_BATCH_RESULT [1]=specName [2]=passed [3]=compileMs [4]=ms [5]=skipped [6]=pipe-names
	if parts.count() < 7 'tooFew'
		return BatchWorkerResult.invalid()
	end 'tooFew'
	let tag = try parts.get(0) otherwise return BatchWorkerResult.invalid()
	if tag != "WORKER_BATCH_RESULT" 'wrongTag'
		return BatchWorkerResult.invalid()
	end 'wrongTag'
	let specName = try parts.get(1) otherwise return BatchWorkerResult.invalid()
	if specName.isEmpty() 'noSpec'
		return BatchWorkerResult.invalid()
	end 'noSpec'
	let passedStr = try parts.get(2) otherwise return BatchWorkerResult.invalid()
	let passed = try int.fromString(passedStr) otherwise return BatchWorkerResult.invalid()
	let compileMsStr = try parts.get(4) otherwise return BatchWorkerResult.invalid()
	let compileMs = try int.fromString(compileMsStr) otherwise return BatchWorkerResult.invalid()
	let skippedStr = try parts.get(6) otherwise return BatchWorkerResult.invalid()
	var skippedNames = StringArray.create()
	if not skippedStr.isEmpty() 'hasSkipped'
		let nameList = skippedStr.split("|")
		for rawName in nameList 'eachName'
			let name = trimWhitespace(rawName)
			if not name.isEmpty() 'nonEmpty'
				skippedNames.push(name)
			end 'nonEmpty'
		end 'eachName'
	end 'hasSkipped'
	return BatchWorkerResult.create(specName, passed: passed as TestCount, compileMs: compileMs as Millis, skippedNames: skippedNames)
end 'parseBatchWorkerResult'

// Find a SpecWorkUnit by spec name. Panics if not found — callers only query
// for names they previously inserted into `units`.
function findUnitByName(units SpecWorkUnitArray, specName String) returns SpecWorkUnit
	for unit in units 'each'
		if unit.specName == specName 'match'
			return unit
		end 'match'
	end 'each'
	panic("findUnitByName: spec '{specName}' not found in units")
end 'findUnitByName'

// Per-spec work unit: partitioned tests and pre-computed missing-lowering failures.
type SpecWorkUnit
	export var specName String
	export var nonBatchable SpecTestArray
	export var batchable SpecTestArray
	export var missingLoweringFailures TextLineArray
	// Count of tests that failed due to missing RequiredLowering blocks.
	export var missingLoweringCount TestCount

	export static function create(specName String, nonBatchable SpecTestArray, batchable SpecTestArray, missingLoweringFailures TextLineArray, missingLoweringCount TestCount) returns SpecWorkUnit
		return Self{specName: specName, nonBatchable: nonBatchable, batchable: batchable, missingLoweringFailures: missingLoweringFailures, missingLoweringCount: missingLoweringCount}
	end 'create'

	// Total number of tests this unit will report (passed + failed combined).
	export function totalCount() returns TestCount
		return self.batchable.count() + self.nonBatchable.count() + self.missingLoweringCount
	end 'totalCount'
end 'SpecWorkUnit'

export typealias SpecWorkUnitArray = Array with SpecWorkUnit

// Partition a spec's parsed tests into batchable / non-batchable / missing-lowering buckets.
// `filter`, when non-empty, restricts to tests whose "{specName}/{test.name}" path contains it.
// A test that authors a RequiredLowering block for some target must author one for THIS
// target too — otherwise lowering changes that affect this target slip through unobserved
// (the original check is silently skipped when the target-qualified block is missing).
function partitionSpecTests(tests SpecTestArray, specName String, filter String, targetKey String) returns SpecWorkUnit
	var batchable = SpecTestArray.create()
	var nonBatchable = SpecTestArray.create()
	var missingLoweringFailures = TextLineArray.create()
	var missingLoweringCount = 0 as TestCount

	for test in tests 'partition'
		let testPath = "{specName}/{test.name}"
		if not filter.isEmpty() 'hasFilter'
			if not testPath.contains(filter) 'noMatch'
				continue
			end 'noMatch'
		end 'hasFilter'
		if test.expectation.hasAnyRequiredLowering and not test.expectation.hasRequiredLowering 'missingTargetLowering'
			missingLoweringFailures.push("specs/{specName}.md::{test.name}")
			missingLoweringFailures.push("  Missing RequiredLowering:{targetKey} block — other targets have one for this test. Run with --update-required to populate, or remove the existing target-specific blocks.")
			missingLoweringCount = missingLoweringCount + 1
			continue
		end 'missingTargetLowering'
		if isBatchable(specName, test: test) 'isBatch'
			batchable.push(test)
		end 'isBatch' else 'isSingle'
			nonBatchable.push(test)
		end 'isSingle'
	end 'partition'

	return SpecWorkUnit.create(specName, nonBatchable: nonBatchable, batchable: batchable, missingLoweringFailures: missingLoweringFailures, missingLoweringCount: missingLoweringCount)
end 'partitionSpecTests'

// Build a fallback-only SpecWorkUnit: every supplied test is filed under
// `nonBatchable` (so the per-fragment retry loop picks them up), batchable
// is empty, and no missing-lowering tally is carried. Used to convert a
// crashed batch into a fallback unit whose individual tests get retried
// in their own subprocesses.
function makeFallbackOnlyUnit(specName String, tests SpecTestArray) returns SpecWorkUnit
	return SpecWorkUnit.create(specName, nonBatchable: tests, batchable: SpecTestArray.create(), missingLoweringFailures: TextLineArray.create(), missingLoweringCount: 0 as TestCount)
end 'makeFallbackOnlyUnit'

// Copy `src` into a fresh SpecTestArray. Used at the boundary where a worker
// crash hands a unit's test list to the per-test retry loop and we need a
// freshly-owned vector.
function cloneSpecTests(src SpecTestArray) returns SpecTestArray
	var dest = SpecTestArray.create()
	for t in src 'eachTest'
		dest.push(t)
	end 'eachTest'
	return dest
end 'cloneSpecTests'

// Look up tests in `batchable` by name and append matches to `dest`. Used to
// route tests the batch rewriter rejected (or that a batch-wide failure forced
// off the batched path) onto the per-fragment fallback path.
function appendSkippedToFallback(dest SpecTestArray, batchable SpecTestArray, skippedNames StringArray)
	for skipName in skippedNames 'eachSkipped'
		for test in batchable 'findTest'
			if test.name == skipName 'matchTest'
				dest.push(test)
			end 'matchTest'
		end 'findTest'
	end 'eachSkipped'
end 'appendSkippedToFallback'

// Run per-fragment tests for `unit`. Also counts pre-computed missing-lowering
// failures toward the returned failed count.
// Returns (passed, failed, failureMessages).
function runSingleTests(unit SpecWorkUnit, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, verbose bool) returns (TestCount, TestCount, TextLineArray)
	let specName = unit.specName
	var specPassed = 0 as TestCount
	var specFailed = unit.missingLoweringCount
	var specFailures = TextLineArray.create()

	for msg in unit.missingLoweringFailures 'copyMissing'
		specFailures.push(msg)
	end 'copyMissing'

	for test in unit.nonBatchable 'eachSingle'
		let testPath = "{specName}/{test.name}"
		let fragPath = fragmentDir.join(specName).join("{test.name}.test")
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: "")

		let fragment = try parseFragment(fragPath) otherwise 'parseFailed'
			logError(LogCategory.testing, message: () gives "[FAIL] {testPath} - could not parse fragment")
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			specFailures.push("  Failed to parse fragment file")
			continue
		end 'parseFailed'

		let result = runTestFromFragment(fragment, projectRoot: root, target: target, specName: specName, specCacheDir: specCacheDir)

		if not result.compileIr.isEmpty() 'hasIr'
			writeFragment(fragmentDir, specName: specName, test: test, compileIr: result.compileIr)
		end 'hasIr'

		if result.passed 'pass'
			specPassed = specPassed + 1
		end 'pass' else 'fail'
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			if not result.errorMessage.isEmpty() 'hasErr'
				specFailures.push("  {result.errorMessage}")
			end 'hasErr'
		end 'fail'

		if verbose 'showTest'
			if result.passed 'showPass'
				logInfo(LogCategory.testing, message: () gives "[PASS] {testPath}")
			end 'showPass' else 'showFail'
				logInfo(LogCategory.testing, message: () gives "[FAIL] {testPath}")
			end 'showFail'
		end 'showTest'
	end 'eachSingle'

	return (specPassed, specFailed, specFailures)
end 'runSingleTests'

// Run spec tests with batch workers spawned as parallel processes.
// Single tests (per-fragment path) always run in-process; only batch compilations
// are offloaded to subprocess workers. Specs with batchable tests are divided via
// round-robin across `workerCount` workers (or fewer, if there are fewer batchable
// specs than workers), so each worker amortizes the stdlib-cache warm-up cost
// across multiple spec batches.
export function runAllSpecTestsParallel(filter String, target Target, workerCount WorkerCount, updateRequired bool = false, verbose bool = false) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: () gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	setLogLevel(LogLevel.ERROR)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let startTime = Process.currentTimeMs()
	totalCompileMs = 0
	startPhaseTiming()

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let tempDir = root.join("temp")

	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Process.execute("mkdir -p {fragmentDir}", timeoutMs: 5000)
	end 'noFragDir'

	// Reap any leftover capture files from a prior crashed run. In the happy
	// path, processCloseCapture deletes them as part of cleanup; if the runner
	// or a worker crashed mid-test, files like `.capture-bw-3.out` remain
	// behind. Best-effort: ignore failures.
	cleanupLeftoverCaptureFiles(fragmentDir)

	// Warm the stdlib cache for the in-process single-test path.
	warmStdlibCache(target)
	markPhase("warmStdlibCache done")

	if updateRequired 'preUpdate'
		updateAllRequiredLowering(specDir, tempDir: tempDir, filter: filter, target: target, targetKey: targetKey)
	end 'preUpdate'

	let specCacheDir = fragmentDir.join(".spec-cache")
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	// Pre-create all fragment and cache subdirs so workers don't race on creation.
	for specName2 in whitelist 'createDirs'
		let cacheSubDir = specCacheDir.join(specName2)
		if not Directory.exists(cacheSubDir) 'noCacheSub'
			_ = Directory.create(cacheSubDir)
		end 'noCacheSub'
		let fragSubDir = fragmentDir.join(specName2)
		if not Directory.exists(fragSubDir) 'noFragSub'
			_ = Directory.create(fragSubDir)
		end 'noFragSub'
	end 'createDirs'

	var totalPassed = 0 as TestCount
	var totalFailed = 0 as TestCount
	var totalTests = 0
	var totalFragmentsWritten = 0

	// Phase 1: Parse all specs and partition tests into batchable / non-batchable.
	var units = SpecWorkUnitArray.create()

	for specName in whitelist 'parseSpecs'
		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise 'readErr'
			logError(LogCategory.testing, message: () gives "Could not read spec: {specPath}")
			continue
		end 'readErr'

		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			continue
		end 'isDraft'

		let tests = parseSpecFile(content, targetKey: targetKey)
		let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
		totalTests = totalTests + unit.totalCount()
		units.push(unit)
	end 'parseSpecs'
	markPhase("Phase 1 parseSpecs done ({units.count()} units, {totalTests} tests)")

	if totalTests == 0 'noTests'
		logInfo(LogCategory.testing, message: () gives "No tests found")
		return 0
	end 'noTests'

	// Phase 2: Distribute specs with batchable tests across `workerCount` workers
	// using round-robin. All workers start before the parent waits for any —
	// this is what enables OS-level parallelism.
	let exePath = Process.executablePath().toString()
	let targetStr = targetToString(target)
	var workers = BatchWorkerHandleArray.create()

	// Collect the names of specs that have batchable tests, in whitelist order.
	var batchableSpecNames = StringArray.create()
	for unit in units 'collectBatchable'
		if unit.batchable.count() > 0 'hasBatch'
			batchableSpecNames.push(unit.specName)
		end 'hasBatch'
	end 'collectBatchable'

	let batchableCount = batchableSpecNames.count()
	var numWorkers = workerCount as TestCount
	if batchableCount < numWorkers 'fewerSpecsThanWorkers'
		numWorkers = batchableCount as TestCount
	end 'fewerSpecsThanWorkers'

	// Round-robin: worker i gets specs at positions i, i+numWorkers, i+2*numWorkers, ...
	// Build a comma-joined spec list for each worker, then spawn them all at once.
	for i in 0 upto numWorkers 'spawnWorkers'
		var specStr = ""
		var j = i
		while j < batchableCount 'collectChunk'
			let sn = try batchableSpecNames.get(j) otherwise break
			if specStr.isEmpty() 'firstInChunk'
				specStr = sn
			end 'firstInChunk' else 'notFirstInChunk'
				specStr = "{specStr},{sn}"
			end 'notFirstInChunk'
			j = j + numWorkers
		end 'collectChunk'
		if not specStr.isEmpty() 'hasChunk'
			let cmd = buildBatchWorkerCommand(exePath, workerSpecs: specStr, targetStr: targetStr, filter: filter, verbose: verbose)
			let (captureOut, captureErr) = captureFilePaths(fragmentDir, stem: "bw-{i}")
			let handle = Process.captureStart(cmd, stdoutPath: captureOut, stderrPath: captureErr)
			workers.push(BatchWorkerHandle.create(specStr, handle: handle))
		end 'hasChunk'
	end 'spawnWorkers'
	markPhase("Phase 2 spawned {workers.count()} batch workers ({batchableCount} specs)")

	// Phase 3: Dispatch single (non-batchable) tests to singles workers so a
	// compile-time panic in one of them is contained as a failed test rather
	// than a runner-killing crash.
	var singlesSpecNames = StringArray.create()
	for unit in units 'collectSingles'
		if unit.nonBatchable.count() > 0 or unit.missingLoweringCount > 0 'hasSingles'
			singlesSpecNames.push(unit.specName)
			totalFragmentsWritten = totalFragmentsWritten + unit.nonBatchable.count()
		end 'hasSingles'
	end 'collectSingles'

	markPhase("Phase 3 about to call runSinglesPhase ({singlesSpecNames.count()} singles specs)")
	let (singlesPassed, singlesFailed) = runSinglesPhase(singlesSpecNames, units: units, exePath: exePath, targetStr: targetStr, filter: filter, verbose: verbose, numWorkers: numWorkers, phaseLabel: "non-batchable", fragmentDir: fragmentDir)
	totalPassed = totalPassed + singlesPassed
	totalFailed = totalFailed + singlesFailed
	markPhase("Phase 3 runSinglesPhase done")

	// Phase 4: Collect batch worker results.
	// captureStdout blocks until the worker exits; all other workers continue
	// running in the OS background while we wait for each in turn.
	// Each worker emits one WORKER_BATCH_RESULT line per spec it was assigned.
	var fallbackUnits = SpecWorkUnitArray.create()

	for worker in workers 'collectWorkers'
		let stdout = Process.captureStdout(worker.handle)
		let stderr = Process.captureStderr(worker.handle)
		_ = Process.captureWait(worker.handle, timeoutMs: 0)
		markPhase("batch drained worker [{worker.specNames}] stdoutLen={stdout.count()} stderrLen={stderr.count()}")

		// A compiler panic in any batch worker means re-running its tests in
		// new subprocesses would just re-panic; abort the whole run now so the
		// user sees the panic immediately rather than waiting for fallback
		// retries to grind through one process per test.
		if workerStderrIsCompilerPanic(stderr) 'panicked'
			abortOnWorkerCompilerPanic("batch [{worker.specNames}]", stderr: stderr)
		end 'panicked'

		// Forward the worker's log output to our stderr (minus compile-breadcrumb
		// markers, which are only useful for panic diagnosis).
		let cleanedStderr = stripCompilingBreadcrumbs(stderr)
		if not cleanedStderr.isEmpty() 'hasWorkerStderr'
			printError(cleanedStderr)
		end 'hasWorkerStderr'

		// Track which specs this worker was assigned so we can detect missing results.
		var pendingSpecs = worker.specNames.split(",")

		let lines = stdout.split("\n")
		for line in lines 'parseResultLines'
			let trimmedLine = trimWhitespace(line)
			if not trimmedLine.startsWith(workerBatchResultMarker) 'notResult'
				continue
			end 'notResult'
			let result = parseBatchWorkerResult(trimmedLine)
			if not result.valid 'invalidResult'
				logError(LogCategory.testing, message: () gives "[BATCH ERROR] malformed result line from worker: {trimmedLine}")
				continue
			end 'invalidResult'

			// Remove this spec from the pending list.
			var remaining = StringArray.create()
			for pn in pendingSpecs 'filterPending'
				if pn != result.specName 'keep'
					remaining.push(pn)
				end 'keep'
			end 'filterPending'
			pendingSpecs = remaining

			totalCompileMs = totalCompileMs + result.compileMs
			totalPassed = totalPassed + result.passed

			if result.skippedNames.count() > 0 'hasSkipped'
				let unit = findUnitByName(units, specName: result.specName)
				var fallbackTests = SpecTestArray.create()
				appendSkippedToFallback(fallbackTests, batchable: unit.batchable, skippedNames: result.skippedNames)
				if fallbackTests.count() > 0 'hasFallback'
					fallbackUnits.push(makeFallbackOnlyUnit(result.specName, tests: fallbackTests))
				end 'hasFallback'
			end 'hasSkipped'
		end 'parseResultLines'

		// Any spec still pending produced no result — worker crashed (panic,
		// timeout, or non-zero exit). Push every batchable test onto the
		// fallback unit list so the Phase-5 fallback path (and its
		// per-test retry-on-crash) gets a chance to identify the single
		// offending test rather than blaming the whole spec.
		for pendingName in pendingSpecs 'handleMissing'
			let pn = trimWhitespace(pendingName)
			if pn.isEmpty() 'emptyName'
				continue
			end 'emptyName'
			let unit = findUnitByName(units, specName: pn)
			if unit.batchable.count() == 0 'noBatchable'
				continue
			end 'noBatchable'
			fallbackUnits.push(makeFallbackOnlyUnit(pn, tests: cloneSpecTests(unit.batchable)))
		end 'handleMissing'
	end 'collectWorkers'
	markPhase("Phase 4 batch workers collected ({fallbackUnits.count()} fallback units)")

	// Phase 5: Run fallback tests via a subprocess worker. Tests reach this
	// path when the batch rewriter rejected them mid-batch; running them
	// per-fragment from a worker keeps a deterministic compile-time panic from
	// killing the parent runner.
	for unit in fallbackUnits 'countFallbackFrags'
		totalFragmentsWritten = totalFragmentsWritten + unit.nonBatchable.count()
	end 'countFallbackFrags'
	let (fallbackPassed, fallbackFailed) = runFallbackPhase(fallbackUnits, exePath: exePath, targetStr: targetStr, filter: filter, verbose: verbose, fragmentDir: fragmentDir, numWorkers: numWorkers)
	totalPassed = totalPassed + fallbackPassed
	totalFailed = totalFailed + fallbackFailed
	markPhase("Phase 5 runFallbackPhase done")

	if totalFragmentsWritten > 0 'showFrags'
		logInfo(LogCategory.testing, message: () gives "Wrote {totalFragmentsWritten} fragment(s)")
	end 'showFrags'

	let elapsedMs = Process.currentTimeMs() - startTime
	logInfo(LogCategory.testing, message: () gives "Total compile time: {totalCompileMs}ms")

	if totalFailed == 0 'allPass'
		logInfo(LogCategory.testing, message: () gives "Tests: {totalPassed} passed (total: {totalTests}) in {elapsedMs}ms")
	end 'allPass' else 'someFail'
		logInfo(LogCategory.testing, message: () gives "Tests: {totalPassed} passed, {totalFailed} failed (total: {totalTests}) in {elapsedMs}ms")
	end 'someFail'

	if totalFailed > 0 'hasFail'
		return 1
	end 'hasFail'
	return 0
end 'runAllSpecTestsParallel'

	"closure-capture",
	"reserved-double-underscore",
	"managed-memory-builtin",
	"ranges",
	"arrays",
	// `list` (16/23) — 7 fragments under `memory.*` / `value-survives-clear*`
	// exercise features the self-hosted compiler doesn't have yet: E3070
	// borrow-check diagnostics (3 fragments) and runtime mm-trace stderr
	// instrumentation (4 fragments). Re-enable once those land.
	"list-custom-types",
	"export-keyword",
	"unused-export",
	"static-variables",
	"dead-top-level-var-elim",
	"vector",
	"bitwise-operators",
	"interface-conformance",
	"interfaces",
	"equatable",
	"primitive-stringable",
	"byte-string-literal",
	"where-clauses",
	"associated-types",
	"ranged-typealias",
	"typealias-collision",
	"set",
	"challenge-struct-field-assign",
	"challenge-nested-structs",
	"challenge-array-of-structs",
	"challenge-struct-lifetime",
	"bool-type",
	// "bool-bit-packing", — 11/15 pass; 4 need bool/int implicit cast + Vector.insert/remove fixes
	"byte-enum-comparison",
	// "char-literal-to-int", — 7/8 pass; codepoint-iteration test hits an
	//                          unresolved-name parser bug
	"error-handling",
	"interface-dispatch-throws-match",
	"interface-dispatch",
	"initablefromarrayliteral",
	"array-managed-elements",
	// "array-realloc-dangling-ref", — needs E3070 borrow-check diagnostics
	"array-return-element-from-loop",
	"array-slice-managed-elements",
	"array-append-managed-elements",
	// "array-managed-field-reassign", — pre-existing cross-type-resolution
	// gap on `struct.arrayField = newArray` field reassignment, not
	// related to Phase 9 unions (revisited at Stage 5 audit 2026-05-12).
	// "array-managed-multi-call-lifecycle", — same field-reassign gap.
	"array-enum-element-size",
	// "repro-array-union-field-reassign", — pre-existing E3070
	// self-field-shadowing diagnostic gaps; orthogonal to unions.
	// "struct-enum-array-grow", — backend panic on large returned
	// struct with many arrays; orthogonal to unions.
	// "init-from-literal",
	// "interfaces",
	"interface-extensions",
	// J.4b re-enabled `conditional-extensions` after the per-receiver
	// monomorphizer landed: 5 of 6 fragments green (basic-equatable,
	// constraint-not-met, type-extension, multiple-constraints,
	// partial-availability). `array-contains` still fails because
	// stdlib's `Array.contains` is a struct extension whose `item ==
	// element` comparison goes through stdlib-extension machinery —
	// J.4c covers that.
	"conditional-extensions",
	// "associated-types",
	"collection",
	"primitive-hashable",
	"primitive-cloneable",
	"primitive-comparable",
	"string-type",
	"string-interpolation",
	"character-type",
	// "exp",
	// "type-checking",
	// "ownership",
	"map",
	"map-struct-bytearray",
	"map-try-otherwise-block",
	"array-hashable",
	"array-sort",
	"stdlib-array",
	// "enums",
	"top-level-let",
	"module-level-struct-var",
	"regalloc",
	// Partial-pass specs are kept OFF the whitelist so a green run is fully
	// green. Each is listed with its current pass count and the gating
	// feature; re-enable when the residual fragment(s) are addressable.
	// "match-statements" (11/12) — 1 residual fragment uses non-enum
	//                              scrutinee patterns (string-literal match).
	// "match-expr-arm-divergent" (1/2) — `arm-panic.interpolated-message`
	//                              needs Phase-7 panic-string interpolation.
	// "match-exhaustive-default-panic" (9/10) — `default-panic.enum-range-statement`
	//                              hits an unexpected-op panic in lowering;
	//                              separate range-arm cleanup.
	// "enum-allcases" (5/8) — `error-enum` needs Phase-11 Hashable witness;
	//                              `string-backed` / `char-backed` parse now
	//                              but need `.rawValue` to return a String /
	//                              char rather than the ordinal int (separate
	//                              accessor work).
	// `enum-allcasenames` re-enabled 2026-05-13: all 8 fragments green —
	// the previously-blocking `string-backed` parser gap is closed.
	"enum-allcasenames",
	// `enum-ordinal` re-enabled 2026-05-13: string/char-backed enums
	// parse correctly now, and `.ordinal` is the runtime representation
	// regardless of declared backing.
	"enum-ordinal",
	"match-range-single-value",
	// `enum-match-exhaustive` re-enabled 2026-05-12: now 17/17 on both
	// x64-windows and wasm32-wasi (the previous wasm float-backed-enum
	// validator mismatch was resolved by the narrow-int storage work in
	// Phases A-K of the enum-backing plan).
	"enum-match-exhaustive",
	// Phase 9 Stage 4: union destructors landed, so the previously-leaking
	// associated-value specs no longer hit exit-code-101. `enum-match-only`
	// stays off — `enum-map-key-still-works.test` panics on a Hashable
	// witness lookup for a bare enum nested in a `Map with (Color, Int)`
	// typealias, which is a Phase-5 (witness-table registration) gap
	// orthogonal to Stage 4's destructor work. `enum-full` stays off —
	// several E-code diagnostic strings need to match the C# bootstrap
	// wording (E3036/E3034/E3081/E3032) and `Container.fromName` lowering
	// panics in the X64 backend; both are Stage 5 follow-ups.
	"match-enum-typed-binding",
	"enum-struct-field-match",
	"mutable-enums",
	"union-cases",
	"enum-function-backing",
	"enum-struct-backing",
	"enum-nested-struct-backing",
	"union-struct-backing",
	"enum-narrow-storage",
	"match-exhaustive-default-panic",
	"export-var-fields",
	// `enum-hashable` panics on `simple-enum-as-map-key` — `Map with
	// (Color, Int)` needs a Hashable witness for the bare-enum element
	// type, and BuildWitnessTables doesn't emit one. Same gap blocks
	// `enum-match-only.enum-map-key-still-works`. Phase-5 (witness-table
	// registration for primitive-conforming enums) territory.
	// "safe-ffi",
	// "challenge-struct-ownership",
	// "challenge-struct-lifetime",
	// "challenge-nested-structs",
	// "challenge-array-of-structs",
	// "optimizations",
	// "export-var-fields",
	"parsable-interface",
	"register-allocator",
	"function-overloads",
	"tuples",
	"panic-stack-trace",
	"command-line-args",
	"file-io",
	"directory",
	"cache-parity",
	"arithmetic-operators",
	"keyword-parameter-names",
	"while-loops",
	"empty-block",
	"self-assignment",
	"break",
	"unused-variables",
	"duplicate-functions",
	"discarded-results",
	"default-values",
	// Tier-1 candidates that aren't on the whitelist but are worth a focused
	// pass each — bootstrap-green specs whose self-hosted gaps surfaced in
	// the 2026-05-19 Tier-1 sweep + the post-Stage-N missing-diagnostic
	// work. Each entry lists the gating feature work:
	// "block-scoping" (11/12) — all diagnostics now fire; one fragment
	//   (`local-shadows-prior-field-access`) needs panic-string interpolation
	//   (shared blocker with `panic-interpolation`, `match-expr-arm-divergent`,
	//   `optimizer-refcount`).
	// "short-circuit-evaluation" (4/11) — needs investigation.
	// "same-name-methods" (2/5) — needs investigation.
	// "tuple-assign" (0/10) — parser doesn't accept `(x, y) = expr` LHS shape.
	// "sizeof" (0/11) — needs investigation; likely missing __sizeof builtin.
	// "short-type" (1/2) — `u16-rdata` writes 168 bytes vs expected 6
	//   (panic-message rdata bleeds in; needs RequiredRdata slice support).
	// "panic-interpolation" — separate spec; blocks block-scoping +
	//   match-expr-arm-divergent + optimizer-refcount; needs a runtime
	//   helper that formats interpolated values into a panic message buffer.
	// "http-client" — HttpClient.maxon + httpHelpers.maxon are now in the
	//   stdlib whitelist (Phase E), so the spec compiles end-to-end, but
	//   most fragments need real socket runtime (Phase D landed
	//   sentinel-erroring `mrt_managed_socket_*` stubs only). The two
	//   network-free fragments (`invalid-url`, `build-request`) also use
	//   `async`/`await` for unrelated fragments in the same spec file,
	//   which the self-hosted compiler doesn't surface yet. Re-enable
	//   once real socket helpers land.
]

// Signed elapsed time in milliseconds (deltas between Clock.nowMs() reads).
typealias Millis = int(i64.min to i64.max)

// Signed process exit code: typically 0..255 / u32.max, but Subprocess.run
// surfaces NTSTATUS-class codes for abnormal termination, so the field has
// to accommodate the full i64 range.
typealias ProcessExitCode = int(i64.min to i64.max)

typealias TestCount = int(0 to u64.max)

// Per-test-process wall-clock budget. Test fragments hitting this limit are
// terminated by the runtime's processWait kill-on-timeout path so a runaway
// child (e.g. an infinite-loop fragment) can't pin the runner. Tuned for
// fast feedback on local runs; raise if a legitimately heavy test trips it.
let testProcessTimeoutMs = 2000

// Per-worker-job wall-clock budget. If a worker doesn't emit WORKER_READY
// within this many ms of receiving a JOB line, the dispatcher force-kills it
// via subprocessKill; the resulting EOF makes the drain GT throw, which
// routes through recoverFromCrashedJob just like a panic does. Sized for the
// heaviest spec (stdlib-array singles) plus headroom; raise if a legitimately
// heavy spec starts tripping it.
let workerJobTimeoutMs = 60000 as Millis

var totalCompileMs = 0

// Phase timestamp helper: emits "[PHASE +<deltaMs>ms] <label>" lines to
// stderr when --profile-passes is active. Used to find which phase of the
// parallel runner is dragging on a given workload. Stderr (not stdout) so it
// never leaks into the worker IPC stream the parent needs to parse.
var lastPhaseTimestamp = 0
var phaseTimingActive = false

function markPhase(label String)
	if not phaseTimingActive 'inactive'
		return
	end 'inactive'
	let now = Clock.nowMs()
	let delta = now - lastPhaseTimestamp
	lastPhaseTimestamp = now
	printError("[PHASE +{delta}ms] {label}\n")
end 'markPhase'

function startPhaseTiming()
	if not passTimingsActive() 'inactive'
		return
	end 'inactive'
	phaseTimingActive = true
	lastPhaseTimestamp = Clock.nowMs()
	printError("[PHASE +0ms] start\n")
end 'startPhaseTiming'

// Walk up from cwd looking for a specs/ directory, returning its parent.
export function findSpecsRoot() returns FilePath throws CompileError
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		let specsPath = dir.join("specs")
		if Directory.exists(specsPath) 'found'
			return dir
		end 'found'
		let parentDir = try dir.parent() otherwise throw CompileError.directoryNotFound(dir)
		dir = parentDir
	end 'search'
	throw CompileError.directoryNotFound(Directory.currentPath())
end 'findSpecsRoot'

// Check if a target matches the host.
function isHostTarget(target Target) returns bool
	let host = detectHostTarget()
	let targetStr = targetToString(target)
	let hostStr = targetToString(host)
	return targetStr == hostStr
end 'isHostTarget'

// Find the vendored wasmtime binary relative to the project root.
function findWasmtimePath() returns String
	var dir = Directory.currentPath()
	for _ in 0 upto 10 'search'
		let candidate = dir.join("vendor").join("wasmtime").join("wasmtime.exe")
		if File.exists(candidate) 'found'
			return candidate.toString()
		end 'found'
		// Also check for non-Windows binary name
		let candidate2 = dir.join("vendor").join("wasmtime").join("wasmtime")
		if File.exists(candidate2) 'found2'
			return candidate2.toString()
		end 'found2'
		let parentDir = try dir.parent() otherwise return ""
		dir = parentDir
	end 'search'
	return ""
end 'findWasmtimePath'

// Build the command to run a compiled binary. The runner's upstream
// `isSupportedTarget` gate guarantees we only get here for the host target or
// wasm32-wasi — no other cross-execution paths are supported.
// Exe + argv pair used by every spec-test invocation. Subprocess.run accepts
// argv as an array directly, so there's no shell parsing on the runtime side
// and nothing else here needs the legacy shell-string form.
type RunCommand
	export var exe as Executable
	export var argv as StringArray

	export static function create(exe Executable, argv StringArray) returns RunCommand
		return Self{exe: exe, argv: argv}
	end 'create'
end 'RunCommand'

function buildRunCommand(outputPath FilePath, target Target, testArgs String) returns RunCommand
	if target.os == Os.wasi 'isWasm'
		return buildWasmRunCommand(outputPath, testArgs: testArgs)
	end 'isWasm'

	var argv = StringArray.create()
	appendSplitArgs(argv, testArgs: testArgs)
	return RunCommand.create(Executable.path(outputPath), argv: argv)
end 'buildRunCommand'

// Build the command to run a WASM binary via vendored wasmtime. wasmtime's
// `run <WASM>...` takes the wasm module and every positional argument that
// follows as wasi argv — there is no shell-style `--` separator (any literal
// `--` in argv is forwarded verbatim and lands as argv[1] inside the module).
// Spec tests that declare `Args: ...` therefore have to pass the args raw.
//
// `--dir=.` preopens the current working directory as fd 3 inside the wasm
// sandbox. Phase 15c's file/directory I/O helpers (mrt_file_*, mrt_directory_*)
// all hardcode `dirfd = 3` for path_open/path_filestat_get/etc, so without
// the preopen every path-based WASI call would return EBADF.
//
// `--dir=..::../` additionally maps the parent directory at host-side `..`
// to the guest-side path `../`. Several directory specs (list-directory,
// directory-exists, directory-is-directory) reference `../bin` because the
// test runner cwd is `projectRoot/temp` and the binaries the tests look
// for live at `projectRoot/bin`. Without this second preopen those tests
// would always fail with ENOENT.
function buildWasmRunCommand(outputPath FilePath, testArgs String) returns RunCommand
	let wasmtimePath = findWasmtimePath()
	if wasmtimePath.isEmpty() 'noWasmtime'
		panic("wasmtime not found in vendor/wasmtime/")
	end 'noWasmtime'
	let wasmtimeExe = try FilePath.from(wasmtimePath) otherwise panic("buildWasmRunCommand: findWasmtimePath returned an invalid path '{wasmtimePath}'")
	var argv = StringArray.create()
	argv.push("run")
	argv.push("--dir=.")
	argv.push("--dir=..::../")
	argv.push(outputPath.toString())
	appendSplitArgs(argv, testArgs: testArgs)
	return RunCommand.create(Executable.path(wasmtimeExe), argv: argv)
end 'buildWasmRunCommand'

// Split a space-separated `Args:` string into individual argv entries. The
// spec format doesn't support args with embedded spaces (no test in the
// corpus uses them), so a plain whitespace split matches what the old
// shell-string path did. One special case: the literal token `""` is the
// shell idiom for "pass an empty string as this argv element" — see the
// command-line-args/empty-string-arg spec test — so we map it to an empty
// argv push rather than letting it pass through as a literal 2-char string
// the Subprocess stub would re-shell-quote.
function appendSplitArgs(argv StringArray, testArgs String)
	if testArgs.isEmpty() 'empty'
		return
	end 'empty'
	for part in testArgs.split(" ") 'each'
		if part.isEmpty() 'blank'
			continue
		end 'blank'
		if part == "\"\"" 'quotedEmpty'
			argv.push("")
			continue
		end 'quotedEmpty'
		argv.push(part)
	end 'each'
end 'appendSplitArgs'

// Compile a test and capture its lowering trace log. Returns empty string on failure.
function captureLoweringLog(source String, testName String, specName String, tempDir FilePath, target Target) returns String
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.TRACE)
	startCapturingTrace()
	let tempSource = tempDir.join("{testName}.test")
	let ext = executableExtension(target)
	let tempExe = tempDir.join("{specName}{ext}")
	// parseFragment trims the source; mirror that here so this lowering
	// capture sees the same byte stream the runner will measure against.
	let normalizedSource = source.trim()
	_ = try compileSourceWithIr(normalizedSource, virtualPath: tempSource, target: target, outputPath: tempExe, coverage: false, covMapPath: tempExe.changeExtension(".covmap")) otherwise 'compileFailed'
		cancelCapturingTrace()
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
		return ""
	end 'compileFailed'
	let loweringLog = stopCapturingTrace()
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
	cleanup(tempExe)
	return loweringLog
end 'captureLoweringLog'

// Update RequiredLowering blocks in all spec files by compiling each test and capturing lowering output.
function updateAllRequiredLowering(specDir FilePath, tempDir FilePath, filter String, target Target, targetKey String)
	for specName in whitelist 'eachSpec'
		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise continue
		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			continue
		end 'isDraft'
		let tests = parseSpecFile(content, targetKey: targetKey)
		var results = TestResultArray.create()
		for test in tests 'eachTest'
			let testPath = "{specName}/{test.name}"
			if not filterMatches(filter, testPath: testPath) 'noMatch'
				continue
			end 'noMatch'
			if test.expectation.hasCompilerStderr 'skipErrorTest'
				continue
			end 'skipErrorTest'
			let loweringLog = captureLoweringLog(test.source, testName: test.name, specName: specName, tempDir: tempDir, target: target)
			if not loweringLog.isEmpty() 'hasLog'
				results.push(TestResult.create(test.name, passed: true, errorMessage: "", filePath: "", loweringLog: loweringLog, compileIr: ""))
			end 'hasLog'
		end 'eachTest'
		if results.count() > 0 'hasResults'
			updateSpecLowering(specPath, targetKey: targetKey, results: results)
		end 'hasResults'
	end 'eachSpec'
	logInfo(LogCategory.testing, message: function() gives "Updated RequiredLowering blocks in spec files")
end 'updateAllRequiredLowering'

// Run all whitelisted spec tests for a specific target.
// Warm the stdlib cache before running spec tests. This ensures all tests
// see consistent behavior: stdlib functions are pre-compiled to machine code
// and linked in, rather than the first test compiling from source.
function warmStdlibCache(target Target)
	let exePath = try Process.executablePath() otherwise panic("warmStdlibCache: cannot determine executable path")
	let exeParent = try exePath.parent() otherwise panic("executable has no parent directory")
	let projectDir = try exeParent.parent() otherwise panic("executable parent has no parent directory")
	logInfo(LogCategory.testing, message: function() gives "Compiling stdlib cache using project dir: {projectDir}")
	var warmupProject = createProject(projectDir, target: target)
	_ = getStdlibModule(warmupProject)
	// Trigger the process-wide runtime-module load + mem2reg-promotion now,
	// while the global log level is still ERROR. Without this, the first
	// test that triggers `augmentWithRuntime` pays the load cost AND emits
	// mem2reg trace lines into its captured RequiredLowering output —
	// which then desyncs from every subsequent test that hits the cached
	// (silent) path. Pre-warming makes runtime-loading invisible to test
	// trace capture.
	_ = loadRuntimeModule()
end 'warmStdlibCache'

// Outcome of running one spec end-to-end via the in-process serial path.
// `ran` distinguishes "spec absent or draft" (no observation) from "spec ran
// and produced 0 tests after filter" — only the former should leave a prior
// failure entry untouched.
type SpecRunOutcome
	export var ran as bool
	export var passed as TestCount
	export var failed as TestCount
	export var totalTests as TestCount
	export var fragmentsWritten as TestCount

	export static function notRun() returns SpecRunOutcome
		return Self{ran: false, passed: 0, failed: 0, totalTests: 0, fragmentsWritten: 0}
	end 'notRun'

	export static function create(ran bool, passed TestCount, failed TestCount, totalTests TestCount, fragmentsWritten TestCount) returns SpecRunOutcome
		return Self{ran: ran, passed: passed, failed: failed, totalTests: totalTests, fragmentsWritten: fragmentsWritten}
	end 'create'
end 'SpecRunOutcome'

// Run one spec end-to-end on the in-process serial path: parse the spec file,
// partition tests, run the batched compile, then run any non-batchable tests
// per-fragment. Logs the per-spec [FAIL] header inline so callers don't repeat
// the formatting. Returns ran=false when the spec file is missing or the spec
// is in draft status — those cases must NOT clear an entry from the failure
// state file.
function runOneSpecSerial(specName String, specDir FilePath, fragmentDir FilePath, specCacheDir FilePath, root FilePath, target Target, filter String, targetKey String, verbose bool) returns SpecRunOutcome
	let specPath = specDir.join("{specName}.md")
	let content = try File.readText(specPath) otherwise 'readErr'
		logError(LogCategory.testing, message: function() gives "Could not read spec: {specPath}")
		return SpecRunOutcome.notRun()
	end 'readErr'

	let fm = parseFrontmatter(content)
	if fm.status == "draft" 'isDraft'
		logDebug(LogCategory.testing, message: function() gives "Skipping draft spec: {specName}")
		return SpecRunOutcome.notRun()
	end 'isDraft'

	let tests = parseSpecFile(content, targetKey: targetKey)
	var unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
	let totalTests = unit.totalCount()

	// If the filter excluded every test (or the spec genuinely has none), we
	// observed nothing for this spec. Return ran=false so the caller leaves the
	// prior failure state untouched — the spec is neither newly-failed nor
	// newly-passed.
	if totalTests == 0 'noTests'
		return SpecRunOutcome.notRun()
	end 'noTests'

	var specPassed = 0 as TestCount
	var specFailed = unit.missingLoweringCount
	var specFailures = TextLineArray.create()
	for msg in unit.missingLoweringFailures 'copyMissing'
		specFailures.push(msg)
	end 'copyMissing'

	if unit.batchable.count() > 0 'hasBatch'
		let batchOutcome = runSpecBatch(unit.batchable, specName: specName, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target)
		specPassed = specPassed + batchOutcome.passed
		if verbose 'showBatch'
			for verboseLine in batchOutcome.verboseLines 'eachVerbose'
				logInfo(LogCategory.testing, message: function() gives verboseLine)
			end 'eachVerbose'
		end 'showBatch'
		appendSkippedToFallback(unit.nonBatchable, batchable: unit.batchable, skippedNames: batchOutcome.skippedTestNames)
	end 'hasBatch'

	var fragmentsWritten = 0 as TestCount
	for test in unit.nonBatchable 'eachSingle'
		let testPath = "{specName}/{test.name}"
		let fragPath = fragmentDir.join(specName).join("{test.name}.test")
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: "")
		fragmentsWritten = fragmentsWritten + 1

		let fragment = try parseFragment(fragPath) otherwise 'parseFailed'
			logError(LogCategory.testing, message: function() gives "[FAIL] {testPath} - could not parse fragment")
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			specFailures.push("  Failed to parse fragment file")
			continue
		end 'parseFailed'

		let result = runTestFromFragment(fragment, projectRoot: root, target: target, specName: specName, specCacheDir: specCacheDir)

		if not result.compileIr.isEmpty() 'hasIr'
			writeFragment(fragmentDir, specName: specName, test: test, compileIr: result.compileIr)
		end 'hasIr'
		if result.passed 'pass'
			specPassed = specPassed + 1
		end 'pass' else 'fail'
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			if not result.errorMessage.isEmpty() 'hasErr'
				specFailures.push("  {result.errorMessage}")
			end 'hasErr'
		end 'fail'

		if verbose 'showTest'
			if result.passed 'showPass'
				logInfo(LogCategory.testing, message: function() gives "[PASS] {testPath}")
			end 'showPass' else 'showFail'
				logInfo(LogCategory.testing, message: function() gives "[FAIL] {testPath}")
			end 'showFail'
		end 'showTest'
	end 'eachSingle'

	if specFailed > 0 'hasSpecFail'
		let specTotal = specPassed + specFailed
		logError(LogCategory.testing, message: function() gives "[FAIL] {specName} ({specPassed}/{specTotal})")
		logSpecFailureMessages(specFailures)
	end 'hasSpecFail'

	return SpecRunOutcome.create(true, passed: specPassed, failed: specFailed, totalTests: totalTests, fragmentsWritten: fragmentsWritten)
end 'runOneSpecSerial'

export function runAllSpecTests(filter String, target Target, updateRequired bool = false, verbose bool = false) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: function() gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	// Suppress compiler info/debug output during spec tests so only test results are visible
	setLogLevel(LogLevel.ERROR)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let startTime = Clock.nowMs()
	totalCompileMs = 0

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let tempDir = root.join("temp")

	// Ensure fragment directory exists
	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Directory.create(fragmentDir)
	end 'noFragDir'

	// Tests run with cwd = projectRoot/temp (see runSpecBatch / runTestFromFragment).
	// Matches TestRunner.cs:93 in the bootstrap C# runner.
	if not Directory.exists(tempDir) 'noTempDir'
		_ = Directory.create(tempDir)
	end 'noTempDir'

	// Warm the stdlib cache before running tests so all tests see consistent
	// behavior (pre-compiled stdlib via linker, not compiled from source).
	warmStdlibCache(target)

	// Update spec files before generating fragments so tests compare against current output
	if updateRequired 'preUpdate'
		updateAllRequiredLowering(specDir, tempDir: tempDir, filter: filter, target: target, targetKey: targetKey)
	end 'preUpdate'

	// On-disk staging area for compiled exes. The run step needs a stable
	// file path to invoke; the directory is NOT used for skipping recompilation.
	// Every test recompiles its fragment on every run.
	let specCacheDir = fragmentDir.join(".spec-cache")
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	// Pre-create spec subdirectories under the staging area
	for specName2 in whitelist 'createCacheDirs'
		let cacheSubDir = specCacheDir.join(specName2)
		if not Directory.exists(cacheSubDir) 'noCacheSub'
			_ = Directory.create(cacheSubDir)
		end 'noCacheSub'
	end 'createCacheDirs'

	var totalPassed = 0
	var totalFailed = 0
	var totalTests = 0
	var totalFragmentsWritten = 0

	for specName in whitelist 'eachSpec'
		let outcome = runOneSpecSerial(specName, specDir: specDir, fragmentDir: fragmentDir, specCacheDir: specCacheDir, root: root, target: target, filter: filter, targetKey: targetKey, verbose: verbose)
		if not outcome.ran 'skipped'
			continue
		end 'skipped'
		totalTests = totalTests + outcome.totalTests
		totalPassed = totalPassed + outcome.passed
		totalFailed = totalFailed + outcome.failed
		totalFragmentsWritten = totalFragmentsWritten + outcome.fragmentsWritten
	end 'eachSpec'

	if totalTests == 0 'noTests'
		logInfo(LogCategory.testing, message: function() gives "No tests found")
		return 0
	end 'noTests'

	if totalFragmentsWritten > 0 'showFrags'
		logInfo(LogCategory.testing, message: function() gives "Wrote {totalFragmentsWritten} fragment(s)")
	end 'showFrags'

	let elapsedMs = Clock.nowMs() - startTime
	logInfo(LogCategory.testing, message: function() gives "Total compile time: {totalCompileMs}ms")

	if totalFailed == 0 'allPass'
		logInfo(LogCategory.testing, message: function() gives "Tests: {totalPassed} passed (total: {totalTests}) in {elapsedMs}ms")
	end 'allPass' else 'someFail'
		logInfo(LogCategory.testing, message: function() gives "Tests: {totalPassed} passed, {totalFailed} failed (total: {totalTests}) in {elapsedMs}ms")
	end 'someFail'

	if totalFailed > 0 'hasFail'
		return 1
	end 'hasFail'
	return 0
end 'runAllSpecTests'

// Outcome of running one spec's batch. Only PASS results survive batching:
// any failure shape forces the affected tests onto the per-fragment path via
// `skippedTestNames`, so the caller — not this type — produces FAIL records
// for those tests.
type BatchOutcome
	export var passed as TestCount
	export var verboseLines as TextLineArray
	// Tests that must be re-run via the per-fragment path: those the rewriter
	// rejected up front, plus (when any batched test fails) every batchable
	// test in the spec. The batched dispatcher omits the rewriter-rejected
	// tests entirely; rerouting failures keeps batching invisible in reports.
	export var skippedTestNames as StringArray

	export static function create() returns BatchOutcome
		return Self{passed: 0, verboseLines: TextLineArray.create(), skippedTestNames: StringArray.create()}
	end 'create'
end 'BatchOutcome'

// True if `name` appears in the rewriter's skipped-names list. Used to
// suppress the dispatcher's run/result accounting for tests that aren't
// part of the batched binary — they're already routed through the
// per-fragment path by the caller.
function isSkippedTestName(skippedNames StringArray, name String) returns bool
	for skipName in skippedNames 'each'
		if skipName == name 'match'
			return true
		end 'match'
	end 'each'
	return false
end 'isSkippedTestName'

// Mark every test that the rewriter accepted (i.e., NOT in `alreadySkipped`)
// for the per-fragment fallback path. Used when the shared batched binary
// fails in any way that can't be cleanly attributed to one test — the user
// sees real per-test pass/fail instead of a batch-flavored error.
function pushBatchableForFallback(outcome BatchOutcome, tests SpecTestArray, alreadySkipped StringArray)
	for test in tests 'each'
		if isSkippedTestName(alreadySkipped, name: test.name) 'skip'
			continue
		end 'skip'
		outcome.skippedTestNames.push(test.name.clone())
	end 'each'
end 'pushBatchableForFallback'

// Build a batched source for `tests`, compile it once to a shared exe, then
// run the exe ONCE: the dispatcher runs every included test in sequence and
// prints BEGIN/END markers around each so we can slice the output into
// per-test stdout and exit code. Tests rejected by the rewriter are returned
// in `outcome.skippedTestNames` for the caller to run via the per-fragment
// path. A batched-compile failure marks every test in the batch failed with
// a clear error message — the runner deliberately does NOT fall back
// silently, so a developer notices and either fixes the rewriter or adjusts
// the spec.
function runSpecBatch(tests SpecTestArray, specName String, fragmentDir FilePath, specCacheDir FilePath, target Target) returns BatchOutcome
	var outcome = BatchOutcome.create()

	let buildResult = buildBatchSource(specName, tests: tests)
	for skipName in buildResult.skippedNames 'collectSkipped'
		outcome.skippedTestNames.push(skipName.clone())
	end 'collectSkipped'
	for reason in buildResult.skippedReasons 'logSkipped'
		logDebug(LogCategory.testing, message: function() gives "[BATCH SKIP] {reason}")
	end 'logSkipped'

	if not buildResult.hasSource 'allRejected'
		// No batchable tests survived the rewriter. The caller will run them
		// all via the per-fragment path; outcome stays empty here.
		return outcome
	end 'allRejected'

	// Compile the batched source to <specCacheDir>/<spec>/<spec>_batch<ext>
	let cacheSpecDir = specCacheDir.join(specName)
	if not Directory.exists(cacheSpecDir) 'noCacheDir'
		_ = Directory.create(cacheSpecDir)
	end 'noCacheDir'

	let ext = executableExtension(target)
	let batchBaseName = batchFragmentBaseName(specName)
	let batchExePath = cacheSpecDir.join("{batchBaseName}{ext}")

	// Virtual path for the batched source used when invoking the compiler.
	// Use the spec name (not `<spec>_batch`) as the stem so the parser-derived
	// namespace matches a non-batched compile — otherwise per-test IR slices
	// inherit `<spec>_batch.<name>` qualifiers that leak the batching detail.
	let virtualPath = fragmentDir.join(specName).join("{specName}.maxon")

	startCapturingErrors()
	let compileStart = Clock.nowMs()
	let batchedSource = buildResult.source
	let covMapPath = batchExePath.changeExtension(".covmap")
	emitWorkerCompiling("{specName} (batch of {tests.count()})")
	let cr = try compileSourceWithIr(batchedSource, virtualPath: virtualPath, target: target, outputPath: batchExePath, coverage: false, covMapPath: covMapPath) otherwise 'batchCompileFailed'
		totalCompileMs = totalCompileMs + (Clock.nowMs() - compileStart)
		let capturedErrors = stopCapturingErrors()
		// The shared compile didn't identify any single test — re-run every
		// batchable test via the per-fragment path so callers see real
		// individual pass/fail instead of a generic batch-flavored error.
		logDebug(LogCategory.testing, message: function() gives "[BATCH FALLBACK] {specName}: batch compile failed: {capturedErrors}")
		pushBatchableForFallback(outcome, tests: tests, alreadySkipped: buildResult.skippedNames)
		return outcome
	end 'batchCompileFailed'
	totalCompileMs = totalCompileMs + (Clock.nowMs() - compileStart)
	cancelCapturingErrors()
	logDebug(LogCategory.testing, message: function() gives "[BATCH OK] {specName} compiled to {cr.outputPath}")

	// Run the batched binary ONCE. The dispatcher runs every included test
	// in sequence and emits BEGIN/END markers around each so we can slice
	// the binary's stdout into per-test stdout and per-test exit code.
	// cwd = projectRoot/temp (matches the bootstrap test runner). The
	// fragmentDir is `{projectRoot}/specs/fragments-{arch}-{os}` so its
	// grandparent is the project root.
	let runCommand = buildRunCommand(batchExePath, target: target, testArgs: "")
	let projectRoot = try fragmentDir.parent() otherwise panic("runSpecBatch: fragmentDir has no parent")
	let projectRootUp = try projectRoot.parent() otherwise panic("runSpecBatch: specs dir has no parent")
	let batchTempDir = projectRootUp.join("temp")
	let runResult = try Subprocess.run(runCommand.exe, arguments: runCommand.argv, workingDirectory: batchTempDir, timeoutMs: testProcessTimeoutMs) otherwise (err) 'batchRun'
		panic("Batch run failed for {batchExePath.toString()}: {err.displayReason()}")
	end 'batchRun'

	// First pass: check each batchable test's slice. Tests with a present and
	// passing slice are committed as PASS immediately; tests with a missing
	// slice or a stdout/exit-code mismatch get pushed onto `outcome.skippedTestNames`
	// so the caller re-runs *just those tests* via the per-fragment path. Tests
	// that succeeded in the batch are NOT re-run — that would double the work
	// every time a single sibling test happens to fail.
	var pendingPassed = TextLineArray.create()
	var failedNames = StringArray.create()
	for test in tests 'firstPass'
		if isSkippedTestName(buildResult.skippedNames, name: test.name) 'skipRun'
			continue
		end 'skipRun'

		let slice = parseBatchSlice(runResult.stdout, testName: test.name)
		if not slice.found 'noSlice'
			failedNames.push(test.name.clone())
			continue
		end 'noSlice'

		var passed = true
		if test.expectation.hasExitCode 'checkEcBatch'
			if slice.exitCode != test.expectation.exitCode 'ecMismatchBatch'
				passed = false
			end 'ecMismatchBatch'
		end 'checkEcBatch'

		if test.expectation.hasStdout 'checkStdoutBatch'
			let expectedOut = trimWhitespace(test.expectation.stdout.replace("\r\n", with: "\n"))
			let actualOut = trimWhitespace(slice.stdout.replace("\r\n", with: "\n"))
			if actualOut != expectedOut 'stdoutMismatchBatch'
				passed = false
			end 'stdoutMismatchBatch'
		end 'checkStdoutBatch'

		if passed 'passBatch'
			pendingPassed.push("[PASS] {specName}/{test.name}")
		end 'passBatch' else 'failBatch'
			failedNames.push(test.name.clone())
		end 'failBatch'
	end 'firstPass'

	if failedNames.count() > 0 'someFailed'
		logDebug(LogCategory.testing, message: function() gives "[BATCH FALLBACK] {specName}: re-running {failedNames.count()} failing batchable test(s) individually")
	end 'someFailed'

	// Commit passes regardless of whether any tests failed — the failed ones
	// will be re-run via the per-fragment path, but the passes are real.
	for line in pendingPassed 'commitPassed'
		outcome.passed = outcome.passed + 1
		outcome.verboseLines.push(line)
	end 'commitPassed'

	// Route only the failed tests (plus rewriter-rejected ones) to the
	// fallback path. The rewriter-rejected names were appended at the top
	// of this function; we add the per-test failures here.
	for failName in failedNames 'addFailedToSkipped'
		outcome.skippedTestNames.push(failName)
	end 'addFailedToSkipped'

	// Slice the batched IR text into per-test snippets and write a fragment
	// file for each batchable test. Inspection aid only — the IR may differ
	// from a per-fragment compile because batched optimization decisions
	// aren't identical.
	writePerTestFragmentsFromBatch(tests, fragmentDir: fragmentDir, specName: specName, batchedIr: cr.ir, skippedNames: buildResult.skippedNames)

	return outcome
end 'runSpecBatch'

// After a successful batched compile, slice the batched IR text into per-test
// snippets and write a fragment file for each batchable test. Tests rejected
// by the rewriter aren't in the binary; the caller reruns those via the
// per-fragment path which writes its own fragment.
function writePerTestFragmentsFromBatch(tests SpecTestArray, fragmentDir FilePath, specName String, batchedIr String, skippedNames StringArray)
	let slices = splitBatchedIr(batchedIr, tests: tests, specName: specName)
	for test in tests 'eachTest'
		if isSkippedTestName(skippedNames, name: test.name) 'skipRewriterRejected'
			continue
		end 'skipRewriterRejected'
		let ir = lookupSliceIr(slices, testName: test.name)
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: ir)
	end 'eachTest'
end 'writePerTestFragmentsFromBatch'

// Find the IR snippet for `testName` in a BatchIrSliceArray. Returns "" when
// no slice was attributed to the test (e.g. the rewriter renamed all of its
// declarations away from any `_b_<sanitized>_` form).
function lookupSliceIr(slices BatchIrSliceArray, testName String) returns String
	for slice in slices 'each'
		if slice.testName == testName 'match'
			return slice.ir
		end 'match'
	end 'each'
	return ""
end 'lookupSliceIr'

// Per-test slice of a batched binary's output. Used by parseBatchSlice.
type BatchSlice
	export var stdout as String
	export var exitCode as ProcessExitCode
	export var found as bool

	export static function missing() returns BatchSlice
		return Self{stdout: "", exitCode: 0, found: false}
	end 'missing'

	export static function present(stdout String, exitCode ProcessExitCode) returns BatchSlice
		return Self{stdout: stdout, exitCode: exitCode, found: true}
	end 'present'
end 'BatchSlice'

// Walk the batched binary's stdout looking for the BEGIN/END marker pair
// belonging to `testName`. Returns the test's per-test stdout (the bytes
// between the BEGIN line and the END line) plus the exit code its
// renamed-main returned. If either marker is missing, returns
// `BatchSlice.missing()` — the caller treats that as "did not run".
function parseBatchSlice(stdout String, testName String) returns BatchSlice
	let beginTag = "{batchTestBeginMarker}{testName}{batchMarkerSuffix}"
	let endTagPrefix = "{batchTestEndMarker}{testName}:"

	let beginIdx = try stdout.findFirst(beginTag) otherwise return BatchSlice.missing()
	// Skip to the character after the BEGIN tag.
	let stdoutStart = beginIdx.bytePos() + beginTag.count()
	let bodyAfterBegin = sliceFromBytePos(stdout, bytePos: stdoutStart)
	let endIdx = try bodyAfterBegin.findFirst(endTagPrefix) otherwise return BatchSlice.missing()
	let testStdoutRaw = bodyAfterBegin.slice(bodyAfterBegin.startIndex(), endIndex: endIdx)

	// Read the exit code: from the char after `:` up to the marker suffix.
	// The dispatcher emits this verbatim from a captured `let ec_<name> =
	// renamedMain()` so the format is fully under our control — a parse
	// failure here means the dispatcher template has drifted from this
	// parser, not a runtime condition.
	let afterEndTagPrefix = sliceFromBytePos(bodyAfterBegin, bytePos: endIdx.bytePos() + endTagPrefix.count())
	let suffixIdx = try afterEndTagPrefix.findFirst(batchMarkerSuffix) otherwise return BatchSlice.missing()
	let exitStr = afterEndTagPrefix.slice(afterEndTagPrefix.startIndex(), endIndex: suffixIdx)
	let ec = try int.fromString(exitStr) otherwise panic("batch dispatcher emitted non-integer exit code '{exitStr}' for {testName}")

	// Trim leading/trailing whitespace that came from the marker lines.
	// (The test's own stdout content gets compared after another trim at the
	// expectation site, so this is symmetric.)
	let cleaned = trimWhitespace(testStdoutRaw)
	return BatchSlice.present(cleaned, exitCode: ec)
end 'parseBatchSlice'

// Return the substring of `s` starting at byte position `bytePos`. Falls
// back to "" if the position is out of range.
function sliceFromBytePos(s String, bytePos BytePos) returns String
	let endIdx = s.endIndex()
	if bytePos >= s.count() 'past'
		return ""
	end 'past'
	let startIdx = StringIndex.create(bytePos, bytePos: bytePos)
	return s.slice(startIdx, endIndex: endIdx)
end 'sliceFromBytePos'

// Dispatch to single- or multi-file compile based on whether the test
// authored `// --- file: name.maxon` markers. The single-file branch keeps
// the fragment's on-disk path so error messages line up with what the
// reader sees in the editor; the multi-file branch synthesizes per-file
// virtual paths under a directory derived from the fragment so module
// visibility (which depends on directory subtree relationships) works.
function compileFragmentInMemory(fragment Fragment, virtualSourcePath FilePath, target Target, outputExe FilePath) returns CompileWithIrResult throws CompileError
	let covMapPath = outputExe.changeExtension(".covmap")
	if not fragment.hasMultiFile 'isSingle'
		return try compileSourceWithIr(fragment.source, virtualPath: virtualSourcePath, target: target, outputPath: outputExe, coverage: false, covMapPath: covMapPath, includeStdlibIr: fragment.includeStdlibIr)
	end 'isSingle'

	// Anchor virtual paths in the fragment's directory so module-visibility
	// rules (which compare directory subtrees) match the spec author's
	// intent: a file marker `feature/main.maxon` lands in `<fragmentDir>/feature/main.maxon`.
	// The runner always gives us an absolute fragment path, so .parent()
	// should never fail; treat a failure as an invariant break.
	let fragmentDir = try virtualSourcePath.parent() otherwise panic("compileFragmentInMemory: fragment path '{virtualSourcePath}' has no parent directory")
	var virtualFiles = VirtualSourceFileArray.create()
	for pair in fragment.sourceFiles 'eachFile'
		let path = fragmentDir.join(pair.fileName)
		// Per-file slices come from the spec parser already trimmed of
		// trailing whitespace; the parser's tokenizer needs a final newline
		// so it doesn't hit EOF mid-statement.
		let normalizedSource = pair.source if pair.source.endsWith("\n") else "{pair.source}\n"
		virtualFiles.push(VirtualSourceFile.create(path, source: normalizedSource))
	end 'eachFile'
	return try compileMultiFileSourceWithIr(virtualFiles, projectRoot: fragmentDir, target: target, outputPath: outputExe, coverage: false, covMapPath: covMapPath, includeStdlibIr: fragment.includeStdlibIr)
end 'compileFragmentInMemory'

// Cache-parity test driver. Compiles `fragment` twice — once with the stdlib
// cache forced off via `setStdlibCacheBypassed(true)`, once with it on — and
// fails if the captured RequiredLowering trace or the compiled PE's `.rdata`
// section differs between legs. Only compared fields are IR + rdata; runtime
// stdout / stderr / exit code are intentionally not checked because a
// cache-masked bug can corrupt slot data or rdata layout without changing
// the program's runtime output (the whole point of running this gate is to
// catch IR-level drift the regular suite would silently let through).
//
// After both legs we call `warmStdlibCache(target)` so the rest of the suite
// resumes from a warm in-process cache (otherwise every subsequent test would
// pay the cold-start parse cost).
function runTestParityCheck(fragment Fragment, projectRoot FilePath, target Target, specName String, specCacheDir FilePath) returns TestResult
	let testName = fragment.testName
	let tempDir = projectRoot.join("temp")
	let virtualSourcePath = try FilePath.from(fragment.filePath) otherwise tempDir.join("{fragment.testName}.test")
	let ext = executableExtension(target)
	let cacheSpecDir = specCacheDir.join(specName)
	if not Directory.exists(cacheSpecDir) 'noCacheDir'
		_ = Directory.create(cacheSpecDir)
	end 'noCacheDir'
	let outputExeA = cacheSpecDir.join("{fragment.testName}-cacheoff{ext}")
	let outputExeB = cacheSpecDir.join("{fragment.testName}-cacheon{ext}")

	// Leg B (cache on) runs first to exercise the in-process warm path that
	// every other spec test uses; leg A (cache off) then wipes the loader
	// state and re-parses stdlib from source. Running A first would leave a
	// partially-restored in-process state that leg B couldn't trust.
	let legB = runParityLeg(fragment, virtualSourcePath: virtualSourcePath, target: target, outputExe: outputExeB, bypassed: false)
	let legA = runParityLeg(fragment, virtualSourcePath: virtualSourcePath, target: target, outputExe: outputExeA, bypassed: true)

	// Restore suite-wide warm state for subsequent (non-parity) tests so the
	// rest of the run keeps its normal wall clock. The reset is essential —
	// leg B left in-process state from a bypassed-then-restored parse cycle
	// that the cache's gid translator can't always reconcile against a fresh
	// warmup project (StdlibCache.translateWriterGenericInstanceId panics
	// without this reset).
	resetStdlibLoaderState()
	warmStdlibCache(target)

	var errorMsg = ""
	var passed = true

	// Compile-status divergence is itself a parity failure: a cache-masked bug
	// can manifest as "compiles with cache on, fails to compile with cache
	// off" (or vice versa). Catch this before the IR/rdata diff.
	if legA.compiled != legB.compiled 'compileStatusDiff'
		passed = false
		errorMsg = "cache-parity: compile status diverged. leg A (cache off) compiled={legA.compiled}; leg B (cache on) compiled={legB.compiled}\nleg A error: {legA.errorMessage}\nleg B error: {legB.errorMessage}"
	end 'compileStatusDiff' else 'sameCompileStatus'
		if not legA.compiled 'bothFailed'
			// Both legs failed: compare error messages. Different errors → still
			// a parity bug.
			if legA.errorMessage != legB.errorMessage 'errorMessageDiff'
				passed = false
				errorMsg = "cache-parity: both legs failed but with different errors.\n--- leg A (cache off) ---\n{legA.errorMessage}\n--- leg B (cache on) ---\n{legB.errorMessage}"
			end 'errorMessageDiff'
		end 'bothFailed' else 'bothOk'
			// Note: lowering-trace comparison is intentionally NOT done on
			// tryold. Leg A (cache off) lowers the full stdlib through the
			// user pipeline; leg B (cache on) loads stdlib metadata from
			// the cache and lowers nothing stdlib-related in the user
			// pipeline. Their lowering traces diverge by design — that's
			// the cache's *purpose*. The right parity invariant on tryold
			// is "same observable output": rdata bytes and (when we add
			// it) text-section function bytes match between legs.
			//
			// Rdata + text comparison is PE-only — non-Windows targets
			// emit code/data into other sections, so we skip the byte
			// compare on those.
			if target.os == Os.windows 'isWindows'
				if legA.rdataBytes != legB.rdataBytes 'rdataMismatch'
					passed = false
					errorMsg = "cache-parity: .rdata diverged between leg A (cache off) and leg B (cache on)\nleg A ({legA.rdataBytes.count()} bytes): {formatHexBytes(legA.rdataBytes)}\nleg B ({legB.rdataBytes.count()} bytes): {formatHexBytes(legB.rdataBytes)}"
				end 'rdataMismatch'
				if legA.textBytes != legB.textBytes 'textMismatch'
					passed = false
					let textMsg = "cache-parity: .text diverged between leg A (cache off) and leg B (cache on); leg A {legA.textBytes.count()} bytes / leg B {legB.textBytes.count()} bytes"
					if errorMsg.isEmpty() 'firstText'
						errorMsg = textMsg
					end 'firstText' else 'appendText'
						errorMsg = "{errorMsg}\n{textMsg}"
					end 'appendText'
				end 'textMismatch'
			end 'isWindows'
		end 'bothOk'
	end 'sameCompileStatus'

	cleanup(outputExeA)
	cleanup(outputExeB)
	return TestResult.create(testName, passed: passed, errorMessage: errorMsg, filePath: fragment.filePath, loweringLog: legB.loweringLog, compileIr: "")
end 'runTestParityCheck'

// Per-leg result for a cache-parity test. `compiled = false` means the compile
// itself failed (which should never happen for either leg when the fix being
// tested is well-formed — both compile or neither does). On success,
// `loweringLog` is the captured IR trace and `rdataBytes` is the .rdata
// section bytes (empty on non-Windows targets).
type ParityLegResult
	export var compiled as bool
	export var errorMessage as String
	export var loweringLog as String
	export var rdataBytes as ByteArray
	export var textBytes as ByteArray

	static function create(compiled bool, errorMessage String, loweringLog String, rdataBytes ByteArray, textBytes ByteArray) returns ParityLegResult
		return Self{compiled: compiled, errorMessage: errorMessage, loweringLog: loweringLog, rdataBytes: rdataBytes, textBytes: textBytes}
	end 'create'
end 'ParityLegResult'

// Run one leg of a cache-parity test. Resets stdlib loader state, flips the
// bypass to the requested value, compiles, and captures both the IR trace and
// (on Windows targets) the compiled .rdata section bytes.
function runParityLeg(fragment Fragment, virtualSourcePath FilePath, target Target, outputExe FilePath, bypassed bool) returns ParityLegResult
	// Reset only on the bypassed leg: that's the one that must re-parse stdlib
	// from source. The non-bypassed leg deliberately leaves the suite-wide
	// warm in-process state in place so it exercises the normal
	// `stdlibLoaded` cached path that every other spec test uses — which is
	// also the path most likely to mask bugs.
	if bypassed 'needsFreshParse'
		resetStdlibLoaderState()
	end 'needsFreshParse'
	setStdlibCacheBypassed(bypassed)
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.TRACE)
	startCapturingTrace()
	startCapturingErrors()

	// We use `compileOk.outputPath` further down (it's the same path we asked
	// the compiler to produce, but binding through the compile result keeps
	// the analyzer satisfied that the call's return value is consumed).
	let compileOk = try compileFragmentInMemory(fragment, virtualSourcePath: virtualSourcePath, target: target, outputExe: outputExe) otherwise 'compileFailed'
		let capturedErrors = stopCapturingErrors()
		cancelCapturingTrace()
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
		setStdlibCacheBypassed(false)
		return ParityLegResult.create(false, errorMessage: capturedErrors, loweringLog: "", rdataBytes: ByteArray.create(), textBytes: ByteArray.create())
	end 'compileFailed'
	let compiledExe = compileOk.outputPath

	cancelCapturingErrors()
	let loweringLog = stopCapturingTrace()
	setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
	setStdlibCacheBypassed(false)

	var rdataBytes = ByteArray.create()
	var textBytes = ByteArray.create()
	if target.os == Os.windows 'readSections'
		let exeBytes = try File.readBinary(compiledExe) otherwise ByteArray.create()
		let sections = try parsePeSections(exeBytes) otherwise PeSectionInfoArray.create()
		if let text = try findSection(sections, name: ".text") 'haveText'
			textBytes = readPeSectionBytes(exeBytes, info: text)
		end 'haveText'
		if let rdata = try findSection(sections, name: ".rdata") 'haveRdata'
			rdataBytes = readPeSectionBytes(exeBytes, info: rdata)
		end 'haveRdata'
	end 'readSections'

	return ParityLegResult.create(true, errorMessage: "", loweringLog: loweringLog, rdataBytes: rdataBytes, textBytes: textBytes)
end 'runParityLeg'

// Run a single test from a parsed fragment. Returns TestResult.
function runTestFromFragment(fragment Fragment, projectRoot FilePath, target Target, captureTrace bool = false, specName String, specCacheDir FilePath) returns TestResult
	// Cache-parity spec files dispatch to a dedicated double-compile harness
	// that fails the test if the IR or .rdata diverges between cache-off and
	// cache-on legs. Runtime stdout / stderr / exit code are intentionally
	// not checked in this mode — see runTestParityCheck for rationale.
	if fragment.cacheParity 'isParity'
		return runTestParityCheck(fragment, projectRoot: projectRoot, target: target, specName: specName, specCacheDir: specCacheDir)
	end 'isParity'

	let tempDir = projectRoot.join("temp")
	// virtualPath ends up embedded in compiler error messages, so point it at
	// the on-disk fragment we just wrote — readers can open the path verbatim.
	let virtualSourcePath = try FilePath.from(fragment.filePath) otherwise tempDir.join("{fragment.testName}.test")
	let ext = executableExtension(target)
	let testName = fragment.testName

	// compiler_error tests compile to temp (we only care about the error message)
	// success tests compile to the cache directory so the exe can be reused
	var outputExe = tempDir.join("{specName}{ext}")
	if not fragment.expectation.hasCompilerStderr 'isSuccessTest'
		let cacheSpecDir = specCacheDir.join(specName)
		if not Directory.exists(cacheSpecDir) 'noCacheDir'
			_ = Directory.create(cacheSpecDir)
		end 'noCacheDir'
		outputExe = cacheSpecDir.join("{fragment.testName}{ext}")
	end 'isSuccessTest'

	// Enable trace capture for RequiredLowering validation or --update-required
	let needTrace = fragment.expectation.hasRequiredLowering or captureTrace
	if needTrace 'enableTrace'
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.TRACE)
		startCapturingTrace()
	end 'enableTrace'

	// Compile source directly from memory, capturing any error output.
	// Multi-file tests (those with `// --- file: name.maxon` markers) feed
	// each fragment as a distinct compilation unit so cross-file references
	// resolve like a real on-disk project.
	startCapturingErrors()
	let compileStart = Clock.nowMs()
	emitWorkerCompiling("{specName}/{testName}")
	let compileResult = try compileFragmentInMemory(fragment, virtualSourcePath: virtualSourcePath, target: target, outputExe: outputExe) otherwise 'compileFailed'
		totalCompileMs = totalCompileMs + (Clock.nowMs() - compileStart)
		let capturedErrors = stopCapturingErrors()
		if needTrace 'cancelTrace'
			cancelCapturingTrace()
			setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
		end 'cancelTrace'

		if fragment.expectation.hasCompilerStderr 'expectedError'
			// Compilation failed as expected — validate the error message
			let expectedStderr = normalizeStderr(fragment.expectation.compilerStderr)
			let actualStderr = normalizeStderr(capturedErrors)
			if actualStderr != expectedStderr 'stderrMismatch'
				cleanup(outputExe)
				return TestResult.create(testName, passed: false, errorMessage: "Stderr mismatch.\nExpected:\n  {expectedStderr}\nActual:\n  {actualStderr}", filePath: fragment.filePath, loweringLog: "", compileIr: "")
			end 'stderrMismatch'
			cleanup(outputExe)
			return TestResult.create(testName, passed: true, errorMessage: "", filePath: fragment.filePath, loweringLog: "", compileIr: "")
		end 'expectedError'

		cleanup(outputExe)
		return TestResult.create(testName, passed: false, errorMessage: "Compilation failed: {capturedErrors}", filePath: fragment.filePath, loweringLog: "", compileIr: "")
	end 'compileFailed'
	totalCompileMs = totalCompileMs + (Clock.nowMs() - compileStart)
	cancelCapturingErrors()
	let outputPath = compileResult.outputPath
	let compileIr = compileResult.ir

	// Capture lowering log if needed
	var loweringLog = ""
	if needTrace 'captureLowering'
		loweringLog = stopCapturingTrace()
		setCategoryLogLevel(LogCategory.ir, level: LogLevel.ERROR)
	end 'captureLowering'

	if fragment.expectation.hasCompilerStderr 'unexpectedSuccess'
		cleanup(outputExe)
		return TestResult.create(testName, passed: false, errorMessage: "Expected compilation error but compilation succeeded", filePath: fragment.filePath, loweringLog: "", compileIr: "")
	end 'unexpectedSuccess'

	// Run the compiled executable. Use projectRoot/temp as cwd so tests
	// that resolve relative paths like `../bin` see the same layout the
	// bootstrap test runner uses (see maxon-sharp/Testing/TestRunner.cs:
	// _tempDir is project_root/temp).
	let runCommand = buildRunCommand(outputPath, target: target, testArgs: fragment.args)
	let runResult = try Subprocess.run(runCommand.exe, arguments: runCommand.argv, workingDirectory: tempDir, timeoutMs: testProcessTimeoutMs) otherwise (err) 'runFail'
		cleanup(outputExe)
		return TestResult.create(testName, passed: false, errorMessage: "Run failed: {err.displayReason()}", filePath: fragment.filePath, loweringLog: loweringLog, compileIr: compileIr)
	end 'runFail'
	let runStdout = runResult.stdout
	let runStderr = runResult.stderr
	let runEc = runResult.exitCode()

	var passed = true
	var errorMsg = ""

	// Check exit code (skip for tests that expect stderr — panic exit codes are platform-dependent)
	if fragment.expectation.hasExitCode and not fragment.expectation.hasRuntimeStderr 'checkEc'
		if runEc != fragment.expectation.exitCode 'ecMismatch'
			passed = false
			errorMsg = "Expected exit code {fragment.expectation.exitCode}, got {runEc}"
		end 'ecMismatch'
	end 'checkEc'

	// Check stdout
	if fragment.expectation.hasStdout 'checkStdout'
		let expectedOut = trimWhitespace(fragment.expectation.stdout)
		let actualOut = trimWhitespace(runStdout)
		if actualOut != expectedOut 'stdoutMismatch'
			passed = false
			if errorMsg.isEmpty() 'firstStdout'
				errorMsg = "Stdout mismatch:\nExpected: {expectedOut}\nActual: {actualOut}"
			end 'firstStdout' else 'appendStdout'
				errorMsg = "{errorMsg}\nStdout mismatch:\nExpected: {expectedOut}\nActual: {actualOut}"
			end 'appendStdout'
		end 'stdoutMismatch'
	end 'checkStdout'

	// Check runtime stderr
	if fragment.expectation.hasRuntimeStderr 'checkStderr'
		let expectedErr = trimWhitespace(fragment.expectation.runtimeStderr)
		// CPU-fault panics now carry an " at rip=0xHEX" suffix that varies per
		// build; strip it so spec expectations match the panic message itself.
		var actualErr = trimWhitespace(stripFaultRipSuffix(runStderr))
		// Convert wasmtime trap output into Maxon-style stack trace
		if target.os == Os.wasi 'convertWasmtimeOutput'
			actualErr = convertWasmtimeStderr(actualErr)
		end 'convertWasmtimeOutput'
		if actualErr != expectedErr 'stderrMismatch'
			passed = false
			if errorMsg.isEmpty() 'firstStderr'
				errorMsg = "Stderr mismatch:\nExpected: {expectedErr}\nActual: {actualErr}"
			end 'firstStderr' else 'appendStderr'
				errorMsg = "{errorMsg}\nStderr mismatch:\nExpected: {expectedErr}\nActual: {actualErr}"
			end 'appendStderr'
		end 'stderrMismatch'
	end 'checkStderr' else 'noExpectedStderr'
		// Unexpected stderr detection
		let trimmedStderr = trimWhitespace(runStderr)
		if not trimmedStderr.isEmpty() 'unexpectedStderr'
			passed = false
			if errorMsg.isEmpty() 'firstUnexpected'
				errorMsg = "Unexpected stderr output:\n{trimmedStderr}"
			end 'firstUnexpected' else 'appendUnexpected'
				errorMsg = "{errorMsg}\nUnexpected stderr output:\n{trimmedStderr}"
			end 'appendUnexpected'
		end 'unexpectedStderr'
	end 'noExpectedStderr'

	// Check RequiredLowering
	if fragment.expectation.hasRequiredLowering 'checkLowering'
		let loweringResult = checkRequiredLowering(fragment.expectation.requiredLowering, actual: loweringLog)
		if not loweringResult.passed 'loweringFailed'
			passed = false
			if errorMsg.isEmpty() 'firstLowering'
				errorMsg = loweringResult.message
			end 'firstLowering' else 'appendLowering'
				errorMsg = "{errorMsg}\n{loweringResult.message}"
			end 'appendLowering'
		end 'loweringFailed'
	end 'checkLowering'

	// Check RequiredRdata — byte-for-byte compare the compiled .exe's .rdata
	// section against the typed values in the spec block. PE-only; ELF and
	// Mach-O don't have a `.rdata` section. Mirrors TestRunner.cs:748.
	if fragment.expectation.hasRequiredRdata 'checkRdata'
		if target.os == Os.windows 'isWindows'
			let rdataResult = checkRequiredRdataBytes(fragment.expectation.requiredRdata, exePath: outputPath)
			if not rdataResult.passed 'rdataFailed'
				passed = false
				if errorMsg.isEmpty() 'firstRdata'
					errorMsg = "Required Rdata mismatch: {rdataResult.message}"
				end 'firstRdata' else 'appendRdata'
					errorMsg = "{errorMsg}\nRequired Rdata mismatch: {rdataResult.message}"
				end 'appendRdata'
			end 'rdataFailed'
		end 'isWindows'
	end 'checkRdata'

	if passed 'didPass'
		logDebug(LogCategory.testing, message: function() gives "[PASS] {testName}")
	end 'didPass'

	// Keep the exe only for passing success tests (cached for future runs)
	if not passed or fragment.expectation.hasCompilerStderr 'cleanupExe'
		cleanup(outputExe)
	end 'cleanupExe'
	return TestResult.create(testName, passed: passed, errorMessage: errorMsg, filePath: fragment.filePath, loweringLog: loweringLog, compileIr: compileIr)
end 'runTestFromFragment'

// Strip the " at rip=0xHEX diag_base=0xHEX addr=0xHEX rbp=0xHEX" suffix the
// runtime appends to CPU-fault panics. These addresses identify the faulting
// instruction and ASLR slide — useful for diagnosis but non-deterministic
// across builds, so spec expectations match only the panic message itself.
function stripFaultRipSuffix(s String) returns String
	let marker = " at rip=0x"
	var out = ""
	var first = true
	for line in s.split("\n") 'eachLine'
		let stripped = stripAtMarker(line, marker: marker)
		if first 'firstLine'
			out = stripped
			first = false
		end 'firstLine' else 'appendLine'
			out = "{out}\n{stripped}"
		end 'appendLine'
	end 'eachLine'
	return out
end 'stripFaultRipSuffix'

function stripAtMarker(line String, marker String) returns String
	let markerIdx = try line.findFirst(marker) otherwise return line
	return line.slice(line.startIndex(), endIndex: markerIdx)
end 'stripAtMarker'

// Convert wasmtime's trap stderr into a Maxon-style stack trace.
// Input:  "panic at ...\nError: failed to run...\n...wasm backtrace:\n  0: 0x445 - <unknown>!mrt_panic\n  1: 0x485 - <unknown>!main\n..."
// Output: "panic at ...\nStack trace:\n  in main\n  in mrt_start"
// Strips mrt_panic from the trace (it's an implementation detail) and the wasmtime boilerplate.
function convertWasmtimeStderr(s String) returns String
	let marker = "\nError: failed to run"
	let markerIdx = try s.findFirst(marker) otherwise return s
	// Extract the program's stderr (before wasmtime's error)
	let programStderr = s.slice(s.startIndex(), endIndex: markerIdx)

	// Extract function names from wasmtime backtrace lines
	// Each line looks like: "           0:  0x445 - <unknown>!funcname"
	var trace = "\nStack trace:"
	let lines = s.split("\n")
	for line in lines 'eachLine'
		let bangIdx = try line.findFirst("!") otherwise continue
		let afterBangIdx = try line.indexAfter(bangIdx) otherwise continue
		let afterBang = line.slice(afterBangIdx, endIndex: line.endIndex())
		let funcName = trimWhitespace(afterBang)
		// Skip mrt_panic (implementation detail) and mrt_start (always last)
		if funcName == "mrt_panic" 'skipPanic'
			continue
		end 'skipPanic'
		trace = "{trace}\n  in {funcName}"
	end 'eachLine'

	return "{programStderr}{trace}"
end 'convertWasmtimeStderr'

function normalizeStderr(s String) returns String
	var result = trimWhitespace(s)
	result = result.replace("\r\n", with: "\n")
	result = result.replace("\\", with: "/")
	let errorLines = result.split("\n")
	var normalized = ""
	var first = true
	for errLine in errorLines 'eachLine'
		let stripped = stripFilePathFromError(errLine)
		if first 'isFirst'
			normalized = stripped
			first = false
		end 'isFirst' else 'notFirst'
			normalized = "{normalized}\n{stripped}"
		end 'notFirst'
	end 'eachLine'
	return normalized
end 'normalizeStderr'

// Strip file path from an error line.
// Input:  "error E2010: /some/path/file.maxon:3:8: Expected '=' but got ':'"
// Output: "error E2010: Expected '=' but got ':'"
function stripFilePathFromError(line String) returns String
	if not line.contains("error E") 'notError'
		return line
	end 'notError'
	try line.findFirst("error E") otherwise return line
	let firstColon = try line.findFirst(": ") otherwise return line
	let afterFirstColon = try line.indexAfter(firstColon) otherwise return line
	let afterFirstColonSpace = try line.indexAfter(afterFirstColon) otherwise return line
	let rest = line.slice(afterFirstColonSpace, endIndex: line.endIndex())
	if not rest.contains("/") 'noPath'
		return line
	end 'noPath'
	let prefix = line.slice(line.startIndex(), endIndex: afterFirstColonSpace)
	let c1 = try rest.findFirst(":") otherwise return line
	let afterC1 = try rest.indexAfter(c1) otherwise return line
	let restAfterC1 = rest.slice(afterC1, endIndex: rest.endIndex())
	let c2 = try restAfterC1.findFirst(":") otherwise return line
	let afterC2 = try restAfterC1.indexAfter(c2) otherwise return line
	let restAfterC2 = restAfterC1.slice(afterC2, endIndex: restAfterC1.endIndex())
	let c3 = try restAfterC2.findFirst(": ") otherwise return line
	let afterC3 = try restAfterC2.indexAfter(c3) otherwise return line
	let afterC3Space = try restAfterC2.indexAfter(afterC3) otherwise return line
	let message = restAfterC2.slice(afterC3Space, endIndex: restAfterC2.endIndex())
	return "{prefix}{message}"
end 'stripFilePathFromError'

function cleanup(tempExe FilePath)
	try File.delete(tempExe) otherwise ignore
end 'cleanup'

// --- RequiredRdata validation ---
//
// Verify a compiled PE executable's `.rdata` section matches the typed-value
// block declared in the spec's `RequiredRdata` block. This is the byte-level
// counterpart to `RequiredIR` — it pins the on-disk constant layout produced
// by the backend so a regression in narrow-storage lowering, struct field
// packing, or rdata serialization surfaces as a comparison failure.
//
// The check is gated on `target.os == Os.windows` because only PE has a
// `.rdata` section. ELF (Linux) and Mach-O (macOS) place read-only data in
// other sections; mirroring this for those formats is out-of-scope here and
// matches the bootstrap's behaviour.

typealias RdataByte = int(0 to u8.max)
typealias RdataValue = int(i64.min to i64.max)
typealias SectionByteCount = int(0 to u64.max)
typealias SectionFileOffset = int(0 to u64.max)
typealias RdataWidth = int(1 to 8)
typealias HexNibble = int(0 to 15)
typealias UnicodeCodepoint = int(0 to 0x10FFFF)

type RdataCheckResult
	export var passed as bool
	export var message as String

	static function create(passed bool, message String) returns RdataCheckResult
		return Self{passed: passed, message: message}
	end 'create'
end 'RdataCheckResult'

enum RdataParseError implements Error
	missingType  // line had no space between type tag and value
	unknownType  // unrecognised type tag
	badInteger  // int.fromString failed
	outOfRange  // integer literal outside the requested type's range
	badFloat  // float.fromString failed
	badQuotedString  // utf8 form missing surrounding quotes
	badEscapeSequence  // unknown / malformed escape inside utf8 string
end 'RdataParseError'

enum PeParseError implements Error
	notPeFile  // missing DOS magic or PE signature
	truncated  // header read off the end of the buffer
	sectionMissing  // requested section name not present
end 'PeParseError'

type PeSectionInfo
	export var name as String
	export var virtualSize as SectionByteCount
	export var rawSize as SectionByteCount
	export var rawOffset as SectionFileOffset

	static function create(name String, virtualSize SectionByteCount, rawSize SectionByteCount, rawOffset SectionFileOffset) returns PeSectionInfo
		return Self{name: name, virtualSize: virtualSize, rawSize: rawSize, rawOffset: rawOffset}
	end 'create'
end 'PeSectionInfo'

typealias PeSectionInfoArray = Array with PeSectionInfo

// Append `value` as `width` little-endian bytes to `buf`. For signed inputs,
// rely on two's-complement bit patterns: `(value and 0xFF)` extracts the
// low byte regardless of sign. Width is the integer width in bytes (1, 2,
// 4, or 8); other widths panic.
function appendLittleEndian(buf ByteArray, value RdataValue, width RdataWidth)
	var v = value
	var i = 0
	while i < width 'shift'
		buf.push((v and 0xFF) as RdataByte)
		v = v shr 8
		i = i + 1
	end 'shift'
end 'appendLittleEndian'

// Parse a signed decimal integer, verify it fits in `[lo, hi]`, and return
// the value. Trims surrounding whitespace first because the spec format is
// comma-or-space separated and individual elements often carry trailing
// spaces.
function parseRangedInt(text String, lo RdataValue, hi RdataValue) returns RdataValue throws RdataParseError
	let trimmed = trimWhitespace(text)
	let value = try int.fromString(trimmed) otherwise throw RdataParseError.badInteger
	if value < lo 'tooSmall'
		throw RdataParseError.outOfRange
	end 'tooSmall'
	if value > hi 'tooBig'
		throw RdataParseError.outOfRange
	end 'tooBig'
	return value
end 'parseRangedInt'

// Decode escape sequences inside a `utf8 "..."` value: supports \n, \t, \r,
// \0, \\, \", \', \xNN, \uNNNN. Mirrors maxon-sharp/StringUtils.ResolveEscapes
// so the bootstrap and self-hosted runners accept the same spec syntax.
function decodeUtf8Escapes(text String) returns ByteArray throws RdataParseError
	let src = text.toByteArray()
	let n = src.count()
	var out = ByteArray.create()
	var i = 0
	while i < n 'walk'
		let c = try src.get(i) otherwise panic("decodeUtf8Escapes: i < n just checked but get({i}) failed")
		if c != '\\' 'plain'
			out.push(c)
			i = i + 1
			continue
		end 'plain'

		if i + 1 >= n 'trailingBackslash'
			throw RdataParseError.badEscapeSequence
		end 'trailingBackslash'

		let next = try src.get(i + 1) otherwise panic("decodeUtf8Escapes: i + 1 < n just checked but get failed")
		if next == 'x' 'hexEscape'
			if i + 3 >= n 'shortHex'
				throw RdataParseError.badEscapeSequence
			end 'shortHex'
			let h1 = try src.get(i + 2) otherwise panic("decodeUtf8Escapes: i + 3 < n just checked")
			let h2 = try src.get(i + 3) otherwise panic("decodeUtf8Escapes: i + 3 < n just checked")
			let v1 = try hexDigitValue(h1) otherwise throw RdataParseError.badEscapeSequence
			let v2 = try hexDigitValue(h2) otherwise throw RdataParseError.badEscapeSequence
			out.push(((v1 shl 4) or v2) as RdataByte)
			i = i + 4
			continue
		end 'hexEscape'

		if next == 'u' 'unicodeEscape'
			if i + 5 >= n 'shortU'
				throw RdataParseError.badEscapeSequence
			end 'shortU'
			let u1 = try src.get(i + 2) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u2 = try src.get(i + 3) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u3 = try src.get(i + 4) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let u4 = try src.get(i + 5) otherwise panic("decodeUtf8Escapes: i + 5 < n just checked")
			let v1 = try hexDigitValue(u1) otherwise throw RdataParseError.badEscapeSequence
			let v2 = try hexDigitValue(u2) otherwise throw RdataParseError.badEscapeSequence
			let v3 = try hexDigitValue(u3) otherwise throw RdataParseError.badEscapeSequence
			let v4 = try hexDigitValue(u4) otherwise throw RdataParseError.badEscapeSequence
			let cp = (v1 shl 12) or (v2 shl 8) or (v3 shl 4) or v4
			appendUtf8Codepoint(out, codepoint: cp)
			i = i + 6
			continue
		end 'unicodeEscape'

		var decoded = 0
		if next == 'n' 'esc_n'
			decoded = 10
		end 'esc_n' else if next == 't' 'esc_t'
			decoded = 9
		end 'esc_t' else if next == 'r' 'esc_r'
			decoded = 13
		end 'esc_r' else if next == '0' 'esc_0'
			decoded = 0
		end 'esc_0' else if next == '\\' 'esc_bs'
			decoded = 92
		end 'esc_bs' else if next == '"' 'esc_dq'
			decoded = 34
		end 'esc_dq' else if next == '\'' 'esc_sq'
			decoded = 39
		end 'esc_sq' else 'unknown'
			throw RdataParseError.badEscapeSequence
		end 'unknown'

		out.push(decoded as RdataByte)
		i = i + 2
	end 'walk'

	return out
end 'decodeUtf8Escapes'

function hexDigitValue(c RdataByte) returns HexNibble throws RdataParseError
	if c >= '0' 'gteZero'
		if c <= '9' 'isDigit'
			return c - '0'
		end 'isDigit'
	end 'gteZero'
	if c >= 'a' 'gteLowerA'
		if c <= 'f' 'isLower'
			return c - 'a' + 10
		end 'isLower'
	end 'gteLowerA'
	if c >= 'A' 'gteUpperA'
		if c <= 'F' 'isUpper'
			return c - 'A' + 10
		end 'isUpper'
	end 'gteUpperA'
	throw RdataParseError.badEscapeSequence
end 'hexDigitValue'

// Encode `codepoint` as UTF-8 into `buf`. Used by the \uNNNN escape — the
// BMP fits in at most 3 bytes per RFC 3629.
function appendUtf8Codepoint(buf ByteArray, codepoint UnicodeCodepoint)
	if codepoint < 0x80 'oneByte'
		buf.push(codepoint as RdataByte)
		return
	end 'oneByte'
	if codepoint < 0x800 'twoByte'
		buf.push((0xC0 or (codepoint shr 6)) as RdataByte)
		buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
		return
	end 'twoByte'
	if codepoint < 0x10000 'threeByte'
		buf.push((0xE0 or (codepoint shr 12)) as RdataByte)
		buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as RdataByte)
		buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
		return
	end 'threeByte'
	buf.push((0xF0 or (codepoint shr 18)) as RdataByte)
	buf.push((0x80 or ((codepoint shr 12) and 0x3F)) as RdataByte)
	buf.push((0x80 or ((codepoint shr 6) and 0x3F)) as RdataByte)
	buf.push((0x80 or (codepoint and 0x3F)) as RdataByte)
end 'appendUtf8Codepoint'

// Parse one comma-separated list of integers and append each as little-endian
// bytes of the given width. Range-checked against `[lo, hi]`.
function parseIntList(buf ByteArray, value String, lo RdataValue, hi RdataValue, width RdataWidth) throws RdataParseError
	let parts = value.split(",")
	for part in parts 'each'
		let n = try parseRangedInt(part, lo: lo, hi: hi)
		appendLittleEndian(buf, value: n, width: width)
	end 'each'
end 'parseIntList'

// Parse one space-separated list of integers — used only by the `u16` form
// (single line, multiple values separated by spaces), preserved for parity
// with the bootstrap parser.
function parseSpaceSeparatedU16(buf ByteArray, value String) throws RdataParseError
	let parts = value.split(" ")
	for part in parts 'each'
		let trimmed = trimWhitespace(part)
		if trimmed.isEmpty() 'skipEmpty'
			continue
		end 'skipEmpty'
		let n = try parseRangedInt(trimmed, lo: 0, hi: 0xFFFF)
		appendLittleEndian(buf, value: n, width: 2)
	end 'each'
end 'parseSpaceSeparatedU16'

function parseUtf8Value(buf ByteArray, value String) throws RdataParseError
	let trimmed = trimWhitespace(value)
	let len = trimmed.bytes().count()
	if len < 2 'tooShort'
		throw RdataParseError.badQuotedString
	end 'tooShort'
	let bytes = trimmed.toByteArray()
	let first = try bytes.get(0) otherwise panic("parseUtf8Value: bytes.count() >= 2 just verified")
	let last = try bytes.get(len - 1) otherwise panic("parseUtf8Value: bytes.count() >= 2 just verified")
	if first != '"' 'noOpenQuote'
		throw RdataParseError.badQuotedString
	end 'noOpenQuote'
	if last != '"' 'noCloseQuote'
		throw RdataParseError.badQuotedString
	end 'noCloseQuote'
	let inner = trimmed.slice(try trimmed.indexAfter(trimmed.startIndex()) otherwise panic("parseUtf8Value: indexAfter(start) failed on non-empty string"), endIndex: try previousIndex(trimmed, idx: trimmed.endIndex()) otherwise panic("parseUtf8Value: previousIndex(end) failed on non-empty string"))
	let decoded = try decodeUtf8Escapes(inner)
	for i in 0 upto decoded.count() 'copy'
		let b = try decoded.get(i) otherwise panic("parseUtf8Value: i < decoded.count() invariant")
		buf.push(b)
	end 'copy'
end 'parseUtf8Value'

// Return the StringIndex one step before `idx`. We need this for `utf8`
// because String slicing is half-open and we want to drop the trailing
// double-quote. Implemented as a linear walk from the start; the utf8 block
// is small enough that this is fine, and avoids needing a `previous` API.
function previousIndex(s String, idx StringIndex) returns StringIndex throws StringError
	var cur = s.startIndex()
	let endIdx = s.endIndex()
	if cur >= idx 'noStep'
		throw StringError.invalidIndex
	end 'noStep'
	while cur < endIdx 'walk'
		let next = try s.indexAfter(cur)
		if next >= idx 'reached'
			return cur
		end 'reached'
		cur = next
	end 'walk'
	throw StringError.invalidIndex
end 'previousIndex'

// Parse a `RequiredRdata` block into the concrete byte sequence the .rdata
// section should start with. Each line is a typed-value form; supported tags
// match the bootstrap (TestRunner.cs:ParseTypedSectionValues) plus the new
// narrow-storage forms (u8[], u16[], u32, u32[], i16[], i32[]) added for the
// enum-narrow-storage spec.
function parseRequiredRdataBytes(spec String) returns ByteArray throws RdataParseError
	var buf = ByteArray.create()
	let lines = spec.split("\n")
	for rawLine in lines 'eachLine'
		let line = trimWhitespace(rawLine)
		if line.isEmpty() 'skipBlank'
			continue
		end 'skipBlank'

		let spaceIdx = try line.findFirst(" ") otherwise throw RdataParseError.missingType
		let afterSpace = try line.indexAfter(spaceIdx) otherwise throw RdataParseError.missingType
		let typeTag = line.slice(line.startIndex(), endIndex: spaceIdx)
		let value = trimWhitespace(line.slice(afterSpace, endIndex: line.endIndex()))

		if typeTag == "i8" 'tagI8'
			let n = try parseRangedInt(value, lo: -128, hi: 127)
			appendLittleEndian(buf, value: n, width: 1)
			continue
		end 'tagI8'
		if typeTag == "u8" 'tagU8'
			let n = try parseRangedInt(value, lo: 0, hi: 0xFF)
			appendLittleEndian(buf, value: n, width: 1)
			continue
		end 'tagU8'
		if typeTag == "i16" 'tagI16'
			let n = try parseRangedInt(value, lo: -32768, hi: 32767)
			appendLittleEndian(buf, value: n, width: 2)
			continue
		end 'tagI16'
		if typeTag == "i32" 'tagI32'
			let n = try parseRangedInt(value, lo: -2147483648, hi: 2147483647)
			appendLittleEndian(buf, value: n, width: 4)
			continue
		end 'tagI32'
		if typeTag == "i64" 'tagI64'
			let n = try parseRangedInt(value, lo: i64.min, hi: i64.max)
			appendLittleEndian(buf, value: n, width: 8)
			continue
		end 'tagI64'
		if typeTag == "u32" 'tagU32'
			let n = try parseRangedInt(value, lo: 0, hi: 0xFFFFFFFF)
			appendLittleEndian(buf, value: n, width: 4)
			continue
		end 'tagU32'
		if typeTag == "u16" 'tagU16'
			// Space-separated values to match the bootstrap (short-type.md).
			try parseSpaceSeparatedU16(buf, value: value)
			continue
		end 'tagU16'
		if typeTag == "i8[]" 'tagI8Arr'
			try parseIntList(buf, value: value, lo: -128, hi: 127, width: 1)
			continue
		end 'tagI8Arr'
		if typeTag == "u8[]" 'tagU8Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFF, width: 1)
			continue
		end 'tagU8Arr'
		if typeTag == "i16[]" 'tagI16Arr'
			try parseIntList(buf, value: value, lo: -32768, hi: 32767, width: 2)
			continue
		end 'tagI16Arr'
		if typeTag == "u16[]" 'tagU16Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFFFF, width: 2)
			continue
		end 'tagU16Arr'
		if typeTag == "i32[]" 'tagI32Arr'
			try parseIntList(buf, value: value, lo: -2147483648, hi: 2147483647, width: 4)
			continue
		end 'tagI32Arr'
		if typeTag == "u32[]" 'tagU32Arr'
			try parseIntList(buf, value: value, lo: 0, hi: 0xFFFFFFFF, width: 4)
			continue
		end 'tagU32Arr'
		if typeTag == "i64[]" 'tagI64Arr'
			let parts = value.split(",")
			for part in parts 'eachI64'
				let trimmed = trimWhitespace(part)
				let n = try int.fromString(trimmed) otherwise throw RdataParseError.badInteger
				appendLittleEndian(buf, value: n, width: 8)
			end 'eachI64'
			continue
		end 'tagI64Arr'
		if typeTag == "f64" 'tagF64'
			let trimmed = trimWhitespace(value)
			let f = try float.fromString(trimmed) otherwise throw RdataParseError.badFloat
			let bits = __Builtins.floatToBits(f)
			appendLittleEndian(buf, value: bits, width: 8)
			continue
		end 'tagF64'
		if typeTag == "utf8" 'tagUtf8'
			try parseUtf8Value(buf, value: value)
			continue
		end 'tagUtf8'
		if typeTag == "pad" 'tagPad'
			let count = try parseRangedInt(value, lo: 0, hi: 0xFFFFFFFF)
			for _ in 0 upto count 'zero'
				buf.push(0)
			end 'zero'
			continue
		end 'tagPad'

		throw RdataParseError.unknownType
	end 'eachLine'
	return buf
end 'parseRequiredRdataBytes'

// Read a 16-bit little-endian unsigned int at `offset` from `buf`.
function readWordLE(buf ByteArray, offset SectionFileOffset) returns RdataValue throws PeParseError
	if offset + 2 > buf.count() 'oob'
		throw PeParseError.truncated
	end 'oob'
	let b0 = try buf.get(offset) otherwise panic("readWordLE: bounds checked above")
	let b1 = try buf.get(offset + 1) otherwise panic("readWordLE: bounds checked above")
	return b0 or (b1 shl 8)
end 'readWordLE'

// Read a 32-bit little-endian unsigned int at `offset` from `buf`.
function readDwordLE(buf ByteArray, offset SectionFileOffset) returns RdataValue throws PeParseError
	if offset + 4 > buf.count() 'oob'
		throw PeParseError.truncated
	end 'oob'
	let b0 = try buf.get(offset) otherwise panic("readDwordLE: bounds checked above")
	let b1 = try buf.get(offset + 1) otherwise panic("readDwordLE: bounds checked above")
	let b2 = try buf.get(offset + 2) otherwise panic("readDwordLE: bounds checked above")
	let b3 = try buf.get(offset + 3) otherwise panic("readDwordLE: bounds checked above")
	return b0 or (b1 shl 8) or (b2 shl 16) or (b3 shl 24)
end 'readDwordLE'

// Parse a PE file's section table from an in-memory copy of the executable.
// Layout reference (PE/COFF spec):
//   0x00      DOS magic ("MZ")
//   0x3C      u32 PE header file offset
//   <PE>      "PE\0\0" signature (4B), COFF header (20B), optional header (size in COFF.OptHdrSize)
//   <secs>    NumberOfSections × 40B section table entries
// Each section entry: name(8) | virtualSize(4) | virtualAddress(4) |
//   rawSize(4) | rawOffset(4) | 12 bytes padding | characteristics(4).
function parsePeSections(buf ByteArray) returns PeSectionInfoArray throws PeParseError
	let dosMagic = try readWordLE(buf, offset: 0)
	if dosMagic != 0x5A4D 'badDos'
		throw PeParseError.notPeFile
	end 'badDos'

	let peOffset = try readDwordLE(buf, offset: 0x3C)
	let peSignature = try readDwordLE(buf, offset: peOffset)
	if peSignature != 0x00004550 'badPe'
		throw PeParseError.notPeFile
	end 'badPe'

	// COFF header begins immediately after the 4-byte PE signature.
	let coff = peOffset + 4
	let numberOfSections = try readWordLE(buf, offset: coff + 2)
	let sizeOfOptionalHeader = try readWordLE(buf, offset: coff + 16)
	// Section table follows COFF (20B) + optional header.
	var entry = coff + 20 + sizeOfOptionalHeader

	var sections = PeSectionInfoArray.create()
	var idx = 0
	while idx < numberOfSections 'eachSection'
		if entry + 40 > buf.count() 'oob'
			throw PeParseError.truncated
		end 'oob'
		let name = readSectionName(buf, offset: entry)
		let virtualSize = try readDwordLE(buf, offset: entry + 8)
		// entry + 12 is virtualAddress (unused — we read the file image directly).
		let rawSize = try readDwordLE(buf, offset: entry + 16)
		let rawOffset = try readDwordLE(buf, offset: entry + 20)
		sections.push(PeSectionInfo.create(name, virtualSize: virtualSize, rawSize: rawSize, rawOffset: rawOffset))
		entry = entry + 40
		idx = idx + 1
	end 'eachSection'
	return sections
end 'parsePeSections'

// Read the 8-byte ASCII section name and strip trailing NUL padding. PE
// names are fixed-width; shorter names are zero-padded.
function readSectionName(buf ByteArray, offset SectionFileOffset) returns String
	var out = ""
	for i in 0 upto 8 'each'
		let b = try buf.get(offset + i) otherwise break
		if b == 0 'pad'
			break
		end 'pad'
		let ch = Character.fromCodepoint(b)
		out = "{out}{ch.toString()}"
	end 'each'
	return out
end 'readSectionName'

// Locate and read a named section's on-disk bytes. PE file padding stops at
// `min(virtualSize, rawSize)` — virtualSize is the logical extent of the
// section's contents, and rawSize is the file-aligned size which may include
// trailing zero padding. Reading `min(...)` matches the bootstrap and trims
// the alignment tail before the byte comparison.
function readPeSectionBytes(buf ByteArray, info PeSectionInfo) returns ByteArray
	var out = ByteArray.create()
	let logical = info.virtualSize if info.virtualSize < info.rawSize else info.rawSize
	let endOff = info.rawOffset + logical
	let cap = buf.count()
	let stop = endOff if endOff <= cap else cap
	for off in info.rawOffset upto stop 'copy'
		let b = try buf.get(off) otherwise break
		out.push(b)
	end 'copy'
	return out
end 'readPeSectionBytes'

// Format a byte array as space-separated lowercase hex for error messages.
function formatHexBytes(bytes ByteArray) returns String
	var out = ""
	let n = bytes.count()
	for i in 0 upto n 'each'
		let b = try bytes.get(i) otherwise break
		if i > 0 'sep'
			out = "{out} "
		end 'sep'
		out = "{out}{b:02x}"
	end 'each'
	return out
end 'formatHexBytes'

function findSection(sections PeSectionInfoArray, name String) returns PeSectionInfo throws PeParseError
	for section in sections 'each'
		if section.name == name 'match'
			return section
		end 'match'
	end 'each'
	throw PeParseError.sectionMissing
end 'findSection'

// Read the executable, locate `.rdata`, and verify the section's leading
// bytes match `expectedSpec`. The match is a prefix-match: the runtime may
// append extra rdata-resident data (string-interner pool, witness tables,
// etc.) after the user values, so we only compare up to the expected length.
// Trailing zero file-alignment padding is excluded by capping the read at
// `virtualSize` in readPeSectionBytes.
export function checkRequiredRdataBytes(expectedSpec String, exePath FilePath) returns RdataCheckResult
	let expected = try parseRequiredRdataBytes(expectedSpec) otherwise (e) 'parseFail'
		let reason = match e 'kind'
			missingType gives "missing type tag (expected '<type> <value>')"
			unknownType gives "unknown type tag"
			badInteger gives "could not parse integer literal"
			outOfRange gives "integer literal outside declared type's range"
			badFloat gives "could not parse float literal"
			badQuotedString gives "utf8 value missing surrounding double-quotes"
			badEscapeSequence gives "malformed escape sequence in utf8 string"
		end 'kind'
		return RdataCheckResult.create(false, message: "RequiredRdata parse error: {reason}")
	end 'parseFail'

	let exeBytes = try File.readBinary(exePath) otherwise 'readFail'
		return RdataCheckResult.create(false, message: "Failed to read executable at {exePath}")
	end 'readFail'

	let sections = try parsePeSections(exeBytes) otherwise (e) 'peFail'
		let reason = match e 'kind'
			notPeFile gives "not a PE file (DOS/PE signature missing)"
			truncated gives "PE headers truncated"
			sectionMissing gives "internal: sectionMissing thrown during parse"
		end 'kind'
		return RdataCheckResult.create(false, message: "Failed to parse PE: {reason}")
	end 'peFail'

	let rdata = try findSection(sections, name: ".rdata") otherwise 'noRdata'
		return RdataCheckResult.create(false, message: "PE does not contain .rdata section")
	end 'noRdata'

	let actual = readPeSectionBytes(exeBytes, info: rdata)
	let expectedLen = expected.count()
	let actualLen = actual.count()

	if actualLen < expectedLen 'tooShort'
		return RdataCheckResult.create(false, message: ".rdata mismatch.\nExpected ({expectedLen} bytes): {formatHexBytes(expected)}\nActual ({actualLen} bytes): {formatHexBytes(actual)}")
	end 'tooShort'

	for i in 0 upto expectedLen 'eachByte'
		let want = try expected.get(i) otherwise panic("checkRequiredRdataBytes: i < expectedLen invariant")
		let got = try actual.get(i) otherwise panic("checkRequiredRdataBytes: i < actualLen >= expectedLen invariant")
		if want != got 'mismatch'
			return RdataCheckResult.create(false, message: ".rdata mismatch.\nExpected ({expectedLen} bytes): {formatHexBytes(expected)}\nActual ({actualLen} bytes): {formatHexBytes(actual)}")
		end 'mismatch'
	end 'eachByte'

	return RdataCheckResult.create(true, message: "")
end 'checkRequiredRdataBytes'

// --- RequiredLowering validation ---

type LoweringCheckResult
	export var passed as bool
	export var message as String

	static function create(passed bool, message String) returns LoweringCheckResult
		return Self{passed: passed, message: message}
	end 'create'
end 'LoweringCheckResult'

function checkRequiredLowering(expected String, actual String) returns LoweringCheckResult
	let expNorm = normalizeLowering(expected)
	let actNorm = normalizeLowering(actual)
	if expNorm != actNorm 'mismatch'
		return LoweringCheckResult.create(false, message: "Lowering mismatch.\nExpected:\n{expNorm}\nActual:\n{actNorm}")
	end 'mismatch'
	return LoweringCheckResult.create(true, message: "")
end 'checkRequiredLowering'

function normalizeLowering(text String) returns String
	let lines = text.split("\n")
	var result = ""
	var first = true

	for line in lines 'eachLine'
		let trimmed = trimWhitespace(line)
		if trimmed.isEmpty() 'skipEmpty'
			continue
		end 'skipEmpty'
		if first 'isFirst'
			result = trimmed
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}\n{trimmed}"
		end 'notFirst'
	end 'eachLine'

	return result
end 'normalizeLowering'

// --- Update RequiredLowering blocks in spec files ---

// Update a single spec file with lowering logs collected during test runs.
function updateSpecLowering(specPath FilePath, targetKey String, results TestResultArray)
	var specContent = try File.readText(specPath) otherwise return

	var modified = false
	var totalUpdated = 0

	for result in results 'eachResult'
		if result.loweringLog.isEmpty() 'noLog'
			continue
		end 'noLog'

		let updatedContent = updateLoweringBlock(specContent, testName: result.testName, targetKey: targetKey, loweringLog: result.loweringLog)
		if updatedContent != specContent 'changed'
			specContent = updatedContent
			modified = true
			totalUpdated = totalUpdated + 1
			logInfo(LogCategory.testing, message: function() gives "Updated RequiredLowering:{targetKey} for {result.testName}")
		end 'changed'
	end 'eachResult'

	if modified 'writeBack'
		try File.writeText(specPath, content: specContent) otherwise 'writeErr'
			logError(LogCategory.testing, message: function() gives "Failed to write spec: {specPath}")
		end 'writeErr'
	end 'writeBack'

	if totalUpdated > 0 'showCount'
		logInfo(LogCategory.testing, message: function() gives "Updated {totalUpdated} RequiredLowering block(s) in {specPath}")
	end 'showCount'
end 'updateSpecLowering'

// Update or insert a RequiredLowering:{targetKey} block for a given test in spec content.
function updateLoweringBlock(specContent String, testName String, targetKey String, loweringLog String) returns String
	let lines = specContent.split("\n")
	let lineCount = lines.count()
	let testMarker = "<!-- test: {testName} -->"
	let blockHeader = "```RequiredLowering:{targetKey}"

	// Find the test marker line
	var testLine = -1
	for i in 0 upto lineCount 'findTest'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed == testMarker 'found'
			testLine = i
			break
		end 'found'
	end 'findTest'

	if testLine < 0 'notFound'
		return specContent
	end 'notFound'

	// Find the boundary: next test marker or end of file
	var nextTestLine = lines.count()
	for i in (testLine + 1) upto lineCount 'findNext'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith("<!-- test:") 'isNext'
			nextTestLine = i
			break
		end 'isNext'
		if trimmed.startsWith("<!-- disabled-test:") 'isDisabledNext'
			nextTestLine = i
			break
		end 'isDisabledNext'
	end 'findNext'

	// Look for existing RequiredLowering:{targetKey} block in this test's range
	var existingStart = -1
	var existingEnd = -1
	for i in (testLine + 1) upto nextTestLine 'findExisting'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith(blockHeader) 'foundStart'
			existingStart = i
		end 'foundStart'
		if existingStart >= 0 'inBlock'
			if i > existingStart 'afterHeader'
				if trimmed == "```" 'foundEnd'
					existingEnd = i
					break
				end 'foundEnd'
			end 'afterHeader'
		end 'inBlock'
	end 'findExisting'

	if existingStart >= 0 'replaceExisting'
		if existingEnd < 0 'noEnd'
			return specContent
		end 'noEnd'
		// Replace lines existingStart..existingEnd (inclusive) with new block
		var result = ""
		let lastLine = lineCount - 1
		for i in 0 upto lineCount 'rebuild'
			if i == existingStart 'insertNew'
				result = "{result}{blockHeader}\n{loweringLog}\n```"
			end 'insertNew' else if i > existingStart 'skipOld'
				if i <= existingEnd 'inOldBlock'
					continue
				end 'inOldBlock'
				let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild: i < lineCount = lines.count() but get({i}) failed")
				result = "{result}{line}"
			end 'skipOld' else 'keepLine'
				let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild: i < lineCount = lines.count() but get({i}) failed")
				result = "{result}{line}"
			end 'keepLine'
			if i < lastLine 'addNewline'
				result = "{result}\n"
			end 'addNewline'
		end 'rebuild'
		return result
	end 'replaceExisting'

	// No block for this target. Only insert one when the test already has a
	// RequiredLowering block for some OTHER target — the author signaled
	// they want lowering checks, so the new target needs parity. Tests with
	// no RequiredLowering anywhere are left alone (this isn't a backfill
	// tool); the missing-target check at run-time only fires when another
	// target's block exists.
	var hasOtherTargetBlock = false
	for i in (testLine + 1) upto nextTestLine 'findOther'
		let line = try lines.get(i) otherwise continue
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith("```RequiredLowering:") 'isLowering'
			hasOtherTargetBlock = true
			break
		end 'isLowering'
	end 'findOther'

	if not hasOtherTargetBlock 'noOther'
		return specContent
	end 'noOther'

	// Insert before nextTestLine, after the last non-empty line of the test
	// region (so blocks stay grouped under the test marker).
	var insertBefore = nextTestLine
	while insertBefore > testLine + 1 'skipTrailingBlank'
		let prevLine = try lines.get(insertBefore - 1) otherwise break
		if not trimWhitespace(prevLine).isEmpty() 'nonBlank'
			break
		end 'nonBlank'
		insertBefore = insertBefore - 1
	end 'skipTrailingBlank'

	var result2 = ""
	let lastLine2 = lineCount - 1
	for i in 0 upto lineCount 'rebuild2'
		if i == insertBefore 'insertHere'
			// Blank line between sibling blocks for readability.
			result2 = "{result2}\n{blockHeader}\n{loweringLog}\n```\n"
		end 'insertHere'
		let line = try lines.get(i) otherwise panic("updateLoweringBlock.rebuild2: i < lineCount but get({i}) failed")
		result2 = "{result2}{line}"
		if i < lastLine2 'addNewline2'
			result2 = "{result2}\n"
		end 'addNewline2'
	end 'rebuild2'
	if insertBefore >= lineCount 'insertAtEnd'
		result2 = "{result2}\n\n{blockHeader}\n{loweringLog}\n```"
	end 'insertAtEnd'
	return result2
end 'updateLoweringBlock'

// ─── Parallel batch infrastructure ───────────────────────────────────────────

// Prefix for the machine-readable result line a batch worker emits to stdout.
let workerBatchResultMarker = "WORKER_BATCH_RESULT:"

// Print one spec's failure messages, separating each failure with a blank
// line. Failure groups start with the fragment path (no leading spaces);
// indented lines that follow describe the failure cause. The blank-line
// gap before each new path keeps consecutive fragment failures visually
// distinct in the test runner output.
function logSpecFailureMessages(failures TextLineArray)
	for failMsg in failures 'eachFailure'
		if not failMsg.startsWith("  ") 'isPath'
			logError(LogCategory.testing, message: function() gives "")
		end 'isPath'
		logError(LogCategory.testing, message: function() gives failMsg)
	end 'eachFailure'
end 'logSpecFailureMessages'

// Join a StringArray with "|" separators (used for encoding skipped test names).
function joinPipe(names StringArray) returns String
	var result = ""
	var first = true
	for name in names 'each'
		if first 'isFirst'
			result = name
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}|{name}"
		end 'notFirst'
	end 'each'
	return result
end 'joinPipe'

// Emit one WORKER_BATCH_RESULT line on stdout. Format:
//   WORKER_BATCH_RESULT:{specName}:{passed}:compileMs:{ms}:skipped:{name1|name2|...}
// The fixed `compileMs:` and `skipped:` markers let parseBatchWorkerResult skip
// over them positionally, isolating the parser from accidental colons in names.
function emitWorkerResult(specName String, passed TestCount, compileMs Millis, skippedNames StringArray)
	let skippedStr = joinPipe(skippedNames)
	print("{workerBatchResultMarker}{specName}:{passed}:compileMs:{compileMs}:skipped:{skippedStr}\n")
end 'emitWorkerResult'

// Set up the on-disk fragment + spec-cache directories the workers all share.
// Called once at worker startup; idempotent so a re-spawned worker after a
// crash doesn't fail on the existing dirs.
function ensureWorkerCacheDirs(fragmentDir FilePath, specCacheDir FilePath)
	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Directory.create(fragmentDir)
	end 'noFragDir'
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'
end 'ensureWorkerCacheDirs'

// Create the per-spec subdirectories under the worker's cache + fragment trees.
function ensurePerSpecCacheDirs(fragmentDir FilePath, specCacheDir FilePath, specName String)
	let cacheSpecDir = specCacheDir.join(specName)
	let fragSpecDir = fragmentDir.join(specName)
	if not Directory.exists(cacheSpecDir) 'noCacheSpecDir'
		_ = Directory.create(cacheSpecDir)
	end 'noCacheSpecDir'
	if not Directory.exists(fragSpecDir) 'noFragSpecDir'
		_ = Directory.create(fragSpecDir)
	end 'noFragSpecDir'
end 'ensurePerSpecCacheDirs'

// Read+parse a spec into its raw test list. Returns an empty array when the
// spec is unreadable or marked draft; the caller treats empty as "skip" and
// emits its mode-specific empty result line. Logs the read failure on the
// runner's normal error path.
function loadSpecTests(root FilePath, specName String, targetKey String) returns SpecTestArray
	let specPath = root.join("specs").join("{specName}.md")
	let content = try File.readText(specPath) otherwise 'readErr'
		logError(LogCategory.testing, message: function() gives "Could not read spec: {specPath}")
		return SpecTestArray.create()
	end 'readErr'
	let fm = parseFrontmatter(content)
	if fm.status == "draft" 'isDraft'
		return SpecTestArray.create()
	end 'isDraft'
	return parseSpecFile(content, targetKey: targetKey)
end 'loadSpecTests'

// Process one spec's batch and emit exactly one WORKER_BATCH_RESULT line.
// Invoked from the persistent worker for each JOB:batch:<spec> line.
function runOneBatchJob(specName String, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, targetKey String, filter String, verbose bool)
	ensurePerSpecCacheDirs(fragmentDir, specCacheDir: specCacheDir, specName: specName)

	let tests = loadSpecTests(root, specName: specName, targetKey: targetKey)
	let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
	let batchable = unit.batchable

	if batchable.count() == 0 'noBatch'
		emitWorkerResult(specName, passed: 0, compileMs: 0, skippedNames: StringArray.create())
		return
	end 'noBatch'

	// Reset per-spec so the result line reports this spec's compile time only.
	totalCompileMs = 0
	let outcome = runSpecBatch(batchable, specName: specName, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target)

	if verbose 'showBatch'
		for verboseLine in outcome.verboseLines 'eachVerbose'
			logInfo(LogCategory.testing, message: function() gives verboseLine)
		end 'eachVerbose'
	end 'showBatch'

	emitWorkerResult(specName, passed: outcome.passed, compileMs: totalCompileMs, skippedNames: outcome.skippedTestNames)
end 'runOneBatchJob'

// Markers for the singles worker protocol. The `FAIL` lines carry one fragment-
// failure message each (verbatim after the prefix); the `RESULT` line summarises
// pass/fail counts and compile time for a spec.
let workerSingleFailMarker = "WORKER_SINGLE_FAIL:"
let workerSingleResultMarker = "WORKER_SINGLE_RESULT:"

// Breadcrumb marker workers emit on stderr right before each compile. The
// parent uses the most recent one to identify which compile triggered a panic.
// Format: `WORKER_COMPILING:<label>\n` where label is `spec/test` for single
// fragments, `spec (batch of N)` for batch compiles. Stripped by the parent
// before forwarding stderr so they don't pollute normal test output.
let workerCompilingMarker = "WORKER_COMPILING:"

// Emit the breadcrumb. Workers call this immediately before each compile so
// that if the compile panics, the parent can read the last breadcrumb and
// report which test was being compiled.
function emitWorkerCompiling(label String)
	printError("{workerCompilingMarker}{label}\n")
end 'emitWorkerCompiling'

// Pull the most recent `WORKER_COMPILING:` label out of the worker's stderr,
// or empty if none. Walks lines; the last match wins, since panics happen
// during the most recent compile.
function lastCompilingLabelFromStderr(stderr String) returns String
	var lastLabel = ""
	let lines = stderr.split("\n")
	for line in lines 'each'
		let trimmed = trimWhitespace(line)
		if not trimmed.startsWith(workerCompilingMarker) 'notMarker'
			continue
		end 'notMarker'
		// The marker ends in `:` and the payload follows. Find the first colon
		// so we don't have to take the marker's character count manually.
		let colonIdx = try trimmed.findFirst(":") otherwise continue
		let afterColon = try trimmed.indexAfter(colonIdx) otherwise continue
		lastLabel = trimmed.slice(afterColon, endIndex: trimmed.endIndex())
	end 'each'
	return lastLabel
end 'lastCompilingLabelFromStderr'

// Strip `WORKER_COMPILING:` lines from a stderr blob so the parent's normal
// forwarding doesn't dump them on the user. We keep the trailing newline of
// each non-stripped line intact so multi-line panic traces stay readable.
function stripCompilingBreadcrumbs(stderr String) returns String
	if not stderr.contains(workerCompilingMarker) 'fastPath'
		return stderr
	end 'fastPath'
	let lines = stderr.split("\n")
	var out = ""
	var first = true
	for line in lines 'each'
		let trimmed = trimWhitespace(line)
		if trimmed.startsWith(workerCompilingMarker) 'skip'
			continue
		end 'skip'
		if first 'firstLine'
			out = line
			first = false
		end 'firstLine' else 'restLine'
			out = "{out}\n{line}"
		end 'restLine'
	end 'each'
	return out
end 'stripCompilingBreadcrumbs'

// True if the worker's stderr looks like a runtime panic from the compiler
// itself (not a test fragment's panic — those are captured into the per-test
// .err file, not the worker's own stderr). The runtime emits panics in a fixed
// format: a `panic at <file>:<line>: <msg>` line followed by `Stack trace:`
// and one `  in <funcName>` per frame. Detecting both anchors avoids false
// positives from logs that incidentally contain the word "panic".
function workerStderrIsCompilerPanic(stderr String) returns bool
	if stderr.isEmpty() 'empty'
		return false
	end 'empty'
	if not stderr.contains("panic at ") 'noPanicAt'
		return false
	end 'noPanicAt'
	return stderr.contains("\nStack trace:")
end 'workerStderrIsCompilerPanic'

// Abort the parent runner immediately with the worker's panic output. Called
// when a worker subprocess panicked during compilation: re-running the same
// fragment in a fresh subprocess would just re-panic, so further retries waste
// minutes. Print the worker's stderr verbatim (it already includes the panic
// message and stack trace) and panic the parent with a one-line summary so
// the test run aborts with a non-zero exit code.
function abortOnWorkerCompilerPanic(workerLabel String, stderr String)
	let compilingLabel = lastCompilingLabelFromStderr(stderr)
	let cleaned = stripCompilingBreadcrumbs(stderr)
	printError("\n=== Compiler panic in worker ({workerLabel}) — aborting test run ===\n")
	if not compilingLabel.isEmpty() 'hasLabel'
		printError("Panicked while compiling: {compilingLabel}\n")
	end 'hasLabel'
	printError(cleaned)
	if not cleaned.endsWith("\n") 'noTrailingNl'
		printError("\n")
	end 'noTrailingNl'
	if compilingLabel.isEmpty() 'noLabel'
		panic("Compiler panicked while running spec tests; see stderr above")
	end 'noLabel'
	panic("Compiler panicked while compiling {compilingLabel}; see stderr above")
end 'abortOnWorkerCompilerPanic'

// Emit one WORKER_SINGLE_RESULT summary line for a spec.
// Format: WORKER_SINGLE_RESULT:{specName}:{passed}:{failed}:compileMs:{ms}
function emitWorkerSinglesResult(specName String, passed TestCount, failed TestCount, compileMs Millis)
	print("{workerSingleResultMarker}{specName}:{passed}:{failed}:compileMs:{compileMs}\n")
end 'emitWorkerSinglesResult'

// Emit one failure line for the given spec. The remainder of the line after the
// prefix is the failure text with newlines escaped so the parent's line-based
// reader sees a single `\n`-terminated record per call. specName contains no
// colons so the boundary between marker and payload is unambiguous.
function emitWorkerSinglesFail(specName String, line String)
	print("{workerSingleFailMarker}{specName}:{encodeFailPayload(line)}\n")
end 'emitWorkerSinglesFail'

// Encode a multi-line failure payload into a single line so the parent's
// line-based reader sees a single `\n`-terminated record per call.
// Backslash-first so the subsequent newline/CR rules don't double-escape
// the inserted backslashes. Reversed by `decodeFailPayload`.
function encodeFailPayload(s String) returns String
	var result = s.replace("\\", with: "\\\\")
	result = result.replace("\n", with: "\\n")
	result = result.replace("\r", with: "\\r")
	return result
end 'encodeFailPayload'

// Reverse of `encodeFailPayload`. Walks the bytes once so escape sequences
// don't recursively re-expand: `\\` → `\`, `\n` → newline, `\r` → CR.
function decodeFailPayload(s String) returns String
	let bytes = s.toByteArray()
	let n = bytes.count()
	var result = ByteArray.create()
	var i = 0
	while i < n 'walk'
		let b = try bytes.get(i) otherwise break
		if b == '\\' and i + 1 < n 'isEscape'
			let nextByte = try bytes.get(i + 1) otherwise 0
			if nextByte == 'n' 'isN'
				result.push(10 as Byte)
				i = i + 2
				continue
			end 'isN'
			if nextByte == 'r' 'isR'
				result.push(13 as Byte)
				i = i + 2
				continue
			end 'isR'
			if nextByte == '\\' 'isBackslash'
				result.push(92 as Byte)
				i = i + 2
				continue
			end 'isBackslash'
		end 'isEscape'
		result.push(b)
		i = i + 1
	end 'walk'
	return String.from(result)
end 'decodeFailPayload'

// Process one spec's non-batchable (single) tests and emit zero+
// WORKER_SINGLE_FAIL lines followed by exactly one WORKER_SINGLE_RESULT line.
// Invoked from the persistent worker for each JOB:singles:<spec> line. A panic
// in compile-pipeline code is contained to this worker process: the parent
// observes a missing/short result stream, marks the spec as failed, and
// continues. Each test is compiled via runTestFromFragment, the same machinery
// the in-process serial path uses.
function runOneSinglesJob(specName String, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, targetKey String, filter String, verbose bool)
	ensurePerSpecCacheDirs(fragmentDir, specCacheDir: specCacheDir, specName: specName)

	let tests = loadSpecTests(root, specName: specName, targetKey: targetKey)
	let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)

	if unit.nonBatchable.count() == 0 and unit.missingLoweringCount == 0 'noSingles'
		emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
		return
	end 'noSingles'

	totalCompileMs = 0
	let (sp, sf, failures) = runSingleTests(unit, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, verbose: verbose)

	for failLine in failures 'eachFailure'
		emitWorkerSinglesFail(specName, line: failLine)
	end 'eachFailure'

	emitWorkerSinglesResult(specName, passed: sp, failed: sf, compileMs: totalCompileMs)
end 'runOneSinglesJob'

// Process the given list of test names from one spec via the per-fragment
// path, emitting zero+ WORKER_SINGLE_FAIL lines and exactly one
// WORKER_SINGLE_RESULT line. Invoked from the persistent worker for each
// JOB:fallback:<spec>:<test1>|<test2>|... line. The known-broken list still
// gates so the parent's crashed-batch retry path doesn't rerun a test we
// deliberately partitioned out.
function runOneFallbackJob(specName String, testNames StringArray, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, targetKey String, verbose bool)
	ensurePerSpecCacheDirs(fragmentDir, specCacheDir: specCacheDir, specName: specName)

	let allTests = loadSpecTests(root, specName: specName, targetKey: targetKey)
	var selected = SpecTestArray.create()
	for tn in testNames 'eachName'
		let trimmedName = trimWhitespace(tn)
		if trimmedName.isEmpty() 'emptyName'
			continue
		end 'emptyName'
		if isSelfHostedKnownBroken(specName, testName: trimmedName) 'skipKnown'
			continue
		end 'skipKnown'
		for t in allTests 'findTest'
			if t.name == trimmedName 'matched'
				selected.push(t)
				break
			end 'matched'
		end 'findTest'
	end 'eachName'

	if selected.count() == 0 'noSelected'
		emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
		return
	end 'noSelected'

	let unit = SpecWorkUnit.create(specName, nonBatchable: selected, batchable: SpecTestArray.create(), missingLoweringFailures: TextLineArray.create(), missingLoweringCount: 0 as TestCount)
	totalCompileMs = 0
	let (sp, sf, failures) = runSingleTests(unit, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, verbose: verbose)

	for failLine in failures 'eachFailure'
		emitWorkerSinglesFail(specName, line: failLine)
	end 'eachFailure'

	emitWorkerSinglesResult(specName, passed: sp, failed: sf, compileMs: totalCompileMs)
end 'runOneFallbackJob'

// Marker emitted once at worker startup (after warmStdlibCache) and again after
// every job completes. The parent dispatcher uses it as the "send me work"
// signal in the streaming work-stealing protocol.
let workerReadyMarker = "WORKER_READY"

// Job-line prefixes for the persistent worker protocol. Each prefix is matched
// by `startsWith` so the remainder of the line is the prefix-stripped payload.
let persistentJobBatchPrefix = "JOB:batch:"
let persistentJobSinglesPrefix = "JOB:singles:"
let persistentJobFallbackPrefix = "JOB:fallback:"
let persistentExitCommand = "EXIT"

function emitWorkerReady()
	print("{workerReadyMarker}\n")
end 'emitWorkerReady'

// Dispatch one parsed job line to the appropriate per-spec helper. Unknown
// lines surface on stderr so the parent's stderr forwarding shows the bad
// payload — silently dropping them would deadlock the dispatcher waiting for
// a WORKER_READY that wouldn't otherwise be paired with a result line.
//
// Prefixes (`JOB:batch:`, etc.) are pure ASCII, so byte position equals
// character position — `sliceFromBytePos` is safe even though the spec name
// or test names that follow may not be.
function dispatchPersistentJob(line String, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, targetKey String, filter String, verbose bool)
	let batchPrefix = persistentJobBatchPrefix
	let singlesPrefix = persistentJobSinglesPrefix
	let fallbackPrefix = persistentJobFallbackPrefix
	if line.startsWith(batchPrefix) 'isBatch'
		let prefixLen = batchPrefix.count()
		let specName = sliceFromBytePos(line, bytePos: prefixLen)
		runOneBatchJob(specName, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, targetKey: targetKey, filter: filter, verbose: verbose)
		return
	end 'isBatch'
	if line.startsWith(singlesPrefix) 'isSingles'
		let prefixLen = singlesPrefix.count()
		let specName = sliceFromBytePos(line, bytePos: prefixLen)
		runOneSinglesJob(specName, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, targetKey: targetKey, filter: filter, verbose: verbose)
		return
	end 'isSingles'
	if line.startsWith(fallbackPrefix) 'isFallback'
		let prefixLen = fallbackPrefix.count()
		let rest = sliceFromBytePos(line, bytePos: prefixLen)
		// `rest` is `specName:test1|test2|...`. Test names may contain colons
		// in principle (spec authors are unconstrained), so split on the FIRST
		// colon only and treat the rest as the pipe-joined test list.
		let colonIdx = try rest.findFirst(":") otherwise 'noColon'
			printError("[PERSISTENT WORKER] malformed fallback job (no colon): {line}\n")
			emitWorkerSinglesResult("", passed: 0, failed: 0, compileMs: 0)
			return
		end 'noColon'
		let specName = rest.slice(rest.startIndex(), endIndex: colonIdx)
		let afterColon = try rest.indexAfter(colonIdx) otherwise 'noAfter'
			printError("[PERSISTENT WORKER] malformed fallback job (truncated): {line}\n")
			emitWorkerSinglesResult(specName, passed: 0, failed: 0, compileMs: 0)
			return
		end 'noAfter'
		let namesPart = rest.slice(afterColon, endIndex: rest.endIndex())
		let testNames = namesPart.split("|")
		runOneFallbackJob(specName, testNames: testNames, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, targetKey: targetKey, verbose: verbose)
		return
	end 'isFallback'
	// Unknown line. Surface to the parent via stderr so the diagnostic is
	// visible; do not emit a fake result line because we don't know which
	// result shape the parent is expecting.
	printError("[PERSISTENT WORKER] unknown job line: {line}\n")
end 'dispatchPersistentJob'

// Persistent worker: stays alive for the parent's whole run, processes one
// JOB line at a time over stdin, emits result markers on stdout. The single
// warmStdlibCache call amortises across every job this worker handles.
//
// Protocol:
//   in :  JOB:batch:<spec>
//         JOB:singles:<spec>
//         JOB:fallback:<spec>:<test1>|<test2>|...
//         EXIT
//   out:  WORKER_READY                    (at startup + after every job)
//         WORKER_BATCH_RESULT:...         (one per batch job)
//         WORKER_SINGLE_RESULT:...        (one per singles/fallback job)
//         WORKER_SINGLE_FAIL:...          (zero+ per singles/fallback job, before RESULT)
//
// The worker shuts down cleanly on `EXIT` or on stdin EOF. Result-line
// formats match what `parseBatchWorkerResult`, `parseSinglesResultLine`, and
// `parseSinglesFailLine` consume on the parent side.
export function runPersistentWorker(filter String, target Target, verbose bool) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: function() gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	setLogLevel(LogLevel.ERROR)
	warmStdlibCache(target)

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let specCacheDir = fragmentDir.join(".spec-cache")

	ensureWorkerCacheDirs(fragmentDir, specCacheDir: specCacheDir)

	var stdin = Console.stdin()
	emitWorkerReady()

	while true 'jobLoop'
		let line = try stdin.readLine() otherwise 'eof'
			break
		end 'eof'
		let trimmed = trimWhitespace(line)
		if trimmed == persistentExitCommand 'isExit'
			break
		end 'isExit'
		if trimmed.isEmpty() 'isEmpty'
			continue
		end 'isEmpty'

		dispatchPersistentJob(trimmed, root: root, fragmentDir: fragmentDir, specCacheDir: specCacheDir, target: target, targetKey: targetKey, filter: filter, verbose: verbose)
		emitWorkerReady()
	end 'jobLoop'

	return 0
end 'runPersistentWorker'

// Aggregated outcome for one spec collected from a singles worker's stdout.
type SinglesWorkerResult
	export var specName as String
	export var passed as TestCount
	export var failed as TestCount
	export var compileMs as Millis
	export var failures as TextLineArray
	export var valid as bool

	export static function invalid() returns SinglesWorkerResult
		return Self{specName: "", passed: 0, failed: 0, compileMs: 0, failures: TextLineArray.create(), valid: false}
	end 'invalid'

	export static function create(specName String, passed TestCount, failed TestCount, compileMs Millis, failures TextLineArray) returns SinglesWorkerResult
		return Self{specName: specName, passed: passed, failed: failed, compileMs: compileMs, failures: failures, valid: true}
	end 'create'
end 'SinglesWorkerResult'

// Parse one WORKER_SINGLE_RESULT line. Returns invalid() on any parse failure.
// Format: WORKER_SINGLE_RESULT:{specName}:{passed}:{failed}:compileMs:{ms}
function parseSinglesResultLine(line String) returns SinglesWorkerResult
	let parts = line.split(":")
	if parts.count() < 6 'tooFew'
		return SinglesWorkerResult.invalid()
	end 'tooFew'
	let tag = try parts.get(0) otherwise return SinglesWorkerResult.invalid()
	if tag != "WORKER_SINGLE_RESULT" 'wrongTag'
		return SinglesWorkerResult.invalid()
	end 'wrongTag'
	let specName = try parts.get(1) otherwise return SinglesWorkerResult.invalid()
	if specName.isEmpty() 'noSpec'
		return SinglesWorkerResult.invalid()
	end 'noSpec'
	let passedStr = try parts.get(2) otherwise return SinglesWorkerResult.invalid()
	let passed = try int.fromString(passedStr) otherwise return SinglesWorkerResult.invalid()
	let failedStr = try parts.get(3) otherwise return SinglesWorkerResult.invalid()
	let failed = try int.fromString(failedStr) otherwise return SinglesWorkerResult.invalid()
	let compileMsStr = try parts.get(5) otherwise return SinglesWorkerResult.invalid()
	let compileMs = try int.fromString(compileMsStr) otherwise return SinglesWorkerResult.invalid()
	return SinglesWorkerResult.create(specName, passed: passed as TestCount, failed: failed, compileMs: compileMs, failures: TextLineArray.create())
end 'parseSinglesResultLine'

// Extract the failure-text payload from a WORKER_SINGLE_FAIL line, given the
// spec name. Returns the empty string if the prefix doesn't match. The marker
// is ASCII and spec names contain no colons, so the second colon in the line
// (the one immediately after `{marker}{specName}`) is the payload boundary.
function parseSinglesFailLine(line String, specName String) returns String
	let prefix = "{workerSingleFailMarker}{specName}:"
	if not line.startsWith(prefix) 'noPrefix'
		return ""
	end 'noPrefix'
	var idx = line.startIndex()
	let prefixLen = prefix.count()
	for _ in 0 upto prefixLen 'advance'
		idx = try line.indexAfter(idx) otherwise return ""
	end 'advance'
	return decodeFailPayload(line.slice(idx, endIndex: line.endIndex()))
end 'parseSinglesFailLine'

// Print all failure-lines whose owner equals `specName`, in stream order.
// Mirrors logSpecFailureMessages but operates on the flat (owners, payloads)
// parallel-array buffer the dispatcher uses.
function logSpecFailuresFor(owners StringArray, payloads TextLineArray, specName String)
	let count = owners.count()
	for i in 0 upto count 'each'
		let owner = try owners.get(i) otherwise continue
		if owner != specName 'skipOther'
			continue
		end 'skipOther'
		let payload = try payloads.get(i) otherwise continue
		if not payload.startsWith("  ") 'isPath'
			logError(LogCategory.testing, message: function() gives "")
		end 'isPath'
		logError(LogCategory.testing, message: function() gives payload)
	end 'each'
end 'logSpecFailuresFor'

// Parsed outcome from one spec's WORKER_BATCH_RESULT stdout line.
type BatchWorkerResult
	export var specName as String
	export var passed as TestCount
	export var compileMs as Millis
	export var skippedNames as StringArray
	export var valid as bool

	export static function invalid() returns BatchWorkerResult
		return Self{specName: "", passed: 0, compileMs: 0, skippedNames: StringArray.create(), valid: false}
	end 'invalid'

	export static function create(specName String, passed TestCount, compileMs Millis, skippedNames StringArray) returns BatchWorkerResult
		return Self{specName: specName, passed: passed, compileMs: compileMs, skippedNames: skippedNames, valid: true}
	end 'create'
end 'BatchWorkerResult'

// Parse WORKER_BATCH_RESULT:{specName}:{passed}:compileMs:{ms}:skipped:{name1|name2|...}
// Returns invalid() on any parse failure; the caller then routes all batchable
// tests for this spec to the per-fragment fallback path.
function parseBatchWorkerResult(line String) returns BatchWorkerResult
	let parts = line.split(":")
	// [0]=WORKER_BATCH_RESULT [1]=specName [2]=passed [3]=compileMs [4]=ms [5]=skipped [6]=pipe-names
	if parts.count() < 7 'tooFew'
		return BatchWorkerResult.invalid()
	end 'tooFew'
	let tag = try parts.get(0) otherwise return BatchWorkerResult.invalid()
	if tag != "WORKER_BATCH_RESULT" 'wrongTag'
		return BatchWorkerResult.invalid()
	end 'wrongTag'
	let specName = try parts.get(1) otherwise return BatchWorkerResult.invalid()
	if specName.isEmpty() 'noSpec'
		return BatchWorkerResult.invalid()
	end 'noSpec'
	let passedStr = try parts.get(2) otherwise return BatchWorkerResult.invalid()
	let passed = try int.fromString(passedStr) otherwise return BatchWorkerResult.invalid()
	let compileMsStr = try parts.get(4) otherwise return BatchWorkerResult.invalid()
	let compileMs = try int.fromString(compileMsStr) otherwise return BatchWorkerResult.invalid()
	let skippedStr = try parts.get(6) otherwise return BatchWorkerResult.invalid()
	var skippedNames = StringArray.create()
	if not skippedStr.isEmpty() 'hasSkipped'
		let nameList = skippedStr.split("|")
		for rawName in nameList 'eachName'
			let name = trimWhitespace(rawName)
			if not name.isEmpty() 'nonEmpty'
				skippedNames.push(name)
			end 'nonEmpty'
		end 'eachName'
	end 'hasSkipped'
	return BatchWorkerResult.create(specName, passed: passed as TestCount, compileMs: compileMs, skippedNames: skippedNames)
end 'parseBatchWorkerResult'

// Find a SpecWorkUnit by spec name. Panics if not found — callers only query
// for names they previously inserted into `units`.
function findUnitByName(units SpecWorkUnitArray, specName String) returns SpecWorkUnit
	for unit in units 'each'
		if unit.specName == specName 'match'
			return unit
		end 'match'
	end 'each'
	panic("findUnitByName: spec '{specName}' not found in units")
end 'findUnitByName'

// Per-spec work unit: partitioned tests and pre-computed missing-lowering failures.
type SpecWorkUnit
	export var specName as String
	export var nonBatchable as SpecTestArray
	export var batchable as SpecTestArray
	export var missingLoweringFailures as TextLineArray
	// Count of tests that failed due to missing RequiredLowering blocks.
	export var missingLoweringCount as TestCount

	export static function create(specName String, nonBatchable SpecTestArray, batchable SpecTestArray, missingLoweringFailures TextLineArray, missingLoweringCount TestCount) returns SpecWorkUnit
		return Self{specName: specName, nonBatchable: nonBatchable, batchable: batchable, missingLoweringFailures: missingLoweringFailures, missingLoweringCount: missingLoweringCount}
	end 'create'

	// Total number of tests this unit will report (passed + failed combined).
	export function totalCount() returns TestCount
		return self.batchable.count() + self.nonBatchable.count() + self.missingLoweringCount
	end 'totalCount'
end 'SpecWorkUnit'

export typealias SpecWorkUnitArray = Array with SpecWorkUnit

// Partition a spec's parsed tests into batchable / non-batchable / missing-lowering buckets.
// `filter`, when non-empty, restricts to tests whose "{specName}/{test.name}" path contains it.
// A test that authors a RequiredLowering block for some target must author one for THIS
// target too — otherwise lowering changes that affect this target slip through unobserved
// (the original check is silently skipped when the target-qualified block is missing).
// J.4e: self-hosted-only skip list for tests that pass in bootstrap but
// hit known gaps in the self-hosted pipeline. Each entry is the
// `{specName}/{testName}` path the runner generates. Tests on this list
// are dropped from the partition entirely — neither counted as passing
// nor reported as failing — mirroring the way `disabled-test:` markers
// would behave, but without requiring spec-file edits that also reduce
// the bootstrap test count. Empty list when self-hosted parity matches
// bootstrap.
function isSelfHostedKnownBroken(specName String, testName String) returns bool
	// J.4e introduced this filter for tests passing in bootstrap but missing
	// in self-hosted. J.4f.1 emptied the list after fixing the stdlib-cache
	// disk-read path so where-clause constraints survive the cache round
	// trip (decodeStdlibCache used to wipe `data.typeParameters` and rebuild
	// it from `project.typeParameters`, which holds no constraints at that
	// point). The hook stays so future transient gaps can be tagged here
	// without retrofitting every call site.
	let path = "{specName}/{testName}"
	if path == "" 'unreachable'
		return true
	end 'unreachable'
	return false
end 'isSelfHostedKnownBroken'

// Match `testPath` against `filter`. Empty filter matches everything. A
// comma-separated filter (`a,b,c`) matches if any of the terms is a
// substring of `testPath` — lets `--filter=basics,arrays,map` run a quick
// representative subset without chaining multiple invocations. Single-term
// filters keep the historical substring semantics. Whitespace around terms
// is trimmed.
function filterMatches(filter String, testPath String) returns bool
	if filter.isEmpty() 'noFilter'
		return true
	end 'noFilter'
	for term in filter.split(",") 'eachTerm'
		let trimmed = term.trim()
		if trimmed.isEmpty() 'skipEmpty'
			continue
		end 'skipEmpty'
		if testPath.contains(trimmed) 'match'
			return true
		end 'match'
	end 'eachTerm'
	return false
end 'filterMatches'

function partitionSpecTests(tests SpecTestArray, specName String, filter String, targetKey String) returns SpecWorkUnit
	var batchable = SpecTestArray.create()
	var nonBatchable = SpecTestArray.create()
	var missingLoweringFailures = TextLineArray.create()
	var missingLoweringCount = 0 as TestCount

	for test in tests 'partition'
		let testPath = "{specName}/{test.name}"
		if not filterMatches(filter, testPath: testPath) 'noMatch'
			continue
		end 'noMatch'
		if isSelfHostedKnownBroken(specName, testName: test.name) 'knownBroken'
			continue
		end 'knownBroken'
		if test.expectation.hasAnyRequiredLowering and not test.expectation.hasRequiredLowering 'missingTargetLowering'
			missingLoweringFailures.push("specs/{specName}.md::{test.name}")
			missingLoweringFailures.push("  Missing RequiredLowering:{targetKey} block — other targets have one for this test. Run with --update-required to populate, or remove the existing target-specific blocks.")
			missingLoweringCount = missingLoweringCount + 1
			continue
		end 'missingTargetLowering'
		if isBatchable(specName, test: test) 'isBatch'
			batchable.push(test)
		end 'isBatch' else 'isSingle'
			nonBatchable.push(test)
		end 'isSingle'
	end 'partition'

	return SpecWorkUnit.create(specName, nonBatchable: nonBatchable, batchable: batchable, missingLoweringFailures: missingLoweringFailures, missingLoweringCount: missingLoweringCount)
end 'partitionSpecTests'

// Look up tests in `batchable` by name and append matches to `dest`. Used to
// route tests the batch rewriter rejected (or that a batch-wide failure forced
// off the batched path) onto the per-fragment fallback path.
function appendSkippedToFallback(dest SpecTestArray, batchable SpecTestArray, skippedNames StringArray)
	for skipName in skippedNames 'eachSkipped'
		for test in batchable 'findTest'
			if test.name == skipName 'matchTest'
				dest.push(test)
			end 'matchTest'
		end 'findTest'
	end 'eachSkipped'
end 'appendSkippedToFallback'

// Run per-fragment tests for `unit`. Also counts pre-computed missing-lowering
// failures toward the returned failed count.
// Returns (passed, failed, failureMessages).
function runSingleTests(unit SpecWorkUnit, root FilePath, fragmentDir FilePath, specCacheDir FilePath, target Target, verbose bool) returns (TestCount, TestCount, TextLineArray)
	let specName = unit.specName
	var specPassed = 0 as TestCount
	var specFailed = unit.missingLoweringCount
	var specFailures = TextLineArray.create()

	for msg in unit.missingLoweringFailures 'copyMissing'
		specFailures.push(msg)
	end 'copyMissing'

	for test in unit.nonBatchable 'eachSingle'
		let testPath = "{specName}/{test.name}"
		let fragPath = fragmentDir.join(specName).join("{test.name}.test")
		writeFragment(fragmentDir, specName: specName, test: test, compileIr: "")

		let fragment = try parseFragment(fragPath) otherwise 'parseFailed'
			logError(LogCategory.testing, message: function() gives "[FAIL] {testPath} - could not parse fragment")
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			specFailures.push("  Failed to parse fragment file")
			continue
		end 'parseFailed'

		let result = runTestFromFragment(fragment, projectRoot: root, target: target, specName: specName, specCacheDir: specCacheDir)

		if not result.compileIr.isEmpty() 'hasIr'
			writeFragment(fragmentDir, specName: specName, test: test, compileIr: result.compileIr)
		end 'hasIr'

		if result.passed 'pass'
			specPassed = specPassed + 1
		end 'pass' else 'fail'
			specFailed = specFailed + 1
			specFailures.push(fragPath.toString())
			if not result.errorMessage.isEmpty() 'hasErr'
				specFailures.push("  {result.errorMessage}")
			end 'hasErr'
		end 'fail'

		if verbose 'showTest'
			if result.passed 'showPass'
				logInfo(LogCategory.testing, message: function() gives "[PASS] {testPath}")
			end 'showPass' else 'showFail'
				logInfo(LogCategory.testing, message: function() gives "[FAIL] {testPath}")
			end 'showFail'
		end 'showTest'
	end 'eachSingle'

	return (specPassed, specFailed, specFailures)
end 'runSingleTests'

// ─── Work-stealing dispatcher: types + helpers ───────────────────────────────

// Worker slot identifier in the pool. Practically capped by the OS process
// table; the upper bound is generous so cast sites don't have to constrain.
typealias WorkerId = int(0 to u32.max)

// One spec's worth of work assigned to the unified job queue. A spec may
// generate up to two jobs (one batch + one singles) plus an optional fallback
// job that's enqueued at runtime when a batch worker reports rewriter-rejected
// tests. `weight` orders the queue slowest-first so the long-pole tests start
// early and overlap with the rest of the run instead of gating wall time.
type SpecJob
	export var kind as String  // "batch" | "singles" | "fallback"
	export var specName as String
	export var fallbackTests as StringArray  // populated only when kind == "fallback"
	export var weight as TestCount  // estimated cost; larger = dispatch first

	export static function createBatch(specName String, weight TestCount) returns SpecJob
		return Self{kind: "batch", specName: specName, fallbackTests: StringArray.create(), weight: weight}
	end 'createBatch'

	export static function createSingles(specName String, weight TestCount) returns SpecJob
		return Self{kind: "singles", specName: specName, fallbackTests: StringArray.create(), weight: weight}
	end 'createSingles'

	export static function createFallback(specName String, tests StringArray, weight TestCount) returns SpecJob
		return Self{kind: "fallback", specName: specName, fallbackTests: tests, weight: weight}
	end 'createFallback'

	// Empty-marker job. Returned by helpers as the "no follow-up needed" or
	// "queue empty" sentinel. Callers test `kind != ""` before using the value.
	export static function empty() returns SpecJob
		return Self{kind: "", specName: "", fallbackTests: StringArray.create(), weight: 0 as TestCount}
	end 'empty'

	// Deep copy: clones the inner fallbackTests so the result does not borrow
	// from `self`. Used by popHeaviestJob to materialise a return value before
	// mutating the source array.
	export function clone() returns SpecJob
		var testsCopy = StringArray.create()
		for t in fallbackTests 'each'
			testsCopy.push(t)
		end 'each'
		return Self{kind: kind, specName: specName, fallbackTests: testsCopy, weight: weight}
	end 'clone'

	// Render the wire-format job line the persistent worker reads from stdin.
	export function toJobLine() returns String
		if kind == "batch" 'isBatch'
			return "{persistentJobBatchPrefix}{specName}"
		end 'isBatch'
		if kind == "singles" 'isSingles'
			return "{persistentJobSinglesPrefix}{specName}"
		end 'isSingles'
		if kind == "fallback" 'isFallback'
			return "{persistentJobFallbackPrefix}{specName}:{joinPipe(fallbackTests)}"
		end 'isFallback'
		panic("SpecJob.toJobLine: unknown kind '{kind}'")
	end 'toJobLine'

	// Diagnostic label for logs / panic messages.
	export function label() returns String
		return "{kind}:{specName}"
	end 'label'
end 'SpecJob'

typealias SpecJobArray = Array with SpecJob

// Pop the highest-weight job, replacing the popped slot with the array's last
// element. Returns the empty-marker job (kind == "") when the queue is empty.
// Mutates `queue` in place; intended for the dispatch loop only.
function popHeaviestJob(queue SpecJobArray) returns SpecJob
	let n = queue.count()
	if n == 0 'empty'
		return SpecJob.empty()
	end 'empty'
	var bestIdx = 0
	var bestWeight = 0 as TestCount
	var first = true
	for i in 0 upto n 'scan'
		let candidate = try queue.get(i) otherwise continue
		if first or candidate.weight > bestWeight 'isBetter'
			bestIdx = i
			bestWeight = candidate.weight
			first = false
		end 'isBetter'
	end 'scan'
	// Swap the heaviest slot with the array's tail, then pop. `.clone()` cuts
	// the borrow from `queue` so the subsequent `queue.set` is allowed: without
	// it the borrow checker keeps `chosen` tied to the array's storage.
	let chosen = (try queue.get(bestIdx) otherwise panic("popHeaviestJob: get({bestIdx}) failed despite earlier scan")).clone()
	if bestIdx != n - 1 'notLast'
		let last = (try queue.get(n - 1) otherwise panic("popHeaviestJob: get(last) failed")).clone()
		try queue.set(bestIdx, value: last) otherwise panic("popHeaviestJob: set({bestIdx}) failed")
	end 'notLast'
	_ = try queue.pop() otherwise panic("popHeaviestJob: pop() failed despite non-empty queue")
	return chosen
end 'popHeaviestJob'

// Read result lines from `child` until the next WORKER_READY marker. Throws
// SubprocessError.ioFailed on EOF before READY (worker crashed mid-job).
//
// Protocol invariant exploited here: workers never emit empty stdout lines.
// The only `print(...)` calls in the worker entry points are WORKER_READY,
// WORKER_BATCH_RESULT, WORKER_SINGLE_RESULT, and WORKER_SINGLE_FAIL — all
// non-empty. So an empty line from readStdoutLine() reliably means EOF.
//
// Lives as a free function (not a method on PersistentWorkerHandle) so the
// dispatcher can launch it via `async drainResultsThunk(...)`. Calling
// `async h.drainResults(...)` would bind the GT to the struct instance which
// the dispatcher needs to keep mutating in the meantime; passing the inner
// `child` handle by value lets the GT run independently of the slot's struct.
// StreamingSubprocess copies share the runtime-side pipe handle by refcount,
// so the GT's copy and the parent's copy reference the same OS object.
function drainResultsThunk(child StreamingSubprocess) returns StringArray throws SubprocessError
	var lines = StringArray.create()
	while true 'lineLoop'
		let line = try child.readStdoutLine()
		if line.isEmpty() 'eof'
			// EOF before WORKER_READY = worker exited mid-job (panic, crash,
			// or watchdog kill). Surface as an ioFailed so the dispatcher's
			// `try await ... otherwise 'workerDied` routes through
			// recoverFromCrashedJob the same way an I/O error does.
			throw SubprocessError.ioFailed("EOF before WORKER_READY")
		end 'eof'
		let trimmed = trimWhitespace(line)
		if trimmed == workerReadyMarker 'done'
			return lines
		end 'done'
		lines.push(line)
	end 'lineLoop'
	panic("drainResultsThunk: unreachable")
end 'drainResultsThunk'

// Promise carrying the drained lines of one async drain. The dispatcher keeps
// a parallel array of these (one per worker slot) and `await`s the slot it
// next wants to read from. Because every drain promise is spawned at dispatch
// time, the underlying overlapped stdout reads are all issued to the IOCP
// runtime in parallel — slow workers don't gate fast ones.
typealias DrainPromise = Promise with StringArray
typealias DrainPromiseArray = Array with DrainPromise

// Per-slot dispatch timestamps (Clock.nowMs() at the moment the drain GT was
// spawned). Used by the dispatcher's idle-tick watchdog to detect a worker
// that hasn't emitted WORKER_READY within workerJobTimeoutMs and force-kill
// it. Entry is 0 for never-dispatched slots; never read on a non-busy slot.
typealias MillisArray = Array with Millis

// One persistent worker subprocess in the work-stealing pool. The struct holds
// only the OS-side handle + an id for diagnostics; per-job state (which job is
// currently in flight, whether the slot is busy, accumulated stderr) lives in
// the dispatcher's parallel arrays so the struct itself is small and copyable.
type PersistentWorkerHandle
	export var child as StreamingSubprocess
	export var workerId as WorkerId

	// Spawn the child WITHOUT blocking on its WORKER_READY hello. The caller is
	// responsible for invoking `awaitReady()` before sending jobs. Used by the
	// two-phase parallel-spawn path so all N workers' CreateProcessW + startup
	// (cmdline parse, runtime init, stdlib cache warm) run concurrently rather
	// than each serializing on the previous worker's READY drain. Net win is
	// ~1.5s wall time over a 12-worker pool because Phase 2 now hides the
	// ~140ms warmStdlibCache per worker under a single readiness barrier.
	//
	// Safety: the underlying runtime emits CreateProcessW with STARTUPINFOEX +
	// PROC_THREAD_ATTRIBUTE_HANDLE_LIST so each child inherits exactly the 3
	// std handles in its own STARTUPINFOW, never sibling spawns' pipes. Without
	// that runtime fix (in X86CodeEmitter.Runtime.cs's __subp_spawn_core), this
	// pipeline pattern races and corrupts IPC.
	export static function spawnNoWait(exe String, workerId WorkerId, targetStr String, filter String, verbose bool) returns PersistentWorkerHandle throws SubprocessError
		let exeFile = try FilePath.from(exe) otherwise 'badExe'
			throw SubprocessError.spawnFailed("worker {workerId}: invalid exe path '{exe}'")
		end 'badExe'
		var argv = StringArray.create()
		argv.push("spec-test")
		argv.push("--worker-persistent")
		argv.push("--target={targetStr}")
		argv.push("--workers=1")
		if not filter.isEmpty() 'hasFilter'
			argv.push("--filter={filter}")
		end 'hasFilter'
		if verbose 'isVerbose'
			argv.push("--verbose")
		end 'isVerbose'
		let c = try StreamingSubprocess.spawn(Executable.path(exeFile), arguments: argv)
		return PersistentWorkerHandle{child: c, workerId: workerId}
	end 'spawnNoWait'

	// Drain the startup WORKER_READY hello from a handle obtained via
	// spawnNoWait. Pairs with the two-phase pool startup.
	export function awaitReady() throws SubprocessError
		let ready = try child.readStdoutLine()
		if trimWhitespace(ready) != workerReadyMarker 'badHello'
			child.release()
			throw SubprocessError.ioFailed("worker {workerId} startup: expected {workerReadyMarker}, got '{ready}'")
		end 'badHello'
	end 'awaitReady'

	// Write one job line; the trailing newline is added by writeStdinLine.
	export function sendJob(jobLine String) throws SubprocessError
		try child.writeStdinLine(jobLine)
	end 'sendJob'

	// Send EXIT, close stdin, await the child, drain whatever it wrote to
	// stderr while alive, then release the OS handle. Drain is synchronous
	// after wait() because the child has exited (its stderr write end is
	// closed by Windows) — the read loop just consumes pipe-buffered bytes
	// and returns when ReadFile returns 0 (EOF). Forwards any non-breadcrumb
	// content to the parent's stderr; aborts on detected compiler panic.
	//
	// An earlier design used `async drainWorkerStderr(child)` to drain
	// continuously, but each async GT leaked 1 MM allocation per worker
	// (Promise box + GT arg buffer not returning to the slab). With workers
	// suppressed at LogLevel.ERROR, stderr volume per run is negligible
	// (zero on the success path) so deferring the drain costs nothing.
	export function shutdownAndDrainStderr() returns ExitInt throws SubprocessError
		try child.writeStdinLine(persistentExitCommand)
		child.closeStdin()
		let code = try child.wait()

		var sb = ""
		let cap = 65536 as ByteLimit
		while true 'lineLoop'
			let line = try child.readStderrLineCapped(cap) otherwise break
			if line.isEmpty() 'eof'
				break
			end 'eof'
			if sb.isEmpty() 'firstLine'
				sb = line
			end 'firstLine' else 'restLine'
				sb = "{sb}\n{line}"
			end 'restLine'
		end 'lineLoop'

		let cleaned = stripCompilingBreadcrumbs(sb)
		if not cleaned.isEmpty() 'hasContent'
			if workerStderrIsCompilerPanic(cleaned) 'panicked'
				abortOnWorkerCompilerPanic("persistent worker {workerId}", stderr: cleaned)
			end 'panicked'
			printError(cleaned)
			if not cleaned.endsWith("\n") 'noNl'
				printError("\n")
			end 'noNl'
		end 'hasContent'

		child.release()
		return code
	end 'shutdownAndDrainStderr'
end 'PersistentWorkerHandle'

typealias PersistentWorkerHandleArray = Array with PersistentWorkerHandle

// Maximum fallback tests packed into a single follow-up job. A batch that
// the rewriter rejected often produces 60+ tests; running them all in one
// worker can take 10+ seconds, gating wall time on a single late-arriving
// long-pole. Splitting into chunks of this size lets several workers crunch
// the fallback concurrently. 8 is a compromise: small enough that 75 tests
// fan out across ~10 chunks (covers a 12-worker pool), large enough that
// the per-job IPC overhead (~5ms send + stdout drain) stays a small
// fraction of each chunk's actual compile work (~1-2s).
let maxFallbackChunk = 8 as TestCount

// Fixed weight bonus for tests that re-compile the world. See the comment
// in `runAllSpecTestsParallel` next to the call site for the rationale.
let stdlibBurden = 16384 as TestCount

// Sum the weighted source bytes of a list of tests, applying `stdlibBurden`
// to any test that triggers a re-compile-the-world path. Shared by the
// batch and singles queue-weight computations so both observe the same
// scoring model.
function sumTestWeight(tests SpecTestArray) returns TestCount
	var total = 0 as TestCount
	for t in tests 'eachTest'
		var w = t.source.byteLength()
		if t.cacheParity or t.includeStdlibIr 'isHeavy'
			w = w + stdlibBurden
		end 'isHeavy'
		total = total + w
	end 'eachTest'
	return total
end 'sumTestWeight'

// Pop-style helper for routing one worker's drained stdout into the dispatcher's
// accumulators. Mutates the accumulators in place; returns any follow-up
// SpecJobs that should be re-queued as a result of this job's output — used
// when a batch job reports rewriter-rejected tests, which are repacked into
// per-`maxFallbackChunk` fallback jobs for the same spec.
function processWorkerResults(resultLines StringArray, job SpecJob, units SpecWorkUnitArray, totalPassed_io VarHolder, totalFailed_io VarHolder, failOwners StringArray, failPayloads TextLineArray) returns SpecJobArray
	// VarHolder dance is a workaround for the runner not having out-params for
	// primitive locals; the caller boxes its accumulators and we update through
	// the boxes.
	var followups = SpecJobArray.create()
	for line in resultLines 'eachLine'
		let trimmedLine = trimWhitespace(line)
		if trimmedLine.startsWith(workerSingleFailMarker) 'isFail'
			let payload = parseSinglesFailLine(trimmedLine, specName: job.specName)
			if not payload.isEmpty() or trimmedLine == "{workerSingleFailMarker}{job.specName}:" 'matches'
				failOwners.push(job.specName)
				failPayloads.push(payload)
			end 'matches' else 'orphan'
				logError(LogCategory.testing, message: function() gives "[DISPATCH ERROR] orphan fail line for {job.label()}: {trimmedLine}")
			end 'orphan'
			continue
		end 'isFail'
		if trimmedLine.startsWith(workerBatchResultMarker) 'isBatchResult'
			let parsed = parseBatchWorkerResult(trimmedLine)
			if not parsed.valid 'invalidBatch'
				logError(LogCategory.testing, message: function() gives "[DISPATCH ERROR] malformed batch result for {job.label()}: {trimmedLine}")
				continue
			end 'invalidBatch'
			totalCompileMs = totalCompileMs + parsed.compileMs
			totalPassed_io.value = totalPassed_io.value + parsed.passed
			if parsed.skippedNames.count() > 0 'hasSkipped'
				// Filter through the unit's batchable list so test names invented
				// by the rewriter (none today) don't get re-issued as fallback
				// work. Pack the surviving names into chunks of `maxFallbackChunk`
				// each, weighted by their source bytes, so several workers can
				// process the chunks concurrently instead of one worker
				// serialising the whole spec's rejected-tests list.
				let unit = findUnitByName(units, specName: parsed.specName)
				var chunkNames = StringArray.create()
				var chunkBytes = 0 as TestCount
				for skipName in parsed.skippedNames 'eachSkip'
					for t in unit.batchable 'findTest'
						if t.name == skipName 'matched'
							chunkNames.push(skipName)
							chunkBytes = chunkBytes + t.source.byteLength()
							break
						end 'matched'
					end 'findTest'
					if chunkNames.count() >= maxFallbackChunk 'flushChunk'
						followups.push(SpecJob.createFallback(parsed.specName, tests: chunkNames, weight: chunkBytes))
						chunkNames = StringArray.create()
						chunkBytes = 0 as TestCount
					end 'flushChunk'
				end 'eachSkip'
				if chunkNames.count() > 0 'tailChunk'
					followups.push(SpecJob.createFallback(parsed.specName, tests: chunkNames, weight: chunkBytes))
				end 'tailChunk'
			end 'hasSkipped'
			continue
		end 'isBatchResult'
		if trimmedLine.startsWith(workerSingleResultMarker) 'isSingleResult'
			let result = parseSinglesResultLine(trimmedLine)
			if not result.valid 'invalidSingle'
				logError(LogCategory.testing, message: function() gives "[DISPATCH ERROR] malformed singles/fallback result for {job.label()}: {trimmedLine}")
				continue
			end 'invalidSingle'
			totalCompileMs = totalCompileMs + result.compileMs
			totalPassed_io.value = totalPassed_io.value + result.passed
			totalFailed_io.value = totalFailed_io.value + result.failed
			if result.failed > 0 'hasFail'
				let specTotal = result.passed + result.failed
				logError(LogCategory.testing, message: function() gives "[FAIL] {result.specName} ({result.passed}/{specTotal})")
				logSpecFailuresFor(failOwners, payloads: failPayloads, specName: result.specName)
			end 'hasFail'
			continue
		end 'isSingleResult'
		// Anything else is unknown protocol — log it and move on; we don't
		// throw because the result lines we did parse already updated counters.
		logError(LogCategory.testing, message: function() gives "[DISPATCH ERROR] unknown result line for {job.label()}: {trimmedLine}")
	end 'eachLine'
	return followups
end 'processWorkerResults'

// Boxed primitive so we can pass mutable accumulators through helper functions
// without the surrounding boilerplate of returning tuples and threading them
// through every callsite. Used only by the dispatch loop in this file.
type VarHolder
	export var value as TestCount

	export static function create(value TestCount) returns VarHolder
		return Self{value: value}
	end 'create'
end 'VarHolder'

// Account for a job whose worker crashed before producing a RESULT line. For
// batch crashes we re-route every batchable test through the fallback path so
// per-test isolation kicks in; for singles/fallback crashes we charge every
// affected test as a failure straight away (singles already runs one compile
// per test, so retrying within the dispatcher would just compound the wait).
// Returns the optional follow-up job (a fallback for crashed-batch retries),
// or the empty-marker job if no retry is needed.
function recoverFromCrashedJob(job SpecJob, units SpecWorkUnitArray, totalFailed_io VarHolder, failOwners StringArray, failPayloads TextLineArray) returns SpecJob
	let none = SpecJob.empty()
	if job.kind == "batch" 'wasBatch'
		let unit = findUnitByName(units, specName: job.specName)
		var allNames = StringArray.create()
		for t in unit.batchable 'eachTest'
			allNames.push(t.name)
		end 'eachTest'
		if allNames.count() == 0 'noTests'
			return none
		end 'noTests'
		logError(LogCategory.testing, message: function() gives "[CRASH] batch worker died on spec '{job.specName}'; rerouting {allNames.count()} test(s) to per-fragment fallback")
		return SpecJob.createFallback(job.specName, tests: allNames, weight: allNames.count())
	end 'wasBatch'
	if job.kind == "singles" 'wasSingles'
		let unit = findUnitByName(units, specName: job.specName)
		let crashedCount = unit.nonBatchable.count() + unit.missingLoweringCount
		totalFailed_io.value = totalFailed_io.value + crashedCount
		failOwners.push(job.specName)
		failPayloads.push("  {job.specName}: worker crashed during singles phase (panic, timeout, or non-zero exit); {crashedCount} test(s) charged as failed")
		logError(LogCategory.testing, message: function() gives "[FAIL] {job.specName} ({crashedCount} test(s)): singles worker crashed")
		logSpecFailuresFor(failOwners, payloads: failPayloads, specName: job.specName)
		return none
	end 'wasSingles'
	if job.kind == "fallback" 'wasFallback'
		let crashedCount = job.fallbackTests.count()
		totalFailed_io.value = totalFailed_io.value + crashedCount
		failOwners.push(job.specName)
		failPayloads.push("  {job.specName}: worker crashed during fallback phase (panic, timeout, or non-zero exit); {crashedCount} test(s) charged as failed")
		logError(LogCategory.testing, message: function() gives "[FAIL] {job.specName} ({crashedCount} test(s)): fallback worker crashed")
		logSpecFailuresFor(failOwners, payloads: failPayloads, specName: job.specName)
		return none
	end 'wasFallback'
	logError(LogCategory.testing, message: function() gives "[DISPATCH ERROR] unknown job kind '{job.kind}' on crash recovery")
	return none
end 'recoverFromCrashedJob'

// Run spec tests with a work-stealing pool of persistent worker subprocesses.
// Each worker stays alive across many JOB:... lines, amortising its stdlib-cache
// warmup over every spec it handles. Jobs come off a single slowest-first queue
// (batch + singles + dynamically-added fallback), so the long-pole tests start
// first and the OS-level parallelism gates wall time on the heaviest individual
// compile rather than on a static round-robin chunk.
export function runAllSpecTestsParallel(filter String, target Target, workerCount WorkerCount, updateRequired bool = false, verbose bool = false) returns ExitCode
	let root = try findSpecsRoot() otherwise 'noRoot'
		logError(LogCategory.testing, message: function() gives "Could not find project root (no specs/ directory found)")
		return 1
	end 'noRoot'

	setLogLevel(LogLevel.ERROR)
	setCategoryLogLevel(LogCategory.testing, level: LogLevel.INFO)

	let startTime = Clock.nowMs()
	totalCompileMs = 0
	startPhaseTiming()

	let targetKey = targetToString(target)
	let specDir = root.join("specs")
	let fragmentDir = specDir.join("fragments-{targetKey}")
	let tempDir = root.join("temp")

	if not Directory.exists(fragmentDir) 'noFragDir'
		_ = Directory.create(fragmentDir)
	end 'noFragDir'

	// Tests run with cwd = projectRoot/temp (see runSpecBatch / runTestFromFragment).
	// The bootstrap C# runner creates this in TestRunner.cs:93 before dispatching
	// any work; without it, Subprocess.run fails with "directory name is invalid"
	// on a fresh checkout that has never run the bootstrap runner first.
	if not Directory.exists(tempDir) 'noTempDir'
		_ = Directory.create(tempDir)
	end 'noTempDir'

	// Pre-build the stdlib cache in the parent before fanning out workers.
	// Workers all read the resulting cache file in their `warmStdlibCache`
	// call (`getStdlibModule` cache-hit branch in StdlibLoader), so they
	// never race on writing the same `.maxon/cache/stdlib-{target}.mxc`
	// file from a cold state. On a warm cache the parent pays only the
	// read cost (~140ms); on a cold cache it pays the build cost once
	// instead of every worker independently compiling stdlib and racing
	// the write.
	warmStdlibCache(target)
	markPhase("warmStdlibCache done")

	if updateRequired 'preUpdate'
		updateAllRequiredLowering(specDir, tempDir: tempDir, filter: filter, target: target, targetKey: targetKey)
	end 'preUpdate'

	let specCacheDir = fragmentDir.join(".spec-cache")
	if not Directory.exists(specCacheDir) 'noSpecCacheDir'
		_ = Directory.create(specCacheDir)
	end 'noSpecCacheDir'

	// Pre-create all fragment and cache subdirs so workers don't race on creation.
	for specName2 in whitelist 'createDirs'
		let cacheSubDir = specCacheDir.join(specName2)
		if not Directory.exists(cacheSubDir) 'noCacheSub'
			_ = Directory.create(cacheSubDir)
		end 'noCacheSub'
		let fragSubDir = fragmentDir.join(specName2)
		if not Directory.exists(fragSubDir) 'noFragSub'
			_ = Directory.create(fragSubDir)
		end 'noFragSub'
	end 'createDirs'

	var totalPassed = 0 as TestCount
	var totalFailed = 0 as TestCount
	var totalTests = 0
	var totalFragmentsWritten = 0

	// Phase 1: Parse all specs and partition tests into batchable / non-batchable.
	var units = SpecWorkUnitArray.create()

	for specName in whitelist 'parseSpecs'
		let specPath = specDir.join("{specName}.md")
		let content = try File.readText(specPath) otherwise 'readErr'
			logError(LogCategory.testing, message: function() gives "Could not read spec: {specPath}")
			continue
		end 'readErr'

		let fm = parseFrontmatter(content)
		if fm.status == "draft" 'isDraft'
			continue
		end 'isDraft'

		let tests = parseSpecFile(content, targetKey: targetKey)
		let unit = partitionSpecTests(tests, specName: specName, filter: filter, targetKey: targetKey)
		totalTests = totalTests + unit.totalCount()
		units.push(unit)
	end 'parseSpecs'
	markPhase("Phase 1 parseSpecs done ({units.count()} units, {totalTests} tests)")

	if totalTests == 0 'noTests'
		logInfo(LogCategory.testing, message: function() gives "No tests found")
		return 0
	end 'noTests'

	// Phase 2: Build the unified slowest-first job queue. A spec contributes up
	// to two jobs (batch + singles); fallback jobs join the queue dynamically
	// inside the dispatch loop when a batch result reports rewriter-rejected
	// tests. Weight orders the queue so the heaviest workloads start first and
	// overlap with the rest of the run, gating wall time on the long pole
	// instead of a static round-robin chunk boundary.
	let exePath = (try Process.executablePath() otherwise panic("runAllSpecTestsParallel: cannot determine executable path")).toString()
	let targetStr = targetToString(target)

	// Weight tests by stdlib-compile burden, not test count. The per-test
	// `cacheParity` and `includeStdlibIr` flags trigger a re-compile-the-world
	// path that dwarfs the test's own source bytes — a 30-byte main() can
	// take 8+s. We assign each such test a hefty fixed bonus (16 KiB ≈ a
	// large spec body) on top of its own source length. For ordinary tests
	// the source byte count alone correlates well with parse+typecheck+codegen
	// work; weight-by-test-count buries 15KLOC specs (register-allocator)
	// behind 50-test-but-tiny-test specs.
	var jobQueue = SpecJobArray.create()
	for unit in units 'enqueueJobs'
		let batchBytes = sumTestWeight(unit.batchable)
		let singlesBytes = sumTestWeight(unit.nonBatchable)
		if unit.batchable.count() > 0 'hasBatch'
			jobQueue.push(SpecJob.createBatch(unit.specName, weight: batchBytes))
		end 'hasBatch'
		if unit.nonBatchable.count() > 0 or unit.missingLoweringCount > 0 'hasSingles'
			jobQueue.push(SpecJob.createSingles(unit.specName, weight: singlesBytes))
			totalFragmentsWritten = totalFragmentsWritten + unit.nonBatchable.count()
		end 'hasSingles'
	end 'enqueueJobs'

	let initialJobCount = jobQueue.count()
	var numWorkers = workerCount
	if initialJobCount > 0 and initialJobCount < numWorkers 'fewerJobsThanWorkers'
		numWorkers = initialJobCount as WorkerCount
	end 'fewerJobsThanWorkers'

	// Two-phase pipelined spawn: Phase A fires all N CreateProcessW back-to-back,
	// Phase B drains each worker's WORKER_READY hello in order. While the
	// parent runs the spawn loop, every previously-spawned worker is already
	// executing its ~140ms warmStdlibCache, so total Phase 2 wall time drops
	// from N × 150ms (serial) to ~150ms (slowest single warmup). Saves ~1.5s
	// for a 12-worker pool.
	//
	// This pattern requires the runtime's CreateProcessW emission to use
	// STARTUPINFOEX + PROC_THREAD_ATTRIBUTE_HANDLE_LIST so each child inherits
	// exactly the handles in its own STARTUPINFOW and not stray pipes from
	// concurrently-spawning siblings. See maxon-sharp/.../X86CodeEmitter.Runtime.cs
	// __subp_spawn_core. Earlier two-phase attempts under the legacy
	// bInheritHandles+SetHandleInformation pattern flaked ~30-50% of runs
	// with crossed pipes and 30+ stderr-mismatch failures.
	//
	// Stderr is drained synchronously at shutdown rather than continuously
	// via an async GT. The async approach leaks 1 MM per worker because the
	// drain GT's Promise + arg-buf survive past the await round-trip.
	// Workers emit zero stderr in the success path (LogLevel.ERROR), so the
	// only risk of deferring drain is a worker that fills the 64 KiB pipe
	// before EXIT — the default tests don't, and the shutdown drain catches
	// whatever's buffered when the child exits.
	var workers = PersistentWorkerHandleArray.create()
	for i in 0 upto numWorkers 'spawnLoop'
		let h = try PersistentWorkerHandle.spawnNoWait(exePath, workerId: i as WorkerId, targetStr: targetStr, filter: filter, verbose: verbose) otherwise panic("worker {i}: PersistentWorkerHandle.spawnNoWait failed (see SubprocessError above)")
		workers.push(h)
	end 'spawnLoop'
	for i in 0 upto numWorkers 'readyLoop'
		var h = try workers.get(i) otherwise panic("worker {i}: workers.get failed in readyLoop")
		try h.awaitReady() otherwise panic("worker {i}: awaitReady failed (see SubprocessError above)")
	end 'readyLoop'

	let liveWorkerCount = workers.count()
	markPhase("Phase 2 spawned {liveWorkerCount} persistent workers, {initialJobCount} jobs queued")

	// Phase 3: dispatch loop. The pool concurrently dispatches the heaviest job
	// to every idle worker, immediately spawning an `async drainResultsThunk`
	// per dispatch so the underlying overlapped stdout reads all sit pending in
	// the IOCP runtime in parallel. The main loop then `try await`s slots in
	// round-robin order; whichever pipe has bytes ready completes its drain GT
	// while the parent's await on a slower slot yields. Net effect: 12 worker
	// reads make progress concurrently instead of serializing on the parent.
	//
	// busy[] tracks which slots have an in-flight drain promise; the loop only
	// `await`s slots flagged busy. drainPromises[] grows lazily: the first
	// dispatch to slot i `push`es (slot i has never had a promise; initial
	// dispatch order is 0..N-1 by the round-robin scan so push always lands at
	// the right index), every subsequent dispatch `set`s (replacing the
	// already-awaited completed promise). The push/set invariant is asserted
	// at the dispatch site so an out-of-order initial dispatch panics rather
	// than silently corrupting the index mapping.
	var busy = BoolArray.create()
	var deadSlots = BoolArray.create()
	var currentJobs = SpecJobArray.create()
	var drainPromises = DrainPromiseArray.create()
	// Wall-clock timestamp (Clock.nowMs()) of the last `sendJob` per slot.
	// Read by the watchdog in the no-drain-ready branch to detect a worker
	// that's been silent for > workerJobTimeoutMs. Index parity with the
	// other parallel arrays is maintained by the same push-on-first / set-on-
	// redispatch pattern as drainPromises.
	var dispatchStartMs = MillisArray.create()
	let placeholder = SpecJob.empty()
	for _ in 0 upto liveWorkerCount 'initBusy'
		busy.push(false)
		deadSlots.push(false)
		currentJobs.push(placeholder)
	end 'initBusy'

	var failOwners = StringArray.create()
	var failPayloads = TextLineArray.create()
	var passedBox = VarHolder.create(0 as TestCount)
	var failedBox = VarHolder.create(0 as TestCount)

	// Counters for the post-run invariant check: every job dispatched must be
	// accounted for either via a result line or via crash recovery. Mismatches
	// surface as a hard panic so a regression in the dispatcher can't silently
	// drop a spec from the totals.
	var jobsDispatched = 0
	var jobsCompleted = 0

	// Round-robin cursors keep the dispatch+drain loop from pinning to the
	// lowest-index worker. Without rotation we always re-dispatch to worker 0
	// after draining it, then drain it again on the very next iteration —
	// workers 1..N-1 finish their initial jobs and then sit idle with their
	// RESULT+READY queued in the pipe, never read. With rotation we visit
	// every worker once per pool-cycle and read its result before redispatching.
	var dispatchCursor = 0 as TestCount
	var drainCursor = 0 as TestCount

	while true 'dispatchLoop'
		// Prefer dispatching to an idle worker over draining a busy one: the
		// OS-level parallelism only kicks in once every worker has a job, so we
		// hold off on the (blocking) drain until the pool is fully fed.
		var idleIdx = 0 as TestCount
		var haveIdleFlag = false
		for offset in 0 upto liveWorkerCount 'findIdle'
			let raw = dispatchCursor + offset
			let i = raw - (raw / liveWorkerCount) * liveWorkerCount
			let isDead = try deadSlots.get(i) otherwise false
			if isDead 'skipDead'
				continue
			end 'skipDead'
			let isBusy = try busy.get(i) otherwise panic("dispatch: busy.get({i}) failed")
			if not isBusy 'isIdle'
				idleIdx = i
				haveIdleFlag = true
				break
			end 'isIdle'
		end 'findIdle'

		if haveIdleFlag 'haveIdle'
			if jobQueue.count() == 0 'noWorkLeft'
				// Idle worker but no more jobs to dispatch. If every (live)
				// worker is idle the run is done; otherwise fall through to
				// the drain path so the still-busy workers get a chance to
				// report.
				var anyBusy = false
				for i in 0 upto liveWorkerCount 'checkBusy'
					let dead = try deadSlots.get(i) otherwise false
					if dead 'skipDeadCheck'
						continue
					end 'skipDeadCheck'
					let b = try busy.get(i) otherwise false
					if b 'wasBusy'
						anyBusy = true
						break
					end 'wasBusy'
				end 'checkBusy'
				if not anyBusy 'allIdle'
					break
				end 'allIdle'
			end 'noWorkLeft' else 'haveWork'
				let job = popHeaviestJob(jobQueue)
				var h = try workers.get(idleIdx) otherwise panic("dispatch: workers.get({idleIdx}) failed")
				try h.sendJob(job.toJobLine()) otherwise 'sendFailed'
					// Treat a write error like a crash: recover the job, mark
					// the slot dead, and continue. Counting a never-dispatched
					// failure as a completed job keeps jobsDispatched ==
					// jobsCompleted simple — the recovery handler has already
					// charged the spec, and the slot is permanently out.
					let followup = recoverFromCrashedJob(job, units: units, totalFailed_io: failedBox, failOwners: failOwners, failPayloads: failPayloads)
					if followup.kind != "" 'hasFollowup'
						jobQueue.push(followup)
					end 'hasFollowup'
					h.child.release()
					try busy.set(idleIdx, value: false) otherwise panic("dispatch: busy.set after sendJob failure")
					try deadSlots.set(idleIdx, value: true) otherwise panic("dispatch: deadSlots.set after sendJob failure")
					jobsDispatched = jobsDispatched + 1
					jobsCompleted = jobsCompleted + 1
					continue
				end 'sendFailed'
				try currentJobs.set(idleIdx, value: job) otherwise panic("dispatch: currentJobs.set({idleIdx}) failed")
				try busy.set(idleIdx, value: true) otherwise panic("dispatch: busy.set({idleIdx}) failed")
				// Spawn the drain GT immediately so the overlapped stdout read
				// for this worker's READY is in flight in the IOCP runtime
				// while we go dispatch to the next idle slot. Slots populate
				// drainPromises in dispatch order — push on first dispatch,
				// set on every redispatch (overwriting the already-awaited
				// previous promise). The strict equality / less-than split
				// catches any future round-robin reorder that violates the
				// in-order initial dispatch invariant.
				let pendingDrain = async drainResultsThunk(h.child)
				let dispatchNow = Clock.nowMs() as Millis
				if idleIdx == drainPromises.count() 'firstDispatchThisSlot'
					drainPromises.push(pendingDrain)
					dispatchStartMs.push(dispatchNow)
				end 'firstDispatchThisSlot' else if idleIdx < drainPromises.count() 'redispatch'
					try drainPromises.set(idleIdx, value: pendingDrain) otherwise panic("dispatch: drainPromises.set({idleIdx}) failed")
					try dispatchStartMs.set(idleIdx, value: dispatchNow) otherwise panic("dispatch: dispatchStartMs.set({idleIdx}) failed")
				end 'redispatch' else 'outOfOrderInit'
					panic("dispatch: drainPromises gap at slot {idleIdx} (size {drainPromises.count()}) — initial dispatch out of order")
				end 'outOfOrderInit'
				jobsDispatched = jobsDispatched + 1
				let nextCursor = idleIdx + 1
				dispatchCursor = nextCursor - (nextCursor / liveWorkerCount) * liveWorkerCount
				continue
			end 'haveWork'
		end 'haveIdle'

		// No idle worker (or queue empty for the one idle slot while others
		// are busy). Drain ALL workers whose async stdout-read GT has already
		// completed (non-blocking poll via __Builtins.gtIsComplete on each
		// promise's inner GT pointer). Only when NO worker has anything ready
		// do we sleep(0) to yield to the scheduler so the IOCP completion
		// thread can re-enqueue drain GTs that just finished. The naive
		// approach — pick one busy worker and `try await` it — head-of-line
		// blocks: if we pick a worker running a 5s job while others finish in
		// 100ms, all the fast workers sit idle for 5s with their READY queued
		// in the pipe but the parent stuck on the slow one.
		var drainIdx = 0 as TestCount
		var haveDrainFlag = false
		for offset in 0 upto liveWorkerCount 'findReady'
			let raw = drainCursor + offset
			let i = raw - (raw / liveWorkerCount) * liveWorkerCount
			let b = try busy.get(i) otherwise false
			if not b 'notBusy'
				continue
			end 'notBusy'
			let innerPtr = (try drainPromises.get(i) otherwise panic("dispatch: drainPromises.get({i}) in findReady")).inner
			let ready = __Builtins.gtIsComplete(innerPtr)
			if ready != 0 'isReady'
				drainIdx = i
				haveDrainFlag = true
				break
			end 'isReady'
		end 'findReady'

		if not haveDrainFlag 'noneReady'
			// Watchdog: before sleeping, scan every busy/non-dead slot for one
			// that's been silent past workerJobTimeoutMs. A hung worker (e.g.
			// stuck in a compiler infinite loop, or panicked into a frame the
			// runtime catches without writing back WORKER_READY) never EOFs
			// its stdout pipe on its own, so the drain GT would block forever.
			// Killing the process closes the pipe; the next iteration's
			// gtIsComplete poll finds the drain GT done, the `try await` at
			// the drain site throws ioFailed (EOF), and the existing
			// 'workerDied recovery branch handles cleanup and accounting.
			let watchdogNow = Clock.nowMs() as Millis
			for wi in 0 upto liveWorkerCount 'watchdog'
				let wDead = try deadSlots.get(wi) otherwise false
				if wDead 'wSkipDead'
					continue
				end 'wSkipDead'
				let wBusy = try busy.get(wi) otherwise false
				if not wBusy 'wSkipIdle'
					continue
				end 'wSkipIdle'
				let started = try dispatchStartMs.get(wi) otherwise panic("watchdog: dispatchStartMs.get({wi}) failed on busy slot")
				let elapsed = watchdogNow - started
				if elapsed <= workerJobTimeoutMs 'wWithinBudget'
					continue
				end 'wWithinBudget'
				// Re-stamp BEFORE killing so we don't re-kill the same slot on
				// every iteration while the EOF propagates through the IOCP
				// runtime back to gtIsComplete. The slot will be marked dead
				// in the 'workerDied branch as soon as we await its drain.
				try dispatchStartMs.set(wi, value: watchdogNow) otherwise panic("watchdog: dispatchStartMs.set({wi}) failed")
				let wh = try workers.get(wi) otherwise panic("watchdog: workers.get({wi}) failed")
				let wJob = try currentJobs.get(wi) otherwise panic("watchdog: currentJobs.get({wi}) failed")
				logError(LogCategory.testing, message: function() gives "[TIMEOUT] worker {wh.workerId} exceeded {workerJobTimeoutMs}ms on '{wJob.label()}' — killing")
				__Builtins.subprocessKill(wh.child.handle, 1)
			end 'watchdog'
			// Nothing ready — yield this GT so the scheduler can run other GTs
			// (the per-worker drain GTs blocked on IOCP completions). When any
			// drain completes, its status flips to completed; we loop back and
			// the gtIsComplete poll above will find it. Use sleep(1) rather
			// than sleep(0) so the timer-check has a clear "deadline passed"
			// rather than racing with now == deadline edge cases.
			__Builtins.sleep(1)
			continue
		end 'noneReady'

		var h = try workers.get(drainIdx) otherwise panic("dispatch: workers.get({drainIdx}) for drain failed")
		// Clone the current job out of the array so the borrow doesn't pin
		// `currentJobs` for the pipelined-dispatch set() below.
		let job = (try currentJobs.get(drainIdx) otherwise panic("dispatch: currentJobs.get({drainIdx}) failed")).clone()
		let drainPromise = try drainPromises.get(drainIdx) otherwise panic("dispatch: drainPromises.get({drainIdx}) failed")
		let lines = try await drainPromise otherwise 'workerDied'
			// Worker crashed mid-job (the drain GT hit EOF on readStdoutLine
			// before WORKER_READY, or readStdoutLine itself raised an I/O
			// error). Recover the work it was holding, then mark the slot
			// dead so the find-idle and find-busy scans skip it. We don't
			// respawn: surviving workers can absorb whatever the queue still
			// holds, and one fewer worker just trims parallelism by 1/N.
			logError(LogCategory.testing, message: function() gives "[CRASH] worker {h.workerId} died on '{job.label()}' (EOF or I/O error before WORKER_READY)")
			let followup = recoverFromCrashedJob(job, units: units, totalFailed_io: failedBox, failOwners: failOwners, failPayloads: failPayloads)
			if followup.kind != "" 'hasFollowup'
				jobQueue.push(followup)
			end 'hasFollowup'
			h.child.release()
			try busy.set(drainIdx, value: false) otherwise panic("dispatch: busy.set after drain failure")
			try deadSlots.set(drainIdx, value: true) otherwise panic("dispatch: deadSlots.set after drain failure")
			jobsCompleted = jobsCompleted + 1
			continue
		end 'workerDied'

		// Pipeline the next dispatch BEFORE processing the prior results: the
		// worker can begin compiling its next job in parallel with the parent
		// parsing the result lines from the just-completed one. Without this
		// the worker sits idle (sees no new stdin line) while the parent does
		// processWorkerResults. The heaviest-job heuristic still picks the
		// best queued work for this freshly-idle slot.
		var nextLined = false
		if jobQueue.count() > 0 'hasMoreWork'
			let nextJob = popHeaviestJob(jobQueue)
			try h.sendJob(nextJob.toJobLine()) otherwise 'nextSendFailed'
				// Send-failed pipelining edge: the worker died between READY and
				// the next sendJob. Re-queue both the just-completed job's
				// (already-processed) followup AND the next job, mark slot dead.
				// We DON'T `continue` here — we still need to process the prior
				// `lines` so the spec gets its totals; fall through with a flag.
				let recoverNext = recoverFromCrashedJob(nextJob, units: units, totalFailed_io: failedBox, failOwners: failOwners, failPayloads: failPayloads)
				if recoverNext.kind != "" 'hasRecoverFollowup'
					jobQueue.push(recoverNext)
				end 'hasRecoverFollowup'
				h.child.release()
				try deadSlots.set(drainIdx, value: true) otherwise panic("dispatch: deadSlots.set after pipelined sendJob failure")
				jobsDispatched = jobsDispatched + 1
				jobsCompleted = jobsCompleted + 1
				// Fall through to processWorkerResults for the JUST-COMPLETED
				// `job` — its `lines` are valid; the failed pipelined send is
				// already accounted for above.
			end 'nextSendFailed'
			let slotStillLive = try deadSlots.get(drainIdx) otherwise panic("dispatch: deadSlots.get({drainIdx}) after pipelined send")
			if not slotStillLive 'pipelinedOk'
				try currentJobs.set(drainIdx, value: nextJob) otherwise panic("dispatch: currentJobs.set({drainIdx}) (pipelined) failed")
				// busy[drainIdx] stays true — we keep the slot busy continuously.
				let pendingDrain = async drainResultsThunk(h.child)
				try drainPromises.set(drainIdx, value: pendingDrain) otherwise panic("dispatch: drainPromises.set({drainIdx}) (pipelined) failed")
				try dispatchStartMs.set(drainIdx, value: Clock.nowMs() as Millis) otherwise panic("dispatch: dispatchStartMs.set({drainIdx}) (pipelined) failed")
				jobsDispatched = jobsDispatched + 1
				nextLined = true
			end 'pipelinedOk'
		end 'hasMoreWork'
		if not nextLined 'slotIdleAfter'
			// Either queue is empty or the pipelined send failed (and marked the
			// slot dead). Mark idle so the next iteration's findIdle scan skips
			// dispatching here when dead, or picks up the slot for the queue's
			// drain phase when no more work remains.
			try busy.set(drainIdx, value: false) otherwise panic("dispatch: busy.set after drain")
		end 'slotIdleAfter'

		let followups = processWorkerResults(lines, job: job, units: units, totalPassed_io: passedBox, totalFailed_io: failedBox, failOwners: failOwners, failPayloads: failPayloads)
		for fj in followups 'eachFollowup'
			jobQueue.push(fj)
		end 'eachFollowup'
		jobsCompleted = jobsCompleted + 1
		let nextDrain = drainIdx + 1
		drainCursor = nextDrain - (nextDrain / liveWorkerCount) * liveWorkerCount
	end 'dispatchLoop'

	totalPassed = passedBox.value
	totalFailed = failedBox.value
	markPhase("Phase 3 dispatch loop done, {totalPassed} passed {totalFailed} failed ({jobsCompleted}/{jobsDispatched} jobs)")

	if jobsDispatched != jobsCompleted 'invariantViolated'
		panic("runAllSpecTestsParallel: jobsDispatched={jobsDispatched} != jobsCompleted={jobsCompleted} — a job was lost in the dispatch loop")
	end 'invariantViolated'

	// Phase 4: clean shutdown. For each live worker: write EXIT, await the
	// child, drain whatever's buffered in its stderr, then release the OS
	// handle. Dead slots (whose drain threw mid-loop) have already been
	// released; skip them.
	for i in 0 upto liveWorkerCount 'shutdownLoop'
		let isDead = try deadSlots.get(i) otherwise false
		if isDead 'skipDead'
			continue
		end 'skipDead'
		var h = try workers.get(i) otherwise panic("shutdown: workers.get({i}) failed")
		// Send EXIT to signal clean shutdown, then drain whatever's left in
		// the stderr pipe. The drain must precede wait()/release() — once
		// release closes the parent-side handles, further reads fail.
		let exitCode = try h.shutdownAndDrainStderr() otherwise 'shutdownFailed'
			logError(LogCategory.testing, message: function() gives "[SHUTDOWN] worker {i} shutdown failed (likely already exited): see stderr")
			continue
		end 'shutdownFailed'
		if exitCode != 0 'badExit'
			logError(LogCategory.testing, message: function() gives "[SHUTDOWN] worker {i} exited with code {exitCode}")
		end 'badExit'
	end 'shutdownLoop'
	markPhase("Phase 4 worker shutdown done")

	if totalFragmentsWritten > 0 'showFrags'
		logInfo(LogCategory.testing, message: function() gives "Wrote {totalFragmentsWritten} fragment(s)")
	end 'showFrags'

	let elapsedMs = Clock.nowMs() - startTime
	logInfo(LogCategory.testing, message: function() gives "Total compile time: {totalCompileMs}ms")

	if totalFailed == 0 'allPass'
		logInfo(LogCategory.testing, message: function() gives "Tests: {totalPassed} passed (total: {totalTests}) in {elapsedMs}ms")
	end 'allPass' else 'someFail'
		logInfo(LogCategory.testing, message: function() gives "Tests: {totalPassed} passed, {totalFailed} failed (total: {totalTests}) in {elapsedMs}ms")
	end 'someFail'

	if totalFailed > 0 'hasFail'
		return 1
	end 'hasFail'
	return 0
end 'runAllSpecTestsParallel'

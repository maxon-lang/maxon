// Incremental compilation test runner.
// Verifies that the query cache correctly hits/misses
// across multiple compilations.

export function runIncrementalTests() returns ExitCode
	logInfo(LogCategory.testing, message: function() gives "Running incremental compilation tests...")

	let projectRoot = try findSpecsRoot() otherwise 'noRoot'
		print("Could not find project root\n")
		return 1
	end 'noRoot'

	let tempDir = projectRoot.join("temp")
	let sourcePath = tempDir.join("incr_test.maxon")
	let exePath = tempDir.join("incr_test.exe")

	// Clean up any stale files from previous runs
	cleanupIncrTest(sourcePath, exePath: exePath)

	var totalPassed = 0
	var totalFailed = 0

	// --- Scenario E (run first): Phase 11.5 per-function query layer ---
	// Spins up its own short-lived project so the assertions are clean and
	// independent of the longer-running A→D scenarios below. Compiles
	// once so queryCodeResult populates the whole-module cache, then
	// drives queryMidForFunction directly.
	logInfo(LogCategory.testing, message: function() gives "Scenario E: Per-function queries...")
	let sourceE = "function main() returns ExitCode\n\treturn 9\nend 'main'\n"
	try File.writeText(sourcePath, content: sourceE) otherwise 'writeErrE'
		print("Scenario E: failed to write source\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'writeErrE'
	var projectE = createProject(sourcePath, target: detectHostTarget())
	// Scenario E exercises the per-function query layer in isolation: the
	// initial compile must NOT pre-populate `midPerFunc`, so the first
	// explicit `queryMidForFunction` call below is a real miss. Stage P
	// Step 6 flipped `enableIncremental` on by default, which would route
	// `compileProject` through the chunk-driven path and warm `midPerFunc`
	// before this test even runs. Override to false here so the assertion
	// pattern (first call miss, second call hit) still matches.
	projectE.db.enableIncremental = false
	try compileProject(projectE) otherwise 'compErrE'
		print("Scenario E: initial compile failed\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'compErrE'
	resetCounters(projectE)
	let scenarioEPassed = runPerFunctionQueryScenario(projectE)
	if scenarioEPassed 'passE'
		print("[PASS] Scenario E: Per-function queries\n")
		totalPassed = totalPassed + 1
	end 'passE' else 'failE'
		print("[FAIL] Scenario E: Per-function queries\n")
		totalFailed = totalFailed + 1
	end 'failE'
	cleanupIncrTest(sourcePath, exePath: exePath)

	// --- Scenario A: Fresh compilation (all misses) ---
	logInfo(LogCategory.testing, message: function() gives "Scenario A: Fresh compilation...")

	let sourceV1 = "function main() returns ExitCode\n    return 5\nend 'main'\n"

	try File.writeText(sourcePath, content: sourceV1) otherwise 'writeErr1'
		print("Could not write test source\n")
		return 1
	end 'writeErr1'

	var project = createProject(sourcePath, target: detectHostTarget())
	// Scenarios A/B/C/D assert classical whole-module query counters
	// (allMid, code, etc.) and predate the chunk-driven per-function path.
	// Stage P Step 6 flipped `enableIncremental` on by default, which would
	// route the backend emit through `emitBackendIncremental` and inflate
	// `allMidHits` (each per-function `queryMidForFunction` re-queries
	// `queryAllMid`). Pin the historical path here so the original counter
	// pattern (and Scenarios B/D, which reuse this project) still hold.
	project.db.enableIncremental = false
	try compileProject(project) otherwise 'compErrA'
		print("Scenario A: Compilation failed\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'compErrA'

	var scenarioAPassed = true
	scenarioAPassed = assertCounter("A tokenHits", actual: project.db.tokenHits, expected: 0) and scenarioAPassed
	scenarioAPassed = assertCounter("A tokenMisses", actual: project.db.tokenMisses, expected: 1) and scenarioAPassed
	scenarioAPassed = assertCounter("A parseHits", actual: project.db.parseHits, expected: 0) and scenarioAPassed
	scenarioAPassed = assertCounter("A parseMisses", actual: project.db.parseMisses, expected: 1) and scenarioAPassed
	scenarioAPassed = assertCounter("A allModuleHits", actual: project.db.allModuleHits, expected: 0) and scenarioAPassed
	scenarioAPassed = assertCounter("A allModuleMisses", actual: project.db.allModuleMisses, expected: 1) and scenarioAPassed
	scenarioAPassed = assertCounter("A allMidHits", actual: project.db.allMidHits, expected: 0) and scenarioAPassed
	scenarioAPassed = assertCounter("A allMidMisses", actual: project.db.allMidMisses, expected: 1) and scenarioAPassed
	scenarioAPassed = assertCounter("A codeHits", actual: project.db.codeHits, expected: 0) and scenarioAPassed
	scenarioAPassed = assertCounter("A codeMisses", actual: project.db.codeMisses, expected: 1) and scenarioAPassed
	// Exit code check skipped: self-hosted codegen produces wrong values for multi-digit literals

	if scenarioAPassed 'passA'
		print("[PASS] Scenario A: Fresh compilation\n")
		totalPassed = totalPassed + 1
	end 'passA' else 'failA'
		print("[FAIL] Scenario A: Fresh compilation\n")
		totalFailed = totalFailed + 1
	end 'failA'

	// --- Scenario B: No-change recompile ---
	// When the top-level code cache is valid, it short-circuits and never
	// calls downstream queries, so only codeHits increments.
	logInfo(LogCategory.testing, message: function() gives "Scenario B: No-change recompile...")

	resetCounters(project)
	try compileProject(project) otherwise 'compErrB'
		print("Scenario B: Compilation failed\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'compErrB'

	var scenarioBPassed = true
	scenarioBPassed = assertCounter("B tokenHits", actual: project.db.tokenHits, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B tokenMisses", actual: project.db.tokenMisses, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B parseHits", actual: project.db.parseHits, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B parseMisses", actual: project.db.parseMisses, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B allModuleHits", actual: project.db.allModuleHits, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B allModuleMisses", actual: project.db.allModuleMisses, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B allMidHits", actual: project.db.allMidHits, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B allMidMisses", actual: project.db.allMidMisses, expected: 0) and scenarioBPassed
	scenarioBPassed = assertCounter("B codeHits", actual: project.db.codeHits, expected: 1) and scenarioBPassed
	scenarioBPassed = assertCounter("B codeMisses", actual: project.db.codeMisses, expected: 0) and scenarioBPassed

	if scenarioBPassed 'passB'
		print("[PASS] Scenario B: No-change recompile\n")
		totalPassed = totalPassed + 1
	end 'passB' else 'failB'
		print("[FAIL] Scenario B: No-change recompile\n")
		totalFailed = totalFailed + 1
	end 'failB'

	// --- Scenario F: chunk-driven incremental rebuild timing ---
	// Runs before Scenario C because C exercises an in-process re-compile of
	// the same project after a file edit, which trips a long-standing
	// parser-side-effect bug (project.funcReturnTypes.insert collides with
	// the prior parse's registration → E2001 "Duplicate function 'main'").
	// That bug short-circuits the rest of `runIncrementalTests` with `return
	// 1`; running F first ensures the timing numbers are always reported.
	//
	// Scenario F itself sidesteps the parser-side-effect bug by using a
	// *fresh `Project` per measurement* — see the comment on
	// `runPerFunctionRebuildScenario` for the architectural rationale.
	logInfo(LogCategory.testing, message: function() gives "Scenario F: Chunk-driven rebuild timing...")
	cleanupIncrTest(sourcePath, exePath: exePath)
	let scenarioFPassed = runPerFunctionRebuildScenario(sourcePath, exePath: exePath)
	if scenarioFPassed 'passF'
		print("[PASS] Scenario F: Chunk-driven rebuild timing\n")
		totalPassed = totalPassed + 1
	end 'passF' else 'failF'
		print("[FAIL] Scenario F: Chunk-driven rebuild timing\n")
		totalFailed = totalFailed + 1
	end 'failF'
	cleanupIncrTest(sourcePath, exePath: exePath)

	// --- Scenario H: chunk-driven cold-build recursion-break (Stage P Step 3) ---
	// Verifies that a fresh `Project` with `enableIncremental = true` and
	// `tier = full` can complete a cold compile WITHOUT looping forever
	// through `queryCodeResult → emitBackendIncremental → queryCodeForFunction
	// → queryCodeResult`. Before Step 3, the chunk-driven miss path recursed
	// back into `queryCodeResult`, which re-dispatched into
	// `emitBackendIncremental`, which called `queryCodeForFunction` on every
	// function — every function was a miss on a cold build, so the loop never
	// terminated. Step 3 routes the miss directly through
	// `backend.emitFunctionChunk`, breaking the recursion.
	//
	// Also asserts that a second compile against the same `Project` hits the
	// chunk cache (`codePerFuncHits > 0`) — proves the direct-emit miss tail
	// stamps `db.codePerFunc` correctly. The 50-function synthetic source is
	// large enough that any cache-stamp regression shows up immediately.
	logInfo(LogCategory.testing, message: function() gives "Scenario H: chunk-driven cold-build recursion break...")
	cleanupIncrTest(sourcePath, exePath: exePath)
	let scenarioHPassed = runChunkDrivenColdBuildScenario(sourcePath, exePath: exePath)
	if scenarioHPassed 'passH'
		print("[PASS] Scenario H: chunk-driven cold-build recursion break\n")
		totalPassed = totalPassed + 1
	end 'passH' else 'failH'
		print("[FAIL] Scenario H: chunk-driven cold-build recursion break\n")
		totalFailed = totalFailed + 1
	end 'failH'
	cleanupIncrTest(sourcePath, exePath: exePath)

	// --- Scenario I: inline-aware cache invalidation ---
	// Verifies that editing a callee body that the inliner spliced into a
	// caller invalidates the caller's cached chunk. Exercises the inline-edge
	// recording (`project.inlineEdges`) and the persistence-layer hooks
	// (`captureInlineDeps` / `callerInlineDepsUnchanged`). Uses a fresh Project
	// per leg to sidestep the same-Project reparse quirk; byte-identity against
	// a clean full build is the load-bearing correctness gate.
	logInfo(LogCategory.testing, message: function() gives "Scenario I: inline-aware invalidation...")
	cleanupIncrTest(sourcePath, exePath: exePath)
	let scenarioIPassed = runInlineInvalidationScenario(sourcePath, exePath: exePath)
	if scenarioIPassed 'passI'
		print("[PASS] Scenario I: inline-aware invalidation\n")
		totalPassed = totalPassed + 1
	end 'passI' else 'failI'
		print("[FAIL] Scenario I: inline-aware invalidation\n")
		totalFailed = totalFailed + 1
	end 'failI'
	cleanupIncrTest(sourcePath, exePath: exePath)

	// --- Scenario G: ReParseParity (parser snapshot/restore correctness) ---
	// Compile source v1 in a fresh Project (bytes A). In a second fresh
	// Project, compile v1, fileChange to v2, fileChange back to v1, compile
	// (bytes B). The parser's per-file delta rolls back the prior parse's
	// registrations on each re-parse, so the post-rollback state should be
	// identical to a fresh compile. Asserting A == B verifies the snapshot
	// machinery is correct end-to-end — anything left over from a prior
	// parse will surface here as a byte-level divergence in the .text
	// section (typically an extra or missing function in the registry).
	logInfo(LogCategory.testing, message: function() gives "Scenario G: ReParseParity (parser snapshot/restore)...")
	cleanupIncrTest(sourcePath, exePath: exePath)
	let scenarioGPassed = runReParseParityScenario(sourcePath, exePath: exePath)
	if scenarioGPassed 'passG'
		print("[PASS] Scenario G: ReParseParity\n")
		totalPassed = totalPassed + 1
	end 'passG' else 'failG'
		print("[FAIL] Scenario G: ReParseParity\n")
		totalFailed = totalFailed + 1
	end 'failG'
	cleanupIncrTest(sourcePath, exePath: exePath)
	// Re-establish Scenario A's source for the subsequent A-already-ran path.
	// (Scenarios C/D continue to operate on the `project` instance created
	// during Scenario A above; the file content `sourceV1` was already loaded
	// into that project's QueryDatabase, so the cleanup-then-rewrite of the
	// on-disk file is benign — the project's cached source view is what
	// matters.)
	try File.writeText(sourcePath, content: sourceV1) otherwise ignore

	// --- Scenario C: Modify file (all misses, full recomputation) ---
	logInfo(LogCategory.testing, message: function() gives "Scenario C: Modify file...")

	resetCounters(project)

	let sourceV2 = "function main() returns ExitCode\n    return 7\nend 'main'\n"
	try File.writeText(sourcePath, content: sourceV2) otherwise 'writeErr2'
		print("Could not overwrite test source\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'writeErr2'

	try compileProject(project) otherwise 'compErrC'
		print("Scenario C: Compilation failed\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'compErrC'

	var scenarioCPassed = true
	scenarioCPassed = assertCounter("C tokenHits", actual: project.db.tokenHits, expected: 0) and scenarioCPassed
	scenarioCPassed = assertCounter("C tokenMisses", actual: project.db.tokenMisses, expected: 1) and scenarioCPassed
	scenarioCPassed = assertCounter("C parseHits", actual: project.db.parseHits, expected: 0) and scenarioCPassed
	scenarioCPassed = assertCounter("C parseMisses", actual: project.db.parseMisses, expected: 1) and scenarioCPassed
	scenarioCPassed = assertCounter("C allModuleHits", actual: project.db.allModuleHits, expected: 0) and scenarioCPassed
	scenarioCPassed = assertCounter("C allModuleMisses", actual: project.db.allModuleMisses, expected: 1) and scenarioCPassed
	scenarioCPassed = assertCounter("C allMidHits", actual: project.db.allMidHits, expected: 0) and scenarioCPassed
	scenarioCPassed = assertCounter("C allMidMisses", actual: project.db.allMidMisses, expected: 1) and scenarioCPassed
	scenarioCPassed = assertCounter("C codeHits", actual: project.db.codeHits, expected: 0) and scenarioCPassed
	scenarioCPassed = assertCounter("C codeMisses", actual: project.db.codeMisses, expected: 1) and scenarioCPassed
	// Exit code check skipped: self-hosted codegen produces wrong values for multi-digit literals

	if scenarioCPassed 'passC'
		print("[PASS] Scenario C: Modify file\n")
		totalPassed = totalPassed + 1
	end 'passC' else 'failC'
		print("[FAIL] Scenario C: Modify file\n")
		totalFailed = totalFailed + 1
	end 'failC'

	// --- Scenario D: Same-content rewrite (code cache hit, no downstream queries) ---
	logInfo(LogCategory.testing, message: function() gives "Scenario D: Same-content rewrite...")

	resetCounters(project)
	try compileProject(project) otherwise 'compErrD'
		print("Scenario D: Compilation failed\n")
		cleanupIncrTest(sourcePath, exePath: exePath)
		return 1
	end 'compErrD'

	var scenarioDPassed = true
	scenarioDPassed = assertCounter("D tokenHits", actual: project.db.tokenHits, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D tokenMisses", actual: project.db.tokenMisses, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D parseHits", actual: project.db.parseHits, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D parseMisses", actual: project.db.parseMisses, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D allModuleHits", actual: project.db.allModuleHits, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D allModuleMisses", actual: project.db.allModuleMisses, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D allMidHits", actual: project.db.allMidHits, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D allMidMisses", actual: project.db.allMidMisses, expected: 0) and scenarioDPassed
	scenarioDPassed = assertCounter("D codeHits", actual: project.db.codeHits, expected: 1) and scenarioDPassed
	scenarioDPassed = assertCounter("D codeMisses", actual: project.db.codeMisses, expected: 0) and scenarioDPassed

	if scenarioDPassed 'passD'
		print("[PASS] Scenario D: Same-content rewrite\n")
		totalPassed = totalPassed + 1
	end 'passD' else 'failD'
		print("[FAIL] Scenario D: Same-content rewrite\n")
		totalFailed = totalFailed + 1
	end 'failD'

	// Summary
	print("\nIncremental tests: {totalPassed} passed, {totalFailed} failed\n")

	if totalFailed > 0 'hasFail'
		return 1
	end 'hasFail'
	return 0
end 'runIncrementalTests'

// Phase 11.5: exercise the per-function query layer once-then-again and
// assert the cache counters match expectations. Returns true on success.
// The first lookup is a miss (memo created); the second is a hit.
function runPerFunctionQueryScenario(project Project) returns bool
	var passed = true
	try queryMidForFunction(project, funcName: "main") otherwise 'midErrE1'
		print("Scenario E: queryMidForFunction failed (first call)\n")
		return false
	end 'midErrE1'
	passed = assertCounter("E1 midPerFuncMisses", actual: project.db.midPerFuncMisses, expected: 1) and passed
	passed = assertCounter("E1 midPerFuncHits", actual: project.db.midPerFuncHits, expected: 0) and passed
	try queryMidForFunction(project, funcName: "main") otherwise 'midErrE2'
		print("Scenario E: queryMidForFunction failed (second call)\n")
		return false
	end 'midErrE2'
	passed = assertCounter("E2 midPerFuncMisses", actual: project.db.midPerFuncMisses, expected: 1) and passed
	passed = assertCounter("E2 midPerFuncHits", actual: project.db.midPerFuncHits, expected: 1) and passed
	return passed
end 'runPerFunctionQueryScenario'

// Scenario G: ReParseParity. Verifies the parser snapshot/restore correctly
// rolls back per-file parser writes between re-parses, by comparing two
// binaries:
//   1. Fresh Project P1 compiles v1 → bytes A.
//   2. Fresh Project P2 compiles v1, then fileChanges to v2, then fileChanges
//      back to v1, then compiles → bytes B.
// Snapshot rollback should fully scrub each file's prior parse-and-drain
// writes, so P2's final state should be identical to P1's. A == B is the
// byte-identity gate; a divergence means a registry insert leaked between
// re-parses.
function runReParseParityScenario(sourcePath FilePath, exePath FilePath) returns bool
	let sourceV1 = "function helper() returns ExitCode\n\treturn 7 as ExitCode\nend 'helper'\nfunction main() returns ExitCode\n\treturn helper()\nend 'main'\n"
	let sourceV2 = "function helper() returns ExitCode\n\treturn 9 as ExitCode\nend 'helper'\nfunction main() returns ExitCode\n\treturn helper()\nend 'main'\n"

	// Leg A: fresh Project, compile v1 once.
	try File.writeText(sourcePath, content: sourceV1) otherwise 'writeAErr'
		print("  Scenario G: failed to write source for leg A\n")
		return false
	end 'writeAErr'
	try File.delete(exePath) otherwise ignore
	var projectA = createProject(sourcePath, target: detectHostTarget())
	let outputA = try compileProject(projectA) otherwise 'compErrA'
		print("  Scenario G: leg A compile failed\n")
		return false
	end 'compErrA'
	let bytesA = try File.readBinary(outputA) otherwise 'readAErr'
		print("  Scenario G: failed to read leg A binary at {outputA}\n")
		return false
	end 'readAErr'

	// Leg B: fresh Project, compile v1, edit to v2, edit back to v1, compile.
	// Each edit triggers a queryParseOps re-parse, which invokes
	// `beginFileParse(project, filePath)` to roll back the prior parse's
	// registry inserts before the new parse runs.
	try File.writeText(sourcePath, content: sourceV1) otherwise 'writeB1Err'
		print("  Scenario G: failed to write source v1 for leg B\n")
		return false
	end 'writeB1Err'
	try File.delete(exePath) otherwise ignore
	var projectB = createProject(sourcePath, target: detectHostTarget())
	try compileProject(projectB) otherwise 'compB1Err'
		print("  Scenario G: leg B first compile failed\n")
		return false
	end 'compB1Err'
	try File.writeText(sourcePath, content: sourceV2) otherwise 'writeB2Err'
		print("  Scenario G: failed to write source v2 for leg B\n")
		return false
	end 'writeB2Err'
	try File.delete(exePath) otherwise ignore
	try compileProject(projectB) otherwise 'compB2Err'
		print("  Scenario G: leg B v2 compile failed\n")
		return false
	end 'compB2Err'
	try File.writeText(sourcePath, content: sourceV1) otherwise 'writeB3Err'
		print("  Scenario G: failed to write source v1 for leg B (final)\n")
		return false
	end 'writeB3Err'
	try File.delete(exePath) otherwise ignore
	let outputB = try compileProject(projectB) otherwise 'compB3Err'
		print("  Scenario G: leg B final compile failed\n")
		return false
	end 'compB3Err'
	let bytesB = try File.readBinary(outputB) otherwise 'readBErr'
		print("  Scenario G: failed to read leg B binary at {outputB}\n")
		return false
	end 'readBErr'

	if bytesA != bytesB 'bytesDiff'
		print("  Scenario G: binaries diverged — leg A ({bytesA.count()} bytes) vs leg B ({bytesB.count()} bytes). Snapshot rollback is incomplete.\n")
		return false
	end 'bytesDiff'

	return true
end 'runReParseParityScenario'

// Scenario I: inline-aware cache invalidation. Builds a program where a tiny
// `int`-returning accessor (`getVal`) is unconditionally inlined into its
// caller (`compute`), then verifies that:
//   1. The inliner recorded the `compute → getVal` edge in `project.inlineEdges`.
//   2. `captureInlineDeps(compute)` returns the callee fingerprint, and
//      `callerInlineDepsUnchanged` agrees the deps are fresh immediately after.
//   3. Editing ONLY `getVal`'s body and recompiling the SAME Project recomputes
//      `compute`'s chunk (inline-aware invalidation), and the v1 deps now fail
//      `callerInlineDepsUnchanged` against the v2 mid module (callee hash flipped).
//   4. The incremental v2 binary is byte-identical to a clean full v2 build.
// `getVal` returns plain `int` (full range) so it isn't gated by the
// observable-frame range-check rule that skips `ExitCode`-returning accessors.
function runInlineInvalidationScenario(sourcePath FilePath, exePath FilePath) returns bool
	let sourceV1 = inlineScenarioSource(1 as MagicReturn)
	let sourceV2 = inlineScenarioSource(2 as MagicReturn)
	var passed = true

	// --- Cold leg: fresh Project, incremental on, compile v1. ---
	try File.writeText(sourcePath, content: sourceV1) otherwise 'writeV1'
		print("  Scenario I: failed to write v1 source\n")
		return false
	end 'writeV1'
	try File.delete(exePath) otherwise ignore
	var project = createProject(sourcePath, target: detectHostTarget())
	project.db.enableIncremental = true
	try compileProject(project) otherwise 'compV1'
		print("  Scenario I: v1 compile failed\n")
		return false
	end 'compV1'

	// (1) The inliner must have spliced `getVal` into `compute`. If this fails
	// the inliner isn't inlining the accessor (e.g. a budget/gate change), and
	// the rest of the scenario can't prove anything — fail loudly here.
	let calleesV1 = try project.inlineEdges.get("compute") otherwise 'noEdge'
		print("  Scenario I: no inline edges recorded for 'compute' — accessor was not inlined; scenario cannot verify invalidation\n")
		return false
	end 'noEdge'
	if not inlineDepsContainCallee(calleesV1, calleeName: "getVal") 'missingCallee'
		print("  Scenario I: 'compute' inline edges did not include 'getVal' (got {calleesV1.count()} edge(s))\n")
		return false
	end 'missingCallee'

	// (2) captureInlineDeps returns the callee fingerprint; comparing it to
	// itself must report "unchanged" (the predicate's reflexive base case).
	let depsV1 = captureInlineDeps(project, callerName: "compute")
	if depsV1.count() == 0 'noDeps'
		print("  Scenario I: captureInlineDeps returned no deps for 'compute'\n")
		return false
	end 'noDeps'
	if not callerInlineDepsUnchanged(depsV1, fresh: depsV1) 'notReflexive'
		print("  Scenario I: callerInlineDepsUnchanged(depsV1, depsV1) returned false (should be true)\n")
		return false
	end 'notReflexive'

	// Record `compute`'s cached-chunk key hash from the v1 build so we can prove
	// it flips after the callee edit (direct invalidation signal, independent of
	// the byte-identity gate below).
	let computeChunkV1 = try project.db.codePerFunc.get("compute") otherwise 'noChunkV1'
		print("  Scenario I: 'compute' has no cached chunk after v1 build\n")
		return false
	end 'noChunkV1'
	let computeKeyHashV1 = computeChunkV1.keyHash

	// --- Edit leg: same Project, edit ONLY getVal's body, recompile. ---
	try File.writeText(sourcePath, content: sourceV2) otherwise 'writeV2'
		print("  Scenario I: failed to write v2 source\n")
		return false
	end 'writeV2'
	try File.delete(exePath) otherwise ignore
	resetCounters(project)
	let incrOutput = try compileProject(project) otherwise 'compV2'
		print("  Scenario I: v2 incremental compile failed\n")
		return false
	end 'compV2'

	// (3a) The caller whose inlined copy of `getVal` changed must have recomputed
	// its chunk: its post-inline body now embeds the new `getVal` literal, so the
	// freshly-stamped chunk's key hash must differ from the v1 key hash. An equal
	// hash would mean `compute`'s cached chunk was reused despite the inlined
	// callee edit — the stale-bytes regression this change guards against.
	let computeChunkV2 = try project.db.codePerFunc.get("compute") otherwise 'noChunkV2'
		print("  Scenario I: 'compute' has no cached chunk after v2 build\n")
		return false
	end 'noChunkV2'
	if computeChunkV2.keyHash == computeKeyHashV1 'keyUnchanged'
		print("  Scenario I: 'compute' chunk key hash unchanged after editing inlined callee 'getVal' — stale-bytes regression\n")
		return false
	end 'keyUnchanged'

	// (3b) The freshly-captured v2 deps must differ from the stored v1 deps —
	// the persistence-layer predicate correctly detects the inlined callee edit
	// (getVal's body hash flipped, so its InlineDep hash differs between builds).
	let depsV2 = captureInlineDeps(project, callerName: "compute")
	if callerInlineDepsUnchanged(depsV1, fresh: depsV2) 'depsStillFresh'
		print("  Scenario I: callerInlineDepsUnchanged(depsV1, depsV2) returned true — inlined callee edit not detected\n")
		return false
	end 'depsStillFresh'

	let incrBytes = try File.readBinary(incrOutput) otherwise 'readIncr'
		print("  Scenario I: failed to read incremental v2 binary\n")
		return false
	end 'readIncr'

	// --- Reference leg: fresh Project, full (non-incremental) v2 build. ---
	try File.delete(exePath) otherwise ignore
	var refProject = createProject(sourcePath, target: detectHostTarget())
	refProject.db.enableIncremental = false
	let refOutput = try compileProject(refProject) otherwise 'compRef'
		print("  Scenario I: reference v2 full build failed\n")
		return false
	end 'compRef'
	let refBytes = try File.readBinary(refOutput) otherwise 'readRef'
		print("  Scenario I: failed to read reference v2 binary\n")
		return false
	end 'readRef'

	// (4) Byte-identity: the incremental rebuild after the callee edit must
	// match a clean full build of the same source.
	if incrBytes != refBytes 'bytesDiffer'
		print("  Scenario I: incremental v2 binary ({incrBytes.count()} bytes) != full v2 binary ({refBytes.count()} bytes) — invalidation produced wrong code\n")
		passed = false
	end 'bytesDiffer'

	return passed
end 'runInlineInvalidationScenario'

// Source for Scenario I: a tiny full-range accessor `getVal` (inlined into
// `compute`), a caller that uses its result, and a `main` that returns it.
// Only `getVal`'s literal flips between v1 and v2 so the edit is isolated to
// the inlined callee body.
function inlineScenarioSource(calleeReturn MagicReturn) returns String
	// `FullInt` is a full-range int alias (i64.min..i64.max) so `getVal` is NOT
	// gated by the inliner's observable-frame range-check rule (which skips
	// narrowed-range returns like `ExitCode`). Bare `int` is rejected by E3005,
	// hence the alias.
	var src = ""
	src.append("typealias FullInt = int(i64.min to i64.max)\n")
	src.append("function getVal() returns FullInt\n")
	src.append("\treturn {calleeReturn}\n")
	src.append("end 'getVal'\n")
	// `barrier` returns the narrowed-range `ExitCode` alias, so the inliner's
	// observable-frame range-check gate always skips it. Keeping a `barrier()`
	// call inside `compute` means `compute` is never pure and never picks up the
	// all-const-args budget bonus at `main`'s call site — so `compute` is NOT
	// inlined into `main` (which would DCE it and leave no standalone chunk to
	// inspect). `getVal`, by contrast, is a tiny full-range accessor that IS
	// inlined into `compute`: exactly the caller-with-inlined-callee shape this
	// scenario needs.
	src.append("function barrier() returns ExitCode\n")
	src.append("\treturn 0 as ExitCode\n")
	src.append("end 'barrier'\n")
	src.append("function compute(seed FullInt) returns FullInt\n")
	src.append("\tlet v = getVal()\n")
	src.append("\tlet b = barrier()\n")
	src.append("\tvar acc = v + seed\n")
	src.append("\tacc = acc + b\n")
	src.append("\tacc = acc + seed\n")
	src.append("\tacc = acc * seed\n")
	src.append("\tacc = acc + v\n")
	src.append("\tacc = acc * v\n")
	src.append("\tacc = acc + seed\n")
	src.append("\tacc = acc * seed\n")
	src.append("\tacc = acc + v\n")
	src.append("\tacc = acc + seed\n")
	src.append("\treturn acc\n")
	src.append("end 'compute'\n")
	src.append("function main() returns ExitCode\n")
	src.append("\tlet c = compute(1 as FullInt)\n")
	src.append("\tlet ok = (c != (0 as FullInt))\n")
	src.append("\treturn (3 as ExitCode) if ok else (0 as ExitCode)\n")
	src.append("end 'main'\n")
	return src
end 'inlineScenarioSource'

function assertCounter(name String, actual Revision, expected Revision) returns bool
	if actual != expected 'mismatch'
		print("  FAIL: {name} expected {expected}, got {actual}\n")
		return false
	end 'mismatch'
	return true
end 'assertCounter'

function cleanupIncrTest(sourcePath FilePath, exePath FilePath)
	try File.delete(sourcePath) otherwise ignore
	try File.delete(exePath) otherwise ignore
end 'cleanupIncrTest'

// Scenario F implementation. See the header comment at the Scenario F call
// site in `runIncrementalTests` for the architectural rationale.
//
// Per-leg loop:
//   For each leg in {off, full}, run `cycles` cold+incremental pairs. Each
//   cold creates a fresh `Project`, writes the unmodified synthetic source,
//   and times `compileProject`. Each incremental writes the edited source
//   into the SAME `Project` and times `compileProject` again. The on-disk
//   stdlib cache stays warm across all measurements (process-level module
//   vars in `StdlibLoader.maxon`); the in-memory per-function query cache
//   carries over from the cold compile and is selectively invalidated by
//   the file-content change.
//
// Stage P Step 4 refit (post Step 3.5a/b):
//   The full leg runs with `project.db.enableIncremental = true` so the
//   chunk-driven path inside `dispatchBackendEmit` engages. The top-level
//   `codeCache` is invalidated by the file-content change (its `sourceFile`
//   dep fails `isInputUnchanged` once `currentRevision` bumps), so
//   `queryCodeResult` re-runs and walks the per-function chunk cache.
//   Of the 100 functions, only the edited one (`f50`) should miss
//   `db.codePerFunc`; the other 99 hit. We assert that exactly, plus a
//   `<=400ms` mean / `<600ms` max budget on the incremental leg.
//
//   The original Phase-11.5 perf claim was 50-200ms. Stage P Step 3.5b
//   cut the warm-rebuild cost roughly in half by skipping target lowering
//   / regalloc / prologue-epilogue for cache-hit functions, landing at
//   ~325ms. The remaining cost is `queryAllMid` (~200ms): the parser
//   (~113ms) plus mid-tier passes (~90ms) still run whole-module on every
//   revision bump because the source file's `sourceFile` dep is the entry
//   point. Getting under 200ms requires caching the StdModule at the
//   `queryAllMid` level so a single-function edit recomputes just that
//   function's mid pipeline — structural work scoped to a future stage.
//   The 400ms / 600ms budgets capture the Stage-P-actual win with enough
//   noise headroom to catch a regression past ~350ms mean.
//
//   The off leg keeps `enableIncremental = false` and exercises the
//   historical whole-module emit path. Its numbers stay reported as a
//   regression baseline but no longer gate the assertion — the win gate
//   is now absolute, not relative.
function runPerFunctionRebuildScenario(sourcePath FilePath, exePath FilePath) returns bool
	// Bumped from 3 to 5 in Step 4 to reduce noise variance on the now-
	// load-bearing `incrementalMean <= 400` assertion. Five samples gives
	// the min/mean/max trio enough resolution to distinguish a real
	// regression from a one-cycle Windows-clock-granularity outlier
	// (~15ms tick) without making the harness wall-clock unmanageable.
	let cycles = 5 as CycleCount
	// 100 functions gives readable timing (well above the ~15ms Windows clock
	// granularity) while staying small enough that the harness runs in well
	// under a minute. The 30-function shape was timing-noisy because most
	// samples clustered on the granularity tick.
	let funcCount = 100 as FuncBodyCount
	let originalSource = buildSyntheticSource(funcCount, magicReturn: 1 as MagicReturn)
	// Edit ONE function's body — the realistic single-function-edit shape.
	// With the parser snapshot/restore now in place (ParseDelta.beginFileParse
	// wired into queryParseOps), same-Project recompile is possible. The
	// in-memory parse and pass caches survive across the cold→incremental
	// transition; the only invalidation is the changed file's content hash.
	let editedSource = buildSyntheticSourceWithOneEdit(funcCount, editIndex: 50, originalReturn: 1, editedReturn: 2)

	let editedReturn = 2 as MagicReturn

	// Baseline leg (`enableIncremental=false`): chunk-driven path stays
	// dormant. The whole-module emit re-runs every cycle so this measures
	// the pre-Stage-P shape — kept around for regression reporting only.
	let offResult = measureRebuild("off", cycles: cycles, sourcePath: sourcePath, originalSource: originalSource, editedSource: editedSource, exePath: exePath, enableIncremental: false, runExe: false)
	if not offResult.ok 'offFailed'
		print("  Scenario F: off-baseline measurement failed: {offResult.failReason}\n")
		return false
	end 'offFailed'

	// Load-bearing leg (`enableIncremental=true`): `dispatchBackendEmit`
	// routes to `emitBackendIncremental`, which walks `db.codePerFunc` and
	// only re-emits the changed function.
	let fullResult = measureRebuild("full", cycles: cycles, sourcePath: sourcePath, originalSource: originalSource, editedSource: editedSource, exePath: exePath, enableIncremental: true, runExe: true)
	if not fullResult.ok 'fullFailed'
		print("  Scenario F: full-incremental measurement failed: {fullResult.failReason}\n")
		return false
	end 'fullFailed'

	print("\n  --- Scenario F measurements ({funcCount}-function synthetic source, {cycles} cycles per leg) ---\n")
	print("  off (enableIncremental=false): cold mean={offResult.coldMean}ms (min={offResult.coldMin}, max={offResult.coldMax}); incremental mean={offResult.incrementalMean}ms (min={offResult.incrementalMin}, max={offResult.incrementalMax})\n")
	print("  full (enableIncremental=true): cold mean={fullResult.coldMean}ms (min={fullResult.coldMin}, max={fullResult.coldMax}); incremental mean={fullResult.incrementalMean}ms (min={fullResult.incrementalMin}, max={fullResult.incrementalMax})\n")
	print("  full chunk cache: cold misses={fullResult.coldMisses}, incremental hits={fullResult.incrementalHits}, misses={fullResult.incrementalMisses}\n")
	print("  full edited-binary exit code: {fullResult.incrementalExitCode} (expected {editedReturn})\n")

	// Step 3.5a: load-bearing correctness checks come BEFORE the perf gate.
	// The perf gate is expected to fail until Step 3.5b fixes the upstream
	// `queryAllMid` bottleneck (the chunk cache is fine; queryAllMid still
	// runs whole-module on every revision bump). Reporting the correctness
	// failures first keeps the post-mortem focused: a hit/miss mismatch or
	// a stale exit code points at the chunk cache; a clean correctness
	// result with a perf miss points at the upstream queries.
	let expectedHits = (fullResult.coldMisses - 1) as Revision
	let expectedMisses = 1 as Revision
	if fullResult.incrementalMisses != expectedMisses 'missesMismatch'
		print("  Scenario F: chunk-cache misses={fullResult.incrementalMisses}, expected {expectedMisses} (only the edited function should miss)\n")
		return false
	end 'missesMismatch'
	if fullResult.incrementalHits != expectedHits 'hitsMismatch'
		print("  Scenario F: chunk-cache hits={fullResult.incrementalHits}, expected {expectedHits} (cold misses {fullResult.coldMisses} minus 1 edited)\n")
		return false
	end 'hitsMismatch'

	// Exec-the-binary gate: a stale-bytes regression returns exit code 0
	// (the edited function's cached chunk wins, main never sees the
	// mismatch literal). A correct fix returns `editedReturn` because the
	// edited f-function's new literal flows through to main's strict
	// equality check.
	if not fullResult.exeOk 'noExe'
		print("  Scenario F: incremental binary did not run — exec the produced .exe failed\n")
		return false
	end 'noExe'
	if fullResult.incrementalExitCode != editedReturn 'exitMismatch'
		print("  Scenario F: incremental .exe returned exit code {fullResult.incrementalExitCode}; expected {editedReturn} (post-edit literal). Stale-bytes regression — the edited function's cached chunk was reused instead of being re-emitted.\n")
		return false
	end 'exitMismatch'

	// Stage P Phase-11.5 perf claim gate. Numbers are absolute (not relative
	// to off-tier) — the per-function chunk cache produces a fixed-cost
	// rebuild on a single-function edit regardless of how slow the cold path
	// happens to be on a given machine. If this gate fires the dig path is
	// either (a) over-invalidation (more than one chunk recomputed — see the
	// hits/misses assertion below) or (b) a mid-tier query (queryAllMid,
	// queryMirForFunction) over-invalidating and forcing more work upstream
	// of the chunk cache. `--profile-passes` on a failing run names the
	// dominant offender.
	let meanBudget = 400 as DurationMs
	let maxBudget = 600 as DurationMs
	if fullResult.incrementalMean > meanBudget 'meanOver'
		print("  Scenario F: incremental mean {fullResult.incrementalMean}ms exceeds {meanBudget}ms budget\n")
		return false
	end 'meanOver'
	if fullResult.incrementalMax > maxBudget 'maxOver'
		print("  Scenario F: incremental max {fullResult.incrementalMax}ms exceeds {maxBudget}ms noise budget\n")
		return false
	end 'maxOver'
	if fullResult.incrementalMin >= meanBudget 'minOver'
		// `min < mean` always, so a failing min means every cycle was
		// already over the mean budget — the assertion is doubly broken.
		// Distinguishing min from mean in the failure message makes the
		// post-mortem cleaner: a min above budget points at a systemic
		// slowdown, not a one-cycle outlier.
		print("  Scenario F: incremental min {fullResult.incrementalMin}ms is at or above {meanBudget}ms budget — every cycle blew the budget\n")
		return false
	end 'minOver'

	return true
end 'runPerFunctionRebuildScenario'

// Stage P Step 3 ad-hoc smoke: drive a cold compile through the chunk-driven
// path with `enableIncremental = true` AND `tier = full`. Before Step 3 this
// looped indefinitely (queryCodeResult → emitBackendIncremental →
// queryCodeForFunction → queryCodeResult …). The mere fact that this
// function RETURNS is the load-bearing verification — if Step 3's
// recursion-break regresses, this scenario hangs rather than failing fast.
//
// Also asserts the cold build recorded misses (every chunk recomputed) and
// stamped `db.codePerFunc` with at least one entry per emitted function.
// The second-build cache-hit assertion belongs to Step 4 (Scenario F's
// refit), where the harness invalidates the whole-binary `codeCache` so the
// chunk-driven path re-runs on the warm Project. Here the top-level
// `codeCache` would short-circuit the second compile before any chunk
// lookup happens, so a hit-counter check would be misleading.
function runChunkDrivenColdBuildScenario(sourcePath FilePath, exePath FilePath) returns bool
	// 50 functions is enough to make a chunk-stamp regression visible (any
	// missed chunk leaves the cache count below 50) while keeping the
	// scenario fast. Smaller programs would only stamp a handful of chunks,
	// leaving more room for an off-by-one stamp bug to hide.
	let funcCount = 50 as FuncBodyCount
	let source = buildSyntheticSource(funcCount, magicReturn: 1 as MagicReturn)
	try File.writeText(sourcePath, content: source) otherwise 'writeSrc'
		print("  Scenario H: failed to write source\n")
		return false
	end 'writeSrc'

	try File.delete(exePath) otherwise ignore
	var project = createProject(sourcePath, target: detectHostTarget())
	// Flip the master switch — this is what activates the chunk-driven path
	// inside `dispatchBackendEmit`. The default-false setting means batch CLI
	// builds and every other scenario stays on the historical whole-module
	// path; only this smoke test exercises the new code path end-to-end.
	project.db.enableIncremental = true

	// Cold build: every function is a chunk-cache miss. Before Step 3 this
	// recursed forever; after Step 3 it terminates because the miss tail
	// emits directly through `backend.emitFunctionChunk`.
	try compileProject(project) otherwise 'cold'
		print("  Scenario H: chunk-driven cold build failed\n")
		return false
	end 'cold'

	// Verify the cold build actually went through the miss path. Zero misses
	// would mean the chunk-driven dispatch never engaged (e.g.
	// `enableIncremental` not propagated, top-level codeCache short-circuited
	// unexpectedly).
	let coldMisses = project.db.codePerFuncMisses
	if coldMisses == 0 'noMisses'
		print("  Scenario H: cold build did not record any per-function misses — chunk-driven path may not have engaged\n")
		return false
	end 'noMisses'

	// Verify the miss tail stamped chunks into the per-function cache. The
	// stamp count must equal the miss count: every miss-then-direct-emit
	// path goes through `stampChunkMemo`, so the two counters move in
	// lockstep. A regression in stampChunkMemo would leave `codePerFunc`
	// empty and break every subsequent same-Project rebuild's cache hit.
	let stampedCount = project.db.codePerFunc.count()
	if stampedCount == 0 'noStamps'
		print("  Scenario H: cold build emitted {coldMisses} chunks but stamped 0 — db.codePerFunc not populated\n")
		return false
	end 'noStamps'

	print("  Scenario H: chunk-driven cold build terminated; codePerFuncMisses={coldMisses}, chunks stamped={stampedCount}\n")

	return true
end 'runChunkDrivenColdBuildScenario'

type RebuildMeasurement
	export var ok as bool
	export var failReason as String
	export var coldMean as DurationMs
	export var coldMin as DurationMs
	export var coldMax as DurationMs
	export var incrementalMean as DurationMs
	export var incrementalMin as DurationMs
	export var incrementalMax as DurationMs
	// Stage P Step 4: chunk-cache counters captured immediately after the
	// final cycle's incremental compile. Counters are reset before each
	// incremental leg so the values here are per-edit, not cumulative.
	// Recorded only for the `enableIncremental=true` measurement in practice;
	// the `enableIncremental=false` baseline doesn't consult `db.codePerFunc`,
	// so its values are zero and uninteresting.
	export var incrementalHits as Revision
	export var incrementalMisses as Revision
	// Step 3.5a: cold-build chunk-cache misses count, captured immediately
	// after the final cycle's cold compile. Represents the total number of
	// function chunks emitted (each cold-build function is a miss because
	// the per-function cache starts empty). The incremental assertion is
	// `hits == coldMisses - 1` so the test is robust against the number of
	// runtime/stdlib chunks that appear in the binary — the only invariant
	// is that exactly one function (the edited one) misses on rebuild and
	// every other function reuses its cached chunk.
	export var coldMisses as Revision
	// Step 3.5a: exit code of the produced .exe after the final cycle's
	// incremental compile. The synthetic main returns `editedReturn` when
	// the edit took effect (the edited function's literal flips from
	// `originalReturn` to `editedReturn` and main detects the mismatch). A
	// stale-bytes regression (the edited chunk reused from cache) shows up
	// as exit code 0 — main never sees the mismatch and falls through.
	// `exeOk` distinguishes "ran successfully" from "couldn't even spawn
	// the binary" so the failure message points the post-mortem at the
	// right layer.
	export var incrementalExitCode as ExitCode
	export var exeOk as bool

	export static function failed(reason String) returns RebuildMeasurement
		return Self{ok: false, failReason: reason, coldMean: 0, coldMin: 0, coldMax: 0, incrementalMean: 0, incrementalMin: 0, incrementalMax: 0, incrementalHits: 0, incrementalMisses: 0, coldMisses: 0, incrementalExitCode: 0, exeOk: false}
	end 'failed'

	export static function create(coldMean DurationMs, coldMin DurationMs, coldMax DurationMs, incrementalMean DurationMs, incrementalMin DurationMs, incrementalMax DurationMs, incrementalHits Revision, incrementalMisses Revision, coldMisses Revision, incrementalExitCode ExitCode, exeOk bool) returns RebuildMeasurement
		return Self{ok: true, failReason: "", coldMean: coldMean, coldMin: coldMin, coldMax: coldMax, incrementalMean: incrementalMean, incrementalMin: incrementalMin, incrementalMax: incrementalMax, incrementalHits: incrementalHits, incrementalMisses: incrementalMisses, coldMisses: coldMisses, incrementalExitCode: incrementalExitCode, exeOk: exeOk}
	end 'create'
end 'RebuildMeasurement'

function measureRebuild(label String, cycles CycleCount, sourcePath FilePath, originalSource String, editedSource String, exePath FilePath, enableIncremental bool, runExe bool) returns RebuildMeasurement
	var coldSamples = DurationArray.create()
	var incrementalSamples = DurationArray.create()
	// Chunk-cache counters from the most recent incremental cycle. The
	// final-cycle values are what the Scenario F assertion consumes — using
	// the LAST cycle (instead of any aggregate across cycles) keeps the
	// expected-99/1 numbers exact and unambiguous.
	var lastIncrHits = 0 as Revision
	var lastIncrMisses = 0 as Revision
	var lastColdMisses = 0 as Revision
	var lastIncrExitCode = 0 as ExitCode
	var lastExeOk = false

	// SAME-Project incremental measurement. Cold leg creates a fresh Project
	// and compiles the original source; incremental leg writes the edited
	// source to the same path, then re-compiles in the SAME Project — the
	// in-memory per-function caches (db.midPerFunc / db.mirPerFunc /
	// db.codePerFunc) carry over from the cold compile and are selectively
	// invalidated by the single-file content change. The parser-side-effect
	// undo path (ParseDelta.beginFileParse, wired into queryParseOps) makes
	// this re-parse safe; before that landed, the second compile crashed
	// with E2001 "Duplicate function 'main'" the moment the parser
	// re-registered any name.
	for cycle in 0 upto cycles 'eachCycle'
		try File.writeText(sourcePath, content: originalSource) otherwise 'writeCold'
			return RebuildMeasurement.failed("write cold source failed at cycle {cycle}")
		end 'writeCold'
		try File.delete(exePath) otherwise ignore
		var sharedProject = createProject(sourcePath, target: detectHostTarget())
		// Master switch for the chunk-driven path. `dispatchBackendEmit`
		// requires `enableIncremental` to engage `emitBackendIncremental`;
		// setting it before cold ensures the cold pass populates
		// `db.codePerFunc` via `stampChunkMemo` from `emitTargetCode`, so
		// the incremental leg can hit it.
		sharedProject.db.enableIncremental = enableIncremental
		let coldStart = Clock.nowMs()
		try compileProject(sharedProject) otherwise 'compColdF'
			return RebuildMeasurement.failed("cold compile failed at cycle {cycle} ({label})")
		end 'compColdF'
		let coldElapsed = Clock.elapsedMs(coldStart)
		coldSamples.push(coldElapsed)
		lastColdMisses = sharedProject.db.codePerFuncMisses

		// Incremental leg: SAME Project, edited source. The in-memory
		// query cache is now populated from the cold compile; with one
		// function body changed, only the affected functions should
		// recompute through queryParseOps → queryAllMid → queryCodeResult.
		try File.writeText(sourcePath, content: editedSource) otherwise 'writeEdit'
			return RebuildMeasurement.failed("write edited source failed at cycle {cycle}")
		end 'writeEdit'
		try File.delete(exePath) otherwise ignore
		// Reset counters BEFORE the incremental leg so the captured
		// hits/misses are exactly the per-edit count, not cumulative
		// across cycles. The cold pass also bumps these counters (through
		// `emitTargetCode`'s stamp loop and any per-function query hits
		// from the upstream pipeline), so without this reset the asserted
		// values would drift cycle-to-cycle.
		resetCounters(sharedProject)
		let incrStart = Clock.nowMs()
		let incrOutputPath = try compileProject(sharedProject) otherwise 'compIncrF'
			return RebuildMeasurement.failed("incremental compile failed at cycle {cycle} ({label})")
		end 'compIncrF'
		let incrElapsed = Clock.elapsedMs(incrStart)
		incrementalSamples.push(incrElapsed)
		lastIncrHits = sharedProject.db.codePerFuncHits
		lastIncrMisses = sharedProject.db.codePerFuncMisses

		// Step 3.5a: exec the produced binary so a stale-bytes regression in
		// the per-function chunk cache surfaces here, not silently in a
		// runtime caller. The synthetic's main returns `editedReturn` when
		// the edit took effect (mismatched literal) and 0 when it didn't.
		// Only run on the final cycle and only when the caller asked for
		// it — the off-baseline doesn't need this gate.
		if runExe and cycle == cycles - 1 'execLast'
			let result = try Subprocess.run(Executable.path(incrOutputPath), arguments: StringArray.create(), workingDirectory: Directory.currentPath(), timeoutMs: 5000) otherwise (err) 'spawnFail'
				return RebuildMeasurement.failed("incremental exec failed at cycle {cycle} ({label}): {err.displayReason()}")
			end 'spawnFail'
			lastIncrExitCode = result.exitCode()
			lastExeOk = true
		end 'execLast'
	end 'eachCycle'

	let coldStats = summarizeSamples(coldSamples)
	let incrStats = summarizeSamples(incrementalSamples)
	return RebuildMeasurement.create(coldStats.mean, coldMin: coldStats.min, coldMax: coldStats.max, incrementalMean: incrStats.mean, incrementalMin: incrStats.min, incrementalMax: incrStats.max, incrementalHits: lastIncrHits, incrementalMisses: lastIncrMisses, coldMisses: lastColdMisses, incrementalExitCode: lastIncrExitCode, exeOk: lastExeOk)
end 'measureRebuild'

typealias DurationArray = Array with DurationMs

type SampleStats
	export var mean as DurationMs
	export var min as DurationMs
	export var max as DurationMs

	export static function create(mean DurationMs, min DurationMs, max DurationMs) returns SampleStats
		return Self{mean: mean, min: min, max: max}
	end 'create'
end 'SampleStats'

function summarizeSamples(samples DurationArray) returns SampleStats
	let n = samples.count()
	if n == 0 'empty'
		return SampleStats.create(0, min: 0, max: 0)
	end 'empty'
	var sum = 0 as DurationMs
	let firstSample = try samples.get(0) otherwise panic("summarizeSamples: count() > 0 just checked but get(0) failed")
	var sMin = firstSample
	var sMax = firstSample
	for sample in samples 'each'
		sum = sum + sample
		if sample < sMin 'newMin'
			sMin = sample
		end 'newMin'
		if sample > sMax 'newMax'
			sMax = sample
		end 'newMax'
	end 'each'
	let mean = (sum / n) as DurationMs
	return SampleStats.create(mean, min: sMin, max: sMax)
end 'summarizeSamples'

// Build a synthetic Maxon source with `funcCount` trivial leaf functions
// `f000..fNNN` that each `return magicReturn as ExitCode`, plus a `main`
// that sums their return values. The `magicReturn` constant is the per-
// function-body delta we flip between the cold and incremental legs:
// every function's body changes, every cached chunk gets invalidated.
typealias FuncBodyCount = int(0 to 1024)
typealias MagicReturn = int(0 to 255)
typealias CycleCount = int(1 to 100)

function buildSyntheticSource(funcCount FuncBodyCount, magicReturn MagicReturn) returns String
	// Trivial leaf functions return an `ExitCode` typealias whose body is a
	// small literal that we flip between cold and incremental legs. `main`
	// composes them with a short-circuit chain so each `f{i}()` call site is
	// exercised in lowering / regalloc / backend emission.
	var src = ""
	for i in 0 upto funcCount 'eachFn'
		src.append("function f{i}() returns ExitCode\n")
		src.append("\treturn {magicReturn} as ExitCode\n")
		src.append("end 'f{i}'\n")
	end 'eachFn'
	src.append("function main() returns ExitCode\n")
	for i in 0 upto funcCount 'eachCall'
		src.append("\tlet r{i} = f{i}()\n")
		src.append("\tif r{i} != ({magicReturn} as ExitCode) 'mismatch{i}'\n")
		src.append("\t\treturn r{i}\n")
		src.append("\tend 'mismatch{i}'\n")
	end 'eachCall'
	src.append("\treturn 0 as ExitCode\n")
	src.append("end 'main'\n")
	return src
end 'buildSyntheticSource'

// Same shape as `buildSyntheticSource` but edits ONLY one function's body
// (the one at `editIndex`). Other functions keep `originalReturn`; only
// `f{editIndex}` returns `editedReturn`. This is the realistic single-
// function-edit shape that the per-function cache should accelerate —
// only one function body's hash changes, so only one function's
// downstream queries (mid, mir, code) should miss the cache; the other
// `funcCount - 1` chunks should hit. Compile-time delta vs the cold
// compile is the per-function-dispatch perf signal.
//
// Step 3.5a: main asserts strict equality against `originalReturn` so a
// post-edit run produces an observable, exit-code-visible difference —
// the edited `f{editIndex}` returns `editedReturn`, mismatches the check,
// and main returns that value. The pre-edit cold-build binary returns 0
// (every function matches); the post-edit incremental-build binary
// returns `editedReturn`. The Scenario F harness execs the produced .exe
// after the incremental compile to confirm the edit took effect — a
// regression of the stale-bytes bug surfaces as the binary still
// returning 0 instead of `editedReturn`.
function buildSyntheticSourceWithOneEdit(funcCount FuncBodyCount, editIndex FuncBodyCount, originalReturn MagicReturn, editedReturn MagicReturn) returns String
	var src = ""
	for i in 0 upto funcCount 'eachFn'
		let r = (editedReturn if i == editIndex else originalReturn)
		src.append("function f{i}() returns ExitCode\n")
		src.append("\treturn {r} as ExitCode\n")
		src.append("end 'f{i}'\n")
	end 'eachFn'
	src.append("function main() returns ExitCode\n")
	for i in 0 upto funcCount 'eachCall'
		src.append("\tlet r{i} = f{i}()\n")
		src.append("\tif r{i} != ({originalReturn} as ExitCode) 'mismatch{i}'\n")
		src.append("\t\treturn r{i}\n")
		src.append("\tend 'mismatch{i}'\n")
	end 'eachCall'
	src.append("\treturn 0 as ExitCode\n")
	src.append("end 'main'\n")
	return src
end 'buildSyntheticSourceWithOneEdit'

function verifyExeExitCode(exePath FilePath, expectedEc ExitCode) returns bool
	let result = try Subprocess.run(Executable.path(exePath), arguments: StringArray.create(), workingDirectory: Directory.currentPath(), timeoutMs: 5000) otherwise (err) 'spawn'
		print("  failed to run {exePath.toString()}: {err.displayReason()}\n")
		return false
	end 'spawn'
	let ec = result.exitCode()
	if ec != expectedEc 'mismatch'
		print("  expected exit code {expectedEc}, got {ec}\n")
		return false
	end 'mismatch'
	return true
end 'verifyExeExitCode'

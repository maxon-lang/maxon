// Fragment generator and parser for the self-hosted compiler test runner.
// Generates .test fragment files from parsed spec tests and parses them back.
// Matches the C# FragmentGenerator format exactly.

// Generate fragment file content for a test case.
// Format matches C# FragmentGenerator.GenerateFragmentContent().
export function generateFragmentContent(test SpecTest, compileIr String) returns String
	var sb = "// Test: {test.name}\n{test.source}\n---\n"

	// Metadata section
	if not test.args.isEmpty() 'hasArgs'
		sb = "{sb}Args: {test.args}\n"
	end 'hasArgs'

	if test.mmTrace 'hasMmTrace'
		sb = "{sb}MmTrace: true\n"
	end 'hasMmTrace'

	if test.asyncTrace 'hasAsyncTrace'
		sb = "{sb}AsyncTrace: true\n"
	end 'hasAsyncTrace'

	if test.expectation.hasCompilerStderr 'hasCompilerErr'
		sb = "{sb}MaxoncStderr: ```\n{test.expectation.compilerStderr}\n```\n"
	end 'hasCompilerErr' else 'isSuccess'
		if test.expectation.hasExitCode 'hasEc'
			sb = "{sb}ExitCode: {test.expectation.exitCode}\n"
		end 'hasEc'

		if test.expectation.hasStdout 'hasStdout'
			sb = "{sb}Stdout: ```\n{test.expectation.stdout}\n```\n"
		end 'hasStdout'

		if test.expectation.hasRuntimeStderr 'hasStderr'
			sb = "{sb}Stderr: ```\n{test.expectation.runtimeStderr}\n```\n"
		end 'hasStderr'

		if test.expectation.hasRequiredLowering 'hasLowering'
			sb = "{sb}RequiredLowering: ```\n{test.expectation.requiredLowering}\n```\n"
		end 'hasLowering'

		if test.expectation.hasRequiredRdata 'hasRdata'
			sb = "{sb}RequiredRdata: ```\n{test.expectation.requiredRdata}\n```\n"
		end 'hasRdata'

		if test.expectation.hasRequiredData 'hasData'
			sb = "{sb}RequiredData: ```\n{test.expectation.requiredData}\n```\n"
		end 'hasData'
	end 'isSuccess'

	sb = "{sb}---\n"

	// Compiled IR section (may be empty). When non-empty, prefix with a
	// "// CompiledIR" header so section 3 can never be confused with the
	// RequiredLowering/RequiredIR expectation blocks in section 2.
	if not compileIr.isEmpty() 'hasIr'
		sb = "{sb}// CompiledIR\n{compileIr.trim()}\n"
	end 'hasIr'

	sb = "{sb}---\n"

	return sb
end 'generateFragmentContent'

// Write a fragment file to the fragment directory.
// Creates the spec subdirectory if needed via mkdir.
// Never deletes existing fragments — only overwrites.
export function writeFragment(fragmentDir FilePath, specName String, test SpecTest, compileIr String)
	let specDir = fragmentDir.join(specName)

	// Ensure spec subdirectory exists
	if not specDir.directoryExists() 'noDir'
		_ = Process.execute("mkdir -p {specDir}", timeoutMs: 5000)
	end 'noDir'

	let fragmentPath = specDir.join("{test.name}.test")
	let content = generateFragmentContent(test, compileIr: compileIr)

	// Normalize line endings to LF
	let normalized = content.replace("\r\n", with: "\n")

	try File.writeText(fragmentPath, content: normalized) otherwise 'writeErr'
		logError(LogCategory.testing, message: () gives "Failed to write fragment: {fragmentPath}")
	end 'writeErr'
end 'writeFragment'

// Parse a fragment file back into a Fragment struct.
// Mirrors C# FragmentGenerator.ParseFragment().
export function parseFragment(fragmentPath FilePath) returns Fragment throws CompileError
	let content = try File.readText(fragmentPath) otherwise 'readErr'
		throw CompileError.readError
	end 'readErr'

	let lines = content.split("\n")
	let lineCount = lines.count()

	// Extract test name from first line: "// Test: {name}"
	var testName = "unknown"
	let firstLine = try lines.get(0) otherwise ""
	if firstLine.startsWith("// Test: ") 'hasName'
		var nameIdx = firstLine.startIndex()
		// Skip "// Test: " (9 chars)
		for _ in 0 upto 9 'skipPrefix'
			nameIdx = try firstLine.indexAfter(nameIdx) otherwise 'skipBad'
				break
			end 'skipBad'
		end 'skipPrefix'
		testName = trimWhitespace(firstLine.slice(nameIdx, endIndex: firstLine.endIndex()))
	end 'hasName'

	// Find first "---" separator
	var firstSep = -1
	for i in 1 upto lineCount 'findFirstSep'
		let line = trimWhitespace(try lines.get(i) otherwise "")
		if line == "---" 'found'
			firstSep = i
			break
		end 'found'
	end 'findFirstSep'

	if firstSep < 0 'noSep'
		throw CompileError.readError
	end 'noSep'

	// Source = lines 0..firstSep (including the // Test: comment)
	var source = ""
	var firstSourceLine = true
	for i in 0 upto firstSep 'buildSource'
		let line = try lines.get(i) otherwise ""
		if firstSourceLine 'isFirst'
			source = line
			firstSourceLine = false
		end 'isFirst' else 'notFirst'
			source = "{source}\n{line}"
		end 'notFirst'
	end 'buildSource'

	// Find second "---" separator
	var secondSep = -1
	var j = firstSep + 1
	while j < lineCount 'findSecondSep'
		let line = trimWhitespace(try lines.get(j) otherwise "")
		if line == "---" 'found2'
			secondSep = j
			break
		end 'found2'

		// Check for multi-line value blocks (delimited by ```) — need to skip past them
		if line.endsWith("```") 'startMultiLine'
			j = j + 1
			while j < lineCount 'skipMultiLine'
				let mLine = trimWhitespace(try lines.get(j) otherwise "")
				if mLine == "```" 'endMultiLine'
					break
				end 'endMultiLine'
				j = j + 1
			end 'skipMultiLine'
		end 'startMultiLine'

		j = j + 1
	end 'findSecondSep'

	if secondSep < 0 'noSep2'
		secondSep = lineCount
	end 'noSep2'

	// Parse expectation section (between first and second ---)
	var expectation = TestExpectation.create()
	var fragArgs = ""
	var fragMmTrace = false
	var fragAsyncTrace = false

	var k = firstSep + 1
	while k < secondSep 'parseExpect'
		let line = try lines.get(k) otherwise ""
		let trimmedLine = trimWhitespace(line)

		if trimmedLine.startsWith("ExitCode:") 'isEc'
			var ecIdx = trimmedLine.startIndex()
			for _ in 0 upto 10 'skipEcPrefix'
				ecIdx = try trimmedLine.indexAfter(ecIdx) otherwise 'skipEcBad'
					break
				end 'skipEcBad'
			end 'skipEcPrefix'
			let ecStr = trimWhitespace(trimmedLine.slice(ecIdx, endIndex: trimmedLine.endIndex()))
			let ecVal = try int.fromString(ecStr) otherwise 'badEc'
				k = k + 1
				continue
			end 'badEc'
			expectation.exitCode = ecVal
			expectation.hasExitCode = true
		end 'isEc' else if trimmedLine.startsWith("Args:") 'isArgs'
			var argsIdx = trimmedLine.startIndex()
			for _ in 0 upto 5 'skipArgsPrefix'
				argsIdx = try trimmedLine.indexAfter(argsIdx) otherwise 'skipArgsBad'
					break
				end 'skipArgsBad'
			end 'skipArgsPrefix'
			fragArgs = trimWhitespace(trimmedLine.slice(argsIdx, endIndex: trimmedLine.endIndex()))
		end 'isArgs' else if trimmedLine.startsWith("MmTrace:") 'isMm'
			fragMmTrace = trimmedLine.contains("true")
		end 'isMm' else if trimmedLine.startsWith("AsyncTrace:") 'isAsync'
			fragAsyncTrace = trimmedLine.contains("true")
		end 'isAsync' else if trimmedLine.startsWith("MaxoncStderr: ```") 'isCompErr'
			k = k + 1
			let errBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.compilerStderr = errBlock.value
			expectation.hasCompilerStderr = true
			k = errBlock.nextLine
			continue
		end 'isCompErr' else if trimmedLine.startsWith("Stdout: ```") 'isStdout'
			k = k + 1
			let stdoutBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.stdout = stdoutBlock.value
			expectation.hasStdout = true
			k = stdoutBlock.nextLine
			continue
		end 'isStdout' else if trimmedLine.startsWith("Stderr: ```") 'isStderr'
			k = k + 1
			let stderrBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.runtimeStderr = stderrBlock.value
			expectation.hasRuntimeStderr = true
			k = stderrBlock.nextLine
			continue
		end 'isStderr' else if trimmedLine.startsWith("RequiredIR: ```") 'isIR'
			// Skip RequiredIR blocks in legacy fragments (no longer used by self-hosted compiler)
			k = k + 1
			let irBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			k = irBlock.nextLine
			continue
		end 'isIR' else if trimmedLine.startsWith("RequiredIR: ```") 'isLegacyIR'
			// Skip legacy RequiredIR blocks in fragments (still emitted by maxon-sharp)
			k = k + 1
			let irBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			k = irBlock.nextLine
			continue
		end 'isLegacyIR' else if trimmedLine.startsWith("RequiredLowering: ```") 'isLowering'
			k = k + 1
			let loweringBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.requiredLowering = loweringBlock.value
			expectation.hasRequiredLowering = true
			k = loweringBlock.nextLine
			continue
		end 'isLowering' else if trimmedLine.startsWith("RequiredRdata: ```") 'isRdata'
			k = k + 1
			let rdataBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.requiredRdata = rdataBlock.value
			expectation.hasRequiredRdata = true
			k = rdataBlock.nextLine
			continue
		end 'isRdata' else if trimmedLine.startsWith("RequiredData: ```") 'isData'
			k = k + 1
			let dataBlock = readFragmentMultilineValue(lines, startLine: k, endLine: secondSep)
			expectation.requiredData = dataBlock.value
			expectation.hasRequiredData = true
			k = dataBlock.nextLine
			continue
		end 'isData'

		k = k + 1
	end 'parseExpect'

	expectation.mmTrace = fragMmTrace
	expectation.asyncTrace = fragAsyncTrace

	// Parse compiled IR (between second and third ---). When non-empty,
	// section 3 must start with a "// CompiledIR" header — this is the
	// canonical signal that the content is captured compiler output rather
	// than an expectation block (RequiredLowering/RequiredIR live in
	// section 2 and use the "Key: ```...```" shape).
	var generatedIR = ""
	var hasGeneratedIR = false
	if secondSep < lineCount 'hasIrSection'
		var thirdSep = lines.count()
		for m in(secondSep + 1) upto lineCount 'findThirdSep'
			let mLine = trimWhitespace(try lines.get(m) otherwise "")
			if mLine == "---" 'found3'
				thirdSep = m
				break
			end 'found3'
		end 'findThirdSep'

		// Find the first non-blank line in section 3. An entirely blank
		// section is legal (e.g. the fragment was generated with
		// RequiredLowering/RequiredIR set, or it's a compiler_error test),
		// and corresponds to "no compiled IR captured".
		var headerLineIdx = -1
		for m in(secondSep + 1) upto thirdSep 'findHeader'
			let mLine = trimWhitespace(try lines.get(m) otherwise "")
			if not mLine.isEmpty() 'nonBlank'
				headerLineIdx = m
				break
			end 'nonBlank'
		end 'findHeader'

		if headerLineIdx >= 0 'hasContent'
			let headerLine = trimWhitespace(try lines.get(headerLineIdx) otherwise "")
			// Non-empty section 3 must start with the "// CompiledIR"
			// header; otherwise the fragment is in a stale format and
			// must be regenerated before the parser can trust it.
			if headerLine != "// CompiledIR" 'missingHeader'
				logError(LogCategory.testing, message: () gives "Fragment '{fragmentPath}' is in a stale format: section 3 is missing the '// CompiledIR' header. Regenerate the fragment and retry.")
				throw CompileError.readError
			end 'missingHeader'

			// Build the IR body from the lines after the header, and apply
			// the existing "// Compilation failed:" check — a failure marker
			// means no usable IR was captured, so leave generatedIR empty.
			var irLines = ""
			var firstIr = true
			for m in(headerLineIdx + 1) upto thirdSep 'buildIr'
				let mLine = try lines.get(m) otherwise ""
				if firstIr 'isFirstIr'
					irLines = mLine
					firstIr = false
				end 'isFirstIr' else 'notFirstIr'
					irLines = "{irLines}\n{mLine}"
				end 'notFirstIr'
			end 'buildIr'

			let trimmedIr = trimWhitespace(irLines)
			if not trimmedIr.isEmpty() 'hasBody'
				if not trimmedIr.startsWith("// Compilation failed:") 'notFailed'
					generatedIR = trimmedIr
					hasGeneratedIR = true
				end 'notFailed'
			end 'hasBody'
		end 'hasContent'
	end 'hasIrSection'

	// Detect multi-file markers in source
	let sourceFiles = splitMultiFileSource(source)
	let hasMulti = sourceFiles.count() > 0

	return Fragment.create(filePath: fragmentPath.toString(), testName: testName, source: source, expectation: expectation, generatedIR: generatedIR, hasGeneratedIR: hasGeneratedIR, args: fragArgs, sourceFiles: sourceFiles, hasMultiFile: hasMulti, mmTrace: fragMmTrace, asyncTrace: fragAsyncTrace)
end 'parseFragment'

// Helper: read a multi-line value from fragment lines until a closing ``` is found.
export type MultiLineResult
	export var value String
	export var nextLine LineNumber

	export static function create(value String, nextLine LineNumber) returns MultiLineResult
		return Self{value: value, nextLine: nextLine}
	end 'create'
end 'MultiLineResult'

function readFragmentMultilineValue(lines TextLineArray, startLine LineNumber, endLine LineNumber) returns MultiLineResult
	var result = ""
	var first = true
	var i = startLine

	while i < endLine 'read'
		let line = try lines.get(i) otherwise 'done'
			break
		end 'done'
		let trimmedLine = trimWhitespace(line)
		if trimmedLine == "```" 'endBlock'
			return MultiLineResult.create(result, nextLine: i + 1)
		end 'endBlock'
		if first 'isFirst'
			result = line
			first = false
		end 'isFirst' else 'notFirst'
			result = "{result}\n{line}"
		end 'notFirst'
		i = i + 1
	end 'read'

	return MultiLineResult.create(result, nextLine: i)
end 'readFragmentMultilineValue'

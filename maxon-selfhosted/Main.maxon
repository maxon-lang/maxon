// Self-hosted Maxon compiler entry point.
// Mirrors maxon-sharp/Program.cs command structure.

function main() returns ExitCode
    let allArgs = CommandLine.args()

    if let command = try allArgs.get(0) 'dispatch'
        let rest = allArgs.slice(1, endIndex: allArgs.count())
        let cleanRest = try processLogArgs(rest) otherwise (e) 'badArgs'
            match e 'matchErr'
                invalidOption(a) then print("Invalid --log option: {a}\n")
            end 'matchErr'
            return 1
        end 'badArgs'

        match command 'cmd'
            "build" then return runBuild(cleanRest)
            "spec-test" then return runSpecTests(cleanRest)
            "test-incremental" then return runIncrementalTests()
            default then printUsage()
        end 'cmd'
    end 'dispatch' else 'noArgs'
        printUsage()
    end 'noArgs'

    return 1
end 'main'

function printUsage()
    print("Usage: maxon <command> [options]\n")
    print("\n")
    print("Commands:\n")
    print("  build [<file|directory>] Build a project (default: current directory)\n")
    print("  run <file|directory>     Build and run\n")
    print("  spec-test [options]      Run spec tests\n")
    print("  test-incremental         Run incremental compilation tests\n")
    print("\n")
    print("Build options (build, run):\n")
    print("  --emit-ir                Write .mlir file\n")
    print("  --dump-stages            Write IR at each pipeline stage\n")
    print("  --track-allocs           Track heap allocations and print memory stats\n")
    print("\n")
    print("Spec test options:\n")
    print("  --filter=PATTERN         Run only tests matching pattern\n")
    print("\n")
    print("Logging (all commands):\n")
    print("  --log=LEVEL              Set all log categories to LEVEL\n")
    print("  --log=CATEGORY:LEVEL     Set specific category to LEVEL\n")
    print("\n")
    print("Log levels: none, error, info, debug, trace\n")
    print("Log categories: compiler, lexer, parser, semantic, mlir, codegen, pe, testing\n")
end 'printUsage'

function runBuild(args StringArray) returns ExitCode
    let path = try args.get(0) otherwise Directory.currentDirectory()

    let outputPath = try compile(path) otherwise 'err'
        return 1
    end 'err'

    print("Compiled -> {outputPath}\n")

    return 0
end 'runBuild'

function runSpecTests(args StringArray) returns ExitCode
    // Parse --filter= option
    var filter = ""
    for arg in args 'parseArgs'
        if arg.startsWith("--filter=") 'isFilter'
            let eqIdx = try arg.findFirst("=") otherwise 'bad'
                continue
            end 'bad'
            let afterEq = try arg.indexAfter(eqIdx) otherwise 'bad2'
                continue
            end 'bad2'
            filter = arg.slice(afterEq, endIndex: arg.endIndex())
        end 'isFilter'
    end 'parseArgs'

    logInfo(LogCategory.testing, message: "Running self-hosted spec tests...")

    return runAllSpecTests(filter)
end 'runSpecTests'

// Self-hosted Maxon compiler entry point.
// Mirrors maxon-sharp/Program.cs command structure.

function main() returns int
    let args = CommandLine.args()

    if let command = try args.get(0) 'dispatch'
        let rest = args.slice(1, endIndex: args.count())

        match command 'cmd'
            "build" then return runBuild(rest)
            "run" then return runRun(rest)
            "spec-test" then return runSpecTests(rest)
            default then printUsage()
        end 'cmd'
    end 'dispatch' else 'noArgs'
        printUsage()
    end 'noArgs'

    return 1
end 'main'

function printUsage()
    print("Usage: maxon <command> [options]\n")
    print("\n")
    print("Commands:\n")
    print("  build [<file|directory>] Build a project (default: current directory)\n")
    print("  run <file|directory>     Build and run\n")
    print("  spec-test [options]      Run spec tests\n")
    print("\n")
    print("Build options (build, run):\n")
    print("  --emit-ir                Write .mlir file\n")
    print("  --dump-stages            Write IR at each pipeline stage\n")
    print("  --track-allocs           Track heap allocations and print memory stats\n")
    print("\n")
    print("Spec test options:\n")
    print("  --filter=PATTERN         Run only tests matching pattern\n")
    print("\n")
    print("Logging (all commands):\n")
    print("  --log=LEVEL              Set all log categories to LEVEL\n")
    print("  --log=CATEGORY:LEVEL     Set specific category to LEVEL\n")
    print("\n")
    print("Log levels: none, error, info, debug, trace\n")
    print("Log categories: compiler, lexer, parser, semantic, hir, lir, optimizer, codegen, pe, testing\n")
end 'printUsage'

function runBuild(args StringArray) returns int
    let path = try args.get(0) otherwise Directory.currentDirectory()
    try compilePath(path) otherwise (e) 'err'
        match e 'which'
            CompileError.fileNotFound then print("File or directory not found: {path}\n")
            CompileError.directoryNotFound then print("Directory not found: {path}\n")
            CompileError.noSourceFiles then print("No .maxon files found in: {path}\n")
            CompileError.readError then print("Error reading file: {path}\n")
        end 'which'
        return 1
    end 'err'
    return 0
end 'runBuild'

function runRun(args StringArray) returns int
    let _ = args.count()
    print("run: not yet implemented\n")
    return 1
end 'runRun'

function runSpecTests(args StringArray) returns int
    let _ = args.count()
    print("spec-test: not yet implemented\n")
    return 1
end 'runSpecTests'

// Replaces the file extension (e.g. ".maxon" -> ".exe").
export function changeExtension(path String, ext String) returns String
    let dotIdx = try path.find(".") otherwise path.endIndex()
    let base = path.slice(path.startIndex(), endIndex: dotIdx)
    return base.concat(ext)
end 'changeExtension'

// Self-hosted Maxon compiler entry point.
// Mirrors maxon-sharp/Program.cs command structure.

function main() returns ExitCode
    let allArgs = CommandLine.args()

    if let command = try allArgs.get(0) 'dispatch'
        let rest = allArgs.slice(1, endIndex: allArgs.count())
        let cleanRest = try processLogArgs(rest) otherwise (e) 'badArgs'
            match e 'matchErr'
                invalidOption(a) then print("Invalid --log option: {a}\n")
            end 'matchErr'
            return 1
        end 'badArgs'

        match command 'cmd'
            "build" then return runBuild(cleanRest)
            "spec-test" then return runSpecTests(cleanRest)
            "test-incremental" then return runIncrementalTests()
            default then printUsage()
        end 'cmd'
    end 'dispatch' else 'noArgs'
        printUsage()
    end 'noArgs'

    return 1
end 'main'

function printUsage()
    print("Usage: maxon <command> [options]\n")
    print("\n")
    print("Commands:\n")
    print("  build [<file|directory>] Build a project (default: current directory)\n")
    print("  run <file|directory>     Build and run\n")
    print("  spec-test [options]      Run spec tests\n")
    print("  test-incremental         Run incremental compilation tests\n")
    print("\n")
    print("Build options (build, run):\n")
    print("  --emit-ir                Write .mlir file\n")
    print("  --dump-stages            Write IR at each pipeline stage\n")
    print("  --track-allocs           Track heap allocations and print memory stats\n")
    print("\n")
    print("Spec test options:\n")
    print("  --filter=PATTERN         Run only tests matching pattern\n")
    print("  --target=<TRIPLE|all>    Cross-compile tests for target (e.g. x86_64-linux-gnu)\n")
    print("\n")
    print("Logging (all commands):\n")
    print("  --log=LEVEL              Set all log categories to LEVEL\n")
    print("  --log=CATEGORY:LEVEL     Set specific category to LEVEL\n")
    print("\n")
    print("Log levels: none, error, info, debug, trace\n")
    print("Log categories: compiler, lexer, parser, semantic, mlir, codegen, pe, testing\n")
end 'printUsage'

function runBuild(args StringArray) returns ExitCode
    var path = ""
    var target = detectHostTriple()

    // Parse args: positional path and --target= option
    for arg in args 'parseArgs'
        if arg.startsWith("--target=") 'isTarget'
            let eqIdx = try arg.findFirst("=") otherwise 'bad'
                continue
            end 'bad'
            let afterEq = try arg.indexAfter(eqIdx) otherwise 'bad2'
                continue
            end 'bad2'
            target = parseTargetTriple(arg.slice(afterEq, endIndex: arg.endIndex()))
        end 'isTarget' else 'notTarget'
            if not arg.startsWith("--") 'isPath'
                path = arg
            end 'isPath'
        end 'notTarget'
    end 'parseArgs'

    if path.isEmpty() 'noPath'
        path = Directory.currentDirectory()
    end 'noPath'

    let outputPath = try compile(path, target: target) otherwise 'err'
        return 1
    end 'err'

    print("Compiled -> {outputPath}\n")

    return 0
end 'runBuild'

function runSpecTests(args StringArray) returns ExitCode
    // Parse --filter= and --target= options
    var filter = ""
    var targetStr = ""
    for arg in args 'parseArgs'
        if arg.startsWith("--filter=") 'isFilter'
            let eqIdx = try arg.findFirst("=") otherwise 'bad'
                continue
            end 'bad'
            let afterEq = try arg.indexAfter(eqIdx) otherwise 'bad2'
                continue
            end 'bad2'
            filter = arg.slice(afterEq, endIndex: arg.endIndex())
        end 'isFilter' else if arg.startsWith("--target=") 'isTarget'
            let eqIdx = try arg.findFirst("=") otherwise 'bad3'
                continue
            end 'bad3'
            let afterEq = try arg.indexAfter(eqIdx) otherwise 'bad4'
                continue
            end 'bad4'
            targetStr = arg.slice(afterEq, endIndex: arg.endIndex())
        end 'isTarget'
    end 'parseArgs'

    if targetStr == "all" 'runAll'
        return runAllTargetTests(filter)
    end 'runAll'

    var target = detectHostTriple()
    if not targetStr.isEmpty() 'hasTarget'
        target = parseTargetTriple(targetStr)
    end 'hasTarget'

    logInfo(LogCategory.testing, message: "Running self-hosted spec tests ({tripleToString(target)})...")
    return runAllSpecTests(filter, target: target)
end 'runSpecTests'

function runAllTargetTests(filter String) returns ExitCode
    var totalFailed = 0

    let t1 = TargetTriple{cpu: CpuArch.x86_64, os: Os.windows, abi: Abi.msvc}
    logInfo(LogCategory.testing, message: "Testing target: {tripleToString(t1)}")
    let ec1 = runAllSpecTests(filter, target: t1)
    totalFailed = totalFailed + ec1

    let t2 = TargetTriple{cpu: CpuArch.x86_64, os: Os.linux, abi: Abi.gnu}
    logInfo(LogCategory.testing, message: "Testing target: {tripleToString(t2)}")
    let ec2 = runAllSpecTests(filter, target: t2)
    totalFailed = totalFailed + ec2

    let t3 = TargetTriple{cpu: CpuArch.aarch64, os: Os.linux, abi: Abi.gnu}
    logInfo(LogCategory.testing, message: "Testing target: {tripleToString(t3)}")
    let ec3 = runAllSpecTests(filter, target: t3)
    totalFailed = totalFailed + ec3

    let t4 = TargetTriple{cpu: CpuArch.aarch64, os: Os.windows, abi: Abi.msvc}
    logInfo(LogCategory.testing, message: "Testing target: {tripleToString(t4)}")
    let ec4 = runAllSpecTests(filter, target: t4)
    totalFailed = totalFailed + ec4

    if totalFailed > 0 'hasFail'
        return 1
    end 'hasFail'
    return 0
end 'runAllTargetTests'

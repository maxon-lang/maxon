<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>maxon</AssemblyName>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OmniSharp.Extensions.LanguageServer" Version="0.19.9" />
  </ItemGroup>

  <Target Name="PublishAfterBuild" AfterTargets="Build">
    <Exec Command="dotnet publish -c $(Configuration) --no-build" />
  </Target>

  <Target Name="CopyToBin" AfterTargets="Publish">
    <Exec
      Command="move /Y $(ProjectDir)..\bin\$(AssemblyName).exe $(ProjectDir)..\bin\$(AssemblyName).old.exe &gt;nul 2&gt;&amp;1 || exit /b 0" />
    <Copy SourceFiles="$(PublishDir)$(AssemblyName).exe" DestinationFolder="$(ProjectDir)..\bin" />
    <Exec Command="taskkill /F /IM maxon.exe &gt;nul 2&gt;&amp;1 || exit /b 0" />
    <Exec
      Command="del /F $(ProjectDir)..\bin\$(AssemblyName).old.exe &gt;nul 2&gt;&amp;1 || exit /b 0" />
  </Target>
</Project>
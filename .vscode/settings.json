{
  "C_Cpp.default.compilerPath": "C:/Program Files/LLVM/bin/clang.exe",
  "C_Cpp.files.exclude": {
    "**/llvm-source/**": true,
    "**/llvm-project/**": true
  },
  "search.exclude": {
    "**/build/**": true,
    "**/build-temp/**": true,
    "**/node_modules/**": true,
    "**/llvm-source/**": true,
    "**/llvm-project/**": true
  },
  "files.watcherExclude": {
    "**/build/**": true,
    "**/build-temp/**": true,
    "**/node_modules/**": true,
    "**/llvm-source/**": true,
    "**/llvm-project/**": true
  },
  "files.exclude": {
    "**/obj": true,
    "vscode-extension/.vscode-test": true,
    "vscode-extension/out": true
  },
  "files.associations": {
    "*.test": "maxon",
    "ostream": "cpp",
    "*.inc": "cpp",
    "cmath": "cpp",
    "numbers": "cpp",
    "bitset": "cpp"
  },
  "editor.formatOnSave": true,
  "giterdone.setupCommands": [
    "mklink /D llvm-project ..\\maxon\\llvm-project",
    "mklink /D llvm-source ..\\maxon\\llvm-source"
  ],
  "terminal.integrated.env.windows": {
    "PATH": "${workspaceFolder}\\bin;${env:PATH}"
  },
  "terminal.integrated.env.linux": {
    "PATH": "${workspaceFolder}/bin:${env:PATH}"
  }
}
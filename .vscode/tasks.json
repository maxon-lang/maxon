{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "bundle"
      ],
      "options": {
        "cwd": "${workspaceFolder}/vscode-extension"
      },
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode-extension",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "path": "vscode-extension",
      "problemMatcher": "$tsc",
      "isBackground": false,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "test",
      "path": "vscode-extension",
      "problemMatcher": [],
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Build hello-world.maxon",
      "type": "shell",
      "command": "maxon.exe",
      "args": [
        "build",
        "examples/hello-world.maxon",
        "-g"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "C# Spec Tests",
      "type": "shell",
      "command": "./maxon-sharp/bin/Debug/net8.0/win-x64/maxon.exe",
      "args": ["spec-test"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Self-Hosted Spec Tests",
      "type": "shell",
      "command": "./maxon-selfhosted/bin/maxon-selfhosted.exe",
      "args": ["spec-test"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Self-Hosted Spec Tests (All Targets)",
      "type": "shell",
      "command": "./maxon-selfhosted/bin/maxon-selfhosted.exe",
      "args": ["spec-test", "--target=all"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build C# Compiler",
      "type": "shell",
      "command": "dotnet",
      "args": ["build"],
      "options": {
        "cwd": "${workspaceFolder}/maxon-sharp"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build Self-Hosted Compiler",
      "type": "shell",
      "command": "./maxon-sharp/bin/Debug/net8.0/win-x64/maxon.exe",
      "args": ["build", "maxon-selfhosted"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}

{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode-extension",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "path": "vscode-extension",
      "problemMatcher": "$tsc",
      "isBackground": false,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "test",
      "path": "vscode-extension",
      "problemMatcher": [],
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Compile hello-world.maxon",
      "type": "shell",
      "command": "${workspaceFolder}/build/bin/maxon.exe",
      "args": [
        "compile",
        "${workspaceFolder}/examples/hello-world.maxon",
        "-g",
        "-o",
        "${workspaceFolder}/examples/hello-world.exe"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    }
  ]
}

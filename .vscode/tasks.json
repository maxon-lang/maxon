{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Initial Build",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "if [ ! -f bin/maxon.exe ] && [ ! -f bin/maxon ]; then echo 'Project not built, running make all...'; make all; else echo 'Project already built.'; fi"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode-extension",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "compile",
      "path": "vscode-extension",
      "problemMatcher": "$tsc",
      "isBackground": false,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "type": "npm",
      "script": "test",
      "path": "vscode-extension",
      "problemMatcher": [],
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Compile hello-world.maxon",
      "type": "shell",
      "command": "maxon.exe",
      "args": [
        "compile",
        "examples/hello-world.maxon",
        "-g"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$gcc"
    }
  ]
}

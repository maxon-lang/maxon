/// Compiler-internal symbols. This file is the only stdlib module allowed to
/// declare names with the reserved `__` prefix (E2051). Everything here is the
/// type-system bridge to compiler intrinsics: error enums thrown by builtin
/// runtime operations, marker interfaces the compiler scans for to resolve
/// literal syntax, and parsing helpers the compiler invokes when rewriting
/// `int.fromString(...)` / `float.fromString(...)` / etc.
/// @category Core

// BuiltinStringLiteral - default type for string literals when no explicit type requested.
// The compiler searches for the type implementing this interface when encountering "..."
// Only one type should implement this interface (typically String).
export interface BuiltinStringLiteral
	static function init(value __ManagedMemory) returns Self
end 'BuiltinStringLiteral'

// BuiltinCharLiteral - default type for character literals when no explicit type requested.
// The compiler searches for the type implementing this interface when encountering '...'
// Only one type should implement this interface (typically Character).
export interface BuiltinCharLiteral
	static function init(value __ManagedMemory) returns Self
end 'BuiltinCharLiteral'

// BuiltinArrayLiteral - default type for array literals when no explicit type requested.
// The compiler searches for the type implementing this interface when encountering [...]
// Only one type should implement this interface (typically Array).
export interface BuiltinArrayLiteral
	static function init(value __ManagedMemory) returns Self
end 'BuiltinArrayLiteral'

// BuiltinDictionaryLiteral - default type for map literals when no explicit type requested.
// The compiler searches for the type implementing this interface when encountering ["key": value, ...]
// Only one type should implement this interface (typically Map).
export interface BuiltinDictionaryLiteral
	static function init(keys __ManagedMemory, values __ManagedMemory) returns Self
end 'BuiltinDictionaryLiteral'

// InitableFromStringLiteral - types that can be initialized from string literals.
// The compiler creates a String from the literal and passes it to init().
// Follows the Swift ExpressibleByStringLiteral pattern.
// Example: var x MyType = "hello" -> var x = MyType.init(String from literal)
export interface InitableFromStringLiteral
	static function init(value String) returns Self
end 'InitableFromStringLiteral'

// InitableFromCharLiteral - types that can be initialized from character literals.
// Similar to InitableFromStringLiteral but for single-character literals like 'A' or '🎉'.
// The compiler creates a Character from the literal and passes it to init().
export interface InitableFromCharLiteral
	static function init(value Character) returns Self
end 'InitableFromCharLiteral'

// InitableFromArrayLiteral - types that can be initialized from array literals.
// The compiler creates an Array from the literal and passes it to init().
// Follows the Swift ExpressibleByArrayLiteral pattern.
// Note: Array itself is special-cased by the compiler (uses __ManagedMemory directly).
export interface InitableFromArrayLiteral uses Element
	typealias ElementArray = Array with Element
	static function init(value ElementArray) returns Self
end 'InitableFromArrayLiteral'

// InitableFromDictionaryLiteral - types that can be initialized from map literals.
// Map literals use syntax: ["key1": value1, "key2": value2]
// The compiler creates two Arrays (keys and values) and passes them to init().
// Both arrays have the same length and corresponding indices represent key-value pairs.
// Note: Map itself is special-cased by the compiler (uses __ManagedMemory directly).
export interface InitableFromDictionaryLiteral uses Key, Value
	typealias KeyArray = Array with Key
	typealias ValueArray = Array with Value
	static function init(keys KeyArray, values ValueArray) returns Self
end 'InitableFromDictionaryLiteral'

// Parsable - types that can be initialized from a string representation.
export interface Parsable
	static function fromString(input String) returns Self throws Error
end 'Parsable'

// ParseError - errors for string-to-value parsing operations
export enum ParseError implements Error
	invalidFormat
end 'ParseError'

// CursorError - errors for cursor navigation (companion to __ManagedMemoryCursor).
export enum CursorError implements Error
	exhausted
	atStart
end 'CursorError'

// __ManagedListError - errors for managed list operations
export enum __ManagedListError implements Error
	empty
	endOfList
	nodeNotInList       // insertAfter/Before, detach, remove where node does not belong to self
	nodeAlreadyInList   // reinsert* where node is still attached
end '__ManagedListError'

// __ManagedMemoryError - errors for __ManagedMemory builtin operations
export enum __ManagedMemoryError implements Error
	indexOutOfBounds    // get, set, remove, byteAt, setByte with bad index
	emptySlot           // get on a slot that was never filled (e.g. after resize() of struct array)
	sliceOutOfBounds    // slice(start, end) with start > end, end > length, or start > length
	invalidLength       // setLength with newLength < 0 or > capacity
	invalidCapacity     // grow with newCapacity < current capacity
	shiftOutOfBounds    // shiftLeft/shiftRight params out of bounds
	invalidByteRange    // makeCharFromBytes with pos + len > byteLength
	invalidAllocation   // static create with count < 0 or elementSize <= 0
end '__ManagedMemoryError'

// __ManagedSocketError - errors for __ManagedSocket builtin operations
export enum __ManagedSocketError implements Error
	bufferOutOfBounds   // sendFrom offset+length > capacity
	resolveFailed       // DNS resolution failed
	connectFailed       // TCP connect refused/timeout
	sendFailed          // send() returned error
	recvFailed          // recv() returned error
	connectionClosed    // peer closed mid-transfer
	closed              // operation on already-closed socket
end '__ManagedSocketError'

// __ManagedFileError - errors for __ManagedFile builtin operations
export enum __ManagedFileError implements Error
	notFound            // path does not exist
	accessDenied        // permission error
	openFailed          // other open errors (invalid path, IO, etc.)
	readFailed          // read() error
	writeFailed         // write() error
	sizeFailed          // stat/seek for size failed
	deleteFailed        // unlink/DeleteFile failed
	statFailed          // stat() failed
	invalidStatBuffer   // statField/statFree with bad buffer
	invalidStatIndex    // statField with out-of-range index
	closed              // operation on already-closed file
end '__ManagedFileError'

// __ManagedDirectoryError - errors for __ManagedDirectory builtin operations
export enum __ManagedDirectoryError implements Error
	notFound
	accessDenied
	openSearchFailed
	nextFailed
	iteratorInvalid     // filename() on exhausted iterator
	createFailed
	currentPathFailed
	closed
end '__ManagedDirectoryError'

// Wide-signed integer used as the return type of __int_fromString /
// __byte_fromString and propagated through user-facing parse APIs.
typealias ParsedInt = int(i64.min to i64.max)

export function __int_fromString(input String) returns ParsedInt throws ParseError
	var result = 0
	var negative = false
	var hasDigits = false

	for cp in input.codepoints() 'chars'
		if cp == '-' 'minus'
			if hasDigits 'minus_after_digits'
				throw ParseError.invalidFormat
			end 'minus_after_digits'
			negative = true
		end 'minus' else 'not_minus'
			if cp >= '0' 'maybe_digit'
				if cp <= '9' 'is_digit'
					hasDigits = true
					result = result * 10 + (cp - '0')
				end 'is_digit' else 'not_digit'
					throw ParseError.invalidFormat
				end 'not_digit'
			end 'maybe_digit' else 'below_zero'
				throw ParseError.invalidFormat
			end 'below_zero'
		end 'not_minus'
	end 'chars'

	if not hasDigits 'empty'
		throw ParseError.invalidFormat
	end 'empty'

	if negative 'negate'
		result = 0 - result
	end 'negate'

	return result
end '__int_fromString'

typealias ParsedFloat = float(f64.min to f64.max)

export function __float_fromString(input String) returns ParsedFloat throws ParseError
	var intPart = 0
	var fracPart = 0.0
	var fracDiv = 1.0
	var pastDot = false
	var negative = false
	var hasDigits = false

	for cp in input.codepoints() 'chars'
		if cp == '.' 'dot'
			if pastDot 'double_dot'
				throw ParseError.invalidFormat
			end 'double_dot'
			pastDot = true
		end 'dot' else 'not_dot'
			if cp == '-' 'minus'
				if hasDigits 'minus_after_digits'
					throw ParseError.invalidFormat
				end 'minus_after_digits'
				if pastDot 'minus_after_dot'
					throw ParseError.invalidFormat
				end 'minus_after_dot'
				negative = true
			end 'minus' else 'not_minus'
				if cp >= '0' 'maybe_digit'
					if cp <= '9' 'is_digit'
						hasDigits = true
						let digit = cp - '0'
						if pastDot 'after_dot'
							fracDiv = fracDiv * 10.0
							fracPart = fracPart + (digit as float) / fracDiv
						end 'after_dot' else 'before_dot'
							intPart = intPart * 10 + digit
						end 'before_dot'
					end 'is_digit' else 'not_digit'
						throw ParseError.invalidFormat
					end 'not_digit'
				end 'maybe_digit' else 'below_zero'
					throw ParseError.invalidFormat
				end 'below_zero'
			end 'not_minus'
		end 'not_dot'
	end 'chars'

	if not hasDigits 'empty'
		throw ParseError.invalidFormat
	end 'empty'

	var result = (intPart as float) + fracPart
	if negative 'negate'
		result = 0.0 - result
	end 'negate'

	return result
end '__float_fromString'

export function __bool_fromString(input String) returns bool throws ParseError
	if input == "true" 'is_true'
		return true
	end 'is_true'
	if input == "false" 'is_false'
		return false
	end 'is_false'
	throw ParseError.invalidFormat
end '__bool_fromString'

export function __byte_fromString(input String) returns ParsedInt throws ParseError
	let result = try __int_fromString(input) otherwise 'err'
		throw ParseError.invalidFormat
	end 'err'

	if result < 0 'too_low'
		throw ParseError.invalidFormat
	end 'too_low'

	if result > 255 'too_high'
		throw ParseError.invalidFormat
	end 'too_high'

	return result
end '__byte_fromString'

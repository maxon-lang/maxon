// Lazy enumerated iterator — wraps any Iterator and yields (Index, Element) tuples.
// Used by the enumerated() extension method on Iterable.

export type EnumeratedIterator uses Source, Element implements Iterator with (Index, Element) where Source is Iterator
	var source Source
	var index Index

	export static function create(source Source) returns Self
		return Self{source: source, index: 0}
	end 'create'

	export function next() returns(Index, Element) throws IterationError
		let element = try source.next()
		let idx = index
		index = index + 1
		return(idx, element)
	end 'next'
end 'EnumeratedIterator'

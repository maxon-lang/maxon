// Lazy enumerated iterator — wraps any Iterable and yields (Index, Element) tuples.
// Used by the enumerated() extension method on Iterable.

export type EnumeratedIterator uses Source, Element implements Iterable with(Index, Element) where Source is Iterable
  var source Source
  var _index Index

  export function createIterator()
    source.createIterator()
    _index = 0
  end 'createIterator'

  export function next() returns(Index, Element) throws IterationError
    var element = try source.next()
    var idx = _index
    _index = _index + 1
    return(idx, element)
  end 'next'
end 'EnumeratedIterator'

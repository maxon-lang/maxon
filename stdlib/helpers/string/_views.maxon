// String iteration views for byte, codepoint, and UTF-16 access

// ============================================
// ByteView - iterate over raw UTF-8 bytes
// ============================================

export type ByteView implements Iterable with Byte
  var _managed __ManagedMemory
  var _pos Index

  export function createIterator()
    _pos = 0
  end 'createIterator'

  export function next() returns Byte throws IterationError
    if _pos >= _managed.length() 'at_end'
      throw IterationError.exhausted
    end 'at_end'
    var b = _managed.byteAt(_pos)
    _pos = _pos + 1
    return b
  end 'next'

  /// Get the number of bytes
  export function count() returns Count
    return _managed.length()
  end 'count'
end 'ByteView'

// ============================================
// CodepointView - iterate over Unicode codepoints
// ============================================

export type CodepointView implements Iterable with Codepoint
  var _managed __ManagedMemory
  var _pos Index

  export function createIterator()
    _pos = 0
  end 'createIterator'

  export function next() returns Codepoint throws IterationError
    if _pos >= _managed.length() 'at_end'
      throw IterationError.exhausted
    end 'at_end'
    var cp = utf8DecodeAt(_managed, pos: _pos)
    var len = utf8ByteLengthAt(_managed, pos: _pos)
    _pos = _pos + len
    return cp
  end 'next'

  /// Get the number of codepoints
  export function count() returns Count
    var count = 0
    var pos = 0
    var len = _managed.length()
    while pos < len 'count_loop'
      var bytes = utf8ByteLengthAt(_managed, pos: pos)
      pos = pos + bytes
      count = count + 1
    end 'count_loop'
    return count
  end 'count'
end 'CodepointView'

// ============================================
// UTF16View - iterate over UTF-16 code units
// ============================================

export type UTF16View implements Iterable with CodeUnit16
  var _managed __ManagedMemory
  var _bytePos Index
  var _pendingCodepoint Codepoint  // Codepoint pending its low surrogate (0 if none)

  export function createIterator()
    _bytePos = 0
    _pendingCodepoint = 0
  end 'createIterator'

  export function next() returns CodeUnit16 throws IterationError
    // If we have a pending codepoint, return its low surrogate
    if _pendingCodepoint != 0 'has_pending'
      var low = utf16TrailSurrogate(_pendingCodepoint)
      _pendingCodepoint = 0
      return low
    end 'has_pending'

    if _bytePos >= _managed.length() 'at_end'
      throw IterationError.exhausted
    end 'at_end'

    var cp = utf8DecodeAt(_managed, pos: _bytePos)
    var len = utf8ByteLengthAt(_managed, pos: _bytePos)
    _bytePos = _bytePos + len

    // BMP codepoint (single code unit)
    if cp < 65536 'bmp'
      return cp
    end 'bmp'

    // Supplementary codepoint (surrogate pair)
    // Store the codepoint so we can return the low surrogate next iteration
    _pendingCodepoint = cp
    return utf16LeadSurrogate(cp)
  end 'next'

  /// Get the number of UTF-16 code units
  export function count() returns Count
    var count = 0
    var pos = 0
    var len = _managed.length()
    while pos < len 'count_loop'
      var cp = utf8DecodeAt(_managed, pos: pos)
      var bytes = utf8ByteLengthAt(_managed, pos: pos)
      pos = pos + bytes
      if cp < 65536 'bmp'
        count = count + 1
      end 'bmp' else 'supplementary'
        count = count + 2
      end 'supplementary'
    end 'count_loop'
    return count
  end 'count'
end 'UTF16View'

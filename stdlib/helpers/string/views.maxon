// String iteration views for byte, codepoint, and UTF-16 access.
//
// Each view implements Iterable (factory): view.createIterator() returns a
// fresh Iterator positioned at the first element (or throws on empty).
// The view itself is cheap to construct — creating a view does not throw.
// All iterators maintain the Iterator invariant: current() is infallible;
// advance() throws IterationError.exhausted at end.

typealias ByteCount = int(0 to u64.max)
typealias CodepointCount = int(0 to u64.max)
typealias Utf16UnitCount = int(0 to u64.max)
typealias Utf8ByteWidth = int(1 to 4)
typealias BytePos = int(0 to u64.max)

// ============================================
// ByteView / ByteIterator — iterate over raw UTF-8 bytes
// ============================================

export type ByteView implements Iterable with(Byte, ByteIterator)
	var managed __ManagedMemory

	export static function create(managed __ManagedMemory) returns ByteView
		return ByteView{managed: managed}
	end 'create'

	export function createIterator() returns ByteIterator throws IterationError
		return try ByteIterator.create(managed: managed)
	end 'createIterator'

	/// Number of bytes
	export function count() returns ByteCount
		return managed.length()
	end 'count'
end 'ByteView'

export type ByteIterator implements Iterator with Byte
	var managed __ManagedMemory
	var pos BytePos
	var currentByte Byte

	export static function create(managed __ManagedMemory) returns Self throws IterationError
		if managed.length() == 0 'empty'
			throw IterationError.exhausted
		end 'empty'
		let firstByte = try managed.byteAt(0) otherwise 'byteErr'
			panic("ByteIterator.create: managed empty after length check — impossible")
		end 'byteErr'
		return Self{managed: managed, pos: 0, currentByte: firstByte}
	end 'create'

	export function current() returns Byte
		return currentByte
	end 'current'

	export function advance() throws IterationError
		let nextPos = pos + 1
		if nextPos >= managed.length() 'done'
			throw IterationError.exhausted
		end 'done'
		pos = nextPos
		currentByte = try managed.byteAt(pos) otherwise 'byteErr'
			panic("ByteIterator.advance: nextPos just validated as < length — impossible")
		end 'byteErr'
	end 'advance'
end 'ByteIterator'

// ============================================
// CodepointView / CodepointIterator — iterate over Unicode codepoints
// ============================================

export type CodepointView implements Iterable with(Codepoint, CodepointIterator)
	var managed __ManagedMemory

	export static function create(managed __ManagedMemory) returns CodepointView
		return CodepointView{managed: managed}
	end 'create'

	export function createIterator() returns CodepointIterator throws IterationError
		return try CodepointIterator.create(managed: managed)
	end 'createIterator'

	/// Number of codepoints (linear scan)
	export function count() returns CodepointCount
		var count = 0
		var pos = 0
		let len = managed.length()
		while pos < len 'count_loop'
			let bytes = utf8ByteLengthAt(managed, pos: pos)
			pos = pos + bytes
			count = count + 1
		end 'count_loop'
		return count
	end 'count'
end 'CodepointView'

export type CodepointIterator implements Iterator with Codepoint
	var managed __ManagedMemory
	var pos BytePos
	var cp Codepoint
	var cpByteLen Utf8ByteWidth

	export static function create(managed __ManagedMemory) returns Self throws IterationError
		if managed.length() == 0 'empty'
			throw IterationError.exhausted
		end 'empty'
		let cp = utf8DecodeAt(managed, pos: 0)
		let len = utf8ByteLengthAt(managed, pos: 0)
		return Self{managed: managed, pos: 0, cp: cp, cpByteLen: len}
	end 'create'

	export function current() returns Codepoint
		return cp
	end 'current'

	export function advance() throws IterationError
		let nextPos = pos + cpByteLen
		if nextPos >= managed.length() 'done'
			throw IterationError.exhausted
		end 'done'
		pos = nextPos
		cp = utf8DecodeAt(managed, pos: pos)
		cpByteLen = utf8ByteLengthAt(managed, pos: pos)
	end 'advance'
end 'CodepointIterator'

// ============================================
// UTF16View / UTF16Iterator — iterate over UTF-16 code units
// ============================================
// Supplementary codepoints (cp >= 0x10000) require two UTF-16 code units:
// a lead surrogate followed by a trail surrogate. The iterator tracks a
// two-state position:
//   onTrailSurrogate = false → current() returns the BMP cp or the lead surrogate
//   onTrailSurrogate = true  → current() returns the trail surrogate of the pending supplementary

export type UTF16View implements Iterable with(CodeUnit16, UTF16Iterator)
	var managed __ManagedMemory

	export static function create(managed __ManagedMemory) returns UTF16View
		return UTF16View{managed: managed}
	end 'create'

	export function createIterator() returns UTF16Iterator throws IterationError
		return try UTF16Iterator.create(managed: managed)
	end 'createIterator'

	/// Number of UTF-16 code units (linear scan)
	export function count() returns Utf16UnitCount
		var count = 0
		var pos = 0
		let len = managed.length()
		while pos < len 'count_loop'
			let cp = utf8DecodeAt(managed, pos: pos)
			let bytes = utf8ByteLengthAt(managed, pos: pos)
			pos = pos + bytes
			if cp < 65536 'bmp'
				count = count + 1
			end 'bmp' else 'supplementary'
				count = count + 2
			end 'supplementary'
		end 'count_loop'
		return count
	end 'count'
end 'UTF16View'

export type UTF16Iterator implements Iterator with CodeUnit16
	var managed __ManagedMemory
	var bytePos BytePos
	var cp Codepoint
	var cpByteLen Utf8ByteWidth
	var onTrailSurrogate bool

	export static function create(managed __ManagedMemory) returns Self throws IterationError
		if managed.length() == 0 'empty'
			throw IterationError.exhausted
		end 'empty'
		let cp = utf8DecodeAt(managed, pos: 0)
		let len = utf8ByteLengthAt(managed, pos: 0)
		return Self{managed: managed, bytePos: 0, cp: cp, cpByteLen: len, onTrailSurrogate: false}
	end 'create'

	export function current() returns CodeUnit16
		if onTrailSurrogate 'trail'
			return utf16TrailSurrogate(cp)
		end 'trail'
		if cp < 65536 'bmp'
			return cp
		end 'bmp'
		return utf16LeadSurrogate(cp)
	end 'current'

	export function advance() throws IterationError
		if not onTrailSurrogate and cp >= 65536 'emitTrail'
			onTrailSurrogate = true
			return
		end 'emitTrail'
		let nextPos = bytePos + cpByteLen
		if nextPos >= managed.length() 'done'
			throw IterationError.exhausted
		end 'done'
		bytePos = nextPos
		cp = utf8DecodeAt(managed, pos: bytePos)
		cpByteLen = utf8ByteLengthAt(managed, pos: bytePos)
		onTrailSurrogate = false
	end 'advance'
end 'UTF16Iterator'

// String iteration views for byte, codepoint, and UTF-16 access

// ============================================
// ByteView - iterate over raw UTF-8 bytes
// ============================================

export type ByteView implements Iterator with Byte
	var managed __ManagedMemory
	var pos Index

	export static function create(managed __ManagedMemory) returns ByteView
		return ByteView{managed: managed, pos: 0}
	end 'create'

	export function next() returns Byte throws IterationError
		if pos >= managed.length() 'at_end'
			throw IterationError.exhausted
		end 'at_end'
		let b = managed.byteAt(pos)
		pos = pos + 1
		return b
	end 'next'

	/// Get the number of bytes
	export function count() returns Count
		return managed.length()
	end 'count'
end 'ByteView'

// ============================================
// CodepointView - iterate over Unicode codepoints
// ============================================

export type CodepointView implements Iterator with Codepoint
	var managed __ManagedMemory
	var pos Index

	export static function create(managed __ManagedMemory) returns CodepointView
		return CodepointView{managed: managed, pos: 0}
	end 'create'

	export function next() returns Codepoint throws IterationError
		if pos >= managed.length() 'at_end'
			throw IterationError.exhausted
		end 'at_end'
		let cp = utf8DecodeAt(managed, pos: pos)
		let len = utf8ByteLengthAt(managed, pos: pos)
		pos = pos + len
		return cp
	end 'next'

	/// Get the number of codepoints
	export function count() returns Count
		var count = 0
		var pos = 0
		let len = managed.length()
		while pos < len 'count_loop'
			let bytes = utf8ByteLengthAt(managed, pos: pos)
			pos = pos + bytes
			count = count + 1
		end 'count_loop'
		return count
	end 'count'
end 'CodepointView'

// ============================================
// UTF16View - iterate over UTF-16 code units
// ============================================

export type UTF16View implements Iterator with CodeUnit16
	var managed __ManagedMemory
	var bytePos Index
	var pendingCodepoint Codepoint  // Codepoint pending its low surrogate (0 if none)

	export static function create(managed __ManagedMemory) returns UTF16View
		return UTF16View{managed: managed, bytePos: 0, pendingCodepoint: 0}
	end 'create'

	export function next() returns CodeUnit16 throws IterationError
		// If we have a pending codepoint, return its low surrogate
		if pendingCodepoint != 0 'has_pending'
			let low = utf16TrailSurrogate(pendingCodepoint)
			pendingCodepoint = 0
			return low
		end 'has_pending'

		if bytePos >= managed.length() 'at_end'
			throw IterationError.exhausted
		end 'at_end'

		let cp = utf8DecodeAt(managed, pos: bytePos)
		let len = utf8ByteLengthAt(managed, pos: bytePos)
		bytePos = bytePos + len

		// BMP codepoint (single code unit)
		if cp < 65536 'bmp'
			return cp
		end 'bmp'

		// Supplementary codepoint (surrogate pair)
		// Store the codepoint so we can return the low surrogate next iteration
		pendingCodepoint = cp
		return utf16LeadSurrogate(cp)
	end 'next'

	/// Get the number of UTF-16 code units
	export function count() returns Count
		var count = 0
		var pos = 0
		let len = managed.length()
		while pos < len 'count_loop'
			let cp = utf8DecodeAt(managed, pos: pos)
			let bytes = utf8ByteLengthAt(managed, pos: pos)
			pos = pos + bytes
			if cp < 65536 'bmp'
				count = count + 1
			end 'bmp' else 'supplementary'
				count = count + 2
			end 'supplementary'
		end 'count_loop'
		return count
	end 'count'
end 'UTF16View'

// Internal grapheme cluster helpers for string types
//
// Purpose: Centralize grapheme cluster operations (UAX #29 algorithm) for string types.

typealias BreakProperty = int(0 to 13)

// ============================================
// Find grapheme end helpers (UAX #29)
// ============================================

// findGraphemeEndManagedRange - Find end of grapheme cluster in range
export function findGraphemeEndManagedRange(managed __ManagedMemory, offset Index, startPos Index, len Count) returns Index
	if startPos >= len 'atEnd'
		return startPos
	end 'atEnd'

	// Fast path: ASCII bytes (< 0x80) are single-byte codepoints.
	// However, a combining mark (Extend/ZWJ/SpacingMark) may follow an ASCII base,
	// e.g. "e\u0301" (e + combining acute). Check the next byte before returning.
	// CR may combine with LF per UAX #29 GB3.
	let firstByte = managed.byteAt(offset + startPos)
	if firstByte < 128 'isAscii'
		if firstByte == 13 'isCR'
			if startPos + 1 < len 'hasNext'
				let nextByte = managed.byteAt(offset + startPos + 1)
				if nextByte == 10 'isCRLF'
					return startPos + 2
				end 'isCRLF'
			end 'hasNext'
		end 'isCR'
		// Check if a non-ASCII byte follows that could be a combining mark
		if startPos + 1 < len 'hasNextByte'
			let nextByte = managed.byteAt(offset + startPos + 1)
			if nextByte >= 128 'nextIsMultibyte'
				// Decode the next codepoint and check if it's Extend, ZWJ, or SpacingMark
				var nextCp = utf8DecodeAt(managed, pos: offset + startPos + 1)
				var nextGbp = graphemeBreakProperty(nextCp)
				// GB9: don't break before Extend(4) or ZWJ(5); GB9a: don't break before SpacingMark(8)
				if nextGbp == 4 or nextGbp == 5 or nextGbp == 8 'isCombining'
					// Fall through to the full algorithm below
				end 'isCombining' else 'notCombining'
					return startPos + 1
				end 'notCombining'
			end 'nextIsMultibyte' else 'nextIsAscii'
				return startPos + 1
			end 'nextIsAscii'
		end 'hasNextByte' else 'atStringEnd'
			return startPos + 1
		end 'atStringEnd'
	end 'isAscii'

	// Decode first codepoint at startPos (with offset)
	var pos = startPos
	var absPos = offset + pos
	var prevCp = utf8DecodeAt(managed, pos: absPos)
	var prevBytes = utf8ByteLengthAt(managed, pos: absPos)
	pos = pos + prevBytes

	// Get grapheme break property for first codepoint
	var prevGbp = graphemeBreakProperty(prevCp)
	var state = graphemeStateInit()
	state = graphemeStateUpdate(state, gbp: prevGbp, cp: prevCp)

	// Scan forward until we find a grapheme break
	while pos < len 'scan'
		absPos = offset + pos
		var currCp = utf8DecodeAt(managed, pos: absPos)
		var currGbp = graphemeBreakProperty(currCp)

		// Check if there's a break before current codepoint
		if isGraphemeBreak(prevGbp, currGbp: currGbp, currCp: currCp, state: state) 'breakFound'
			return pos
		end 'breakFound'

		// Update state and advance to next codepoint
		state = graphemeStateUpdate(state, gbp: currGbp, cp: currCp)
		prevGbp = currGbp
		prevCp = currCp
		var currBytes = utf8ByteLengthAt(managed, pos: absPos)
		pos = pos + currBytes
	end 'scan'

	return pos
end 'findGraphemeEndManagedRange'

// ============================================
// Find grapheme start helpers (backward scanning, UAX #29)
// ============================================

// findPrevCodepointStart - Find the start byte position of the codepoint before pos.
// Walks backward skipping UTF-8 continuation bytes (10xxxxxx).
function findPrevCodepointStart(managed __ManagedMemory, offset Index, pos Index) returns Index
	var p = pos - 1
	while p > 0 and utf8IsContinuation(managed.byteAt(offset + p)) 'back'
		p = p - 1
	end 'back'
	return p
end 'findPrevCodepointStart'

// findGraphemeStartManaged - Find the start of the grapheme cluster ending at beforePos.
// Scans backward from beforePos applying UAX #29 rules in reverse.
// Returns the byte position where the grapheme cluster begins.
export function findGraphemeStartManaged(managed __ManagedMemory, offset Index, beforePos Index) returns Index
	if beforePos <= 0 'atStart'
		return 0
	end 'atStart'

	// Step back one codepoint to get the last codepoint of this grapheme
	var pos = findPrevCodepointStart(managed, offset: offset, pos: beforePos)
	var cp = utf8DecodeAt(managed, pos: offset + pos)
	var gbp = graphemeBreakProperty(cp)

	// The simple case: if this codepoint is Control/CR/LF, the grapheme is just this codepoint
	// GB4/GB5: break around Control/CR/LF
	if gbp == 3 or gbp == 1 or gbp == 2 'control_stop'
		// Special case GB3: CR+LF is a single grapheme
		if gbp == 2 and pos > 0 'check_crlf'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			if prevCp == 13 'is_crlf'
				return prevPos
			end 'is_crlf'
		end 'check_crlf'
		return pos
	end 'control_stop'

	// GB9: Extend(4) and ZWJ(5) don't break from what precedes them
	// GB9a: SpacingMark(8) doesn't break from what precedes it
	// Keep stepping backward through these combining characters
	while pos > 0 and (gbp == 4 or gbp == 5 or gbp == 8) 'extend_back'
		var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
		var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
		var prevGbp = graphemeBreakProperty(prevCp)

		// GB4: break after Control/CR/LF - the Extend attaches to nothing before
		if prevGbp == 3 or prevGbp == 1 or prevGbp == 2 'control_before_extend'
			return pos
		end 'control_before_extend'

		// GB11: Extended_Pictographic Extend* ZWJ x Extended_Pictographic
		// We are scanning backward through Extend/ZWJ. If we find an Extended_Pictographic,
		// check if it is part of an emoji ZWJ sequence by looking at what follows pos.
		// The forward-facing check is: if the current trailing part (from pos to beforePos)
		// starts with ZWJ followed by Extended_Pictographic, and we just found an
		// Extended_Pictographic with possible Extend* before the ZWJ.
		// But since we're accumulating backward, we handle this by just continuing
		// to absorb the Extended_Pictographic as the base character.

		pos = prevPos
		cp = prevCp
		gbp = prevGbp
	end 'extend_back'

	// Now pos points to the "base" character. Handle special base types.

	// GB11: If we arrived at an Extended_Pictographic that might be part of an emoji ZWJ sequence,
	// check if there's a ZWJ+Extend*+Extended_Pictographic before it.
	if isExtendedPictographic(cp) and pos > 0 'check_emoji_zwj'
		// Look backward for ZWJ (possibly preceded by Extend*)
		var scanPos = pos
		var prevPos = findPrevCodepointStart(managed, offset: offset, pos: scanPos)
		var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
		var prevGbp = graphemeBreakProperty(prevCp)

		// Skip Extend characters before ZWJ
		while prevGbp == 4 and prevPos > 0 'skip_extend_before_zwj'
			prevPos = findPrevCodepointStart(managed, offset: offset, pos: prevPos)
			prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			prevGbp = graphemeBreakProperty(prevCp)
		end 'skip_extend_before_zwj'

		if prevGbp == 5 and prevPos > 0 'found_zwj'
			// Found ZWJ, now check if Extended_Pictographic precedes it
			var epPos = findPrevCodepointStart(managed, offset: offset, pos: prevPos)
			var epCp = utf8DecodeAt(managed, pos: offset + epPos)
			if isExtendedPictographic(epCp) 'found_emoji_base'
				// This is an emoji ZWJ sequence - recurse to find the full start
				return findGraphemeStartManaged(managed, offset: offset, beforePos: pos)
			end 'found_emoji_base'
		end 'found_zwj'
	end 'check_emoji_zwj'

	// GB9b: Prepend x (don't break after Prepend)
	if pos > 0 and gbp != 3 and gbp != 1 and gbp != 2 'check_prepend'
		var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
		var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
		var prevGbp = graphemeBreakProperty(prevCp)
		if prevGbp == 7 'is_prepend'
			pos = prevPos
		end 'is_prepend'
	end 'check_prepend'

	// GB6-8: Hangul syllable sequences
	if gbp == 11 'hangul_t'
		// T can be preceded by T, LVT, LV, or V
		while pos > 0 'hangul_t_back'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			var prevGbp = graphemeBreakProperty(prevCp)
			if prevGbp == 11 'more_t'
				pos = prevPos
			end 'more_t' else 'not_t'
				if prevGbp == 13 or prevGbp == 12 'lvt_or_lv'
					pos = prevPos
					gbp = prevGbp
					break
				end 'lvt_or_lv' else 'not_hangul_before_t'
					if prevGbp == 10 'v_before_t'
						pos = prevPos
						gbp = prevGbp
					end 'v_before_t'
					break
				end 'not_hangul_before_t'
			end 'not_t'
		end 'hangul_t_back'
	end 'hangul_t'

	if gbp == 10 or gbp == 12 'hangul_v_lv'
		// V or LV can be preceded by V or L; LV can be preceded by L
		while pos > 0 'hangul_v_back'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			var prevGbp = graphemeBreakProperty(prevCp)
			if prevGbp == 10 and gbp == 10 'more_v'
				pos = prevPos
			end 'more_v' else 'not_v'
				if prevGbp == 9 'l_before_v'
					pos = prevPos
					break
				end 'l_before_v'
				break
			end 'not_v'
		end 'hangul_v_back'
	end 'hangul_v_lv'

	if gbp == 13 'hangul_lvt'
		// LVT can be preceded by L
		if pos > 0 'check_l_before_lvt'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			var prevGbp = graphemeBreakProperty(prevCp)
			if prevGbp == 9 'l_before_lvt'
				pos = prevPos
			end 'l_before_lvt'
		end 'check_l_before_lvt'
	end 'hangul_lvt'

	if gbp == 9 'hangul_l'
		// L can be preceded by more L
		while pos > 0 'hangul_l_back'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: pos)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			var prevGbp = graphemeBreakProperty(prevCp)
			if prevGbp == 9 'more_l'
				pos = prevPos
			end 'more_l' else 'not_l'
				break
			end 'not_l'
		end 'hangul_l_back'
	end 'hangul_l'

	// GB12-13: Regional Indicators pair up from the start of the run.
	// Walk backward to find the start of the RI run, count total RIs.
	// If even count, break at pairs; if odd, the first RI is unpaired.
	if gbp == 6 'ri_check'
		var riStart = pos
		var riCount = 1
		while riStart > 0 'ri_back'
			var prevPos = findPrevCodepointStart(managed, offset: offset, pos: riStart)
			var prevCp = utf8DecodeAt(managed, pos: offset + prevPos)
			var prevGbp = graphemeBreakProperty(prevCp)
			if prevGbp == 6 'more_ri'
				riStart = prevPos
				riCount = riCount + 1
			end 'more_ri' else 'not_ri'
				break
			end 'not_ri'
		end 'ri_back'
		// RIs pair from the start. If total count is even, pos is the start of the last pair.
		// If odd, the first RI is unpaired, then pairs follow.
		// We need the start of the pair that contains 'pos'.
		// The number of RIs from riStart to pos (inclusive of pos) = riCount.
		// The number of RIs after pos up to beforePos = 1 (the one at pos).
		// Actually, pos is the last RI before beforePos. Count how many from riStart to pos.
		// Pairs form left-to-right: (0,1), (2,3), (4,5), ...
		// pos is at index (riCount-1) from riStart. If riCount is even, pos is at an odd index
		// (second of a pair), so the pair starts one RI before pos. If riCount is odd, pos is
		// at an even index (first of a pair or unpaired).
		if riCount mod 2 == 0 'even_count'
			// pos is the second RI in its pair. Step back one RI for the pair start.
			pos = findPrevCodepointStart(managed, offset: offset, pos: pos)
		end 'even_count'
		// else: pos is already at the start of its pair (or unpaired)
	end 'ri_check'

	return pos
end 'findGraphemeStartManaged'

// ============================================
// Count grapheme helpers
// ============================================

// countGraphemesManagedRange - Count grapheme clusters in range
function countGraphemesManagedRange(managed __ManagedMemory, offset Index, len Count) returns Count
	var graphemeCount = 0
	var pos = 0
	while pos < len 'countLoop'
		pos = findGraphemeEndManagedRange(managed, offset: offset, startPos: pos, len: len)
		graphemeCount = graphemeCount + 1
	end 'countLoop'
	return graphemeCount
end 'countGraphemesManagedRange'

/// Count the total number of grapheme clusters in a __ManagedMemory
export function countGraphemesManaged(managed __ManagedMemory) returns Count
	return countGraphemesManagedRange(managed, offset: 0, len: managed.length())
end 'countGraphemesManaged'

/// Convert a byte index to a grapheme (character) index
/// Returns the number of grapheme clusters before the byte position
export function byteIndexToGraphemeIndex(managed __ManagedMemory, byteIdx Index) returns Count
	var graphemeIdx = 0
	var pos = 0
	var len = managed.length()
	while pos < byteIdx and pos < len 'count'
		pos = findGraphemeEndManagedRange(managed, offset: 0, startPos: pos, len: len)
		graphemeIdx = graphemeIdx + 1
	end 'count'
	return graphemeIdx
end 'byteIndexToGraphemeIndex'

/// Advance from a byte position by a number of grapheme clusters
/// Returns the byte position after advancing by `count` graphemes
export function graphemeOffsetToBytePos(managed __ManagedMemory, startBytePos Index, count Count) returns Index
	var pos = startBytePos
	var len = managed.length()
	var i = 0
	while i < count and pos < len 'advance'
		pos = findGraphemeEndManagedRange(managed, offset: 0, startPos: pos, len: len)
		i = i + 1
	end 'advance'
	return pos
end 'graphemeOffsetToBytePos'

// Grapheme_Cluster_Break property values (used as return values):
//   0 = Other, 1 = CR, 2 = LF, 3 = Control, 4 = Extend, 5 = ZWJ,
//   6 = Regional_Indicator, 7 = Prepend, 8 = SpacingMark,
//   9 = L, 10 = V, 11 = T, 12 = LV, 13 = LVT

// Get Grapheme_Cluster_Break property for a codepoint
// Returns: 0=Other, 1=CR, 2=LF, 3=Control, 4=Extend, 5=ZWJ,
//          6=Regional_Indicator, 7=Prepend, 8=SpacingMark,
//          9=L, 10=V, 11=T, 12=LV, 13=LVT
export function graphemeBreakProperty(cp Codepoint) returns BreakProperty
	// CR (return 1)
	if cp == 13 'cr'
		return 1
	end 'cr'

	// LF (return 2)
	if cp == 10 'lf'
		return 2
	end 'lf'

	// Control characters (return 3)
	if cp < 32 or(cp >= 127 and cp < 160) 'control'
		return 3
	end 'control'

	// ZWJ U+200D (return 5)
	if cp == 8205 'zwj'
		return 5
	end 'zwj'

	// Regional Indicators U+1F1E6..U+1F1FF (return 6)
	if cp >= 127462 and cp <= 127487 'ri'
		return 6
	end 'ri'

	// Hangul syllables U+AC00..U+D7A3
	if cp >= 44032 and cp <= 55203 'hangul'
		var sindex = cp - 44032
		if sindex mod 28 == 0 'lv'
			return 12  // LV
		end 'lv' else 'lvt'
			return 13  // LVT
		end 'lvt'
	end 'hangul'

	// Hangul Jamo L U+1100..U+115F (return 9)
	if cp >= 4352 and cp <= 4447 'jamo_l'
		return 9
	end 'jamo_l'

	// Hangul Jamo V U+1160..U+11A7 (return 10)
	if cp >= 4448 and cp <= 4519 'jamo_v'
		return 10
	end 'jamo_v'

	// Hangul Jamo T U+11A8..U+11FF (return 11)
	if cp >= 4520 and cp <= 4607 'jamo_t'
		return 11
	end 'jamo_t'

	// Skin tone modifiers U+1F3FB..U+1F3FF (return 4 = Extend)
	if cp >= 127995 and cp <= 127999 'skin_tone'
		return 4
	end 'skin_tone'

	// Variation selectors U+FE00..U+FE0F (return 4 = Extend)
	if cp >= 65024 and cp <= 65039 'vs'
		return 4
	end 'vs'

	// Combining Diacritical Marks U+0300..U+036F (return 4 = Extend)
	if cp >= 768 and cp <= 879 'combining'
		return 4
	end 'combining'

	// Format characters that are Control (return 3)
	// ZWSP U+200B, LRM/RLM U+200E-200F, Line/Para separators U+2028-202E
	if cp == 8203 or(cp >= 8206 and cp <= 8207) or(cp >= 8232 and cp <= 8238) 'format_control'
		return 3
	end 'format_control'

	// ZWNJ U+200C (return 4 = Extend)
	if cp == 8204 'zwnj'
		return 4
	end 'zwnj'

	// Other (return 0)
	return 0
end 'graphemeBreakProperty'

// Check if codepoint has Extended_Pictographic property (emoji base)
export function isExtendedPictographic(cp Codepoint) returns bool
	// Basic emoji range U+1F600..U+1F64F
	if cp >= 128512 and cp <= 128591 'emoji_faces'
		return true
	end 'emoji_faces'

	// Emoji symbols U+1F300..U+1F5FF
	if cp >= 127744 and cp <= 128511 'emoji_symbols'
		return true
	end 'emoji_symbols'

	// Transport and map symbols U+1F680..U+1F6FF
	if cp >= 128640 and cp <= 128767 'emoji_transport'
		return true
	end 'emoji_transport'

	// Supplemental symbols U+1F900..U+1F9FF
	if cp >= 129280 and cp <= 129535 'emoji_supp'
		return true
	end 'emoji_supp'

	// Additional emoji U+1FA00..U+1FAFF
	if cp >= 129536 and cp <= 130047 'emoji_extra'
		return true
	end 'emoji_extra'

	// Miscellaneous symbols U+2600..U+26FF
	if cp >= 9728 and cp <= 9983 'misc_symbols'
		return true
	end 'misc_symbols'

	// Dingbats U+2700..U+27BF
	if cp >= 9984 and cp <= 10175 'dingbats'
		return true
	end 'dingbats'

	return false
end 'isExtendedPictographic'

// State for tracking complex grapheme sequences
type GraphemeState
	export var riCount Count  // Count of consecutive Regional Indicators (for GB12-13)
	export var inEmojiSeq bool  // Inside Extended_Pictographic...ZWJ sequence (for GB11)

	static function create(riCount Count, inEmojiSeq bool) returns GraphemeState
		return GraphemeState{riCount: riCount, inEmojiSeq: inEmojiSeq}
	end 'create'
end 'GraphemeState'

// Create initial grapheme state
function graphemeStateInit() returns GraphemeState
	return GraphemeState.create(0, inEmojiSeq: false)
end 'graphemeStateInit'

// Check if there should be a grapheme break between two codepoints
// prevGbp: Grapheme_Cluster_Break property of previous codepoint
// currGbp: Grapheme_Cluster_Break property of current codepoint
// prevCp: Previous codepoint value (needed for Extended_Pictographic check)
// currCp: Current codepoint value (needed for Extended_Pictographic check)
// state: State for tracking RI counts and emoji sequences
//
// Returns true if there should be a break BEFORE the current codepoint
function isGraphemeBreak(prevGbp BreakProperty, currGbp BreakProperty, currCp Codepoint, state GraphemeState) returns bool

	// GB3: Do not break between CR and LF (CR × LF)
	// prevGbp == 1 (CR) and currGbp == 2 (LF)
	if prevGbp == 1 and currGbp == 2 'gb3'
		return false
	end 'gb3'

	// GB4: Break after Control, CR, or LF
	// prevGbp == 3 (Control) or prevGbp == 1 (CR) or prevGbp == 2 (LF)
	if prevGbp == 3 or prevGbp == 1 or prevGbp == 2 'gb4'
		return true
	end 'gb4'

	// GB5: Break before Control, CR, or LF
	if currGbp == 3 or currGbp == 1 or currGbp == 2 'gb5'
		return true
	end 'gb5'

	// GB6: Do not break Hangul syllable sequences (L × L/V/LV/LVT)
	// prevGbp == 9 (L)
	if prevGbp == 9 'gb6'
		// currGbp == 9 (L), 10 (V), 12 (LV), or 13 (LVT)
		if currGbp == 9 or currGbp == 10 or currGbp == 12 or currGbp == 13 'gb6_inner'
			return false
		end 'gb6_inner'
	end 'gb6'

	// GB7: Do not break Hangul syllable sequences (LV/V × V/T)
	// prevGbp == 12 (LV) or 10 (V)
	if prevGbp == 12 or prevGbp == 10 'gb7'
		// currGbp == 10 (V) or 11 (T)
		if currGbp == 10 or currGbp == 11 'gb7_inner'
			return false
		end 'gb7_inner'
	end 'gb7'

	// GB8: Do not break Hangul syllable sequences (LVT/T × T)
	// prevGbp == 13 (LVT) or 11 (T)
	if prevGbp == 13 or prevGbp == 11 'gb8'
		// currGbp == 11 (T)
		if currGbp == 11 'gb8_inner'
			return false
		end 'gb8_inner'
	end 'gb8'

	// GB9: Do not break before Extend or ZWJ (× Extend/ZWJ)
	// currGbp == 4 (Extend) or 5 (ZWJ)
	if currGbp == 4 or currGbp == 5 'gb9'
		return false
	end 'gb9'

	// GB9a: Do not break before SpacingMark (× SpacingMark)
	// currGbp == 8 (SpacingMark)
	if currGbp == 8 'gb9a'
		return false
	end 'gb9a'

	// GB9b: Do not break after Prepend (Prepend ×)
	// prevGbp == 7 (Prepend)
	if prevGbp == 7 'gb9b'
		return false
	end 'gb9b'

	// GB11: Do not break within emoji ZWJ sequences
	// \p{Extended_Pictographic} Extend* ZWJ × \p{Extended_Pictographic}
	// prevGbp == 5 (ZWJ)
	if prevGbp == 5 and isExtendedPictographic(currCp) 'gb11'
		if state.inEmojiSeq 'gb11_check'
			return false
		end 'gb11_check'
	end 'gb11'

	// GB12-13: Do not break within emoji flag sequences
	// Only pair up RIs; odd-numbered RIs break before next RI
	// prevGbp == 6 (Regional_Indicator) and currGbp == 6
	if prevGbp == 6 and currGbp == 6 'gb12'
		if state.riCount mod 2 == 1 'gb12_odd'
			return false
		end 'gb12_odd'
	end 'gb12'

	// GB999: Otherwise, break everywhere
	return true
end 'isGraphemeBreak'

// Update grapheme state after processing a codepoint
function graphemeStateUpdate(state GraphemeState, gbp BreakProperty, cp Codepoint) returns GraphemeState
	var newState = GraphemeState.create(0, inEmojiSeq: false)

	// Track Regional Indicator sequences (gbp == 6)
	if gbp == 6 'ri_update'
		newState.riCount = state.riCount + 1
	end 'ri_update'

	// Track emoji sequences for GB11
	if isExtendedPictographic(cp) 'emoji_base'
		newState.inEmojiSeq = true
	end 'emoji_base' else 'not_emoji_base'
		if state.inEmojiSeq 'emoji_continue'
			// gbp == 4 (Extend) or 5 (ZWJ)
			if gbp == 4 or gbp == 5 'emoji_extend'
				newState.inEmojiSeq = true
			end 'emoji_extend'
		end 'emoji_continue'
	end 'not_emoji_base'

	return newState
end 'graphemeStateUpdate'

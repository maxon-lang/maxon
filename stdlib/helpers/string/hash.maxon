// Internal hash and equality helpers for string types
//
// Purpose: Centralize hash and equality algorithms for string types.

typealias ByteCount = int(0 to u64.max)
typealias BytePos = int(0 to u64.max)

// ============================================
// Hash helpers (djb2 algorithm)
// ============================================

// hashManagedStringRange - Hash a range in __ManagedMemory using djb2
function hashManagedStringRange(managed __ManagedMemory, offset BytePos, len ByteCount) returns HashValue
	var h = 5381
	for i in 0 upto len 'hash_loop'
		let b = try managed.byteAt(offset + i) otherwise panic("hashManagedStringRange: byteAt OOB — caller guarantees offset+len <= managed.length()")
		h = h * 33 + b
	end 'hash_loop'
	return h and 0xFFFFFFFF
end 'hashManagedStringRange'

/// Hash a __ManagedMemory using the djb2 algorithm
/// Returns a 32-bit hash value
export function hashManagedString(managed __ManagedMemory) returns HashValue
	return hashManagedStringRange(managed, offset: 0, len: managed.length())
end 'hashManagedString'

// ============================================
// Equality helpers (byte-by-byte comparison)
// ============================================

// equalsManagedStringRange - Compare two ranges in __ManagedMemorys
function equalsManagedStringRange(a __ManagedMemory, aOffset BytePos, b __ManagedMemory, bOffset BytePos, len ByteCount) returns bool
	for i in 0 upto len 'compare_loop'
		let ab = try a.byteAt(aOffset + i) otherwise panic("equalsManagedStringRange: byteAt OOB — caller guarantees aOffset+len <= a.length()")
		let bb = try b.byteAt(bOffset + i) otherwise panic("equalsManagedStringRange: byteAt OOB — caller guarantees bOffset+len <= b.length()")
		if ab != bb 'byte_check'
			return false
		end 'byte_check'
	end 'compare_loop'
	return true
end 'equalsManagedStringRange'

/// Compare two __ManagedMemorys for byte-by-byte equality
export function equalsManagedString(a __ManagedMemory, b __ManagedMemory) returns bool
	let len = a.length()
	if len != b.length() 'length_check'
		return false
	end 'length_check'
	return equalsManagedStringRange(a, aOffset: 0, b: b, bOffset: 0, len: len)
end 'equalsManagedString'

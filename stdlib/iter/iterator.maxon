// stdlib/iter/iterator.maxon
// Iterator interface - base contract for all iterators in Maxon

// Iterator struct - core interface for iteration
export struct Iterator
    current int
    limit int
    step int
end 'Iterator'

// Check if iterator has more elements
// Returns: 1 if more elements available, 0 if done
export function hasNext(it Iterator) int
    if it.step > 0 'forward'
        if it.current < it.limit 'check'
            return 1
        end 'check'
        return 0
    end 'forward'
    
    if it.current > it.limit 'backward_check'
        return 1
    end 'backward_check'
    return 0
end 'hasNext'

// Get current value from iterator
export function getCurrent(it Iterator) int
    return it.current
end 'getCurrent'

// Advance iterator to next element
export function next(it Iterator) Iterator
    var result = Iterator{
        current: it.current + it.step,
        limit: it.limit,
        step: it.step
    }
    return result
end 'next'

/// Console output for printing strings to stderr.
/// @category System

typealias BytesWritten = int(0 to i64.max)

/// Print a string to stderr
/// Returns the number of bytes written, or negative on error
export function printError(value String) returns BytesWritten
  var cs = value.cstr()
  let n = __cstring_write_stderr(cs)
  return n
end 'printError'

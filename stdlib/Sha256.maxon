/// SHA-256 cryptographic hash function.
/// @category Crypto
typealias Word32 = int(i64.min to i64.max)
typealias Sha256Words = Array with Word32

// SHA-256 round constants (FIPS 180-4 section 4.2.2)
let sha256KTable = [
	0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
	0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
	0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
	0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
	0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
	0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
	0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
	0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
	0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
	0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
	0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
	0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
	0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
	0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
	0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
	0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
]

function sha256RotR(v Word32, n Word32) returns Word32
	let right = v shr n
	let left = (v shl (32 - n)) and 0xFFFFFFFF
	return (right or left) and 0xFFFFFFFF
end 'sha256RotR'

function sha256Ch(a Word32, b Word32, c Word32) returns Word32
	let notA = (0xFFFFFFFF xor a) and 0xFFFFFFFF
	return ((a and b) xor (notA and c)) and 0xFFFFFFFF
end 'sha256Ch'

function sha256Maj(a Word32, b Word32, c Word32) returns Word32
	return ((a and b) xor (a and c) xor (b and c)) and 0xFFFFFFFF
end 'sha256Maj'

function sha256BigSigma0(v Word32) returns Word32
	let r2 = sha256RotR(v, n: 2)
	let r13 = sha256RotR(v, n: 13)
	let r22 = sha256RotR(v, n: 22)
	return (r2 xor r13 xor r22) and 0xFFFFFFFF
end 'sha256BigSigma0'

function sha256BigSigma1(v Word32) returns Word32
	let r6 = sha256RotR(v, n: 6)
	let r11 = sha256RotR(v, n: 11)
	let r25 = sha256RotR(v, n: 25)
	return (r6 xor r11 xor r25) and 0xFFFFFFFF
end 'sha256BigSigma1'

function sha256SmSigma0(v Word32) returns Word32
	let r7 = sha256RotR(v, n: 7)
	let r18 = sha256RotR(v, n: 18)
	let s3 = (v shr 3) and 0xFFFFFFFF
	return (r7 xor r18 xor s3) and 0xFFFFFFFF
end 'sha256SmSigma0'

function sha256SmSigma1(v Word32) returns Word32
	let r17 = sha256RotR(v, n: 17)
	let r19 = sha256RotR(v, n: 19)
	let s10 = (v shr 10) and 0xFFFFFFFF
	return (r17 xor r19 xor s10) and 0xFFFFFFFF
end 'sha256SmSigma1'

function sha256ReadBE32(buf ByteArray, off Word32) returns Word32
	// The caller (sha256's block loop) guarantees off+3 < buf.count(); the otherwise
	// branch is unreachable but must be syntactically present since Array.get throws.
	let b0 = try buf.get(off) otherwise 0
	let b1 = try buf.get(off + 1) otherwise 0
	let b2 = try buf.get(off + 2) otherwise 0
	let b3 = try buf.get(off + 3) otherwise 0
	return (b0 shl 24) or (b1 shl 16) or (b2 shl 8) or b3
end 'sha256ReadBE32'

/// Compute the SHA-256 hash of data. Returns a 32-byte ByteArray.
export function sha256(data ByteArray) returns ByteArray
	// Initial hash state from FIPS 180-4 §5.3.3. Scalars (not an Array) so round
	// bookkeeping doesn't require bounds-checked indexing.
	var h0 = 0x6a09e667
	var h1 = 0xbb67ae85
	var h2 = 0x3c6ef372
	var h3 = 0xa54ff53a
	var h4 = 0x510e527f
	var h5 = 0x9b05688c
	var h6 = 0x1f83d9ab
	var h7 = 0x5be0cd19

	let msgLen = data.count()
	let bitLen = msgLen * 8

	var padded = ByteArray.create()
	padded.reserve(msgLen + 72)
	padded.append(data)
	padded.push(0x80)

	while padded.count() mod 64 != 56 'pad'
		padded.push(0)
	end 'pad'

	padded.push((bitLen shr 56) and 0xFF)
	padded.push((bitLen shr 48) and 0xFF)
	padded.push((bitLen shr 40) and 0xFF)
	padded.push((bitLen shr 32) and 0xFF)
	padded.push((bitLen shr 24) and 0xFF)
	padded.push((bitLen shr 16) and 0xFF)
	padded.push((bitLen shr 8) and 0xFF)
	padded.push(bitLen and 0xFF)

	var blockOff = 0
	while blockOff < padded.count() 'processBlocks'
		// Message schedule: 64 extended words. Kept as a mutable array only because
		// round r reads w[r-2], w[r-7], w[r-15], w[r-16] by offset — no iterator fits.
		// All reads use indexes the loop-header guarantees are in range, so the bounds
		// check is unreachable (stdlib Array.get panics uncatchably if misused).
		var w = Sha256Words.create()
		w.reserve(64)

		var wi = 0
		while wi < 16 'readWords'
			w.push(sha256ReadBE32(padded, off: blockOff + wi * 4))
			wi = wi + 1
		end 'readWords'

		while wi < 64 'extend'
			// wi is in [16, 64); wi-16 >= 0 and wi-2 < 64 so all indexes are in w's range.
			let wm2 = try w.get(wi - 2) otherwise panic("sha256: extend w[wi-2] unreachable")
			let wm7 = try w.get(wi - 7) otherwise panic("sha256: extend w[wi-7] unreachable")
			let wm15 = try w.get(wi - 15) otherwise panic("sha256: extend w[wi-15] unreachable")
			let wm16 = try w.get(wi - 16) otherwise panic("sha256: extend w[wi-16] unreachable")
			let s0 = sha256SmSigma0(wm15)
			let s1 = sha256SmSigma1(wm2)
			w.push((wm16 + s0 + wm7 + s1) and 0xFFFFFFFF)
			wi = wi + 1
		end 'extend'

		var a = h0
		var b = h1
		var c = h2
		var d = h3
		var ve = h4
		var f = h5
		var g = h6
		var hv = h7

		// Iterate the K table and w schedule in lockstep via a K-iterator; w is
		// indexed by the outer for-loop's counter. This avoids bounds-checked
		// random access on sha256KTable (which is constant and safely 64-long).
		let kCursor = try sha256KTable.createIterator() otherwise panic("Sha256: K table iterator failed (unreachable)")
		for wri in w 'rounds'
			let ki = kCursor.current()
			let ss1 = sha256BigSigma1(ve)
			let ch = sha256Ch(ve, b: f, c: g)
			let t1 = (hv + ss1 + ch + ki + wri) and 0xFFFFFFFF
			let ss0 = sha256BigSigma0(a)
			let maj = sha256Maj(a, b: b, c: c)
			let t2 = (ss0 + maj) and 0xFFFFFFFF

			hv = g
			g = f
			f = ve
			ve = (d + t1) and 0xFFFFFFFF
			d = c
			c = b
			b = a
			a = (t1 + t2) and 0xFFFFFFFF

			try kCursor.advance() otherwise break
		end 'rounds'

		h0 = (h0 + a) and 0xFFFFFFFF
		h1 = (h1 + b) and 0xFFFFFFFF
		h2 = (h2 + c) and 0xFFFFFFFF
		h3 = (h3 + d) and 0xFFFFFFFF
		h4 = (h4 + ve) and 0xFFFFFFFF
		h5 = (h5 + f) and 0xFFFFFFFF
		h6 = (h6 + g) and 0xFFFFFFFF
		h7 = (h7 + hv) and 0xFFFFFFFF

		blockOff = blockOff + 64
	end 'processBlocks'

	var result = ByteArray.create()
	result.reserve(32)
	emitBE32(result, val: h0)
	emitBE32(result, val: h1)
	emitBE32(result, val: h2)
	emitBE32(result, val: h3)
	emitBE32(result, val: h4)
	emitBE32(result, val: h5)
	emitBE32(result, val: h6)
	emitBE32(result, val: h7)
	return result
end 'sha256'

function emitBE32(result ByteArray, val Word32)
	result.push((val shr 24) and 0xFF)
	result.push((val shr 16) and 0xFF)
	result.push((val shr 8) and 0xFF)
	result.push(val and 0xFF)
end 'emitBE32'

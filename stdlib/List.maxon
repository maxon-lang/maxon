/// Doubly linked list with O(1) insertion and removal at both ends, O(n) indexed access.
/// Nodes are represented as a discriminated union: either `empty` or a `node` with
/// a value and links to the next and previous nodes. Because associated-value unions
/// use heap-pointer reference semantics, mutations to node links propagate in-place.
/// @category Collections

export union ListNode uses Element
  empty
  node(value Element, next ListNode, prev ListNode)
end 'ListNode'

export type List uses Element implements InitableFromArrayLiteral with Element, Iterable with Element, Disposable
  typealias ElementArray = Array with Element
  typealias Node = ListNode with Element

  var head Node
  var tail Node
  var size Count
  var iterNode Node

  // InitableFromArrayLiteral conformance — called by compiler for `List from [1, 2, 3]`
  static function init(arr ElementArray) returns Self
    var result = Self{}
    for item in arr 'build'
      result.append(item)
    end 'build'
    return result
  end 'init'

  /// Get the number of elements in the list
  export function count() returns Count
    return size
  end 'count'

  /// Check if the list is empty
  export function isEmpty() returns bool
    return size == 0
  end 'isEmpty'

  /// Get the first element, throws if empty
  export function first() returns Element throws ArrayError
    match head 'check'
      node(v, _next, _prev) then return v
      empty then throw ArrayError.indexOutOfBounds
    end 'check'
  end 'first'

  /// Get the last element, throws if empty
  export function last() returns Element throws ArrayError
    match tail 'check'
      node(v, _next, _prev) then return v
      empty then throw ArrayError.indexOutOfBounds
    end 'check'
  end 'last'

  // Extract the next node from a ListNode, returns Node.empty if the node is empty
  function nodeNext(n Node) returns Node
    match n 'check'
      node(_v, nx, _prev) then return nx
      empty then return Node.empty
    end 'check'
  end 'nodeNext'

  // Extract the previous node from a ListNode, returns Node.empty if the node is empty
  function nodePrev(n Node) returns Node
    match n 'check'
      node(_v, _next, pv) then return pv
      empty then return Node.empty
    end 'check'
  end 'nodePrev'

  // Extract the value from a ListNode, throws if empty
  function nodeValue(n Node) returns Element throws ArrayError
    match n 'check'
      node(v, _next, _prev) then return v
      empty then throw ArrayError.indexOutOfBounds
    end 'check'
  end 'nodeValue'

  // Check if a node is empty
  function nodeIsEmpty(n Node) returns bool
    match n 'check'
      empty then return true
      node(_v, _nx, _pv) then return false
    end 'check'
  end 'nodeIsEmpty'

  // Set the next pointer of a node in-place
  function setNext(n Node, target Node)
    match n 'set'
      node(_v, next, _prev) then next = target
      empty then return
    end 'set'
  end 'setNext'

  // Set the prev pointer of a node in-place
  function setPrev(n Node, target Node)
    match n 'set'
      node(_v, _next, prev) then prev = target
      empty then return
    end 'set'
  end 'setPrev'

  // Get the node at a given index by walking from head
  function nodeAt(idx Index) returns Node
    var current = head
    var i = 0
    while i < idx 'walk'
      current = nodeNext(current)
      i = i + 1
    end 'walk'
    return current
  end 'nodeAt'

  /// Get element at index (0-based, front to back), throws if out of bounds
  export function get(index Index) returns Element throws ArrayError
    if index >= size 'bounds'
      throw ArrayError.indexOutOfBounds
    end 'bounds'
    var current = nodeAt(idx: index)
    return try nodeValue(current) otherwise 'err'
      throw ArrayError.indexOutOfBounds
    end 'err'
  end 'get'

  /// Add an element to the front of the list. O(1).
  export function prepend(value Element)
    var newNode = Node.node(value, head, Node.empty)
    if size == 0 'wasEmpty'
      head = newNode
      tail = newNode
    end 'wasEmpty' else 'hasElements'
      setPrev(head, target: newNode)
      head = newNode
    end 'hasElements'
    size = size + 1
    iterNode = head
  end 'prepend'

  /// Add an element to the back of the list. O(1).
  export function append(value Element)
    var newNode = Node.node(value, Node.empty, tail)
    if size == 0 'wasEmpty'
      head = newNode
      tail = newNode
    end 'wasEmpty' else 'hasElements'
      setNext(tail, target: newNode)
      tail = newNode
    end 'hasElements'
    size = size + 1
    iterNode = head
  end 'append'

  /// Insert an element at the given index. O(n).
  export function insert(at Index, value Element)
    if at == 0 'front'
      prepend(value)
      return
    end 'front'
    if at >= size 'back'
      append(value)
      return
    end 'back'
    var before = nodeAt(idx: at - 1)
    var after = nodeNext(before)
    var newNode = Node.node(value, after, before)
    setNext(before, target: newNode)
    setPrev(after, target: newNode)
    size = size + 1
    iterNode = head
  end 'insert'

  /// Remove and return the first element, throws if empty. O(1).
  export function removeFirst() returns Element throws ArrayError
    if size == 0 'empty'
      throw ArrayError.indexOutOfBounds
    end 'empty'
    var result = try nodeValue(head) otherwise 'err'
      throw ArrayError.indexOutOfBounds
    end 'err'
    head = nodeNext(head)
    size = size - 1
    if size == 0 'nowEmpty'
      tail = Node.empty
    end 'nowEmpty' else 'stillHas'
      setPrev(head, target: Node.empty)
    end 'stillHas'
    iterNode = head
    return result
  end 'removeFirst'

  /// Remove and return the last element, throws if empty. O(1).
  export function removeLast() returns Element throws ArrayError
    if size == 0 'empty'
      throw ArrayError.indexOutOfBounds
    end 'empty'
    var result = try nodeValue(tail) otherwise 'err'
      throw ArrayError.indexOutOfBounds
    end 'err'
    tail = nodePrev(tail)
    size = size - 1
    if size == 0 'nowEmpty'
      head = Node.empty
    end 'nowEmpty' else 'stillHas'
      setNext(tail, target: Node.empty)
    end 'stillHas'
    iterNode = head
    return result
  end 'removeLast'

  /// Remove and return element at index, throws if out of bounds. O(n).
  export function remove(at Index) returns Element throws ArrayError
    if at >= size 'bounds'
      throw ArrayError.indexOutOfBounds
    end 'bounds'
    if at == 0 'front'
      var first = try removeFirst() otherwise 'err1'
        throw ArrayError.indexOutOfBounds
      end 'err1'
      return first
    end 'front'
    if at == size - 1 'back'
      var last = try removeLast() otherwise 'err2'
        throw ArrayError.indexOutOfBounds
      end 'err2'
      return last
    end 'back'
    var target = nodeAt(idx: at)
    var result = try nodeValue(target) otherwise 'err3'
      throw ArrayError.indexOutOfBounds
    end 'err3'
    var before = nodePrev(target)
    var after = nodeNext(target)
    setNext(before, target: after)
    setPrev(after, target: before)
    size = size - 1
    iterNode = head
    return result
  end 'remove'

  /// Remove all elements
  export function clear()
    head = Node.empty
    tail = Node.empty
    size = 0
    iterNode = Node.empty
  end 'clear'

  // Break circular prev references so refcount cleanup can free the chain.
  // Called automatically by the compiler at scope exit.
  function dispose()
    var current = head
    while nodeIsEmpty(current) == false 'walk'
      var nx = nodeNext(current)
      setPrev(current, target: Node.empty)
      current = nx
    end 'walk'
  end 'dispose'

  /// Get next element in iteration (front to back), throws when exhausted
  export function next() returns Element throws IterationError
    if nodeIsEmpty(iterNode) 'done'
      throw IterationError.exhausted
    end 'done'
    var result = try nodeValue(iterNode) otherwise 'err'
      throw IterationError.exhausted
    end 'err'
    iterNode = nodeNext(iterNode)
    return result
  end 'next'
end 'List'

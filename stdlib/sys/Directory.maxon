enum DirectoryError is Error
	notFound
	permissionDenied
	notDirectory
	alreadyExists
end 'DirectoryError'

export type Directory
	/// List files and directories in a path
	export static function list(path String) returns Array of String throws DirectoryError
		var pattern = "{path}\\*"
		var cs = pattern.cstr()
		var handle = __find_first_file(cs)
		if handle == 0 'notFound'
			throw DirectoryError.notFound
		end 'notFound'
		var result = Array of String{}
		var filename = __find_filename(handle)
		var name = String.fromCString(filename)
		if name != "." and name != ".." 'notDot1'
			result.push(name)
		end 'notDot1'
		var nextResult = __find_next_file(handle)
		while nextResult != 0 'loop'
			filename = __find_filename(handle)
			name = String.fromCString(filename)
			if name != "." and name != ".." 'notDot2'
				result.push(name)
			end 'notDot2'
			nextResult = __find_next_file(handle)
		end 'loop'
		__find_close(handle)
		return result
	end 'list'

	/// Check if a path exists and is a directory
	export static function exists(path String) returns bool
		var cs = path.cstr()
		return __directory_exists(cs)
	end 'exists'

	/// Alias for exists
	export static function isDirectory(path String) returns bool
		return Directory.exists(path)
	end 'isDirectory'
end 'Directory'

// stdlib/sys/process.maxon
// Process execution functions
// Namespace: stdlib.sys

/// Execute a process and wait for it to complete
/// Returns the exit code of the process, or -1 on failure
///
/// Example:
///     let exitCode = executeProcess("notepad.exe")
///     let exitCode = executeProcess("cmd.exe /c dir")
export function executeProcess(commandLine string) returns int
	var cs = commandLine.cstr()
	return __execute_process(cs)
end 'executeProcess'


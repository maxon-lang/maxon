// stdlib/sys/print.maxon
// Integer printing function
// Namespace: stdlib.sys

/// Print a string to stdout (no newline)
/// Returns the number of bytes written, or negative on error
export function print(value string) int
	var cs = value.cstr()
	let n = __cstring_write_stdout(cs)
	var newline = "\n"
	var newline_cs = newline.cstr()
	__cstring_write_stdout(newline_cs) // Add newline after printing
	return n + 1 // Include newline in byte count
end 'print'

/// Print an integer to stdout followed by a newline
/// Returns the number of bytes written, or negative on error
export function print_int(value int) int
	// Allocate buffer for integer formatting (12 bytes max for -2147483648)
	var buffer = [12]char

	// Format the integer into the buffer
	var length = format_int_array(value, buffer)

	// Create string from buffer and print it with newline
	var s = string_from_chars(buffer, length)
	return print(s)
end 'print_int'

/// Print a float to stdout with specified precision followed by a newline
/// Returns the number of bytes written, or negative on error
export function print_float(value float, precision int) int
	// Allocate buffer for float formatting (max size for typical float output)
	var buffer = [64]char

	// Format the float into the buffer
	var length = format_float_array(value, buffer, precision)

	// Create string from buffer and print it with newline
	var s = string_from_chars(buffer, length)
	return print(s)
end 'print_float'

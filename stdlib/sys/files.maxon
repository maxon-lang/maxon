/// Error for file read operations
export enum ReadError is Error
	notFound
end 'ReadError'

/// Error for file write operations
export enum WriteError is Error
	failed
end 'WriteError'

/// Error for file delete operations
export enum DeleteError is Error
	notFound
end 'DeleteError'

let INVALID_HANDLE = -1

export type File
	/// Open a file for reading, returning INVALID_HANDLE if it doesn't exist
	static function tryOpen(path String) returns int
		return __file_open_read(path.cstr())
	end 'tryOpen'

	/// Open file for reading, throwing if not found
	static function openForRead(path String) returns int throws ReadError
		let handle = tryOpen(path)
		if handle == INVALID_HANDLE 'notFound'
			throw ReadError.notFound
		end 'notFound'
		return handle
	end 'openForRead'

	/// Read file into a managed memory
	static function readFileData(path String, extraBytes int) returns __ManagedMemory throws ReadError
		let handle = try openForRead(path)
		let size = __file_size(handle)
		var managed = __managed_memory_create(size + extraBytes, 1)
		let bytesRead = __file_read(handle, managed, size)
		__file_close(handle)
		__managed_memory_set_length(managed, bytesRead)
		return managed
	end 'readFileData'

	/// Read text file content as a UTF-8 string
	export static function readText(path String) returns String throws ReadError
		var managed = try readFileData(path, extraBytes: 1)
		let len = __managed_memory_len(managed)
		__managed_memory_set_byte(managed, len, 0)
		return String{_managed: managed, _iterPos: 0}
	end 'readText'

	/// Read file content as raw bytes
	export static function readBinary(path String) returns Array of byte throws ReadError
		var managed = try readFileData(path, extraBytes: 0)
		return Array of byte{managed: managed, iterIndex: 0}
	end 'readBinary'

	/// Write string content to a text file
	export static function writeText(path String, content String) throws WriteError
		let res = __write_file(path.cstr(), content.cstr())
		if res != 0 'failed'
			throw WriteError.failed
		end 'failed'
	end 'writeText'

	/// Write binary content to a file
	export static function writeBinary(path String, content Array of byte) throws WriteError
		let res = __write_file_binary(path.cstr(), content)
		if res != 0 'failed'
			throw WriteError.failed
		end 'failed'
	end 'writeBinary'

	/// Check if a file exists at the given path
	export static function exists(path String) returns bool
		let handle = tryOpen(path)
		if handle == INVALID_HANDLE 'notFound'
			return false
		end 'notFound'
		__file_close(handle)
		return true
	end 'exists'

	/// Delete a file at the given path
	export static function delete(path String) throws DeleteError
		let res = __file_delete(path.cstr())
		if res != 0 'failed'
			throw DeleteError.notFound
		end 'failed'
	end 'delete'
end 'File'

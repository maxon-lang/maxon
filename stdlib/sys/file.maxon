enum FileError is Error
	notFound
	permissionDenied
	alreadyExists
	diskFull
	invalidPath
	readError
	writeError
end 'FileError'

// INVALID_HANDLE_VALUE from Windows API
let INVALID_HANDLE = -1

export type File
	var _unused int  // Types require at least one field

	/// Read text file content as a UTF-8 string
	export static function readText(path String) returns String throws FileError
		var cs = path.cstr()
		let handle = __file_open_read(cs)
		if handle == INVALID_HANDLE 'notFound'
			throw FileError.notFound
		end 'notFound'

		let size = __file_size(handle)
		var managed = __managed_array_create(size + 1, 1)
		let bytesRead = __file_read(handle, managed, size)
		__file_close(handle)
		__managed_array_set_length(managed, bytesRead)
		// Null-terminate for C compatibility
		__managed_array_set_byte(managed, bytesRead, 0)
		return String{_managed: managed, _iterPos: 0}
	end 'readText'

	/// Read file content as raw bytes
	export static function readBinary(path String) returns Array of byte throws FileError
		var cs = path.cstr()
		let handle = __file_open_read(cs)
		if handle == INVALID_HANDLE 'notFound'
			throw FileError.notFound
		end 'notFound'

		let size = __file_size(handle)
		var managed = __managed_array_create(size, 1)
		let bytesRead = __file_read(handle, managed, size)
		__file_close(handle)
		__managed_array_set_length(managed, bytesRead)
		return Array of byte{managed: managed, iterIndex: 0}
	end 'readBinary'

	/// Write string content to a text file
	export static function writeText(path String, content String) throws FileError
		var cs = path.cstr()
		var contentCs = content.cstr()
		let res = __write_file(cs, contentCs)
		if res != 0 'failed'
			throw FileError.writeError
		end 'failed'
	end 'writeText'

	/// Write binary content to a file
	export static function writeBinary(path String, content Array of byte) throws FileError
		var cs = path.cstr()
		let res = __write_file_binary(cs, content)
		if res != 0 'failed'
			throw FileError.writeError
		end 'failed'
	end 'writeBinary'

	/// Check if a file exists at the given path
	export static function exists(path String) returns bool
		var cs = path.cstr()
		let handle = __file_open_read(cs)
		if handle == INVALID_HANDLE 'notFound'
			return false
		end 'notFound'
		__file_close(handle)
		return true
	end 'exists'

	/// Delete a file at the given path
	export static function delete(path String) throws FileError
		var cs = path.cstr()
		let res = __file_delete(cs)
		if res != 0 'failed'
			throw FileError.notFound
		end 'failed'
	end 'delete'
end 'File'

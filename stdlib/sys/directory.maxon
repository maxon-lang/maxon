// stdlib/sys/directory.maxon
// Directory operations with error handling

enum DirectoryError is Error
	notFound
	permissionDenied
	notDirectory
	alreadyExists
end 'DirectoryError'

export type Directory
	var _unused int  // Types require at least one field

	/// List files and directories in a path
	/// Returns array of filenames (excluding . and ..)
	export static function list(path String) returns Array of String throws DirectoryError
		var cs = path.cstr()
		let maybeFiles = __list_directory(cs)
		if let files = maybeFiles 'hasFiles'
			return files
		end 'hasFiles'
		throw DirectoryError.notFound
	end 'list'

	/// Check if a path exists and is a directory
	export static function exists(path String) returns bool
		var cs = path.cstr()
		let res = __is_directory(cs)
		return res == 1
	end 'exists'

	/// Check if a path is a directory (alias for exists)
	export static function isDirectory(path String) returns bool
		var cs = path.cstr()
		let res = __is_directory(cs)
		return res == 1
	end 'isDirectory'
end 'Directory'

/// Unicode character classification utilities.
/// @category Text

export type Unicode
  /// Returns true if the codepoint is a Unicode whitespace character.
  /// Covers all characters with the Unicode White_Space property.
  export static function isWhitespace(cp Codepoint) returns bool
    // ASCII whitespace: HT, LF, VT, FF, CR, SP
    if cp >= 9 and cp <= 13 'ascii_control_ws'
      return true
    end 'ascii_control_ws'
    if cp == 32 'space'
      return true
    end 'space'
    // NEL (Next Line)
    if cp == 133 'nel'
      return true
    end 'nel'
    // NBSP (No-Break Space)
    if cp == 160 'nbsp'
      return true
    end 'nbsp'
    // OGHAM SPACE MARK
    if cp == 5760 'ogham'
      return true
    end 'ogham'
    // EN QUAD through HAIR SPACE (U+2000-U+200A)
    if cp >= 8192 and cp <= 8202 'general_punctuation_spaces'
      return true
    end 'general_punctuation_spaces'
    // LINE SEPARATOR
    if cp == 8232 'line_sep'
      return true
    end 'line_sep'
    // PARAGRAPH SEPARATOR
    if cp == 8233 'para_sep'
      return true
    end 'para_sep'
    // NARROW NO-BREAK SPACE
    if cp == 8239 'nnbsp'
      return true
    end 'nnbsp'
    // MEDIUM MATHEMATICAL SPACE
    if cp == 8287 'mmsp'
      return true
    end 'mmsp'
    // IDEOGRAPHIC SPACE
    if cp == 12288 'ideographic'
      return true
    end 'ideographic'
    return false
  end 'isWhitespace'
end 'Unicode'

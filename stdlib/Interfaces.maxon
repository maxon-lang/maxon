/// Core interfaces and error types for type conformance and protocols.
/// @category Core

// Purpose-specific typealiases for stdlib internals
export typealias Count = int(0 to u64.max)
export typealias Index = int(0 to u64.max)
export typealias HashValue = int(0 to u32.max)
export typealias Codepoint = int(0 to 1114111)
export typealias Offset = int(i64.min to i64.max)
export typealias MathValue = float(f64.min to f64.max)
export typealias ExitCode = int(0 to u32.max)

// These are auto-discovered when a type declares conformance with 'implements'

// BuiltinStringLiteral - default type for string literals when no explicit type requested
// The compiler searches for the type implementing this interface when encountering "..."
// Only one type should implement this interface (typically String).
export interface BuiltinStringLiteral
  static function init(value __ManagedMemory) returns Self
end 'BuiltinStringLiteral'

// BuiltinCharLiteral - default type for character literals when no explicit type requested
// The compiler searches for the type implementing this interface when encountering '...'
// Only one type should implement this interface (typically Character).
export interface BuiltinCharLiteral
  static function init(value __ManagedMemory) returns Self
end 'BuiltinCharLiteral'

// BuiltinArrayLiteral - default type for array literals when no explicit type requested
// The compiler searches for the type implementing this interface when encountering [...]
// Only one type should implement this interface (typically Array).
export interface BuiltinArrayLiteral
  static function init(value __ManagedMemory) returns Self
end 'BuiltinArrayLiteral'

// BuiltinDictionaryLiteral - default type for map literals when no explicit type requested
// The compiler searches for the type implementing this interface when encountering ["key": value, ...]
// Only one type should implement this interface (typically Map).
export interface BuiltinDictionaryLiteral
  static function init(keys __ManagedMemory, values __ManagedMemory) returns Self
end 'BuiltinDictionaryLiteral'

// Error - marker interface for throwable error types
// Only unions can conform to Error. Error unions represent distinct error conditions
// and can be thrown and caught using try/throw/catch.
// Examples:
//   union FileError implements Error
//       notFound
//       permissionDenied
//   end 'FileError'
//
//   union HttpError int implements Error
//       notFound = 404
//       serverError = 500
//   end 'HttpError'
export interface Error
end 'Error'

// ArrayError - errors for indexed collection operations
export union ArrayError implements Error
  indexOutOfBounds
  emptySlot
end 'ArrayError'

// MapError - errors for dictionary/map operations
export union MapError implements Error
  keyNotFound
end 'MapError'

// IterationError - errors for iterator exhaustion
export union IterationError implements Error
  exhausted
end 'IterationError'

// UnionError - errors for union operations
export union EnumError implements Error
  invalidName
end 'EnumError'

// StringError - errors for string operations
export union StringError implements Error
  notFound
  invalidIndex
end 'StringError'

// CharacterError - errors for character operations
export union CharacterError implements Error
  notAscii
end 'CharacterError'

// ParseError - errors for string-to-value parsing operations
export union ParseError implements Error
  invalidFormat
end 'ParseError'

// __ManagedListError - errors for managed list operations
export union __ManagedListError implements Error
  empty
  endOfList
end '__ManagedListError'

// ListError - errors for list operations
export union ListError implements Error
  empty
end 'ListError'

// Ordering - result of comparing two values
export union Ordering
  lessThan
  equalTo
  greaterThan
end 'Ordering'

// Hashable - types that can be hashed to an integer
export interface Hashable
  function hash() returns HashValue
end 'Hashable'

// Equatable - types that can be compared for equality
export interface Equatable
  function equals(other Self) returns bool
end 'Equatable'

// Comparable - types that can be ordered
export interface Comparable
  function compare(other Self) returns Ordering
end 'Comparable'

// Cloneable - types that can be copied
export interface Cloneable
  function clone() returns Self
end 'Cloneable'

// Strideable - types that can be advanced by integer steps (used for range iteration)
// Types implementing Strideable can be used with `to` and `upto` range expressions.
export interface Strideable
  function advancedBy(n Offset) returns Self
end 'Strideable'

// Iterable - types that can be iterated over (used by for-in loops)
// createIterator() resets iteration state to the beginning; called by the compiler before each for-in loop.
// next() advances the iterator and returns the element, throwing IterationError.exhausted when done.
// Structs provide concrete Element type via 'implements Iterable with Type'.
export interface Iterable uses Element
  function createIterator()
  function next() returns Element throws IterationError
end 'Iterable'

// Extension methods for Iterable - available on all conforming types
export extension Iterable
  typealias ElementArray = Array with Element

  function map(transform(Element) returns Element) returns ElementArray
    var result = ElementArray{}
    for item in self 'loop'
      result.push(transform(item))
    end 'loop'
    return result
  end 'map'

  function contains(predicate(Element) returns bool) returns bool
    for item in self 'loop'
      if predicate(item) 'match'
        return true
      end 'match'
    end 'loop'
    return false
  end 'contains'

  typealias EnumSelf = EnumeratedIterator with Self, Element

  export function enumerated() returns EnumSelf
    return EnumSelf{source: self, _index: 0}
  end 'enumerated'
end 'Iterable'

// Stringable - enables custom types to participate in string interpolation
// Built-in types (int, float, bool, byte, character, string) are handled by the
// compiler directly and do not need to implement this interface.
// Implement this for user-defined types: "{myValue}" calls toString()
export interface Stringable
  function toString() returns String
end 'Stringable'

// FormattedStringable - enables format specifiers in string interpolation
// Implement this for user-defined types that support: "{myValue:format}"
// The format string after the colon is passed to toString(format)
export interface FormattedStringable
  function toString(format String) returns String
end 'FormattedStringable'

// Subscriptable - types that support range-based subscripting (slicing)
// Used for s[start..end], s[start..], s[..end] syntax
export interface Subscriptable
  function subscript(startIndex Index, endIndex Index) returns Self
end 'Subscriptable'

// InitableFromStringLiteral - types that can be initialized from string literals
// The compiler creates a String from the literal and passes it to init().
// This follows the Swift ExpressibleByStringLiteral pattern.
// Example: var x MyType = "hello" -> var x = MyType.init(String from literal)
export interface InitableFromStringLiteral
  static function init(value String) returns Self
end 'InitableFromStringLiteral'

// InitableFromCharLiteral - types that can be initialized from character literals
// Similar to InitableFromStringLiteral but for single-character literals like 'A' or '🎉'
// The compiler creates a Character from the literal and passes it to init().
export interface InitableFromCharLiteral
  static function init(value Character) returns Self
end 'InitableFromCharLiteral'

// InitableFromArrayLiteral - types that can be initialized from array literals
// The compiler creates an Array from the literal and passes it to init().
// This follows the Swift ExpressibleByArrayLiteral pattern.
// The compiler detects conformance and transforms: var x MyType = [1, 2, 3] -> var x = MyType.init(Array.init(managed))
// Note: Array itself is special-cased by the compiler (uses __ManagedMemory directly).
export interface InitableFromArrayLiteral uses Element
  typealias ElementArray = Array with Element
  static function init(value ElementArray) returns Self
end 'InitableFromArrayLiteral'

// InitableFromDictionaryLiteral - types that can be initialized from map literals
// Map literals use syntax: ["key1": value1, "key2": value2]
// The compiler creates two Arrays (keys and values) and passes them to init().
// Both arrays have the same length and corresponding indices represent key-value pairs.
// Note: Map itself is special-cased by the compiler (uses __ManagedMemory directly).
export interface InitableFromDictionaryLiteral uses Key, Value
  typealias KeyArray = Array with Key
  typealias ValueArray = Array with Value
  static function init(keys KeyArray, values ValueArray) returns Self
end 'InitableFromDictionaryLiteral'

export interface Parsable
  static function fromString(input String) returns Self throws Error
end 'Parsable'

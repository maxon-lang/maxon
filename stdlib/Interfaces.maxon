/// Cross-cutting protocol interfaces that don't belong to any one domain type:
/// Hashable, Equatable, Comparable, Cloneable, Iterator/BidirectionalIterator,
/// Iterable, Stringable/FormattedStringable, plus the base `Error` interface
/// that every error enum implements.
/// @category Core
export typealias HashValue = int(0 to u32.max)
export typealias IterStep = int(i64.min to i64.max)

// Error - marker interface for throwable error types
// Only enums can conform to Error. Error enums represent distinct error conditions
// and can be thrown and caught using try/throw/catch.
// Examples:
//   enum FileError implements Error
//       notFound
//       permissionDenied
//   end 'FileError'
//
//   enum HttpError int implements Error
//       notFound = 404
//       serverError = 500
//   end 'HttpError'
export interface Error
end 'Error'

// IterationError - errors for iterator navigation
// exhausted: advance() past the last element
// atStart:   retreat() before the first element
export enum IterationError implements Error
	exhausted
	atStart
end 'IterationError'

// Ordering - result of comparing two values
export enum Ordering
	lessThan
	equalTo
	greaterThan
end 'Ordering'

// Hashable - types that can be hashed to an integer
export interface Hashable
	function hash() returns HashValue
end 'Hashable'

// Equatable - types that can be compared for equality
export interface Equatable
	function equals(other Self) returns bool
end 'Equatable'

// Comparable - types that can be ordered
export interface Comparable
	function compare(other Self) returns Ordering
end 'Comparable'

// Cloneable - types that can be copied
export interface Cloneable
	function clone() returns Self
end 'Cloneable'

// Iterator - types that hold iteration state and produce elements one at a time.
//
// Positioning invariant: a live iterator always points at a valid element. This
// is established by the constructor (which throws IterationError.exhausted on
// empty) and preserved by every successful advance(). Because the invariant is
// maintained at every navigation site, current() has no error path — it just
// reads.
//
// current() returns the element at the current position (infallible) and
// remains callable for the lifetime of the iterator.
// advance() moves to the next element; throws IterationError.exhausted when
// called while positioned on the final element. A thrown advance() leaves the
// position unchanged, so current() still returns that final element.
export interface Iterator uses Element
	function current() returns Element
	function advance() throws IterationError
end 'Iterator'

// Extension methods for Iterator - available on all conforming types.
// advanceBy(n) defaults to calling advance() n times; concrete iterators may
// override with a faster implementation.
export extension Iterator
	export function advanceBy(n IterStep) throws IterationError
		var i = 0
		while i < n 'loop'
			try self.advance()
			i = i + 1
		end 'loop'
	end 'advanceBy'
end 'Iterator'

// BidirectionalIterator - iterators that can walk backward as well as forward.
// Types implementing this must also supply retreat(); retreatBy(n) is supplied
// as an extension method.
export interface BidirectionalIterator extends Iterator
	function retreat() throws IterationError
end 'BidirectionalIterator'

export extension BidirectionalIterator
	export function retreatBy(n IterStep) throws IterationError
		var i = 0
		while i < n 'loop'
			try self.retreat()
			i = i + 1
		end 'loop'
	end 'retreatBy'
end 'BidirectionalIterator'

// Iterable - types that can be iterated over (used by for-in loops).
// createIterator() returns a fresh Iterator for traversal. Each call produces an
// independent iterator, so nested for-in loops over the same collection work correctly.
// Conformance: implements Iterable with (ElementType, IteratorType)
export interface Iterable uses Element, Iter
	function createIterator() returns Iter
end 'Iterable'

// Extension methods for Iterable - available on all conforming types
export extension Iterable
	typealias ElementArray = Array with Element
	typealias ElementTransform = function(Element) returns Element
	typealias ElementPredicate = function(Element) returns bool

	function map(transform ElementTransform) returns ElementArray
		var result = ElementArray{}
		for item in self 'loop'
			result.push(transform(item))
		end 'loop'
		return result
	end 'map'

	function filter(keep ElementPredicate) returns ElementArray
		var result = ElementArray{}
		for item in self 'loop'
			if keep(item) 'match'
				result.push(item)
			end 'match'
		end 'loop'
		return result
	end 'filter'

	function contains(predicate ElementPredicate) returns bool
		for item in self 'loop'
			if predicate(item) 'match'
				return true
			end 'match'
		end 'loop'
		return false
	end 'contains'

	typealias WithIterSelf = WithIterIterator with Iter, Element

	export function withIterator() returns WithIterSelf throws IterationError
		let iter = try self.createIterator()
		return WithIterSelf.create(iter)
	end 'withIterator'
end 'Iterable'

// Stringable - enables custom types to participate in string interpolation
// Built-in types (int, float, bool, byte, character, string) are handled by the
// compiler directly and do not need to implement this interface.
// Implement this for user-defined types: "{myValue}" calls toString()
export interface Stringable
	function toString() returns String
end 'Stringable'

// FormattedStringable - enables format specifiers in string interpolation
// Implement this for user-defined types that support: "{myValue:format}"
// The format string after the colon is passed to toString(format)
export interface FormattedStringable
	function toString(format String) returns String
end 'FormattedStringable'

/// File reading, writing, and manipulation operations.
/// @category System

/// Error for file read operations
export enum FileReadError implements Error
  notFound
end 'FileReadError'

/// Error for file write operations
export enum FileWriteError implements Error
  failed
end 'FileWriteError'

/// Error for file delete operations
export enum FileDeleteError implements Error
  notFound
end 'FileDeleteError'

export typealias FileHandle = u32

export type File
  typealias Buffer = Array with byte

  /// Open file for reading, throwing if not found
  static function openForRead(path String) returns FileHandle throws FileReadError
    let handle = __file_open_read(path.cstr())
    if handle < 0 'notFound'
      throw FileReadError.notFound
    end 'notFound'
    return handle
  end 'openForRead'

  /// Read file into a managed memory
  static function readFileData(path String, extraBytes Count) returns __ManagedMemory throws FileReadError
    let handle = try openForRead(path)
    let size = __file_size(handle)
    var managed = __managed_memory_create(size + extraBytes, 1)
    let bytesRead = __file_read(handle, managed, size)
    __file_close(handle)
    __managed_memory_set_length(managed, bytesRead)
    return managed
  end 'readFileData'

  /// Read text file content as a UTF-8 string
  export static function readText(path String) returns String throws FileReadError
    var managed = try readFileData(path, extraBytes: 1)
    let len = __managed_memory_len(managed)
    __managed_memory_set_byte(managed, len, 0)
    return {_managed: managed, _iterPos: 0}
  end 'readText'

  /// Read file content as raw bytes
  export static function readBinary(path String) returns Buffer throws FileReadError
    var managed = try readFileData(path, extraBytes: 0)
    return {managed: managed, iterIndex: 0}
  end 'readBinary'

  /// Write string content to a text file
  export static function writeText(path String, content String) throws FileWriteError
    let res = __write_file(path.cstr(), content.cstr())
    if res != 0 'failed'
      throw FileWriteError.failed
    end 'failed'
  end 'writeText'

  /// Write binary content to a file
  export static function writeBinary(path String, content Buffer) throws FileWriteError
    let res = __write_file_binary(path.cstr(), content)
    if res != 0 'failed'
      throw FileWriteError.failed
    end 'failed'
  end 'writeBinary'

  /// Check if a file exists at the given path
  export static function exists(path String) returns bool
    let handle = __file_open_read(path.cstr())
    if handle < 0 'notFound'
      return false
    end 'notFound'
    __file_close(handle)
    return true
  end 'exists'

  /// Delete a file at the given path
  export static function delete(path String) throws FileDeleteError
    let res = __file_delete(path.cstr())
    if res != 0 'failed'
      throw FileDeleteError.notFound
    end 'failed'
  end 'delete'
end 'File'

/// Dynamic array with automatic growth and element access by index.
/// @category Collections

// Array receives __ManagedMemory directly for literal initialization via BuiltinArrayLiteral.
typealias Integer = int(min to max)
typealias Count = int(0 to max)
typealias Index = int(0 to max)

export type Array uses Element implements BuiltinArrayLiteral, Iterable with Element
  var iterIndex Integer          // Current iteration position (now at offset 0)
  var managed __ManagedMemory  // Compiler-managed opaque array storage (now at offset 8)

  // =========================================================================
  // Builtin initialization (compiler special-case)
  // =========================================================================

  // Default type for array literals - compiler discovers this via BuiltinArrayLiteral interface
  static function init(managed __ManagedMemory) returns Self
    return {managed: managed, iterIndex: 0}
  end 'init'

  // =========================================================================
  // Static Constructors
  // =========================================================================

  typealias ElementIterable = Iterable with Element

  /// Create an array by collecting all elements from an iterable
  export static function from(source ElementIterable) returns Self
    var result = Self{}
    for item in source 'collect'
      result.push(item)
    end 'collect'
    return result
  end 'from'

  // =========================================================================
  // Properties
  // =========================================================================

  /// Get the number of elements in the array
  export function count() returns Integer
    return __managed_memory_len(managed)
  end 'count'

  /// Get the current capacity (allocated space)
  export function capacity() returns Integer
    return __managed_memory_capacity(managed)
  end 'capacity'

  /// Check if array is empty
  export function isEmpty() returns bool
    return __managed_memory_len(managed) == 0
  end 'isEmpty'

  /// Get first element, throws if empty
  export function first() returns Element throws ArrayError
    if __managed_memory_len(managed) == 0 'empty'
      throw ArrayError.indexOutOfBounds
    end 'empty'
    return __managed_memory_get_unchecked(managed, 0)
  end 'first'

  /// Get last element, throws if empty
  export function last() returns Element throws ArrayError
    var len = __managed_memory_len(managed)
    if len == 0 'empty'
      throw ArrayError.indexOutOfBounds
    end 'empty'
    return __managed_memory_get_unchecked(managed, len - 1)
  end 'last'

  // =========================================================================
  // Element Access
  // =========================================================================

  /// Get element at index, throws if out of bounds
  export function get(index Integer) returns Element throws ArrayError
    var len = __managed_memory_len(managed)
    if index < 0 'lower'
      throw ArrayError.indexOutOfBounds
    end 'lower'
    if index >= len 'upper'
      throw ArrayError.indexOutOfBounds
    end 'upper'
    return __managed_memory_get_unchecked(managed, index)
  end 'get'

  /// Set element at index (no-op if index out of bounds)
  export function set(index Integer, value Element)
    var len = __managed_memory_len(managed)
    if index >= 0 'lower'
      if index < len 'upper'
        __managed_memory_set_at(managed, index, value)
      end 'upper'
    end 'lower'
  end 'set'

  // =========================================================================
  // Slicing
  // =========================================================================

  /// Create a new array from elements [start, endIndex)
  export function slice(start Integer, endIndex Integer) returns Self
    var len = __managed_memory_len(managed)
    var s = start
    var e = endIndex
    // Clamp to valid range
    if s < 0 'clamp_start'
      s = 0
    end 'clamp_start'
    if e > len 'clamp_end'
      e = len
    end 'clamp_end'
    if s >= e 'empty_slice'
      return {managed: __managed_memory_slice(managed, 0, 0), iterIndex: 0}
    end 'empty_slice'
    return {managed: __managed_memory_slice(managed, s, e), iterIndex: 0}
  end 'slice'

  // =========================================================================
  // Mutating Operations
  // =========================================================================

  /// Ensure capacity for at least requiredLen elements, growing if needed
  function ensureCapacity(requiredLen Integer)
    var cap = __managed_memory_capacity(managed)
    if requiredLen > cap 'grow'
      // Double capacity until sufficient, minimum 4
      var newCap = cap
      if newCap < 4 'min'
        newCap = 4
      end 'min'
      while newCap < requiredLen 'double'
        newCap = newCap * 2
      end 'double'
      __managed_memory_grow(managed, newCap)
    end 'grow'
  end 'ensureCapacity'

  /// Append element to end
  export function push(value Element)
    var len = __managed_memory_len(managed)
    ensureCapacity(len + 1)
    __managed_memory_set_at(managed, len, value)
    __managed_memory_set_length(managed, len + 1)
  end 'push'

  /// Append all elements from another array
  export function append(other Self)
    managed = __managed_memory_concat(managed, other.managed)
  end 'append'

  /// Remove and return last element, throws if empty
  export function pop() returns Element throws ArrayError
    var len = __managed_memory_len(managed)
    if len == 0 'empty'
      throw ArrayError.indexOutOfBounds
    end 'empty'
    var newLen = len - 1
    var value = __managed_memory_get_unchecked(managed, newLen)
    __managed_memory_set_length(managed, newLen)
    return value
  end 'pop'

  /// Insert element at index, shifting elements to the right (clamps index to [0, count])
  export function insert(at Integer, value Element)
    var len = __managed_memory_len(managed)
    var index = at

    // Clamp index to valid range
    if index < 0 'clamp_low'
      index = 0
    end 'clamp_low'
    if index > len 'clamp_high'
      index = len
    end 'clamp_high'

    // Ensure capacity
    ensureCapacity(len + 1)

    // Shift elements right to make room
    if index < len 'shift'
      __managed_memory_shift_right(managed, index, 1)
    end 'shift'

    // Insert element and update length
    __managed_memory_set_at(managed, index, value)
    __managed_memory_set_length(managed, len + 1)
  end 'insert'

  /// Remove and return element at index, shifting elements to the left (throws if out of bounds)
  export function remove(at Integer) returns Element throws ArrayError
    var len = __managed_memory_len(managed)

    // Check bounds
    if at < 0 'lower'
      throw ArrayError.indexOutOfBounds
    end 'lower'
    if at >= len 'upper'
      throw ArrayError.indexOutOfBounds
    end 'upper'

    // Save element before shifting
    var value = __managed_memory_get_unchecked(managed, at)

    // Shift elements left to fill gap
    if at < len - 1 'shift'
      __managed_memory_shift_left(managed, at, 1)
    end 'shift'

    __managed_memory_set_length(managed, len - 1)
    return value
  end 'remove'

  /// Remove all elements from the array (keeps capacity)
  export function clear()
    __managed_memory_set_length(managed, 0)
  end 'clear'

  // =========================================================================
  // Capacity Management
  // =========================================================================

  /// Reserve space by ensuring array has at least minCapacity slots
  export function reserve(minCapacity Integer)
    var cap = __managed_memory_capacity(managed)
    if minCapacity > cap 'grow'
      __managed_memory_grow(managed, minCapacity)
    end 'grow'
  end 'reserve'

  /// Resize array to newLength elements, allocating if needed
  /// New elements are zero-initialized
  export function resize(newLength Integer)
    reserve(newLength)
    __managed_memory_set_length(managed, newLength)
  end 'resize'

  // =========================================================================
  // Iterable Interface
  // =========================================================================

  /// Get next element in iteration, throws when exhausted
  function next() returns Element throws IterationError
    var len = __managed_memory_len(managed)
    if iterIndex >= len 'done'
      throw IterationError.exhausted
    end 'done'
    var value = __managed_memory_get_unchecked(managed, iterIndex)
    iterIndex = iterIndex + 1
    return value
  end 'next'
end 'Array'

// Conditional extension: contains is only available when Element is Equatable
export extension Array where Element is Equatable
  typealias ElementArray = Array with Element

  function contains(elements ElementArray) returns bool
    let selfLen = count()
    let elemLen = elements.count()

    if elemLen == 0 'empty'
      return true
    end 'empty'

    var i = 0
    while i <= selfLen - elemLen 'scan'
      var matched = true
      var j = 0
      while j < elemLen and matched 'cmp'
        let a = try get(i + j) otherwise 'a'
          break
        end 'a'
        let b = try elements.get(j) otherwise 'b'
          break
        end 'b'
        if a != b 'ne'
          matched = false
        end 'ne'
        j = j + 1
      end 'cmp'
      if matched 'found'
        return true
      end 'found'
      i = i + 1
    end 'scan'
    return false
  end 'contains'
end 'Array'

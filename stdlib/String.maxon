/// UTF-8 encoded immutable string with Unicode grapheme cluster iteration.
/// @category Text

// String receives __ManagedMemory directly for literal initialization via BuiltinStringLiteral.
export type String implements BuiltinStringLiteral, Hashable, Equatable, Iterable with Character
  var _managed __ManagedMemory
  var _iterPos Index

  // Default type for string literals - compiler discovers this via BuiltinStringLiteral interface
  static function init(managed __ManagedMemory) returns String
    return String{_managed: managed, _iterPos: 0}
  end 'init'

  /// Create a String from a raw null-terminated C string pointer
  export static function from(cstr cstring) returns String
    var managed = __cstring_to_managed(cstr)
    return String{_managed: managed, _iterPos: 0}
  end 'from'

  /// Create a String from a byte array (zero-copy slice of the array's backing memory)
  export static function from(bytes ByteArray) returns String
    return String{_managed: bytes.managed, _iterPos: 0}
  end 'from'

  /// Return the raw UTF-8 bytes as a ByteArray (zero-copy, shares backing memory)
  export function toByteArray() returns ByteArray
    return ByteArray{managed: _managed}
  end 'toByteArray'

  export function byteLength() returns Count
    return __managed_memory_len(_managed)
  end 'byteLength'

  export function isEmpty() returns bool
    return __managed_memory_len(_managed) == 0
  end 'isEmpty'

  /// Get grapheme cluster count (number of user-perceived characters)
  export function count() returns Count
    return countGraphemesManaged(_managed)
  end 'count'

  export function hash() returns HashValue
    return hashManagedString(_managed)
  end 'hash'

  export function equals(other String) returns bool
    var lenA = __managed_memory_len(_managed)
    var lenB = __managed_memory_len(other._managed)
    if lenA != lenB 'lenMismatch'
      return false
    end 'lenMismatch'
    var i = 0
    while i < lenA 'byteCheck'
      if __managed_memory_byte_at(_managed, i) != __managed_memory_byte_at(other._managed, i) 'mismatch'
        return false
      end 'mismatch'
      i = i + 1
    end 'byteCheck'
    return true
  end 'equals'

  export function next() returns Character throws IterationError
    if _iterPos < __managed_memory_len(_managed) 'check'
      var len = __managed_memory_len(_managed)
      var endPos = findGraphemeEndManaged(_managed, startPos: _iterPos, len: len)
      var graphemeLen = endPos - _iterPos
      let grapheme = _makeCharFromBytes(_iterPos, len: graphemeLen)
      _iterPos = endPos
      return grapheme
    end 'check'
    throw IterationError.exhausted
  end 'next'

  function _makeCharFromBytes(pos Index, len Count) returns Character
    return __make_char_from_bytes(_managed, pos, len)
  end '_makeCharFromBytes'

  // String index methods
  export function startIndex() returns StringIndex
    return StringIndex{_charIndex: 0, _bytePos: 0}
  end 'startIndex'

  export function endIndex() returns StringIndex
    var charCount = countGraphemesManaged(_managed)
    return StringIndex{_charIndex: charCount, _bytePos: __managed_memory_len(_managed)}
  end 'endIndex'

  /// Get character at the given index. Returns the grapheme cluster at that position.
  export function charAt(idx StringIndex) returns Character
    // Calculate the byte length of this grapheme at the given byte position
    var len = __managed_memory_len(_managed)
    var byteStart = idx.bytePos()
    var endPos = findGraphemeEndManaged(_managed, startPos: byteStart, len: len)
    var byteLen = endPos - byteStart
    return _makeCharFromBytes(byteStart, len: byteLen)
  end 'charAt'

  /// Get the index after the given position (for iteration)
  export function indexAfter(idx StringIndex) returns StringIndex throws StringError
    if idx.charIndex() >= countGraphemesManaged(_managed) 'atEnd'
      throw StringError.invalidIndex
    end 'atEnd'
    var len = __managed_memory_len(_managed)
    var byteStart = idx.bytePos()
    var endPos = findGraphemeEndManaged(_managed, startPos: byteStart, len: len)
    var byteLen = endPos - byteStart
    return StringIndex{_charIndex: idx.charIndex() + 1, _bytePos: byteStart + byteLen}
  end 'indexAfter'

  // concat method
  export function concat(other String) returns String
    var result = __managed_memory_concat(_managed, other._managed)
    return String{_managed: result, _iterPos: 0}
  end 'concat'

  // Search methods
  export function startsWith(prefix String) returns bool
    return startsWithManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: prefix._managed)
  end 'startsWith'

  export function endsWith(suffix String) returns bool
    return endsWithManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: suffix._managed)
  end 'endsWith'

  export function contains(needle String) returns bool
    if try findManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: needle._managed) 'found'
      return true
    end 'found'
    return false
  end 'contains'

  export function contains(character Character) returns bool
    var charStr = character.toString()
    if try findManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: charStr._managed) 'found'
      return true
    end 'found'
    return false
  end 'contains'

  export function findFirst(needle String) returns StringIndex throws StringError
    var byteIdx = try findManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: needle._managed)
    var charIdx = byteIndexToGraphemeIndex(_managed, byteIdx: byteIdx)
    return StringIndex{_charIndex: charIdx, _bytePos: byteIdx}
  end 'findFirst'

  export function findLast(needle String) returns StringIndex throws StringError
    var needleLen = __managed_memory_len(needle._managed)
    var selfLen = __managed_memory_len(_managed)
    var found = false
    var lastByteIdx = 0
    var searchPos = 0
    while searchPos <= selfLen - needleLen 'scan'
      if let idx = try findManaged(_managed, offset: searchPos, len: selfLen - searchPos, needle: needle._managed) 'try_find'
        lastByteIdx = searchPos + idx
        searchPos = lastByteIdx + 1
        found = true
      end 'try_find' else 'done'
        break 'scan'
      end 'done'
    end 'scan'
    if not found 'not_found'
      throw StringError.notFound
    end 'not_found'
    var charIdx = byteIndexToGraphemeIndex(_managed, byteIdx: lastByteIdx)
    return StringIndex{_charIndex: charIdx, _bytePos: lastByteIdx}
  end 'findLast'

  // Slicing - returns a new String backed by slice into this string's buffer
  // Use endIndex for end position, or length for character count
  export function slice(start StringIndex, endIndex StringIndex) returns String
    var result = __managed_memory_slice(_managed, start.bytePos(), endIndex.bytePos())
    return String{_managed: result, _iterPos: 0}
  end 'slice'

  export function slice(start StringIndex, length Count) returns String
    var endBytePos = graphemeOffsetToBytePos(_managed, startBytePos: start.bytePos(), count: length)
    var result = __managed_memory_slice(_managed, start.bytePos(), endBytePos)
    return String{_managed: result, _iterPos: 0}
  end 'slice'

  // View methods
  export function bytes() returns ByteView
    return ByteView{_managed: _managed, _pos: 0}
  end 'bytes'

  export function codepoints() returns CodepointView
    return CodepointView{_managed: _managed, _pos: 0}
  end 'codepoints'

  export function utf16() returns UTF16View
    return UTF16View{_managed: _managed, _bytePos: 0, _pendingCodepoint: 0}
  end 'utf16'

  /// Convert to a C-compatible null-terminated string for FFI operations
  /// For normal strings, shares the existing buffer (with refcount)
  /// For slices, allocates and copies to a new null-terminated buffer
  export function cstr() returns cstring
    return __managed_memory_to_cstring(_managed)
  end 'cstr'

  // Replace methods
  export function replace(old String, with String) returns String
    var oldLen = __managed_memory_len(old._managed)
    if oldLen == 0 'empty_old'
      return String{_managed: _managed, _iterPos: 0}
    end 'empty_old'

    var selfLen = __managed_memory_len(_managed)

    // First pass: count matches
    var matchCount = 0
    var searchPos = 0
    while searchPos <= selfLen - oldLen 'count_loop'
      if let idx = try findManaged(_managed, offset: searchPos, len: selfLen - searchPos, needle: old._managed) 'try_count'
        matchCount = matchCount + 1
        searchPos = searchPos + idx + oldLen
      end 'try_count' else 'done_count'
        break 'count_loop'
      end 'done_count'
    end 'count_loop'

    if matchCount == 0 'no_matches'
      return String{_managed: _managed, _iterPos: 0}
    end 'no_matches'

    // Build result by processing matches
    var builtResult = __managed_memory_slice(_managed, 0, 0)
    var pos = 0
    while pos <= selfLen - oldLen 'search'
      if let idx = try findManaged(_managed, offset: pos, len: selfLen - pos, needle: old._managed) 'try_find'
        var matchPos = pos + idx
        if matchPos > pos 'has_prefix'
          var prefixSlice = __managed_memory_slice(_managed, pos, matchPos)
          builtResult = __managed_memory_concat(builtResult, prefixSlice)
        end 'has_prefix'
        builtResult = __managed_memory_concat(builtResult, with._managed)
        pos = matchPos + oldLen
      end 'try_find' else 'no_more'
        break 'search'
      end 'no_more'
    end 'search'

    // Append remaining suffix
    if pos < selfLen 'has_suffix'
      var suffixSlice = __managed_memory_slice(_managed, pos, selfLen)
      builtResult = __managed_memory_concat(builtResult, suffixSlice)
    end 'has_suffix'

    return String{_managed: builtResult, _iterPos: 0}
  end 'replace'

  export function replaceFirst(old String, with String) returns String
    var oldLen = __managed_memory_len(old._managed)
    if oldLen == 0 'empty_old'
      return String{_managed: _managed, _iterPos: 0}
    end 'empty_old'

    if let idx = try findManaged(_managed, offset: 0, len: __managed_memory_len(_managed), needle: old._managed) 'try_find'
      var selfLen = __managed_memory_len(_managed)
      var prefixSlice = __managed_memory_slice(_managed, 0, idx)
      var suffixSlice = __managed_memory_slice(_managed, idx + oldLen, selfLen)
      var result = __managed_memory_concat(__managed_memory_concat(prefixSlice, with._managed), suffixSlice)
      return String{_managed: result, _iterPos: 0}
    end 'try_find'
    return String{_managed: _managed, _iterPos: 0}
  end 'replaceFirst'

  // Case conversion
  export function toLower() returns String
    var len = __managed_memory_len(_managed)
    if len == 0 'empty'
      return String{_managed: _managed, _iterPos: 0}
    end 'empty'

    var i = 0
    while i < len 'convert'
      var b = __managed_memory_byte_at(_managed, i)
      // ASCII uppercase A-Z (65-90) -> lowercase a-z (97-122)
      if b >= 65 and b <= 90 'is_upper'
        __managed_memory_set_byte(_managed, i, b + 32)
      end 'is_upper'
      i = i + 1
    end 'convert'
    return String{_managed: _managed, _iterPos: 0}
  end 'toLower'

  export function toUpper() returns String
    var len = __managed_memory_len(_managed)
    if len == 0 'empty'
      return String{_managed: _managed, _iterPos: 0}
    end 'empty'

    var i = 0
    while i < len 'convert'
      var b = __managed_memory_byte_at(_managed, i)
      // ASCII lowercase a-z (97-122) -> uppercase A-Z (65-90)
      if b >= 97 and b <= 122 'is_lower'
        __managed_memory_set_byte(_managed, i, b - 32)
      end 'is_lower'
      i = i + 1
    end 'convert'
    return String{_managed: _managed, _iterPos: 0}
  end 'toUpper'
end 'String'

// StringIndex type - type-safe string position
export type StringIndex implements Equatable, Comparable
  var _charIndex Index
  var _bytePos Index

  export function charIndex() returns Index
    return _charIndex
  end 'charIndex'

  export function bytePos() returns Index
    return _bytePos
  end 'bytePos'

  export function equals(other StringIndex) returns bool
    return _charIndex == other._charIndex
  end 'equals'

  export function compare(other StringIndex) returns Ordering
    if _charIndex < other._charIndex 'less'
      return Ordering.lessThan
    end 'less'
    if _charIndex > other._charIndex 'greater'
      return Ordering.greaterThan
    end 'greater'
    return Ordering.equalTo
  end 'compare'
end 'StringIndex'

function startsWithManaged(haystack __ManagedMemory, offset Index, len Count, needle __ManagedMemory) returns bool
  var prefixLen = __managed_memory_len(needle)

  if prefixLen > len 'length_check'
    return false
  end 'length_check'

  var i = 0
  while i < prefixLen 'compare_loop'
    if __managed_memory_byte_at(haystack, offset + i) != __managed_memory_byte_at(needle, i) 'byte_check'
      return false
    end 'byte_check'
    i = i + 1
  end 'compare_loop'
  return true
end 'startsWithManaged'

function endsWithManaged(haystack __ManagedMemory, offset Index, len Count, needle __ManagedMemory) returns bool
  var suffixLen = __managed_memory_len(needle)

  if suffixLen > len 'length_check'
    return false
  end 'length_check'

  var start = offset + (len - suffixLen)
  var i = 0
  while i < suffixLen 'compare_loop'
    if __managed_memory_byte_at(haystack, start + i) != __managed_memory_byte_at(needle, i) 'byte_check'
      return false
    end 'byte_check'
    i = i + 1
  end 'compare_loop'
  return true
end 'endsWithManaged'

function findManaged(haystack __ManagedMemory, offset Index, len Count, needle __ManagedMemory) returns Index throws StringError
  var needleLen = __managed_memory_len(needle)

  if needleLen == 0 'empty_needle'
    return 0
  end 'empty_needle'

  if needleLen > len 'too_long'
    throw StringError.notFound
  end 'too_long'

  var i = 0
  while i <= len - needleLen 'search_loop'
    var found = true
    var j = 0
    while j < needleLen 'compare_loop'
      if __managed_memory_byte_at(haystack, offset + i + j) != __managed_memory_byte_at(needle, j) 'byte_check'
        found = false
        break 'compare_loop'
      end 'byte_check'
      j = j + 1
    end 'compare_loop'

    if found 'found_check'
      return i
    end 'found_check'
    i = i + 1
  end 'search_loop'
  throw StringError.notFound
end 'findManaged'

// stdlib/string/char.maxon
// Char Type - Extended Grapheme Cluster (EGC) representing a user-perceived character
//
// A char represents what a user perceives as a single character, which may be
// composed of multiple Unicode codepoints (e.g., emoji sequences, combining marks).
//
// Memory Layout (16 bytes, identical to string):
// - Small Char (MSB of byte 15 = 0): UTF-8 data inline in bytes 0-14
// - Large Char (MSB of byte 15 = 1): Heap-allocated for sequences > 15 bytes
//
// The char type is NOT an alias for byte. UTF-8 characters can span multiple bytes:
// - 'A' = 1 byte (ASCII)
// - 'é' = 2 bytes (Latin Extended)
// - '中' = 3 bytes (CJK)
// - '🎉' = 4 bytes (Emoji)
// - '👨‍👩‍👧‍👦' = 25 bytes (Family emoji with ZWJ sequences)

// char struct - represents an Extended Grapheme Cluster
// Uses the same internal representation as string (_ManagedString)
export struct char is Equatable, Hashable, ExpressibleByCharLiteral
	var _managed _ManagedString  // Compiler-managed storage (same layout as string)

	// ============================================
	// ExpressibleByCharLiteral conformance
	// ============================================

	// Initialize char from compiler-constructed _ManagedString
	export function ExpressibleByCharLiteral.init(managed _ManagedString) char
		return char{_managed: managed}
	end 'init'

	// ============================================
	// Basic properties
	// ============================================

	// isEmpty - check if char is empty (should never be true for valid char)
	export function isEmpty() bool
		return __string_len(_managed) == 0
	end 'isEmpty'

	// ============================================
	// Conversion
	// ============================================

	// toString - convert char to string
	export function toString() string
		// Create a new string from the char's data
		return string{_managed: _managed, _iterPos: 0}
	end 'toString'

	// ============================================
	// Equatable conformance
	// ============================================

	export function Equatable.equals(other char) bool
		var len = __string_len(_managed)
		if len != __string_len(other._managed) 'length_check'
			return false
		end 'length_check'

		var i = 0
		while i < len 'compare_loop'
			if __string_byte_at(_managed, i) != __string_byte_at(other._managed, i) 'byte_check'
				return false
			end 'byte_check'
			i = i + 1
		end 'compare_loop'
		return true
	end 'equals'

	// ============================================
	// Hashable conformance
	// ============================================

	export function Hashable.hash() int
		var h = 5381
		var i = 0
		var len = __string_len(_managed)
		while i < len 'hash_loop'
			var b = __string_byte_at(_managed, i)
			h = h * 33 + (b as int)
			i = i + 1
		end 'hash_loop'
		return h
	end 'hash'

	// ============================================
	// View accessors
	// ============================================

	// codepoints - iterate over codepoints in this grapheme
	export function codepoints() CodepointView
		return CodepointView{_managed: _managed, _pos: 0}
	end 'codepoints'

	// bytes - iterate over raw UTF-8 bytes
	export function bytes() ByteView
		return ByteView{_managed: _managed, _pos: 0}
	end 'bytes'

	// utf16 - iterate over UTF-16 code units
	export function utf16() UTF16View
		return UTF16View{_managed: _managed, _bytePos: 0, _highSurrogate: 0}
	end 'utf16'

	// ============================================
	// Comparison (for ordering)
	// ============================================

	// Compare chars lexicographically by their UTF-8 bytes
	export function compareTo(other char) int
		var len1 = __string_len(_managed)
		var len2 = __string_len(other._managed)
		var minLen = len1
		if len2 < minLen 'min'
			minLen = len2
		end 'min'

		var i = 0
		while i < minLen 'compare_loop'
			var b1 = __string_byte_at(_managed, i) as int
			var b2 = __string_byte_at(other._managed, i) as int
			if b1 < b2 'less'
				return 0 - 1
			end 'less'
			if b1 > b2 'greater'
				return 1
			end 'greater'
			i = i + 1
		end 'compare_loop'

		// Equal prefix - shorter is less
		if len1 < len2 'len_less'
			return 0 - 1
		end 'len_less'
		if len1 > len2 'len_greater'
			return 1
		end 'len_greater'
		return 0
	end 'compareTo'
end 'char'

// ============================================
// Char Views
// ============================================

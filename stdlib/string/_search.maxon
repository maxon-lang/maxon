// stdlib/string/_search.maxon
// Internal search helpers for string types
//
// Purpose: Centralize string search algorithms to avoid duplication
//          across string and substring types.
//
// Unified Implementation: Uses __substring_parent_managed() and
//   __substring_byte_offset() intrinsics to allow substring to reuse
//   the managed string implementation with offset adjustment.
//
// Note: All search methods take string (not substring) as the needle parameter,
//       which simplifies implementation - we only need _ManagedString for needle.
//
// Maintenance: Single algorithm implementation - substring wrapper delegates
//              to managed version with parent string and offset.

// ============================================
// startsWith helpers
// ============================================

// startsWithManagedRange - Check if range in managed string starts with prefix
function startsWithManagedRange(haystack _ManagedString, offset int, len int, needle _ManagedString) bool
	var prefixLen = __string_len(needle)

	if prefixLen > len 'length_check'
		return false
	end 'length_check'

	var i = 0
	while i < prefixLen 'compare_loop'
		if __string_byte_at(haystack, offset + i) != __string_byte_at(needle, i) 'byte_check'
			return false
		end 'byte_check'
		i = i + 1
	end 'compare_loop'
	return true
end 'startsWithManagedRange'

/// Check if a _ManagedString starts with the given prefix
export function startsWithManaged(haystack _ManagedString, needle _ManagedString) bool
	return startsWithManagedRange(haystack, 0, __string_len(haystack), needle)
end 'startsWithManaged'

/// Check if a substring starts with the given prefix
export function startsWithSubstring(haystack substring, needle _ManagedString) bool
	var parent = __substring_parent_managed(haystack)
	var offset = __substring_byte_offset(haystack)
	var len = __substring_len(haystack)
	return startsWithManagedRange(parent, offset, len, needle)
end 'startsWithSubstring'

// ============================================
// endsWith helpers
// ============================================

// endsWithManagedRange - Check if range in managed string ends with suffix
function endsWithManagedRange(haystack _ManagedString, offset int, len int, needle _ManagedString) bool
	var suffixLen = __string_len(needle)

	if suffixLen > len 'length_check'
		return false
	end 'length_check'

	var start = offset + (len - suffixLen)
	var i = 0
	while i < suffixLen 'compare_loop'
		if __string_byte_at(haystack, start + i) != __string_byte_at(needle, i) 'byte_check'
			return false
		end 'byte_check'
		i = i + 1
	end 'compare_loop'
	return true
end 'endsWithManagedRange'

/// Check if a _ManagedString ends with the given suffix
export function endsWithManaged(haystack _ManagedString, needle _ManagedString) bool
	return endsWithManagedRange(haystack, 0, __string_len(haystack), needle)
end 'endsWithManaged'

/// Check if a substring ends with the given suffix
export function endsWithSubstring(haystack substring, needle _ManagedString) bool
	var parent = __substring_parent_managed(haystack)
	var offset = __substring_byte_offset(haystack)
	var len = __substring_len(haystack)
	return endsWithManagedRange(parent, offset, len, needle)
end 'endsWithSubstring'

// ============================================
// find helpers (naive string search)
// ============================================

// findManagedRange - Find first occurrence of needle in range, return relative index or -1
function findManagedRange(haystack _ManagedString, offset int, len int, needle _ManagedString) int
	var needleLen = __string_len(needle)

	if needleLen == 0 'empty_needle'
		return 0
	end 'empty_needle'

	if needleLen > len 'too_long'
		return 0 - 1
	end 'too_long'

	var i = 0
	while i <= len - needleLen 'search_loop'
		var found = true
		var j = 0
		while j < needleLen 'compare_loop'
			if __string_byte_at(haystack, offset + i + j) != __string_byte_at(needle, j) 'byte_check'
				found = false
				break 'compare_loop'
			end 'byte_check'
			j = j + 1
		end 'compare_loop'

		if found 'found_check'
			return i
		end 'found_check'
		i = i + 1
	end 'search_loop'
	return 0 - 1
end 'findManagedRange'

/// Find the first occurrence of needle in a _ManagedString
/// Returns the byte index of the match, or -1 if not found
export function findManaged(haystack _ManagedString, needle _ManagedString) int
	return findManagedRange(haystack, 0, __string_len(haystack), needle)
end 'findManaged'

/// Find the first occurrence of needle in a substring
/// Returns the byte index of the match, or -1 if not found
export function findSubstring(haystack substring, needle _ManagedString) int
	var parent = __substring_parent_managed(haystack)
	var offset = __substring_byte_offset(haystack)
	var len = __substring_len(haystack)
	return findManagedRange(parent, offset, len, needle)
end 'findSubstring'

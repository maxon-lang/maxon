// stdlib/string/_search.maxon
// Internal search helpers for string types
//
// Purpose: Centralize string search algorithms for string types.

// ============================================
// startsWith helpers
// ============================================

// startsWithManagedRange - Check if range in managed string starts with prefix
function startsWithManagedRange(haystack __ManagedString, offset int, len int, needle __ManagedString) returns bool
	var prefixLen = __string_len(needle)

	if prefixLen > len 'length_check'
		return false
	end 'length_check'

	var i = 0
	while i < prefixLen 'compare_loop'
		if __string_byte_at(haystack, offset + i) != __string_byte_at(needle, i) 'byte_check'
			return false
		end 'byte_check'
		i = i + 1
	end 'compare_loop'
	return true
end 'startsWithManagedRange'

/// Check if a __ManagedString starts with the given prefix
export function startsWithManaged(haystack __ManagedString, needle __ManagedString) returns bool
	return startsWithManagedRange(haystack, 0, __string_len(haystack), needle)
end 'startsWithManaged'

// ============================================
// endsWith helpers
// ============================================

// endsWithManagedRange - Check if range in managed string ends with suffix
function endsWithManagedRange(haystack __ManagedString, offset int, len int, needle __ManagedString) returns bool
	var suffixLen = __string_len(needle)

	if suffixLen > len 'length_check'
		return false
	end 'length_check'

	var start = offset + (len - suffixLen)
	var i = 0
	while i < suffixLen 'compare_loop'
		if __string_byte_at(haystack, start + i) != __string_byte_at(needle, i) 'byte_check'
			return false
		end 'byte_check'
		i = i + 1
	end 'compare_loop'
	return true
end 'endsWithManagedRange'

/// Check if a __ManagedString ends with the given suffix
export function endsWithManaged(haystack __ManagedString, needle __ManagedString) returns bool
	return endsWithManagedRange(haystack, 0, __string_len(haystack), needle)
end 'endsWithManaged'

// ============================================
// find helpers (naive string search)
// ============================================

// findManagedRange - Find first occurrence of needle in range, return relative index or -1
function findManagedRange(haystack __ManagedString, offset int, len int, needle __ManagedString) returns int
	var needleLen = __string_len(needle)

	if needleLen == 0 'empty_needle'
		return 0
	end 'empty_needle'

	if needleLen > len 'too_long'
		return 0 - 1
	end 'too_long'

	var i = 0
	while i <= len - needleLen 'search_loop'
		var found = true
		var j = 0
		while j < needleLen 'compare_loop'
			if __string_byte_at(haystack, offset + i + j) != __string_byte_at(needle, j) 'byte_check'
				found = false
				break 'compare_loop'
			end 'byte_check'
			j = j + 1
		end 'compare_loop'

		if found 'found_check'
			return i
		end 'found_check'
		i = i + 1
	end 'search_loop'
	return 0 - 1
end 'findManagedRange'

/// Find the first occurrence of needle in a __ManagedString
/// Returns the byte index of the match, or -1 if not found
export function findManaged(haystack __ManagedString, needle __ManagedString) returns int
	return findManagedRange(haystack, 0, __string_len(haystack), needle)
end 'findManaged'

// stdlib/string/Character.maxon
// Character type - minimal implementation for basic character support
//
// A character represents an Extended Grapheme Cluster (EGC).
// Uses same __ManagedString storage as String.

export type Character is Hashable, Equatable, InitableFromCharLiteral
	var _managed __ManagedString

	// InitableFromCharLiteral conformance
	static function InitableFromCharLiteral.init(managed __ManagedString) returns Character
		return Character{_managed: managed}
	end 'init'

	// Basic properties
	export function byteLength() returns int
		return __string_len(_managed)
	end 'byteLength'

	// View methods - returns ByteView for iterating over raw UTF-8 bytes
	export function bytes() returns ByteView
		return ByteView{_managed: _managed, _pos: 0}
	end 'bytes'

	// Equatable conformance
	function Equatable.equals(other Character) returns bool
		var len1 = __string_len(_managed)
		var len2 = __string_len(other._managed)
		if len1 != len2 'length_check'
			return false
		end 'length_check'
		var i = 0
		while i < len1 'compare_loop'
			if __string_byte_at(_managed, i) != __string_byte_at(other._managed, i) 'byte_check'
				return false
			end 'byte_check'
			i = i + 1
		end 'compare_loop'
		return true
	end 'equals'

	// Hashable conformance (djb2 hash algorithm)
	function Hashable.hash() returns int
		var h = 5381
		var len = __string_len(_managed)
		var i = 0
		while i < len 'hash_loop'
			var b = __string_byte_at(_managed, i) as int
			h = h * 33 + b
			i = i + 1
		end 'hash_loop'
		return h
	end 'hash'

	// Returns ASCII value (0-127) for single-byte ASCII characters, nil otherwise
	export function asciiValue() returns int?
		var len = __string_len(_managed)
		if len != 1 'check_len'
			return nil
		end 'check_len'
		var b = __string_byte_at(_managed, 0)
		if b >= 128 'check_ascii'
			return nil
		end 'check_ascii'
		return b as int
	end 'asciiValue'
end 'Character'

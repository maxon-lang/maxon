// UTF-8 utility functions for string processing
//
// UTF-8 encoding:
//   1-byte (ASCII):  0xxxxxxx         (0x00-0x7F)
//   2-byte:          110xxxxx 10xxxxxx (0x80-0x7FF)
//   3-byte:          1110xxxx 10xxxxxx 10xxxxxx (0x800-0xFFFF)
//   4-byte:          11110xxx 10xxxxxx 10xxxxxx 10xxxxxx (0x10000-0x10FFFF)

/// Get the number of bytes in a UTF-8 sequence from its lead byte
/// Returns 1-4 for valid lead bytes
export function utf8ByteLength(leadByte byte) returns int
	// ASCII (0xxxxxxx)
	if leadByte < 128 'ascii'
		return 1
	end 'ascii'

	// Invalid continuation byte or overlong encoding
	if leadByte < 192 'invalid'
		return 1
	end 'invalid'

	// 2-byte sequence (110xxxxx)
	if leadByte < 224 'two_byte'
		return 2
	end 'two_byte'

	// 3-byte sequence (1110xxxx)
	if leadByte < 240 'three_byte'
		return 3
	end 'three_byte'

	// 4-byte sequence (11110xxx)
	return 4
end 'utf8ByteLength'

/// Check if a byte is a UTF-8 continuation byte (10xxxxxx)
export function utf8IsContinuation(b byte) returns bool
	return b >= 128 and b < 192
end 'utf8IsContinuation'

/// Check if a byte is a valid UTF-8 lead byte
export function utf8IsLead(b byte) returns bool
	// Lead byte is either ASCII (< 128) or starts with 11xxxxxx (>= 192)
	return b < 128 or b >= 192
end 'utf8IsLead'

/// Check if a byte is ASCII (0-127)
export function utf8IsAscii(b byte) returns bool
	return b < 128
end 'utf8IsAscii'

/// Count the number of UTF-8 codepoints in a byte array
/// This counts lead bytes only (skips continuation bytes)
export function utf8CodepointCount(data Array of byte, len int) returns int
	var count = 0
	var i = 0

	while i < len 'count_loop'
		var b = try data.get(i) otherwise 0

		// Only count non-continuation bytes
		if b < 128 or b >= 192 'is_lead'
			count = count + 1
		end 'is_lead'

		i = i + 1
	end 'count_loop'

	return count
end 'utf8CodepointCount'

/// Decode a UTF-8 codepoint from a byte array at the given offset
/// Returns the codepoint value as an integer
/// Assumes valid UTF-8 encoding at the offset
export function utf8Decode(data Array of byte, offset int) returns int
	var b0 = try data.get(offset) otherwise 0

	// ASCII (1 byte): 0xxxxxxx
	if b0 < 128 'ascii'
		return b0
	end 'ascii'

	// 2-byte sequence: 110xxxxx 10xxxxxx
	if b0 < 224 'two_byte'
		var b1 = try data.get(index: offset + 1) otherwise 0
		var cp = ((b0 mod 32) * 64) + (b1 mod 64)
		return cp
	end 'two_byte'

	// 3-byte sequence: 1110xxxx 10xxxxxx 10xxxxxx
	if b0 < 240 'three_byte'
		var b1 = try data.get(index: offset + 1) otherwise 0
		var b2 = try data.get(index: offset + 2) otherwise 0
		var cp = ((b0 mod 16) * 4096) + ((b1 mod 64) * 64) + (b2 mod 64)
		return cp
	end 'three_byte'

	// 4-byte sequence: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx
	var b1 = try data.get(index: offset + 1) otherwise 0
	var b2 = try data.get(index: offset + 2) otherwise 0
	var b3 = try data.get(index: offset + 3) otherwise 0
	var cp = ((b0 mod 8) * 262144) + ((b1 mod 64) * 4096) + ((b2 mod 64) * 64) + (b3 mod 64)
	return cp
end 'utf8Decode'

/// Get the number of bytes needed to encode a codepoint in UTF-8
export function utf8EncodeLength(codepoint int) returns int
	if codepoint < 128 'ascii'
		return 1
	end 'ascii'

	if codepoint < 2048 'two_byte'
		return 2
	end 'two_byte'

	if codepoint < 65536 'three_byte'
		return 3
	end 'three_byte'

	return 4
end 'utf8EncodeLength'

/// Check if an integer is a valid Unicode codepoint
/// Returns false for negative values, values > 0x10FFFF, and surrogate pairs (0xD800-0xDFFF)
export function utf8IsValidCodepoint(cp int) returns bool
	// Valid range: 0x0000-0x10FFFF, excluding surrogate pairs (0xD800-0xDFFF)
	if cp < 0 or cp > 1114111 'range_check'
		return false
	end 'range_check'

	// Exclude surrogate pairs
	if cp >= 55296 and cp <= 57343 'surrogate_check'
		return false
	end 'surrogate_check'

	return true
end 'utf8IsValidCodepoint'

// ============================================
// __ManagedMemory helpers (for internal use by string views)
// ============================================

/// Get the UTF-8 sequence length from the lead byte in a __ManagedMemory
export function utf8ByteLengthAt(managed __ManagedMemory, pos int) returns int
	var b0 = __managed_memory_byte_at(managed, pos)
	if b0 < 128 'ascii'
		return 1
	end 'ascii'
	if b0 < 224 'two'
		return 2
	end 'two'
	if b0 < 240 'three'
		return 3
	end 'three'
	return 4
end 'utf8ByteLengthAt'

/// Decode a UTF-8 codepoint from a __ManagedMemory at the given position
export function utf8DecodeAt(managed __ManagedMemory, pos int) returns int
	var b0 = __managed_memory_byte_at(managed, pos)
	if b0 < 128 'ascii'
		return b0
	end 'ascii'
	if b0 < 224 'two'
		var b1 = __managed_memory_byte_at(managed, pos + 1)
		return ((b0 mod 32) * 64) + (b1 mod 64)
	end 'two'
	if b0 < 240 'three'
		var b1 = __managed_memory_byte_at(managed, pos + 1)
		var b2 = __managed_memory_byte_at(managed, pos + 2)
		return ((b0 mod 16) * 4096) + ((b1 mod 64) * 64) + (b2 mod 64)
	end 'three'
	var b1 = __managed_memory_byte_at(managed, pos + 1)
	var b2 = __managed_memory_byte_at(managed, pos + 2)
	var b3 = __managed_memory_byte_at(managed, pos + 3)
	return ((b0 mod 8) * 262144) + ((b1 mod 64) * 4096) + ((b2 mod 64) * 64) + (b3 mod 64)
end 'utf8DecodeAt'

// stdlib/string/_hash.maxon
// Internal hash and equality helpers for string types
//
// Purpose: Centralize hash and equality algorithms to avoid duplication
//          across string, substring, and character types.
//
// Unified Implementation: Uses __substring_parent_managed() and
//   __substring_byte_offset() intrinsics to allow substring to reuse
//   the managed string implementation with offset adjustment.
//
// Maintenance: Single algorithm implementation - substring wrapper delegates
//              to managed version with parent string and offset.

// ============================================
// Hash helpers (djb2 algorithm)
// ============================================

// hashManagedStringRange - Hash a range in _ManagedString using djb2
function hashManagedStringRange(managed _ManagedString, offset int, len int) int
	var h = 5381
	var i = 0
	while i < len 'hash_loop'
		var b = __string_byte_at(managed, offset + i)
		h = h * 33 + (b as int)
		i = i + 1
	end 'hash_loop'
	return h
end 'hashManagedStringRange'

/// Hash a _ManagedString using the djb2 algorithm
/// Returns a 32-bit hash value
export function hashManagedString(managed _ManagedString) int
	return hashManagedStringRange(managed, 0, __string_len(managed))
end 'hashManagedString'

/// Hash a substring using the djb2 algorithm
/// Returns a 32-bit hash value
export function hashSubstring(sub substring) int
	var parent = __substring_parent_managed(sub)
	var offset = __substring_byte_offset(sub)
	var len = __substring_len(sub)
	return hashManagedStringRange(parent, offset, len)
end 'hashSubstring'

// ============================================
// Equality helpers (byte-by-byte comparison)
// ============================================

// equalsManagedStringRange - Compare two ranges in _ManagedStrings
function equalsManagedStringRange(a _ManagedString, aOffset int, b _ManagedString, bOffset int, len int) bool
	var i = 0
	while i < len 'compare_loop'
		if __string_byte_at(a, aOffset + i) != __string_byte_at(b, bOffset + i) 'byte_check'
			return false
		end 'byte_check'
		i = i + 1
	end 'compare_loop'
	return true
end 'equalsManagedStringRange'

/// Compare two _ManagedStrings for byte-by-byte equality
export function equalsManagedString(a _ManagedString, b _ManagedString) bool
	var len = __string_len(a)
	if len != __string_len(b) 'length_check'
		return false
	end 'length_check'
	return equalsManagedStringRange(a, 0, b, 0, len)
end 'equalsManagedString'

/// Compare two substrings for byte-by-byte equality
export function equalsSubstring(a substring, b substring) bool
	var len = __substring_len(a)
	if len != __substring_len(b) 'length_check'
		return false
	end 'length_check'

	var aParent = __substring_parent_managed(a)
	var aOffset = __substring_byte_offset(a)
	var bParent = __substring_parent_managed(b)
	var bOffset = __substring_byte_offset(b)

	return equalsManagedStringRange(aParent, aOffset, bParent, bOffset, len)
end 'equalsSubstring'


// Internal grapheme cluster helpers for string types
//
// Purpose: Centralize grapheme cluster operations (UAX #29 algorithm)
//          to avoid duplication across string and substring types.
//
// Unified Implementation: Uses __substring_parent_managed() and
//   __substring_byte_offset() intrinsics to allow substring to reuse
//   the managed string implementation with offset adjustment.
//
// Maintenance: Single algorithm implementation - substring wrapper delegates
//              to managed version with parent string and offset.

// ============================================
// Find grapheme end helpers (UAX #29)
// ============================================

// findGraphemeEndManagedRange - Find end of grapheme cluster in range
function findGraphemeEndManagedRange(managed _ManagedString, offset int, startPos int, len int) returns int
	if startPos >= len 'atEnd'
		return startPos
	end 'atEnd'

	// Decode first codepoint at startPos (with offset)
	var pos = startPos
	var absPos = offset + pos
	var prevCp = utf8DecodeAt(managed, absPos)
	var prevBytes = utf8ByteLengthAt(managed, absPos)
	pos = pos + prevBytes

	// Get grapheme break property for first codepoint
	var prevGbp = graphemeBreakProperty(prevCp)
	var state = graphemeStateInit()
	state = graphemeStateUpdate(state, prevGbp, prevCp)

	// Scan forward until we find a grapheme break
	while pos < len 'scan'
		absPos = offset + pos
		var currCp = utf8DecodeAt(managed, absPos)
		var currGbp = graphemeBreakProperty(currCp)

		// Check if there's a break before current codepoint
		if isGraphemeBreak(prevGbp, currGbp, prevCp, currCp, state) 'breakFound'
			return pos
		end 'breakFound'

		// Update state and advance to next codepoint
		state = graphemeStateUpdate(state, currGbp, currCp)
		prevGbp = currGbp
		prevCp = currCp
		var currBytes = utf8ByteLengthAt(managed, absPos)
		pos = pos + currBytes
	end 'scan'

	return pos
end 'findGraphemeEndManagedRange'

/// Find the end of the grapheme cluster in a _ManagedString starting at startPos
/// Returns the byte offset of the end of the grapheme cluster
export function findGraphemeEndManaged(managed _ManagedString, startPos int, len int) returns int
	return findGraphemeEndManagedRange(managed, 0, startPos, len)
end 'findGraphemeEndManaged'

/// Find the end of the grapheme cluster in a substring starting at startPos
/// Returns the byte offset of the end of the grapheme cluster
export function findGraphemeEndSubstring(sub substring, startPos int, len int) returns int
	var parent = __substring_parent_managed(sub)
	var offset = __substring_byte_offset(sub)
	return findGraphemeEndManagedRange(parent, offset, startPos, len)
end 'findGraphemeEndSubstring'

// ============================================
// Count grapheme helpers
// ============================================

// countGraphemesManagedRange - Count grapheme clusters in range
function countGraphemesManagedRange(managed _ManagedString, offset int, len int) returns int
	var graphemeCount = 0
	var pos = 0
	while pos < len 'countLoop'
		pos = findGraphemeEndManagedRange(managed, offset, pos, len)
		graphemeCount = graphemeCount + 1
	end 'countLoop'
	return graphemeCount
end 'countGraphemesManagedRange'

/// Count the total number of grapheme clusters in a _ManagedString
export function countGraphemesManaged(managed _ManagedString) returns int
	return countGraphemesManagedRange(managed, 0, __string_len(managed))
end 'countGraphemesManaged'

/// Count the total number of grapheme clusters in a substring
export function countGraphemesSubstring(sub substring) returns int
	var parent = __substring_parent_managed(sub)
	var offset = __substring_byte_offset(sub)
	var len = __substring_len(sub)
	return countGraphemesManagedRange(parent, offset, len)
end 'countGraphemesSubstring'

// Grapheme_Cluster_Break property values (used as return values):
//   0 = Other, 1 = CR, 2 = LF, 3 = Control, 4 = Extend, 5 = ZWJ,
//   6 = Regional_Indicator, 7 = Prepend, 8 = SpacingMark,
//   9 = L, 10 = V, 11 = T, 12 = LV, 13 = LVT

// Get Grapheme_Cluster_Break property for a codepoint
// Returns: 0=Other, 1=CR, 2=LF, 3=Control, 4=Extend, 5=ZWJ,
//          6=Regional_Indicator, 7=Prepend, 8=SpacingMark,
//          9=L, 10=V, 11=T, 12=LV, 13=LVT
function graphemeBreakProperty(cp int) returns int
	// CR (return 1)
	if cp == 13 'cr'
		return 1
	end 'cr'

	// LF (return 2)
	if cp == 10 'lf'
		return 2
	end 'lf'

	// Control characters (return 3)
	if cp < 32 or (cp >= 127 and cp < 160) 'control'
		return 3
	end 'control'

	// ZWJ U+200D (return 5)
	if cp == 8205 'zwj'
		return 5
	end 'zwj'

	// Regional Indicators U+1F1E6..U+1F1FF (return 6)
	if cp >= 127462 and cp <= 127487 'ri'
		return 6
	end 'ri'

	// Hangul syllables U+AC00..U+D7A3
	if cp >= 44032 and cp <= 55203 'hangul'
		var sindex = cp - 44032
		if sindex mod 28 == 0 'lv'
			return 12  // LV
		end 'lv' else 'lvt'
		return 13  // LVT
	end 'lvt'
end 'hangul'

// Hangul Jamo L U+1100..U+115F (return 9)
if cp >= 4352 and cp <= 4447 'jamo_l'
	return 9
end 'jamo_l'

// Hangul Jamo V U+1160..U+11A7 (return 10)
if cp >= 4448 and cp <= 4519 'jamo_v'
	return 10
end 'jamo_v'

// Hangul Jamo T U+11A8..U+11FF (return 11)
if cp >= 4520 and cp <= 4607 'jamo_t'
	return 11
end 'jamo_t'

// Skin tone modifiers U+1F3FB..U+1F3FF (return 4 = Extend)
if cp >= 127995 and cp <= 127999 'skin_tone'
	return 4
end 'skin_tone'

// Variation selectors U+FE00..U+FE0F (return 4 = Extend)
if cp >= 65024 and cp <= 65039 'vs'
	return 4
end 'vs'

// Combining Diacritical Marks U+0300..U+036F (return 4 = Extend)
if cp >= 768 and cp <= 879 'combining'
	return 4
end 'combining'

// Format characters that are Control (return 3)
// ZWSP U+200B, LRM/RLM U+200E-200F, Line/Para separators U+2028-202E
if cp == 8203 or (cp >= 8206 and cp <= 8207) or (cp >= 8232 and cp <= 8238) 'format_control'
	return 3
end 'format_control'

// ZWNJ U+200C (return 4 = Extend)
if cp == 8204 'zwnj'
	return 4
end 'zwnj'

// Other (return 0)
return 0
end 'graphemeBreakProperty'

// Check if codepoint has Extended_Pictographic property (emoji base)
function isExtendedPictographic(cp int) returns bool
	// Basic emoji range U+1F600..U+1F64F
	if cp >= 128512 and cp <= 128591 'emoji_faces'
		return true
	end 'emoji_faces'

	// Emoji symbols U+1F300..U+1F5FF
	if cp >= 127744 and cp <= 128511 'emoji_symbols'
		return true
	end 'emoji_symbols'

	// Transport and map symbols U+1F680..U+1F6FF
	if cp >= 128640 and cp <= 128767 'emoji_transport'
		return true
	end 'emoji_transport'

	// Supplemental symbols U+1F900..U+1F9FF
	if cp >= 129280 and cp <= 129535 'emoji_supp'
		return true
	end 'emoji_supp'

	// Additional emoji U+1FA00..U+1FAFF
	if cp >= 129536 and cp <= 130047 'emoji_extra'
		return true
	end 'emoji_extra'

	// Miscellaneous symbols U+2600..U+26FF
	if cp >= 9728 and cp <= 9983 'misc_symbols'
		return true
	end 'misc_symbols'

	// Dingbats U+2700..U+27BF
	if cp >= 9984 and cp <= 10175 'dingbats'
		return true
	end 'dingbats'

	return false
end 'isExtendedPictographic'

// State for tracking complex grapheme sequences
struct GraphemeState
	var riCount int           // Count of consecutive Regional Indicators (for GB12-13)
	var inEmojiSeq bool      // Inside Extended_Pictographic...ZWJ sequence (for GB11)
end 'GraphemeState'

// Create initial grapheme state
function graphemeStateInit() returns GraphemeState
	return GraphemeState{riCount: 0, inEmojiSeq: false}
end 'graphemeStateInit'

// Check if there should be a grapheme break between two codepoints
// prevGbp: Grapheme_Cluster_Break property of previous codepoint
// currGbp: Grapheme_Cluster_Break property of current codepoint
// prevCp: Previous codepoint value (needed for Extended_Pictographic check)
// currCp: Current codepoint value (needed for Extended_Pictographic check)
// state: State for tracking RI counts and emoji sequences
//
// Returns true if there should be a break BEFORE the current codepoint
function isGraphemeBreak(prevGbp int, currGbp int, prevCp int, currCp int, state GraphemeState) returns bool
	// Use prevCp to avoid unused parameter warning (reserved for future Extended_Pictographic checks)
	var unused = prevCp
	unused = unused

	// GB3: Do not break between CR and LF (CR × LF)
	// prevGbp == 1 (CR) and currGbp == 2 (LF)
	if prevGbp == 1 and currGbp == 2 'gb3'
		return false
	end 'gb3'

	// GB4: Break after Control, CR, or LF
	// prevGbp == 3 (Control) or prevGbp == 1 (CR) or prevGbp == 2 (LF)
	if prevGbp == 3 or prevGbp == 1 or prevGbp == 2 'gb4'
		return true
	end 'gb4'

	// GB5: Break before Control, CR, or LF
	if currGbp == 3 or currGbp == 1 or currGbp == 2 'gb5'
		return true
	end 'gb5'

	// GB6: Do not break Hangul syllable sequences (L × L/V/LV/LVT)
	// prevGbp == 9 (L)
	if prevGbp == 9 'gb6'
		// currGbp == 9 (L), 10 (V), 12 (LV), or 13 (LVT)
		if currGbp == 9 or currGbp == 10 or currGbp == 12 or currGbp == 13 'gb6_inner'
			return false
		end 'gb6_inner'
	end 'gb6'

	// GB7: Do not break Hangul syllable sequences (LV/V × V/T)
	// prevGbp == 12 (LV) or 10 (V)
	if prevGbp == 12 or prevGbp == 10 'gb7'
		// currGbp == 10 (V) or 11 (T)
		if currGbp == 10 or currGbp == 11 'gb7_inner'
			return false
		end 'gb7_inner'
	end 'gb7'

	// GB8: Do not break Hangul syllable sequences (LVT/T × T)
	// prevGbp == 13 (LVT) or 11 (T)
	if prevGbp == 13 or prevGbp == 11 'gb8'
		// currGbp == 11 (T)
		if currGbp == 11 'gb8_inner'
			return false
		end 'gb8_inner'
	end 'gb8'

	// GB9: Do not break before Extend or ZWJ (× Extend/ZWJ)
	// currGbp == 4 (Extend) or 5 (ZWJ)
	if currGbp == 4 or currGbp == 5 'gb9'
		return false
	end 'gb9'

	// GB9a: Do not break before SpacingMark (× SpacingMark)
	// currGbp == 8 (SpacingMark)
	if currGbp == 8 'gb9a'
		return false
	end 'gb9a'

	// GB9b: Do not break after Prepend (Prepend ×)
	// prevGbp == 7 (Prepend)
	if prevGbp == 7 'gb9b'
		return false
	end 'gb9b'

	// GB11: Do not break within emoji ZWJ sequences
	// \p{Extended_Pictographic} Extend* ZWJ × \p{Extended_Pictographic}
	// prevGbp == 5 (ZWJ)
	if prevGbp == 5 and isExtendedPictographic(currCp) 'gb11'
		if state.inEmojiSeq 'gb11_check'
			return false
		end 'gb11_check'
	end 'gb11'

	// GB12-13: Do not break within emoji flag sequences
	// Only pair up RIs; odd-numbered RIs break before next RI
	// prevGbp == 6 (Regional_Indicator) and currGbp == 6
	if prevGbp == 6 and currGbp == 6 'gb12'
		if state.riCount mod 2 == 1 'gb12_odd'
			return false
		end 'gb12_odd'
	end 'gb12'

	// GB999: Otherwise, break everywhere
	return true
end 'isGraphemeBreak'

// Update grapheme state after processing a codepoint
function graphemeStateUpdate(state GraphemeState, gbp int, cp int) returns GraphemeState
	var new_state = GraphemeState{riCount: 0, inEmojiSeq: false}

	// Track Regional Indicator sequences (gbp == 6)
	if gbp == 6 'ri_update'
		new_state.riCount = state.riCount + 1
	end 'ri_update'

	// Track emoji sequences for GB11
	if isExtendedPictographic(cp) 'emoji_base'
		new_state.inEmojiSeq = true
	end 'emoji_base' else 'not_emoji_base'
	if state.inEmojiSeq 'emoji_continue'
		// gbp == 4 (Extend) or 5 (ZWJ)
		if gbp == 4 or gbp == 5 'emoji_extend'
			new_state.inEmojiSeq = true
		end 'emoji_extend'
	end 'emoji_continue'
end 'not_emoji_base'

return new_state
end 'graphemeStateUpdate'

/// Find the next grapheme cluster boundary in UTF-8 data
/// Returns the byte offset of the next boundary, or len if at end
export function nextGraphemeBoundary(data array of byte, len int, offset int) returns int
	if offset >= len 'at_end'
		return len
	end 'at_end'

	// Decode first codepoint
	var pos = offset
	var prevCp = utf8Decode(data, pos)
	var prevGbp = graphemeBreakProperty(prevCp)
	var prevLen = utf8ByteLength(data[pos])
	pos = pos + prevLen

	// Initialize state
	var state = graphemeStateInit()
	state = graphemeStateUpdate(state, prevGbp, prevCp)

	// Scan forward looking for a break
	while pos < len 'scan'
		var currCp = utf8Decode(data, pos)
		var currGbp = graphemeBreakProperty(currCp)

		if isGraphemeBreak(prevGbp, currGbp, prevCp, currCp, state) 'found_break'
			return pos
		end 'found_break'

		state = graphemeStateUpdate(state, currGbp, currCp)
		prevCp = currCp
		prevGbp = currGbp
		var currLen = utf8ByteLength(data[pos])
		pos = pos + currLen
	end 'scan'

	return len
end 'nextGraphemeBoundary'

// Find the previous grapheme cluster boundary in UTF-8 data
// Returns the byte offset of the previous boundary, or 0 if at start
function prevGraphemeBoundary(data array of byte, len int, offset int) returns int
	// Clamp offset to valid range
	var safeOffset = offset
	if safeOffset > len 'clamp'
		safeOffset = len
	end 'clamp'
	if safeOffset <= 0 'at_start'
		return 0
	end 'at_start'

	// Find start of current codepoint (back up past continuation bytes)
	var pos = safeOffset - 1
	while pos > 0 and utf8IsContinuation(data[pos]) 'find_start'
		pos = pos - 1
	end 'find_start'

	// Scan from beginning up to pos to find boundaries
	var boundary = 0
	var scanPos = 0
	var state = graphemeStateInit()
	var prevCp = 0
	var prevGbp = 0  // GBP_Other
	var first = true

	while scanPos < pos 'scan_back'
		var currCp = utf8Decode(data, scanPos)
		var currGbp = graphemeBreakProperty(currCp)
		var currLen = utf8ByteLength(data[scanPos])

		if not first 'check_break'
			if isGraphemeBreak(prevGbp, currGbp, prevCp, currCp, state) 'found_prev'
				boundary = scanPos
			end 'found_prev'
		end 'check_break'

		state = graphemeStateUpdate(state, currGbp, currCp)
		prevCp = currCp
		prevGbp = currGbp
		scanPos = scanPos + currLen
		first = false
	end 'scan_back'

	return boundary
end 'prevGraphemeBoundary'

// Count grapheme clusters in UTF-8 data
function graphemeCount(data array of byte, len int) returns int
	if len == 0 'empty'
		return 0
	end 'empty'

	var count = 1  // Start with 1 (first grapheme)
	var pos = 0
	var state = graphemeStateInit()
	var prevCp = utf8Decode(data, pos)
	var prevGbp = graphemeBreakProperty(prevCp)
	var prevLen = utf8ByteLength(data[pos])
	pos = pos + prevLen
	state = graphemeStateUpdate(state, prevGbp, prevCp)

	while pos < len 'count_loop'
		var currCp = utf8Decode(data, pos)
		var currGbp = graphemeBreakProperty(currCp)

		if isGraphemeBreak(prevGbp, currGbp, prevCp, currCp, state) 'break_found'
			count = count + 1
		end 'break_found'

		state = graphemeStateUpdate(state, currGbp, currCp)
		prevCp = currCp
		prevGbp = currGbp
		var currLen = utf8ByteLength(data[pos])
		pos = pos + currLen
	end 'count_loop'

	return count
end 'graphemeCount'



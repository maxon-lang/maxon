/// Compiler internals: platform-neutral runtime helpers that need raw access
/// to Std-level system ops. Only this file is allowed to invoke `__Internals.*`
/// intrinsics — the lowering pass rejects calls from any other source file.
/// 
/// Functions in here participate in the full stdlib optimization pipeline
/// (canonicalize, cse, licm, dce, Stage A const hoist, inliner) — that's why
/// they live in stdlib rather than runtime.std (which only gets mem2reg).
/// 
/// @category Compiler-internal
// Raw machine word — covers pointers, sizes, byte values, refcounts, and
// any other i64-sized scalar that flows through the runtime intrinsics.
// Internals.maxon traffics in raw bits and addresses; the full i64 range
// is intentional here so signed-arithmetic on byte offsets, atomic xadd
// with negative deltas, and pointer values all flow through one type.
typealias MachineWord = int(i64.min to i64.max)

// Atomically increment the refcount at [ptr - 8]. Caller must ensure ptr is
// the user-region pointer (32-byte mm header sits at ptr-32..ptr-1; refcount
// is the trailing word at ptr-8). Migrated from runtime.std's mm_incref so
// the inliner can see this 2-op body at every call site.
function __mm_incref(ptr MachineWord)
	// STRICT: see `__mm_decref`. A null or non-heap value reaching incref is a
	// classification bug — fault on the `[ptr-8]` header write rather than
	// silently no-opping (which would let the bug hide and the real reference
	// leak). incref has no maybe-null sibling: the inserter only increfs values
	// it has proven live (a fresh allocation or a dominating definition), so a
	// null here is always wrong.
	__Internals.atomicInc(ptr - 8)
end '__mm_incref'

// Atomically decrement the refcount at [ptr - 8]. If the prior value was 1
// (refcount transitions to 0) call __mm_free to release the allocation.
// Caller must ensure ptr is non-null.
//
// We use atomicXadd with -1 rather than atomicDec because we need the prior
// value to detect the transition to zero across architectures uniformly —
// the bare atomic_dec op has no result Id in Std-IR.
function __mm_decref(ptr MachineWord)
	// STRICT: __mm_decref dereferences the allocation header at `[ptr-8]` (and
	// `[ptr-32]` on free). A null or non-heap value reaching here is NOT tolerated
	// — it is a refcount-inserter / lowering classification BUG, and faulting on
	// the header read surfaces it loudly with a stack trace instead of silently
	// no-opping (which masks the bug and leaks the real owner). The ONLY caller
	// allowed to pass a possibly-null pointer is `__mm_decref_maybenull_helper`, which
	// tolerates EXACTLY null (==0) at the statically-maybe-null release sites
	// (incomingOwner / selfReturnBorrow values, field-reassign old-occupant drop)
	// and calls through to this strict body for every non-null pointer.
	let prior = __Internals.atomicXadd(ptr - 8, value: -1)
	if prior == 1 'lastRef'
		__mm_free(ptr)
	end 'lastRef'
	// STRICT over-release trap: prior == 0 means this decref releases a
	// reference that was never taken (the sole-owner rc=0 reference belongs to
	// `__mm_drop`, never to decref); prior < 0 means the header is already
	// corrupt. Both are refcount-inserter / lowering bugs. Silently going
	// negative masks the bug as a leak — or, once a later incref crosses zero
	// again, as a delayed double-free whose slab-slot reuse corrupts unrelated
	// data. Fault loudly at the source instead.
	if prior <= 0 'overRelease'
		panic("__mm_decref: over-release — refcount was already 0")
	end 'overRelease'
end '__mm_decref'

// Owner-drop for the alloc-at-0 model. `[ptr-8]` counts EXTRA references beyond
// the single owner; a freshly-allocated value owned by exactly one binding sits
// at rc=0 its whole life (it was moved in, never shared/incref'd). When that
// owner's scope ends:
//   - rc == 0  → this is the sole reference; free the block directly.
//   - rc  > 0  → the value escaped (was incref'd for another owner); decref the
//                extra reference and leave the block for the last owner to free.
// Null-tolerant (==0 ptr) for slots that were zero-initialized but never assigned
// on the taken exit path — the scope-exit drop runs unconditionally per slot.
// This is the primitive the binding scope-exit drop uses; it is DISTINCT from
// `__mm_decref` (which frees only on prior-rc==1 and is for releasing an EXTRA
// reference an aliasing owner holds, not the sole owner's rc=0 reference).
function __mm_drop(ptr MachineWord)
	if ptr == 0 'null'
		return
	end 'null'
	let rc = __Internals.loadIndirect(ptr - 8)
	if rc == 0 'soleOwner'
		// Scope-exit drop of the sole owner (rc==0): this is the sole reference,
		// so free the block directly.
		__mm_free(ptr)
		return
	end 'soleOwner'
	// rc>0: the value escaped (an extra owner exists). Decref this owner's ref; the
	// last owner frees. (No mm_drop marker — a plain decref like any shared value.)
	__mm_decref(ptr)
end '__mm_drop'

// =============================================================================
// Sharded slab allocator (migrated from runtime.std — sharded variant).
//
// This is the per-P sharded (Go/mimalloc-style) slab. The fast path is
// lockless: each P owns its own mcache ROW (mcache_base + shard*144), and the
// span it pops from is its sole writer. A cross-P free is CAS-pushed onto the
// owner P's remote-free MPSC queue and replayed by the owner on its alloc slow
// path. The slow path (refill / mcentral mutation / OS-direct) takes the global
// __slab_lock. On single-P targets (wasm / arm64 / pre-scheduler x64)
// __slab_current_p_id returns -1 → shard 0, collapsing to a single shard.
//
// mspan struct (80-byte / 0x50 slot):
//   +0x00 base_addr  +0x08 slot_size  +0x10 free_list  +0x18 free_count
//   +0x20 next_span  +0x28 class_idx  +0x30 total_slots +0x38 arena_base
//   +0x40 owning_p   (RAW P id; 0xFFFFFFFF sentinel while parked in mcentral)
//
// ProcContext remote-free queue head sits at p_ptr + 0x78 (Treiber stack).
//
// `__Internals.atomicCas(addr, old, new)` returns 1 on success / 0 on failure
// (NOT the prior value) — the CAS loops below test it as a success boolean.
// =============================================================================

// Zeroes `size` bytes starting at `ptr`. Byte-at-a-time loop — callers do not
// have to align `size` to 8 bytes.
function __slab_memzero(ptr MachineWord, size MachineWord)
	for i in 0 upto size 'loop'
		__Internals.storeByte(ptr, offset: i, value: 0)
	end 'loop'
end '__slab_memzero'

// Allocates the very first 64 MiB arena from the OS, initialises its metadata
// and bitmap, prepends it to the arena list, and flips __slab_init_done to 1.
// Bitmap layout: chunk 0 holds the metadata, so its bit stays 0 (used); the
// other 8191 chunks start as 1 (free). 128 qwords of bitmap: qword 0 = -2
// (0xFFFFFFFFFFFFFFFE), qwords 1..127 = -1 (all free).
//
// globalAddr results are inlined (never bound to a local) so drop-injection
// does not treat them as heap-owned and emit a stray sys.free at function exit.
function __slab_arena_init()
	let arenaBase = __Internals.osAllocPages(0x4000000)
	// metadata: next = NULL (offset 0)
	__Internals.storeIndirect(arenaBase, value: 0)
	// bitmap qword 0 = 0xFFFFFFFFFFFFFFFE (chunk 0 used, rest free)
	__Internals.storeIndirect(arenaBase + 0x10, value: -2)
	// qwords 1..127 = -1 (all free)
	for i in 1 upto 128 'fill'
		__Internals.storeIndirect(arenaBase + 0x10 + (i shl 3), value: -1)
	end 'fill'
	// Prepend to the arena list head: new->next = old_head; head = new.
	let oldHead = __Internals.loadIndirect(__Internals.slabArenaListHeadAddr())
	__Internals.storeIndirect(arenaBase, value: oldHead)
	__Internals.storeIndirect(__Internals.slabArenaListHeadAddr(), value: arenaBase)
	// __slab_init_done = 1
	__Internals.storeIndirect(__Internals.slabInitDoneAddr(), value: 1)
end '__slab_arena_init'

// Walks the arena list scanning each arena's bitmap bit-by-bit for a run of
// `numChunks` consecutive free chunks. On success: clears those bits, stores
// the arena base in __slab_arena_last_base, and returns
// (arena_base + run_start * CHUNK_SIZE). On failure (no arena had room),
// allocates a fresh 64 MiB arena via the OS, links it in, and retries.
function __slab_arena_alloc_chunks(numChunks MachineWord) returns MachineWord
	var arenaPtr = __Internals.loadIndirect(__Internals.slabArenaListHeadAddr())
	while true 'arenaLoop'
		if arenaPtr == 0 'grow'
			// No arena had room — alloc a fresh 64 MiB arena and link in.
			let newArena = __Internals.osAllocPages(0x4000000)
			// metadata: next = old_head
			__Internals.storeIndirect(newArena, value: __Internals.loadIndirect(__Internals.slabArenaListHeadAddr()))
			// bitmap qword 0 = 0xFFFFFFFFFFFFFFFE
			__Internals.storeIndirect(newArena + 0x10, value: -2)
			// qwords 1..127 = -1 (all free)
			for j in 1 upto 128 'growFill'
				__Internals.storeIndirect(newArena + 0x10 + (j shl 3), value: -1)
			end 'growFill'
			// head = new_arena
			__Internals.storeIndirect(__Internals.slabArenaListHeadAddr(), value: newArena)
			// Restart the scan against the fresh arena.
			arenaPtr = newArena
			continue
		end 'grow'

		// Scan this arena's bitmap. Skip chunk 0 (always used by metadata).
		var i = 1
		var runLen = 0
		var runStart = 0
		var found = false
		while i < 0x2000 'bitLoop'
			let qwordIdx = i shr 6
			let qwordAddr = arenaPtr + 0x10 + (qwordIdx shl 3)
			let qword = __Internals.loadIndirect(qwordAddr)
			let bit = (qword shr (i and 63)) and 1
			if bit == 0 'used'
				runLen = 0
			end 'used'
			if bit != 0 'free'
				if runLen == 0 'startRun'
					runStart = i
				end 'startRun'
				runLen = runLen + 1
				if runLen >= numChunks 'gotRun'
					found = true
					break
				end 'gotRun'
			end 'free'
			i = i + 1
		end 'bitLoop'

		if found 'haveRun'
			// Clear bits runStart..runStart+numChunks-1 in the bitmap.
			for j in runStart upto runStart + numChunks 'clear'
				let qwordIdx = j shr 6
				let qwordAddr = arenaPtr + 0x10 + (qwordIdx shl 3)
				// mask = ~(1 << (j & 63)). Maxon has no unary bitNot; xor with -1
				// (all-ones two's complement) is the same.
				let bit = 1 shl (j and 63)
				let mask = bit xor -1
				let prior = __Internals.loadIndirect(qwordAddr)
				__Internals.storeIndirect(qwordAddr, value: prior and mask)
			end 'clear'
			// __slab_arena_last_base = arena_ptr
			__Internals.storeIndirect(__Internals.slabArenaLastBaseAddr(), value: arenaPtr)
			// result = arena + runStart * CHUNK_SIZE
			return arenaPtr + (runStart shl 13)
		end 'haveRun'

		// No run found in this arena; advance to next (offset 0 = next pointer).
		arenaPtr = __Internals.loadIndirect(arenaPtr)
	end 'arenaLoop'
	// Unreachable — the while-true above either returns or grows then retries.
	return 0
end '__slab_arena_alloc_chunks'

// Marks chunks [chunkIndex, chunkIndex + numChunks) as free in the bitmap of
// the given arena. Bit-by-bit OR.
function __slab_arena_free_chunks(arenaBase MachineWord, chunkIndex MachineWord, numChunks MachineWord)
	for j in chunkIndex upto chunkIndex + numChunks 'loop'
		let qwordIdx = j shr 6
		let qwordAddr = arenaBase + 0x10 + (qwordIdx shl 3)
		let bit = 1 shl (j and 63)
		let prior = __Internals.loadIndirect(qwordAddr)
		__Internals.storeIndirect(qwordAddr, value: prior or bit)
	end 'loop'
end '__slab_arena_free_chunks'

// Public init entry. Idempotent — runs __slab_arena_init only if the
// `__slab_init_done` flag is still 0, then initialises the slab lock. The
// lock init runs exactly once (guarded by init_done) on the main thread
// before any worker, serializing slow-path mutations once GTs run on
// multiple OS threads.
function __slab_init()
	let done = __Internals.loadIndirect(__Internals.slabInitDoneAddr())
	if done == 0 'doInit'
		__slab_arena_init()
		__Internals.osLockInit(__Internals.slabLockAddr())
	end 'doInit'
end '__slab_init'

// Size-class size lookup table. Returns the byte size of class `idx`.
function __slab_class_size(idx MachineWord) returns MachineWord
	if idx == 0 'c'
		return 8
	end 'c'
	if idx == 1 'c'
		return 16
	end 'c'
	if idx == 2 'c'
		return 24
	end 'c'
	if idx == 3 'c'
		return 32
	end 'c'
	if idx == 4 'c'
		return 48
	end 'c'
	if idx == 5 'c'
		return 64
	end 'c'
	if idx == 6 'c'
		return 96
	end 'c'
	if idx == 7 'c'
		return 128
	end 'c'
	if idx == 8 'c'
		return 192
	end 'c'
	if idx == 9 'c'
		return 256
	end 'c'
	if idx == 10 'c'
		return 384
	end 'c'
	if idx == 11 'c'
		return 512
	end 'c'
	if idx == 12 'c'
		return 1024
	end 'c'
	if idx == 13 'c'
		return 2048
	end 'c'
	if idx == 14 'c'
		return 4096
	end 'c'
	if idx == 15 'c'
		return 8192
	end 'c'
	if idx == 16 'c'
		return 16384
	end 'c'
	return 32768
end '__slab_class_size'

// Objects-per-span lookup table. Kept in lock-step with __slab_class_size.
function __slab_objs_per_span(idx MachineWord) returns MachineWord
	if idx == 0 'c'
		return 1024
	end 'c'
	if idx == 1 'c'
		return 512
	end 'c'
	if idx == 2 'c'
		return 341
	end 'c'
	if idx == 3 'c'
		return 256
	end 'c'
	if idx == 4 'c'
		return 170
	end 'c'
	if idx == 5 'c'
		return 128
	end 'c'
	if idx == 6 'c'
		return 85
	end 'c'
	if idx == 7 'c'
		return 64
	end 'c'
	if idx == 8 'c'
		return 42
	end 'c'
	if idx == 9 'c'
		return 32
	end 'c'
	if idx == 10 'c'
		return 21
	end 'c'
	if idx == 11 'c'
		return 16
	end 'c'
	if idx == 12 'c'
		return 8
	end 'c'
	if idx == 13 'c'
		return 4
	end 'c'
	if idx == 14 'c'
		return 2
	end 'c'
	if idx == 15 'c'
		return 4
	end 'c'
	if idx == 16 'c'
		return 2
	end 'c'
	return 1
end '__slab_objs_per_span'

// Hands out 80-byte (0x50) slots used as mspan-header storage. Three-tier:
//   1. Pop from the intrusive free-list at __slab_meta_free_head if non-null.
//   2. Otherwise bump within the current metadata chunk if it has room
//      (bump_ptr + 0x50 <= bump_end).
//   3. Otherwise grab a fresh 8 KiB chunk; reserve its first 0x50 bytes as the
//      result and reseed bump_ptr = chunk + 0x50, bump_end = chunk + 0x2000.
function __slab_meta_alloc() returns MachineWord
	let head = __Internals.loadIndirect(__Internals.slabMetaFreeHeadAddr())
	if head != 0 'popFree'
		// result = head; head = [head]
		let next = __Internals.loadIndirect(head)
		__Internals.storeIndirect(__Internals.slabMetaFreeHeadAddr(), value: next)
		return head
	end 'popFree'

	// Bump path. Std-IR uses signed Lt for the gate; both values are well below
	// the high bit so signed/unsigned agree.
	let bumpPtr = __Internals.loadIndirect(__Internals.slabMetaBumpPtrAddr())
	let advanced = bumpPtr + 0x50
	let bumpEnd = __Internals.loadIndirect(__Internals.slabMetaBumpEndAddr())
	if bumpEnd >= advanced 'doBump'
		__Internals.storeIndirect(__Internals.slabMetaBumpPtrAddr(), value: advanced)
		return bumpPtr
	end 'doBump'

	// Grow: fresh 8 KiB metadata chunk. First 0x50 bytes is the result; the
	// rest becomes the new bump region.
	let chunkBase = __slab_arena_alloc_chunks(1)
	__Internals.storeIndirect(__Internals.slabMetaBumpPtrAddr(), value: chunkBase + 0x50)
	__Internals.storeIndirect(__Internals.slabMetaBumpEndAddr(), value: chunkBase + 0x2000)
	return chunkBase
end '__slab_meta_alloc'

// Pushes `ptr` onto the metadata free list. `[ptr] = old_head; head = ptr.`
function __slab_meta_free(ptr MachineWord)
	let oldHead = __Internals.loadIndirect(__Internals.slabMetaFreeHeadAddr())
	__Internals.storeIndirect(ptr, value: oldHead)
	__Internals.storeIndirect(__Internals.slabMetaFreeHeadAddr(), value: ptr)
end '__slab_meta_free'

// Shard id of the calling OS thread's adopted P, or -1 when no multi-P
// scheduler owns this thread. Signature stub (returns -1) for targets without
// a GMP scheduler; x64-Windows overrides this label with a TLS-reading
// machine-code version (emitX64SlabCurrentPId).
function __slab_current_p_id() returns MachineWord
	return -1
end '__slab_current_p_id'

// Number of mcache shard rows (one per possible P). The mcache base is sized
// SLAB_MAX_SHARDS × SLAB_NUM_SIZE_CLASSES × 8 bytes (see the `__slab_mcache_base`
// data-section entry).
let SLAB_MAX_SHARDS = 256

// Bytes between consecutive mcache rows: one 8-byte span* slot per size class.
// Must stay lock-step with the size-class count baked into the mcache base size.
let SLAB_MCACHE_ROW_STRIDE = 144

// Sentinel stamped into an mspan's owning_p (+0x40) while the span is parked in
// mcentral (owned by no P). A real raw P id can never collide with it, so a
// cross-P free that observes it has hit a returned-span invariant violation.
let MSPAN_OWNING_P_PARKED = 0xFFFFFFFF

// The mcache row reserved for ALL raw OS threads (id < 0: the subprocess sync
// worker, the IOCP completion poller — threads with no adopted P). It MUST be
// distinct from every real P's row (a real P's row is its id, 0..num_procs-1),
// so a raw thread's lockless-looking fast path never shares a cached span with
// P[0]. Real Ps never reach num_procs == SLAB_MAX_SHARDS in practice; the
// `>= SLAB_MAX_SHARDS` cap below is for an unreachable >256-CPU host and would
// only collide there. Raw-thread access to this row is additionally serialized
// under __slab_lock (see __slab_alloc / __slab_free), since multiple raw threads
// share it — they have no exclusive-owner guarantee the per-P fast path relies on.
let SLAB_RAW_SHARD = SLAB_MAX_SHARDS - 1

// Map a raw P id into the mcache row index range [0, SLAB_MAX_SHARDS).
// A -1 (no scheduler / raw OS thread) becomes the dedicated raw shard, NOT shard
// 0 — sharing shard 0 with P[0] (the main thread, which actively allocates while
// draining green threads in an await loop) raced the main thread's lockless pops
// against a raw thread's, handing the same slab slot to both → heap corruption
// (the async-subprocess flake: a managed pointer overwritten by a concurrent
// cmdline UTF-16 / child-output write). A (practically unreachable) id >= 256 is
// capped to the last row. This is the MCACHE INDEX only — a span's owning_p
// stores the RAW id, so the cap never affects free correctness.
function __slab_clamp_shard(rawId MachineWord) returns MachineWord
	if rawId < 0 'neg'
		return SLAB_RAW_SHARD
	end 'neg'
	if rawId >= SLAB_MAX_SHARDS 'cap'
		return SLAB_MAX_SHARDS - 1
	end 'cap'
	return rawId
end '__slab_clamp_shard'

// The ProcContext* for shard `id` from the scheduler's P array
// (__sched_procs), or 0 when there is no P (id < 0, or __sched_procs is still
// NULL). procs is an array of P*; entry `id` is itself a P*.
function __slab_proc_at(id MachineWord) returns MachineWord
	if id < 0 'none'
		return 0
	end 'none'
	let procs = __Internals.loadIndirect(__Internals.schedProcsAddr())
	if procs == 0 'noProcs'
		return 0
	end 'noProcs'
	return __Internals.loadIndirect(procs + (id shl 3))
end '__slab_proc_at'

// CAS-push `slot` onto P `pPtr`'s remote-free MPSC queue (Treiber stack at
// pPtr + 0x78). The slot's first 8 bytes hold the `next` link. Lock-free,
// multiple producers. On single-threaded targets the CAS never contends.
function __slab_remote_free_push(pPtr MachineWord, slot MachineWord)
	let headAddr = pPtr + 0x78
	while true 'retry'
		// old = [headAddr]; [slot] = old (link new node to the current head)
		let old = __Internals.loadIndirect(headAddr)
		__Internals.storeIndirect(slot, value: old)
		// success = CAS(headAddr, old, slot) — returns 1 on success / 0 on fail.
		if __Internals.atomicCas(headAddr, old: old, new: slot) != 0 'done'
			return
		end 'done'
	end 'retry'
end '__slab_remote_free_push'

// Drain P `pPtr`'s remote-free MPSC queue back onto the owning spans' free
// lists. Called ONLY by the owner P (on its alloc slow path), so the per-span
// pushes are lockless (single-writer). One AtomicCAS detaches the entire chain
// (head -> NULL); we then walk it, looking up each node's span via the arena
// map and pushing it onto span.free_list. A NULL pPtr (no P) is a no-op.
function __slab_drain_remote_frees(pPtr MachineWord)
	if pPtr == 0 'none'
		return
	end 'none'

	let headAddr = pPtr + 0x78
	// Detach the chain: CAS([p+0x78], old, NULL) until we win or it's empty.
	var chainHead = 0
	while true 'detachRetry'
		let old = __Internals.loadIndirect(headAddr)
		if old == 0 'empty'
			return
		end 'empty'
		// success = CAS(headAddr, old, 0) — 1 on success / 0 on fail.
		if __Internals.atomicCas(headAddr, old: old, new: 0) != 0 'detached'
			chainHead = old
			break
		end 'detached'
	end 'detachRetry'

	// Walk the detached chain, replaying each node onto its span's free list.
	var current = chainHead
	while current != 0 'walk'
		// Park `next` before the span lookup / free-list push clobbers [current].
		let next = __Internals.loadIndirect(current)
		// span = arena_map_get(current). Per the cross-P invariant this always
		// succeeds (the span is registered at creation and never unregistered).
		let span = __slab_arena_map_get(current)
		// Single-writer push onto span.free_list (same helper the local free
		// path uses; fully empties → returns span to mcentral).
		__slab_free_class_with_mspan(current, mspan: span)
		current = next
	end 'walk'
end '__slab_drain_remote_frees'

// Repopulates this P's mcache row entry mcache[shard][classIdx] with a span
// that has at least one free slot. Two-tier:
//   1. Pop the head of mcentral[classIdx].partial (clearing its next_span) and
//      install it; re-stamp owning_p = rawId under the lock.
//   2. If partial is empty: build a fresh span — alloc chunks for slot data, an
//      mspan header from the metadata slab, init the mspan fields (owning_p =
//      rawId), register it in the arena map, and wire up the intrusive free
//      list.
//
// Slow path: reads mcentral and drives the chunk / metadata / arena-map
// allocators, so the whole body runs under the global __slab_lock. The per-P
// mcache fast path takes NO lock.
//
// `shard = clamp(rawId)` is the mcache row index (must match __slab_alloc_class);
// `rawId` is stamped into owning_p so cross-P frees compare it exactly.
function __slab_refill_mcache(classIdx MachineWord, rawId MachineWord)
	let rowShard = __slab_clamp_shard(rawId)

	__Internals.osLockAcquire(__Internals.slabLockAddr())

	// mcentral entry = base + classIdx * 16; mcache slot = base + rowShard*stride + classIdx*8.
	let mcentralEntry = __Internals.slabMcentralArrayAddr() + (classIdx shl 4)
	let mcacheSlot = __Internals.slabMcacheBaseAddr() + (rowShard * SLAB_MCACHE_ROW_STRIDE) + (classIdx shl 3)

	let partial = __Internals.loadIndirect(mcentralEntry)
	var span = 0
	if partial != 0 'takePartial'
		// span = partial; partial_head = span.next_span; span.next_span = 0
		span = partial
		let nextSpan = __Internals.loadIndirect(partial + 0x20)
		__Internals.storeIndirect(mcentralEntry, value: nextSpan)
		__Internals.storeIndirect(partial + 0x20, value: 0)
		// Re-stamp owning_p = rawId — this P now exclusively owns the span (it
		// carried the 0xFFFFFFFF sentinel while parked in mcentral).

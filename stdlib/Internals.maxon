	// record into a NEW Array via `Self{managed: newManaged}`; that owning field holds
	// the lone reference, dropped exactly once by the Array's destructor. The call
	// result is classified `callReturnRc1` (owns a +1), so without this incref the
	// record stays rc=0 and the owner's single decref goes 0->-1 and never frees → the
	// sliced record + its copied buffer leak.
	__mm_incref(newStruct)

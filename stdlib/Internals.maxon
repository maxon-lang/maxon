			stillMiss = true
		end 'noSpan2'
		if probedSpan != 0 'haveSpan2'
			if __Internals.loadIndirect(probedSpan + 0x18) == 0 'depleted2'
				stillMiss = true
			end 'depleted2'
		end 'haveSpan2'


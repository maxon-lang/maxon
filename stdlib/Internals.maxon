	if count > 0 'hasContent'
		let size = count * elemSize
		newBuf = __managed_mem_alloc_buffer(size)
	end 'hasContent'
	__Internals.storeIndirect(newStruct, value: newBuf)
	__Internals.storeIndirect(newStruct + MM_OFFSET_LENGTH, value: 0)
	__Internals.storeIndirect(newStruct + MM_OFFSET_CAPACITY, value: count)
	__Internals.storeIndirect(newStruct + MM_OFFSET_ELEMENT_SIZE, value: elemSize)
	__Internals.storeIndirect(newStruct + MM_OFFSET_PARENT, value: MM_PARENT_ROOT)
	__Internals.storeIndirect(newStruct + MM_OFFSET_ELEMENT_DESTROY, value: elementDestroy)
	return newStruct
end '__managed_mem_create_managed'

// set_element_destroy_from_layout(self, layoutDesc, elementDestroy) — stamp the
// record's element_destroy@40 from a runtime layout descriptor. Used by the
// generic-container element-walk wiring: inside a generic `Array<Element>` body
// the backing `__ManagedMemory` is created/grown where `Element` is still an
// unbound type-parameter, so `mmCreateElementIsManagedPointer`'s static check
// can't see whether the element is managed — but the body DOES carry the
// instance's layout descriptor (forwarded as the implicit layout param). This
// helper reads that descriptor's `flags@24` HAS_HEAP_REFS bit and, when set,
// stamps `elementDestroy` (lowering passes &__mm_decref for pointer elements) so
// the destructor's ROOT-branch element-walk fires. When the bit is clear (raw /
// primitive elements) the record's element_destroy stays 0 and the walk is inert
// — so a raw-int array is never walked (decref-ing a raw int would fault). Set-
// once / idempotent: re-stamping the same pointer on every grow is harmless.
// `layoutDesc == 0` is tolerated (no descriptor available → leave 0, no walk).
function __managed_mem_set_element_destroy_from_layout(self MachineWord, layoutDesc MachineWord, elementDestroy MachineWord) returns MachineWord

	__Internals.storeIndirect(newStruct, value: newBuf)
	__Internals.storeIndirect(newStruct + 8, value: sliceLen)
	__Internals.storeIndirect(newStruct + 16, value: sliceLen)
	__Internals.storeIndirect(newStruct + 24, value: elemSize)
	__Internals.storeIndirect(newStruct + 32, value: -1)
	return newStruct
end '__managed_mem_slice'

// create(count, elemSize) — static `__ManagedMemory.create`. Allocates a
// fresh root __ManagedMemory header plus, when count > 0, a fresh
// untagged buffer sized for `count` elements. Initializes length=0,
// capacity=count, element_size=elemSize, parent_ptr=-1 (root).
// Non-throwing (allocation-failure signalling is reserved for a future hook).
function __managed_mem_create(count int, elemSize int) returns int
	let destructor = __Internals.destructManagedMemoryAddr()
	let newStruct = __mm_alloc(40, destructor: destructor, tag: 0)
	var newBuf = 0
	if count > 0 'hasContent'
		let size = count * elemSize
		newBuf = __mm_alloc(size, destructor: 0, tag: 0)
	end 'hasContent'
	__Internals.storeIndirect(newStruct, value: newBuf)
	__Internals.storeIndirect(newStruct + 8, value: 0)
	__Internals.storeIndirect(newStruct + 16, value: count)
	__Internals.storeIndirect(newStruct + 24, value: elemSize)
	__Internals.storeIndirect(newStruct + 32, value: -1)
	return newStruct
end '__managed_mem_create'


			__mm_incref(slot)
		end 'live'
		i = i + 1
	end 'eachElem'
end '__managed_mem_retain_range'

// create(count, elemSize) — static `__ManagedMemory.create`. Allocates a
// fresh root __ManagedMemory header plus, when count > 0, a fresh
// untagged buffer sized for `count` elements. Initializes length=0,
// capacity=count, element_size=elemSize, parent_ptr=-1 (root).
// Non-throwing (allocation-failure signalling is reserved for a future hook).
function __managed_mem_create(count MachineWord, elemSize MachineWord) returns MachineWord
	return __managed_mem_create_managed(count, elemSize: elemSize, elementDestroy: 0)
end '__managed_mem_create'

// create_managed(count, elemSize, elementDestroy) — like __managed_mem_create
// but additionally stamps element_destroy@40 with the per-element teardown
// function pointer. Lowering passes &__mm_decref here when the element type is
// drop-tracked and stored as an 8-byte managed pointer, so the destructor's
// ROOT-branch element-walk decrefs each live element (cascading into the
// element's own destructor). For raw/byte/primitive element buffers lowering
// passes 0 (via __managed_mem_create), leaving the walk disabled.
function __managed_mem_create_managed(count MachineWord, elemSize MachineWord, elementDestroy MachineWord) returns MachineWord
	let destructor = __Internals.destructManagedMemoryAddr()
	let newStruct = __mm_alloc(MANAGED_MEM_RECORD_SIZE, destructor: destructor)

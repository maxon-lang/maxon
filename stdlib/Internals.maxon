// Ensures L1, L2, and spans[] arrays exist for the arena map entry covering
// `addr`. Lazy-allocates each layer on first need.
//   bits 39+   -> L1 slot      (256 entries, 2048 bytes)
//   bits 26-38 -> L2 slot      (8192 entries, 65536 bytes)
//   bits 13-25 -> spans[] slot (8192 entries, 65536 bytes)

	// destructor / size / refcount offsets stay at their historical
	// `user_ptr - 24 / -16 / -8`.
	__Internals.storeIndirect(slotBase, value: 0)
	__Internals.storeIndirect(slotBase + 8, value: destructor)
	__Internals.storeIndirect(slotBase + 16, value: clampedSize)

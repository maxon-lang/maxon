	while __Internals.loadByte(cstr, offset: len) != 0 'scan'
		len = len + 1
	end 'scan'
	let bufSize = len + 1
	let destructor = __Internals.destructManagedMemoryAddr()
	let newStruct = __mm_alloc(MANAGED_MEM_RECORD_SIZE, destructor: destructor)
	let newBuf = __managed_mem_alloc_buffer(bufSize)
	__Internals.memcpy(newBuf, src: cstr, size: bufSize)
	__Internals.storeIndirect(newStruct, value: newBuf)
	__Internals.storeIndirect(newStruct + MM_OFFSET_LENGTH, value: len)
	__Internals.storeIndirect(newStruct + MM_OFFSET_CAPACITY, value: bufSize)
	__Internals.storeIndirect(newStruct + MM_OFFSET_ELEMENT_SIZE, value: 1)
	__Internals.storeIndirect(newStruct + MM_OFFSET_PARENT, value: MM_PARENT_ROOT)
	__Internals.storeIndirect(newStruct + MM_OFFSET_ELEMENT_DESTROY, value: 0)
	return newStruct
end '__managed_mem_from_cstring'

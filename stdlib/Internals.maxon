	__Internals.storeIndirect(self + MM_OFFSET_LENGTH, value: newLength)
	return 0
end '__managed_mem_append'

// slice(self, start, end) — allocate a fresh root __ManagedMemory header
// plus a fresh buffer sized for (end - start) elements, copy the slice's
// bytes in, and return the new MM pointer. The slice owns its buffer
// (parent_ptr = -1), we don't hold a reference to the source. Bounds:
// 0 <= start <= end <= length. Throws sliceOutOfBounds (wire 3).
function __managed_mem_slice(self MachineWord, start MachineWord, endIdx MachineWord) returns MachineWord throws __ManagedMemoryError
	if start < 0 'startNeg'
		throw __ManagedMemoryError.sliceOutOfBounds
	end 'startNeg'
	if endIdx < start 'endLow'
		throw __ManagedMemoryError.sliceOutOfBounds
	end 'endLow'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)

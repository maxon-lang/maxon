		return 0
	end 'noDesc'
	let flags = __Internals.loadIndirect(layoutDesc + LAYOUT_OFFSET_FLAGS)
	if (flags and LAYOUT_FLAG_HAS_HEAP_REFS) != 0 'managed'
		__Internals.storeIndirect(self + MM_OFFSET_ELEMENT_DESTROY, value: elementDestroy)
	end 'managed'
	return 0
end '__managed_mem_set_element_destroy_from_layout'

// toCString(self) — return a NUL-terminated byte pointer into self's buffer.
// A zero-copy slice or rdata-backed literal often has `buffer[length] != 0`
// (the byte there belongs to the next element / the next constant), so a bare
// `loadIndirect(self)` would hand back a pointer that `strlen` walks off the
// end of — a buffer overrun (and a hard out-of-bounds trap on wasm's
// bounds-checked memory). Mirror the bootstrap's `MaxonManagedToCStringOp`:
// when the terminator slot is already `\0`, return the buffer as-is; otherwise
// COW to an owned buffer, grow capacity to `length + 1`, write the terminator,
// and return the (possibly reallocated) buffer. Non-throwing — the grow path's
// `newCap = length + 1 > capacity` can never trip `invalidCapacity`.
function __managed_mem_to_cstring(self MachineWord) returns MachineWord

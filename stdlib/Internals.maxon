	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	if __Internals.loadByte(buffer, offset: length) == 0 'alreadyTerminated'
		return buffer
	end 'alreadyTerminated'
	// A capacity that already fits `length + 1` is always a positive (owned)
	// value — the rdata/shared sentinels are negative and so are < length + 1,
	// routing through `grow`, which COWs then reallocs. So reaching the
	// terminator write below always means we own the buffer.
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity < length + 1 'needRoom'
		_ = try __managed_mem_grow(self, newCap: length + 1) otherwise panic("__managed_mem_to_cstring: grow to length+1 cannot shrink")
	end 'needRoom'
	let ownedBuf = __Internals.loadIndirect(self)
	__Internals.storeByte(ownedBuf, offset: length, value: 0)
	return ownedBuf
end '__managed_mem_to_cstring'

// fromCString(cstr) — static `__ManagedMemory.fromCString`. Convert a
// NUL-terminated byte pointer into a fresh byte-element __ManagedMemory.
// Walks the pointer to find its length (the byte before the terminating
// `\0`), allocates a root header plus a buffer of `length + 1` bytes, and
// copies the bytes *including* the terminator so the result is itself a valid
// cstring (`toCString` on it returns the same shape). length=len,
// capacity=len+1, element_size=1, parent_ptr=-1 (root). Non-throwing.
// Mirrors the bootstrap's `LowerCStringToManagedCore`.
function __managed_mem_from_cstring(cstr MachineWord) returns MachineWord

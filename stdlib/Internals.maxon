	let shard = __slab_clamp_shard(rawId)

	let mcacheSlot = __Internals.slabMcacheBaseAddr() + (shard * SLAB_MCACHE_ROW_STRIDE) + (classIdx shl 3)
	let cachedSpan = __Internals.loadIndirect(mcacheSlot)

	// Determine whether the cached span is a miss (empty slot, or free_count==0).

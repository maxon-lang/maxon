/// Compiler internals: platform-neutral runtime helpers that need raw access
/// to Std-level system ops. Only this file is allowed to invoke `__Internals.*`
/// intrinsics — the lowering pass rejects calls from any other source file.
///
/// Functions in here participate in the full stdlib optimization pipeline
/// (canonicalize, cse, licm, dce, Stage A const hoist, inliner) — that's why
/// they live in stdlib rather than runtime.std (which only gets mem2reg).
///
/// @category Compiler-internal

// Atomically increment the refcount at [ptr - 8]. Caller must ensure ptr is
// the user-region pointer (24-byte mm header sits at ptr-24..ptr-1; refcount
// is the trailing word at ptr-8). Migrated from runtime.std's mm_incref so
// the inliner can see this 2-op body at every call site.
function __mm_incref(ptr int)
	__Internals.atomicInc(ptr - 8)
end '__mm_incref'

// Atomically decrement the refcount at [ptr - 8]. If the prior value was 1
// (refcount transitions to 0) call __mm_free to release the allocation.
// Caller must ensure ptr is non-null.
//
// We use atomicXadd with -1 rather than atomicDec because we need the prior
// value to detect the transition to zero across architectures uniformly —
// the bare atomic_dec op has no result Id in Std-IR.
function __mm_decref(ptr int)
	let prior = __Internals.atomicXadd(ptr - 8, value: -1)
	if prior == 1 'lastRef'
		__mm_free(ptr)
	end 'lastRef'
end '__mm_decref'

// Allocate a tracked block of `size` bytes through the slab allocator.
// Layout: 24-byte mm header followed by the user region.
//   slot_base + 0  : destructor (function pointer; 0 means "no destructor")
//   slot_base + 8  : size (user-region size)
//   slot_base + 16 : refcount (initialized to 1)
//   user_ptr       = slot_base + 24 (returned)
//
// `tag` is currently unused — preserved in the signature for parity with the
// older runtime body and for forward compatibility with allocation-site
// tagging. Sizes below 1 are clamped to 1; we don't panic.
function __mm_alloc(size int, destructor int, tag int) returns int
	// `tag` is currently a placeholder; binding it to the discard pattern
	// keeps the param name labelable from call sites without tripping E3012.
	_ = tag
	var clampedSize = size
	if size < 1 'clamp'
		clampedSize = 1
	end 'clamp'
	__Internals.atomicInc(__Internals.mmAllocCountAddr())
	let slotBase = __slab_alloc(clampedSize + 24)
	__Internals.storeIndirect(slotBase, value: destructor)
	__Internals.storeIndirect(slotBase + 8, value: clampedSize)
	__Internals.storeIndirect(slotBase + 16, value: 1)
	return slotBase + 24
end '__mm_alloc'

// Release a tracked allocation. Reads the destructor from [ptr - 24] and
// invokes it (if non-null) before slab-freeing. The destructor is
// responsible for decreffing managed fields stored inside the user region;
// __mm_free only releases the surrounding allocation.
//
// Tolerates ptr == 0 as a no-op so callers don't have to null-check.
function __mm_free(ptr int)
	if ptr == 0 'nullPtr'
		return
	end 'nullPtr'
	let destructor = __Internals.loadIndirect(ptr - 24)
	if destructor != 0 'hasDtor'
		__Internals.indirectCall1(destructor, arg: ptr)
	end 'hasDtor'
	__Internals.atomicDec(__Internals.mmAllocCountAddr())
	__slab_free(ptr - 24)
end '__mm_free'

// Top-level slab allocator entry point. Routes to the OS-direct path for
// requests larger than 32KB, otherwise picks the smallest size class that
// fits and forwards to __slab_alloc_class. Migrated from runtime.std so
// the inliner can see this dispatch logic and (eventually) inline the
// small-path entirely at hot call sites.
//
// Size class lookup is a linear scan over 18 size classes because the
// cascade compiles to a binary-search-like pattern after canonicalize/cse
// see through the loop. A precomputed size→class table would be a future
// micro-optimization.
function __slab_alloc(size int) returns int
	if size > 32768 'osPath'
		return __Internals.slabOsDirectAlloc(size)
	end 'osPath'
	var classIdx = 0
	for _ in 0 upto 18 'classLoop'
		let classSize = __slab_class_size(classIdx)
		if classSize >= size 'fits'
			return __Internals.slabAllocClass(classIdx)
		end 'fits'
		classIdx = classIdx + 1
	end 'classLoop'
	// Unreachable (size <= 32768 fits in class 17). Exit cleanly rather
	// than continuing past the dispatch table.
	__Internals.osExit(136)
	return 0
end '__slab_alloc'

// Top-level slab free entry point. Recovers the owning mspan via the
// two-level arena map; if the lookup misses, the pointer came from the
// OS-direct path. Migrated from runtime.std.
function __slab_free(ptr int)
	let mspan = __slab_arena_map_get(ptr)
	if mspan == 0 'osDirect'
		__slab_os_direct_free(ptr)
		return
	end 'osDirect'
	__slab_free_class_with_mspan(ptr, mspan: mspan)
end '__slab_free'

// Size-class size lookup table. Returns the byte size of class `idx`.
// Migrated from runtime.std as an 18-way cascade; the optimizer compiles
// this into a binary-search-shaped jump tree. Once inlined into
// __slab_alloc, the call site's class index is often a constant (when
// callers explicitly route through a fixed class), enabling constant
// folding of the entire lookup down to a single immediate.
function __slab_class_size(idx int) returns int
	if idx == 0 'c'
		return 8
	end 'c'
	if idx == 1 'c'
		return 16
	end 'c'
	if idx == 2 'c'
		return 24
	end 'c'
	if idx == 3 'c'
		return 32
	end 'c'
	if idx == 4 'c'
		return 48
	end 'c'
	if idx == 5 'c'
		return 64
	end 'c'
	if idx == 6 'c'
		return 96
	end 'c'
	if idx == 7 'c'
		return 128
	end 'c'
	if idx == 8 'c'
		return 192
	end 'c'
	if idx == 9 'c'
		return 256
	end 'c'
	if idx == 10 'c'
		return 384
	end 'c'
	if idx == 11 'c'
		return 512
	end 'c'
	if idx == 12 'c'
		return 1024
	end 'c'
	if idx == 13 'c'
		return 2048
	end 'c'
	if idx == 14 'c'
		return 4096
	end 'c'
	if idx == 15 'c'
		return 8192
	end 'c'
	if idx == 16 'c'
		return 16384
	end 'c'
	return 32768
end '__slab_class_size'

// Objects-per-span lookup table. Kept in lock-step with `__slab_class_size`:
// class N's mspan holds `__slab_objs_per_span(N)` slots of `__slab_class_size(N)`
// bytes each, packed in chunks totaling roughly the class's natural span
// budget (8KB for small classes, larger for larger ones).
function __slab_objs_per_span(idx int) returns int
	if idx == 0 'c'
		return 1024
	end 'c'
	if idx == 1 'c'
		return 512
	end 'c'
	if idx == 2 'c'
		return 341
	end 'c'
	if idx == 3 'c'
		return 256
	end 'c'
	if idx == 4 'c'
		return 170
	end 'c'
	if idx == 5 'c'
		return 128
	end 'c'
	if idx == 6 'c'
		return 85
	end 'c'
	if idx == 7 'c'
		return 64
	end 'c'
	if idx == 8 'c'
		return 42
	end 'c'
	if idx == 9 'c'
		return 32
	end 'c'
	if idx == 10 'c'
		return 21
	end 'c'
	if idx == 11 'c'
		return 16
	end 'c'
	if idx == 12 'c'
		return 8
	end 'c'
	if idx == 13 'c'
		return 4
	end 'c'
	if idx == 14 'c'
		return 2
	end 'c'
	if idx == 15 'c'
		return 4
	end 'c'
	if idx == 16 'c'
		return 2
	end 'c'
	return 1
end '__slab_objs_per_span'

// Zeroes `size` bytes starting at `ptr`. Byte-at-a-time loop — callers do not
// have to align `size` to 8 bytes. Migrated from runtime.std's
// `__slab_memzero` so the inliner can see this body at every caller (the
// lazy-init paths in __slab_arena_map_ensure and __slab_os_direct_alloc each
// hit it once per fresh chunk).
function __slab_memzero(ptr int, size int)
	for i in 0 upto size 'loop'
		__Internals.storeByte(ptr, offset: i, value: 0)
	end 'loop'
end '__slab_memzero'

// Allocates the very first 64 MiB arena from the OS, initialises its metadata
// and bitmap, prepends it to the arena list, and flips __slab_init_done to 1.
// Idempotent at the __slab_init level — the caller guards on init_done.
//
// Bitmap layout: chunk 0 holds the metadata, so its bit must stay 0 (used).
// All other 8191 chunks start as 1 (free). 128 qwords of bitmap. We write
// 0xFFFFFFFFFFFFFFFE (-2) into qword 0 and 0xFFFFFFFFFFFFFFFF (-1) into
// qwords 1..127.
function __slab_arena_init()
	let arenaBase = __Internals.osAllocPages(0x4000000)
	// metadata: next = NULL (offset 0)
	__Internals.storeIndirect(arenaBase, value: 0)
	// bitmap qword 0 = 0xFFFFFFFFFFFFFFFE (chunk 0 used, rest free)
	__Internals.storeIndirect(arenaBase + 0x10, value: -2)
	// qwords 1..127 = -1 (all free)
	for i in 1 upto 128 'fill'
		__Internals.storeIndirect(arenaBase + 0x10 + (i shl 3), value: -1)
	end 'fill'
	// Prepend to the arena list head: new->next = old_head; head = new.
	//
	// We avoid binding the globalAddr result (`slabArenaListHeadAddr()`) to a
	// local — drop-injection treats globalAddr-derived slot values as heap-
	// owned and would emit a `sys.free` at function exit, surfacing as a
	// stray `mrt_free` call. Inlining each use keeps the value temp-only.
	let oldHead = __Internals.loadIndirect(__Internals.slabArenaListHeadAddr())
	__Internals.storeIndirect(arenaBase, value: oldHead)
	__Internals.storeIndirect(__Internals.slabArenaListHeadAddr(), value: arenaBase)
	// __slab_init_done = 1
	__Internals.storeIndirect(__Internals.slabInitDoneAddr(), value: 1)
end '__slab_arena_init'

// Walks the arena list scanning each arena's bitmap bit-by-bit for a run of
// `numChunks` consecutive free chunks. On success: clears those bits, stores
// the arena base in __slab_arena_last_base, and returns
// (arena_base + run_start * CHUNK_SIZE). On failure (no arena had room),
// allocates a fresh 64 MiB arena via the OS, links it in, and retries.
//
// The C# implementation has a qword-level fast path with BSF; this port
// keeps the runtime's bit-by-bit scan. Chunk allocation is rare (mspan
// refill or arena-map L2), so the simpler scan is fine.
//
// Avoid binding any globalAddr result to a local — drop-injection would treat
// it as heap-owned and emit a stray sys.free at function exit.
function __slab_arena_alloc_chunks(numChunks int) returns int
	var arenaPtr = __Internals.loadIndirect(__Internals.slabArenaListHeadAddr())
	while true 'arenaLoop'
		if arenaPtr == 0 'grow'
			// No arena had room — alloc a fresh 64 MiB arena and link in.
			let newArena = __Internals.osAllocPages(0x4000000)
			// metadata: next = old_head
			__Internals.storeIndirect(newArena, value: __Internals.loadIndirect(__Internals.slabArenaListHeadAddr()))
			// bitmap qword 0 = 0xFFFFFFFFFFFFFFFE
			__Internals.storeIndirect(newArena + 0x10, value: -2)
			// qwords 1..127 = -1 (all free)
			for j in 1 upto 128 'growFill'
				__Internals.storeIndirect(newArena + 0x10 + (j shl 3), value: -1)
			end 'growFill'
			// head = new_arena
			__Internals.storeIndirect(__Internals.slabArenaListHeadAddr(), value: newArena)
			// Restart the scan against the fresh arena.
			arenaPtr = newArena
			continue
		end 'grow'

		// Scan this arena's bitmap. Skip chunk 0 (always used by metadata).
		var i = 1
		var runLen = 0
		var runStart = 0
		var found = false
		while i < 0x2000 'bitLoop'
			let qwordIdx = i shr 6
			let qwordAddr = arenaPtr + 0x10 + (qwordIdx shl 3)
			let qword = __Internals.loadIndirect(qwordAddr)
			let bit = (qword shr (i and 63)) and 1
			if bit == 0 'used'
				runLen = 0
			end 'used'
			if bit != 0 'free'
				if runLen == 0 'startRun'
					runStart = i
				end 'startRun'
				runLen = runLen + 1
				if runLen >= numChunks 'gotRun'
					found = true
					break
				end 'gotRun'
			end 'free'
			i = i + 1
		end 'bitLoop'

		if found 'haveRun'
			// Clear bits runStart..runStart+numChunks-1 in the bitmap.
			for j in runStart upto runStart + numChunks 'clear'
				let qwordIdx = j shr 6
				let qwordAddr = arenaPtr + 0x10 + (qwordIdx shl 3)
				// ~(1 << (j & 63)) — Maxon has no unary `bitNot`, so xor with -1
				// (all-ones in two's complement) achieves the same result.
				let mask = (1 shl (j and 63)) xor -1
				let prior = __Internals.loadIndirect(qwordAddr)
				__Internals.storeIndirect(qwordAddr, value: prior and mask)
			end 'clear'
			// __slab_arena_last_base = arena_ptr
			__Internals.storeIndirect(__Internals.slabArenaLastBaseAddr(), value: arenaPtr)
			// result = arena + runStart * CHUNK_SIZE
			return arenaPtr + (runStart shl 13)
		end 'haveRun'

		// No run found in this arena; advance to next.
		arenaPtr = __Internals.loadIndirect(arenaPtr)
	end 'arenaLoop'
	// Unreachable — the while-true above either returns or grows then retries.
	return 0
end '__slab_arena_alloc_chunks'

// Marks chunks [chunkIndex, chunkIndex + numChunks) as free in the bitmap of
// the given arena. Bit-by-bit OR; the C# version uses qword masks for speed,
// but this is on the cold free path.
function __slab_arena_free_chunks(arenaBase int, chunkIndex int, numChunks int)
	for j in chunkIndex upto chunkIndex + numChunks 'loop'
		let qwordIdx = j shr 6
		let qwordAddr = arenaBase + 0x10 + (qwordIdx shl 3)
		let bit = 1 shl (j and 63)
		let prior = __Internals.loadIndirect(qwordAddr)
		__Internals.storeIndirect(qwordAddr, value: prior or bit)
	end 'loop'
end '__slab_arena_free_chunks'

// Public init entry. Idempotent — runs __slab_arena_init only if the
// `__slab_init_done` flag is still 0. The size-class tables, mcache /
// mcentral arrays, arena map, and OS-direct array are zeroed by the linker
// (they live in BSS-equivalent data section entries); their setup is
// implicit / lazy.
function __slab_init()
	let done = __Internals.loadIndirect(__Internals.slabInitDoneAddr())
	if done == 0 'doInit'
		__slab_arena_init()
	end 'doInit'
end '__slab_init'

// Hands out 64-byte slots used as mspan-header storage. Three-tier:
//   1. Pop from intrusive free-list at __slab_meta_free_head if non-null.
//   2. Otherwise bump within the current metadata chunk if it has room.
//   3. Otherwise grab a fresh 8 KiB chunk from the chunk allocator (one
//      chunk = 128 mspans), reserve its first 64B as the return value, and
//      reseed bump_ptr / bump_end.
function __slab_meta_alloc() returns int
	let head = __Internals.loadIndirect(__Internals.slabMetaFreeHeadAddr())
	if head != 0 'popFree'
		// result = head; head = [head]
		let next = __Internals.loadIndirect(head)
		__Internals.storeIndirect(__Internals.slabMetaFreeHeadAddr(), value: next)
		return head
	end 'popFree'

	// Bump path: if bump_ptr + 64 <= bump_end, take the current bump_ptr and
	// advance. Std-IR used signed Lt for the gate; both values are well below
	// the high bit so signed/unsigned agree.
	let bumpPtr = __Internals.loadIndirect(__Internals.slabMetaBumpPtrAddr())
	let advanced = bumpPtr + 0x40
	let bumpEnd = __Internals.loadIndirect(__Internals.slabMetaBumpEndAddr())
	if bumpEnd >= advanced 'doBump'
		__Internals.storeIndirect(__Internals.slabMetaBumpPtrAddr(), value: advanced)
		return bumpPtr
	end 'doBump'

	// Grow: fresh 8 KiB metadata chunk. First 64B is the result; the rest
	// becomes the new bump region.
	let chunkBase = __slab_arena_alloc_chunks(1)
	__Internals.storeIndirect(__Internals.slabMetaBumpPtrAddr(), value: chunkBase + 0x40)
	__Internals.storeIndirect(__Internals.slabMetaBumpEndAddr(), value: chunkBase + 0x2000)
	return chunkBase
end '__slab_meta_alloc'

// Pushes `ptr` onto the metadata free list. `[ptr] = old_head; head = ptr.`
// The slot's first 8 bytes get clobbered with the next pointer — fine, the
// caller is done with the contents.
function __slab_meta_free(ptr int)
	let oldHead = __Internals.loadIndirect(__Internals.slabMetaFreeHeadAddr())
	__Internals.storeIndirect(ptr, value: oldHead)
	__Internals.storeIndirect(__Internals.slabMetaFreeHeadAddr(), value: ptr)
end '__slab_meta_free'

// Repopulates mcache[classIdx] with a span that has at least one free slot.
// Two-tier:
//   1. Pop the head of mcentral[classIdx].partial — clearing its next_span
//      pointer — and install it as mcache[classIdx].
//   2. If partial is empty: build a fresh span by allocating chunks for the
//      slot data, an mspan header from the metadata slab, initialising the
//      mspan fields, registering it in the arena map, then walking the slot
//      region to wire up the intrusive free list.
//
// Lock acquire/release elided — single-threaded today (see step 6a.17 TODO
// in runtime.std for the multi-thread plan).
//
// mspan layout (64 bytes):
//   +0x00 base_addr   +0x08 slot_size   +0x10 free_list   +0x18 free_count
//   +0x20 next_span   +0x28 class_idx   +0x30 total_slots +0x38 arena_base
function __slab_refill_mcache(classIdx int)
	// mcentral entry address = base + classIdx * 16 (two pointer-slot pairs
	// per class). mcache slot address = base + classIdx * 8.
	let mcentralEntry = __Internals.slabMcentralArrayAddr() + (classIdx shl 4)
	let mcacheSlot = __Internals.slabMcacheBaseAddr() + (classIdx shl 3)

	let partial = __Internals.loadIndirect(mcentralEntry)
	var span = 0
	if partial != 0 'takePartial'
		// span = partial; partial_head = span.next_span; span.next_span = 0
		span = partial
		let nextSpan = __Internals.loadIndirect(partial + 0x20)
		__Internals.storeIndirect(mcentralEntry, value: nextSpan)
		__Internals.storeIndirect(partial + 0x20, value: 0)
	end 'takePartial'

	if partial == 0 'growNew'
		let slotSize = __slab_class_size(classIdx)
		let totalSlots = __slab_objs_per_span(classIdx)
		let dataSize = slotSize * totalSlots
		// numChunks = ceil(dataSize / 8192)
		let numChunks = (dataSize + 8191) shr 13

		let pageBase = __slab_arena_alloc_chunks(numChunks)
		let arenaBase = __Internals.loadIndirect(__Internals.slabArenaLastBaseAddr())

		span = __slab_meta_alloc()

		// Initialise mspan fields.
		__Internals.storeIndirect(span, value: pageBase)
		__Internals.storeIndirect(span + 0x08, value: slotSize)
		__Internals.storeIndirect(span + 0x10, value: pageBase)
		__Internals.storeIndirect(span + 0x18, value: totalSlots)
		__Internals.storeIndirect(span + 0x20, value: 0)
		__Internals.storeIndirect(span + 0x28, value: classIdx)
		__Internals.storeIndirect(span + 0x30, value: totalSlots)
		__Internals.storeIndirect(span + 0x38, value: arenaBase)

		// Register the new mspan in the arena map. num_pages == num_chunks
		// because chunks and pages are both 8KB. The migrated function's
		// second param is `endAddr` for legacy reasons; it actually
		// carries num_pages.
		__slab_arena_map_set(pageBase, endAddr: numChunks, mspan: span)

		// Build the intrusive free list: slot[i] -> slot[i+1], last slot -> 0.
		for i in 0 upto totalSlots 'linkLoop'
			let current = pageBase + i * slotSize
			if i + 1 == totalSlots 'lastSlot'
				__Internals.storeIndirect(current, value: 0)
			end 'lastSlot'
			if i + 1 != totalSlots 'midSlot'
				__Internals.storeIndirect(current, value: pageBase + (i + 1) * slotSize)
			end 'midSlot'
		end 'linkLoop'
	end 'growNew'

	// mcache[classIdx] = span
	__Internals.storeIndirect(mcacheSlot, value: span)
end '__slab_refill_mcache'

// Fast-path slab allocator. Pops a slot from the cached mspan in
// mcache[classIdx]. Refills via __slab_refill_mcache when the slot is empty
// (or the cached span unexpectedly has free_count == 0), retries the load,
// then proceeds with the pop. A successful pop that drains the span clears
// the mcache entry so the next allocation triggers a refill rather than
// walking a depleted span on every call.
function __slab_alloc_class(classIdx int) returns int
	let mcacheBase = __Internals.slabMcacheBaseAddr()
	let mcacheSlot = mcacheBase + (classIdx shl 3)
	let initialSpan = __Internals.loadIndirect(mcacheSlot)

	// Refill when the mcache slot is empty OR the cached span is depleted.
	// A `var span` we'd later re-assign tripped the optimizer in early
	// experiments; this two-pass form (one load before refill, one after)
	// keeps the per-branch SSA clean.
	var needRefill = false
	if initialSpan == 0 'noSpan'
		needRefill = true
	end 'noSpan'
	if initialSpan != 0 'haveSpan'
		if __Internals.loadIndirect(initialSpan + 0x18) == 0 'depleted'
			needRefill = true
		end 'depleted'
	end 'haveSpan'
	if needRefill 'doRefill'
		__slab_refill_mcache(classIdx)
	end 'doRefill'

	let span = __Internals.loadIndirect(mcacheSlot)
	// result = span.free_list
	let result = __Internals.loadIndirect(span + 0x10)
	// span.free_list = [result] (next pointer at slot offset 0)
	__Internals.storeIndirect(span + 0x10, value: __Internals.loadIndirect(result))
	// span.free_count -= 1
	let newFreeCount = __Internals.loadIndirect(span + 0x18) - 1
	__Internals.storeIndirect(span + 0x18, value: newFreeCount)
	// Drop drained spans from the mcache so the next call hits the refill
	// path cleanly. The span lives on through free callers via the arena map.
	if newFreeCount == 0 'evict'
		__Internals.storeIndirect(mcacheSlot, value: 0)
	end 'evict'
	return result
end '__slab_alloc_class'

// Returns `slot` to its owning mspan's free list:
//   [slot] = mspan.free_list
//   mspan.free_list = slot
//   mspan.free_count += 1
//
// Building block for __slab_free; the caller is expected to have resolved
// the owning mspan via the arena map.
function __slab_free_class_with_mspan(slot int, mspan int)
	let oldFreeList = __Internals.loadIndirect(mspan + 0x10)
	__Internals.storeIndirect(slot, value: oldFreeList)
	__Internals.storeIndirect(mspan + 0x10, value: slot)
	let newCount = __Internals.loadIndirect(mspan + 0x18) + 1
	__Internals.storeIndirect(mspan + 0x18, value: newCount)
end '__slab_free_class_with_mspan'

// Ensures L1, L2, and spans[] arrays exist for the arena map entry covering
// `addr`. Lazy-allocates each layer on first need.
//
// Three-level structure (mirrors EmitArenaMapEnsure in the C# bootstrap):
//   bits 39+   -> L1 slot      (256 entries, 2048 bytes)
//   bits 26-38 -> L2 slot      (8192 entries, 65536 bytes)
//   bits 13-25 -> spans[] slot (8192 entries, 65536 bytes)
// Each L2 covers a 64MB region; each spans[] entry covers one 8KB page.
//
// Single-threaded today — see step 6a.17 TODO in runtime.std for the
// lock-acquire / lock-release plan when threads land.
function __slab_arena_map_ensure(addr int)
	// Lazy-allocate L1 if missing.
	if __Internals.loadIndirect(__Internals.slabArenaMapL1Addr()) == 0 'allocL1'
		let l1Chunk = __slab_arena_alloc_chunks(1)
		__slab_memzero(l1Chunk, size: 2048)
		__Internals.storeIndirect(__Internals.slabArenaMapL1Addr(), value: l1Chunk)
	end 'allocL1'


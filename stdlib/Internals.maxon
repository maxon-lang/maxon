end '__mm_free'

// =============================================================================
// __ManagedMemory destructor and builtin helpers (Phase 4 migration).
//
// Each helper mirrors the runtime.std body bit-for-bit (the runtime body still
// exists for the C# bootstrap). Throwing helpers return (i64 primary, i64
// errorWire) via the multi-value error ABI: `return X` inside a `throws`
// function lowers to `errorReturn(X, 0)`, and `throw __ManagedMemoryError.case`
// lowers to `errorReturn(0, ord+1)`. The `+1` on the wire keeps 0 reserved
// for "no error in flight" — same convention used by every other throwing
// builtin (lookupVariantOrdinalPlusOne in LowerMaxonToStd.maxon).
//
// __ManagedMemoryError wire map:
//   ordinal | name              | wire
//   0       | indexOutOfBounds  | 1
//   1       | emptySlot         | 2
//   2       | sliceOutOfBounds  | 3
//   3       | invalidLength     | 4
//   4       | invalidCapacity   | 5
//   5       | shiftOutOfBounds  | 6
//   6       | invalidByteRange  | 7
//   7       | invalidAllocation | 8
//
// __ManagedMemory layout (6-field, 48-byte struct, all i64):
//   offset 0  buffer         (heap pointer to mm_alloc'd buffer, or 0)
//   offset 8  length         (live element count)
//   offset 16 capacity       (allocated element slots; -1 = slice, -2 = rdata)
//   offset 24 element_size   (sizeof(Element); 1 for Byte, 8 otherwise)
//   offset 32 parent_ptr     (-1 root; -2 rdata-backed; otherwise parent ptr)
//   offset 40 element_destroy(per-element teardown fn ptr, or 0 — see MM_OFFSET_ELEMENT_DESTROY)
//
// We use `int` rather than `__ManagedMemory` for self/result types — the
// helpers treat MMs as raw pointers and the call site re-stamps the result
// type via refineMmCallResultType.
// =============================================================================

// Single source of truth for the __ManagedMemory record size. Every hand-rolled
// __mm_alloc of a record header references this so the size lives in one place.
// (Does NOT cover element buffers or the separate __ManagedMemoryCursor struct.)
let MANAGED_MEM_RECORD_SIZE = 48

// Named byte-offsets of the five i64 fields in the __ManagedMemory record, and
// the three sentinel values the parent_ptr field can hold. Replacing the magic
// literals at every mm-record access site so the layout lives in one place.
let MM_OFFSET_BUFFER = 0
let MM_OFFSET_LENGTH = 8
let MM_OFFSET_CAPACITY = 16
let MM_OFFSET_ELEMENT_SIZE = 24
let MM_OFFSET_PARENT = 32
let MM_OFFSET_ELEMENT_DESTROY = 40
let MM_PARENT_ROOT = -1
let MM_PARENT_RDATA = -2
let MM_PARENT_UNINIT = 0

// Runtime-readable fields of the per-instantiation layout descriptor blob.
// ABI source of truth is `maxon-selfhosted/Compiler/IR/LayoutDescriptor.maxon`
// (56-byte rdata image: size@0, alignment@8, elementSize@16, flags@24,
// copyFunc@32, destroyFunc@40, fieldOffsetsPtr@48). Only the two fields the
// generic-body element-walk wiring reads at runtime are mirrored here; changing
// either end requires updating the other in lockstep. `flags` bit 0 is set when
// the instance's element type is heap-managed (a String / generic-instance
// pointer, or — after the recursive widening — a struct with managed fields).
let LAYOUT_OFFSET_FLAGS = 24
let LAYOUT_OFFSET_DESTROY_FUNC = 40
let LAYOUT_FLAG_HAS_HEAP_REFS = 1

// Allocate a raw element buffer for an mm record and return it at refcount 1.
// A ROOT `__ManagedMemory`'s `__destruct___ManagedMemory` does exactly ONE
// `__mm_decref(buffer)` at teardown, and `__mm_decref` frees only on the 1->0
// transition (alloc-at-0), so the buffer MUST be rc=1 when stored — a bare
// `__mm_alloc(size, 0, 0)` (rc=0) would have its single ROOT decref go 0->-1 and
// never free → the buffer leaks. This wraps alloc+incref (the same rc=1 contract
// `mrt_alloc` and `mm_realloc` already honor for owned buffers) so every record
// builder (create/slice/cow/from_cstring) shares one place to get an owned
// buffer. destructor=0: the buffer is raw bytes; its element pointers (if any)
// are torn down by the record's element-walk, not the buffer's own destructor.
function __managed_mem_alloc_buffer(byteLen MachineWord) returns MachineWord
	let buf = __mm_alloc(byteLen, destructor: 0)
	__mm_incref(buf)
	// Zero-fill the buffer (matches the C# `mm_raw_alloc`, which zero-fills every
	// raw allocation). `__mm_alloc` hands back a reused slab slot holding the
	// previous occupant's bytes. A container that fills its buffer SPARSELY — a
	// Map/Set hash table writes keys at hashed positions, leaving the rest
	// unwritten — would have those stale bytes read by the ROOT destructor's
	// element-walk and decref'd as live managed pointers → a fault (the
	// String-keyed-map teardown crash). Zero-init makes unoccupied slots read null
	// so the walk's `if slot != 0` guard skips them.
	var i = 0
	while i < byteLen 'zero'
		__Internals.storeByte(buf, offset: i, value: 0)
		i = i + 1
	end 'zero'
	return buf
end '__managed_mem_alloc_buffer'

// Destructor invoked indirectly by mm_free via the destructor function
// pointer baked into the mm_alloc header. Inspects `parent_ptr` (offset 32)
// to decide what to free:
//   parent == -1: root MM — drop our refcount on the buffer
//   parent == -2: rdata-backed — buffer lives in .rdata, nothing to free
//   parent == 0:  uninitialized — nothing to free
//   otherwise:    slice view — drop one ref on the parent MM
//
// Returns i64 (always 0) rather than void: indirect calls require a uniform
// signature across every callable destructor, and the wasm backend's
// call_indirect needs the static call-site type to match exactly. The
// returned 0 is silently discarded.
function __destruct___ManagedMemory(self MachineWord) returns MachineWord
	let parent = __Internals.loadIndirect(self + MM_OFFSET_PARENT)
	if parent == MM_PARENT_ROOT 'root'
		// Container element-walk teardown. element_destroy@40 holds the
		// per-element teardown function pointer (or 0 for raw/unmanaged-element
		// buffers). For managed-pointer elements it is &__mm_decref: each live
		// slot in [0, length) carries exactly +1 (push moved the caller's ref in
		// without an incref), so decref-ing the slot value once nets to zero and
		// cascades into the element's own destructor. Walk ONLY in the ROOT
		// branch — slice/rdata views alias a buffer they do not own and walking
		// them would double-free. The element_destroy==0 gate keeps raw/byte/
		// primitive buffers from being walked (decref-ing a raw int would fault).
		__managed_mem_walk_elements(self)
		let buffer = __Internals.loadIndirect(self)
		if buffer != 0 'hasBuf'
			__mm_decref(buffer)
		end 'hasBuf'
		return 0
	end 'root'
	if parent == MM_PARENT_RDATA 'rdata'
		return 0
	end 'rdata'
	if parent == MM_PARENT_UNINIT 'uninit'
		return 0
	end 'uninit'
	// Slice view: drop one ref on the parent __ManagedMemory.
	__mm_decref(parent)
	return 0
end '__destruct___ManagedMemory'

// Walk the live elements [0, length) of a ROOT record and run the per-element
// teardown (`element_destroy@40`, &__mm_decref for managed-pointer elements) on each
// non-null slot. Shared by the record's destructor (teardown) and `__managed_mem_clear`
// (truncate-to-empty): each live slot carries exactly +1 (push moved the caller's ref
// in without an incref), so one decref nets to zero and cascades into the element's
// own destructor. A 0 `element_destroy` (raw/primitive elements) makes this a no-op —
// decref-ing a raw int would fault. Does NOT touch the buffer or length; callers do.
function __managed_mem_walk_elements(self MachineWord)
	let elementDestroy = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_DESTROY)
	if elementDestroy == 0 'rawElems'
		return
	end 'rawElems'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let walkBuf = __Internals.loadIndirect(self)
	if walkBuf == 0 'noBuf'
		return
	end 'noBuf'
	var i = 0
	while i < length 'eachElem'
		let slot = __Internals.loadIndirect(walkBuf + i * elemSize)
		if slot != 0 'live'
			// `element_destroy` is `&__mm_decref` (void), so use the void-shaped
			// indirect call — wasm's `call_indirect` type-checks the site against the
			// target's `(i64) -> void` signature (`indirectCall1` would trap as a
			// mismatch). See `lowerInternalsIndirectCall1`.
			__Internals.indirectCallVoid1(elementDestroy, arg: slot)
		end 'live'
		i = i + 1
	end 'eachElem'
end '__managed_mem_walk_elements'

// clear(self) — drop every live managed element, then truncate to empty (length=0).
// `Array.clear()` formerly lowered to a bare `length = 0`, which leaked every managed
// element (the slots' +1 refs were orphaned with no walk). Walk-then-truncate frees
// them; the backing buffer + capacity are retained for reuse. For a raw-element record
// the walk is inert, so this stays correct (and a no-op beyond the length store) for
// `Array with Integer`/`Byte`. Returns 0 (the void result the lowering binds).
function __managed_mem_clear(self MachineWord) returns MachineWord
	__managed_mem_walk_elements(self)
	__Internals.storeIndirect(self + MM_OFFSET_LENGTH, value: 0)
	return 0
end '__managed_mem_clear'

// __destruct___ManagedMemoryCursor(self): release the source __ManagedMemory the
// cursor RETAINED at creation. A for-in cursor borrows the source collection's
// buffer (cursor.buffer@0 aliases source.buffer), so the source MUST stay alive
// for the whole loop — lowerCreateCursor increfs source_ptr@32 when building the
// cursor, and this destructor drops that ref when the iterator (which owns the
// cursor) is torn down. Without the retain+release pair the inserter freed the
// source collection right after createIterator() (its textual last use), leaving
// the cursor's buffer pointer dangling → SIGSEGV on the 2nd iteration once the
// freed slab slot was reused. `buffer@0` is NOT decref'd here: it is owned by the
// source record (source_ptr), released transitively when source_ptr's refcount
// hits 0. Returns i64 (0) to match the indirect-call destructor ABI.
function __destruct___ManagedMemoryCursor(self MachineWord) returns MachineWord
	let sourcePtr = __Internals.loadIndirect(self + 32)
	if sourcePtr != 0 'hasSource'
		__mm_decref(sourcePtr)
	end 'hasSource'
	return 0
end '__destruct___ManagedMemoryCursor'

// setLength(self, n) — bounds-check n against capacity, then write to
// self.length. Throws invalidLength (wire 4) on n > capacity.
function __managed_mem_set_length(self MachineWord, n MachineWord) returns MachineWord throws __ManagedMemoryError
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if n > capacity 'tooLong'
		throw __ManagedMemoryError.invalidLength
	end 'tooLong'
	__Internals.storeIndirect(self + MM_OFFSET_LENGTH, value: n)
	return 0
end '__managed_mem_set_length'

// Bit-packed-bool element access (element_size == 0 sentinel): one bit per
// element, bit (idx & 7) of byte (idx >> 3). These two helpers are the single
// source of truth for that layout, shared by get / cursor_current (read) and
// set / raw_set (write) so the masking math can never drift between sites.
function __managed_mem_read_bit(buffer MachineWord, idx MachineWord) returns MachineWord
	let byte = __Internals.loadByte(buffer + (idx shr 3), offset: 0)
	return (byte shr (idx and 7)) and 1
end '__managed_mem_read_bit'

function __managed_mem_write_bit(buffer MachineWord, idx MachineWord, value MachineWord)
	let byteAddr = buffer + (idx shr 3)
	let bitOff = idx and 7
	let cur = __Internals.loadByte(byteAddr, offset: 0)
	let cleared = cur and (255 xor (1 shl bitOff))
	let newByte = cleared or ((value and 1) shl bitOff)
	__Internals.storeByte(byteAddr, offset: 0, value: newByte)
end '__managed_mem_write_bit'

// Width-dispatched scalar load/store at a precomputed element address. The
// element_size cascade (1→byte, 2→halfword, 4→word, else qword) was copied
// across get / cursor_current (load) and set / raw_set (store); centralize it
// so a new width or a fixed default lands in exactly one place. Unsigned reads —
// typed sign-extension is applied by the caller's field-load shim.
function __managed_mem_load_sized(addr MachineWord, elemSize MachineWord) returns MachineWord
	if elemSize == 1 'b'
		return __Internals.loadByte(addr, offset: 0)
	end 'b'
	if elemSize == 2 'h'
		return __Internals.loadHalfword(addr)
	end 'h'
	if elemSize == 4 'w'
		return __Internals.loadWord(addr)
	end 'w'
	return __Internals.loadIndirect(addr)
end '__managed_mem_load_sized'

function __managed_mem_store_sized(addr MachineWord, elemSize MachineWord, value MachineWord)
	if elemSize == 1 'b'
		__Internals.storeByte(addr, offset: 0, value: value)
		return
	end 'b'
	if elemSize == 2 'h'
		__Internals.storeHalfword(addr, value: value)
		return
	end 'h'
	if elemSize == 4 'w'
		__Internals.storeWord(addr, value: value)
		return
	end 'w'
	__Internals.storeIndirect(addr, value: value)
end '__managed_mem_store_sized'

// cursor_current(cursor) — load the element at the cursor's current
// position, dispatching on element_size like __managed_mem_get does.
// Non-throwing: callers (the for-in iterator protocol) only invoke this
// after a successful `advance()`, which guarantees `position < length`,
// so the bounds check from __managed_mem_get is provably dead.
// Cursor layout: buffer @0, position @8, length @16, element_size @24,
// source_ptr @32. Each load is zero-extending; source-level signed
// narrow types are sign-extended at the call site by the
// `maybeSignExtendCallResult` shim in LowerMaxonToStd.
function __managed_mem_cursor_current(cursor MachineWord) returns MachineWord
	let buffer = __Internals.loadIndirect(cursor)
	let position = __Internals.loadIndirect(cursor + 8)
	let elemSize = __Internals.loadIndirect(cursor + 24)
	// element_size == 0 is the bit-packed-bool sentinel: extract bit
	// (position & 7) of byte (position >> 3) — same layout as __managed_mem_get.
	if elemSize == 0 'bit'
		return __managed_mem_read_bit(buffer, idx: position)
	end 'bit'
	return __managed_mem_load_sized(buffer + position * elemSize, elemSize: elemSize)
end '__managed_mem_cursor_current'

// get(self, idx) — bounds-check idx ∈ [0, length), then load the element.
// Dispatch on element_size: 1 byte (loadByte), 2 (loadHalfword), 4 (loadWord),
// fall through to qword (loadIndirect). Unsigned reads — typed sign-extension
// is handled by the source-level field-load path with signed: true.
// Throws indexOutOfBounds (wire 1) on OOB.
function __managed_mem_get(self MachineWord, idx MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 0 'lo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'lo'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	if idx >= length 'hi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'hi'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	// element_size == 0 is the bit-packed-bool sentinel: one bit per element.
	// Extract bit (idx & 7) of byte (idx >> 3) and normalize to 0/1.
	if elemSize == 0 'bit'
		return __managed_mem_read_bit(buffer, idx: idx)
	end 'bit'
	return __managed_mem_load_sized(buffer + idx * elemSize, elemSize: elemSize)
end '__managed_mem_get'

// set(self, idx, value) — bounds-check idx ∈ [0, capacity) (push() reserves
// then writes-past-length-but-within-capacity), then store. COW-aware: if
// capacity < 0 (rdata=-2 or slice=-1), materialize a private heap buffer
// first via cow_check, then re-bounds-check against the post-COW capacity
// (now == length). Throws indexOutOfBounds (wire 1) on OOB.
function __managed_mem_set(self MachineWord, idx MachineWord, value MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 0 'lo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'lo'
	var capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity < 0 'cow'
		_ = __managed_mem_cow_check(self)
		capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	end 'cow'
	if idx >= capacity 'hi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'hi'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	// In-place overwrite of a LIVE managed element must release the displaced
	// occupant, or its +1 leaks (the teardown walk only decrefs whatever the slot
	// holds at teardown — the new value, not the one we overwrite here). Gate on
	// element_destroy != 0 (managed-pointer elements only — raw/primitive slots
	// hold no refcounted occupant) AND idx < length (the slot already holds a live
	// element). `push` writes at idx == length (a fresh, never-occupied slot) so it
	// is correctly excluded — it MOVES the caller's +1 in with no decref. The new
	// value's +1 likewise moves in here (the caller's last-use decref is suppressed
	// by `opMovesValueIntoContainer`), so net per element stays 0.
	let elementDestroy = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_DESTROY)
	if elementDestroy != 0 'maybeReleaseOld'
		let curLength = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
		if idx < curLength 'liveSlot'
			let oldVal = __Internals.loadIndirect(buffer + idx * elemSize)
			if oldVal != 0 'haveOld'
				// `element_destroy` is `&__mm_decref` (void) — void-shaped indirect call
				// so wasm's typed `call_indirect` matches the target (mirrors the
				// element-walk site; see `lowerInternalsIndirectCall1`).
				__Internals.indirectCallVoid1(elementDestroy, arg: oldVal)
			end 'haveOld'
		end 'liveSlot'
	end 'maybeReleaseOld'
	// element_size == 0 is the bit-packed-bool sentinel: read-modify-write the
	// single bit (idx & 7) of byte (idx >> 3).
	if elemSize == 0 'bit'
		__managed_mem_write_bit(buffer, idx: idx, value: value)
		return 0
	end 'bit'
	__managed_mem_store_sized(buffer + idx * elemSize, elemSize: elemSize, value: value)
	return 0
end '__managed_mem_set'

// swap(self, i, j) — exchange the raw element_size bytes of slots i and j with
// NO refcount traffic. A swap MOVES ownership between slots: both occupants stay
// live inside the container, their refcounts unchanged. This is exactly why it
// must NOT go through get+set — `__managed_mem_set` decrefs the displaced
// occupant (correct for an OVERWRITE, where the old value is discarded), which
// during a swap would free a box that is merely being relocated to the other
// slot → use-after-free / corrupted elements (the sort-of-managed-elements bug).
// COW-aware: a slice/rdata-backed buffer (capacity < 0) is materialized private
// first so the swap never mutates shared storage. Bounds: i,j ∈ [0, length).
// Throws indexOutOfBounds (wire 1) on OOB.
function __managed_mem_swap(self MachineWord, i MachineWord, j MachineWord) returns MachineWord throws __ManagedMemoryError
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	if i < 0 'iLo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'iLo'
	if i >= length 'iHi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'iHi'
	if j < 0 'jLo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'jLo'
	if j >= length 'jHi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'jHi'
	if i == j 'noOp'
		return 0
	end 'noOp'
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity < 0 'cow'
		_ = __managed_mem_cow_check(self)
	end 'cow'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	// element_size == 0 is the bit-packed-bool sentinel: swap the two bits in
	// place (read both, write each to the other's slot) — no whole-byte copy.
	if elemSize == 0 'bit'
		let iByteAddr = buffer + (i shr 3)
		let iBitOff = i and 7
		let jByteAddr = buffer + (j shr 3)
		let jBitOff = j and 7
		let iCur = __Internals.loadByte(iByteAddr, offset: 0)
		let jCur = __Internals.loadByte(jByteAddr, offset: 0)
		let iBit = (iCur shr iBitOff) and 1
		let jBit = (jCur shr jBitOff) and 1
		let iCleared = iCur and (255 xor (1 shl iBitOff))
		__Internals.storeByte(iByteAddr, offset: 0, value: iCleared or (jBit shl iBitOff))
		// Re-read j's byte: i and j may live in the SAME byte, so the store above
		// can have changed it — operate on the freshest value to avoid clobbering.
		let jCur2 = __Internals.loadByte(jByteAddr, offset: 0)
		let jCleared = jCur2 and (255 xor (1 shl jBitOff))
		__Internals.storeByte(jByteAddr, offset: 0, value: jCleared or (iBit shl jBitOff))
		return 0
	end 'bit'
	let iAddr = buffer + i * elemSize
	let jAddr = buffer + j * elemSize
	// Byte-wise exchange of the two element_size-byte slots. The slots are
	// distinct (i != j), so no overlap — a forward byte loop is safe.
	var b = 0
	while b < elemSize 'swapBytes'
		let ib = __Internals.loadByte(iAddr, offset: b)
		let jb = __Internals.loadByte(jAddr, offset: b)
		__Internals.storeByte(iAddr, offset: b, value: jb)
		__Internals.storeByte(jAddr, offset: b, value: ib)
		b = b + 1
	end 'swapBytes'
	return 0
end '__managed_mem_swap'

// rawSet(self, idx, value) — store `value` into slot `idx` as a pure
// element_size-byte overwrite, with NO refcount traffic: it does NOT decref the
// displaced occupant (unlike `set`) and does NOT assume the stored value carries
// a +1 to move in. This is the relocation primitive for a PERMUTATION (the sort):
// the same multiset of elements is shuffled within the buffer, so every element's
// refcount must stay invariant — the displaced occupant is not discarded, it is
// being moved elsewhere by another rawSet in the same pass. Bounds: idx ∈
// [0, capacity); COW-materializes a shared buffer first. For a scalar element the
// `value` IS the datum; for a managed/struct element it is the element pointer.
// Throws indexOutOfBounds (wire 1) on OOB.
function __managed_mem_raw_set(self MachineWord, idx MachineWord, value MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 0 'lo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'lo'
	var capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity < 0 'cow'
		_ = __managed_mem_cow_check(self)
		capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	end 'cow'
	if idx >= capacity 'hi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'hi'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	// element_size == 0 is the bit-packed-bool sentinel: read-modify-write the bit.
	if elemSize == 0 'bit'
		__managed_mem_write_bit(buffer, idx: idx, value: value)
		return 0
	end 'bit'
	__managed_mem_store_sized(buffer + idx * elemSize, elemSize: elemSize, value: value)
	return 0
end '__managed_mem_raw_set'

// Buffer-level Copy-On-Write. If capacity >= 0 the buffer is already
// mm_alloc-owned and writable — no-op. If capacity < 0 (rdata = -2 or
// slice = -1) the buffer is shared / read-only; allocate a fresh
// length*elemSize-byte buffer, memcpy, and rewire self.buffer + self.capacity.
// The old rdata/slice buffer is intentionally NOT freed (rdata is in the
// binary's read-only section; slice buffers are owned by their parent).
// Non-throwing.
function __managed_mem_cow_check(self MachineWord) returns MachineWord
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity >= 0 'noCopy'
		return 0
	end 'noCopy'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	// Bit-packed bool buffers (element_size == 0) hold (length + 7) >> 3 bytes;
	// every other element type holds length * element_size bytes.
	let byteLen = ((length + 7) shr 3) if elemSize == 0 else (length * elemSize)
	// Owned (rc=1) raw byte buffer — see __managed_mem_alloc_buffer. mm_alloc
	// clamps zero-sized requests to 1.
	let newBuf = __managed_mem_alloc_buffer(byteLen)
	let oldBuf = __Internals.loadIndirect(self)
	// memcpy handles byteLen == 0 as a no-op per ABI.
	__Internals.memcpy(newBuf, src: oldBuf, size: byteLen)
	__Internals.storeIndirect(self, value: newBuf)
	__Internals.storeIndirect(self + MM_OFFSET_CAPACITY, value: length)
	// Promote the record to ROOT now that it owns a private heap buffer.
	// `__destruct___ManagedMemory` keys teardown on parent_ptr (NOT capacity), so
	// without this the record kept its pre-COW parent — RDATA (-2: "nothing to
	// free", so the new owned buffer leaked — the append/grow-from-literal leak) or
	// a slice parent (whose ref we must now drop, since we no longer alias its
	// buffer). Capture the old parent before overwriting, set ROOT, then release a
	// real slice parent (a heap pointer, i.e. not one of the ROOT/RDATA/UNINIT
	// sentinels).
	let oldParent = __Internals.loadIndirect(self + MM_OFFSET_PARENT)
	__Internals.storeIndirect(self + MM_OFFSET_PARENT, value: MM_PARENT_ROOT)
	if oldParent != MM_PARENT_ROOT and oldParent != MM_PARENT_RDATA and oldParent != MM_PARENT_UNINIT 'wasSlice'
		__mm_decref(oldParent)
	end 'wasSlice'
	return 0
end '__managed_mem_cow_check'

// grow(self, newCap) — promote rdata/slice buffer to a private heap buffer
// (no-op when capacity >= 0), then reallocate via mm_realloc. Throws
// invalidCapacity (wire 5) on newCap < capacity. mm_realloc is still in
// runtime.std, so we cross the bridge via `__Internals.mmRealloc`.
function __managed_mem_grow(self MachineWord, newCap MachineWord) returns MachineWord throws __ManagedMemoryError
	_ = __managed_mem_cow_check(self)
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if newCap < capacity 'tooSmall'
		throw __ManagedMemoryError.invalidCapacity
	end 'tooSmall'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let newSize = newCap * elemSize
	let oldBuf = __Internals.loadIndirect(self)
	let newBuf = __Internals.mmRealloc(oldBuf, newSize: newSize)
	__Internals.storeIndirect(self, value: newBuf)
	__Internals.storeIndirect(self + MM_OFFSET_CAPACITY, value: newCap)
	return 0
end '__managed_mem_grow'

// byteAt(self, i) — load a single byte at byte-offset `i` from the buffer.
// Bound: 0 <= i < length * element_size. Throws invalidByteRange (wire 7).
function __managed_mem_byte_at(self MachineWord, i MachineWord) returns MachineWord throws __ManagedMemoryError
	if i < 0 'lo'
		throw __ManagedMemoryError.invalidByteRange
	end 'lo'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let limit = length * elemSize
	if i >= limit 'hi'
		throw __ManagedMemoryError.invalidByteRange
	end 'hi'
	let buffer = __Internals.loadIndirect(self)
	return __Internals.loadByte(buffer, offset: i)
end '__managed_mem_byte_at'

// setByte(self, i, value) — store a single byte at byte-offset `i`. Bound:
// 0 <= i < length * element_size. COWs the buffer first so rdata-backed
// MMs become writable. Throws invalidByteRange (wire 7).
function __managed_mem_set_byte(self MachineWord, i MachineWord, value MachineWord) returns MachineWord throws __ManagedMemoryError
	if i < 0 'lo'
		throw __ManagedMemoryError.invalidByteRange
	end 'lo'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let limit = length * elemSize
	if i >= limit 'hi'
		throw __ManagedMemoryError.invalidByteRange
	end 'hi'
	_ = __managed_mem_cow_check(self)
	let buffer = __Internals.loadIndirect(self)
	__Internals.storeByte(buffer, offset: i, value: value)
	return 0
end '__managed_mem_set_byte'

// remove(self, idx) — load the element at idx, shift the tail left by one
// element via a byte-by-byte ascending loop (overlap-safe), decrement
// length, and return the loaded value. Throws indexOutOfBounds (wire 1).
function __managed_mem_remove(self MachineWord, idx MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 0 'lo'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'lo'
	let length = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	if idx >= length 'hi'
		throw __ManagedMemoryError.indexOutOfBounds
	end 'hi'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	let elemAddr = buffer + idx * elemSize
	// Element-width dispatch mirrors __managed_mem_get. After the load we
	// shift the tail via the byte-loop below regardless of element width.
	var result = 0
	if elemSize == 1 'b'
		result = __Internals.loadByte(elemAddr, offset: 0)
	end 'b' else 'notByte'
		if elemSize == 2 'h'
			result = __Internals.loadHalfword(elemAddr)
		end 'h' else 'notHalf'
			if elemSize == 4 'w'
				result = __Internals.loadWord(elemAddr)
			end 'w' else 'qword'
				result = __Internals.loadIndirect(elemAddr)
			end 'qword'
		end 'notHalf'
	end 'notByte'
	// Byte-loop shift: src byte = (idx + 1) * elemSize; dst = src - elemSize.
	let srcStart = (idx + 1) * elemSize
	let endByte = length * elemSize
	var i = srcStart
	while i < endByte 'shiftLoop'
		let byte = __Internals.loadByte(buffer, offset: i)
		__Internals.storeByte(buffer, offset: i - elemSize, value: byte)
		i = i + 1
	end 'shiftLoop'
	__Internals.storeIndirect(self + MM_OFFSET_LENGTH, value: length - 1)
	return result
end '__managed_mem_remove'

// shiftRight(self, idx, count) — shift `count` elements starting at idx
// right by one element. Bounds: idx >= 0, count >= 0, idx + count <=
// capacity. Implemented as a descending byte-loop so overlapping copies
// are safe. Throws shiftOutOfBounds (wire 6).
function __managed_mem_shift_right(self MachineWord, idx MachineWord, count MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 0 'idxNeg'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'idxNeg'
	if count < 0 'countNeg'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'countNeg'
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if idx + count > capacity 'oob'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'oob'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	// sourceLastByte = (idx + count) * elemSize - 1; descend to
	// startByte = idx * elemSize.
	let startByte = idx * elemSize
	var i = (idx + count) * elemSize - 1
	while i >= startByte 'loop'
		let byte = __Internals.loadByte(buffer, offset: i)
		__Internals.storeByte(buffer, offset: i + elemSize, value: byte)
		i = i - 1
	end 'loop'
	// Zero the vacated source slot at buffer[idx] so the caller's following
	// `set(idx, value)` does not decref the STALE DUPLICATE pointer the shift left
	// there (the original occupant was copied to buffer[idx+1]). Without this, the
	// `set` decref-old frees the element we just relocated → dangling slot at idx+1.
	// This MIRRORS the C# bootstrap's `LowerManagedMemShift` intrinsic, which is the
	// reference implementation: C# intercepts every `__managed_mem_*` builtin and
	// emits its own lowering that zeroes this same slot ("prevent the subsequent
	// set() from decrefing a stale duplicate pointer"). The self-hosted compiler runs
	// THIS Maxon body instead, so it must carry the identical zeroing.
	var z = startByte
	let holeEnd = startByte + elemSize
	while z < holeEnd 'clearHole'
		__Internals.storeByte(buffer, offset: z, value: 0)
		z = z + 1
	end 'clearHole'
	return 0
end '__managed_mem_shift_right'

// shiftLeft(self, idx, count) — shift `count` elements starting at idx left
// by one element. Bounds: idx >= 1 (so idx-1 is valid), count >= 0,
// idx + count <= capacity. Ascending byte-loop for overlap safety.
// Throws shiftOutOfBounds (wire 6).
function __managed_mem_shift_left(self MachineWord, idx MachineWord, count MachineWord) returns MachineWord throws __ManagedMemoryError
	if idx < 1 'idxLow'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'idxLow'
	if count < 0 'countNeg'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'countNeg'
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if idx + count > capacity 'oob'
		throw __ManagedMemoryError.shiftOutOfBounds
	end 'oob'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let buffer = __Internals.loadIndirect(self)
	let endByte = (idx + count) * elemSize
	var i = idx * elemSize
	while i < endByte 'loop'
		let byte = __Internals.loadByte(buffer, offset: i)
		__Internals.storeByte(buffer, offset: i - elemSize, value: byte)
		i = i + 1
	end 'loop'
	return 0
end '__managed_mem_shift_left'

// append(self, other) — grow self if needed so capacity >= self.length +
// other.length, then memcpy other's first (other.length * elemSize) bytes
// onto the end of self.buffer. Element-size compatibility is the caller's
// responsibility (we use self.element_size for byte arithmetic on both
// sides — same as the bootstrap). Non-throwing.
function __managed_mem_append(self MachineWord, other MachineWord) returns MachineWord
	let selfLen = __Internals.loadIndirect(self + MM_OFFSET_LENGTH)
	let otherLen = __Internals.loadIndirect(other + MM_OFFSET_LENGTH)
	let newLength = selfLen + otherLen
	let capacity = __Internals.loadIndirect(self + MM_OFFSET_CAPACITY)
	if capacity < newLength 'doGrow'
		// Geometric growth: request max(newLength, capacity*2) so a series
		// of `append` calls runs in amortized O(1) per element. Without
		// this, every append reallocates the full buffer at exactly the
		// new length — turning loops like `for x in items: s.append(x)`
		// into O(N²). Start at 8 elements when growing from empty so a
		// few-element accumulation doesn't bounce-grow.
		var requested = newLength
		let doubled = capacity * 2
		if doubled > requested 'preferDoubled'
			requested = doubled
		end 'preferDoubled'
		if requested < 8 'atLeast8'
			requested = 8
		end 'atLeast8'
		// grow throws invalidCapacity, but requested > capacity here so the
		// throw path is unreachable. We discard the tuple result; the error
		// wire is also discarded because no try/otherwise surrounds the call.
		_ = try __managed_mem_grow(self, newCap: requested) otherwise 0
	end 'doGrow'
	let elemSize = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_SIZE)
	let selfBuf = __Internals.loadIndirect(self)
	let otherBuf = __Internals.loadIndirect(other)
	let dst = selfBuf + selfLen * elemSize
	let nBytes = otherLen * elemSize
	__Internals.memcpy(dst, src: otherBuf, size: nBytes)

	// Managed-element append SHARES the copied elements with `other`: take +1 on
	// each copied slot (released once by each record's teardown walk) and
	// propagate the element_destroy stamp onto a destination that doesn't carry
	// it yet (an `Array.create()`-fresh accumulator) so the destination's walk
	// actually fires. Either record may carry the stamp — read both. Without
	// this, freeing the source array freed the appended elements out from under
	// the destination (the append-managed-elements source-freed UAF).
	let selfDestroy = __Internals.loadIndirect(self + MM_OFFSET_ELEMENT_DESTROY)
	let otherDestroy = __Internals.loadIndirect(other + MM_OFFSET_ELEMENT_DESTROY)

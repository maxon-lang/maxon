// Hash map implementation using open addressing with linear probing
//
// **Design Philosophy**:
// - Open addressing for cache-friendly access
// - Linear probing for simplicity
// - Automatic resize at 75% load factor
// - Keys must implement Hashable interface
//
// **Slot States**:
// - 0 = EMPTY (never used)
// - 1 = OCCUPIED (has valid key-value pair)
// - 2 = DELETED (tombstone for probing continuity)
//
// **Usage**:
// ```maxon
// var m = Map from ["a": 1, "b": 2, "c": 3]
// m.insert(key: "d", value: 4)
// var v = try m.get(key: "b") otherwise 0
// print("found: {v}")
// ```

enum SlotState
	Empty
	Occupied
	Deleted
end 'SlotState'

// Map is special-cased by the compiler for map literal initialization.
// It receives __ManagedArrays directly rather than going through InitableFromDictionaryLiteral.
export type Map uses Key, Value is Builtin, Sized, Dictionary with (Key, Value), Iterable with (Pair with (Key, Value))
	var keys Array of Key              // Key storage
	var values Array of Value          // Value storage
	var states Array of SlotState      // Slot states
	var count int                      // Number of occupied entries
	var capacity int                   // Total slots
	var iterIndex int                  // Iteration state

	// Internal init used by compiler for map literal initialization
	// Called by the compiler for `Map from ["a": 1, "b": 2]` syntax
	// The keys and values are received as raw __ManagedArray containing typed elements
	static function Builtin.init(initKeys __ManagedArray, initValues __ManagedArray) returns Self
		// Get number of elements in the managed arrays
		var numElements = __managed_array_len(initKeys)

		// Calculate capacity: at least 16, or next power of 2 above numElements * 2
		var cap = 16
		while cap < numElements * 2 'calc_cap'
			cap = cap * 2
		end 'calc_cap'

		// Allocate internal arrays
		var ks = Array of cap Key
		var vs = Array of cap Value
		var sts = Array of cap SlotState

		// Create the map with arrays but zero count
		var result = Self{keys: ks, values: vs, states: sts, count: 0, capacity: cap, iterIndex: 0}

		// Insert each key-value pair from the init arrays
		// Use __map_get_init_key/value which look up "Key"/"Value" generic params
		var i = 0
		while i < numElements 'insert_loop'
			var k = __map_get_init_key(initKeys, i)
			var v = __map_get_init_value(initValues, i)
			result.insert(key: k, value: v)
			i = i + 1
		end 'insert_loop'

		return result
	end 'init'

	/// Insert a key-value pair into the map
	/// If the key already exists, updates the value
	/// Automatically resizes the map when load factor exceeds 75%
	export function Dictionary.insert(key Key, value Value)
		// Initialize if empty struct was created with zero capacity
		if capacity == 0 'init_empty'
			var newKeys = Array of 16 Key
			var newValues = Array of 16 Value
			var newStates = Array of 16 SlotState
			keys = newKeys
			values = newValues
			states = newStates
			capacity = 16
		end 'init_empty'

		// Check load factor and grow if needed (75% threshold)
		var loadLimit = trunc((capacity * 3) / 4)
		if count >= loadLimit 'do_grow'
			grow()
		end 'do_grow'

		var hash = key.hash()
		var index = hash mod capacity
		if index < 0 'fix_negative'
			index = index + capacity
		end 'fix_negative'

		var firstDeleted = -1
		var probes = 0

		while probes < capacity 'probe'
			var state = try states.get(index: index) otherwise SlotState.Empty

			if state == SlotState.Empty 'empty'
				// Empty slot - insert here or at first deleted
				var insertIndex = index
				if firstDeleted >= 0 'use_deleted'
					insertIndex = firstDeleted
				end 'use_deleted'

				keys.set(index: insertIndex, value: key)
				values.set(index: insertIndex, value: value)
				states.set(index: insertIndex, value: SlotState.Occupied)
				count = count + 1
				return
			end 'empty'

			if state == SlotState.Deleted and firstDeleted < 0 'mark_deleted'
				firstDeleted = index
			end 'mark_deleted'

			if state == SlotState.Occupied 'check_key'
				if let existing = try keys.get(index: index) 'get_existing'
					if existing == key 'exists'
						// Key already exists - update value
						values.set(index: index, value: value)
						return
					end 'exists'
				end 'get_existing'
			end 'check_key'

			// Linear probing
			index = (index + 1) mod capacity
			probes = probes + 1
		end 'probe'

		// Should never reach here if load factor is maintained
		// But if we do, insert at first deleted slot
		if firstDeleted >= 0 'fallback'
			keys.set(index: firstDeleted, value: key)
			values.set(index: firstDeleted, value: value)
			states.set(index: firstDeleted, value: SlotState.Occupied)
			count = count + 1
		end 'fallback'
	end 'insert'

	/// Get the value for a key, throws if not found
	export function Dictionary.get(key Key) returns Value throws MapError
		// Empty map contains nothing
		if capacity == 0 'empty_check'
			throw MapError.keyNotFound
		end 'empty_check'

		var hash = key.hash()
		var index = hash mod capacity
		if index < 0 'fix_negative'
			index = index + capacity
		end 'fix_negative'

		var probes = 0
		while probes < capacity 'probe'
			var state = try states.get(index: index) otherwise SlotState.Empty

			if state == SlotState.Empty 'empty'
				throw MapError.keyNotFound
			end 'empty'

			if state == SlotState.Occupied 'check_key'
				if let existing = try keys.get(index: index) 'get_existing'
					if existing == key 'found'
						if let v = try values.get(index: index) 'get_value'
							return v
						end 'get_value'
					end 'found'
				end 'get_existing'
			end 'check_key'

			index = (index + 1) mod capacity
			probes = probes + 1
		end 'probe'

		throw MapError.keyNotFound
	end 'get'

	/// Check if key exists in the map
	export function Dictionary.contains(key Key) returns bool
		// Empty map contains nothing
		if capacity == 0 'empty_check'
			return false
		end 'empty_check'

		var hash = key.hash()
		var index = hash mod capacity
		if index < 0 'fix_negative'
			index = index + capacity
		end 'fix_negative'

		var probes = 0
		while probes < capacity 'probe'
			var state = try states.get(index: index) otherwise SlotState.Empty

			if state == SlotState.Empty 'empty'
				return false
			end 'empty'

			if state == SlotState.Occupied 'check_key'
				if let existing = try keys.get(index: index) 'get_existing'
					if existing == key 'found'
						return true
					end 'found'
				end 'get_existing'
			end 'check_key'

			index = (index + 1) mod capacity
			probes = probes + 1
		end 'probe'

		return false
	end 'contains'

	/// Remove key from map, returns true if key was present
	export function Dictionary.remove(key Key) returns bool
		// Empty map has nothing to remove
		if capacity == 0 'empty_check'
			return false
		end 'empty_check'

		var hash = key.hash()
		var index = hash mod capacity
		if index < 0 'fix_negative'
			index = index + capacity
		end 'fix_negative'

		var probes = 0
		while probes < capacity 'probe'
			var state = try states.get(index: index) otherwise SlotState.Empty

			if state == SlotState.Empty 'empty'
				return false
			end 'empty'

			if state == SlotState.Occupied 'check_key'
				if let existing = try keys.get(index: index) 'get_existing'
					if existing == key 'found'
						states.set(index: index, value: SlotState.Deleted)
						count = count - 1
						return true
					end 'found'
				end 'get_existing'
			end 'check_key'

			index = (index + 1) mod capacity
			probes = probes + 1
		end 'probe'

		return false
	end 'remove'

	/// Get number of entries in the map
	export function Sized.count() returns int
		return count
	end 'count'

	/// Iterate through map entries, returning key-value pairs
	function Iterable.next() returns Pair of Key Value throws IterationError
		while iterIndex < capacity 'scan'
			var state = try states.get(index: iterIndex) otherwise SlotState.Empty
			var idx = iterIndex
			iterIndex = iterIndex + 1
			if state == SlotState.Occupied 'occupied'
				var k = try keys.get(index: idx) otherwise 'get_k'
				throw IterationError.exhausted
				end 'get_k'
				var v = try values.get(index: idx) otherwise 'get_v'
				throw IterationError.exhausted
				end 'get_v'
				return Pair{key: k, value: v}
			end 'occupied'
		end 'scan'
		throw IterationError.exhausted
	end 'next'

	/// Get current capacity (total number of slots)
	export function getCapacity() returns int
		return capacity
	end 'getCapacity'

	// Internal: grow the table when load factor exceeds threshold
	function grow()
		var oldCapacity = capacity
		var newCapacity = oldCapacity * 2
		if newCapacity == 0 'handle_zero'
			newCapacity = 16
		end 'handle_zero'

		// Save references to old arrays
		var oldKeys = keys
		var oldValues = values
		var oldStates = states

		// Allocate new arrays
		var newKeys = Array of newCapacity Key
		var newValues = Array of newCapacity Value
		var newStates = Array of newCapacity SlotState

		// Update type to use new arrays
		keys = newKeys
		values = newValues
		states = newStates
		capacity = newCapacity
		count = 0

		// Rehash all occupied entries from old arrays
		var i = 0
		while i < oldCapacity 'rehash'
			var state = try oldStates.get(index: i) otherwise SlotState.Empty

			if state == SlotState.Occupied 'occupied'
				// Re-insert into new arrays using insert logic
				var key = try oldKeys.get(index: i) otherwise 'skip_key'
				i = i + 1
				continue 'rehash'
				end 'skip_key'
				var value = try oldValues.get(index: i) otherwise 'skip_val'
				i = i + 1
				continue 'rehash'
				end 'skip_val'
				var hash = key.hash()
				var index = hash mod newCapacity
				if index < 0 'fix_negative'
					index = index + newCapacity
				end 'fix_negative'

				// Find empty slot (no deleted slots in fresh array)
				var currentState = try states.get(index: index) otherwise SlotState.Empty
				while currentState != SlotState.Empty 'find_slot'
					index = (index + 1) mod newCapacity
					currentState = try states.get(index: index) otherwise SlotState.Empty
				end 'find_slot'

				keys.set(index: index, value: key)
				values.set(index: index, value: value)
				states.set(index: index, value: SlotState.Occupied)
				count = count + 1
			end 'occupied'
			i = i + 1
		end 'rehash'
	end 'grow'
end 'Map'

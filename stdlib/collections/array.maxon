// stdlib/collections/array.maxon
// Array wrapper providing count() method via intrinsic
//
// This struct wraps a raw array and provides stdlib methods.
// Access to array length is through the __array_len() intrinsic.

export struct array uses Element is Iterable with character
	var _data []Element

	// Get the number of elements in the array
	export function count() int
		return __array_len(_data)
	end 'count'
end 'array'


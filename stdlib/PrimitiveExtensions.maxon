/// Extension methods for primitive types implementing core interfaces.

extension int implements Hashable, Equatable, Comparable, Stringable, Cloneable, Strideable
  function hash() returns int
    return self
  end 'hash'

  function equals(other int) returns bool
    return self == other
  end 'equals'

  function compare(other int) returns int
    if self < other 'lt'
      return 0 - 1
    end 'lt'
    if self > other 'gt'
      return 1
    end 'gt'
    return 0
  end 'compare'

  function toString() returns String
    return "{self}"
  end 'toString'

  function clone() returns int
    return self
  end 'clone'

  function advancedBy(n int) returns int
    return self + n
  end 'advancedBy'
end 'int'

extension float
  function hash() returns int
    var bits = __float_to_bits(self)
    if bits == 0 - 9223372036854775807 - 1 'negzero'
      return 0
    end 'negzero'
    return bits
  end 'hash'

  function equals(other float) returns bool
    return self == other
  end 'equals'

  function compare(other float) returns int
    if self < other 'lt'
      return 0 - 1
    end 'lt'
    if self > other 'gt'
      return 1
    end 'gt'
    return 0
  end 'compare'

  function toString() returns String
    return "{self}"
  end 'toString'

  function clone() returns float
    return self
  end 'clone'
end 'float'

extension bool
  function hash() returns int
    if self 'h'
      return 1
    end 'h'
    return 0
  end 'hash'

  function equals(other bool) returns bool
    return self == other
  end 'equals'

  function compare(other bool) returns int
    var a = 0
    var b = 0
    if self 's'
      a = 1
    end 's'
    if other 'o'
      b = 1
    end 'o'
    if a < b 'lt'
      return 0 - 1
    end 'lt'
    if a > b 'gt'
      return 1
    end 'gt'
    return 0
  end 'compare'

  function toString() returns String
    return "{self}"
  end 'toString'

  function clone() returns bool
    return self
  end 'clone'
end 'bool'

extension byte
  function hash() returns int
    return self as int
  end 'hash'

  function equals(other byte) returns bool
    return self == other
  end 'equals'

  function compare(other byte) returns int
    var a = self as int
    var b = other as int
    if a < b 'lt'
      return 0 - 1
    end 'lt'
    if a > b 'gt'
      return 1
    end 'gt'
    return 0
  end 'compare'

  function toString() returns String
    return "{self}"
  end 'toString'

  function clone() returns byte
    return self
  end 'clone'
end 'byte'

// stdlib/fs/streams.maxon
// File system and stream operations

// Get stdout handle (calls Windows API)
export function stdout() ptr
    var handle int = sys.STD_OUTPUT_HANDLE()
    var h ptr = sys.GetStdHandle(handle)
    return h
end 'stdout'

// Get stderr handle
export function stderr() ptr
    var handle int = sys.STD_ERROR_HANDLE()
    var h ptr = sys.GetStdHandle(handle)
    return h
end 'stderr'

// Write bytes to a handle
// Returns number of bytes written, or 0 on error
export function write(handle ptr, buffer ptr, length int) int
    var bytesWritten int = 0
    var pBytesWritten ptr = &bytesWritten
    var overlapped ptr = 0 as ptr
    
    var result int = sys.WriteFile(handle, buffer, length, pBytesWritten, overlapped)
    
    if result = 0 'check_result'
        return 0
    end 'check_result'
    
    return bytesWritten
end 'write'

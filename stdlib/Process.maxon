/// Introspection of the currently-running process.
/// 
/// For launching and managing child processes, see `stdlib/Subprocess.maxon`.
/// For monotonic time, see `stdlib/Clock.maxon`.
/// 
/// @category System
#if os(Windows)
	export typealias ExitCode = int(0 to u32.max)
#else
	#if os(Wasi)
		// WASI's `proc_exit` accepts a u32, but wasmtime's runtime
		// validator rejects exit codes ≥ 126 with "exit with invalid
		// exit status outside of [0..126)". Cap to 0..125 so programs
		// that compute an exit value (e.g. a masked hash) automatically
		// land in the runtime-accepted range on this target.
		export typealias ExitCode = int(0 to 125)
	#else
		// POSIX-style byte-sized exit codes on Linux and macOS.
		export typealias ExitCode = int(0 to 255)
	#endif
#endif

/// Errors raised by current-process introspection APIs (e.g. `Process.executablePath`).
export enum ProcessIntrospectionError implements Error
	pathUnavailable
end 'ProcessIntrospectionError'

/// Information about the currently-running process.
export type Process
	/// Returns the absolute path to the current executable.
	/// Uses OS-specific APIs: GetModuleFileNameA (Windows),
	/// _NSGetExecutablePath (macOS), /proc/self/exe (Linux).
	export static function executablePath() returns FilePath throws ProcessIntrospectionError
		let managed = __Builtins.executablePath()
		let path = String.init(managed)
		return try FilePath.from(path) otherwise throw ProcessIntrospectionError.pathUnavailable
	end 'executablePath'
end 'Process'

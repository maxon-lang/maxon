/// Type-safe filesystem path with platform-aware separator.
/// @category System

#if os(Windows)
  let _pathSeparator = "\\"
  let _pathSeparatorByte = 92
  let _otherSeparatorByte = 47
#else
  let _pathSeparator = "/"
  let _pathSeparatorByte = 47
  let _otherSeparatorByte = 92
#endif

export union FilePathError implements Error
  invalidCharacter
end 'FilePathError'

export type FilePath implements InitableFromStringLiteral, Equatable, Hashable, Stringable
  export var _path String

  /// Create FilePath from a string literal via `FilePath from "..."` syntax.
  /// Panics if the path contains invalid characters.
  /// Non-native separators are replaced with the platform-native separator.
  static function init(value String) returns FilePath
    if _hasInvalidChars(value) 'bad'
      panic("FilePath: invalid characters in path")
    end 'bad'
    return FilePath{_path: _normalizeSeparators(value)}
  end 'init'

  /// Create FilePath from an explicit string.
  /// Throws FilePathError.invalidCharacter if the path contains invalid characters.
  /// Non-native separators are replaced with the platform-native separator.
  export static function from(path String) returns FilePath throws FilePathError
    if _hasInvalidChars(path) 'bad'
      throw FilePathError.invalidCharacter
    end 'bad'
    return FilePath{_path: _normalizeSeparators(path)}
  end 'from'

  /// Check for characters that are invalid in filesystem paths.
  /// On Windows: control chars (0x01-0x1F), <, >, ", |, ?, *
  /// On Linux: only NUL (0x00), but that can't appear in Maxon strings.
  static function _hasInvalidChars(path String) returns bool
    #if os(Windows)
      let len = path.byteLength()
      var i = 0
      while i < len 'scan'
        let b = path.managed.byteAt(i)
        // Control characters 0x01-0x1F
        if b >= 1 and b <= 31 'control'
          return true
        end 'control'
        // < = 60, > = 62, " = 34, | = 124, ? = 63, * = 42
        if b == 60 or b == 62 or b == 34 or b == 124 or b == 63 or b == 42 'special'
          return true
        end 'special'
        i = i + 1
      end 'scan'
    #endif
    return false
  end '_hasInvalidChars'

  /// Replace non-native separators with the platform-native separator.
  static function _normalizeSeparators(path String) returns String
    let len = path.byteLength()
    if len == 0 'empty'
      return path
    end 'empty'
    // Scan for any non-native separator byte
    var hasOther = false
    var i = 0
    while i < len 'scan'
      if path.managed.byteAt(i) == _otherSeparatorByte 'found'
        hasOther = true
        break
      end 'found'
      i = i + 1
    end 'scan'
    if not hasOther 'noChange'
      return path
    end 'noChange'
    #if os(Windows)
      return path.replace("/", with: "\\")
    #else
      return path.replace("\\", with: "/")
    #endif
  end '_normalizeSeparators'

  /// The platform-native path separator string.
  export static function separator() returns String
    return _pathSeparator
  end 'separator'

  // --- Stringable ---
  export function toString() returns String
    return _path
  end 'toString'

  // --- Equatable ---
  export function equals(other FilePath) returns bool
    return _path == other._path
  end 'equals'

  // --- Hashable ---
  export function hash() returns HashValue
    return _path.hash()
  end 'hash'

  // --- Query ---

  export function isEmpty() returns bool
    return _path.isEmpty()
  end 'isEmpty'

  export function isAbsolute() returns bool
    let len = _path.byteLength()
    #if os(Windows)
      // Drive letter: X:\ (e.g. C:\)
      if len >= 3 'checkDrive'
        let b0 = _path.managed.byteAt(0)
        let b1 = _path.managed.byteAt(1)
        let b2 = _path.managed.byteAt(2)
        // ':' = 58, '\' = 92 (path is normalized, so only native separator)
        if b1 == 58 and b2 == 92 'hasDriveColon'
          // a-z = 97-122, A-Z = 65-90
          if (b0 >= 65 and b0 <= 90) or (b0 >= 97 and b0 <= 122) 'isDrive'
            return true
          end 'isDrive'
        end 'hasDriveColon'
      end 'checkDrive'
      // UNC path: starts with \\
      if len >= 2 'checkUNC'
        let u0 = _path.managed.byteAt(0)
        let u1 = _path.managed.byteAt(1)
        if u0 == 92 and u1 == 92 'isUNC'
          return true
        end 'isUNC'
      end 'checkUNC'
    #else
      // Unix: starts with /
      if len >= 1 'checkSlash'
        if _path.managed.byteAt(0) == 47 'isAbsUnix'
          return true
        end 'isAbsUnix'
      end 'checkSlash'
    #endif
    return false
  end 'isAbsolute'

  export function isRelative() returns bool
    return not isAbsolute()
  end 'isRelative'

  // --- Component extraction ---

  /// Scan backwards for the last path separator.
  /// Returns the byte index + 1, or 0 if none found.
  function _lastSepPlusOne() returns Count
    let len = _path.byteLength()
    if len == 0 'empty'
      return 0
    end 'empty'
    var i = len
    while i > 0 'scan'
      i = i - 1
      if _path.managed.byteAt(i) == _pathSeparatorByte 'isSep'
        return i + 1
      end 'isSep'
    end 'scan'
    return 0
  end '_lastSepPlusOne'

  /// Get the filename (last path component). Returns the full path if no separator.
  export function filename() returns String
    let sepPlusOne = _lastSepPlusOne()
    if sepPlusOne == 0 'noSep'
      return _path
    end 'noSep'
    let len = _path.byteLength()
    let nameManaged = _path.managed.slice(sepPlusOne, len)
    return String{managed: nameManaged, _iterPos: 0}
  end 'filename'

  /// Get the file extension including the dot, or empty string if none.
  /// Leading dots are not treated as extension separators (e.g. ".gitignore" has no extension).
  export function fileExtension() returns String
    let name = filename()
    let nameLen = name.byteLength()
    if nameLen <= 1 'tooShort'
      return ""
    end 'tooShort'
    var i = nameLen
    // Scan backwards for '.', but skip position 0 (leading dot)
    while i > 1 'scan'
      i = i - 1
      if name.managed.byteAt(i) == 46 'isDot'
        let extManaged = name.managed.slice(i, nameLen)
        return String{managed: extManaged, _iterPos: 0}
      end 'isDot'
    end 'scan'
    return ""
  end 'fileExtension'

  /// Get the filename without extension (stem).
  export function stem() returns String
    let name = filename()
    let nameLen = name.byteLength()
    if nameLen <= 1 'tooShort'
      return name
    end 'tooShort'
    var i = nameLen
    while i > 1 'scan'
      i = i - 1
      if name.managed.byteAt(i) == 46 'isDot'
        let stemManaged = name.managed.slice(0, i)
        return String{managed: stemManaged, _iterPos: 0}
      end 'isDot'
    end 'scan'
    return name
  end 'stem'

  /// Get the parent directory path. Returns empty FilePath if no parent.
  export function parent() returns FilePath
    let sepPlusOne = _lastSepPlusOne()
    if sepPlusOne == 0 'noSep'
      return FilePath{_path: ""}
    end 'noSep'
    let parentManaged = _path.managed.slice(0, sepPlusOne - 1)
    let parentStr = String{managed: parentManaged, _iterPos: 0}
    return FilePath{_path: parentStr}
  end 'parent'

  // --- Manipulation ---

  /// Join this path with a child component using the platform-native separator.
  export function join(component String) returns FilePath
    if _path.isEmpty() 'emptyBase'
      return FilePath{_path: _normalizeSeparators(component)}
    end 'emptyBase'
    let normalized = _normalizeSeparators(component)
    // Check if path already ends with a separator
    let lastByte = _path.managed.byteAt(_path.byteLength() - 1)
    if lastByte == _pathSeparatorByte 'hasSep'
      return FilePath{_path: "{_path}{normalized}"}
    end 'hasSep'
    return FilePath{_path: "{_path}{_pathSeparator}{normalized}"}
  end 'join'

  /// Join with another FilePath component.
  export function join(component FilePath) returns FilePath
    return join(component._path)
  end 'join'

  /// Replace the file extension. newExt should include the dot (e.g. ".exe").
  /// If no extension exists, the new extension is appended.
  export function changeExtension(newExt String) returns FilePath
    let sepPlusOne = _lastSepPlusOne()
    let name = filename()
    let nameLen = name.byteLength()
    // Find dot in filename (skip leading dot)
    var dotPos = 0
    var foundDot = false
    if nameLen > 1 'canScan'
      var i = nameLen
      while i > 1 'scan'
        i = i - 1
        if name.managed.byteAt(i) == 46 'isDot'
          dotPos = i
          foundDot = true
          break
        end 'isDot'
      end 'scan'
    end 'canScan'
    var stemStr = name
    if foundDot 'hasDot'
      let stemManaged = name.managed.slice(0, dotPos)
      stemStr = String{managed: stemManaged, _iterPos: 0}
    end 'hasDot'
    if sepPlusOne == 0 'noParent'
      return FilePath{_path: "{stemStr}{newExt}"}
    end 'noParent'
    let parentManaged = _path.managed.slice(0, sepPlusOne)
    let parentStr = String{managed: parentManaged, _iterPos: 0}
    return FilePath{_path: "{parentStr}{stemStr}{newExt}"}
  end 'changeExtension'

  /// Returns self (paths are normalized on construction).
  export function normalize() returns FilePath
    return self
  end 'normalize'

  // --- File/Directory convenience ---

  export function readText() returns String throws FileReadError
    return try File.readText(self)
  end 'readText'

  export function readBinary() returns ByteArray throws FileReadError
    return try File.readBinary(self)
  end 'readBinary'

  export function writeText(content String) throws FileWriteError
    try File.writeText(self, content: content)
  end 'writeText'

  export function fileExists() returns bool
    return File.exists(self)
  end 'fileExists'

  export function directoryExists() returns bool
    return Directory.exists(self)
  end 'directoryExists'

  typealias StringArray = Array with String

  export function listDirectory() returns StringArray throws DirectoryListError
    return try Directory.list(self)
  end 'listDirectory'

end 'FilePath'

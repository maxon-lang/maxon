/// Type-safe filesystem path with platform-aware separator.
/// @category System
#if os(Windows)
	let pathSeparator = "\\"
	let pathSeparatorByte = 92
	let otherSeparatorByte = 47
#else
	let pathSeparator = "/"
	let pathSeparatorByte = 47
	let otherSeparatorByte = 92
#endif

export enum FilePathError implements Error
	invalidCharacter
	notFileURL
	noParent
end 'FilePathError'

typealias FpByte = int(0 to 255)
typealias PathByteOffset = int(0 to u64.max)

// Caller guarantees index is in bounds
function fpByteAt(managed __ManagedMemory, index PathByteOffset) returns FpByte
	return try managed.byteAt(index) otherwise 'err'
		panic("fpByteAt: index out of bounds — caller guarantees valid index")
	end 'err'
end 'fpByteAt'

export type FilePath implements InitableFromStringLiteral, Equatable, Hashable, Stringable
	export let path String

	/// Create FilePath from a string literal via `FilePath from "..."` syntax.
	/// Panics if the path contains invalid characters or is a non-file URL.
	static function init(value String) returns FilePath
		return try create(value) otherwise panic("FilePath: invalid path")
	end 'init'

	/// Create FilePath from an explicit string.
	/// Accepts file:// URLs (extracts the path) or regular path strings.
	export static function from (path String) returns FilePath throws FilePathError
		return try create(path)
	end 'from'

	/// Resolve URL, validate characters, normalize separators.
	static function create(input String) returns FilePath throws FilePathError
		let resolved = try resolveFileURL(input)
		#if os(Windows)
			if hasInvalidChars(resolved) 'bad'
				throw FilePathError.invalidCharacter
			end 'bad'
		#endif
		return FilePath{path: normalizeSeparators(resolved)}
	end 'create'

	#if os(Windows)
		/// Check for characters that are invalid in Windows filesystem paths:
		/// control chars (0x01-0x1F), <, >, ", |, ?, *
		static function hasInvalidChars(path String) returns bool
			let len = path.byteLength()
			var i = 0
			while i < len 'scan'
				let b = fpByteAt(path.managed, index: i)
				if b >= 1 and b <= 31 'control'
					return true
				end 'control'
				// < = 60, > = 62, " = 34, | = 124, ? = 63, * = 42
				if b == 60 or b == 62 or b == 34 or b == 124 or b == 63 or b == 42 'special'
					return true
				end 'special'
				i = i + 1
			end 'scan'
			return false
		end 'hasInvalidChars'
	#endif

	/// Replace non-native separators with the platform-native separator.
	static function normalizeSeparators(path String) returns String
		let len = path.byteLength()
		if len == 0 'empty'
			return path
		end 'empty'
		// Scan for any non-native separator byte
		var hasOther = false
		var i = 0
		while i < len 'scan'
			if fpByteAt(path.managed, index: i) == otherSeparatorByte 'found'
				hasOther = true
				break
			end 'found'
			i = i + 1
		end 'scan'
		if not hasOther 'noChange'
			return path
		end 'noChange'
		#if os(Windows)
			return path.replace("/", with: "\\")
		#else
			return path.replace("\\", with: "/")
		#endif
	end 'normalizeSeparators'

	/// Detect file:// URLs and extract the filesystem path.
	/// Returns the path unchanged if not a URL.
	/// Throws FilePathError.notFileURL for non-file URL schemes.
	static function resolveFileURL(input String) returns String throws FilePathError
		// Quick check: must contain "://" to be a URL
		let len = input.byteLength()
		var hasScheme = false
		var i = 0
		while i + 2 < len 'scan'
			// ':' = 58, '/' = 47
			if fpByteAt(input.managed, index: i) == 58 'colon'
				if fpByteAt(input.managed, index: i + 1) == 47 'slash1'
					if fpByteAt(input.managed, index: i + 2) == 47 'slash2'
						hasScheme = true
						break
					end 'slash2'
				end 'slash1'
			end 'colon'
			i = i + 1
		end 'scan'
		if not hasScheme 'notURL'
			return input
		end 'notURL'
		// Parse as URL
		let url = try URL.parse(input) otherwise 'parseErr'
			return input
		end 'parseErr'
		// Check scheme is "file"
		if url.scheme() != "file" 'notFile'
			throw FilePathError.notFileURL
		end 'notFile'
		var filePath = url.path()
		#if os(Windows)
			// file:///C:/path produces path "/C:/path" — strip leading slash before drive letter
			let pathLen = filePath.byteLength()
			if pathLen >= 3 'checkDrive'
				// Check for /X: pattern (slash + alpha + colon)
				if fpByteAt(filePath.managed, index: 0) == 47 'leadingSlash'
					let driveByte = fpByteAt(filePath.managed, index: 1)
					if fpByteAt(filePath.managed, index: 2) == 58 'hasColon'
						if (driveByte >= 65 and driveByte <= 90) or (driveByte >= 97 and driveByte <= 122) 'isDrive'
							let trimmed = try filePath.managed.slice(1, pathLen) otherwise panic("FilePath: drive-strip slice — pathLen >= 3 guaranteed")
							filePath = String.init(trimmed)
						end 'isDrive'
					end 'hasColon'
				end 'leadingSlash'
			end 'checkDrive'
		#endif
		return filePath
	end 'resolveFileURL'

	/// The platform-native path separator string.
	export static function separator() returns String
		return pathSeparator
	end 'separator'

	// --- Stringable ---
	export function toString() returns String
		return path
	end 'toString'

	/// Returns a copy of `s` suitable for case-insensitive comparison
	/// on the host filesystem. Windows: lower-cased clone (NTFS treats
	/// `C:\Foo` and `c:\foo` as the same path). POSIX: returned as-is.
	/// 
	/// `String.toLower` mutates its receiver's managed buffer in place,
	/// so the clone is mandatory — otherwise this would silently lower-
	/// case the caller's string (typically the FilePath's own `path`
	/// field), and every later read of `.path` (subprocess spawn, file
	/// I/O, error reporting) would see the lower-cased copy.
	static function canonicalForCompare(s String) returns String
		#if os(Windows)
			return s.clone().toLower()
		#else
			return s
		#endif
	end 'canonicalForCompare'

	// --- Equatable ---

	/// Path equality matching the host filesystem's semantics:
	/// case-insensitive on Windows, exact byte match on POSIX.
	export function equals(other FilePath) returns bool
		return canonicalForCompare(path) == canonicalForCompare(other.path)
	end 'equals'

	// --- Hashable ---

	/// Hash that agrees with `equals`: case-insensitive on Windows
	/// so map lookups find an entry inserted with `C:\foo` when
	/// queried with `c:\Foo`.
	export function hash() returns HashValue
		return canonicalForCompare(path).hash()
	end 'hash'

	// --- Containment test ---

	/// True when this path lies inside `dir` (i.e. `dir` is a proper
	/// ancestor directory of `self`, or `self == dir`). Component-
	/// aware: appends the platform separator before testing the
	/// prefix so `/foo/bar` is NOT considered to be inside `/foo/ba`.
	/// Case semantics match `equals` (case-insensitive on Windows,
	/// exact on POSIX).
	export function isInside(dir FilePath) returns bool
		if equals(dir) 'same'
			return true
		end 'same'
		let dirStr = dir.path
		if dirStr.isEmpty() 'emptyDir'
			return false
		end 'emptyDir'
		let needle = "{dirStr}{pathSeparator}"
		return canonicalForCompare(path).startsWith(canonicalForCompare(needle))
	end 'isInside'

	// --- Query ---

	export function isEmpty() returns bool
		return path.isEmpty()
	end 'isEmpty'

	export function isAbsolute() returns bool
		let len = path.byteLength()
		#if os(Windows)
			// Drive letter: X:\ (e.g. C:\)
			if len >= 3 'checkDrive'
				let b0 = fpByteAt(path.managed, index: 0)
				let b1 = fpByteAt(path.managed, index: 1)
				let b2 = fpByteAt(path.managed, index: 2)
				// ':' = 58, '\' = 92 (path is normalized, so only native separator)
				if b1 == 58 and b2 == 92 'hasDriveColon'
					// a-z = 97-122, A-Z = 65-90
					if (b0 >= 65 and b0 <= 90) or (b0 >= 97 and b0 <= 122) 'isDrive'
						return true
					end 'isDrive'
				end 'hasDriveColon'
			end 'checkDrive'
			// UNC path: starts with \\
			if len >= 2 'checkUNC'
				let u0 = fpByteAt(path.managed, index: 0)
				let u1 = fpByteAt(path.managed, index: 1)
				if u0 == 92 and u1 == 92 'isUNC'
					return true
				end 'isUNC'
			end 'checkUNC'
			// Rooted path: starts with single backslash (e.g. \path — absolute to current drive)
			if len >= 1 'checkRooted'
				if fpByteAt(path.managed, index: 0) == 92 'isRooted'
					return true
				end 'isRooted'
			end 'checkRooted'
		#else
			// Unix: starts with /
			if len >= 1 'checkSlash'
				if fpByteAt(path.managed, index: 0) == 47 'isAbsUnix'
					return true
				end 'isAbsUnix'
			end 'checkSlash'
		#endif
		return false
	end 'isAbsolute'

	export function isRelative() returns bool
		return not isAbsolute()
	end 'isRelative'

	// --- Component extraction ---

	/// Scan backwards for the last path separator.
	/// Returns the byte index + 1, or 0 if none found.
	function lastSepPlusOne() returns PathByteOffset
		let len = path.byteLength()
		if len == 0 'empty'
			return 0
		end 'empty'
		var i = path.byteLength()
		while i > 0 'scan'
			i = i - 1
			if fpByteAt(path.managed, index: i) == pathSeparatorByte 'isSep'
				return i + 1
			end 'isSep'
		end 'scan'
		return 0
	end 'lastSepPlusOne'

	/// Get the filename (last path component). Returns the full path if no separator.
	export function filename() returns String
		let sepPlusOne = lastSepPlusOne()
		if sepPlusOne == 0 'noSep'
			return path
		end 'noSep'
		let len = path.byteLength()
		let nameManaged = try path.managed.slice(sepPlusOne, len) otherwise 'nameSliceErr'
			panic("FilePath.filename: slice — sepPlusOne from lastSepPlusOne, always <= len")
		end 'nameSliceErr'
		return String.init(nameManaged)
	end 'filename'

	/// Get the file extension including the dot, or empty string if none.
	/// Leading dots are not treated as extension separators (e.g. ".gitignore" has no extension).
	export function fileExtension() returns String
		let name = filename()
		let nameLen = name.byteLength()
		if nameLen <= 1 'tooShort'
			return ""
		end 'tooShort'
		// Scan backwards for '.', but skip position 0 (leading dot)
		var i = name.byteLength()
		while i > 1 'scan'
			i = i - 1
			if fpByteAt(name.managed, index: i) == 46 'isDot'
				let extManaged = try name.managed.slice(i, nameLen) otherwise 'extSliceErr'
					panic("FilePath.fileExtension: slice — i from backwards scan, always <= nameLen")
				end 'extSliceErr'
				return String.init(extManaged)
			end 'isDot'
		end 'scan'
		return ""
	end 'fileExtension'

	/// Get the filename without extension (stem).
	export function stem() returns String
		let name = filename()
		let nameLen = name.byteLength()
		if nameLen <= 1 'tooShort'
			return name
		end 'tooShort'
		var i = name.byteLength()
		while i > 1 'scan'
			i = i - 1
			if fpByteAt(name.managed, index: i) == 46 'isDot'
				let stemManaged = try name.managed.slice(0, i) otherwise 'stemSliceErr'
					panic("FilePath.stem: slice — i from backwards scan, always < nameLen")
				end 'stemSliceErr'
				return String.init(stemManaged)
			end 'isDot'
		end 'scan'
		return name
	end 'stem'

	/// Get the parent directory path. Throws if no parent exists.
	export function parent() returns FilePath throws FilePathError
		let sepPlusOne = lastSepPlusOne()
		if sepPlusOne == 0 'noSep'
			throw FilePathError.noParent
		end 'noSep'
		let parentManaged = try path.managed.slice(0, sepPlusOne - 1) otherwise 'parentSliceErr'
			panic("FilePath.parent: slice — sepPlusOne > 0 guaranteed, so sepPlusOne-1 >= 0")
		end 'parentSliceErr'
		let parentStr = String.init(parentManaged)
		return FilePath{path: parentStr}
	end 'parent'

	// --- Manipulation ---

	/// Join this path with a child component using the platform-native separator.
	export function join(component String) returns FilePath
		if path.isEmpty() 'emptyBase'
			return FilePath{path: normalizeSeparators(component)}
		end 'emptyBase'
		let normalized = normalizeSeparators(component)
		// Check if path already ends with a separator
		let lastByte = fpByteAt(path.managed, index: path.byteLength() - 1)
		if lastByte == pathSeparatorByte 'hasSep'
			return FilePath{path: "{path}{normalized}"}
		end 'hasSep'
		return FilePath{path: "{path}{pathSeparator}{normalized}"}
	end 'join'

	/// Join with another FilePath component.
	export function join(component FilePath) returns FilePath
		return join(component.path)
	end 'join'

	/// Replace the file extension. newExt should include the dot (e.g. ".exe").
	/// If no extension exists, the new extension is appended.
	export function changeExtension(newExt String) returns FilePath
		let sepPlusOne = lastSepPlusOne()
		let name = filename()
		let nameLen = name.byteLength()
		// Find dot in filename (skip leading dot)
		var dotPos = 0
		var foundDot = false
		if nameLen > 1 'canScan'
			var i = name.byteLength()
			while i > 1 'scan'
				i = i - 1
				if fpByteAt(name.managed, index: i) == 46 'isDot'
					dotPos = i
					foundDot = true
					break
				end 'isDot'
			end 'scan'
		end 'canScan'
		if foundDot 'hasDot'
			let stemManaged = try name.managed.slice(0, dotPos) otherwise 'stemSliceErr2'
				panic("FilePath.changeExtension: stem slice — dotPos from backwards scan, always < nameLen")
			end 'stemSliceErr2'
			let stemStr = String.init(stemManaged)
			if sepPlusOne == 0 'noParent2'
				return FilePath{path: "{stemStr}{newExt}"}
			end 'noParent2'
			let parentManaged = try path.managed.slice(0, sepPlusOne) otherwise 'parentSliceErr2'
				panic("FilePath.changeExtension: parent slice — sepPlusOne from lastSepPlusOne, always <= len")
			end 'parentSliceErr2'
			let parentStr = String.init(parentManaged)
			return FilePath{path: "{parentStr}{stemStr}{newExt}"}
		end 'hasDot'
		if sepPlusOne == 0 'noParent'
			return FilePath{path: "{name}{newExt}"}
		end 'noParent'
		let parentManaged = try path.managed.slice(0, sepPlusOne) otherwise 'parentSliceErr3'
			panic("FilePath.changeExtension: parent slice — sepPlusOne from lastSepPlusOne, always <= len")
		end 'parentSliceErr3'
		let parentStr = String.init(parentManaged)
		return FilePath{path: "{parentStr}{name}{newExt}"}
	end 'changeExtension'

	/// Returns self (paths are normalized on construction).
	export function normalize() returns FilePath
		return self
	end 'normalize'

	// --- Resolution ---

	/// Resolve this path against a base directory, returning an absolute FilePath.
	/// If this path is already absolute, returns self unchanged.
	export function resolve(base FilePath) returns FilePath
		if isAbsolute() 'alreadyAbsolute'
			return self
		end 'alreadyAbsolute' else 'relative'
			return base.join(path)
		end 'relative'
	end 'resolve'

	/// Compute this path relative to `base`. Returns the suffix of `self.path`
	/// after stripping `base.path` and any trailing separator.
	/// 
	/// Throws `FilePathError.noParent` when `self` is not contained within
	/// `base` (no shared prefix or only a partial component match). Callers
	/// that want a fallback should use `try ... otherwise`.
	/// 
	/// Examples:
	///   - base="/proj",   self="/proj/utils/helpers.maxon" -> "utils/helpers.maxon"
	///   - base="/proj",   self="/proj/main.maxon"          -> "main.maxon"
	///   - base="/proj",   self="/proj"                     -> ""
	///   - base="/proj/",  self="/proj/main.maxon"          -> "main.maxon"
	///   - base="/proj",   self="/other/x.maxon"            -> throws noParent
	export function relativeTo(base FilePath) returns FilePath throws FilePathError
		// Normalize away any trailing separator on `base` so callers that pass
		// a directory with a trailing slash don't trip `startsWith`'s
		// component-boundary check (which expects a separator AFTER the prefix
		// in `self`, not as the last byte of `prefix`).
		let basePath = base.path
		let baseLen = basePath.byteLength()
		var trimmedBase = base
		if baseLen > 0 'maybeTrim'
			let lastByte = fpByteAt(basePath.managed, index: baseLen - 1)
			if lastByte == pathSeparatorByte or lastByte == otherSeparatorByte 'trailingSep'
				let trimmedManaged = try basePath.managed.slice(0, baseLen - 1) otherwise 'trimErr'
					panic("FilePath.relativeTo: trim slice — baseLen > 0 guaranteed")
				end 'trimErr'
				trimmedBase = FilePath{path: String.init(trimmedManaged)}
			end 'trailingSep'
		end 'maybeTrim'
		if not startsWith(trimmedBase) 'notUnder'
			throw FilePathError.noParent
		end 'notUnder'
		let trimmedLen = trimmedBase.path.byteLength()
		let selfLen = path.byteLength()
		if trimmedLen == selfLen 'exact'
			return FilePath{path: ""}
		end 'exact'
		// startsWith guarantees the byte at trimmedLen is a separator. Skip it.
		var start = trimmedLen
		let firstByte = fpByteAt(path.managed, index: start)
		if firstByte == pathSeparatorByte or firstByte == otherSeparatorByte 'hasSep'
			start = start + 1
		end 'hasSep'
		if start >= selfLen 'allConsumed'
			return FilePath{path: ""}
		end 'allConsumed'
		let relManaged = try path.managed.slice(start, selfLen) otherwise 'sliceErr'
			panic("FilePath.relativeTo: slice — start < selfLen guaranteed")
		end 'sliceErr'
		return FilePath{path: String.init(relManaged)}
	end 'relativeTo'

	/// Check whether this path starts with the given directory prefix.
	/// Compares full path components, so "/foo/bar" starts with "/foo" but not "/fo".
	export function startsWith(prefix FilePath) returns bool
		let selfStr = path
		let prefixStr = prefix.path
		if not selfStr.startsWith(prefixStr) 'noMatch'
			return false
		end 'noMatch'
		let prefixLen = prefixStr.byteLength()
		let selfLen = selfStr.byteLength()
		// Exact match or next character is a separator
		if prefixLen == selfLen 'exact'
			return true
		end 'exact'
		let nextByte = fpByteAt(selfStr.managed, index: prefixLen)
		return nextByte == pathSeparatorByte or nextByte == otherSeparatorByte
	end 'startsWith'
end 'FilePath'

// stdlib/math/exp.maxon
// Exponential function implementation (e^x)

/// Calculate e^x where e is Euler's number
/// Uses Taylor series: e^x = 1 + x + x^2/2! + x^3/3! + ...
export function exp(x float) returns float
	// Handle special cases
	if x == 0.0 'zero'
		return 1.0
	end 'zero'

	// For large positive x, use exp(x) = exp(x/2)^2 repeatedly
	// For large negative x, use exp(x) = 1/exp(-x)
	var is_negative = x < 0.0
	if is_negative 'neg'
		x = -x
	end 'neg'

	// Reduce x to a smaller range using exp(x) = exp(x/2)^2
	var reduction_count = 0
	while x > 1.0 'reduce'
		x = x / 2.0
		reduction_count = reduction_count + 1
	end 'reduce'

	// Compute exp(x) using Taylor series for small x
	var term = 1.0
	var sum = 1.0
	var k = 1.0

	// Compute first 20 terms
	while k < 20.0 'series'
		term = term * x
		var k_float = k
		term = term / k_float
		sum = sum + term
		k = k + 1
	end 'series'

	// Square the result reduction_count times to get exp(original_x)
	var result = sum
	var i = 0
	while i < reduction_count 'square'
		result = result * result
		i = i + 1
	end 'square'

	// Handle negative input
	if is_negative 'invert'
		result = 1.0 / result
	end 'invert'

	return result
end 'exp'

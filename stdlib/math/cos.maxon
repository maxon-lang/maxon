// stdlib/math/cos.maxon
// Cosine function implementation

/// Calculate the cosine of an angle (in radians)
/// Uses Taylor series: cos(x) = 1 - x^2/2! + x^4/4! - x^6/6! + ...
export function cos(x float) returns float
	// Handle zero case
	if x == 0.0 'zero'
		return 1.0
	end 'zero'

	// Reduce x to range [-π, π] for better convergence
	// π ≈ 3.14159265358979323846
	var pi = 3.14159265358979323846
	var two_pi = 6.28318530717958647692

	// Normalize to [-π, π]
	while x > pi 'reduce_pos'
		x = x - two_pi
	end 'reduce_pos'
	while x < -pi 'reduce_neg'
		x = x + two_pi
	end 'reduce_neg'

	// Taylor series for cos(x):
	// cos(x) = 1 - x^2/2! + x^4/4! - x^6/6! + ...
	// Term n: (-1)^n * x^(2n) / (2n)!

	var x_squared = x * x
	var term = 1.0  // First term is 1
	var sum = 1.0
	var n = 1.0

	// Compute terms until convergence (about 12 terms is enough for double precision)
	while n < 12.0 'series'
		// Next term: multiply by -x^2 / ((2n-1)(2n))
		var two_n = 2.0 * n
		term = term * (-x_squared) / ((two_n - 1.0) * two_n)
		sum = sum + term
		n = n + 1.0
	end 'series'

	return sum
end 'cos'

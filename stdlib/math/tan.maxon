// stdlib/math/tan.maxon
// Tangent function implementation

/// Calculate the tangent of an angle (in radians)
/// Uses the identity: tan(x) = sin(x) / cos(x)
export function tan(x float) returns float
	// Handle zero case
	if x == 0.0 'zero'
		return 0.0
	end 'zero'

	// tan(x) = sin(x) / cos(x)
	var s = sin(x)
	var c = cos(x)

	// Avoid division by zero near π/2, 3π/2, etc.
	// cos(x) is very small near these points
	if c == 0.0 'div_zero'
		// Return a large value with correct sign
		if s > 0.0 'positive'
			return 1000000000.0
		end 'positive'
		return -1000000000.0
	end 'div_zero'

	return s / c
end 'tan'

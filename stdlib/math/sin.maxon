// stdlib/math/sin.maxon
// Sine function implementation

/// Calculate the sine of an angle (in radians)
/// Uses Taylor series: sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
export function sin(x float) returns float
	// Handle zero case
	if x == 0.0 'zero'
		return 0.0
	end 'zero'

	// Reduce x to range [-π, π] for better convergence
	// π ≈ 3.14159265358979323846
	var pi = 3.14159265358979323846
	var two_pi = 6.28318530717958647692

	// Normalize to [-π, π]
	while x > pi 'reduce_pos'
		x = x - two_pi
	end 'reduce_pos'
	while x < -pi 'reduce_neg'
		x = x + two_pi
	end 'reduce_neg'

	// Taylor series for sin(x):
	// sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
	// Term n: (-1)^n * x^(2n+1) / (2n+1)!

	var x_squared = x * x
	var term = x  // First term is x
	var sum = x
	var n = 1.0

	// Compute terms until convergence (about 12 terms is enough for double precision)
	while n < 12.0 'series'
		// Next term: multiply by -x^2 / ((2n)(2n+1))
		var two_n = 2.0 * n
		term = term * (-x_squared) / (two_n * (two_n + 1.0))
		sum = sum + term
		n = n + 1.0
	end 'series'

	return sum
end 'sin'

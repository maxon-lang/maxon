// Main function that demonstrates block identifiers
function main() int
	var x = 5
	var i = 3
	// Loop three times, incrementing x
	while i > 0 'while loop'
    	if i = 3 'if test'
      		x = x + 5  // First iteration adds 5
    	else 'if test'
      		x = x + 2  // Subsequent iterations add 2
    	end 'if test'
		i = i - 1
	end 'while loop'
	return x
end 'main'


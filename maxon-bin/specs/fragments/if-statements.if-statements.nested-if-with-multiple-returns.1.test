// Test: if-statements.if-statements.nested-if-with-multiple-returns.1
function test(c int, next int) returns int
    if c == 0 'maybePrefix'
        if next == 1 'isHex'
            return 1
        end 'isHex'
        if next == 2 'isBinary'
            return 2
        end 'isBinary'
    end 'maybePrefix'
    return 42
end 'test'

function main() returns int
    return test(5, next: 0)
end 'main'
---
ExitCode: 42
---
function test() -> i64 {
entry_0:
    %c = param i64 0
    %next = param i64 1
    %next.1 = alloca ptr
    store %next.1 %next
    %tmp_const = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %c %tmp_const
    br.cond %tmp_icmp @then$maybePrefix_1 @end$maybePrefix_6
then$maybePrefix_1:
    %tmp_load.1 = load i64 %next.1
    %tmp_const.1 = const.i64 i64 1
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.1
    br.cond %tmp_icmp.1 @then$isHex_2 @end$isHex_3
then$isHex_2:
    %tmp_const.2 = const.i64 i64 1
    ret %tmp_const.2
end$isHex_3:
    %tmp_load.3 = load i64 %next.1
    %tmp_const.3 = const.i64 i64 2
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.3 %tmp_const.3
    br.cond %tmp_icmp.2 @then$isBinary_4 @end$isBinary_5
then$isBinary_4:
    %tmp_const.4 = const.i64 i64 2
    ret %tmp_const.4
end$isBinary_5:
    br @end$maybePrefix_6
end$maybePrefix_6:
    %tmp_const.5 = const.i64 i64 42
    ret %tmp_const.5
}

function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 5
    %tmp_const.1 = const.i64 i64 0
    %tmp_call = call i64 @test(%tmp_const, %tmp_const.1)
    ret %tmp_call
}

---

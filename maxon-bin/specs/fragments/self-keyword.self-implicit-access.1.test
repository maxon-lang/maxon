// Test: self-keyword.self-implicit-access.1
type Counter
    var count int

    function increment()
        count = count + 1
    end 'increment'

    function get() returns int
        return count
    end 'get'
end 'Counter'

function main() returns int
    var c = Counter{count: 0}
    c.increment()
    c.increment()
    c.increment()
    return c.get()
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %c = alloca.sized ptr 8
    memset %c 0 8
    %tmp_fieldptr = getfieldptr ptr %c 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    call @Counter$increment(%c)
    call @Counter$increment(%c)
    call @Counter$increment(%c)
    %tmp_call = call i64 @Counter$get(%c)
    ret %tmp_call
}

function Counter$increment() -> void {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_const = const.i64 i64 1
    %tmp_add = add i64 %tmp_load %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret
}

function Counter$get() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

---

// Test: associated-types.multiple-associated-types.1
interface Pair uses First, Second
    function getFirst() returns First
    function getSecond() returns Second
end 'Pair'

type IntFloat is Pair with int, float
    var a int
    var b float

    function Pair.getFirst() returns int
        return a
    end 'getFirst'

    function Pair.getSecond() returns float
        return b
    end 'getSecond'
end 'IntFloat'

function main() returns int
    var p = IntFloat{a: 40, b: 2.5}
    var x = p.getFirst()
    var y = trunc(p.getSecond())
    return x + y
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 40
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_fconst = const.f64 f64 2.5
    store %tmp_fieldptr.1 %tmp_fconst
    %tmp_call = call i64 @IntFloat$getFirst(%p)
    %tmp_call.1 = call f64 @IntFloat$getSecond(%p)
    %tmp_fptosi = fptosi i64 %tmp_call.1
    %tmp_add = add i64 %tmp_call %tmp_fptosi
    ret %tmp_add
}

function IntFloat$getFirst() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function IntFloat$getSecond() -> f64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 8
    %tmp_load = load f64 %tmp_fieldptr
    ret %tmp_load
}

---

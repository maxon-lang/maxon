// Test: method-calls.method-call-with-args.1
type Adder
    var total int

    function add(n int)
        total = total + n
    end 'add'

    function get() returns int
        return total
    end 'get'
end 'Adder'

function main() returns int
    var a = Adder{total: 0}
    a.add(10)
    a.add(20)
    a.add(12)
    return a.get()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %a = alloca.sized ptr 8
    memset %a 0 8
    %tmp_fieldptr = getfieldptr ptr %a 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 10
    call @Adder$add(%a, %tmp_const.1)
    %tmp_const.3 = const.i64 i64 20
    call @Adder$add(%a, %tmp_const.3)
    %tmp_const.5 = const.i64 i64 12
    call @Adder$add(%a, %tmp_const.5)
    %tmp_call = call i64 @Adder$get(%a)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Adder$add() -> void {
entry_0:
    %self = param ptr 0
    %n = param i64 1
    %n.1 = alloca ptr
    store %n.1 %n
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_load.1 = load i64 %n.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret
}

function Adder$get() -> i64 {
entry_0:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}


    var val1 = try squared.get(1) otherwise 0
    var val2 = try squared.get(2) otherwise 0
    var val3 = try squared.get(3) otherwise 0
    print("{val0}\n")
    print("{val1}\n")
    print("{val2}\n")
    print("{val3}\n")
    return 0
end 'main'

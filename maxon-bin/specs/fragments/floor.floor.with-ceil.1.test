    %tmp_load = load f64 %x
    %tmp_ffloor = ffloor i64 %tmp_load
    %a = alloca ptr
    store %a %tmp_ffloor
    %tmp_load.1 = load f64 %x
    %tmp_fceil = fceil i64 %tmp_load.1
    %b = alloca ptr
    store %b %tmp_fceil
    %tmp_load.2 = load i64 %a
    %tmp_load.3 = load i64 %b
    %tmp_add = add i64 %tmp_load.2 %tmp_load.3
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_add
    %tmp_load.4 = load i64 %tmp_alloca.3
    ret %tmp_load.4
}


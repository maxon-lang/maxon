// Test: floor.floor.with-ceil.1
function main() returns int
    var x = 3.7
    var a = floor(x)
    var b = ceil(x)
    return a + b
end 'main'
---
ExitCode: 7
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.7
    %x = alloca ptr

// Test: expressions.comparison-in-expression.1
function main() returns int
    var isGreater = 10 > 5
    if isGreater 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %tmp_const.1 = const.i64 i64 5
    %tmp_icmp = icmp.gt i64 %tmp_const %tmp_const.1
    %isGreater = alloca ptr
    store %isGreater %tmp_icmp
    %tmp_load = load i64 %isGreater
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const.2 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.2
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
end:
    %tmp_const.3 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.3
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

    %tmp_load.1 = load i64 %x
    br @match_check_1
match_check_1:
    %tmp_const.3 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.3
    br.cond %tmp_icmp @match_body_2 @match_check_3
match_body_2:
    %tmp_const.4 = const.i64 i64 10

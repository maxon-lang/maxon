    store %tmp_alloca.1 %tmp_const.4
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
match_check_3:
    %tmp_const.5 = const.i64 i64 2
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.1 %tmp_const.5
    br.cond %tmp_icmp.1 @match_body_4 @match_default_5
match_body_4:
    %tmp_const.6 = const.i64 i64 20
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.6
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
match_default_5:
    %tmp_const.7 = const.i64 i64 0
    %tmp_alloca.3 = alloca ptr
    store %tmp_alloca.3 %tmp_const.7
    %tmp_load.4 = load i64 %tmp_alloca.3

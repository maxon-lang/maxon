// Test: arithmetic.division.1
function main() returns int
    return 100 / 4
end 'main'
---
ExitCode: 25
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 100
    %tmp_const.1 = const.i64 i64 4
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_sitofp.1 = sitofp f64 %tmp_const.1
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_fptosi
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}


// Test: byte-type.byte-from-hex.1
function main() returns int
    var b = 0xff as byte
    return b as int
end 'main'
---
ExitCode: 255
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 255
    %tmp_const.1 = const.i64 i64 255
    %tmp_band = band i64 %tmp_const %tmp_const.1
    %b = alloca ptr
    store %b %tmp_band
    %tmp_load = load i64 %b
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}


// Test: mem2reg-phi-placement.doc-example-1.1
function main() returns int
    var x = 10
    return x + 5
end 'main'
---
ExitCode: 15
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 5
    %tmp_add = add i64 %tmp_load %tmp_const.1
    ret %tmp_add
}

---

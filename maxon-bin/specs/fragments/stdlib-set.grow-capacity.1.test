// Test: stdlib-set.grow-capacity.1
function main() returns int
    var s = Set of int{}
    var initialCap = s.capacity()

    // Insert enough elements to trigger growth (75% of 16 = 12)
    var i = 0
    while i < 15 'insert'
        s.insert(i)
        i = i + 1
    end 'insert'

    if s.capacity() <= initialCap 'grew'
        return 1
    end 'grew'

    if s.count() != 15 'count'
        return 2
    end 'count'

    return 0
end 'main'

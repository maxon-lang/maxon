// Test: nil-coalescing.nil-coalesce-has-value.1
function getOptional(hasValue bool) returns int or nil
    if hasValue 'ret'
        return 42
    end 'ret'
    return nil
end 'getOptional'

function main() returns int
    var opt = getOptional(true)
    var result = opt or 0
    return result
end 'main'
---
ExitCode: 42
---
function getOptional() -> ptr {
entry:
    %tmp_param = param ptr 0
    %hasValue = param i64 1
    %hasValue.1 = alloca ptr
    store %hasValue.1 %hasValue
    %tmp_load = load i64 %hasValue.1
    br.cond %tmp_load @block1 @block2
then:
    %tmp_const = const.i64 i64 42
    %tmp_const.1 = const.i64 i64 1
    store %tmp_param %tmp_const.1
    %tmp_fieldptr = getfieldptr ptr %tmp_param 8
    store %tmp_fieldptr %tmp_const
    ret %tmp_param
end:
    %tmp_const.2 = const.i64 i64 0
    store %tmp_param %tmp_const.2
    ret %tmp_param
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 1
    %tmp_call = call ptr @getOptional(%tmp_alloca, %tmp_const)
    %opt = alloca ptr
    store %opt %tmp_alloca
    %tmp_load = load ptr %opt
    %tmp_const.1 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const.2 = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.2
    br.cond %tmp_icmp @block1 @block2
or_has_value:
    %tmp_fieldptr = getfieldptr ptr %tmp_load 8
    %tmp_load.2 = load i64 %tmp_fieldptr
    store %tmp_alloca.2 %tmp_load.2
    br @block3
or_default:
    store %tmp_alloca.2 %tmp_const.1
    br @block3
or_merge:
    %tmp_load.3 = load i64 %tmp_alloca.2
    %result = alloca ptr
    store %result %tmp_load.3
    %tmp_load.4 = load i64 %result
    ret %tmp_load.4
}

---

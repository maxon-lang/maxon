// Test: arithmetic-operators.complex-expression.1
function main() returns int
    var a = 10
    var b = 3
    var result = (a + b) * 2 - trunc(a / b)
    return result
end 'main'
---
ExitCode: 23
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 3
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_const.2 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_add %tmp_const.2
    %tmp_load.2 = load i64 %a
    %tmp_load.3 = load i64 %b
    %tmp_sitofp = sitofp f64 %tmp_load.2
    %tmp_sitofp.1 = sitofp f64 %tmp_load.3
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %tmp_sub = sub i64 %tmp_mul %tmp_fptosi
    %result = alloca ptr
    store %result %tmp_sub
    %tmp_load.4 = load i64 %result
    ret %tmp_load.4
}


// Test: arithmetic-operators.trunc-division-optimizes.1
function main() returns int
    return trunc(20 / 3)     // Optimized to sdiv, returns 6
end 'main'
---
ExitCode: 6
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 20
    %tmp_const.1 = const.i64 i64 3
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_sitofp.1 = sitofp f64 %tmp_const.1
    %tmp_fdiv = fdiv f64 %tmp_sitofp %tmp_sitofp.1
    %tmp_fptosi = fptosi i64 %tmp_fdiv
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_fptosi
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

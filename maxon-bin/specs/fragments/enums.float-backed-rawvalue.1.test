// Test: enums.float-backed-rawvalue.1
enum Weights
    light = 1.5
    medium = 2.5
    heavy = 3.5
end 'Weights'

function main() returns int
    var w = Weights.medium
    var rawVal = w.rawValue
    if rawVal > 2.0 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 2.5
    %tmp_bitcast = bitcast.f64.i64 i64 %tmp_fconst
    %w = alloca ptr
    store %w %tmp_bitcast
    %tmp_load = load i64 %w
    %tmp_bitcast.1 = bitcast.i64.f64 f64 %tmp_load
    %rawVal = alloca ptr
    store %rawVal %tmp_bitcast.1
    %tmp_load.1 = load f64 %rawVal
    %tmp_fconst.1 = const.f64 f64 2
    %tmp_fcmp = fcmp.gt i64 %tmp_load.1 %tmp_fconst.1
    br.cond %tmp_fcmp @block1 @block2
then:
    %tmp_const = const.i64 i64 1
    ret %tmp_const
end:
    %tmp_const.1 = const.i64 i64 0
    ret %tmp_const.1
}

---

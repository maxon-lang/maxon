// Test: string-interpolation.stringable-format-spec.1
type Counter is Stringable
    var value int

    function Stringable.toString(format String or nil) returns String
        if let fmt = format 'unwrap'
            if fmt == "verbose" 'verbose'
                return "Counter(value={value})"
            end 'verbose'
        end 'unwrap'
        return "{value}"
    end 'toString'
end 'Counter'

function main() returns int
    var c = Counter{value: 42}
    print("{c}")
    print("{c:verbose}")
    return 0
end 'main'
---
ExitCode: 0
Stdout: ```
42
Counter(value=42)
```

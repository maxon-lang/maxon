// Test: type-methods.type-method-with-params.1
type Adder
    var total int

    function add(value int)
        total = total + value
    end 'add'

    function getTotal() returns int
        return total
    end 'getTotal'
end 'Adder'

function main() returns int
    var a = Adder{total: 0}
    a.add(10)
    a.add(32)
    return a.getTotal()
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %a = alloca.sized ptr 8
    memset %a 0 8
    %tmp_fieldptr = getfieldptr ptr %a 0
    %tmp_const = const.i64 i64 0
    store %tmp_fieldptr %tmp_const
    %tmp_const.1 = const.i64 i64 10
    call @Adder$add(%a, %tmp_const.1)
    %tmp_const.3 = const.i64 i64 32
    call @Adder$add(%a, %tmp_const.3)
    %tmp_call = call i64 @Adder$getTotal(%a)
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_call
    %tmp_load = load i64 %tmp_alloca.1
    ret %tmp_load
}

function Adder$add() -> void {
entry:
    %self = param ptr 0
    %value = param i64 1
    %value.1 = alloca ptr
    store %value.1 %value
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_load.1 = load i64 %value.1
    %tmp_add = add i64 %tmp_load %tmp_load.1
    %tmp_fieldptr.1 = getfieldptr ptr %self 0
    store %tmp_fieldptr.1 %tmp_add
    ret
}

function Adder$getTotal() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca
    ret %tmp_load.1
}

---

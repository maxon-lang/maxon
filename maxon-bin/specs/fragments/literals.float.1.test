// Test: literals.float.1
function main() returns int
    var x = 3.14
    return trunc(x)
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 3.14
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_load = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}


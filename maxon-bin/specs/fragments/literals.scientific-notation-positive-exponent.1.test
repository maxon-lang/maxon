// Test: literals.scientific-notation-positive-exponent.1
function main() returns int
    var x = 1.5e2
    return trunc(x) - 140
end 'main'
---
ExitCode: 10
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 150
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_load = load f64 %x
    %tmp_fptosi = fptosi i64 %tmp_load
    %tmp_const = const.i64 i64 140
    %tmp_sub = sub i64 %tmp_fptosi %tmp_const
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_sub
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}


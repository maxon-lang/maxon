// Test: abs.abs.zero.1
function main() returns int
    var x = abs(0.0)
    if x == 0.0 'check'
        return 0
    end 'check'
    return 1
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 0
    %tmp_fabs = fabs f64 %tmp_fconst
    %x = alloca ptr
    store %x %tmp_fabs
    %tmp_load = load f64 %x
    %tmp_fconst.1 = const.f64 f64 0
    %tmp_fcmp = fcmp.eq i64 %tmp_load %tmp_fconst.1
    br.cond %tmp_fcmp @block1 @block2
then:
    %tmp_const = const.i64 i64 0
    ret %tmp_const
end:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
}

---

// Test: int-type.basic-int.1
function main() returns int
    var x = 42
    return x
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 42
    %x = alloca ptr
    store %x %tmp_const
    %tmp_load = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}


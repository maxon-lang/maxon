// Test: while-loops.nested-control.1
function main() returns int
    var result = 0
    var i = 0
    while i < 3 'outer'
        var j = 0
        while j < 3 'inner'
            if (i + j) mod 2 == 0 'even'
                result = result + 1
            end 'even'
            j = j + 1
        end 'inner'
        i = i + 1
    end 'outer'
    return result
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %result = alloca ptr
    store %result %tmp_const
    %tmp_const.1 = const.i64 i64 0
    %i = alloca ptr
    store %i %tmp_const.1
    br @block1
whilecond:
    %tmp_load = load i64 %i
    %tmp_const.2 = const.i64 i64 3
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.2
    %j = br.cond %tmp_icmp @block2
whilebody:
    %tmp_const.3 = const.i64 i64 0
    %j = alloca ptr
    store %j %tmp_const.3
    br @block3
whilecond:
    %tmp_load.1 = load i64 %j
    %tmp_const.4 = const.i64 i64 3
    %tmp_icmp.1 = icmp.lt i64 %tmp_load.1 %tmp_const.4
    %tmp_const.3 = br.cond %tmp_icmp.1 @block4
whilebody:
    %tmp_load.2 = load i64 %i
    %tmp_load.3 = load i64 %j
    %tmp_add = add i64 %tmp_load.2 %tmp_load.3
    %tmp_const.5 = const.i64 i64 2
    %tmp_mod = mod i64 %tmp_add %tmp_const.5
    %tmp_const.6 = const.i64 i64 0
    %tmp_icmp.2 = icmp.eq i64 %tmp_mod %tmp_const.6
    %tmp_icmp = br.cond %tmp_icmp.2 @block5
then:
    %tmp_load.4 = load i64 %result
    %tmp_const.7 = const.i64 i64 1
    %tmp_add.1 = add i64 %tmp_load.4 %tmp_const.7
    store %result %tmp_add.1
    br @block6
end:
    %tmp_load.5 = load i64 %j
    %tmp_const.8 = const.i64 i64 1
    %tmp_add.2 = add i64 %tmp_load.5 %tmp_const.8
    store %j %tmp_add.2
    br @block3
whilecont:
    %tmp_load.6 = load i64 %i
    %tmp_const.9 = const.i64 i64 1
    %tmp_add.3 = add i64 %tmp_load.6 %tmp_const.9
    store %i %tmp_add.3
    br @block1
whilecont:
    %tmp_load.7 = load i64 %result
    ret %tmp_load.7
}


// Test: exp.int-promotion.1
function main() returns int
    var result = Math.exp(3)  // Int promoted to float
    return trunc(result)
end 'main'
---
ExitCode: 20
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 3
    %tmp_sitofp = sitofp f64 %tmp_const
    %tmp_call = call f64 @Math$exp(%tmp_sitofp)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_fptosi
    %tmp_load.1 = load i64 %tmp_alloca.1
    ret %tmp_load.1
}

---

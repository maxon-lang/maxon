// Test: challenge-array-of-structs.array-of-structs-indexed-access.1
type Pair
    var first int
    var second int
end 'Pair'

function main() returns int
    var p = Pair{first: 10, second: 20}
    var arr = [p]
    if let elem = arr[0] 'get'
        return elem.first + elem.second
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %p = alloca.sized ptr 16
    memset %p 0 16
    %tmp_fieldptr = getfieldptr ptr %p 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %tmp_fieldptr.1 = getfieldptr ptr %p 8
    %tmp_const.1 = const.i64 i64 20
    store %tmp_fieldptr.1 %tmp_const.1
    %arr = alloca.sized ptr 8
    %tmp_const.2 = const.i64 i64 0
    %7 = getelemptr ptr %arr %tmp_const.2 elemsize=8
    store %7 %p
    %tmp_const.3 = const.i64 i64 0
    %tmp_const.4 = const.i64 i64 1
    %tmp_alloca.2 = alloca.sized ptr 16
    %tmp_const.5 = const.i64 i64 0
    %tmp_icmp = icmp.ge i64 %tmp_const.3 %tmp_const.5
    %tmp_icmp.1 = icmp.lt i64 %tmp_const.3 %tmp_const.4
    %tmp_mul = mul i64 %tmp_icmp %tmp_icmp.1
    br.cond %tmp_mul @block1 @block2
index_in_bounds:
    %tmp_const.6 = const.i64 i64 1
    store %tmp_alloca.2 %tmp_const.6
    %16 = getelemptr ptr %arr %tmp_const.3 elemsize=8
    %tmp_load = load ptr %16
    %tmp_fieldptr.2 = getfieldptr ptr %tmp_alloca.2 8
    store %tmp_fieldptr.2 %tmp_load
    br @block3
index_out_of_bounds:
    %tmp_const.7 = const.i64 i64 0
    store %tmp_alloca.2 %tmp_const.7
    br @block3
index_merge:
    %tmp_load.1 = load i64 %tmp_alloca.2
    %tmp_const.8 = const.i64 i64 1
    %tmp_icmp.2 = icmp.eq i64 %tmp_load.1 %tmp_const.8
    br.cond %tmp_icmp.2 @block4 @block5
if_let_then:
    %tmp_fieldptr.3 = getfieldptr ptr %tmp_alloca.2 8
    %tmp_load.2 = load ptr %tmp_fieldptr.3
    %elem = alloca ptr
    store %elem %tmp_load.2
    %tmp_load.3 = load ptr %elem
    %tmp_fieldptr.4 = getfieldptr ptr %tmp_load.3 0
    %tmp_load.4 = load i64 %tmp_fieldptr.4
    %tmp_load.5 = load ptr %elem
    %tmp_fieldptr.5 = getfieldptr ptr %tmp_load.5 8
    %tmp_load.6 = load i64 %tmp_fieldptr.5
    %tmp_add = add i64 %tmp_load.4 %tmp_load.6
    ret %tmp_add
if_let_else:
    %tmp_const.9 = const.i64 i64 0
    ret %tmp_const.9
if_let_end:
}


// Test: challenge-array-of-structs.array-of-structs-indexed-access.1
type Pair
    var first int
    var second int
end 'Pair'

function main() returns int
    var p = Pair{first: 10, second: 20}
    var arr = [p]
    if let elem = arr[0] 'get'
        return elem.first + elem.second
    end 'get' else 'nil'
        return 0
    end 'nil'
end 'main'

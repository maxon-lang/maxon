// Test: pow.doc-example-1.1
function main() returns int
    var result = pow(2.0, 3.0)  // 2^3 = 8
    return trunc(result)
end 'main'
---
ExitCode: 8
---
function main() -> i64 {
entry:
    %tmp_fconst = const.f64 f64 2
    %tmp_fconst.1 = const.f64 f64 3
    %tmp_call = call f64 @pow(%tmp_fconst, %tmp_fconst.1)
    %result = alloca ptr
    store %result %tmp_call
    %tmp_load = load f64 %result
    %tmp_fptosi = fptosi i64 %tmp_load
    ret %tmp_fptosi
}

---

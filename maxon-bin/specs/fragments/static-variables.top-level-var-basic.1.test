// Test: static-variables.top-level-var-basic.1
var counter = 0

function main() returns int
    counter = 42
    return counter
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 0
    %tmp_globaladdr = global.addr ptr @global.counter elemsize=8
    store %tmp_globaladdr %tmp_const
    %tmp_const.1 = const.i64 i64 42
    %tmp_globaladdr.1 = global.addr ptr @global.counter elemsize=8
    store %tmp_globaladdr.1 %tmp_const.1
    %tmp_globaladdr.2 = global.addr ptr @global.counter elemsize=8
    %tmp_load = load i64 %tmp_globaladdr.2
    ret %tmp_load
}

---

// Test: ownership.multiple-assignments.1
function main() returns int
    var a = 1
    var b = 2
    a = a + b
    b = a + b
    return b
end 'main'
---
ExitCode: 5
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 1
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 2
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_load %tmp_load.1
    store %a %tmp_add
    %tmp_load.2 = load i64 %a
    %tmp_load.3 = load i64 %b
    %tmp_add.1 = add i64 %tmp_load.2 %tmp_load.3
    store %b %tmp_add.1
    %tmp_load.4 = load i64 %b
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.4
    %tmp_load.5 = load i64 %tmp_alloca.2
    ret %tmp_load.5
}


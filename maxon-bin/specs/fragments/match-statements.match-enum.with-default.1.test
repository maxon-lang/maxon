// Test: match-statements.match-enum.with-default.1
enum Color
    red
    green
    blue
end 'Color'

function main() returns int
    var c = Color.blue
    match c 'check'
        Color.red then return 1
        default then return 0
    end 'check'
end 'main'
---
ExitCode: 0
---
function main() -> i64 {
entry_0:
    %tmp_const = const.i64 i64 2
    %c = alloca ptr
    store %c %tmp_const
    %tmp_load.1 = load i64 %c
    br @match_check_1
match_check_1:
    %tmp_const.2 = const.i64 i64 0
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const.2
    br.cond %tmp_icmp @match_body_2 @match_default_3
match_body_2:
    %tmp_const.3 = const.i64 i64 1
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_const.3
    %tmp_load.2 = load i64 %tmp_alloca.1
    ret %tmp_load.2
match_default_3:
    %tmp_const.4 = const.i64 i64 0
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_const.4
    %tmp_load.3 = load i64 %tmp_alloca.2
    ret %tmp_load.3
match_merge_4:
}


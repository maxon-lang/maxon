// Test: string-type.heap-string-endsWith.1
function main() returns int
    var s = "This is a very long string that is heap allocated"
    if s.endsWith("heap allocated") 'c19'
        print("{1}\n")
    end 'c19'
    if s.endsWith("stack allocated") 'c20'
        print("{0}\n")
    end 'c20'
    return 0
end 'main'

// Test: break.break.labeled-break-outer.1
function main() returns int
    var x = 0
    while x < 10 'outer'
        x = x + 1
        while true 'inner'
            if x == 3 'check'
                break 'outer'
            end 'check'
            break 'inner'
        end 'inner'
    end 'outer'
    return x
end 'main'
---
ExitCode: 3
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 0
    %x = alloca ptr
    store %x %tmp_const
    br @block1
whilecond:
    %tmp_load = load i64 %x
    %tmp_const.1 = const.i64 i64 10
    %tmp_icmp = icmp.lt i64 %tmp_load %tmp_const.1
    br.cond %tmp_icmp @block2 @block8
whilebody:
    %tmp_load.1 = load i64 %x
    %tmp_const.2 = const.i64 i64 1
    %tmp_add = add i64 %tmp_load.1 %tmp_const.2
    store %x %tmp_add
    br @block3
whilecond:
    %tmp_const.3 = const.i64 i64 1
    br.cond %tmp_const.3 @block4 @block7
whilebody:
    %tmp_load.2 = load i64 %x
    %tmp_const.4 = const.i64 i64 3
    %tmp_icmp.1 = icmp.eq i64 %tmp_load.2 %tmp_const.4
    br.cond %tmp_icmp.1 @block5 @block6
then:
    br @block8
    br @block6
end:
    br @block7
whilecont:
    br @block1
whilecont:
    %tmp_load.3 = load i64 %x
    %tmp_alloca.1 = alloca ptr
    store %tmp_alloca.1 %tmp_load.3
    %tmp_load.4 = load i64 %tmp_alloca.1
    ret %tmp_load.4
}

---

// Test: match-statements.doc-example-9.1
function main() returns int
    var temp = 25
    let category = match temp 'weather'
        ..<0 gives 1      // freezing
        0..<15 gives 2    // cold  
        15..<25 gives 3   // mild
        25.. gives 4      // warm
    end 'weather'
    return category
end 'main'

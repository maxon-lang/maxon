// Test: command-line-args.iterate-args.1
function main(args Array of String) returns int
    var i = 1
    while i < args.count() 'loop'
        var arg = try args.get(i) otherwise ""
        print(arg)
        print("\n")
        i = i + 1
    end 'loop'
    return 0
end 'main'

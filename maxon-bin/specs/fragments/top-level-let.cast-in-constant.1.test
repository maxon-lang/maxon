// Test: top-level-let.cast-in-constant.1
let OFFSET = 10
let SCALED = OFFSET * 3

function main() returns int
    return SCALED
end 'main'
---
ExitCode: 30
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 30
    %tmp_alloca = alloca ptr
    store %tmp_alloca %tmp_const
    %tmp_load = load i64 %tmp_alloca
    ret %tmp_load
}

---

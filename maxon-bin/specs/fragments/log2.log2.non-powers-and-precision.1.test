// Test: log2.log2.non-powers-and-precision.1
function main() returns int
    // Non-powers of 2 require high precision
    var r3 = Math.log2(3.0)
    var r5 = Math.log2(5.0)
    var r6 = Math.log2(6.0)
    var r1000000 = Math.log2(1000000.0)
    
    print("{r3}\n")
    print("{r5}\n")
    print("{r6}\n")
    print("{r1000000}\n")
    
    return 0
end 'main'

// Test: expressions.mixed-operators.1
function main() returns int
    var a = 10
    var b = 3
    return a * 2 + b - 1
end 'main'
---
ExitCode: 22
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 10
    %a = alloca ptr
    store %a %tmp_const
    %tmp_const.1 = const.i64 i64 3
    %b = alloca ptr
    store %b %tmp_const.1
    %tmp_load = load i64 %a
    %tmp_const.2 = const.i64 i64 2
    %tmp_mul = mul i64 %tmp_load %tmp_const.2
    %tmp_load.1 = load i64 %b
    %tmp_add = add i64 %tmp_mul %tmp_load.1
    %tmp_const.3 = const.i64 i64 1
    %tmp_sub = sub i64 %tmp_add %tmp_const.3
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_sub
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---

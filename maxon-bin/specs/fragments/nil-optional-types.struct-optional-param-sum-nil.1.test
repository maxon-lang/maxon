// Test: nil-optional-types.struct-optional-param-sum-nil.1
type Point
    export var x int
    export var y int
end 'Point'

function sumCoords(p Point or nil) returns int
    if let pt = p 'hasPoint'
        return pt.x + pt.y
    end 'hasPoint' else 'noPoint'
        return 99
    end 'noPoint'
end 'sumCoords'

function main() returns int
    return sumCoords(nil)
end 'main'
---
ExitCode: 99
---
function sumCoords() -> i64 {
entry:
    %tmp_param = param ptr 0
    %p = alloca ptr
    store %p %tmp_param
    %tmp_load = load ptr %p
    %tmp_load.1 = load i64 %tmp_load
    %tmp_const = const.i64 i64 1
    %tmp_icmp = icmp.eq i64 %tmp_load.1 %tmp_const
    br.cond %tmp_icmp @block1 @block2
if_let_then:
    %pt = getfieldptr ptr %tmp_load 8
    %tmp_fieldptr.1 = getfieldptr ptr %pt 0
    %tmp_load.2 = load i64 %tmp_fieldptr.1
    %tmp_fieldptr.2 = getfieldptr ptr %pt 8
    %tmp_load.3 = load i64 %tmp_fieldptr.2
    %tmp_add = add i64 %tmp_load.2 %tmp_load.3
    ret %tmp_add
if_let_else:
    %tmp_const.1 = const.i64 i64 99
    ret %tmp_const.1
if_let_end:
}

function main() -> i64 {
entry:
    %tmp_alloca = alloca.sized ptr 16
    %tmp_const = const.i64 i64 0
    store %tmp_alloca %tmp_const
    %tmp_call = call i64 @sumCoords(%tmp_alloca)
    ret %tmp_call
}

---

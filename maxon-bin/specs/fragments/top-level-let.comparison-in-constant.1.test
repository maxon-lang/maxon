// Test: top-level-let.comparison-in-constant.1
let IS_LARGE = 100 > 50

function main() returns int
    if IS_LARGE 'check'
        return 1
    end 'check'
    return 0
end 'main'
---
ExitCode: 1
---
function main() -> i64 {
entry:
    %tmp_const = const.i64 i64 1
    br.cond %tmp_const @block1 @block2
then:
    %tmp_const.1 = const.i64 i64 1
    ret %tmp_const.1
end:
    %tmp_const.2 = const.i64 i64 0
    ret %tmp_const.2
}


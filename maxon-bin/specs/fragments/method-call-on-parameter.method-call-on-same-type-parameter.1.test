// Test: method-call-on-parameter.method-call-on-same-type-parameter.1
type Foo
    var x int
    
    function bar() returns int
        return x
    end 'bar'
    
    function callBarOn(other Foo) returns int
        return other.bar()
    end 'callBarOn'
end 'Foo'

function main() returns int
    var f1 = Foo{x: 10}
    var f2 = Foo{x: 42}
    return f1.callBarOn(f2)
end 'main'
---
ExitCode: 42
---
function main() -> i64 {
entry:
    %f1 = alloca.sized ptr 8
    memset %f1 0 8
    %tmp_fieldptr = getfieldptr ptr %f1 0
    %tmp_const = const.i64 i64 10
    store %tmp_fieldptr %tmp_const
    %f2 = alloca.sized ptr 8
    memset %f2 0 8
    %tmp_fieldptr.1 = getfieldptr ptr %f2 0
    %tmp_const.1 = const.i64 i64 42
    store %tmp_fieldptr.1 %tmp_const.1
    %tmp_call = call i64 @Foo$callBarOn(%f1, %f2)
    ret %tmp_call
}

function Foo$bar() -> i64 {
entry:
    %self = param ptr 0
    %tmp_fieldptr = getfieldptr ptr %self 0
    %tmp_load = load i64 %tmp_fieldptr
    ret %tmp_load
}

function Foo$callBarOn() -> i64 {
entry:
    %other = param ptr 1
    %tmp_call = call i64 @Foo$bar(%other)
    ret %tmp_call
}

---

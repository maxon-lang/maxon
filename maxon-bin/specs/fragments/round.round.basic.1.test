// Test: round.round.basic.1
function main() returns int
    var x = 3.7
    var y = round(x)
    return y
end 'main'
---
ExitCode: 4
---
function main() -> i64 {
entry_0:
    %tmp_fconst = const.f64 f64 3.7
    %x = alloca ptr
    store %x %tmp_fconst
    %tmp_load = load f64 %x
    %tmp_fround = fround i64 %tmp_load
    %y = alloca ptr
    store %y %tmp_fround
    %tmp_load.1 = load i64 %y
    %tmp_alloca.2 = alloca ptr
    store %tmp_alloca.2 %tmp_load.1
    %tmp_load.2 = load i64 %tmp_alloca.2
    ret %tmp_load.2
}

---
